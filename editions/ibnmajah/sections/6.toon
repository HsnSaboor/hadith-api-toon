hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
1167,"حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْحَارِثِ، عَنْ عَلِيٍّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لِلْمُسْلِمِ عَلَى الْمُسْلِمِ سِتَّةٌ بِالْمَعْرُوفِ يُسَلِّمُ عَلَيْهِ إِذَا لَقِيَهُ وَيُجِيبُهُ إِذَا دَعَاهُ وَيُشَمِّتُهُ إِذَا عَطَسَ وَيَعُودُهُ إِذَا مَرِضَ وَيَتْبَعُ جِنَازَتَهُ إِذَا مَاتَ وَيُحِبُّ لَهُ مَا يُحِبُّ لِنَفْسِهِ ‏""""‏ ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الصلاة ۲۰۵ (۴۳۵)،(تحفة الأشراف:۱۵۴۱۲),,It was\nnarrated that ‘Ali said that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1168,"حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ وَمُحَمَّدُ بْنُ بَشَّارٍ قَالاَ حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ جَعْفَرٍ، عَنْ أَبِيهِ، عَنْ حَكِيمِ بْنِ أَفْلَحَ، عَنْ أَبِي مَسْعُودٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لِلْمُسْلِمِ عَلَى الْمُسْلِمِ أَرْبَعُ خِلاَلٍ يُشَمِّتُهُ إِذَا عَطَسَ وَيُجِيبُهُ إِذَا دَعَاهُ وَيَشْهَدُهُ إِذَا مَاتَ وَيَعُودُهُ إِذَا مَرِضَ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الصلاة ۳۳۶ (۱۴۱۸)، سنن الترمذی/الصلاة۲۱۵ (۴۵۲)،(تحفة الأشراف:۳۴۵۰)، وقد أخرجہ: سنن الدارمی/الصلاة ۲۰۸ (۱۶۱۷),,It was\nnarrated from Abu Mas’ud that the Prophet (ﷺ) said:,Chapters Regarding Funerals
1169,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ خَمْسٌ مِنْ حَقِّ الْمُسْلِمِ عَلَى الْمُسْلِمِ رَدُّ التَّحِيَّةِ وَإِجَابَةُ الدَّعْوَةِ وَشُهُودُ الْجِنَازَةِ وَعِيَادَةُ الْمَرِيضِ وَتَشْمِيتُ الْعَاطِسِ إِذَا حَمِدَ اللَّهَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الصلاة ۳۳۶ (۱۴۱۶)، سنن الترمذی/الصلاة ۲۱۶ (۴۵۳)، سنن النسائی/قیام اللیل ۲۷ (۱۶۷۶)،(تحفة الأشراف:۱۰۱۳۵)، وقد أخرجہ: مسند احمد (۱/۱۰۰،۱۱۰،۱۴۳،۱۴۴،۱۴۸)، سنن الدارمی/الصلاة ۲۰۹ (۱۶۲۱),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1170,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الأَعْلَى الصَّنْعَانِيُّ، حَدَّثَنَا سُفْيَانُ، قَالَ سَمِعْتُ مُحَمَّدَ بْنَ الْمُنْكَدِرِ، يَقُولُ سَمِعْتُ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ عَادَنِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ مَاشِيًا وَأَبُو بَكْرٍ وَأَنَا فِي بَنِي سَلِمَةَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الصلاة ۳۳۶ (۱۴۱۷)،(تحفة الأشراف:۹۶۲۷),1170,Jabir\nbin ‘Abdullah said:,Chapters Regarding Funerals
1171,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا مَسْلَمَةُ بْنُ عُلَىٍّ، حَدَّثَنَا ابْنُ جُرَيْجٍ، عَنْ حُمَيْدٍ الطَّوِيلِ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ لاَ يَعُودُ مَرِيضًا إِلاَّ بَعْدَ ثَلاَثٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الصلاة ۳۳۹ (۱۴۲۳)، سنن النسائی/قیام اللیل ۳۴ (۱۷۰۰)،(تحفة الأشراف:۵۴)،(یہ حدیث مکرر ہے، دیکھئے:۱۱۸۲),1171,It was\nnarrated that Anas bin Malik said:,Chapters Regarding Funerals
1172,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عُقْبَةُ بْنُ خَالِدٍ السَّكُونِيُّ، عَنْ مُوسَى بْنِ مُحَمَّدِ بْنِ إِبْرَاهِيمَ التَّيْمِيِّ، عَنْ أَبِيهِ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا دَخَلْتُمْ عَلَى الْمَرِيضِ فَنَفِّسُوا لَهُ فِي الأَجَلِ فَإِنَّ ذَلِكَ لاَ يَرُدُّ شَيْئًا وَهُوَ يَطِيبُ بِنَفْسِ الْمَرِيضِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن الترمذی/الصلاة ۲۲۳ (۴۶۲)، سنن النسائی/قیام اللیل ۳۴ (۱۷۰۳)،(تحفة الأشراف:۵۵۸۷)، وقد أخرجہ: مسند احمد (۱/۳۷۲)، سنن الدارمی/الصلاة ۲۱۲ (۱۶۲۷،۱۶۳۰),,It was\nnarrated from Abu Sa’eed Al-Khudri that the Messenger of Allah\n(ﷺ) said:,Chapters Regarding Funerals
1173,"حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا صَفْوَانُ بْنُ هُبَيْرَةَ، حَدَّثَنَا أَبُو مَكِينٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ عَادَ رَجُلاً فَقَالَ ‏""‏ مَا تَشْتَهِي ‏""‏ ‏.‏ قَالَ أَشْتَهِي خُبْزَ بُرٍّ ‏.‏ قَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ مَنْ كَانَ عِنْدَهُ خُبْزُ بُرٍّ فَلْيَبْعَثْ إِلَى أَخِيهِ ‏""‏ ثُمَّ قَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ إِذَا اشْتَهَى مَرِيضُ أَحَدِكُمْ شَيْئًا فَلْيُطْعِمْهُ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الصلاة ۳۳۹ (۱۴۲۴)، سنن الترمذی/الصلاة ۲۲۳ (۴۶۳)،(تحفة الأشراف:۱۶۳۰۶)وقد أخرجہ: مسند احمد (۶/ ۲۲۷),1173,It was\nnarrated from Ibn ‘Abbas that the Prophet (ﷺ) visited a man\nand\nsaid:,Chapters Regarding Funerals
1174,"حَدَّثَنَا سُفْيَانُ بْنُ وَكِيعٍ، حَدَّثَنَا أَبُو يَحْيَى الْحِمَّانِيُّ، عَنِ الأَعْمَشِ، عَنْ يَزِيدَ الرَّقَاشِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ دَخَلَ النَّبِيُّ ـ صلى الله عليه وسلم ـ عَلَى مَرِيضٍ يَعُودُهُ فَقَالَ ‏ ‏ أَتَشْتَهِي شَيْئًا أَتَشْتَهِي كَعْكًا ‏""""‏ ‏.‏ قَالَ نَعَمْ ‏.‏ فَطَلَبُوا لَهُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: صحیح البخاری/الوتر۱ (۹۹۵)، صحیح مسلم/المسافرین۲۰ (۷۴۹)، سنن الترمذی/الصلاة ۲۲۲ (۴۶۱)،(تحفة الأشراف:۶۶۵۲،۷۲۶۷)، وقد أخرجہ: سنن ابی داود/الصلاة ۳۳۸ (۱۴۲۱)، سنن النسائی/قیام اللیل۳۴ (۱۶۹۰)، موطا امام مالک/صلاة اللیل ۳ (۱۳)، مسند احمد (۲/۳۳،۴۳،۴۵،۴۹،۵۱،۵۴،۸۱،۸۳،۱۵۴)، سنن الدارمی/الصلاة ۱۵۴ (۱۴۹۹)،۱۵۵ (۱۵۰۰),,It was\nnarrated that Anas bin Malik said:,Chapters Regarding Funerals
1175,"حَدَّثَنَا جَعْفَرُ بْنُ مُسَافِرٍ، حَدَّثَنِي كَثِيرُ بْنُ هِشَامٍ، حَدَّثَنَا جَعْفَرُ بْنُ بُرْقَانَ، عَنْ مَيْمُونِ بْنِ مِهْرَانَ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، قَالَ قَالَ لِي النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا دَخَلْتَ عَلَى مَرِيضٍ فَمُرْهُ أَنْ يَدْعُوَ لَكَ فَإِنَّ دُعَاءَهُ كَدُعَاءِ الْمَلاَئِكَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۵۶۰),,It was\nnarrated that ‘Umar bin Al-Khattab said:,Chapters Regarding Funerals
1176,"حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنَا الأَعْمَشُ، عَنِ الْحَكَمِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، عَنْ عَلِيٍّ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَنْ أَتَى أَخَاهُ الْمُسْلِمَ عَائِدًا مَشَى فِي خِرَافَةِ الْجَنَّةِ حَتَّى يَجْلِسَ فَإِذَا جَلَسَ غَمَرَتْهُ الرَّحْمَةُ فَإِنْ كَانَ غُدْوَةً صَلَّى عَلَيْهِ سَبْعُونَ أَلْفَ مَلَكٍ حَتَّى يُمْسِيَ وَإِنْ كَانَ مَسَاءً صَلَّى عَلَيْهِ سَبْعُونَ أَلْفَ مَلَكٍ حَتَّى يُصْبِحَ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۴۵۹، ومصباح الزجاجة:۴۱۵),,It was\nnarrated that ‘Ali said:,Chapters Regarding Funerals
1177,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يُوسُفُ بْنُ يَعْقُوبَ، حَدَّثَنَا أَبُو سِنَانٍ الْقَسْمَلِيُّ، عَنْ عُثْمَانَ بْنِ أَبِي سَوْدَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ عَادَ مَرِيضًا نَادَى مُنَادٍ مِنَ السَّمَاءِ طِبْتَ وَطَابَ مَمْشَاكَ وَتَبَوَّأْتَ مِنَ الْجَنَّةِ مَنْزِلاً ‏""""‏ ‏.‏""",Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تفرد بہ ابن ماجہ، (تحفة الأشراف: ۱۶۶۱۸، ومصباح الزجاجة: ۴۱۶),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1178,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنْ يَزِيدَ بْنِ كَيْسَانَ، عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لَقِّنُوا مَوْتَاكُمْ لاَ إِلَهَ إِلاَّ اللَّهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الصلاة ۳۴۰ (۱۴۲۵، ۱۴۲۶)، سنن الترمذی/الصلاة ۲۲۴ (۴۶۴)، سنن النسائی/قیام اللیل ۴۲ (۱۷۴۶)، (تحفة الأشراف: ۳۴۰۴)، وقد أخرجہ: مسند احمد (۱/۱۹۹، ۲۰۰),,It was\nnarrated that Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1179,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ سُلَيْمَانَ بْنِ بِلاَلٍ، عَنْ عُمَارَةَ بْنِ غَزِيَّةَ، عَنْ يَحْيَى بْنِ عُمَارَةَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لَقِّنُوا مَوْتَاكُمْ لاَ إِلَهَ إِلاَّ اللَّهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/الصلاة ۳۴۰ (۱۴۲۷)، سنن الترمذی/الدعوات ۱۱۳ (۳۵۶۶)،(تحفة الأشراف:۱۰۲۰۷)، وقد أخرجہ: سنن النسائی/قیام اللیل ۴۳ (۱۷۴۹)، مسند احمد (۱/۹۶،۱۱۸،۱۵۰),,It was\nnarrated that Abu Sa’eed Al-Khudri said:,Chapters Regarding Funerals
1180,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو عَامِرٍ، حَدَّثَنَا كَثِيرُ بْنُ زَيْدٍ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللَّهِ بْنِ جَعْفَرٍ، عَنْ أَبِيهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ لَقِّنُوا مَوْتَاكُمْ لاَ إِلَهَ إِلاَّ اللَّهُ الْحَلِيمُ الْكَرِيمُ سُبْحَانَ اللَّهِ رَبِّ الْعَرْشِ الْعَظِيمِ الْحَمْدُ لِلَّهِ رَبِّ الْعَالَمِينَ ‏""‏ ‏.‏ قَالُوا يَا رَسُولَ اللَّهِ كَيْفَ لِلأَحْيَاءِ قَالَ ‏""‏ أَجْوَدُ وَأَجْوَدُ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الاستسسقاء ۲۲ (۱۰۳۱)المناقب ۲۳ (۳۵۶۵)، الدعوات ۲۳ (۶۳۴۱)، صحیح مسلم/الاستسقاء ۱ (۸۹۵)، سنن ابی داود/الصلاة۲۶۰ (۱۷۷۰)، قیام اللیل ۴۳ (۱۷۴۹)،(تحفة الأشراف:۱۱۶۸)، وقد أخرجہ: سنن النسائی/الاستسقاء ۹ (۱۵۱۲)، مسند احمد (۳/۲۸۲)، سنن الدارمی/الصلاة ۱۸۹ (۱۵۷۶),1180,It was\nnarrated from Ishaq bin ‘Abdullah bin Ja’far that his father\nsaid:,Chapters Regarding Funerals
1181,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ شَقِيقٍ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ إِذَا حَضَرْتُمُ الْمَرِيضَ أَوِ الْمَيِّتَ فَقُولُوا خَيْرًا فَإِنَّ الْمَلاَئِكَةَ يُؤَمِّنُونَ عَلَى مَا تَقُولُونَ ‏""‏ ‏.‏ فَلَمَّا مَاتَ أَبُو سَلَمَةَ أَتَيْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَقُلْتُ يَا رَسُولَ اللَّهِ إِنَّ أَبَا سَلَمَةَ قَدْ مَاتَ ‏.‏ قَالَ ‏""‏ قُولِي اللَّهُمَّ اغْفِرْ لِي وَلَهُ وَأَعْقِبْنِي مِنْهُ عُقْبَى حَسَنَةً ‏""‏ ‏.‏ قَالَتْ فَفَعَلْتُ فَأَعْقَبَنِي اللَّهُ مَنْ هُوَ خَيْرٌ مِنْهُ ‏.‏ مُحَمَّدٌ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الصلاة ۳۵۸،(۱۴۸۵)،(تحفة الأشراف:۶۴۴۸، ومصباح الزجاجة:۴۱۷)،(یہ حدیث مکرر ہے، دیکھئے:۳۸۶۶),1181,It was\nnarrated that Umm Salamah said:,Chapters Regarding Funerals
1182,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ الْحَسَنِ بْنِ شَقِيقٍ، عَنِ ابْنِ الْمُبَارَكِ، عَنْ سُلَيْمَانَ التَّيْمِيِّ، عَنْ أَبِي عُثْمَانَ، - وَلَيْسَ بِالنَّهْدِيِّ - عَنْ أَبِيهِ، عَنْ مَعْقِلِ بْنِ يَسَارٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اقْرَءُوهَا عِنْدَ مَوْتَاكُمْ ‏""""‏ ‏.‏ يَعْنِي ‏{يس}‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الصلاة ۳۳۹ (۱۴۲۳)، سنن النسائی/قیام اللیل ۳۴ (۱۷۰۰)،(تحفة الأشراف:۵۴)، وقد أخرجہ: مسند احمد (۵/۱۲۳),,It was\nnarrated from Ma’qil bin Yasar that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters Regarding Funerals
1183,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ، حَدَّثَنَا الْمُحَارِبِيُّ، جَمِيعًا عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنِ الْحَارِثِ بْنِ فُضَيْلٍ، عَنِ الزُّهْرِيِّ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ كَعْبِ بْنِ مَالِكٍ، عَنْ أَبِيهِ، قَالَ لَمَّا حَضَرَتْ كَعْبًا الْوَفَاةُ أَتَتْهُ أُمُّ بِشْرٍ بِنْتُ الْبَرَاءِ بْنِ مَعْرُورٍ فَقَالَتْ يَا أَبَا عَبْدِ الرَّحْمَنِ إِنْ لَقِيتَ فُلاَنًا فَاقْرَأْ عَلَيْهِ مِنِّي السَّلاَمَ ‏.‏ قَالَ غَفَرَ اللَّهُ لَكِ يَا أُمَّ بِشْرٍ نَحْنُ أَشْغَلُ مِنْ ذَلِكِ ‏.‏ قَالَتْ يَا أَبَا عَبْدِ الرَّحْمَنِ أَمَا سَمِعْتَ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ إِنَّ أَرْوَاحَ الْمُؤْمِنِينَ فِي طَيْرٍ خُضْرٍ تَعْلُقُ فِي شَجَرِ الْجَنَّةِ ‏""""‏ ‏.‏ قَالَ بَلَى ‏.‏ قَالَتْ فَهُوَ ذَاكَ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۸۷ ومصباح الزجاجة:۴۱۸)، وقد أخرجہ: صحیح البخاری/الأذان ۱۲۶ (۷۹۸)، صحیح مسلم/المساجد ۵۴ (۶۷۷)، سنن ابی داود/الصلاة ۳۴۵ (۱۴۴۴)، سنن النسائی/التطبیق ۲۷ (۱۰۷۲)، مسند احمد (۳/۲۱۷،۲۳۲)، سنن الدارمی/الصلاة ۲۱۶ (۱۶۳۷),,"It was\nnarrated from ‘Abdur-Rahman bin Ka’b bin Malik, about Ka’b:",Chapters Regarding Funerals
1184,حَدَّثَنَا أَحْمَدُ بْنُ الأَزْهَرِ، حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى، حَدَّثَنَا يُوسُفُ بْنُ الْمَاجِشُونِ، حَدَّثَنَا مُحَمَّدُ بْنُ الْمُنْكَدِرِ، قَالَ دَخَلْتُ عَلَى جَابِرِ بْنِ عَبْدِ اللَّهِ وَهُوَ يَمُوتُ فَقُلْتُ اقْرَأْ عَلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ السَّلاَمَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الوتر ۷ (۱۰۰۱)، المغازي ۲۹ (۴۰۸۹)، الدعوات ۵۸ (۶۳۹۴)، صحیح مسلم/المساجد ۵۴ (۶۷۷)، سنن ابی داود/الصلاة ۳۴۵ (۱۴۴۴)،(تحفة الأشراف:۱۴۵۳)، وقد أخرجہ: سنن النسائی/التطبیق ۲۶ (۱۰۷۱)، مسند احمد (۳/۱۱۳،۵۱۱،۱۶۶،۱۶۷),1184,Muhammad\nbin Munkadir said:,Chapters Regarding Funerals
1185,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا الأَوْزَاعِيُّ، عَنْ عَطَاءٍ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ دَخَلَ عَلَيْهَا وَعِنْدَهَا حَمِيمٌ لَهَا يَخْنُقُهُ الْمَوْتُ فَلَمَّا رَأَى النَّبِيُّ ـ صلى الله عليه وسلم ـ مَا بِهَا قَالَ لَهَا ‏ ‏ لاَ تَبْتَئِسِي عَلَى حَمِيمِكِ فَإِنَّ ذَلِكَ مِنْ حَسَنَاتِهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المسافرین ۱۷ (۷۴۵)، سنن الترمذی/الصلاة ۲۱۸ (۴۵۶)، سنن النسائی/قیام اللیل ۲۸ (۱۶۸۲)،(تحفة الأشراف:۱۷۶۵۳)، وقد أخرجہ: صحیح البخاری/الوتر ۲ (۹۹۶)، سنن ابی داود/الصلاة ۳۴۳ (۱۴۳۵)، مسند احمد (۶/۱۲۹،۲۰۴)، سنن الدارمی/الصلا ة ۲۱۱،(۱۶۲۸),,"It was\nnarrated from ‘Aishah that the Messenger of Allah (ﷺ)\nentered\nupon her and there was a close relative of hers who was in the\nthroes\nof death. When the Prophet (ﷺ) saw how upset she was, he\nsaid:",Chapters Regarding Funerals
1186,"حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنِ الْمُثَنَّى بْنِ سَعِيدٍ، عَنْ قَتَادَةَ، عَنِ ابْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ الْمُؤْمِنُ يَمُوتُ بِعَرَقِ الْجَبِينِ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۱۴۵، ومصباح الزجاجة:۹۱۴)، وقد أخرجہ: مسند احمد (۱/۷۸،۸۶،۱۰۴،۱۳۷،۱۴۳،۱۴۷),,It was\nnarrated from Abu Buraidah from his father that the Prophet\n(ﷺ)\nsaid:,Chapters Regarding Funerals
1187,"حَدَّثَنَا رَوْحُ بْنُ الْفَرَجِ، حَدَّثَنَا نَصْرُ بْنُ حَمَّادٍ، حَدَّثَنَا مُوسَى بْنُ كَرْدَمٍ، عَنْ مُحَمَّدِ بْنِ قَيْسٍ، عَنْ أَبِي بُرْدَةَ، عَنْ أَبِي مُوسَى، قَالَ سَأَلْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ مَتَى تَنْقَطِعُ مَعْرِفَةُ الْعَبْدِ مِنَ النَّاسِ قَالَ ‏ ‏ إِذَا عَايَنَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المسافرین ۲۱ (۷۵۵)، سنن الترمذی/الصلاة ۲۱۷ (۴۵۵)،(تحفة الأشراف:۲۲۹۷)، وقد أخرجہ: مسند احمد (۳/ ۳۱۵،۳۸۹),,It was\nnarrated that Abu Musa said:,Chapters Regarding Funerals
1188,"حَدَّثَنَا إِسْمَاعِيلُ بْنُ أَسَدٍ، حَدَّثَنَا مُعَاوِيَةُ بْنُ عَمْرٍو، حَدَّثَنَا أَبُو إِسْحَاقَ الْفَزَارِيُّ، عَنْ خَالِدٍ الْحَذَّاءِ، عَنْ أَبِي قِلاَبَةَ، عَنْ قَبِيصَةَ بْنِ ذُؤَيْبٍ، عَنْ أُمِّ سَلَمَةَ، قَالَتْ دَخَلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَلَى أَبِي سَلَمَةَ وَقَدْ شَقَّ بَصَرُهُ فَأَغْمَضَهُ ثُمَّ قَالَ ‏ ‏ إِنَّ الرُّوحَ إِذَا قُبِضَ تَبِعَهُ الْبَصَرُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الصلاة ۳۴۱ (۱۴۳۱)، سنن الترمذی/الصلاة ۲۲۵ (۴۶۵،۴۶۶)،(تحفة الأشراف:۴۱۶۸)، وقد أخرجہ: مسند احمد (۳/۳۱،۴۴),,It was\nnarrated that Umm Salamah said:,Chapters Regarding Funerals
1189,"حَدَّثَنَا أَبُو دَاوُدَ، سُلَيْمَانُ بْنُ تَوْبَةَ حَدَّثَنَا عَاصِمُ بْنُ عَلِيٍّ، حَدَّثَنَا قَزَعَةُ بْنُ سُوَيْدٍ، عَنْ حُمَيْدٍ الأَعْرَجِ، عَنِ الزُّهْرِيِّ، عَنْ مَحْمُودِ بْنِ لَبِيدٍ، عَنْ شَدَّادِ بْنِ أَوْسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا حَضَرْتُمْ مَوْتَاكُمْ فَأَغْمِضُوا الْبَصَرَ فَإِنَّ الْبَصَرَ يَتْبَعُ الرُّوحَ وَقُولُوا خَيْرًا فَإِنَّ الْمَلاَئِكَةَ تُؤَمِّنُ عَلَى مَا قَالَ أَهْلُ الْبَيْتِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المسافرین۲۰ (۷۵۴)، سنن الترمذی/الصلاة ۲۲۶ (۴۶۸)، سنن النسائی/قیام اللیل ۲۹ (۱۶۸۴)،(تحفة الأشراف:۴۳۸۴)، وقد أخرجہ: سنن ابی داود/الصلاة ۳۴۳ (۱۴۲۲)، مسند احمد (۳/۱۳،۳۵،۳۷،۷۱)، سنن الدارمی/الصلاة ۲۱۱ (۱۶۲۹),,It was\nnarrated from Shaddad bin Aws that the Messenger of Allah\n(ﷺ) said:,Chapters Regarding Funerals
1190,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ عَاصِمِ بْنِ عُبَيْدِ اللَّهِ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ، عَنْ عَائِشَةَ، قَالَتْ قَبَّلَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عُثْمَانَ بْنَ مَظْعُونٍ وَهُوَ مَيِّتٌ فَكَأَنِّي أَنْظُرُ إِلَى دُمُوعِهِ تَسِيلُ عَلَى خَدَّيْهِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/الصلاة ۳۳۸ (۱۴۲۲)، سنن النسائی/قیام اللیل ۳۴ (۱۷۱۱،۱۷۱۲)،(تحفة الأشراف:۳۴۸۰)، وقد أخرجہ: مسند احمد (۵/۴۱۸)، سنن الدارمی/الصلاة ۲۱۰ (۱۶۲۶),1190,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1191,حَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، وَالْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ، وَسَهْلُ بْنُ أَبِي سَهْلٍ، قَالُوا حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ سُفْيَانَ، عَنْ مُوسَى بْنِ أَبِي عَائِشَةَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنِ ابْنِ عَبَّاسٍ، وَعَائِشَةَ، أَنَّ أَبَا بَكْرٍ، قَبَّلَ النَّبِيَّ ـ صلى الله عليه وسلم ـ وَهُوَ مَيِّتٌ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن النسائی/السہو ۶۷ (۱۳۱۶)،(تحفة الأشراف:۱۶۱۰۷)، وقد أخرجہ: صحیح مسلم/المسافرین ۱۸ (۷۴۶)، الصلاة ۳۱۶ (۱۳۴۲)، مسند احمد (۶/۴۴،۵۴),1191,,Chapters Regarding Funerals
1192,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، عَنْ أَيُّوبَ، عَنْ مُحَمَّدِ بْنِ سِيرِينَ، عَنْ أُمِّ عَطِيَّةَ، قَالَتْ دَخَلَ عَلَيْنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَنَحْنُ نُغَسِّلُ ابْنَتَهُ أُمَّ كُلْثُومٍ فَقَالَ ‏""‏ اغْسِلْنَهَا ثَلاَثًا أَوْ خَمْسًا أَوْ أَكْثَرَ مِنْ ذَلِكِ إِنْ رَأَيْتُنَّ ذَلِكِ بِمَاءٍ وَسِدْرٍ وَاجْعَلْنَ فِي الآخِرَةِ كَافُورًا أَوْ شَيْئًا مِنْ كَافُورٍ فَإِذَا فَرَغْتُنَّ فَآذِنَّنِي ‏""‏ ‏.‏ فَلَمَّا فَرَغْنَا آذَنَّاهُ فَأَلْقَى إِلَيْنَا حَقْوَهُ ‏.‏ وَقَالَ ‏""‏ أَشْعِرْنَهَا إِيَّاهُ ‏""‏ ‏.‏",Zubair Ali Zai: Sahih,takhreej: سنن النسائی/قیام اللیل ۳۵ (۱۷۱۵)،(تحفةالأشراف:۱۸۲۱۴)، وقد أخرجہ: سنن الترمذی/الوتر ۵ (۴۵۷)، مسند احمد (۶/۲۹۰،۳۱۰،۳۲۱),1192,Muhammad\nbin Sirin narrated that Umm ‘Atiyyah said:,Chapters Regarding Funerals
1193,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، عَنْ أَيُّوبَ، حَدَّثَتْنِي حَفْصَةُ، عَنْ أُمِّ عَطِيَّةَ، بِمِثْلِ حَدِيثِ مُحَمَّدٍ وَكَانَ فِي حَدِيثِ حَفْصَةَ ‏""‏ اغْسِلْنَهَا وِتْرًا ‏""‏ ‏.‏ وَكَانَ فِيهِ ‏""‏ اغْسِلْنَهَا ثَلاَثًا أَوْ خَمْسًا ‏""‏ ‏.‏ وَكَانَ فِيهِ ‏""‏ ابْدَءُوا بِمَيَامِنِهَا وَمَوَاضِعِ الْوُضُوءِ مِنْهَا ‏""‏ ‏.‏ وَكَانَ فِيهِ أَنَّ أُمَّ عَطِيَّةَ قَالَتْ وَامْشِطْنَهَا ثَلاَثَةَ قُرُونٍ ‏.‏",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۷۴۷، ومصباح الزجاجة:۴۲۰)، وقد أخرجہ: مسند احمد (۲/۸۶),1193,It was\nnarrated from Ayyub who said:,Chapters Regarding Funerals
1194,"حَدَّثَنَا بِشْرُ بْنُ آدَمَ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، عَنِ ابْنِ جُرَيْجٍ، عَنْ حَبِيبِ بْنِ أَبِي ثَابِتٍ، عَنْ عَاصِمِ بْنِ ضَمْرَةَ، عَنْ عَلِيٍّ، قَالَ قَالَ لِي النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تُبْرِزْ فَخِذَكَ وَلاَ تَنْظُرْ إِلَى فَخِذِ حَىٍّ وَلاَ مَيِّتٍ ‏""""‏ ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۷۷۵،۷۱۱۶، ومصباح الزجاجة:۴۲۱)، مسند احمد (۱/۲۴۱),,It was\nnarrated that ‘Ali said:,Chapters Regarding Funerals
1195,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، حَدَّثَنَا بَقِيَّةُ بْنُ الْوَلِيدِ، عَنْ مُبَشِّرِ بْنِ عُبَيْدٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لِيُغَسِّلْ مَوْتَاكُمُ الْمَأْمُونُونَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الوتر ۱۴ (۴۷۱)،(تحفة الأشراف:۱۸۲۵۵)، وقد أخرجہ: مسند احمد (۶/۲۹۸),,It was\nnarrated from ‘Abdullah bin ‘Umar that the Messenger of Allah\n(ﷺ) said:,Chapters Regarding Funerals
1196,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِبِيُّ، حَدَّثَنَا عَبَّادُ بْنُ كَثِيرٍ، عَنْ عَمْرِو بْنِ خَالِدٍ، عَنْ حَبِيبِ بْنِ أَبِي ثَابِتٍ، عَنْ عَاصِمِ بْنِ ضَمْرَةَ، عَنْ عَلِيٍّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ غَسَّلَ مَيِّتًا وَكَفَّنَهُ وَحَنَّطَهُ وَحَمَلَهُ وَصَلَّى عَلَيْهِ وَلَمْ يُفْشِ عَلَيْهِ مَا رَأَى خَرَجَ مِنْ خَطِيئَتِهِ مِثْلَ يَوْمِ وَلَدَتْهُ أُمُّهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۷۱۵ومصباح الزجاجة:۴۲۳)، وقد أخرجہ: صحیح البخاری/الأذان ۱۲ (۶۹۱)، التہجد ۲۲ (۱۱۵۹)، صحیح مسلم/المسافرین ۱۷ (۷۳۸)، سنن ابی داود/الصلاة ۳۱۶ (۱۳۴۰)، سنن النسائی/قیام اللیل ۴۶ (۱۷۵۷)، مسند احمد (۶/۵۳،۸۱),,It was\nnarrated from ‘Ali that the Messenger of Allah (ﷺ) said:,Chapters Regarding Funerals
1197,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ الْمُخْتَارِ، عَنْ سُهَيْلِ بْنِ أَبِي صَالِحٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ غَسَّلَ مَيِّتًا فَلْيَغْتَسِلْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۷۱۵)، وقد أخرجہ: صحیح البخاری/التہجد ۷ (۱۱۳۳)، صحیح مسلم/المسافرین ۱۷ (۷۴۲)، سنن ابی داود/الصلاة ۳۱۲ (۱۳۱۸)، مسند احمد (۶/۱۳۷،۱۶۱،۲۰۵،۲۷۰),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1198,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا أَحْمَدُ بْنُ خَالِدٍ الْوَهْبِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ، عَنْ يَحْيَى بْنِ عَبَّادِ بْنِ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ لَوْ كُنْتُ اسْتَقْبَلْتُ مِنَ الأَمْرِ مَا اسْتَدْبَرْتُ مَا غَسَّلَ النَّبِيَّ ـ صلى الله عليه وسلم ـ غَيْرُ نِسَائِهِ ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۵۰۹)، وقد أخرجہ: صحیح البخاری/الأذان ۱۴ (۶۲۶)، التہجد ۲۳ (۱۱۶۰)،۲۴ (۱۱۶۱)، الدعوات ۵ (۶۳۱۰)، سنن الترمذی/الصلاة ۲۰۸ (۴۴۰)، سنن النسائی/قیام اللیل ۴۹ (۱۷۶۳)، مسند احمد (۶/۳۴،۳۵)، سنن الدارمی/الصلاة ۱۶۵ (۱۵۱۴),1198,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1199,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا أَحْمَدُ بْنُ حَنْبَلٍ، حَدَّثَنَا مُحَمَّدُ بْنُ سَلَمَةَ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ يَعْقُوبَ بْنِ عُتْبَةَ، عَنِ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنْ عَائِشَةَ، قَالَتْ رَجَعَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ مِنَ الْبَقِيعِ فَوَجَدَنِي وَأَنَا أَجِدُ صُدَاعًا فِي رَأْسِي وَأَنَا أَقُولُ وَارَأْسَاهُ فَقَالَ ‏""‏ بَلْ أَنَا يَا عَائِشَةُ وَارَأْسَاهُ ‏""‏ ‏.‏ ثُمَّ قَالَ ‏""‏ مَا ضَرَّكِ لَوْ مِتِّ قَبْلِي فَقُمْتُ عَلَيْكِ فَغَسَّلْتُكِ وَكَفَّنْتُكِ وَصَلَّيْتُ عَلَيْكِ وَدَفَنْتُكِ ‏""‏ ‏.‏",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih,takhreej: : تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۶۸۵)، سنن ابی داود/الصلاة ۲۹۳ (۱۲۶۱)، سنن الترمذی/الصلاة ۱۹۴ (۴۲۰),1199,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1200,حَدَّثَنَا سَعِيدُ بْنُ يَحْيَى بْنِ الأَزْهَرِ الْوَاسِطِيُّ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنَا أَبُو بُرْدَةَ، عَنْ عَلْقَمَةَ بْنِ مَرْثَدٍ، عَنِ ابْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، قَالَ لَمَّا أَخَذُوا فِي غُسْلِ النَّبِيِّ ـ صلى الله عليه وسلم ـ نَادَاهُمْ مُنَادٍ مِنَ الدَّاخِلِ لاَ تَنْزِعُوا عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَمِيصَهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الوتر ۵ (۹۹۹)، تقصیرالصلاة ۷ (۱۰۹۵)،۸ (۱۰۹۶)،۱۲ (۱۱۰۵)، صحیح مسلم/المسافرین ۴ (۷۰۰)، سنن الترمذی/الصلاة ۲۲۸ (۴۷۲)، سنن النسائی/قیام اللیل ۳۱ (۱۶۸۹)،(تحفة الأشراف:۷۰۸۵)، وقد أخرجہ: موطا امام مالک/صلاة اللیل ۳ (۱۵)مسند احمد (۲/۵۷،۱۳۸)، سنن الدارمی/الصلاة ۲۱۳ (۱۶۳۱),1200,It was\nnarrated from Abu Buraidah that his father said:,Chapters Regarding Funerals
1201,حَدَّثَنَا يَحْيَى بْنُ خِذَامٍ، حَدَّثَنَا صَفْوَانُ بْنُ عِيسَى، أَنْبَأَنَا مَعْمَرٌ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ عَلِيِّ بْنِ أَبِي طَالِبٍ، قَالَ لَمَّا غَسَّلَ النَّبِيَّ ـ صلى الله عليه وسلم ـ ذَهَبَ يَلْتَمِسُ مِنْهُ مَا يَلْتَمِسُ مِنَ الْمَيِّتِ فَلَمْ يَجِدْهُ ‏.‏ فَقَالَ بِأَبِي الطَّيِّبُ طِبْتَ حَيًّا وَطِبْتَ مَيِّتًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۱۴۰، ومصباح الزجاجة:۴۲۴),1201,"It was\nnarrated that ‘Ali bin Abu Talib said that when he washed the\nMessenger of Allah (ﷺ) he looked for what which is usually looked\nfor on the deceased (i.e., dirt), and he found none. He said:",Chapters Regarding Funerals
1202,"حَدَّثَنَا عَبَّادُ بْنُ يَعْقُوبَ، حَدَّثَنَا الْحُسَيْنُ بْنُ زَيْدِ بْنِ عَلِيِّ بْنِ الْحُسَيْنِ بْنِ عَلِيٍّ، عَنْ إِسْمَاعِيلَ بْنِ عَبْدِ اللَّهِ بْنِ جَعْفَرٍ، عَنْ أَبِيهِ، عَنْ عَلِيٍّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا أَنَا مُتُّ فَاغْسِلْنِي بِسَبْعِ قِرَبٍ مِنْ بِئْرِي بِئْرِ غَرْسٍ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۳۷۳، ومصباح الزجاجة:۴۲۵)، وقد أخرجہ: مسند احمد (۳/۳۰۹،۳۳۰),,It was\nnarrated from ‘Ali that the Messenger of Allah (ﷺ) said:,Chapters Regarding Funerals
1203,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كُفِّنَ فِي ثَلاَثَةِ أَثْوَابٍ بِيضٍ يَمَانِيَةٍ لَيْسَ فِيهَا قَمِيصٌ وَلاَ عِمَامَةٌ فَقِيلَ لِعَائِشَةَ إِنَّهُمْ كَانُوا يَزْعُمُونَ أَنَّهُ قَدْ كَانَ كُفِّنَ فِي حِبَرَةٍ ‏.‏ فَقَالَتْ عَائِشَةُ قَدْ جَاءُوا بِبُرْدِ حِبَرَةٍ فَلَمْ يُكَفِّنُوهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المساجد ۱۹ (۵۷۲)، سنن ابی داود/الصلاة ۱۹۶ (۱۰۲۱)،(تحفة الأشراف:۹۴۲۴)، وقد أخرجہ: صحیح البخاری/الصلاة ۲۳ (۴۰۱)، سنن الترمذی/الصلاة ۱۷۳ (۳۹۲)، سنن النسائی/السہو۲۵ (۱۲۴۲)، مسند احمد (۱/۳۷۹،۴۲۹،۴۳۸،۴۵۵),1203,"It was\nnarrated from ‘Aishah that the Prophet (ﷺ) was shrouded in\nthree\nwhite Yemeni cloths, among which there was no shirt and no\nturban. It\nwas said to ‘Aishah:",Chapters Regarding Funerals
1204,حَدَّثَنَا مُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلاَنِيُّ، حَدَّثَنَا عَمْرُو بْنُ أَبِي سَلَمَةَ، قَالَ هَذَا مَا سَمِعْتُ مِنْ أَبِي مُعَيْدٍ، حَفْصِ بْنِ غَيْلاَنَ عَنْ سُلَيْمَانَ بْنِ مُوسَى، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، قَالَ كُفِّنَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فِي ثَلاَثِ رِيَاطٍ بِيضٍ سَحُولِيَّةٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الصلاة ۱۹۷ (۱۰۲۹)، سنن الترمذی/الصلاة ۱۷ (۳۹۶)،(تحفة الأشراف:۴۳۹۶)، وقد أخرجہ: صحیح مسلم/المساجد ۱۹ (۵۷۱)، سنن النسائی/السہو ۲۴ (۱۲۴۰)، موطا امام مالک/الصلاة ۱۶ (۶۲)، مسند احمد (۳/۱۲،۳۷،۵۰،۵۱،۵۳،۵۴)، سنن الدارمی/الصلاة ۱۷۴ (۱۵۳۶),1204,It was\nnarrated that ‘Abdullah bin ‘Umar said:,Chapters Regarding Funerals
1205,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنِ الْحَكَمِ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ كُفِّنَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فِي ثَلاَثَةِ أَثْوَابٍ قَمِيصُهُ الَّذِي قُبِضَ فِيهِ وَحُلَّةٌ نَجْرَانِيَّةٌ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الصلاة ۳۱ (۴۰۱)،۳۲ (۴۰۴)، السہو۲ (۱۲۲۶)، الأیمان ۱۵ (۶۶۷۱)، صحیح مسلم/المساجد ۱۹ (۵۷۲)سنن ابی داود/الصلاة ۱۹۶ (۱۰۱۹)، سنن الترمذی/الصلاة ۱۷۳ (۳۹۲)، سنن النسائی/السہو۲۶ (۱۲۵۵)،(تحفة الأشراف:۹۴۱۱)وقد أخرجہ: مسند احمد (۱/۳۷۹،۴۲۹،۴۳۸،۳۷۶،۴۴۳،۴۶۵)، سنن الدارمی/الصلاة ۱۷۵ (۱۵۳۹),1205,It was\nnarrated that Ibn ‘Abbas said:,Chapters Regarding Funerals
1206,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ رَجَاءٍ الْمَكِّيُّ، عَنْ عَبْدِ اللَّهِ بْنِ عُثْمَانَ بْنِ خُثَيْمٍ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ خَيْرُ ثِيَابِكُمُ الْبَيَاضُ فَكَفِّنُوا فِيهَا مَوْتَاكُمْ وَالْبَسُوهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الاذان ۱۴۶ (۸۲۹)،۱۴۷ (۸۳۰)، السہو۱ (۱۲۲۴)،۵ (۱۲۳۰)، الأیمان ۱۵ (۶۶۷۰)، صحیح مسلم/المساجد ۱۹ (۵۷۰)، سنن ابی داود/الصلاة ۲۰۰ (۱۰۳۴،۱۰۳۵)، سنن الترمذی/الصلاة ۱۷۲ (۳۹۱)، سنن النسائی/التطبیق ۱۰۶ (۱۱۷۸،۱۱۷۹)السہو۲۱ (۱۲۲۳،۱۲۲۴)،(تحفة الأشراف:۹۱۵۴)، وقد أخرجہ: موطا امام مالک/الصلاة ۱۷ (۶۵)، مسند احمد (۵/۳۴۵،۳۴۶)، سنن الدارمی/الصلاة ۱۷۶ (۱۵۴۰),,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1207,"حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الأَعْلَى، حَدَّثَنَا ابْنُ وَهْبٍ، أَنْبَأَنَا هِشَامُ بْنُ سَعْدٍ، عَنْ حَاتِمِ بْنِ أَبِي نَصْرٍ، عَنْ عُبَادَةَ بْنِ نُسَىٍّ، عَنْ أَبِيهِ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ خَيْرُ الْكَفَنِ الْحُلَّةُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: انظر ما قبلہ,,It was\nnarrated from ‘Ubadah bin Samit that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters Regarding Funerals
1208,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عُمَرُ بْنُ يُونُسَ، حَدَّثَنَا عِكْرِمَةُ بْنُ عَمَّارٍ، عَنْ هِشَامِ بْنِ حَسَّانٍ، عَنْ مُحَمَّدِ بْنِ سِيرِينَ، عَنْ أَبِي قَتَادَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا وَلِيَ أَحَدُكُمْ أَخَاهُ فَلْيُحْسِنْ كَفَنَهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/الصلاة ۲۰۱ (۱۰۳۶)، سنن الترمذی/الصلاة ۱۵۲ (۳۶۴ تعلیقاً)،(تحفة الأشراف:۲۵ ۱۱۵)وقد أخرجہ: مسند احمد (۴/۲۵۳،۲۵۴)، سنن الدارمی/الصلاة ۱۷۶ (۱۵۴۰),,It was\nnarrated from Abu Qatadah that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1209,"حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ بْنِ سَمُرَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ الْحَسَنِ، حَدَّثَنَا أَبُو شَيْبَةَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ لَمَّا قُبِضَ إِبْرَاهِيمُ ابْنُ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ لَهُمُ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تُدْرِجُوهُ فِي أَكْفَانِهِ حَتَّى أَنْظُرَ إِلَيْهِ ‏""""‏ ‏.‏ فَأَتَاهُ فَانْكَبَّ عَلَيْهِ وَبَكَى ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Hasan,takhreej: سنن الترمذی/الصلاة ۱۷۵ (۳۹۸)،(تحفة الأشراف:۹۷۲۲)، وقد أخرجہ: مسند احمد (۱/۱۹۰،۱۹۳،۱۹۵),,It was\nnarrated that Anas bin Malik said:,Chapters Regarding Funerals
1210,حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، عَنْ حَبِيبِ بْنِ سُلَيْمٍ، عَنْ بِلاَلِ بْنِ يَحْيَى، قَالَ كَانَ حُذَيْفَةُ إِذَا مَاتَ لَهُ الْمَيِّتُ قَالَ لاَ تُؤْذِنُوا بِهِ أَحَدًا إِنِّي أَخَافُ أَنْ يَكُونَ نَعْيًا إِنِّي سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ بِأُذُنَىَّ هَاتَيْنِ يَنْهَى عَنِ النَّعْىِ ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المساجد ۱۹ (۵۷۱)، سنن ابی داود/الصلاة ۱۹۷ (۱۰۲۴،۱۰۲۷)، سنن النسائی/السہو ۴۲ (۱۲۳۹،۱۲۴۰)(تحفة الأشراف:۴۱۶۳)، وقد أخرجہ: موطا امام مالک/الصلاة۱۶ (۶۲)، مسند احمد (۳/۷۲،۸۳،۸۴،۸۷)سنن الدارمی/الصلاة ۱۷۴ (۱۵۳۶),1210,It was\nnarrated that Bilal bin Yahya said:,Chapters Regarding Funerals
1211,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَهِشَامُ بْنُ عَمَّارٍ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَسْرِعُوا بِالْجِنَازَةِ فَإِنْ تَكُنْ صَالِحَةً فَخَيْرٌ تُقَدِّمُونَهَا إِلَيْهِ وَإِنْ تَكُنْ غَيْرَ ذَلِكَ فَشَرٌّ تَضَعُونَهُ عَنْ رِقَابِكُمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الصلاة ۳۱ (۴۰۱)،۳۲ (۴۰۴)، السہو ۲ (۱۲۲۶)، الأیمان والنذور ۱۵ (۶۶۷۱)، أخبارالآحاد۱،(۷۲۴۹)، صحیح مسلم/المساجد ۱۹ (۵۷۲)، سنن ابی داود/الصلاة ۱۹۶ (۱۰۲۰)، سنن النسائی/السہو ۲۵ (۱۲۴۱،۱۲۴۲)،(تحفة الأشراف:۹۴۵۱)، وقد أخرجہ: سنن الترمذی/الصلاة ۱۷۳،(۳۹۲)، مسند احمد (۱/۳۷۹،۴۱۹،۴۳۸،۴۵۵)، دي الصلاة ۱۷۵ (۱۵۳۹),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1212,حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ مَنْصُورٍ، عَنْ عُبَيْدِ بْنِ نِسْطَاسٍ، عَنْ أَبِي عُبَيْدَةَ، قَالَ قَالَ عَبْدُ اللَّهِ بْنُ مَسْعُودٍ مَنِ اتَّبَعَ جِنَازَةً فَلْيَحْمِلْ بِجِوَانِبِ السَّرِيرِ كُلِّهَا فَإِنَّهُ مِنَ السُّنَّةِ ثُمَّ إِنْ شَاءَ فَلْيَتَطَوَّعْ وَإِنْ شَاءَ فَلْيَدَعْ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: انظر ما قبلہ،(تحفة الأشراف:۹۴۵۱),1212,It was\nnarrated that Abu ‘Ubaidah said:,Chapters Regarding Funerals
1213,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدِ بْنِ عَقِيلٍ، حَدَّثَنَا بِشْرُ بْنُ ثَابِتٍ، حَدَّثَنَا شُعْبَةُ، عَنْ لَيْثٍ، عَنْ أَبِي بُرْدَةَ، عَنْ أَبِي مُوسَى، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ أَنَّهُ رَأَى جِنَازَةً يُسْرِعُونَ بِهَا قَالَ ‏ ‏ لِتَكُنْ عَلَيْكُمُ السَّكِينَةُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/الصلاة ۱۹۵ (۱۰۱۷)،(تحفة الأشراف:۷۸۳۸),,It was\nnarrated from Abu Musa that the Prophet (ﷺ) saw a funeral\n(procession) with which the people were rushing. He said:,Chapters Regarding Funerals
1214,"حَدَّثَنَا كَثِيرُ بْنُ عُبَيْدٍ الْحِمْصِيُّ، حَدَّثَنَا بَقِيَّةُ بْنُ الْوَلِيدِ، عَنْ أَبِي بَكْرِ بْنِ أَبِي مَرْيَمَ، عَنْ رَاشِدِ بْنِ سَعْدٍ، عَنْ ثَوْبَانَ، مَوْلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ رَأَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ نَاسًا رُكْبَانًا عَلَى دَوَابِّهِمْ فِي جِنَازَةٍ فَقَالَ ‏ ‏ أَلاَ تَسْتَحْيُونَ أَنَّ مَلاَئِكَةَ اللَّهِ يَمْشُونَ عَلَى أَقْدَامِهِمْ وَأَنْتُمْ رُكْبَانٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الصلاة ۸۸ (۴۸۲)، الأذان ۶۹ (۷۱۴،۷۱۵)، السہو۳ (۱۲۲۷)،۴ (۱۲۲۸)،۵ (۱۲۲۹)، الادب ۴۵ (۶۰۵۱)، أخبارالآحاد ۱ (۷۲۵۰)، سنن ابی داود/الصلاة ۱۹۵ (۱۰۱۱)، سنن النسائی/السہو ۲۲ (۱۲۲۵)،(تحفة الأشراف:۱۴۴۶۹)، وقد أخرجہ: صحیح مسلم/المساجد ۱۹ (۵۷۳)، سنن الترمذی/الصلاة ۱۷۶ (۳۹۹)، مسند احمد (۲/۲۳۵،۴۲۳،۴۶۰),,"It was\nnarrated that Thawban, the freed slave of the Messenger of\nAllah\n(ﷺ), said:",Chapters Regarding Funerals
1215,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، حَدَّثَنَا سَعِيدُ بْنُ عُبَيْدِ اللَّهِ بْنِ جُبَيْرِ بْنِ حَيَّةَ، حَدَّثَنِي زِيَادُ بْنُ جُبَيْرِ بْنِ حَيَّةَ، سَمِعَ الْمُغِيرَةَ بْنَ شُعْبَةَ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ الرَّاكِبُ خَلْفَ الْجِنَازَةِ وَالْمَاشِي مِنْهَا حَيْثُ شَاءَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المساجد ۱۹ (۵۷۴)، سنن ابی داود/الصلاة ۲۰۲ (۱۰۱۸)، سنن النسائی/السہو ۲۳ (۱۲۳۸)،(تحفة الأشراف:۱۰۸۸۲)، وقد أخرجہ: سنن الترمذی/الصلاة ۱۷۴ (۳۹۵)، مسند احمد (۴/۴۲۷،۴۳۱،۴۴۰،۵/۱۱۰),,Al-Mughirah bin Shu’bah said:,Chapters Regarding Funerals
1216,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَهِشَامُ بْنُ عَمَّارٍ، وَسَهْلُ بْنُ أَبِي سَهْلٍ، قَالُوا حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، قَالَ رَأَيْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ وَأَبَا بَكْرٍ وَعُمَرَ يَمْشُونَ أَمَامَ الْجِنَازَةِ ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/الصلاة ۳۱ (۵۱۶)،۱۹۸ (۱۰۳۲)،(تحفة الأشراف:۱۵۲۵۲)، وقد أخرجہ: صحیح البخاری/الأذان ۴ (۶۰۸)، صحیح مسلم/المساجد ۱۹ (۳۸۹)، سنن الترمذی/الصلاة ۱۷۴ (۳۹۷)، موطا امام مالک/السہو ۱ (۱),1216,It was\nnarrated from Salim that his father said:,Chapters Regarding Funerals
1217,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، وَهَارُونُ بْنُ عَبْدِ اللَّهِ الْحَمَّالُ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ بَكْرٍ الْبُرْسَانِيُّ، أَنْبَأَنَا يُونُسُ بْنُ يَزِيدَ الأَيْلِيُّ، عَنِ الزُّهْرِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَأَبُو بَكْرٍ وَ عُمَرُ وَعُثْمَانُ يَمْشُونَ أَمَامَ الْجِنَازَةِ ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۹۶۲)، وقد أخرجہ: صحیح البخاری/الأذان ۴ (۶۰۸)، العمل في الصلاة ۱۸ (۱۲۲۲)، السہو ۶ (۱۲۳۱)، بدء الخلق ۱۱ (۳۲۸۵)، صحیح مسلم/السہو۱۹ (۳۸۹)سنن ابی داود/الصلاة ۳۱ (۵۱۶)، مسند احمد (۲/۳۱۳،۳۹۸،۴۱۱),1217,It was\nnarrated that Anas bin Malik said:,Chapters Regarding Funerals
1218,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، أَنْبَأَنَا عَبْدُ الْوَاحِدِ بْنُ زِيَادٍ، عَنْ يَحْيَى بْنِ عَبْدِ اللَّهِ التَّيْمِيِّ، عَنْ أَبِي مَاجِدَةَ الْحَنَفِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْجِنَازَةُ مَتْبُوعَةٌ وَلَيْسَتْ بِتَابِعَةٍ لَيْسَ مِنْهَا مَنْ تَقَدَّمَهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۴۶۰)، وقد أخرجہ: مسند احمد (۱/۳۶۳،۳۷۶),,It was\nnarrated from ‘Abdullah bin Mas’ud that the Messenger of Allah\n(ﷺ) said:,Chapters Regarding Funerals
1219,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، أَخْبَرَنِي عَمْرُو بْنُ النُّعْمَانِ، حَدَّثَنَا عَلِيُّ بْنُ الْحَزَوَّرِ، عَنْ نُفَيْعٍ، عَنْ عِمْرَانَ بْنِ الْحُصَيْنِ، وَأَبِي، بَرْزَةَ قَالاَ خَرَجْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فِي جِنَازَةٍ فَرَأَى قَوْمًا قَدْ طَرَحُوا أَرْدِيَتَهُمْ يَمْشُونَ فِي قُمُصٍ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَبِفِعْلِ الْجَاهِلِيَّةِ تَأْخُذُونَ - أَوْ بِصُنْعِ الْجَاهِلِيَّةِ تَشَبَّهُونَ - لَقَدْ هَمَمْتُ أَنْ أَدْعُوَ عَلَيْكُمْ دَعْوَةً تَرْجِعُونَ فِي غَيْرِ صُوَرِكُمْ ‏""""‏ ‏.‏ قَالَ فَأَخَذُوا أَرْدِيَتَهُمْ وَلَمْ يَعُودُوا لِذَلِكَ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/الصلاة ۲۰۲ (۱۰۳۸)،(تحفة الأشراف:۲۰۷۷)، وقد أخرجہ: مسند احمد (۵/۲۸۰),,It was\nnarrated that ‘Imran bin Husain and Abu Barzah said:,Chapters Regarding Funerals
1220,"حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي سَعِيدُ بْنُ عَبْدِ اللَّهِ الْجُهَنِيُّ، أَنَّ مُحَمَّدَ بْنَ عُمَرَ بْنِ عَلِيِّ بْنِ أَبِي طَالِبٍ، حَدَّثَهُ عَنْ أَبِيهِ، عَنْ جَدِّهِ، عَلِيِّ بْنِ أَبِي طَالِبٍ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ تُؤَخِّرُوا الْجِنَازَةَ إِذَا حَضَرَتْ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۵۹۴، ومصباح الزجاجة:۴۲۷)، وقد أخرجہ: صحیح البخاری/الأذان ۲۵ (۶۴۰،۶۳۹)، صحیح مسلم/المساجد ۲۹ (۶۰۵)، سنن ابی داود/الطہارة ۹۴ (۲۳۵)، سنن النسائی/الإمامة ۱۴ (۷۹۳)، مسند احمد (۱/۳۶۸،۲/۲۳۷،۲۵۹،۴۴۸),,It was\nnarrated from ‘Ali bin Abu Talib that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters Regarding Funerals
1221,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الأَعْلَى الصَّنْعَانِيُّ، أَنْبَأَنَا مُعْتَمِرُ بْنُ سُلَيْمَانَ، قَالَ قَرَأْتُ عَلَى الْفُضَيْلِ بْنِ مَيْسَرَةَ عَنْ أَبِي حَرِيزٍ، أَنَّ أَبَا بُرْدَةَ، حَدَّثَهُ قَالَ أَوْصَى أَبُو مُوسَى الأَشْعَرِيُّ حِينَ حَضَرَهُ الْمَوْتُ فَقَالَ لاَ تُتْبِعُونِي بِمِجْمَرٍ ‏.‏ قَالُوا لَهُ أَوَ سَمِعْتَ فِيهِ شَيْئًا قَالَ نَعَمْ مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۲۵۲، ومصباح الزجاجة:۴۲۸),1221,It was\nnarrated from Abu Hariz that Abu Burdah said:,Chapters Regarding Funerals
1222,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عُبَيْدُ اللَّهِ، أَنْبَأَنَا شَيْبَانُ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ صَلَّى عَلَيْهِ مِائَةٌ مِنَ الْمُسْلِمِينَ غُفِرَ لَهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۱۲۹، ومصباح الزجاجة:۴۲۹)، وقد أخرجہ: سنن ابی داود/الصلاة ۲۳۶ (۱۱۱۴),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters Regarding Funerals
1223,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، حَدَّثَنَا بَكْرُ بْنُ سُلَيْمٍ، حَدَّثَنِي حُمَيْدُ بْنُ زِيَادٍ الْخَرَّاطُ، عَنْ كُرَيْبٍ، مَوْلَى عَبْدِ اللَّهِ بْنِ عَبَّاسٍ قَالَ هَلَكَ ابْنٌ لِعَبْدِ اللَّهِ بْنِ عَبَّاسٍ فَقَالَ لِي يَا كُرَيْبُ قُمْ فَانْظُرْ هَلِ اجْتَمَعَ لاِبْنِي أَحَدٌ فَقُلْتُ نَعَمْ ‏.‏ فَقَالَ وَيْحَكَ كَمْ تَرَاهُمْ؟ أَرْبَعِينَ؟ قُلْتُ: لاَ. بَلْ هُمْ أَكْثَرُ ‏.‏ قَالَ: فَاخْرُجُوا بِابْنِي فَأَشْهَدُ لَسَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَا مِنْ أَرْبَعِينَ مِنْ مُؤْمِنٍ يَشْفَعُونَ لِمُؤْمِنٍ إِلاَّ شَفَّعَهُمُ اللَّهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الصلاة ۱۷۹ (۹۵۲)، سنن الترمذی/الصلاة ۱۵۸ (۳۷۲)،(تحفة الأشراف:۱۰۸۳۲)، وقد أخرجہ: صحیح البخاری/تقصیر الصلاة ۱۹ (۱۱۱۷),,It was\nnarrated that Kuraib the freed slave of ‘Abdullah bin ‘Abbas\nsaid:,Chapters Regarding Funerals
1224,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ مَرْثَدِ بْنِ عَبْدِ اللَّهِ الْيَزَنِيِّ، عَنْ مَالِكِ بْنِ هُبَيْرَةَ الشَّامِيِّ، - وَكَانَتْ لَهُ صُحْبَةٌ - قَالَ كَانَ إِذَا أُتِيَ بِجِنَازَةٍ فَتَقَالَّ مَنْ تَبِعَهَا جَزَّأَهُمْ ثَلاَثَةَ صُفُوفٍ ثُمَّ صَلَّى عَلَيْهَا وَقَالَ إِنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا صَفَّ صُفُوفٌ ثَلاَثَةٌ مِنَ الْمُسْلِمِينَ عَلَى مَيِّتٍ إِلاَّ أَوْجَبَ ‏""""‏ ‏.‏""",Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۷۸۹، ومصباح الزجاجة:۴۳۰),,"Malik\nbin Hubairah Ash-Shami, who was a Companion of the Prophet\n(ﷺ),\nsaid:",Chapters Regarding Funerals
1225,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ ثَابِتٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ مُرَّ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ بِجِنَازَةٍ فَأُثْنِيَ عَلَيْهَا خَيْرًا فَقَالَ ‏""‏ وَجَبَتْ ‏""‏ ‏.‏ ثُمَّ مُرَّ عَلَيْهِ بِجِنَازَةٍ فَأُثْنِيَ عَلَيْهَا شَرًّا فَقَالَ ‏""‏ وَجَبَتْ ‏""‏ ‏.‏ فَقِيلَ يَا رَسُولَ اللَّهِ قُلْتَ لِهَذِهِ وَجَبَتْ وَلِهَذِهِ وَجَبَتْ فَقَالَ ‏""‏ شَهَادَةُ الْقَوْمِ وَالْمُؤْمِنُونَ شُهُودُ اللَّهِ فِي الأَرْضِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن النسائی/قیام اللیل ۱۷ (۱۶۵۵،۱۶۵۶)،(تحفة الأشراف:۱۸۲۳۶)، وقد أخرجہ: مسند احمد (۶/۳۰۵،۳۱۹،۳۲۰،۳۲۱،۳۲۲),1225,It was\nnarrated that Anas bin Malik said:,Chapters Regarding Funerals
1226,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ مُرَّ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ بِجِنَازَةٍ - فَأُثْنِيَ عَلَيْهَا خَيْرًا فِي مَنَاقِبِ الْخَيْرِ فَقَالَ ‏""‏ وَجَبَتْ ‏""‏ ‏.‏ ثُمَّ مَرُّوا عَلَيْهِ بِأُخْرَى فَأُثْنِيَ عَلَيْهَا شَرًّا فِي مَنَاقِبِ الشَّرِّ فَقَالَ ‏""‏ وَجَبَتْ إِنَّكُمْ شُهَدَاءُ اللَّهِ فِي الأَرْضِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المسافرین ۱۶ (۷۳۱)، سنن النسائی/قیام اللیل ۱۶ (۱۶۵۱)،(تحفة الأشراف:۱۷۹۵۰)، وقد أخرجہ: موطا امام مالک/صلاة الجماعة ۷ (۲۲)، مسند احمد (۶/۲۱۷),1226,It was\nnarrated that Abu Hurairah said:,Chapters Regarding Funerals
1227,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو أُسَامَةَ، قَالَ الْحُسَيْنُ بْنُ ذَكْوَانَ أَخْبَرَنِي عَنْ عَبْدِ اللَّهِ بْنِ بُرَيْدَةَ الأَسْلَمِيِّ، عَنْ سَمُرَةَ بْنِ جُنْدُبٍ الْفَزَارِيِّ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ صَلَّى عَلَى امْرَأَةٍ مَاتَتْ فِي نِفَاسِهَا فَقَامَ وَسَطَهَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۰۳۰، ومصباح الزجاجة:۴۳۱)، وقد أخرجہ: صحیح البخاری/تقصیرالصلاة ۲۰ (۱۱۱۸)، صحیح مسلم/المسافرین ۱۶ (۷۳۱)، سنن ابی داود/الصلاة ۱۷۹ (۹۵۳)، سنن الترمذی/الصلاة ۱۵۸ (۳۷۲)، سنن النسائی/قیام اللیل ۱۶ (۱۶۵۰)، موطا امام مالک/ صلاة الجماعة ۷ (۲۲)، مسند احمد (۶/۴۶),1227,,Chapters Regarding Funerals
1228,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا سَعِيدُ بْنُ عَامِرٍ، عَنْ هَمَّامٍ، عَنْ أَبِي غَالِبٍ، قَالَ رَأَيْتُ أَنَسَ بْنَ مَالِكٍ صَلَّى عَلَى جِنَازَةِ رَجُلٍ فَقَامَ حِيَالَ رَأْسِهِ فَجِيءَ بِجِنَازَةٍ أُخْرَى بِامْرَأَةٍ فَقَالُوا يَا أَبَا حَمْزَةَ صَلِّ عَلَيْهَا ‏.‏ فَقَامَ حِيَالَ وَسَطِ السَّرِيرِ فَقَالَ لَهُ الْعَلاَءُ بْنُ زِيَادٍ يَا أَبَا حَمْزَةَ هَكَذَا رَأَيْتَ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَامَ مِنَ الْجِنَازَةِ مُقَامَكَ مِنَ الرَّجُلِ وَقَامَ مِنَ الْمَرْأَةِ مُقَامَكَ مِنَ الْمَرْأَةِ قَالَ نَعَمْ ‏.‏ فَأَقْبَلَ عَلَيْنَا فَقَالَ احْفَظُوا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المسافرین ۱۶ (۷۳۰)،(تحفة الأشراف:۱۶۲۰۵)، وقد أخرجہ: سنن ابی داود/الصلاة ۱۷۹ (۹۵۵)، سنن الترمذی/الصلاة ۱۵۸ (۳۷۵)، سنن النسائی/ قیام اللیل ۱۶ (۱۶۴۷)، مسند احمد (۶/۲۶۲،۳۶۵),1228,It was\nnarrated that Abu Ghalib said:,Chapters Regarding Funerals
1229,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ عُثْمَانَ، عَنِ الْحَكَمِ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَرَأَ عَلَى الْجِنَازَةِ بِفَاتِحَةِ الْكِتَابِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۸۳۷)، وقد أخرجہ: صحیح مسلم/المسافرین ۱۶ ۷۳۵)، سنن ابی داود/الصلاة ۱۷۹ (۹۵۰)، سنن النسائی/قیام اللیل ۱۸ (۱۶۶۰)، موطا امام مالک/صلاة الجماعة ۶ (۱۹)، مسند احمد (۲/۱۶۲)، سنن الدارمی/الصلاة ۱۰۸ (۱۴۲۴),1229,,Chapters Regarding Funerals
1230,حَدَّثَنَا عَمْرُو بْنُ أَبِي عَاصِمٍ النَّبِيلُ، وَإِبْرَاهِيمُ بْنُ الْمُسْتَمِرِّ، قَالاَ حَدَّثَنَا أَبُو عَاصِمٍ، حَدَّثَنَا حَمَّادُ بْنُ جَعْفَرٍ الْعَبْدِيُّ، حَدَّثَنِي شَهْرُ بْنُ حَوْشَبٍ، حَدَّثَتْنِي أُمُّ شَرِيكٍ الأَنْصَارِيَّةُ، قَالَتْ أَمَرَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ نَقْرَأَ عَلَى الْجِنَازَةِ بِفَاتِحَةِ الْكِتَابِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۲۹، ومصباح الزجاجة:۴۳۲)، وقد أخرجہ: مسند احمد (۳/۲۱۴،۲۴۰),1230,Umm\nSharik Al-Ansari said:,Chapters Regarding Funerals
1231,"حَدَّثَنَا أَبُو عُبَيْدٍ، مُحَمَّدُ بْنُ عُبَيْدِ بْنِ مَيْمُونٍ الْمَدِينِيُّ حَدَّثَنَا مُحَمَّدُ بْنُ سَلَمَةَ الْحَرَّانِيُّ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ مُحَمَّدِ بْنِ إِبْرَاهِيمَ بْنِ الْحَارِثِ التَّيْمِيِّ، عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ إِذَا صَلَّيْتُمْ عَلَى الْمَيِّتِ فَأَخْلِصُوا لَهُ الدُّعَاءَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/تقصیرالصلاة ۱۷ (۱۱۱۵)،۱۸ (۱۱۱۶)،۱۹ (۱۱۱۸)، سنن ابی داود/الصلاة ۱۷۹ (۹۵۱)، سنن الترمذی/الصلاة ۱۵۸ (۳۷۱)، سنن النسائی/ قیام اللیل ۱۹ (۱۶۶۱)،(تحفة الأشراف:۱۰۸۳۱)، وقد أخرجہ: مسند احمد (۴/۴۳۳،۴۳۵،۴۴۲،۴۴۳),,It was\nnarrated that Abu Hurairah said:,Chapters Regarding Funerals
1232,"حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ مُحَمَّدِ بْنِ إِبْرَاهِيمَ، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِذَا صَلَّى عَلَى جِنَازَةٍ يَقُولُ ‏ ‏ اللَّهُمَّ اغْفِرْ لِحَيِّنَا وَمَيِّتِنَا وَشَاهِدِنَا وَغَائِبِنَا وَصَغِيرِنَا وَكَبِيرِنَا وَذَكَرِنَا وَأُنْثَانَا اللَّهُمَّ مَنْ أَحْيَيْتَهُ مِنَّا فَأَحْيِهِ عَلَى الإِسْلاَمِ وَمَنْ تَوَفَّيْتَهُ مِنَّا فَتَوَفَّهُ عَلَى الإِيمَانِ اللَّهُمَّ لاَ تَحْرِمْنَا أَجْرَهُ وَلاَ تُضِلَّنَا بَعْدَهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الأذان ۳۹ (۶۶۴)،۶۷ (۷۱۲)،۶۸ (۷۱۳)، صحیح مسلم/الصلاة ۲۲ (۴۱۸)، ن الکبري/الأمانة ۴۰ (۹۰۷)،(تحفة الأشراف:۱۵۹۴۵)، وقد أخرجہ: موطا امام مالک/قصرالصلاة ۲۴ (۸۳)، مسند احمد (۵/۲۶۱،۶/۲۱۰،۲۲۴)، سنن الدارمی/المقدمة ۱۴ (۸۳),,It was\nnarrated that Abu Hurairah said:,Chapters Regarding Funerals
1233,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا مَرْوَانُ بْنُ جَنَاحٍ، حَدَّثَنِي يُونُسُ بْنُ مَيْسَرَةَ بْنِ حَلْبَسٍ، عَنْ وَاثِلَةَ بْنِ الأَسْقَعِ، قَالَ: صَلَّى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَلَى رَجُلٍ مِنَ الْمُسْلِمِينَ فَأَسْمَعُهُ يَقُولُ ‏ ‏ اللَّهُمَّ إِنَّ فُلاَنَ بْنَ فُلاَنٍ فِي ذِمَّتِكَ وَحَبْلِ جِوَارِكَ فَقِهِ مِنْ فِتْنَةِ الْقَبْرِ وَعَذَابِ النَّارِ وَأَنْتَ أَهْلُ الْوَفَاءِ وَالْحَقِّ فَاغْفِرْ لَهُ وَارْحَمْهُ إِنَّكَ أَنْتَ الْغَفُورُ الرَّحِيمُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الأذان ۴۷ (۶۸۳)، صحیح مسلم/الصلاة ۲۱ (۴۱۸)،(تحفة الأشراف:۱۶۹۷۹)، وقد أخرجہ: مسند احمد (۶/۲۳۱),,It was\nnarrated that Wathilah bin Asqa’ said:,Chapters Regarding Funerals
1234,"حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، حَدَّثَنَا أَبُو دَاوُدَ الطَّيَالِسِيُّ، حَدَّثَنَا فَرَجُ بْنُ الْفَضَالَةِ، حَدَّثَنِي عِصْمَةُ بْنُ رَاشِدٍ، عَنْ حَبِيبِ بْنِ عُبَيْدٍ، عَنْ عَوْفِ بْنِ مَالِكٍ، قَالَ شَهِدْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ صَلَّى عَلَى رَجُلٍ مِنَ الأَنْصَارِ فَسَمِعْتُهُ يَقُولُ ‏ ‏ اللَّهُمَّ صَلِّ عَلَيْهِ وَاغْفِرْ لَهُ وَارْحَمْهُ وَعَافِهِ وَاعْفُ عَنْهُ وَاغْسِلْهُ بِمَاءٍ وَثَلْجٍ وَبَرَدٍ وَنَقِّهِ مِنَ الذُّنُوبِ وَالْخَطَايَا كَمَا يُنَقَّى الثَّوْبُ الأَبْيَضُ مِنَ الدَّنَسِ وَأَبْدِلْهُ بِدَارِهِ دَارًا خَيْرًا مِنْ دَارِهِ وَأَهْلاً خَيْرًا مِنْ أَهْلِهِ وَقِهِ فِتْنَةَ الْقَبْرِ وَعَذَابَ النَّارِ ‏""""‏ ‏.‏ قَالَ عَوْفٌ فَلَقَدْ رَأَيْتُنِي فِي مُقَامِي ذَلِكَ أَتَمَنَّى أَنْ أَكُونَ مَكَانَ ذَلِكَ الرَّجُلِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۷۸۷، ومصباح الزجاجة:۴۳۳),,It was\nnarrated that ‘Awf bin Malik said:,Chapters Regarding Funerals
1235,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، عَنْ حَجَّاجٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ مَا أَبَاحَ لَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَلاَ أَبُو بَكْرٍ وَلاَ عُمَرُ فِي شَىْءٍ مَا أَبَاحُوا فِي الصَّلاَةِ عَلَى الْمَيِّتِ ‏.‏ يَعْنِي لَمْ يُوَقِّتْ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۳۵۸، ومصباح الزجاجة:۴۳۴)، وقد أخرجہ: مسند احمد (۱/۲۳۱،۲۳۲،۳۴۳،۳۵۵،۳۵۶،۳۵۷),1235,It was\nnarrated that Jabir said:,Chapters Regarding Funerals
1236,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَنِ، حَدَّثَنَا خَالِدُ بْنُ إِلْيَاسَ، عَنْ إِسْمَاعِيلَ بْنِ عَمْرِو بْنِ سَعِيدِ بْنِ الْعَاصِ، عَنْ عُثْمَانَ بْنِ عَبْدِ اللَّهِ بْنِ الْحَكَمِ بْنِ الْحَارِثِ، عَنْ عُثْمَانَ بْنِ عَفَّانَ، ‏.‏ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ صَلَّى عَلَى عُثْمَانَ بْنِ مَظْعُونٍ وَكَبَّرَ عَلَيْهِ أَرْبَعًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الطہارة ۲۲ (۲۷۴)، سنن النسائی/الطہارة ۸۷ (۱۰۸)،(تحفة الأشراف:۱۱۴۹۵)، وقد أخرجہ: مسند احمد (۶/ ۲۴۸،۲۵۱،۱۱۲،۱۵۰،۲۱۰،۲۴۸)، سنن الدارمی/الصلاة ۸۱ (۱۳۷۵),1236,,Chapters Regarding Funerals
1237,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِبِيُّ، حَدَّثَنَا الْهَجَرِيُّ، قَالَ صَلَيْتُ مَعَ عَبْدِ اللَّهِ بْنِ أَبِي أَوْفَى الأَسْلَمِيِّ صَاحِبِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ عَلَى جِنَازَةِ ابْنَةٍ لَهُ فَكَبَّرَ عَلَيْهَا أَرْبَعًا فَمَكَثَ بَعْدَ الرَّابِعَةِ شَيْئًا ‏.‏ قَالَ فَسَمِعْتُ الْقَوْمَ يُسَبِّحُونَ بِهِ مِنْ نَوَاحِي الصُّفُوفِ فَسَلَّمَ ثُمَّ قَالَ أَكُنْتُمْ تُرَوْنَ أَنِّي مُكَبِّرٌ خَمْسًا قَالُوا تَخَوَّفْنَا ذَلِكَ ‏.‏ قَالَ لَمْ أَكُنْ لأَفْعَلَ ‏.‏ وَلَكِنْ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَانَ يُكَبِّرُ أَرْبَعًا ثُمَّ يَمْكُثُ سَاعَةً فَيَقُولُ مَا شَاءَ اللَّهُ أَنْ يَقُولَ ثُمَّ يُسَلِّمُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح مسلم/الصلاة ۱۹ (۴۱۲)،(تحفة الأشراف:۱۷۰۶۷)، وقد أخرجہ: صحیح البخاری/الأذان ۵۱ (۶۸۸)، تقصیر الصلاة ۱۷ (۱۱۱۳)،۲۰ (۱۱۱۹)، سنن ابی داود/الصلاة ۶۹ (۶۰۵)، مسند احمد (۶/۱۱۴،۱۶۹),1237,Al-Hajari said:,Chapters Regarding Funerals
1238,حَدَّثَنَا أَبُو هِشَامٍ الرِّفَاعِيُّ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، وَأَبُو بَكْرِ بْنُ خَلاَّدٍ قَالُوا حَدَّثَنَا يَحْيَى بْنُ الْيَمَانِ، عَنِ الْمِنْهَالِ بْنِ خَلِيفَةَ، عَنْ حَجَّاجٍ، عَنْ عَطَاءٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَبَّرَ أَرْبَعًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الصلاة ۱۸ (۳۷۸)، الأذان ۵۱ (۶۸۹)،۸۲ (۷۳۲)،۱۲۸ (۸۰۵)، تقصیرالصلاة ۱۷ (۱۱۱۴)، صحیح مسلم/الصلاة ۱۹ (۴۱۱)، سنن النسائی/الإمامة ۱۶ (۷۹۵)،۴۰ (۸۳۳)، التطبیق ۲۲ (۱۰۶۲)،(تحفة الأشراف:۱۴۸۵)، وقد أخرجہ: سنن ابی داود/الصلاة ۶۹ (۳۶۱)، سنن الترمذی/الصلاة ۱۵۱ (۷۹۳)، موطا امام مالک/الجماعة ۵ (۱۶)، مسند احمد (۳/۱۱۰،۱۶۲)، سنن الدارمی/الصلاة ۴۴ (۱۲۹۱),1238,,Chapters Regarding Funerals
1239,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، ح وَحَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، وَأَبُو دَاوُدَ عَنْ شُعْبَةَ، عَنْ عَمْرِو بْنِ مُرَّةَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي لَيْلَى، قَالَ كَانَ زَيْدُ بْنُ أَرْقَمَ يُكَبِّرُ عَلَى جَنَائِزِنَا أَرْبَعًا وَأَنَّهُ كَبَّرَ عَلَى جِنَازَةٍ خَمْسًا فَسَأَلْتُهُ فَقَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يُكَبِّرُهَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۹۸۸)، وقد أخرجہ: صحیح البخاری/الأذان ۸۲ (۷۳۴)، تقصیر الصلاة ۱۷ (۱۱۱۴)، صحیح مسلم/الصلاة ۱۹ (۴۱۴)، سنن ابی داود/الصلاة ۶۹ (۶۰۳)، مسند احمد (۲/۳۱۴،۲۳۰،۴۱۱،۴۳۸،۴۷۵)، سنن الدارمی/الصلاة ۷۱ (۱۳۵۰),1239,It was\nnarrated that ‘Abdur-Rahman bin Abi Laila said:,Chapters Regarding Funerals
1240,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ عَلِيٍّ الرَّافِعِيُّ، عَنْ كَثِيرِ بْنِ عَبْدِ اللَّهِ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَبَّرَ خَمْسًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الصلاة ۱۹ (۴۱۳)، سنن ابی داود/الصلاة ۶۹ (۶۰۶)، ن السہو ۱۱ (۱۱۹۹)،(تحفة الأشراف:۲۹۰۶)، وقد أخرجہ: مسند احمد (۳/۳۳۴),1240,,Chapters Regarding Funerals
1241,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، قَالَ حَدَّثَنَا سَعِيدُ بْنُ عُبَيْدِ اللَّهِ بْنِ جُبَيْرِ بْنِ حَيَّةَ، حَدَّثَنِي عَمِّي، زِيَادُ بْنُ جُبَيْرٍ حَدَّثَنِي أَبِي جُبَيْرُ بْنُ حَيَّةَ، أَنَّهُ سَمِعَ الْمُغِيرَةَ بْنَ شُعْبَةَ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ الطِّفْلُ يُصَلَّى عَلَيْهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن الترمذی/الصلاة ۱۷۸ (۴۰۲)، سنن النسائی/التطبیق ۳۲ (۱۰۷۹)،(تحفة الأشراف:۴۹۷۶)، وقد أخرجہ: مسند احمد (۳/۴۷۲،۶/۳۹۴),,Abu\nJubair bin Hayyah narrated that he heard Mughirah bin Shu’bah\nsay:,Chapters Regarding Funerals
1242,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الرَّبِيعُ بْنُ بَدْرٍ، حَدَّثَنَا أَبُو الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا اسْتَهَلَّ الصَّبِيُّ صُلِّيَ عَلَيْهِ وَوُرِثَ ‏""""‏ ‏.‏""",Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ (تحفة الأشراف:۱۸۲۱۹، ومصباح الزجاجة:۴۳۵),,It was\nnarrated from Jabir bin ‘Abdullah that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters Regarding Funerals
1243,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْبَخْتَرِيُّ بْنُ عُبَيْدٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ صَلُّوا عَلَى أَطْفَالِكُمْ فَإِنَّهُمْ مِنْ أَفْرَاطِكُمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/المغازي ۲۹ (۴۰۸۹)، صحیح مسلم/المساجد ۵۴ (۶۷۷)، سنن النسائی/التطبیق ۲۷ (۱۰۷۲)،(تحفة الأشراف:۱۳۵۴)، وقد أخرجہ: سنن ابی داود/الصلاة ۳۴۵ (۱۴۴۴)، مسند احمد (۳/۱۱۵،۱۸۰،۲۱۷،۲۶۱),,It was\nnarrated that Abu Hurairah said:,Chapters Regarding Funerals
1244,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ أَبِي خَالِدٍ، قَالَ قُلْتُ لِعَبْدِ اللَّهِ بْنِ أَبِي أَوْفَى رَأَيْتَ إِبْرَاهِيمَ ابْنَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ مَاتَ وَهُوَ صَغِيرٌ وَلَوْ قُضِيَ أَنْ يَكُونَ بَعْدَ مُحَمَّدٍ ـ صلى الله عليه وسلم ـ نَبِيٌّ لَعَاشَ ابْنُهُ وَلَكِنْ لاَ نَبِيَّ بَعْدَهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الأذان ۱۲۸ (۸۰۴)، الاستسقاء ۲ (۱۰۰۶)، الجہاد ۹۸ (۲۹۳۲)، الأنبیاء ۱۹ (۳۳۸۶)، تفسیرآلعمران ۹ (۴۵۶۰)، تفسیرالنساء ۲۱ (۴۵۹۸)، الدعوات ۵۸ (۶۳۹۳)، الإکرا ہ ۱ (۶۹۴۰)، الأدب ۱۱۰ (۶۲۰۰)، صحیح مسلم/المساجد ۵۴ (۶۷۵)، سنن النسائی/التطبیق ۲۷ (۱۰۷۴)،(تحفة الأشراف:۱۳۱۳۲)، وقد أخرجہ: سنن ابی داود/الصلاة ۳۴۵ (۱۴۴۲)، مسند احمد (۲/۲۳۹،۲۵۵،۲۷۱،۴۱۸،۴۷۰،۵۰۷،۵۲۱)، سنن الدارمی/الصلاة ۲۱۶ (۱۶۳۶),1244,Isma’il\nbin Abu Khalid said:,Chapters Regarding Funerals
1245,"حَدَّثَنَا عَبْدُ الْقُدُّوسِ بْنُ مُحَمَّدٍ، حَدَّثَنَا دَاوُدُ بْنُ شَبِيبٍ الْبَاهِلِيُّ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ عُثْمَانَ، حَدَّثَنَا الْحَكَمُ بْنُ عُتَيْبَةَ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ لَمَّا مَاتَ إِبْرَاهِيمُ ابْنُ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ صَلَّى عَلَيْهِ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَقَالَ ‏ ‏ إِنَّ لَهُ مُرْضِعًا فِي الْجَنَّةِ وَلَوْ عَاشَ لَكَانَ صِدِّيقًا نَبِيًّا ‏.‏ وَلَوْ عَاشَ لَعَتَقَتْ أَخْوَالُهُ الْقِبْطُ وَمَا اسْتُرِقَّ قِبْطِيٌّ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الصلاة ۱۶۹ (۹۲۱)، سنن الترمذی/الصلاة ۱۷۰ (۳۹۰)، سنن النسائی/السہو۱۲ (۱۲۰۳)،(تحفة الأشراف:۱۳۵۱۳)، وقد أخرجہ: مسند احمد (۲/۲۳۳،۲۵۵،۲۷۳،۲۷۵،۲۸۴،۴۹۰)، سنن الدارمی/الصلاة ۱۷۸ (۱۵۴۵),,It was\nnarrated that Ibn ‘Abbas said:,Chapters Regarding Funerals
1246,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عِمْرَانَ، حَدَّثَنَا أَبُو دَاوُدَ، حَدَّثَنَا هِشَامُ بْنُ أَبِي الْوَلِيدِ، عَنْ أُمِّهِ، عَنْ فَاطِمَةَ بِنْتِ الْحُسَيْنِ، عَنْ أَبِيهَا الْحُسَيْنِ بْنِ عَلِيٍّ، قَالَ لَمَّا تُوُفِّيَ الْقَاسِمُ ابْنُ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَتْ خَدِيجَةُ يَا رَسُولَ اللَّهِ دَرَّتْ لُبَيْنَةُ الْقَاسِمِ فَلَوْ كَانَ اللَّهُ أَبْقَاهُ حَتَّى يَسْتَكْمِلَ رَضَاعَهُ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ إِنَّ تَمَامَ رَضَاعِهِ فِي الْجَنَّةِ ‏""‏ ‏.‏ قَالَتْ لَوْ أَعْلَمُ ذَلِكَ يَا رَسُولَ اللَّهِ لَهَوَّنَ عَلَىَّ أَمْرَهُ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ إِنْ شِئْتِ دَعَوْتُ اللَّهَ تَعَالَى فَأَسْمَعَكِ صَوْتَهُ ‏""‏ ‏.‏ قَالَتْ يَا رَسُولَ اللَّهِ بَلْ أُصَدِّقُ اللَّهَ وَرَسُولَهُ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۱۲۵، ومصباح الزجاجة:۴۳۶)، وقد أخرجہ: مسند احمد (۶/۲۵۰),1246,Husain\nbin ‘Ali said:,Chapters Regarding Funerals
1247,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، عَنْ يَزِيدَ بْنِ أَبِي زِيَادٍ، عَنْ مِقْسَمٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ أُتِيَ بِهِمْ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَوْمَ أُحُدٍ فَجَعَلَ يُصَلِّي عَلَى عَشَرَةٍ عَشَرَةٍ وَحَمْزَةُ هُوَ كَمَا هُوَ يُرْفَعُونَ وَهُوَ كَمَا هُوَ مَوْضُوعٌ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۰۲۲، ومصباح الزجاجة:۴۳۷),1247,It was\nnarrated that Ibn ‘Abbas said:,Chapters Regarding Funerals
1248,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنِ ابْنِ شِهَابٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ كَعْبِ بْنِ مَالِكٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَانَ يَجْمَعُ بَيْنَ الرَّجُلَيْنِ وَالثَّلاَثَةِ مِنْ قَتْلَى أُحُدٍ فِي ثَوْبٍ وَاحِدٍ ثُمَّ يَقُولُ ‏""‏ أَيُّهُمْ أَكْثَرُ أَخْذًا لِلْقُرْآنِ ‏""‏ ‏.‏ فَإِذَا أُشِيرَ لَهُ إِلَى أَحَدِهِمْ قَدَّمَهُ فِي اللَّحْدِ وَقَالَ ‏""‏ أَنَا شَهِيدٌ عَلَى هَؤُلاَءِ ‏""‏ ‏.‏ وَأَمَرَ بِدَفْنِهِمْ فِي دِمَائِهِمْ وَلَمْ يُصَلِّ عَلَيْهِمْ وَلَمْ يُغَسَّلُوا ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/المواقیت ۳۰ (۵۸۴)،۳۱ (۵۸۸)، اللباس ۲۰ (۵۸۱۹)، صحیح مسلم/المسافرین ۵۱ (۸۲۵)، سنن النسائی/المواقیت ۳۲ (۵۶۵)،(تحفة الأشراف:۱۲۲۶۵)، وقد أخرجہ: موطا امام مالک/القرآن ۱۰ (۴۸)، مسند احمد (۲/۴۶۲،۴۹۶،۵۱۰،۵۲۹)،(یہ حدیث مکرر ہے، دیکھئے:۲۱۶۹،۳۵۶۰),1248,It was\nnarrated from Jabir bin ‘Abdullah that the Messenger of Allah\n(ﷺ)\nused to put two or three of the slain of Uhud in one shroud. He\nwould\nask:,Chapters Regarding Funerals
1249,حَدَّثَنَا مُحَمَّدُ بْنُ زِيَادٍ، حَدَّثَنَا عَلِيُّ بْنُ عَاصِمٍ، عَنْ عَطَاءِ بْنِ السَّائِبِ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَمَرَ بِقَتْلَى أُحُدٍ أَنْ يُنْزَعَ عَنْهُمُ الْحَدِيدُ وَالْجُلُودُ وَأَنْ يُدْفَنُوا فِي ثِيَابِهِمْ بِدِمَائِهِمْ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/المواقیت ۳۱ (۵۸۶)، الصوم ۶۷ (۱۹۹۵)،(تحفة الأشراف:۴۲۷۹)، وقد أخرجہ: صحیح مسلم/المسافرین۵۱ (۸۲۷)، سنن النسائی/المواقیت ۳۴ (۵۶۸)، مسند احمد (۳/۷،۳۹،۴۶،۵۲،۵۳،۶۰،۶۷،۷۱),1249,,Chapters Regarding Funerals
1250,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَسَهْلُ بْنُ أَبِي سَهْلٍ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الأَسْوَدِ بْنِ قَيْسٍ، سَمِعَ نُبَيْحًا الْعَنَزِيَّ، يَقُولُ سَمِعْتُ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ إِنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَمَرَ بِقَتْلَى أُحُدٍ أَنْ يُرَدُّوا إِلَى مَصَارِعِهِمْ وَكَانُوا نُقِلُوا إِلَى الْمَدِينَةِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/المواقیت۳۰ (۵۸۱)، صحیح مسلم/المسافرین ۵۱ (۸۲۶)، سنن ابی داود/الصلاة ۲۹۹ (۱۲۷۶)، سنن الترمذی/الصلاة۲۰ (۱۸۳)، سنن النسائی/المواقیت ۳۲ (۵۶۳)،(تحفة الأشراف:۱۰۴۹۲)، وقد أخرجہ: مسند احمد (۱/۲۱،۳۹،۵۰،۵۱)، سنن الدارمی/الصلاة ۱۴۲ (۱۴۷۳),1250,It was\nnarrated from Aswad bin Qais that he heard Nubaih Al-‘Anazi\nsay:,Chapters Regarding Funerals
1251,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنِ ابْنِ أَبِي ذِئْبٍ، عَنْ صَالِحٍ، مَوْلَى التَّوْأَمَةِ عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ صَلَّى عَلَى جِنَازَةٍ فِي الْمَسْجِدِ فَلَيْسَ لَهُ شَىْءٌ ‏""""‏ ‏.‏""",Al-Albani: Munkar; Muhammad Fouad Abd al-Baqi: Munkar; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن النسائی/المواقیت ۳۹ (۵۸۵)،(تحفة الأشراف:۱۰۷۶۲)، وقد أخرجہ: صحیح مسلم/المسافرین ۵۲ (۸۳۲)، سنن ابی داود/الصلاة ۲۹۹ (۱۲۷۷)، سنن الترمذی/الدعوات ۱۱۹ (۳۵۷۹)، مسند احمد (۴/۱۱۱،۱۱۴،۳۸۵)،(یہ حدیث مکرر ہے، دیکھئے:۱۳۶۴),,It was\nnarrated that Abu Hurairah said:,Chapters Regarding Funerals
1252,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، حَدَّثَنَا فُلَيْحُ بْنُ سُلَيْمَانَ، عَنْ صَالِحِ بْنِ عَجْلاَنَ، عَنْ عَبَّادِ بْنِ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ، عَنْ عَائِشَةَ، قَالَتْ وَاللَّهِ مَا صَلَّى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَلَى سُهَيْلِ ابْنِ بَيْضَاءَ إِلاَّ فِي الْمَسْجِدِ ‏.‏ قَالَ ابْنُ مَاجَهْ حَدِيثُ عَائِشَةَ أَقْوَى ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۹۶۳، ومصباح الزجاجة:۴۳۸)، ومسند احمد (۵/۳۱۲),1252,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1253,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، ح وَحَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، جَمِيعًا عَنْ مُوسَى بْنِ عُلَىِّ بْنِ رَبَاحٍ، قَالَ سَمِعْتُ أَبِي يَقُولُ، سَمِعْتُ عُقْبَةَ بْنَ عَامِرٍ الْجُهَنِيَّ، يَقُولُ: ثَلاَثُ سَاعَاتٍ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَنْهَانَا أَنْ نُصَلِّيَ فِيهِنَّ أَوْ نَقْبِرَ فِيهِنَّ مَوْتَانَا حِينَ تَطْلُعُ الشَّمْسُ بَازِغَةً، وَحِينَ يَقُومُ قَائِمُ الظَّهِيرَةِ حَتَّى تَمِيلَ الشَّمْسُ، وَحِينَ تَضَيَّفُ لِلْغُرُوبِ حَتَّى تَغْرُبَ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Sahih,takhreej: سنن النسائی/المواقیت ۳۰ (۵۶۰)،(تحفة الأشراف:۹۶۷۸)، موطا امام مالک/القرآن ۱۰ (۴۴)، مسند احمد (۴/۳۴۸،۳۴۹),1253,‘Uqbah\nbin ‘Amir Al-Juhani said:,Chapters Regarding Funerals
1254,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا يَحْيَى بْنُ الْيَمَانِ، عَنْ مِنْهَالِ بْنِ خَلِيفَةَ، عَنْ عَطَاءٍ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَدْخَلَ رَجُلاً قَبْرَهُ لَيْلاً وَأَسْرَجَ فِي قَبْرِهِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/المناسک ۵۳ (۱۸۹۴)، سنن الترمذی/الحج ۴۲ (۸۶۸)، سنن النسائی/المواقیت ۴۰ (۵۸۶)، المناسک والحج ۱۳۷ (۲۹۲۷)،(تحفة الأشراف:۳۱۸۷)، وقد أخرجہ: مسند احمد (۴/۸۰،۸۱)،۸۴، سنن الدارمی/المناسک ۷۹ (۱۹۶۷),1254,,Chapters Regarding Funerals
1255,"حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ الأَوْدِيُّ، حَدَّثَنَا وَكِيعٌ، عَنْ إِبْرَاهِيمَ بْنِ يَزِيدَ الْمَكِّيِّ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَدْفِنُوا مَوْتَاكُمْ بِاللَّيْلِ إِلاَّ أَنْ تُضْطَرُّوا ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: سنن النسائی/الإمامة ۲ (۷۸۰)،(تحفة الأشراف:۹۲۱۱)، وقد أخرجہ: صحیح مسلم/المساجد ۵ (۵۳۴)، نحوہ، سنن ابی داود/الصلاة ۱۰ (۴۳۲)، مسند احمد (۱/۳۷۹،۴۵۵،۴۵۹),,It was\nnarrated from Jabir bin ‘Abdullah that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters Regarding Funerals
1256,"حَدَّثَنَا الْعَبَّاسُ بْنُ عُثْمَانَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، عَنِ ابْنِ لَهِيعَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ صَلُّوا عَلَى مَوْتَاكُمْ بِاللَّيْلِ وَالنَّهَارِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المساجد ۴۱ (۶۴۸)، سنن ابی داود/الصلاة ۱۰ (۴۳۱)، سنن الترمذی/الصلاة ۱۵ (۱۷۶)،(تحفة الأشراف:۱۱۹۵۰)، وقد أخرجہ: سنن النسائی/الإمامة ۲ (۷۷۹،۷۸۰)،۵۵ (۸۶۰)، مسند احمد (۵/۱۶۸،۱۶۹،۱۴۹،۱۵۶،۱۶۳)، سنن الدارمی/الصلاة ۲۵ (۹۱۲۶۴),,It was\nnarrated from Jabir bin ‘Abdullah that the Prophet (ﷺ) said:,Chapters Regarding Funerals
1257,"حَدَّثَنَا أَبُو بِشْرٍ، بَكْرُ بْنُ خَلَفٍ حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ لَمَّا تُوُفِّيَ عَبْدُ اللَّهِ بْنُ أُبَىٍّ جَاءَ ابْنُهُ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ يَا رَسُولَ اللَّهِ أَعْطِنِي قَمِيصَكَ أُكَفِّنْهُ فِيهِ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ آذِنُونِي بِهِ ‏""‏ ‏.‏ فَلَمَّا أَرَادَ النَّبِيُّ ـ صلى الله عليه وسلم ـ أَنْ يُصَلِّيَ عَلَيْهِ قَالَ لَهُ عُمَرُ بْنُ الْخَطَّابِ مَا ذَاكَ لَكَ ‏.‏ فَصَلَّى عَلَيْهِ النَّبِيُّ ـ صلى الله عليه وسلم ـ فَقَالَ لَهُ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ أَنَا بَيْنَ خِيرَتَيْنِ ‏{اسْتَغْفِرْ لَهُمْ أَوْ لاَ تَسْتَغْفِرْ لَهُمْ }‏ ‏""‏ ‏.‏ فَأَنْزَلَ اللَّهُ سُبْحَانَهُ ‏{وَلاَ تُصَلِّ عَلَى أَحَدٍ مِنْهُمْ مَاتَ أَبَدًا وَلاَ تَقُمْ عَلَى قَبْرِهِ}‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/الصلاة ۱۰ (۴۳۳)،(تحفة الأشراف:۵۰۹۷)، وقد أخرجہ: مسند احمد (۱/۳۸۴،۳۸۷،۲/۹۵،۳/۲۴،۲۸،۵/۳۱۵،۳۲۹),1257,It was\nnarrated that Ibn ‘Umar said:,Chapters Regarding Funerals
1258,حَدَّثَنَا عَمَّارُ بْنُ خَالِدٍ الْوَاسِطِيُّ، وَسَهْلُ بْنُ أَبِي سَهْلٍ، قَالاَ حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ مُجَالِدٍ، عَنْ عَامِرٍ، عَنْ جَابِرٍ، قَالَ مَاتَ رَأْسُ الْمُنَافِقِينَ بِالْمَدِينَةِ وَأَوْصَى أَنْ يُصَلِّيَ عَلَيْهِ النَّبِيُّ ـ صلى الله عليه وسلم ـ وَأَنْ يُكَفِّنَهُ فِي قَمِيصِهِ فَصَلَّى عَلَيْهِ وَكَفَّنَهُ فِي قَمِيصِهِ وَقَامَ عَلَى قَبْرِهِ فَأَنْزَلَ اللَّهُ ‏{وَلاَ تُصَلِّ عَلَى أَحَدٍ مِنْهُمْ مَاتَ أَبَدًا وَلاَ تَقُمْ عَلَى قَبْرِهِ}‏ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۸۱۹)وقد أخرجہ: صحیح البخاری/الخوف ۱ (۹۴۳)، صحیح مسلم/المسافرین ۵۷ (۸۳۹)، سنن ابی داود/الصلاة ۲۸۵ (۱۲۴۳)، سنن الترمذی/الصلاة ۲۸۱ (الجمعة ۴۶)(۵۶۴)، سنن النسائی/الخوف (۱۵۳۹)، مسند احمد (۲/۱۴۷),1258,It was\nnarrated that Jabir said:,Chapters Regarding Funerals
1259,"حَدَّثَنَا أَحْمَدُ بْنُ يُوسُفَ السُّلَمِيُّ، حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا الْحَارِثُ بْنُ نَبْهَانَ، حَدَّثَنَا عُتْبَةُ بْنُ يَقْظَانَ، عَنْ أَبِي سَعِيدٍ، عَنْ مَكْحُولٍ، عَنْ وَاثِلَةَ بْنِ الأَسْقَعِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ صَلُّوا عَلَى كُلِّ مَيِّتٍ وَجَاهِدُوا مَعَ كُلِّ أَمِيرٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/المغازي ۳۲ (۴۱۳۱)، صحیح مسلم/المسافرین ۵۷ (۸۴۱)، سنن ابی داود/الصلاة ۲۸۲ (۱۲۳۷)،۲۸۳،(۱۲۳۹)، سنن الترمذی/الصلاة ۲۸۱ (الجمعة ۴۶)(۵۶۶)، سنن النسائی/الخوف (۱۵۳۷)،(تحفة الأشراف:۴۶۴۵)، وقد أخرجہ: موطا امام مالک/صلاة الخوف ۱ (۲)، مسند احمد (۳/۴۴۸)، سنن الدارمی/الصلاة ۱۸۵ (۱۵۶۳),,It was\nnarrated from Wathilah bin Asqa’ that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters Regarding Funerals
1260,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَامِرِ بْنِ زُرَارَةَ، حَدَّثَنَا شَرِيكُ بْنُ عَبْدِ اللَّهِ، عَنْ سِمَاكِ بْنِ حَرْبٍ، عَنْ جَابِرِ بْنِ سَمُرَةَ، أَنَّ رَجُلاً، مِنْ أَصْحَابِ النَّبِيِّ ـ صلى الله عليه وسلم ـ جُرِحَ فَآذَتْهُ الْجِرَاحَةُ فَدَبَّ إِلَى مَشَاقِصِهِ فَذَبَحَ بِهِ نَفْسَهُ فَلَمْ يُصَلِّ عَلَيْهِ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏.‏ قَالَ وَكَانَ ذَلِكَ أَدَبًا مِنْهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۶۷۳، ومصباح الزجاجة:۴۴۰)، وقد أخرجہ: صحیح البخاری/ المغازي ۳۱ (۴۱۳۰)، صحیح مسلم/المسافرین ۵۷ (۸۴۰)، سنن ابی داود/الصلاة (تعلیقا)۲۸۱ (۱۲۸۶)، سنن النسائی/صلاة الخوف (۱۹۳۶)، مسند احمد (۳/۲۹۸),1260,,Chapters Regarding Funerals
1261,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، أَنْبَأَنَا حَمَّادُ بْنُ زَيْدٍ، حَدَّثَنَا ثَابِتٌ، عَنْ أَبِي رَافِعٍ، عَنْ أَبِي هُرَيْرَةَ، ‏.‏ أَنَّ امْرَأَةً، سَوْدَاءَ كَانَتْ تَقُمُّ الْمَسْجِدَ فَفَقَدَهَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَسَأَلَ عَنْهَا بَعْدَ أَيَّامٍ فَقِيلَ لَهُ إِنَّهَا مَاتَتْ ‏.‏ قَالَ ‏ ‏ فَهَلاَّ آذَنْتُمُونِي ‏""""‏ ‏.‏ فَأَتَى قَبْرَهَا فَصَلَّى عَلَيْهَا ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الکسوف ۱ (۱۰۴۱)،۱۲ (۱۰۵۷)، بدأالخلق ۴ (۳۲۰۴)، صحیح مسلم/الکسوف ۵ (۹۱۱)، سنن النسائی/الکسوف ۴ (۱۴۶۳)،(تحفة الأشراف:۱۰۰۰۳)، وقد أخرجہ: مسند احمد (۴/۱۲۲)، سنن الدارمی/الصلاة ۱۸۷ (۱۵۶۶),,It was\nnarrated from Abu Hurairah that a black woman used to sweep\nthe\nmosque. The Messenger of Allah (ﷺ) noticed she was missing and\nhe\nasked about her after a few days. He was told that she had died. He\nsaid:,Chapters Regarding Funerals
1262,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا هُشَيْمٌ، حَدَّثَنَا عُثْمَانُ بْنُ حَكِيمٍ، حَدَّثَنَا خَارِجَةُ بْنُ زَيْدِ بْنِ ثَابِتٍ، عَنْ يَزِيدَ بْنِ ثَابِتٍ، وَكَانَ، أَكْبَرَ مِنْ زَيْدٍ قَالَ خَرَجْنَا مَعَ النَّبِيِّ ـ صلى الله عليه وسلم ـ فَلَمَّا وَرَدَ الْبَقِيعَ فَإِذَا هُوَ بِقَبْرٍ جَدِيدٍ فَسَأَلَ عَنْهُ فَقَالُوا فُلاَنَةُ ‏.‏ قَالَ فَعَرَفَهَا وَقَالَ ‏""‏ أَلاَ آذَنْتُمُونِي بِهَا ‏""‏ ‏.‏ قَالُوا كُنْتَ قَائِلاً صَائِمًا فَكَرِهْنَا أَنْ نُؤْذِيَكَ ‏.‏ قَالَ ‏""‏ فَلاَ تَفْعَلُوا لاَ أَعْرِفَنَّ مَا مَاتَ فِيكُمْ مَيِّتٌ مَا كُنْتُ بَيْنَ أَظْهُرِكُمْ إِلاَّ آذَنْتُمُونِي بِهِ فَإِنَّ صَلاَتِي عَلَيْهِ لَهُ رَحْمَةٌ ‏""‏ ‏.‏ ثُمَّ أَتَى الْقَبْرَ فَصَفَّنَا خَلْفَهُ فَكَبَّرَ عَلَيْهِ أَرْبَعًا ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الصلاة ۲۶۸ (۱۱۹۳)، سنن النسائی/الکسوف ۱۶ (۱۴۸۶)،(تحفة الأشراف:۱۱۶۳۱)، وقد أخرجہ: مسند احمد (۴/۲۶۷،۲۶۹،۲۷۱،۲۷۷),1262,"Kharijah\nbin Zaid bin Thabit narrated that Yazid bin Thabit, who was\nolder\nthan Zaid, said:",Chapters Regarding Funerals
1263,"حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِيُّ، عَنْ مُحَمَّدِ بْنِ زَيْدِ بْنِ الْمُهَاجِرِ بْنِ قُنْفُذٍ، عَنْ عَبْدِ اللَّهِ بْنِ عَامِرِ بْنِ رَبِيعَةَ، عَنْ أَبِيهِ، أَنَّ امْرَأَةً، سَوْدَاءَ مَاتَتْ و لَمْ يُؤْذَنْ بِهَا النَّبِيُّ ـ صلى الله عليه وسلم ـ فَأُخْبِرَ بِذَلِكَ فَقَالَ ‏""‏ هَلاَّ آذَنْتُمُونِي بِهَا ‏""‏ ‏.‏ ثُمَّ قَالَ لأَصْحَابِهِ ‏""‏ صُفُّوا عَلَيْهَا ‏""‏ ‏.‏ فَصَلَّى عَلَيْهَا ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الکسوف ۴ (۱۰۴۶)،۵ (۱۰۴۷)،۱۳ (۱۰۵۸)، العمل في الصلاة ۱۱ (۱۲۱۲)، بدأالخلق ۴ (۳۲۰۳)، صحیح مسلم/الکسوف ۱ (۹۰۱)، سنن ابی داود/الصلاة ۲۶۲ (۱۱۸۰)، سنن النسائی/الکسوف ۱۱ (۱۴۷۶)،(تحفة الأشراف:۱۶۶۹۲)، وقد أخرجہ: موطا امام مالک/الکسوف ۱ (۱)، مسند احمد (۶/۷۶،۸۷،۱۶۴،۱۶۸)، سنن الدارمی/الصلاة ۱۸۷ (۱۵۷۰),1263,"It was\nnarrated from ‘Abdullah bin ‘Amir bin Rabi’ah, from his\nfather,\nthat a black woman died and the Prophet (ﷺ) was not told\nabout\nthat. Then he was informed of it, and he said:",Chapters Regarding Funerals
1264,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنْ أَبِي إِسْحَاقَ الشَّيْبَانِيِّ، عَنِ الشَّعْبِيِّ، عَنِ ابْنِ عَبَّاسٍ، قَالَ مَاتَ رَجُلٌ وَكَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَعُودُهُ. فَدَفَنُوهُ بِاللَّيْلِ. فَلَمَّا أَصْبَحَ أَعْلَمُوهُ. فَقَالَ ‏ ‏ مَا مَنَعَكُمْ أَنْ تُعْلِمُونِي ‏""""‏ ‏.‏ قَالُوا كَانَ اللَّيْلُ وَكَانَتِ الظُّلْمَةُ فَكَرِهْنَا أَنْ نَشُقَّ عَلَيْكَ ‏.‏ فَأَتَى قَبْرَهُ، فَصَلَّى عَلَيْهِ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الصلاة ۲۶۲ (۱۱۸۴)، سنن الترمذی/الصلاة ۲۸۰ (۵۶۲)سنن النسائی/الکسوف ۱۹ (۱۴۹۶)،(تحفة الأشراف:۴۵۷۳)، وقد أخرجہ: مسند احمد (۵/۱۴،۱۶،۱۷،۱۹،۲۳),,It was\nnarrated that Ibn ‘Abbas said:,Chapters Regarding Funerals
1265,حَدَّثَنَا الْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ الْعَنْبَرِيُّ، وَمُحَمَّدُ بْنُ يَحْيَى، قَالاَ حَدَّثَنَا أَحْمَدُ بْنُ حَنْبَلٍ، حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَةَ، عَنْ حَبِيبِ بْنِ الشَّهِيدِ، عَنْ ثَابِتٍ، عَنْ أَنَسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ صَلَّى عَلَى قَبْرٍ بَعْدَ مَا قُبِرَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/الأذان ۹۰ (۷۴۹)، سنن النسائی/الکسوف ۲۱ (۱۴۹۹)،(تحفة الأشراف:۱۵۷۱۷)، وقد أخرجہ: موطا امام مالک/الکسوف ۲ (۴)، مسند احمد (۶/۳۱۵),1265,,Chapters Regarding Funerals
1266,حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ، حَدَّثَنَا مِهْرَانُ بْنُ أَبِي عُمَرَ، عَنْ أَبِي سِنَانٍ، عَنْ عَلْقَمَةَ بْنِ مَرْثَدٍ، عَنِ ابْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ صَلَّى عَلَى مَيِّتٍ بَعْدَ مَا دُفِنَ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الصلاة ۲۵۸ (۱۱۶۵)، سنن الترمذی/الصلاة ۲۷۸ (الجمعة۴۳)(۵۵۸،۵۵۹)، سنن النسائی/الاستسقاء ۳ (۱۵۰۷)،۴ (۱۵۰۹)،۱۳ (۱۵۲۲)،(تحفة الأشراف:۵۳۵۹)، وقد أخرجہ: مسند احمد (۱/۲۳۰،۲۶۰،۳۵۵),1266,,Chapters Regarding Funerals
1267,"حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا سَعِيدُ بْنُ شُرَحْبِيلَ، عَنِ ابْنِ لَهِيعَةَ، عَنْ عُبَيْدِ اللَّهِ بْنِ الْمُغِيرَةِ، عَنْ أَبِي الْهَيْثَمِ، عَنْ أَبِي سَعِيدٍ، قَالَ كَانَتْ سَوْدَاءُ تَقُمُّ الْمَسْجِدَ فَتُوُفِّيَتْ لَيْلاً فَلَمَّا أَصْبَحَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أُخْبِرَ بِمَوْتِهَا فَقَالَ ‏ ‏ أَلاَ آذَنْتُمُونِي بِهَا ‏""""‏ ‏.‏ فَخَرَجَ بِأَصْحَابِهِ فَوَقَفَ عَلَى قَبْرِهَا فَكَبَّرَ عَلَيْهَا وَالنَّاسُ مِنْ خَلْفِهِ وَدَعَا لَهَا ثُمَّ انْصَرَفَ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الاستسقاء ۱ (۱۰۰۵)،۴ (۱۰۱۱)،۱۵ (۱۰۲۳)،۱۶ (۱۰۲۴)،۱۷ (۱۰۲۵)،۱۸ (۱۰۲۶)،۱۹ (۱۰۲۷)،۲۰ (۱۰۲۸)، الدعوات ۲۵ (۶۳۴۳)، صحیح مسلم/الاستسقاء ۱ (۸۹۴)، سنن ابی داود/الصلاة ۲۵۸ (۱۱۶۱)،۲۵۹ (۱۱۶۶)، سنن الترمذی/الصلاة ۲۷۸ (الجمعة ۴۳)(۵۵۶)، سنن النسائی/الاستسقاء ۲ (۱۵۰۶)،۳ (۱۵۰۸)،۵ (۱۵۱۰)،۶ (۱۵۱۱)،۷ (۱۵۱۲)،۸ (۱۵۱۳)،۱۲ (۱۵۲۱)،۱۴ (۱۵۲۳)،(تحفة الأشراف:۵۲۹۷)، وقد أخرجہ: موطا امام مالک/ صلاةالإستسقاء ۱ (۱)مسند احمد (۴/۳۹،۴۰،۴۱،۴۲)، سنن الدارمی/الصلاة ۱۸۸ (۱۵۷۴),,It was\nnarrated that Abu Sa’eed said:,Chapters Regarding Funerals
1268,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الأَعْلَى، عَنْ مَعْمَرٍ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ النَّجَاشِيَّ قَدْ مَاتَ ‏""""‏ ‏.‏ فَخَرَجَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَأَصْحَابُهُ إِلَى الْبَقِيعِ ‏.‏ فَصَفَّنَا خَلْفَهُ وَتَقَدَّمَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَكَبَّرَ أَرْبَعَ تَكْبِيرَاتٍ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۲۹۱، ومصباح الزجاجة:۴۴۲)، وقد أخرجہ: مسند احمد (۲/۳۲۶),,It was\nnarrated from Abu Hurairah:,Chapters Regarding Funerals
1269,"حَدَّثَنَا يَحْيَى بْنُ خَلَفٍ، وَمُحَمَّدُ بْنُ زِيَادٍ، قَالاَ حَدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ، ح وَحَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا هُشَيْمٌ، جَمِيعًا عَنْ يُونُسَ، عَنْ أَبِي قِلاَبَةَ، عَنْ أَبِي الْمُهَلَّبِ، عَنْ عِمْرَانَ بْنِ الْحُصَيْنِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ أَخَاكُمُ النَّجَاشِيَّ قَدْ مَاتَ فَصَلُّوا عَلَيْهِ ‏""""‏ ‏.‏ قَالَ فَقَامَ فَصَلَّيْنَا خَلْفَهُ وَإِنِّي لَفِي الصَّفِّ الثَّانِي فَصَلَّى عَلَيْهِ صفَّين‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۱۶۵، ومصباح الزجاجة:۴۴۱،۴۴۳)، وقد أخرجہ: مسند احمد (۴/۲۳۵،۲۳۶),,It was\nnarrated from ‘Imran bin Husain:,Chapters Regarding Funerals
1270,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، حَدَّثَنَا سُفْيَانُ، عَنْ حُمْرَانَ بْنِ أَعْيَنَ، عَنْ أَبِي الطُّفَيْلِ، عَنْ مُجَمِّعِ بْنِ جَارِيَةَ الأَنْصَارِيِّ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ أَخَاكُمُ النَّجَاشِيَّ قَدْ مَاتَ فَقُومُوا فَصَلُّوا عَلَيْهِ ‏""""‏ ‏.‏ فَصَففنَا خَلْفَهُ صَفَّيْنِ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۳۹۲، ومصباح الزجاجة:۴۴۴),,It was\nnarrated from Mujammi’ bin Jariyah Al-Ansari that the\nMessenger of\nAllah (ﷺ) said:,Chapters Regarding Funerals
1271,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنِ الْمُثَنَّى بْنِ سَعِيدٍ، عَنْ قَتَادَةَ، عَنْ أَبِي الطُّفَيْلِ، عَنْ حُذَيْفَةَ بْنِ أَسِيدٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ خَرَجَ بِهِمْ فَقَالَ ‏""‏ صَلُّوا عَلَى أَخٍ لَكُمْ مَاتَ بِغَيْرِ أَرْضِكُمْ ‏""‏ ‏.‏ قَالُوا: مَنْ هُوَ؟ قَالَ: ‏""‏ النَّجَاشِيُّ ‏""‏ ‏.‏",Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۲۲۲، ومصباح الزجاجة:۴۴۵)، وقد أخرجہ: مسند احمد۲/۲۳۵،۳۷۰),1271,It was\nnarrated from Hudhaifah bin Asid that the Prophet (ﷺ) led\nthem out\nand said:,Chapters Regarding Funerals
1272,حَدَّثَنَا سَهْلُ بْنُ أَبِي سَهْلٍ، حَدَّثَنَا مَكِّيُّ بْنُ إِبْرَاهِيمَ أَبُو السَّكَنِ، عَنْ مَالِكٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ صَلَّى عَلَى النَّجَاشِيِّ فَكَبَّرَ أَرْبَعًا ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: صحیح البخاری/الاستسقاء ۳ تعلیقاً وموصولا (۱۰۰۹عقیب حدیث عبد اللہ بن دینار)،(تحفة الأشراف:۶۷۷۵)، وقد أخرجہ: مسند احمد (۲/۹۳),1272,,Chapters Regarding Funerals
1273,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الأَعْلَى، عَنْ مَعْمَرٍ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏""‏ مَنْ صَلَّى عَلَى جِنَازَةٍ فَلَهُ قِيرَاطٌ وَمَنِ انْتَظَرَ حَتَّى يُفْرَغَ مِنْهَا فَلَهُ قِيرَاطَانِ ‏""‏ ‏.‏ قَالُوا وَمَا الْقِيرَاطَانِ قَالَ ‏""‏ مِثْلُ الْجَبَلَيْنِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/العیدین ۱۶ (۹۷۵)،۱۸ (۹۷۷)، الزکاة ۳۳ (۱۴۴۹)، النکاح ۱۲۵ (۵۲۴۹)، اللباس ۵۶ (۵۸۸۰)، الاعتصام ۱۶ (۷۳۲۵)، صحیح مسلم/العیدین (۸۸۴)، سنن ابی داود/الصلاة ۲۴۸ (۱۱۴۲)، سنن النسائی/العیدین ۱۳ (۱۵۷۰)،(تحفة الأشراف:۵۸۸۳)، وقد أخرجہ: مسند احمد (۱/۲۲۰،۲۲۶،۲۴۲،۳۴۵،۳۴۶،۳۵۷،۳۶۸)، سنن الدارمی/الصلاة ۲۱۸ (۱۶۴۴),1273,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters Regarding Funerals
1274,"حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، حَدَّثَنَا سَعِيدٌ، عَنْ قَتَادَةَ، حَدَّثَنِي سَالِمُ بْنُ أَبِي الْجَعْدِ، عَنْ مَعْدَانَ بْنِ أَبِي طَلْحَةَ، عَنْ ثَوْبَانَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ مَنْ صَلَّى عَلَى جِنَازَةٍ فَلَهُ قِيرَاطٌ وَمَنْ شَهِدَ دَفْنَهَا فَلَهُ قِيرَاطَانِ ‏""‏ ‏.‏ قَالَ: فَسُئِلَ نَبِيُّ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الْقِيرَاطِ؟ فَقَالَ ‏""‏ مِثْلُ أُحُدٍ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/العیدین ۸ (۹۶۲)، صحیح مسلم/العیدین (۸۸۴)، سنن ابی داود/الصلاة ۲۵۰ (۱۱۴۷)،(تحفة الأشراف:۵۶۹۸)، وقد أخرجہ: مسند احمد (۱/۲۲۷،۲۴۲،۲۸۵،۳۳۱،۳۴۵،۳۴۶),1274,It was\nnarrated from Thawban that the Messenger of Allah (ﷺ) said:,Chapters Regarding Funerals
1275,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِبِيُّ، عَنْ حَجَّاجِ بْنِ أَرْطَاةَ، عَنْ عَدِيِّ بْنِ ثَابِتٍ، عَنْ زِرِّ بْنِ حُبَيْشٍ، عَنْ أُبَىِّ بْنِ كَعْبٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ صَلَّى عَلَى جِنَازَةٍ فَلَهُ قِيرَاطٌ وَمَنْ شَهِدَهَا حَتَّى تُدْفَنَ فَلَهُ قِيرَاطَانِ وَالَّذِي نَفْسُ مُحَمَّدٍ بِيَدِهِ الْقِيرَاطُ أَعْظَمُ مِنْ أُحُدٍ هَذَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الإیمان ۲۰ (۴۹)، سنن ابی داود/الصلاة ۲۴۸ (۱۱۴۰)، سنن الترمذی/الفتن ۱۱ (۷۱۷۲)، سنن النسائی/الإیمان ۱۷ (۵۰۱۱)،(تحفة الأشراف:۴۰۸۵)، وقد أخرجہ: صحیح البخاری/العیدین ۶ (۹۵۶)، مسند احمد (۳/۱۰،۴۹،۵۲،۵۳،۵۴،۹۲),,It was\nnarrated from Ubayy bin Ka’b that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1276,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنْ عَامِرِ بْنِ رَبِيعَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ ح: وَحَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، عَنْ عَامِرِ بْنِ رَبِيعَةَ، سَمِعَهُ يُحَدِّثُ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ: ‏ ‏ إِذَا رَأَيْتُمُ الْجِنَازَةَ فَقُومُوا لَهَا حَتَّى تُخَلِّفَكُمْ أَوْ تُوضَعَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/العیدین ۸ (۹۶۳)،۱۹ (۹۷۹)، صحیح مسلم/العیدین (۸۸۸)، سنن الترمذی/الصلاة ۲۶۶ (الجمعة ۳۱)(۵۳۱)،(تحفة الأشراف:۷۸۲۳)، وقد أخرجہ: سنن النسائی/العیدین ۸ (۱۵۶۵)، مسند احمد (۲/۱۲،۳۸),,It was\nnarrated from ‘Amir bin Rabi’ah that the Prophet (ﷺ) said:,Chapters Regarding Funerals
1277,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَهَنَّادُ بْنُ السَّرِيِّ، قَالاَ حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ مُرَّ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ بِجِنَازَةٍ فَقَامَ وَقَالَ ‏ ‏ قُومُوا فَإِنَّ لِلْمَوْتِ فَزَعًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۸۲۹، ومصباح الزجاجة:۴۴۶)، وقد أخرجہ: سنن الدارمی/الصلاة ۲۲۰ (۱۶۴۷),,It was\nnarrated that Abu Hurairah said:,Chapters Regarding Funerals
1278,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ شُعْبَةَ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ، عَنْ مَسْعُودِ بْنِ الْحَكَمِ، عَنْ عَلِيِّ بْنِ أَبِي طَالِبٍ، قَالَ قَامَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ لِجِنَازَةٍ فَقُمْنَا حَتَّى جَلَسَ فَجَلَسْنَا ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الصلاة ۲۵۱،(۱۱۵۱)،(تحفة الأشراف:۸۷۲۸)، وقد أخرجہ: مسند احمد (۲/۱۸۰),1278,It was\nnarrated that ‘Ali bin Abu Talib said:,Chapters Regarding Funerals
1279,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَعُقْبَةُ بْنُ مُكْرَمٍ، قَالاَ حَدَّثَنَا صَفْوَانُ بْنُ عِيسَى، حَدَّثَنَا بِشْرُ بْنُ رَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ سُلَيْمَانَ بْنِ جُنَادَةَ بْنِ أَبِي أُمَيَّةَ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِذَا اتَّبَعَ جِنَازَةً لَمْ يَقْعُدْ حَتَّى تُوضَعَ فِي اللَّحْدِ فَعَرَضَ لَهُ حَبْرٌ فَقَالَ هَكَذَا نَصْنَعُ يَا مُحَمَّدُ ‏.‏ فَجَلَسَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَقَالَ ‏ ‏ خَالِفُوهُمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Hasan,takhreej: سنن الترمذی/الجمعة ۳۴ (۵۳۶)،(تحفة الأشراف:۱۰۷۷۴),,It was\nnarrated that ‘Ubadah bin Samit said:,Chapters Regarding Funerals
1280,"حَدَّثَنَا إِسْمَاعِيلُ بْنُ مُوسَى، حَدَّثَنَا شَرِيكُ بْنُ عَبْدِ اللَّهِ، عَنْ عَاصِمِ بْنِ عُبَيْدِ اللَّهِ، عَنْ عَبْدِ اللَّهِ بْنِ عَامِرِ بْنِ رَبِيعَةَ، عَنْ عَائِشَةَ، قَالَتْ فَقَدْتُهُ - تَعْنِي النَّبِيَّ ـ صلى الله عليه وسلم ـ - فَإِذَا هُوَ بِالْبَقِيعِ فَقَالَ ‏ ‏ السَّلاَمُ عَلَيْكُمْ دَارَ قَوْمٍ مُؤْمِنِينَ أَنْتُمْ لَنَا فَرَطٌ وَإِنَّا بِكُمْ لاَحِقُونَ اللَّهُمَّ لاَ تَحْرِمْنَا أَجْرَهُمْ وَلاَ تَفْتِنَّا بَعْدَهُمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/الصلاة ۲۵۱ (۱۱۴۹)،(تحفة الأشراف:۱۶۴۲۵،۱۶۵۴۸)، وقد أخرجہ: مسند احمد (۶/۶۵،۷۰),,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1281,حَدَّثَنَا مُحَمَّدُ بْنُ عَبَّادِ بْنِ آدَمَ، حَدَّثَنَا أَبُو أَحْمَدَ، حَدَّثَنَا سُفْيَانُ، عَنْ عَلْقَمَةَ بْنِ مَرْثَدٍ، عَنْ سُلَيْمَانَ بْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، قَالَ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يُعَلِّمُهُمْ إِذَا خَرَجُوا إِلَى الْمَقَابِرِ. كَانَ قَائِلُهُمْ يَقُولُ: السَّلاَمُ عَلَيْكُمْ أَهْلَ الدِّيَارِ مِنَ الْمُؤْمِنِينَ وَالْمُسْلِمِينَ وَإِنَّا إِنْ شَاءَ اللَّهُ بِكُمْ لاَحِقُونَ نَسْأَلُ اللَّهَ لَنَا وَلَكُمُ الْعَافِيَةَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الجمعة ۱۶ (۸۷۸)، سنن ابی داود/الصلاة ۲۴۲ (۱۱۲۲)، سنن الترمذی/الصلاة۲۶۸ (الجمعة۳۳)(۵۳۳)، سنن النسائی/الجمعة ۳۹ (۱۴۲۵)،(تحفة الأشراف:۱۱۶۱۲)، وقد أخرجہ: موطا امام مالک/الجمعة ۹ (۱۹)، مسند احمد (۴/۲۷۱،۲۷۳،۲۷۶،۲۷۷)، سنن الدارمی/الصلاة ۲۲۱ (۱۶۴۸),1281,It was\nnarrated from Sulaiman bin Buraidah that his father said:,Chapters Regarding Funerals
1282,حَدَّثَنَا مُحَمَّدُ بْنُ زِيَادٍ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ يُونُسَ بْنِ خَبَّابٍ، عَنِ الْمِنْهَالِ بْنِ عَمْرٍو، عَنْ زَاذَانَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، قَالَ خَرَجْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فِي جِنَازَةٍ فَقَعَدَ حِيَالَ الْقِبْلَةِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/العیدین ۳ (۸۹۱)، سنن ابی داود/الصلا ة ۲۵۲ (۱۱۵۴)، سنن الترمذی/الصلاة ۲۶۸ (الجمعة ۳۳)،۵۳۴،۵۳۵)، سنن النسائی/العیدین ۱۱ (۱۵۶۸)،(تحفة الأشراف:۱۵۵۱۳)، وقد أخرجہ: موطا امام مالک/العیدین ۴ (۸)، مسند احمد (۵/۲۱۷،۲۱۸،۲۱۹),1282,It was\nnarrated that Bara’ bin ‘Azib said:,Chapters Regarding Funerals
1283,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنْ عَمْرِو بْنِ قَيْسٍ، عَنِ الْمِنْهَالِ بْنِ عَمْرٍو، عَنْ زَاذَانَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، قَالَ خَرَجْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فِي جِنَازَةٍ فَانْتَهَيْنَا إِلَى الْقَبْرِ فَجَلَسَ وَجَلَسْنَا كَأَنَّ عَلَى رُءُوسِنَا الطَّيْرَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۴۴۷، ومصباح الزجاجة:۴۴۷),1283,It was\nnarrated that Bara’ bin ‘Azib said:,Chapters Regarding Funerals
1284,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنَا لَيْثُ بْنُ أَبِي سُلَيْمٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ ح وَحَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، حَدَّثَنَا الْحَجَّاجُ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ إِذَا أُدْخِلَ الْمَيِّتُ الْقَبْرَ قَالَ ‏""‏ بِسْمِ اللَّهِ وَعَلَى مِلَّةِ رَسُولِ اللَّهِ ‏""‏ ‏.‏ وَقَالَ أَبُو خَالِدٍ مَرَّةً إِذَا وُضِعَ الْمَيِّتُ فِي لَحْدِهِ قَالَ ‏""‏ بِسْمِ اللَّهِ وَعَلَى سُنَّةِ رَسُولِ اللَّهِ ‏""‏ ‏.‏ وَقَالَ هِشَامٌ فِي حَدِيثِهِ ‏""‏ بِسْمِ اللَّهِ وَفِي سَبِيلِ اللَّهِ وَعَلَى مِلَّةِ رَسُولِ اللَّهِ ‏""‏ ‏.‏",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن النسائی/العیدین ۱۶ (۱۵۷۴)،(تحفة الأشراف:۱۲۱۴۲)، وقد أخرجہ: مسند احمد (۴/۳۰۶),1284,It was\nnarrated that Ibn ‘Umar said:,Chapters Regarding Funerals
1285,حَدَّثَنَا عَبْدُ الْمَلِكِ بْنُ مُحَمَّدٍ الرَّقَاشِيُّ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ الْخَطَّابِ، حَدَّثَنَا مِنْدَلُ بْنُ عَلِيٍّ، أَخْبَرَنِي مُحَمَّدُ بْنُ عُبَيْدِ اللَّهِ بْنِ أَبِي رَافِعٍ، عَنْ دَاوُدَ بْنِ الْحُصَيْنِ، عَنْ أَبِيهِ، عَنْ أَبِي رَافِعٍ، قَالَ سَلَّ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ سَعْدًا وَرَشَّ عَلَى قَبْرِهِ مَاءً ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: انظر ما قبلہ،(تحفة الأشراف:۱۲۱۴۲),1285,It was\nnarrated that Abu Rafi’ said:,Chapters Regarding Funerals
1286,حَدَّثَنَا هَارُونُ بْنُ إِسْحَاقَ، حَدَّثَنَا الْمُحَارِبِيُّ، عَنْ عَمْرِو بْنِ قَيْسٍ، عَنْ عَطِيَّةَ، عَنْ أَبِي سَعِيدٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أُخِذَ مِنْ قِبَلِ الْقِبْلَةِ وَاسْتُقْبِلَ اسْتِقْبَالاً وَاسْتُلَّ اسْتِلاَلاً ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الحج ۶۲ (۱۹۱۶)، سنن النسائی/الحج ۱۹۸ (۳۰۱۰)،(تحفة الأشراف:۱۱۵۸۹)، وقد أخرجہ: مسند احمد (۴/ ۳۰۵،۳۰۶),1286,,Chapters Regarding Funerals
1287,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا حَمَّادُ بْنُ عَبْدِ الرَّحْمَنِ الْكَلْبِيُّ، حَدَّثَنَا إِدْرِيسُ الأَوْدِيُّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، قَالَ حَضَرْتُ ابْنَ عُمَرَ فِي جِنَازَةٍ فَلَمَّا وَضَعَهَا فِي اللَّحْدِ قَالَ بِسْمِ اللَّهِ وَفِي سَبِيلِ اللَّهِ وَعَلَى مِلَّةِ رَسُولِ اللَّهِ ‏.‏ فَلَمَّا أُخِذَ فِي تَسْوِيَةِ اللَّبِنِ عَلَى اللَّحْدِ قَالَ اللَّهُمَّ أَجِرْهَا مِنَ الشَّيْطَانِ وَمِنْ عَذَابِ الْقَبْرِ اللَّهُمَّ جَافِ الأَرْضَ عَنْ جَنْبَيْهَا وَصَعِّدْ رُوحَهَا وَلَقِّهَا مِنْكَ رِضْوَانًا ‏.‏ قُلْتُ يَا ابْنَ عُمَرَ أَشَىْءٌ سَمِعْتَهُ مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ أَمْ قُلْتَهُ بِرَأْيِكَ قَالَ إِنِّي إِذًا لَقَادِرٌ عَلَى الْقَوْلِ بَلْ شَىْءٌ سَمِعْتُهُ مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۸۳۰، ومصباح الزجاجة:۴۴۸),1287,It was\nnarrated that Sa’eed bin Musayyab said:,Chapters Regarding Funerals
1288,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا حَكَّامُ بْنُ سَلْمٍ الرَّازِيُّ، قَالَ سَمِعْتُ عَلِيَّ بْنَ عَبْدِ الأَعْلَى، يَذْكُرُ عَنْ أَبِيهِ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اللَّحْدُ لَنَا وَالشَّقُّ لِغَيْرِنَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الحیض ۶ (۳۰۴)، العیدین ۶ (۹۶۴،۹۸۹)، الزکاة ۴۴ (۱۴۳۱)، صحیح مسلم/الایمان ۳۴ (۷۹،۸۰)، العیدین ۹ (۸۴۴)، سنن النسائی/العیدین ۱۹ (۱۵۷۷)،(تحفة الأشراف:۵۵۵۸)، وقد أخرجہ: مسند احمد (۳/۳۶،۵۷),,It was\nnarrated that Ibn ‘Abbas said:,Chapters Regarding Funerals
1289,"حَدَّثَنَا إِسْمَاعِيلُ بْنُ مُوسَى السُّدِّيُّ، حَدَّثَنَا شَرِيكٌ، عَنْ أَبِي الْيَقْظَانِ، عَنْ زَاذَانَ، عَنْ جَرِيرِ بْنِ عَبْدِ اللَّهِ الْبَجَلِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اللَّحْدُ لَنَا وَالشَّقُّ لِغَيْرِنَا ‏""""‏ ‏.‏""",Al-Albani: Munkar; Muhammad Fouad Abd al-Baqi: Munkar; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۶۶۱، ومصباح الزجاجة:۴۴۹),,It was\nnarrated that Jarir bin ‘Abdullah Al-Bajali said:,Chapters Regarding Funerals
1290,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا أَبُو عَامِرٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ جَعْفَرٍ الزُّهْرِيُّ، عَنْ إِسْمَاعِيلَ بْنِ مُحَمَّدِ بْنِ سَعْدٍ، عَنْ عَامِرِ بْنِ سَعْدٍ، عَنْ سَعْدٍ، أَنَّهُ قَالَ: أَلْحِدُوا لِي لَحْدًا وَانْصِبُوا عَلَىَّ اللَّبِنَ نَصْبًا كَمَا فُعِلَ بِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الصلاة ۲۵۳ (۱۱۵۵)، سنن النسائی/العیدین ۱۴ (۱۵۷۲)،(تحفة الأشراف:۵۳۱۵),1290,It was\nnarrated that Sa’d said:,Chapters Regarding Funerals
1291,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا هَاشِمُ بْنُ الْقَاسِمِ، حَدَّثَنَا مُبَارَكُ بْنُ فَضَالَةَ، حَدَّثَنِي حُمَيْدٌ الطَّوِيلُ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ: لَمَّا تُوُفِّيَ النَّبِيُّ ـ صلى الله عليه وسلم ـ كَانَ بِالْمَدِينَةِ رَجُلٌ يَلْحَدُ وَآخَرُ يَضْرَحُ. فَقَالُوا: نَسْتَخِيرُ رَبَّنَا وَنَبْعَثُ إِلَيْهِمَا فَأَيُّهُمَا سَبَقَ تَرَكْنَاهُ ‏.‏ فَأُرْسِلَ إِلَيْهِمَا فَسَبَقَ صَاحِبُ اللَّحْدِ. فَلَحَدُوا لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/العیدین ۸ (۹۶۴)،۲۶ (۹۸۹)، الزکاة ۲۱ (۱۴۳۱)، اللباس ۵۷ (۵۸۸۱)،۵۹ (۵۸۸۳)، صحیح مسلم/العیدین ۲ (۸۸۴)، سنن ابی داود/الصلاة ۲۵۶ (۱۱۵۹)، سنن الترمذی/الصلاة ۲۷۰ (الجمعة ۳۵)(۵۳۷)، سنن النسائی/العیدین ۲۸ (۱۵۸۸)،(تحفة الأشراف:۵۵۵۸)، وقد أخرجہ: مسند احمد (۱/ ۲۸۰،۳۴۰،۳۵۵)، سنن الدارمی/الصلاة ۲۱۹ (۱۶۴۶),1291,It was\nnarrated that Anas bin Malik said:,Chapters Regarding Funerals
1292,حَدَّثَنَا عُمَرُ بْنُ شَبَّةَ بْنِ عُبَيْدَةَ بْنِ زَيْدٍ، حَدَّثَنَا عُبَيْدُ بْنُ طُفَيْلٍ الْمُقْرِئُ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ أَبِي مُلَيْكَةَ الْقُرَشِيُّ، حَدَّثَنَا ابْنُ أَبِي مُلَيْكَةَ، عَنْ عَائِشَةَ، قَالَتْ لَمَّا مَاتَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ اخْتَلَفُوا فِي اللَّحْدِ وَالشَّقِّ حَتَّى تَكَلَّمُوا فِي ذَلِكَ وَارْتَفَعَتْ أَصْوَاتُهُمْ ‏.‏ فَقَالَ: عُمَرُ لاَ تَصْخَبُوا عِنْدَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ حَيًّا وَلاَ مَيِّتًا أَوْ كَلِمَةً نَحْوَهَا ‏.‏ فَأَرْسَلُوا إِلَى الشَّقَّاقِ وَاللاَّحِدِ جَمِيعًا فَجَاءَ اللاَّحِدُ فَلَحَدَ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ثُمَّ دُفِنَ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۷۲۹، ومصباح الزجاجة:۴۵۰)، وقد أخرجہ: مسند احمد (۲/۱۸۰),1292,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1293,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، حَدَّثَنَا مُوسَى بْنُ عُبَيْدَةَ، حَدَّثَنِي سَعِيدُ بْنُ أَبِي سَعِيدٍ، عَنِ الأَدْرَعِ السُّلَمِيِّ، قَالَ جِئْتُ لَيْلَةً أَحْرُسُ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَإِذَا رَجُلٌ قِرَاءَتُهُ عَالِيَةٌ فَخَرَجَ النَّبِيُّ ـ صلى الله عليه وسلم ـ فَقُلْتُ يَا رَسُولَ اللَّهِ هَذَا مُرَاءٍ ‏.‏ قَالَ فَمَاتَ بِالْمَدِينَةِ فَفَرَغُوا مِنْ جِهَازِهِ فَحَمَلُوا نَعْشَهُ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏""‏ ارْفُقُوا بِهِ رَفَقَ اللَّهُ بِهِ إِنَّهُ كَانَ يُحِبُّ اللَّهَ وَرَسُولَهُ ‏""‏ ‏.‏ قَالَ وَحَفَرَ حُفْرَتَهُ فَقَالَ ‏""‏ أَوْسِعُوا لَهُ وَسَّعَ اللَّهُ عَلَيْهِ ‏""‏ ‏.‏ فَقَالَ بَعْضُ أَصْحَابِهِ يَا رَسُولَ اللَّهِ لَقَدْ حَزِنْتَ عَلَيْهِ ‏.‏ فَقَالَ ‏""‏ أَجَلْ إِنَّهُ كَانَ يُحِبُّ اللَّهَ وَرَسُولَهُ ‏""‏ ‏.‏",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۱۸۷، ومصباح الزجاجة:۴۵۱)، وقد أخرجہ: مسند احمد (۳/۴۰),1293,It was\nnarrated that Adra’ As-Sulami said:,Chapters Regarding Funerals
1294,"حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ، حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، حَدَّثَنَا أَيُّوبُ، عَنْ حُمَيْدِ بْنِ هِلاَلٍ، عَنْ أَبِي الدَّهْمَاءِ، عَنْ هِشَامِ بْنِ عَامِرٍ، قَالَ: قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ احْفِرُوا وَأَوْسِعُوا وَأَحْسِنُوا ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۸۳۱، ومصباح الزجاجة:۴۵۲),,It was\nnarrated from Hisham bin ‘Amir that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters Regarding Funerals
1295,حَدَّثَنَا الْعَبَّاسُ بْنُ جَعْفَرٍ، حَدَّثَنَا مُحَمَّدُ بْنُ أَيُّوبَ أَبُو هُرَيْرَةَ الْوَاسِطِيُّ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ كَثِيرِ بْنِ زَيْدٍ، عَنْ زَيْنَبَ بِنْتِ نُبَيْطٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَعْلَمَ قَبْرَ عُثْمَانَ بْنِ مَظْعُونٍ بِصَخْرَةٍ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۷۴۰ و ۸۰۲۰، ومصباح الزجاجة:۴۵۳),1295,,Chapters Regarding Funerals
1296,حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ، وَمُحَمَّدُ بْنُ زِيَادٍ، قَالاَ حَدَّثَنَا عَبْدُ الْوَارِثِ، عَنْ أَيُّوبَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ تَقْصِيصِ الْقُبُورِ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الجمعة ۳۰ (۵۳۰)،(تحفة الأشراف:۱۰۰۴۲),1296,It was\nnarrated that Jabir said:,Chapters Regarding Funerals
1297,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، عَنِ ابْنِ جُرَيْجٍ، عَنْ سُلَيْمَانَ بْنِ مُوسَى، عَنْ جَابِرٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يُكْتَبَ عَلَى الْقَبْرِ شَىْءٌ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۰۲۱، ومصباح الزجاجة:۴۵۴),1297,It was\nnarrated that Jabir said:,Chapters Regarding Funerals
1298,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الرَّقَاشِيُّ، حَدَّثَنَا وُهَيْبٌ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ يَزِيدَ بْنِ جَابِرٍ، عَنِ الْقَاسِمِ بْنِ مُخَيْمِرَةَ، عَنْ أَبِي سَعِيدٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى أَنْ يُبْنَى عَلَى الْقَبْرِ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۸۳۲، ومصباح الزجاجة:۴۵۶),1298,,Chapters Regarding Funerals
1299,حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ، حَدَّثَنَا يَحْيَى بْنُ صَالِحٍ، حَدَّثَنَا سَلَمَةُ بْنُ كُلْثُومٍ، حَدَّثَنَا الأَوْزَاعِيُّ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ صَلَّى عَلَى جِنَازَةٍ ثُمَّ أَتَى قَبْرَ الْمَيِّتِ فَحَثَى عَلَيْهِ مِنْ قِبَلِ رَأْسِهِ ثَلاَثًا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الصلاة ۲۵۴ (۱۱۵۶)،(تحفة الأشراف:۷۷۲۲)، وقد أخرجہ: مسند احمد (۲/۱۰۹),1299,,Chapters Regarding Funerals
1300,"حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ، عَنْ سُهَيْلٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ: قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لأَنْ يَجْلِسَ أَحَدُكُمْ عَلَى جَمْرَةٍ تُحْرِقُهُ خَيْرٌ لَهُ مِنْ أَنْ يَجْلِسَ عَلَى قَبْرٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۰۲۱، ومصباح الزجاجة:۴۵۵),,It was\nnarrated from Abu Hurairah said:,Chapters Regarding Funerals
1301,"حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ بْنِ سَمُرَةَ، حَدَّثَنَا الْمُحَارِبِيُّ، عَنِ اللَّيْثِ بْنِ سَعْدٍ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ أَبِي الْخَيْرِ، مَرْثَدِ بْنِ عَبْدِ اللَّهِ الْيَزَنِيِّ عَنْ عُقْبَةَ بْنِ عَامِرٍ، قَالَ: قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لأَنْ أَمْشِيَ عَلَى جَمْرَةٍ أَوْ سَيْفٍ أَوْ أَخْصِفَ نَعْلِي بِرِجْلِي أَحَبُّ إِلَىَّ مِنْ أَنْ أَمْشِيَ عَلَى قَبْرِ مُسْلِمٍ وَمَا أُبَالِي أَوَسَطَ الْقُبُورِ قَضَيْتُ حَاجَتِي أَوْ وَسَطَ السُّوقِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/العیدین ۲۴ (۹۸۶)، سنن الترمذی/الصلاة ۲۷۲ (الجمعة ۳۷)،(۵۴۱)،(تحفة الأشراف:۱۲۹۳۷)، وقد أخرجہ: مسند احمد (۲/۲۰۹،۳۸۸),,It was\nnarrated from ‘Uqbah bin ‘Amir that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters Regarding Funerals
1302,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا الأَسْوَدُ بْنُ شَيْبَانَ، عَنْ خَالِدِ بْنِ سُمَيْرٍ، عَنْ بَشِيرِ بْنِ نَهِيكٍ، عَنْ بَشِيرِ بْنِ الْخَصَاصِيَةِ، قَالَ بَيْنَمَا أَنَا أَمْشِي، مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ ‏""‏ يَا ابْنَ الْخَصَاصِيَةِ مَا تَنْقِمُ عَلَى اللَّهِ أَصْبَحْتَ تُمَاشِي رَسُولَ اللَّهِ ‏""‏ ‏.‏ فَقُلْتُ يَا رَسُولَ اللَّهِ مَا أَنْقِمُ عَلَى اللَّهِ شَيْئًا كُلُّ خَيْرٍ قَدْ أَتَانِيهِ اللَّهُ ‏.‏ فَمَرَّ عَلَى مَقَابِرِ الْمُسْلِمِينَ فَقَالَ ‏""‏ أَدْرَكَ هَؤُلاَءِ خَيْرًا كَثِيرًا ‏""‏ ‏.‏ ثُمَّ مَرَّ عَلَى مَقَابِرِ الْمُشْرِكِينَ فَقَالَ ‏""‏ سَبَقَ هَؤُلاَءِ خَيْرٌ كَثِيرٌ ‏""‏ ‏.‏ قَالَ فَالْتَفَتَ فَرَأَى رَجُلاً يَمْشِي بَيْنَ الْمَقَابِرِ فِي نَعْلَيْهِ فَقَالَ ‏""‏ يَا صَاحِبَ السِّبْتِيَّتَيْنِ أَلْقِهِمَا ‏""‏ ‏.‏ حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ قَالَ كَانَ عَبْدُ اللَّهِ بْنُ عُثْمَانَ يَقُولُ حَدِيثٌ جَيِّدٌ وَرَجُلٌ ثِقَةٌ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۰۱۷، ومصباح الزجاجة:۱۳۰۲),1302,It was\nnarrated that Bashir bin Khasasiyyah said:,Chapters Regarding Funerals
1303,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ، عَنْ يَزِيدَ بْنِ كَيْسَانَ، عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ: قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ زُورُوا الْقُبُورَ فَإِنَّهَا تُذَكِّرُكُمُ الآخِرَةَ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۰۹۱، و مصباح الزجاجة:۴۵۸)، وقد أخرجہ: مسند احمد (۳/۴۲۲),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1304,حَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعِيدٍ الْجَوْهَرِيُّ، حَدَّثَنَا رَوْحٌ، حَدَّثَنَا بِسْطَامُ بْنُ مُسْلِمٍ، قَالَ سَمِعْتُ أَبَا التَّيَّاحِ، قَالَ سَمِعْتُ ابْنَ أَبِي مُلَيْكَةَ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ رَخَّصَ فِي زِيَارَةِ الْقُبُورِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: صحیح البخاری/العیدین ۱۳ (۹۷۲)،۱۴ (۹۷۳)،(تحفة الأشراف:۷۷۵۷)، وقد أخرجہ: صحیح مسلم/الصلاة ۴۷ (۵۰۱)، سنن ابی داود/الصلاة ۱۰۲ (۶۸۷)، سنن النسائی/العیدین ۹ (۱۵۶۶)، مسند احمد (۲/۹۸،۱۴۵،۱۵۱)، سنن الدارمی/الصلاة ۱۲۴ (۱۴۵۰),1304,,Chapters Regarding Funerals
1305,"حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الأَعْلَى، حَدَّثَنَا ابْنُ وَهْبٍ، أَنْبَأَنَا ابْنُ جُرَيْجٍ، عَنْ أَيُّوبَ بْنِ هَانِئٍ، عَنْ مَسْرُوقِ بْنِ الأَجْدَعِ، عَنِ ابْنِ مَسْعُودٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ كُنْتُ نَهَيْتُكُمْ عَنْ زِيَارَةِ الْقُبُورِ فَزُورُوا الْقُبُورَ فَإِنَّهَا تُزَهِّدُ فِي الدُّنْيَا وَتُذَكِّرُ الآخِرَةَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۰۷۸)، وقد أخرجہ: صحیح البخاری/الصلاة ۹۲ (۴۹۸)، صحیح مسلم/الصلاة ۴۷ (۵۰۱)، سنن ابی داود/الصلاة ۱۰۲ (۶۸۷)، سنن النسائی/القبلة ۴ (۷۴۸)، مسند احمد (۲/۱۳،۱۸،۱۴۲)،(یہ حدیث مکرر ہے، دیکھئے:۹۴۱),,,Chapters Regarding Funerals
1306,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ، حَدَّثَنَا يَزِيدُ بْنُ كَيْسَانَ، عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ زَارَ النَّبِيُّ ـ صلى الله عليه وسلم ـ قَبْرَ أُمِّهِ فَبَكَى وَأَبْكَى مَنْ حَوْلَهُ فَقَالَ: ‏ ‏ اسْتَأْذَنْتُ رَبِّي فِي أَنْ أَسْتَغْفِرَ لَهَا فَلَمْ يَأْذَنْ لِي وَاسْتَأْذَنْتُ رَبِّي فِي أَنْ أَزُورَ قَبْرَهَا فَأَذِنَ لِي فَزُورُوا الْقُبُورَ فَإِنَّهَا تُذَكِّرُكُمُ الْمَوْتَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۵۸، ومصباح الزجاجة:۴۵۹),,It was\nnarrated that Abu Hurairah said:,Chapters Regarding Funerals
1307,"حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ بْنِ الْبَخْتَرِيِّ الْوَاسِطِيُّ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ إِبْرَاهِيمَ بْنِ سَعْدٍ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، قَالَ جَاءَ أَعْرَابِيٌّ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ يَا رَسُولَ اللَّهِ إِنَّ أَبِي كَانَ يَصِلُ الرَّحِمَ وَكَانَ وَكَانَ. فَأَيْنَ هُوَ قَالَ ‏""‏ فِي النَّارِ ‏""‏ ‏.‏ قَالَ فَكَأَنَّهُ وَجَدَ مِنْ ذَلِكَ فَقَالَ يَا رَسُولَ اللَّهِ فَأَيْنَ أَبُوكَ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ حَيْثُمَا مَرَرْتَ بِقَبْرِ كَافِرٍ فَبَشِّرْهُ بِالنَّارِ ‏""‏ ‏.‏ قَالَ فَأَسْلَمَ الأَعْرَابِيُّ بَعْدُ وَقَالَ لَقَدْ كَلَّفَنِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ تَعَبًا مَا مَرَرْتُ بِقَبْرِ كَافِرٍ إِلاَّ بَشَّرْتُهُ بِالنَّارِ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/العیدین ۱ (۸۹۰)، سنن الترمذی/الصلاة ۲۷۱ (۵۳۹)، سنن النسائی/الحیض الاستحاضہ ۲۲ (۳۹۰)، العیدین ۲ (۱۵۵۹)،۳ (۱۵۶۰)،(تحفة الأشراف:۱۸۱۳۶)، وقد أخرجہ: صحیح البخاری/الحیض ۲۳ (۳۲۴)، الصلاة ۲ (۳۵۱)، العیدین ۱۵ (۹۷۴)،۲۰ (۹۸۰)،۲۱ (۹۸۱)، الحج ۸۱ (۱۶۵۲)، سنن ابی داود/الصلاة ۲۴۷ (۱۱۳۶)، مسند احمد (۵/۸۴،۸۵)، سنن الدارمی/الصلاة ۲۲۳ (۱۶۵۰),1307,It was\nnarrated from Salim that his father said:,Chapters Regarding Funerals
1308,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَأَبُو بِشْرٍ قَالاَ حَدَّثَنَا قَبِيصَةُ، ح: وَحَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا عُبَيْدُ بْنُ سَعِيدٍ، ح: وَحَدَّثَنَا مُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلاَنِيُّ، حَدَّثَنَا الْفِرْيَابِيُّ، وَقَبِيصَةُ، كُلُّهُمْ عَنْ سُفْيَانَ، عَنْ عَبْدِ اللَّهِ بْنِ عُثْمَانَ بْنِ خُثَيْمٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ بَهْمَانَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَسَّانَ بْنِ ثَابِتٍ، عَنْ أَبِيهِ، قَالَ: لَعَنَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ زُوَّارَاتِ الْقُبُورِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/العدین ۱۵ (۹۷۴)، مخصراً صحیح مسلم/صلاة العیدین ۱ (۸۹۰)، سنن ابی داود/الصلاة ۲۴۷ (۱۱۳۶،۱۱۳۷)، مطولاً سنن النسائی/صلاة العیدین ۲ (۱۵۵۹)،(تحفة الأشراف:۱۸۰۹۵),1308,It was\nnarrated from ‘Abdur-Rahman bin Hassan bin Thabit that his\nfather\nsaid:,Chapters Regarding Funerals
1309,حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ، حَدَّثَنَا عَبْدُ الْوَارِثِ، حَدَّثَنَا مُحَمَّدُ بْنُ جُحَادَةَ، عَنْ أَبِي صَالِحٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لَعَنَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ زُوَّارَاتِ الْقُبُورِ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ این ماجہ،(تحفة الأشراف:۵۸۱۸، ومصباح الزجاجة:۴۶۰)، وقد أخرجہ: مسند احمد (۱/۲۳۱،۳۵۳),1309,It was\nnarrated that Ibn ‘Abbas said:,Chapters Regarding Funerals
1310,حَدَّثَنَا مُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلاَنِيُّ أَبُو نَصْرٍ، حَدَّثَنَا مُحَمَّدُ بْنُ طَالِبٍ، حَدَّثَنَا أَبُو عَوَانَةَ، عَنْ عُمَرَ بْنِ أَبِي سَلَمَةَ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ: لَعَنَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ زُوَّارَاتِ الْقُبُورِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الصلاة ۲۱۷ (۱۰۷۰)، سنن النسائی/العیدین ۳۱ (۱۵۹۲)،(تحفة الأشراف:۳۶۵۷)، وقد أخرجہ: مسند احمد (۴/۳۷۲)، سنن الدارمی/الصلاة ۲۲۵،(۱۶۵۳),1310,It was\nnarrated that Abu Hurairah said:,Chapters Regarding Funerals
1311,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ هِشَامٍ، عَنْ حَفْصَةَ، عَنْ أُمِّ عَطِيَّةَ، قَالَتْ: نُهِينَا عَنِ اتِّبَاعِ الْجَنَائِزِ، وَلَمْ يُعْزَمْ عَلَيْنَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۴۱۹، ومصباح الزجاجة:۴۶۱),1311,It was\nnarrated that Umm ‘Atiyyah said:,Chapters Regarding Funerals
1312,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، حَدَّثَنَا أَحْمَدُ بْنُ خَالِدٍ، حَدَّثَنَا إِسْرَائِيلُ، عَنْ إِسْمَاعِيلَ بْنِ سَلْمَانَ، عَنْ دِينَارٍ أَبِي عُمَرَ، عَنِ ابْنِ الْحَنَفِيَّةِ، عَنْ عَلِيٍّ، قَالَ خَرَجَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَإِذَا نِسْوَةٌ جُلُوسٌ فَقَالَ ‏""‏ مَا يُجْلِسُكُنَّ ‏""‏ ‏.‏ قُلْنَ نَنْتَظِرُ الْجِنَازَةَ ‏.‏ قَالَ ‏""‏ هَلْ تَغْسِلْنَ ‏""‏ ‏.‏ قُلْنَ لاَ ‏.‏ قَالَ ‏""‏ هَلْ تَحْمِلْنَ ‏""‏ ‏.‏ قُلْنَ لاَ ‏.‏ قَالَ ‏""‏ هَلْ تُدْلِينَ فِيمَنْ يُدْلِي ‏""‏ ‏.‏ قُلْنَ لاَ ‏.‏ قَالَ ‏""‏ فَارْجِعْنَ مَأْزُورَاتٍ غَيْرَ مَأْجُورَاتٍ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۷۷۲، ومصباح الزجاجة:۴۶۲),1312,It was\nnarrated that ‘Ali said:,Chapters Regarding Funerals
1313,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ يَزِيدَ بْنِ عَبْدِ اللَّهِ، مَوْلَى الصَّهْبَاءِ عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ أُمِّ سَلَمَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ ‏{وَلاَ يَعْصِينَكَ فِي مَعْرُوفٍ}‏ قَالَ: ‏""‏ النَّوْحُ ‏""‏ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الصلاة ۲۵۷ (۱۱۶۰)،(تحفة الأشراف:۱۴۱۲۰),1313,It was\nnarrated from Umm Salamah from the Prophet (ﷺ) regarding:,Chapters Regarding Funerals
1314,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ دِينَارٍ، حَدَّثَنَا حَرِيزٌ، مَوْلَى مُعَاوِيَةَ قَالَ خَطَبَ مُعَاوِيَةُ بِحِمْصَ فَذَكَرَ فِي خُطْبَتِهِ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ نَهَى عَنِ النَّوْحِ ‏.‏,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۵۰۸، ومصباح الزجاجة:۴۶۳),1314,"Jarir,\nthe freed slave of Mu’awiyah, said:",Chapters Regarding Funerals
1315,"حَدَّثَنَا الْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ الْعَنْبَرِيُّ، وَمُحَمَّدُ بْنُ يَحْيَى، قَالاَ حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنِ ابْنِ مُعَانِقٍ، عَنْ أَبِي مَالِكٍ الأَشْعَرِيِّ، قَالَ: قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ النِّيَاحَةُ مِنْ أَمْرِ الْجَاهِلِيَّةِ وَإِنَّ النَّائِحَةَ إِذَا مَاتَتْ وَلَمْ تَتُبْ قَطَعَ اللَّهُ لَهَا ثِيَابًا مِنْ قَطِرَانٍ وَدِرْعًا مِنْ لَهَبِ النَّارِ ‏""""‏ ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۵۰۸، ومصباح الزجاجة:۴۶۴),,It was\nnarrated from Abu Malik Ash’ari that the Messenger of Allah\n(ﷺ)\nsaid:,Chapters Regarding Funerals
1316,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، حَدَّثَنَا عُمَرُ بْنُ رَاشِدٍ الْيَمَامِيُّ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ النِّيَاحَةُ عَلَى الْمَيِّتِ مِنْ أَمْرِ الْجَاهِلِيَّةِ فَإِنَّ النَّائِحَةَ إِنْ لَمْ تَتُبْ قَبْلَ أَنْ تَمُوتَ فَإِنَّهَا تُبْعَثُ يَوْمَ الْقِيَامَةِ عَلَيْهَا سَرَابِيلُ مِنْ قَطِرَانٍ ثُمَّ يُعْلَى عَلَيْهَا بِدُرُوعٍ مِنْ لَهَبِ النَّارِ ‏""""‏ ‏.‏""",Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Zubair Ali Zai: Daif,takhreej: رسول اللہ صلی اللہ علیہ وسلم عید الفطر، عید الاضحی اور عرفہ کے دن غسل فرمایا کرتے تھے اور فاکہ رضی اللہ عنہ اپنے اہل و عیال کو ان دنوں میں غسل کا حکم دیا کرتے تھے۔,,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1317,حَدَّثَنَا أَحْمَدُ بْنُ يُوسُفَ، حَدَّثَنَا عُبَيْدُ اللَّهِ، أَنْبَأَنَا إِسْرَائِيلُ، عَنْ أَبِي يَحْيَى، عَنْ مُجَاهِدٍ، عَنِ ابْنِ عُمَرَ، قَالَ: نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ تُتْبَعَ جِنَازَةٌ مَعَهَا رَانَّةٌ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الصلاة ۲۴۶،(۱۱۳۵)،(تحفة الأشراف:۵۲۰۶),1317,It was\nnarrated that Ibn ‘Umar said:,Chapters Regarding Funerals
1318,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، وَعَبْدُ الرَّحْمَنِ، جَمِيعًا عَنْ سُفْيَانَ، عَنْ زُبَيْدٍ، عَنْ إِبْرَاهِيمَ، عَنْ مَسْرُوقٍ، ح وَحَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَأَبُو بَكْرِ بْنُ خَلاَّدٍ قَالاَ: حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا الأَعْمَشُ، عَنْ عَبْدِ اللَّهِ بْنِ مُرَّةَ، عَنْ مَسْرُوقٍ، عَنْ عَبْدِ اللَّهِ، قَالَ: قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لَيْسَ مِنَّا مَنْ شَقَّ الْجُيُوبَ وَضَرَبَ الْخُدُودَ وَدَعَا بِدَعْوَى الْجَاهِلِيَّةِ ‏""""‏ ‏.‏""",Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: انظر حدیث: رقم ۱۱۷۴،(تحفة الأشراف:۶۶۵۲),,It was\nnarrated from ‘Abdullah that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1319,حَدَّثَنَا مُحَمَّدُ بْنُ جَابِرٍ الْمُحَارِبِيُّ، وَمُحَمَّدُ بْنُ كَرَامَةَ، قَالاَ حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ يَزِيدَ بْنِ جَابِرٍ، عَنْ مَكْحُولٍ، وَالْقَاسِمِ، عَنْ أَبِي أُمَامَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ لَعَنَ الْخَامِشَةَ وَجْهَهَا وَالشَّاقَّةَ جَيْبَهَا وَالدَّاعِيَةَ بِالْوَيْلِ وَالثُّبُورِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: سنن الترمذی/الصلاة ۲۰۶ (۴۳۷)، سنن النسائی/قیام اللیل ۲۴ (۱۶۷۲)،(تحفة الأشراف:۸۲۸۸)، وقد أخرجہ: مسند احمد (۲/۱۱۹),1319,,Chapters Regarding Funerals
1320,"حَدَّثَنَا أَحْمَدُ بْنُ عُثْمَانَ بْنِ حَكِيمٍ الأَوْدِيُّ، حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ، عَنْ أَبِي الْعُمَيْسِ، قَالَ سَمِعْتُ أَبَا صَخْرَةَ، يَذْكُرُ عَنْ عَبْدِ الرَّحْمَنِ بْنِ يَزِيدَ، وَأَبِي، بُرْدَةَ قَالاَ: لَمَّا ثَقُلَ أَبُو مُوسَى أَقْبَلَتِ امْرَأَتُهُ أُمُّ عَبْدِ اللَّهِ تَصِيحُ بِرَنَّةٍ فَأَفَاقَ فَقَالَ لَهَا: أَوَ مَا عَلِمْتِ أَنِّي بَرِيءٌ مِمَّنْ بَرِئَ مِنْهُ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَكَانَ يُحَدِّثُهَا أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ: ‏ ‏ أَنَا بَرِيءٌ مِمَّنْ حَلَقَ وَسَلَقَ وَخَرَقَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: حدیث طاوس وسالم: أخرجہ: صحیح مسلم/المسافرین۲۰ (۷۴۹)، سنن النسائی/قیام اللیل۲۴ (۱۶۶۸)،(تحفة الأشراف:۶۸۳۰،۷۰۹۹)، وحدیث عبد اللہ بن دینار عن ابن عمر تفرد بہ ابن ماجہ:(تحفة الأشراف:۷۱۷۶)وقد أخرجہ:صحیح البخاری/الوتر ۱ (۹۹۰)، سنن ابی داود/الصلاة ۳۱۴ (۱۳۲۶)، موطا امام مالک/صلاةاللیل ۳ (۱۳)، مسند احمد (۲/۴۹،۵۴،۶۶)، سنن الدارمی/الصلاة ۱۵۴ (۱۴۹۹)،۱۵۵ (۱۵۰۰),,‘Abdur-Rahman bin Yazid and Abu Burdah said:,Chapters Regarding Funerals
1321,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ وَهْبِ بْنِ كَيْسَانَ، عَنْ مُحَمَّدِ بْنِ عَمْرِو بْنِ عَطَاءٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ كَانَ فِي جِنَازَةٍ فَرَأَى عُمَرُ امْرَأَةً فَصَاحَ بِهَا فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ دَعْهَا يَا عُمَرُ فَإِنَّ الْعَيْنَ دَامِعَةٌ وَالنَّفْسَ مُصَابَةٌ وَالْعَهْدَ قَرِيبٌ ‏""""‏ ‏.‏ حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ، عَنْ حَمَّادِ بْنِ سَلَمَةَ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ وَهْبِ بْنِ كَيْسَانَ، عَنْ مُحَمَّدِ بْنِ عَمْرِو بْنِ عَطَاءٍ، عَنْ سَلَمَةَ بْنِ الأَزْرَقِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ بِنَحْوِهِ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۳۸۰)، وقد أخرجہ: سنن النسائی/الکبرٰي الصلاة ۴۳ (۴۰۵)، سنن ابی داود/الطہارة ۳۰ (۵۸)، مسند احمد (۱/ ۲۱۸)،(یہ حدیث مکرر ہے، دیکھئے:۲۸۸),,,Chapters Regarding Funerals
1322,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِيَادٍ، حَدَّثَنَا عَاصِمٌ الأَحْوَلُ، عَنْ أَبِي عُثْمَانَ، عَنْ أُسَامَةَ بْنِ زَيْدٍ، قَالَ كَانَ ابْنٌ لِبَعْضِ بَنَاتِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ يَقْضِي فَأَرْسَلَتْ إِلَيْهِ أَنْ يَأْتِيَهَا فَأَرْسَلَ إِلَيْهَا أَنَّ ‏""‏ لِلَّهِ مَا أَخَذَ وَلَهُ مَا أَعْطَى وَكُلُّ شَىْءٍ عِنْدَهُ إِلَى أَجَلٍ مُسَمًّى فَلْتَصْبِرْ وَلْتَحْتَسِبْ ‏""‏ ‏.‏ فَأَرْسَلَتْ إِلَيْهِ فَأَقْسَمَتْ عَلَيْهِ فَقَامَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَقُمْتُ مَعَهُ وَمَعَهُ مُعَاذُ بْنُ جَبَلٍ وَأُبَىُّ بْنُ كَعْبٍ وَعُبَادَةُ بْنُ الصَّامِتِ فَلَمَّا دَخَلْنَا نَاوَلُوا الصَّبِيَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ وَرُوحُهُ تَقَلْقَلُ فِي صَدْرِهِ ‏.‏ قَالَ حَسِبْتُهُ قَالَ كَأَنَّهُ شَنَّةٌ ‏.‏ قَالَ فَبَكَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ لَهُ عُبَادَةُ بْنُ الصَّامِتِ: مَا هَذَا يَا رَسُولَ اللَّهِ؟ قَالَ: ‏""‏ الرَّحْمَةُ الَّتِي جَعَلَهَا اللَّهُ فِي بَنِي آدَمَ وَإِنَّمَا يَرْحَمُ اللَّهُ مِنْ عِبَادِهِ الرُّحَمَاءَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/الصلاة ۳۰۲ (۱۲۹۵)، سنن الترمذی/الصلاة ۳۰۱ (۵۹۷)، سنن النسائی/قیام اللیل ۲۴ (۱۶۶۷)،(تحفة الأشراف:۷۳۴۹)، وقد أخرجہ: مسند احمد (۲/۲۶،۵۱)، سنن الدارمی/الصلاة ۱۵۵ (۱۵۰۰),1322,Usamah\nbin Zaid said:,Chapters Regarding Funerals
1323,"حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا يَحْيَى بْنُ سُلَيْمٍ، عَنِ ابْنِ خُثَيْمٍ، عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ أَسْمَاءَ بِنْتِ يَزِيدَ، قَالَتْ لَمَّا تُوُفِّيَ ابْنُ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ إِبْرَاهِيمُ بَكَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ لَهُ الْمُعَزِّي - إِمَّا أَبُو بَكْرٍ وَإِمَّا عُمَرُ - أَنْتَ أَحَقُّ مَنْ عَظَّمَ اللَّهَ حَقَّهُ ‏.‏ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ تَدْمَعُ الْعَيْنُ وَيَحْزَنُ الْقَلْبُ وَلاَ نَقُولُ مَا يُسْخِطُ الرَّبَّ لَوْلاَ أَنَّهُ وَعْدٌ صَادِقٌ وَمَوْعُودٌ جَامِعٌ وَأَنَّ الآخِرَ تَابِعٌ لِلأَوَّلِ لَوَجَدْنَا عَلَيْكَ يَا إِبْرَاهِيمُ أَفْضَلَ مِمَّا وَجَدْنَا وَإِنَّا بِكَ لَمَحْزُونُونَ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Munkar; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الصلاة ۳۰۱ (۱۲۹۰)،(تحفة الأشراف:۱۸۱۰)، وقد أخرجہ: صحیح البخاری/الغسل ۲۱ (۲۸۰)، الصلاة ۴ (۳۵۷)، الجزیة ۹ (۳۱۷۱)، الأدب ۹۴ (۶۱۵۸)، صحیح مسلم/الحیض ۱۶ (۳۳۶)، المسافرین ۱۳ (۳۳۶)، سنن الترمذی/الوتر ۱۵ (۴۷۴)، الاستئذان ۳۴ (۲۷۳۴)، سنن النسائی/الطہارة ۱۴۳ (۲۲۶)، موطا امام مالک/صلاةالضحیٰ ۸ (۲۷)، سنن الدارمی/الصلاة ۱۵۱ (۱۴۹۴),,It was\nnarrated that Asma’ bint Yazid said:,Chapters Regarding Funerals
1324,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا إِسْحَاقُ بْنُ مُحَمَّدٍ الْفَرْوِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عُمَرَ، عَنْ إِبْرَاهِيمَ بْنِ مُحَمَّدِ بْنِ عَبْدِ اللَّهِ بْنِ جَحْشٍ، عَنْ أَبِيهِ، عَنْ حَمْنَةَ بِنْتِ جَحْشٍ، أَنَّهُ قِيلَ لَهَا قُتِلَ أَخُوكِ ‏.‏ فَقَالَتْ رَحِمَهُ اللَّهُ وَإِنَّا لِلَّهِ وَإِنَّا إِلَيْهِ رَاجِعُونَ ‏.‏ قَالُوا قُتِلَ زَوْجُكِ ‏.‏ قَالَتْ وَاحُزْنَاهُ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ لِلزَّوْجِ مِنَ الْمَرْأَةِ لَشُعْبَةً مَا هِيَ لِشَىْءٍ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۳۶۰، ومصباح الزجاجة:۴۶۶),,It was\nnarrated from Hamnah bint Jahsh that it was said to her:,Chapters Regarding Funerals
1325,"حَدَّثَنَا هَارُونُ بْنُ سَعِيدٍ الْمِصْرِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَنْبَأَنَا أُسَامَةُ بْنُ زَيْدٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ مَرَّ بِنِسَاءِ عَبْدِ الأَشْهَلِ يَبْكِينَ هَلْكَاهُنَّ يَوْمَ أُحُدٍ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ لَكِنَّ حَمْزَةَ لاَ بَوَاكِيَ لَهُ ‏""‏ ‏.‏ فَجَاءَ نِسَاءُ الأَنْصَارِ يَبْكِينَ حَمْزَةَ فَاسْتَيْقَظَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ ‏""‏ وَيْحَهُنَّ مَا انْقَلَبْنَ بَعْدُ؟ مُرُوهُنَّ فَلْيَنْقَلِبْنَ وَلاَ يَبْكِينَ عَلَى هَالِكٍ بَعْدَ الْيَوْمِ ‏""‏ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الصلاة ۳۰۲ (۱۲۹۶)،(تحفة الأشراف:۱۱۲۸۸)، وقد أخرجہ: مسند احمد (۴/۱۶۷),1325,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\npassed by\nsome women of ‘Abdul-Ashhal who were weeping for their slain\non the\nDay of Uhud. The Messenger of Allah (ﷺ) said:,Chapters Regarding Funerals
1326,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ، عَنْ إِبْرَاهِيمَ الْهَجَرِيِّ، عَنِ ابْنِ أَبِي أَوْفَى، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الْمَرَاثِي ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۰۹۱)، وقد أخرجہ: صحیح البخاری/الإیمان ۲۸ (۳۷)، لیلة القدر ۱ (۲۰۱۴)، صحیح مسلم/المسافرین ۲۵ (۷۵۹)، سنن ابی داود/الصلاة ۳۱۸ (۱۳۷۱)، سنن الترمذی/الصوم ۱ (۶۸۳)، سنن النسائی/الصیام ۳ (۶۱۰۴)، موطا امام مالک/الصلاة في رمضان ۱ (۲)، مسند احمد (۲/۲۳۲،۲۴۱،۳۸۵،۴۷۳،۵۰۳)، سنن الدارمی/الصوم ۵۴ (۱۸۱۷),1326,It was\nnarrated that Ibn Abi Awfa said:,Chapters Regarding Funerals
1327,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا شَاذَانُ، ح: وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَمُحَمَّدُ بْنُ الْوَلِيدِ، قَالاَ: حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، ح: وَحَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ، حَدَّثَنَا عَبْدُ الصَّمَدِ، وَوَهْبُ بْنُ جَرِيرٍ، قَالُوا: حَدَّثَنَا شُعْبَةُ، عَنْ قَتَادَةَ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنِ ابْنِ عُمَرَ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ: ‏ ‏ الْمَيِّتُ يُعَذَّبُ بِمَا نِيحَ عَلَيْهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/الصلاة ۳۱۸ (۱۳۷۵)، سنن الترمذی/الصوم ۸۱ (۸۰۶)، سنن النسائی/السہو ۱۰۳ (۱۳۶۵)، قیام اللیل ۴ (۱۶۰۶)،(تحفة الأشراف:۱۱۹۰۳)، وقد أخرجہ: مسند احمد (۵/۱۵۹،۱۶۳)، سنن الدارمی/الصوم ۵۴ (۱۸۱۸),,It was\nnarrated from ‘Umar bin Khattab that the Prophet (ﷺ) said:,Chapters Regarding Funerals
1328,"حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِيُّ، حَدَّثَنَا أَسِيدُ بْنُ أَبِي أَسِيدٍ، عَنْ مُوسَى بْنِ أَبِي مُوسَى الأَشْعَرِيِّ، عَنْ أَبِيهِ، ‏.‏ أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏""‏ الْمَيِّتُ يُعَذَّبُ بِبُكَاءِ الْحَىِّ إِذَا قَالُوا وَاعَضُدَاهْ وَاكَاسِيَاهْ ‏.‏ وَانَاصِرَاهْ وَاجَبَلاَهْ وَنَحْوَ هَذَا - يُتَعْتَعُ وَيُقَالُ أَنْتَ كَذَلِكَ أَنْتَ كَذَلِكَ ‏""‏ ‏.‏ قَالَ أَسِيدٌ فَقُلْتُ سُبْحَانَ اللَّهِ إِنَّ اللَّهَ يَقُولُ ‏{وَلاَ تَزِرُ وَازِرَةٌ وِزْرَ أُخْرَى }‏ ‏.‏ قَالَ وَيْحَكَ أُحَدِّثُكَ أَنَّ أَبَا مُوسَى حَدَّثَنِي عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَتَرَى أَنَّ أَبَا مُوسَى كَذَبَ عَلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ أَوْ تَرَى أَنِّي كَذَبْتُ عَلَى أَبِي مُوسَى؟",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن النسائی/الصیام ۲۲ (۲۲۱۰)،(تحفة الأشراف:۹۷۲۹)، وقد أخرجہ: مسند احمد (۱/۱۹۱،۱۹۵),1328,"It was\nnarrated from Asid bin Abu Asid, from Musa bin Abu Musa Ash’ari,\nfrom his father that the Prophet (ﷺ) said:",Chapters Regarding Funerals
1329,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرٍو، عَنِ ابْنِ أَبِي مُلَيْكَةَ، عَنْ عَائِشَةَ، قَالَتْ إِنَّمَا كَانَتْ يَهُودِيَّةٌ مَاتَتْ. فَسَمِعَهُمُ النَّبِيُّ ـ صلى الله عليه وسلم ـ يَبْكُونَ عَلَيْهَا قَالَ: ‏ ‏ فَإِنَّ أَهْلَهَا يَبْكُونَ عَلَيْهَا وَإِنَّهَا تُعَذَّبُ فِي قَبْرِهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۵۵۰)، وقد أخرجہ: صحیح البخاری/التہجد ۱۲ (۱۴۴۲)، بدأالخلق ۱۱ (۳۲۶۹)، صحیح مسلم/المسافرین ۲۸ (۷۷۶)، سنن ابی داود/الصلاة ۳۰۷ (۱۳۰۶)، سنن النسائی/قیام اللیل۵ (۱۶۰۸)، موطا امام مالک/قصرالصلاة ۲۵ (۹۵)، مسند احمد (۲/۲۴۳،۲۵۳),,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1330,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ سَعْدِ بْنِ سِنَانٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ: قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّمَا الصَّبْرُ عِنْدَ الصَّدْمَةِ الأُولَى ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/التہجد ۱۳ (۱۱۴۴)، بدأالخلق ۱۱ (۳۲۷۰)، صحیح مسلم/المسافرین ۲۸ (۷۷۴)، سنن النسائی/قیام اللیل ۵ (۱۶۰۹،۱۶۱۰)،(تحفة الأشراف:۹۲۹۷)، وقد أخرجہ: مسند احمد (۱/۴۷۵،۴۲۷),,It was\nnarrated from Anas bin Malik that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1331,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنَا ثَابِتُ بْنُ عَجْلاَنَ، عَنِ الْقَاسِمِ، عَنْ أَبِي أُمَامَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ: ‏ ‏ يَقُولُ اللَّهُ سُبْحَانَهُ: ابْنَ آدَمَ إِنْ صَبَرْتَ وَاحْتَسَبْتَ عِنْدَ الصَّدْمَةِ الأُولَى لَمْ أَرْضَ لَكَ ثَوَابًا دُونَ الْجَنَّةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/التہجد ۱۹ (۱۱۵۲)، صحیح مسلم/الصیام ۳۵ (۱۱۵۹)، سنن النسائی/قیام اللیل ۵۰ (۱۷۶۴)،(تحفة الأشراف:۸۹۶۱)، وقد أخرجہ: مسند احمد (۲/۱۷۰),,It was\nnarrated from Abu Umamah that the Prophet (ﷺ) said:,Chapters Regarding Funerals
1332,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا عَبْدُ الْمَلِكِ بْنُ قُدَامَةَ الْجُمَحِيُّ، عَنْ أَبِيهِ، عَنْ عُمَرَ بْنِ أَبِي سَلَمَةَ، عَنْ أُمِّ سَلَمَةَ، أَنَّ أَبَا سَلَمَةَ، حَدَّثَهَا أَنَّهُ، سَمِعَ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ: ‏ ‏ مَا مِنْ مُسْلِمٍ يُصَابُ بِمُصِيبَةٍ فَيَفْزَعُ إِلَى مَا أَمَرَ اللَّهُ بِهِ مِنْ قَوْلِهِ: إِنَّا لِلَّهِ وَإِنَّا إِلَيْهِ رَاجِعُونَ اللَّهُمَّ عِنْدَكَ احْتَسَبْتُ مُصِيبَتِي فَأْجُرْنِي فِيهَا وَعُضْنِي مِنْهَا - إِلاَّ آجَرَهُ اللَّهُ عَلَيْهَا وَعَاضَهُ خَيْرًا مِنْهَا ‏""""‏ ‏.‏ قَالَتْ: فَلَمَّا تُوُفِّيَ أَبُو سَلَمَةَ ذَكَرْتُ الَّذِي حَدَّثَنِي عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقُلْتُ: إِنَّا لِلَّهِ وَإِنَّا إِلَيْهِ رَاجِعُونَ اللَّهُمَّ عِنْدَكَ احْتَسَبْتُ مُصِيبَتِي هَذِهِ فَأْجُرْنِي عَلَيْهَا ‏.‏ فَإِذَا أَرَدْتُ أَنْ أَقُولَ وَعُضْنِي خَيْرًا مِنْهَا قُلْتُ فِي نَفْسِي: أُعَاضُ خَيْرًا مِنْ أَبِي سَلَمَةَ ؟ ثُمَّ قُلْتُهَا فَعَاضَنِي اللَّهُ مُحَمَّدًا ـ صلى الله عليه وسلم ـ ‏.‏ وَآجَرَنِي فِي مُصِيبَتِي ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: (تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۰۹۴، ومصباح الزجاجة:۴۶۷),,It was\nnarrated from Umm Salamah that Abu Salamah told her that he\nheard the\nMessenger of Allah (ﷺ) say:,Chapters Regarding Funerals
1333,"حَدَّثَنَا الْوَلِيدُ بْنُ عَمْرِو بْنِ السُّكَيْنِ، حَدَّثَنَا أَبُو هَمَّامٍ، حَدَّثَنَا مُوسَى بْنُ عُبَيْدَةَ، حَدَّثَنَا مُصْعَبُ بْنُ مُحَمَّدٍ، عَنْ أَبِي سَلَمَةَ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ عَائِشَةَ، قَالَتْ فَتَحَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بَابًا بَيْنَهُ وَبَيْنَ النَّاسِ أَوْ كَشَفَ سِتْرًا فَإِذَا النَّاسُ يُصَلُّونَ وَرَاءَ أَبِي بَكْرٍ فَحَمِدَ اللَّهَ عَلَى مَا رَأَى مِنْ حُسْنِ حَالِهِمْ رَجَاءَ أَنْ يَخْلُفَهُ اللَّهُ فِيهِمْ بِالَّذِي رَآهُمْ فَقَالَ ‏ ‏ يَا أَيُّهَا النَّاسُ أَيُّمَا أَحَدٍ مِنَ النَّاسِ أَوْ مِنَ الْمُؤْمِنِينَ أُصِيبَ بِمُصِيبَةٍ فَلْيَتَعَزَّ بِمُصِيبَتِهِ بِي عَنِ الْمُصِيبَةِ الَّتِي تُصِيبُهُ بِغَيْرِي فَإِنَّ أَحَدًا مِنْ أُمَّتِي لَنْ يُصَابَ بِمُصِيبَةٍ بَعْدِي أَشَدَّ عَلَيْهِ مِنْ مُصِيبَتِي ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۳۳۶، ومصباح الزجاجة:۴۶۸),,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1334,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعُ بْنُ الْجَرَّاحِ، عَنْ هِشَامِ بْنِ زِيَادٍ، عَنْ أُمِّهِ، عَنْ فَاطِمَةَ بِنْتِ الْحُسَيْنِ، عَنْ أَبِيهَا، قَالَ قَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ أُصِيبَ بِمُصِيبَةٍ فَذَكَرَ مُصِيبَتَهُ فَأَحْدَثَ اسْتِرْجَاعًا - وَإِنْ تَقَادَمَ عَهْدُهَا - كَتَبَ اللَّهُ لَهُ مِنَ الأَجْرِ مِثْلَهُ يَوْمَ أُصِيبَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: سنن الترمذی/القیامة ۴۲ (۲۴۸۵)،(تحفة الأشراف:۵۳۳۱)، وقد أخرجہ: مسند احمد (۵/۴۵۱)، سنن الدارمی/الصلاة ۱۵۶ (۱۵۰۱)،(حدیث مکرر ہے، دیکھئے:۳۲۵۱),,It was\nnarrated from Fatimah bint Husain that her father said:,Chapters Regarding Funerals
1335,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، حَدَّثَنِي قَيْسٌ أَبُو عُمَارَةَ، مَوْلَى الأَنْصَارِ قَالَ سَمِعْتُ عَبْدَ اللَّهِ بْنَ أَبِي بَكْرِ بْنِ مُحَمَّدِ بْنِ عَمْرِو بْنِ حَزْمٍ، يُحَدِّثُ عَنْ أَبِيهِ، عَنْ جَدِّهِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ أَنَّهُ قَالَ ‏ ‏ مَا مِنْ مُؤْمِنٍ يُعَزِّي أَخَاهُ بِمُصِيبَةٍ إِلاَّ كَسَاهُ اللَّهُ سُبْحَانَهُ مِنْ حُلَلِ الْكَرَامَةِ يَوْمَ الْقِيَامَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الصلاة ۳۰۷ (۱۳۰۹)،(تحفة الأشراف:۳۹۶۵،۱۲۱۹۵),,"Qais,\nAbu ‘Umarah, the freed slave of the Ansar, said:",Chapters Regarding Funerals
1336,"حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، قَالَ حَدَّثَنَا عَلِيُّ بْنُ عَاصِمٍ، عَنْ مُحَمَّدِ بْنِ سُوقَةَ، عَنْ إِبْرَاهِيمَ، عَنِ الأَسْوَدِ، عَنْ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ عَزَّى مُصَابًا فَلَهُ مِثْلُ أَجْرِهِ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الصلاة ۳۰۷ (۱۳۰۸)،۳۴۸ (۱۴۵۰)، سنن النسائی/ قیام اللیل ۵ (۱۶۱۱)،(تحفة الأشراف:۱۲۸۶۰)، وقد أخرجہ: مسند احمد (۲/۲۵۰،۴۳۶),,It was\nnarrated that ‘Abdullah said:,Chapters Regarding Funerals
1337,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ يَمُوتُ لِرَجُلٍ ثَلاَثَةٌ مِنَ الْوَلَدِ فَيَلِجَ النَّارَ إِلاَّ تَحِلَّةَ الْقَسَمِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۹۰۰، ومصباح الزجاجة:۴۶۹)وقد أخرجہ: سنن ابی داود/الصلاة ۳۵۵ (۱۴۶۹),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,Chapters Regarding Funerals
1338,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، قَالَ حَدَّثَنَا إِسْحَاقُ بْنُ سُلَيْمَانَ، حَدَّثَنَا حَرِيزُ بْنُ عُثْمَانَ، عَنْ شُرَحْبِيلَ بْنِ شُفْعَةَ، قَالَ لَقِيَنِي عُتْبَةُ بْنُ عَبْدٍ السُّلَمِيُّ فَقَالَ: سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ: ‏ ‏ مَا مِنْ مُسْلِمٍ يَمُوتُ لَهُ ثَلاَثَةٌ مِنَ الْوَلَدِ لَمْ يَبْلُغُوا الْحِنْثَ إِلاَّ تَلَقَّوْهُ مِنْ أَبْوَابِ الْجَنَّةِ الثَّمَانِيَةِ مِنْ أَيِّهَا شَاءَ دَخَلَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: تفرد بہ، ابن ماجہ،(تحفة الأشراف:۱۶۳۰۳، ومصباح الزجاجة:۴۷۰)، ومسند احمد (۶/۱۶۵),,‘Utbah\nbin ‘Abd Sulami said:,Chapters Regarding Funerals
1339,"حَدَّثَنَا يُوسُفُ بْنُ حَمَّادٍ الْمَعْنِيُّ، حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، عَنْ عَبْدِ الْعَزِيزِ بْنِ صُهَيْبٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا مِنْ مُسْلِمَيْنِ يُتَوَفَّى لَهُمَا ثَلاَثَةٌ مِنَ الْوَلَدِ لَمْ يَبْلُغُوا الْحِنْثَ إِلاَّ أَدْخَلَهُمُ اللَّهُ الْجَنَّةَ بِفَضْلِ رَحْمَةِ اللَّهِ إِيَّاهُمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۶۴۶، ومصباح الزجاجة:۴۷۱),,It was\nnarrated from Anas bin Malik that the Prophet (ﷺ) said:,Chapters Regarding Funerals
1340,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا إِسْحَاقُ بْنُ يُوسُفَ، عَنِ الْعَوَّامِ بْنِ حَوْشَبٍ، عَنْ أَبِي مُحَمَّدٍ، مَوْلَى عُمَرَ بْنِ الْخَطَّابِ عَنْ أَبِي عُبَيْدَةَ، عَنْ عَبْدِ اللَّهِ، قَالَ: قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ مَنْ قَدَّمَ ثَلاَثَةً مِنَ الْوَلَدِ لَمْ يَبْلُغُوا الْحِنْثَ كَانُوا لَهُ حِصْنًا حَصِينًا مِنَ النَّارِ ‏""‏ ‏.‏ فَقَالَ أَبُو ذَرٍّ: قَدَّمْتُ اثْنَيْنِ ‏.‏ قَالَ: ‏""‏ وَاثْنَيْنِ ‏""‏ ‏.‏ فَقَالَ أُبَىُّ بْنُ كَعْبٍ أَبُو الْمُنْذِرِ سَيِّدُ الْقُرَّاءِ: قَدَّمْتُ وَاحِدًا ‏.‏ قَالَ"" ‏""‏ وَوَاحِدًا ‏""‏ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۰۴۰، ومصباح الزجاجة:۴۷۲)، وقد أخرجہ: مسند احمد (۶/۱۹،۲۰),1340,It was\nnarrated from ‘Abdullah that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1341,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، قَالَ حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، حَدَّثَنَا يَزِيدُ بْنُ عَبْدِ الْمَلِكِ النَّوْفَلِيُّ، عَنْ يَزِيدَ بْنِ رُومَانَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لَسِقْطٌ أُقَدِّمُهُ بَيْنَ يَدَىَّ أَحَبُّ إِلَىَّ مِنْ فَارِسٍ أُخَلِّفُهُ خَلْفِي ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۱۱۹، ومصباح الزجاجة:۴۷۳)، وقد أخر جہ: سنن النسائی/الافتتاح ۸۳ (۱۰۲۰)، مسند احمد (۲/۳۵۴،۳۶۹،۴۵۰),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1342,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، وَمُحَمَّدُ بْنُ إِسْحَاقَ أَبُو بَكْرٍ الْبَكَّائِيُّ، قَالاَ حَدَّثَنَا أَبُو غَسَّانَ، قَالَ حَدَّثَنَا مِنْدَلٌ، عَنِ الْحَسَنِ بْنِ الْحَكَمِ النَّخَعِيِّ، عَنْ أَسْمَاءَ بِنْتِ عَابِسِ بْنِ رَبِيعَةَ، عَنْ أَبِيهَا، عَنْ عَلِيٍّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ السِّقْطَ لَيُرَاغِمُ رَبَّهُ إِذَا أَدْخَلَ أَبَوَيْهِ النَّارَ ‏.‏ فَيُقَالُ أَيُّهَا السِّقْطُ الْمُرَاغِمُ رَبَّهُ أَدْخِلْ أَبَوَيْكَ الْجَنَّةَ ‏.‏ فَيَجُرُّهُمَا بِسَرَرِهِ حَتَّى يُدْخِلَهُمَا الْجَنَّةَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/الصلاة ۳۵۵ (۱۴۶۸)، سنن النسائی/الافتتاح ۸۳ (۱۰۱۶)،(تحفة الأشراف:۱۷۷۵)، وقد أخرجہ: صحیح البخاری/التوحید ۵۲ تعلیقًا، مسند احمد (۴/۲۸۳،۲۸۵،۳۰۴)، سنن الدارمی/فضائل القرآن ۳۴ (۳۵۴۳),,It was\nnarrated that ‘Ali said:,Chapters Regarding Funerals
1343,"حَدَّثَنَا عَلِيُّ بْنُ هَاشِمِ بْنِ مَرْزُوقٍ، حَدَّثَنَا عَبِيدَةُ بْنُ حُمَيْدٍ، حَدَّثَنَا يَحْيَى بْنُ عُبَيْدِ اللَّهِ، عَنْ عُبَيْدِ اللَّهِ بْنِ مُسْلِمٍ الْحَضْرَمِيِّ، عَنْ مُعَاذِ بْنِ جَبَلٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ وَالَّذِي نَفْسِي بِيَدِهِ إِنَّ السِّقْطَ لَيَجُرُّ أُمَّهُ بِسَرَرِهِ إِلَى الْجَنَّةِ إِذَا احْتَسَبَتْهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المسافرین ۱۸ (۷۴۷)، سنن ابی داود/الصلاة ۳۰۹ (۱۳۱۳)، سنن الترمذی/الصلاة ۲۹۱ (الجمعة۵۶)(۸۵۱)، سنن النسائی/قیام اللیل۵۶ (۱۷۹۱،۱۷۹۲،۱۷۹۳)،(تحفة الأشراف:۱۰۵۹۲)، وقد أخرجہ: موطا امام مالک/القرآن ۳ (۳)، مسند احمد (۱/۳۲،۵۳)، سنن الدارمی/الصلاة ۱۶۷ (۱۵۱۸),,It was\nnarrated from Mu’adh bin Jabal that the Prophet (ﷺ) said:,Chapters Regarding Funerals
1344,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ جَعْفَرِ بْنِ خَالِدٍ، عَنْ أَبِيهِ، عَنْ عَبْدِ اللَّهِ بْنِ جَعْفَرٍ، قَالَ لَمَّا جَاءَ نَعْىُ جَعْفَرٍ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اصْنَعُوا لآلِ جَعْفَرٍ طَعَامًا. فَقَدْ أَتَاهُمْ مَا يَشْغَلُهُمْ أَوْ أَمْرٌ يَشْغَلُهُمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih,takhreej: سنن النسائی/قیام اللیل ۵۴ (۱۷۸۸)،(تحفة الأشراف:۱۰۹۳۷),,It was\nnarrated that ‘Abdullah bin Ja’far said:,Chapters Regarding Funerals
1345,"حَدَّثَنَا يَحْيَى بْنُ خَلَفٍ أَبُو سَلَمَةَ، قَالَ حَدَّثَنَا عَبْدُ الأَعْلَى، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، حَدَّثَنِي عَبْدُ اللَّهِ بْنُ أَبِي بَكْرٍ، عَنْ أُمِّ عِيسَى الْجَزَّارِ، قَالَتْ حَدَّثَتْنِي أُمُّ عَوْنٍ ابْنَةُ مُحَمَّدِ بْنِ جَعْفَرٍ، عَنْ جَدَّتِهَا، أَسْمَاءَ بِنْتِ عُمَيْسٍ قَالَتْ لَمَّا أُصِيبَ جَعْفَرٌ رَجَعَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِلَى أَهْلِهِ فَقَالَ ‏ ‏ إِنَّ آلَ جَعْفَرٍ قَدْ شُغِلُوا بِشَأْنِ مَيِّتِهِمْ فَاصْنَعُوا لَهُمْ طَعَامًا ‏""""‏ ‏.‏ قَالَ عَبْدُ اللَّهِ فَمَا زَالَتْ سُنَّةً حَتَّى كَانَ حَدِيثًا فَتُرِكَ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الصلاة ۳۲۶ (۱۳۹۳)،(تحفة الأشراف:۱۷۳۷),,Asma’\nbint ‘Umais said:,Chapters Regarding Funerals
1346,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، قَالَ حَدَّثَنَا سَعِيدُ بْنُ مَنْصُورٍ، حَدَّثَنَا هُشَيْمٌ، ح وَحَدَّثَنَا شُجَاعُ بْنُ مَخْلَدٍ أَبُو الْفَضْلِ، قَالَ حَدَّثَنَا هُشَيْمٌ، عَنْ إِسْمَاعِيلَ بْنِ أَبِي خَالِدٍ، عَنْ قَيْسِ بْنِ أَبِي حَازِمٍ، عَنْ جَرِيرِ بْنِ عَبْدِ اللَّهِ الْبَجَلِيِّ، قَالَ كُنَّا نَرَى الاِجْتِمَاعَ إِلَى أَهْلِ الْمَيِّتِ وَصَنْعَةَ الطَّعَامِ مِنَ النِّيَاحَةِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۹۴۵)، وقد أخرجہ: صحیح البخاری/الصوم ۵۴ (۱۹۷۸)، فضائل القرآن ۳۴ (۵۰۵۳،۵۰۵۴)، صحیح مسلم/الصوم ۳۵ (۱۱۵۹)، سنن ابی داود/الصلاة ۳۲۵ (۱۳۸۸)، سنن الترمذی/القراء ات ۱۳ (۲۹۴۶)، سنن النسائی/الصیام ۴۵ (۲۳۹۱،۲۳۹۲)، مسند احمد (۲/۱۶۳،۱۹۹)، سنن الدارمی/فضائل القرآن ۳۲ (۳۵۱۳),1346,It was\nnarrated that Jarir bin ‘Abdullah Al-Bajali said:,Chapters Regarding Funerals
1347,"حَدَّثَنَا جَمِيلُ بْنُ الْحَسَنِ، قَالَ حَدَّثَنَا أَبُو الْمُنْذِرِ الْهُذَيْلُ بْنُ الْحَكَمِ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي رَوَّادٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَوْتُ غُرْبَةٍ شَهَادَةٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/الصلاة ۳۲۶ (۱۳۹۴)، سنن الترمذی/القراء ا ت ۱۳ (۲۹۴۹)،(تحفة الأشراف:۸۹۵۰)، وقد أخرجہ: مسند احمد (۲/۱۶۳،۱۹۹)، سنن الدارمی/الصلاة ۱۷۳ (۱۵۳۴)، فضائل القرآن ۳۲ (۳۵۱۴),,It was\nnarrated from Ibn ‘Abbas that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1348,"حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، قَالَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، حَدَّثَنِي حُيَىُّ بْنُ عَبْدِ اللَّهِ الْمَعَافِرِيُّ، عَنْ أَبِي عَبْدِ الرَّحْمَنِ الْحُبُلِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ تُوُفِّيَ رَجُلٌ بِالْمَدِينَةِ مِمَّنْ وُلِدَ بِالْمَدِينَةِ فَصَلَّى عَلَيْهِ النَّبِيُّ ـ صلى الله عليه وسلم ـ فَقَالَ: ‏""‏ يَا لَيْتَهُ مَاتَ فِي غَيْرِ مَوْلِدِهِ ‏""‏ ‏.‏ فَقَالَ رَجُلٌ مِنَ النَّاسِ وَلِمَ يَا رَسُولَ اللَّهِ؟ قَالَ: ‏""‏ إِنَّ الرَّجُلَ إِذَا مَاتَ فِي غَيْرِ مَوْلِدِهِ قِيسَ لَهُ مِنْ مَوْلِدِهِ إِلَى مُنْقَطَعِ أَثَرِهِ فِي الْجَنَّةِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن النسائی/قیام اللیل ۱۵ (۱۶۴۲)،(تحفة الأشراف:۱۶۱۰۸)، و صحیح مسلم/المسافرین ۱۸ (۷۴۶),1348,It was\nnarrated that ‘Abdullah bin ‘Amr said:,Chapters Regarding Funerals
1349,"حَدَّثَنَا أَحْمَدُ بْنُ يُوسُفَ، قَالَ حَدَّثَنَا عَبْدُ الرَّزَّاقِ، قَالَ أَنْبَأَنَا ابْنُ جُرَيْجٍ، ح وَحَدَّثَنَا أَبُو عُبَيْدَةَ بْنُ أَبِي السَّفَرِ، قَالَ حَدَّثَنَا حَجَّاجُ بْنُ مُحَمَّدٍ، قَالَ قَالَ ابْنُ جُرَيْجٍ أَخْبَرَنِي إِبْرَاهِيمُ بْنُ مُحَمَّدِ بْنِ أَبِي عَطَاءٍ، عَنْ مُوسَى بْنِ وَرْدَانَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ مَاتَ مَرِيضًا مَاتَ شَهِيدًا وَوُقِيَ فِتْنَةَ الْقَبْرِ وَغُدِيَ وَرِيحَ عَلَيْهِ بِرِزْقِهِ مِنَ الْجَنَّةِ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۰۱۶، ومصباح الزجاجة:۴۷۴)، وقد أخرجہ: سنن النسائی/الافتتاح ۸۱ (۱۰۱۴)، مسند احمد (۶/۳۴۲،۳۴۳،۳۴۴)، سنن الترمذی/الشمائل ۴۳ (۳۱۸),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1350,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، قَالَ حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِيُّ، قَالَ حَدَّثَنَا سَعْدُ بْنُ سَعِيدٍ، عَنْ عَمْرَةَ، عَنْ عَائِشَةَ، قَالَتْ: قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ كَسْرُ عَظْمِ الْمَيِّتِ كَكَسْرِهِ حَيًّا ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۰۱۲، ومصباح الزجاجة:۴۷۵)، وقد أخرجہ: سنن النسائی/الافتتاح ۷۹ (۱۰۱۱)، مسند احمد (۵/۱۴۹),,It was\nnarrated from ‘Aishah that the Messenger of Allah (ﷺ) said:,Chapters Regarding Funerals
1351,"حَدَّثَنَا مُحَمَّدُ بْنُ مَعْمَرٍ، حَدَّثَنَا مُحَمَّدُ بْنُ بَكْرٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ زِيَادٍ، أَخْبَرَنِي أَبُو عُبَيْدَةَ بْنُ عَبْدِ اللَّهِ بْنِ زَمْعَةَ، عَنْ أُمِّهِ، عَنْ أُمِّ سَلَمَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ كَسْرُ عَظْمِ الْمَيِّتِ كَكَسْرِ عَظْمِ الْحَىِّ فِي الإِثْمِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: صحیح مسلم/المسافرین ۲۷ (۷۷۲)، سنن ابی داود/الصلاة ۱۵۱ (۸۷۱)، سنن الترمذی/الصلاة ۷۹ (۲۶۲)، سنن النسائی/الافتتاح ۷۷ (۱۰۰۹)، التطبیق ۷۴ (۱۱۳۴)،(تحفة الأشراف:۳۳۵۸)، وحم (۵/۳۸۲،۳۸۴،۳۹۴)، سنن الدارمی/الصلاة۶۹ (۱۳۴۵),,It was\nnarrated from Umm Salamah that the Prophet (ﷺ) said:,Chapters Regarding Funerals
1352,حَدَّثَنَا سَهْلُ بْنُ أَبِي سَهْلٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، قَالَ: سَأَلْتُ عَائِشَةَ فَقُلْتُ: أَىْ أُمَّهْ أَخْبِرِينِي عَنْ مَرَضِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ قَالَتِ: اشْتَكَى فَعَلَقَ يَنْفُثُ فَجَعَلْنَا نُشَبِّهُ نَفْثَهُ بِنَفْثَةِ آكِلِ الزَّبِيبِ وَكَانَ يَدُورُ عَلَى نِسَائِهِ فَلَمَّا ثَقُلَ اسْتَأْذَنَهُنَّ أَنْ يَكُونَ فِي بَيْتِ عَائِشَةَ وَأَنْ يَدُرْنَ عَلَيْهِ ‏.‏ قَالَتْ: فَدَخَلَ عَلَىَّ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَهُوَ بَيْنَ رَجُلَيْنِ وَرِجْلاَهُ تَخُطَّانِ بِالأَرْضِ أَحَدُهُمَا الْعَبَّاسُ فَحَدَّثْتُ بِهِ ابْنَ عَبَّاسٍ فَقَالَ: أَتَدْرِي مَنِ الرَّجُلُ الَّذِي لَمْ تُسَمِّهِ عَائِشَةُ؟ هُوَ عَلِيُّ بْنُ أَبِي طَالِبٍ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الصلاة ۱۵۳ (۸۸۱)،(تحفة الأشراف:۱۲۱۵۳)وقد أخرجہ: مسند احمد (۴/۳۴۷),1352,It was\nnarrated that ‘Ubaidullah bin ‘Abdullah said:,Chapters Regarding Funerals
1353,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ مُسْلِمٍ، عَنْ مَسْرُوقٍ، عَنْ عَائِشَةَ، قَالَتْ: كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ يَتَعَوَّذُ بِهَؤُلاَءِ الْكَلِمَاتِ ‏""‏ أَذْهِبِ الْبَاسَ رَبَّ النَّاسِ ‏.‏ وَاشْفِ أَنْتَ الشَّافِي لاَ شِفَاءَ إِلاَّ شِفَاؤُكَ شِفَاءً لاَ يُغَادِرُ سَقَمًا ‏""‏ ‏.‏ فَلَمَّا ثَقُلَ النَّبِيُّ ـ صلى الله عليه وسلم ـ فِي مَرَضِهِ الَّذِي مَاتَ فِيهِ أَخَذْتُ بِيَدِهِ فَجَعَلْتُ أَمْسَحُهُ وَأَقُولُهَا ‏.‏ فَنَزَعَ يَدَهُ مِنْ يَدِي ثُمَّ قَالَ: ‏""‏ اللَّهُمَّ اغْفِرْ لِي وَأَلْحِقْنِي بِالرَّفِيقِ الأَعْلَى ‏""‏ ‏.‏ قَالَتْ: فَكَانَ هَذَا آخِرَ مَا سَمِعْتُ مِنْ كَلاَمِهِ ـ صلى الله عليه وسلم ـ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: صحیح البخاری/فضائل القرآن ۲۹ (۵۰۴۵)، سنن ابی داود/الصلاة ۳۵۵ (۱۴۶۵)، سنن النسائی/الافتتاح ۸۲ (۱۰۱۵)،(تحفة الأشراف:۱۱۴۵)، وقد أخرجہ: مسند احمد (۳/۱۱۹،۱۲۷،۱۹۸،۲۸۹)، سنن الترمذی/الشمائل ۴۳ (۳۱۵),1353,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1354,"حَدَّثَنَا أَبُو مَرْوَانَ الْعُثْمَانِيُّ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعْدٍ، عَنْ أَبِيهِ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، قَالَتْ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏""‏ مَا مِنْ نَبِيٍّ يَمْرَضُ إِلاَّ خُيِّرَ بَيْنَ الدُّنْيَا وَالآخِرَةِ ‏""‏ ‏.‏ قَالَتْ فَلَمَّا كَانَ مَرَضُهُ الَّذِي قُبِضَ فِيهِ أَخَذَتْهُ بُحَّةٌ فَسَمِعْتُهُ يَقُولُ ‏""‏ مَعَ الَّذِينَ أَنْعَمَ اللَّهُ عَلَيْهِمْ مِنَ النَّبِيِّينَ وَالصِّدِّيقِينَ وَالشُّهَدَاءِ وَالصَّالِحِينَ ‏""‏ ‏.‏ فَعَلِمْتُ أَنَّهُ خُيِّرَ ‏.‏",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الطہارة ۹۰ (۲۲۶)، فضائل القرآن ۲۳ (۲۲۹۴)، سنن النسائی/الطہارة ۱۴۱ (۲۲۳)، الغسل ۶ (۴۰۵)،(تحفة الأشراف:۱۷۴۲۹)، وقد أخرجہ: مسند احمد (۶/ ۱۳۸،۱۴۹),1354,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1355,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ زَكَرِيَّا، عَنْ فِرَاسٍ، عَنْ عَامِرٍ، عَنْ مَسْرُوقٍ، عَنْ عَائِشَةَ، قَالَتِ اجْتَمَعْنَ نِسَاءُ النَّبِيِّ ـ صلى الله عليه وسلم ـ فَلَمْ تُغَادِرْ مِنْهُنَّ امْرَأَةٌ فَجَاءَتْ فَاطِمَةُ كَأَنَّ مِشْيَتَهَا مِشْيَةُ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ: ‏""‏ مَرْحَبًا بِابْنَتِي ‏""‏ ‏.‏ ثُمَّ أَجْلَسَهَا عَنْ شِمَالِهِ ثُمَّ إِنَّهُ أَسَرَّ إِلَيْهَا حَدِيثًا فَبَكَتْ فَاطِمَةُ. ثُمَّ إِنَّهُ سَارَّهَا. فَضَحِكَتْ أَيْضًا فَقُلْتُ لَهَا: مَا يُبْكِيكِ؟ قَالَتْ: مَا كُنْتُ لأُفْشِيَ سِرَّ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ فَقُلْتُ: مَا رَأَيْتُ كَالْيَوْمِ فَرَحًا أَقْرَبَ مِنْ حُزْنٍ ‏.‏ فَقُلْتُ لَهَا حِينَ بَكَتْ: أَخَصَّكِ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِحَدِيثٍ دُونَنَا ثُمَّ تَبْكِينَ؟ وَسَأَلْتُهَا عَمَّا قَالَ ‏.‏ فَقَالَتْ: مَا كُنْتُ لأُفْشِيَ سِرَّ رَسُولِ اللَّهِ -صلى الله عليه وسلم - ‏.‏ حَتَّى إِذَا قُبِضَ سَأَلْتُهَا عَمَّا قَالَ. فَقَالَتْ: إِنَّهُ كَانَ يُحَدِّثُنِي أَنَّ جِبْرَائِيلَ كَانَ يُعَارِضُهُ بِالْقُرْآنِ فِي كُلِّ عَامٍ مَرَّةً وَأَنَّهُ عَارَضَهُ بِهِ الْعَامَ مَرَّتَيْنِ ‏""‏ وَلاَ أُرَانِي إِلاَّ قَدْ حَضَرَ أَجَلِي وَأَنَّكِ أَوَّلُ أَهْلِي لُحُوقًا بِي وَنِعْمَ السَّلَفُ أَنَا لَكِ ‏""‏ ‏.‏ فَبَكَيْتُ ثُمَّ إِنَّهُ سَارَّنِي فَقَالَ: ‏""‏ أَلاَ تَرْضَيْنَ أَنْ تَكُونِي سَيِّدَةَ نِسَاءِ الْمُؤْمِنِينَ - أَوْ نِسَاءِ هَذِهِ الأُمَّةِ - ‏""‏ ‏.‏ فَضَحِكْتُ لِذَلِكَ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/التہجد ۱ (۱۱۲۰)، والدعوات ۱۰ (۶۳۱۷)، التوحید ۸ (۷۳۸۵)،۲۴ (۷۴۴۲)،۳۵ (۷۴۹۹)، صحیح مسلم/المسافرین ۲۶ (۷۶۹)، سنن النسائی/قیام اللیل ۹ (۱۶۲۰)،(تحفة الأشراف:۵۷۰۲)، وقد أخرجہ: موطا امام مالک/القرآن ۸ (۳۴)، مسند احمد (۱/۲۹۸،۳۵۸،۳۶۶)، سنن الدارمی/الصلاة ۱۶۹ (۱۵۲۷),1355,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1356,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا مُصْعَبُ بْنُ الْمِقْدَامِ، حَدَّثَنَا سُفْيَانُ، عَنِ الأَعْمَشِ، عَنْ شَقِيقٍ، عَنْ مَسْرُوقٍ، قَالَ: قَالَتْ عَائِشَةُ: مَا رَأَيْتُ أَحَدًا أَشَدَّ عَلَيْهِ الْوَجَعُ مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الصلاة ۱۲۱ (۷۶۶)، سنن النسائی/قیام اللیل ۹ (۱۶۱۸)،(تحفة الأشراف:۱۶۱۶۶)، وقد أخرجہ: مسند احمد (۶/۱۴۳),1356,‘Aishah\nsaid:,Chapters Regarding Funerals
1357,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، حَدَّثَنَا لَيْثُ بْنُ سَعْدٍ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ مُوسَى بْنِ سَرْجِسَ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ، عَنْ عَائِشَةَ، قَالَتْ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ وَهُوَ يَمُوتُ وَعِنْدَهُ قَدَحٌ فِيهِ مَاءٌ فَيُدْخِلُ يَدَهُ فِي الْقَدَحِ ثُمَّ يَمْسَحُ وَجْهَهُ بِالْمَاءِ ثُمَّ يَقُولُ: ‏ ‏ اللَّهُمَّ أَعِنِّي عَلَى سَكَرَاتِ الْمَوْتِ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المسافرین ۲۶ (۷۷۰)، سنن ابی داود/الصلاة ۱۲۱ (۷۶۷)، سنن الترمذی/الدعوات ۳۱ (۳۴۲۰)، سنن النسائی/قیام اللیل ۱۱ (۱۶۲۶)،(تحفة الأشراف:۱۷۷۷۹)، وقد أخرجہ: مسند احمد (۶/۱۵۶),,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1358,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، سَمِعَ أَنَسَ بْنَ مَالِكٍ، يَقُولُ آخِرُ نَظْرَةٍ نَظَرْتُهَا إِلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ كَشْفُ السِّتَارَةِ يَوْمَ الاِثْنَيْنِ فَنَظَرْتُ إِلَى وَجْهِهِ كَأَنَّهُ وَرَقَةُ مُصْحَفٍ وَالنَّاسُ خَلْفَ أَبِي بَكْرٍ فِي الصَّلاَةِ فَأَرَادَ أَنْ يَتَحَرَّكَ فَأَشَارَ إِلَيْهِ أَنِ اثْبُتْ وَأَلْقَى السِّجْفَ وَمَاتَ مِنْ آخِرِ ذَلِكَ الْيَوْمِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الصلاة ۳۱۶ (۱۳۳۶،۱۳۳۷)، سنن النسائی/الأذان ۴۱ (۶۸۶)،(تحفة الأشراف:۱۵۶۱۵،۱۶۶۱۸، ومصباح الزجاجة:۴۷۷)، وقد أخرجہ: صحیح البخاری/الأذان ۱۲ (۶۱۹)، االتہجد ۳ (۱۱۲۳)، صحیح مسلم/المسافرین ۱۷ (۷۳۶)، سنن الترمذی/الصلاہ ۲۰۹ (۴۴۱)، موطا امام مالک/صلاة اللیل ۲ (۸)، مسند احمد (۶/۳۴،۳۵)، سنن الدارمی/الصلاہ ۱۴۸ (۱۴۸۷),1358,It was\nnarrated that Zuhri heard Anas bin Malik say:,Chapters Regarding Funerals
1359,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، حَدَّثَنَا هَمَّامٌ، عَنْ قَتَادَةَ، عَنْ صَالِحٍ أَبِي الْخَلِيلِ، عَنْ سَفِينَةَ، عَنْ أُمِّ سَلَمَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ كَانَ يَقُولُ فِي مَرَضِهِ الَّذِي تُوُفِّيَ فِيهِ ‏ ‏ الصَّلاَةَ وَمَا مَلَكَتْ أَيْمَانُكُمْ ‏""""‏ ‏.‏ فَمَا زَالَ يَقُولُهَا حَتَّى مَا يَفِيضَ بِهَا لِسَانُهُ ‏.‏""",Al-Albani: Shadh; Muhammad Fouad Abd al-Baqi: Shadh; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المسافرین ۱۷ (۷۳۷)،(تحفة الأشراف:۱۷۰۵۲)، وقد أخرجہ: صحیح البخاری/التہجد ۱۰ (۱۱۴۰)، سنن ابی داود/الصلاة ۳۱۶ (۱۳۳۴)، سنن الترمذی/الصلاة۲۱۰ (۴۴۴)، موطا امام مالک/صلاة اللیل ۲ (۸),,"It was\nnarrated from Umm Salamah that the Messenger of Allah (ﷺ)\nused to\nsay, during the illness that would be his last:",Chapters Regarding Funerals
1360,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، عَنِ ابْنِ عَوْنٍ، عَنْ إِبْرَاهِيمَ، عَنِ الأَسْوَدِ، قَالَ: ذَكَرُوا عِنْدَ عَائِشَةَ أَنَّ عَلِيًّا كَانَ وَصِيًّا ‏.‏ فَقَالَتْ: مَتَى أَوْصَى إِلَيْهِ؟ فَلَقَدْ كُنْتُ مُسْنِدَتَهُ إِلَى صَدْرِي - أَوْ إِلَى حِجْرِي فَدَعَا بِطَسْتٍ فَلَقَدِ انْخَنَثَ فِي حِجْرِي فَمَاتَ وَمَا شَعَرْتُ بِهِ. فَمَتَى أَوْصَى ـ صلى الله عليه وسلم ـ؟ ‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن الترمذی/الصلاة ۲۱۱ (۴۴۳،۴۴۴)، سنن النسائی/قیام اللیل ۳۳ (۱۶۹۷)،(تحفة الأشراف:۱۵۹۵۱)، وقد أخرجہ: صحیح البخاری/الأذان ۱۲ (۶۱۹)، الوتر ۳ (۱۱۲۳)، صحیح مسلم/المسافرین ۱۷ (۷۳۸)، سنن ابی داود/الصلاہ ۲۹۳ (۱۳۳۴)، مسند احمد (۶/۱۰۰،۲۵۳)، سنن الدارمی/الصلاة ۱۴۸،(۱۴۸۷),1360,It was\nnarrated that Aswad said:,Chapters Regarding Funerals
1361,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي بَكْرٍ، عَنِ ابْنِ أَبِي مُلَيْكَةَ، عَنْ عَائِشَةَ، قَالَتْ لَمَّا قُبِضَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَأَبُو بَكْرٍ عِنْدَ امْرَأَتِهِ ابْنَةِ خَارِجَةَ بِالْعَوَالِي فَجَعَلُوا يَقُولُونَ لَمْ يَمُتِ النَّبِيُّ ـ صلى الله عليه وسلم ـ إِنَّمَا هُوَ بَعْضُ مَا كَانَ يَأْخُذُهُ عِنْدَ الْوَحْىِ ‏.‏ فَجَاءَ أَبُو بَكْرٍ فَكَشَفَ عَنْ وَجْهِهِ وَقَبَّلَ بَيْنَ عَيْنَيْهِ وَقَالَ أَنْتَ أَكْرَمُ عَلَى اللَّهِ مِنْ أَنْ يُمِيتَكَ مَرَّتَيْنِ قَدْ وَاللَّهِ مَاتَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ وَعُمَرُ فِي نَاحِيَةِ الْمَسْجِدِ يَقُولُ وَاللَّهِ مَا مَاتَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَلاَ يَمُوتُ حَتَّى يَقْطَعَ أَيْدِيَ أُنَاسٍ مِنَ الْمُنَافِقِينَ كَثِيرٍ وَأَرْجُلَهُمْ ‏.‏ فَقَامَ أَبُو بَكْرٍ فَصَعِدَ الْمِنْبَرَ فَقَالَ مَنْ كَانَ يَعْبُدُ اللَّهَ فَإِنَّ اللَّهَ حَىٌّ لَمْ يَمُتْ وَمَنْ كَانَ يَعْبُدُ مُحَمَّدًا فَإِنَّ مُحَمَّدًا قَدْ مَاتَ ‏{وَمَا مُحَمَّدٌ إِلاَّ رَسُولٌ قَدْ خَلَتْ مِنْ قَبْلِهِ الرُّسُلُ أَفَإِنْ مَاتَ أَوْ قُتِلَ انْقَلَبْتُمْ عَلَى أَعْقَابِكُمْ وَمَنْ يَنْقَلِبْ عَلَى عَقِبَيْهِ فَلَنْ يَضُرَّ اللَّهَ شَيْئًا وَسَيَجْزِي اللَّهُ الشَّاكِرِينَ}‏ ‏.‏ قَالَ عُمَرُ فَلَكَأَنِّي لَمْ أَقْرَأْهَا إِلاَّ يَوْمَئِذٍ ‏.‏,Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۷۷۰، ومصباح الزجاجة:۴۷۶),1361,It was\nnarrated that ‘Aishah said:,Chapters Regarding Funerals
1362,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، أَنْبَأَنَا وَهْبُ بْنُ جَرِيرٍ، حَدَّثَنَا أَبِي، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، حَدَّثَنِي حُسَيْنُ بْنُ عَبْدِ اللَّهِ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ لَمَّا أَرَادُوا أَنْ يَحْفِرُوا، لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ بَعَثُوا إِلَى أَبِي عُبَيْدَةَ بْنِ الْجَرَّاحِ وَكَانَ يَضْرَحُ كَضَرِيحِ أَهْلِ مَكَّةَ وَبَعَثُوا إِلَى أَبِي طَلْحَةَ وَكَانَ هُوَ الَّذِي يَحْفِرُ لأَهْلِ الْمَدِينَةِ وَكَانَ يَلْحَدُ فَبَعَثُوا إِلَيْهِمَا رَسُولَيْنِ وَقَالُوا اللَّهُمَّ خِرْ لِرَسُولِكَ ‏.‏ فَوَجَدُوا أَبَا طَلْحَةَ فَجِيءَ بِهِ وَلَمْ يُوجَدْ أَبُو عُبَيْدَةَ فَلَحَدَ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ قَالَ فَلَمَّا فَرَغُوا مِنْ جِهَازِهِ يَوْمَ الثُّلاَثَاءِ وُضِعَ عَلَى سَرِيرِهِ فِي بَيْتِهِ ‏.‏ ثُمَّ دَخَلَ النَّاسُ عَلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ أَرْسَالاً ‏.‏ يُصَلُّونَ عَلَيْهِ حَتَّى إِذَا فَرَغُوا أَدْخَلُوا النِّسَاءَ حَتَّى إِذَا فَرَغُوا أَدْخَلُوا الصِّبْيَانَ وَلَمْ يَؤُمَّ النَّاسَ عَلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ أَحَدٌ ‏.‏ لَقَدِ اخْتَلَفَ الْمُسْلِمُونَ فِي الْمَكَانِ الَّذِي يُحْفَرُ لَهُ فَقَالَ قَائِلُونَ يُدْفَنُ فِي مَسْجِدِهِ ‏.‏ وَقَالَ قَائِلُونَ يُدْفَنُ مَعَ أَصْحَابِهِ ‏.‏ فَقَالَ أَبُو بَكْرٍ إِنِّي سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَا قُبِضَ نَبِيٌّ إِلاَّ دُفِنَ حَيْثُ يُقْبَضُ ‏""""‏ ‏.‏ قَالَ فَرَفَعُوا فِرَاشَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ الَّذِي تُوُفِّيَ عَلَيْهِ فَحَفَرُوا لَهُ ثُمَّ دُفِنَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَسْطَ اللَّيْلِ مِنْ لَيْلَةِ الأَرْبِعَاءِ ‏.‏ وَنَزَلَ فِي حُفْرَتِهِ عَلِيُّ بْنُ أَبِي طَالِبٍ وَالْفَضْلُ وَقُثَمُ ابْنَا الْعَبَّاسِ وَشُقْرَانُ مَوْلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ وَقَالَ أَوْسُ بْنُ خَوْلِيٍّ وَهُوَ أَبُو لَيْلَى لِعَلِيِّ بْنِ أَبِي طَالِبٍ أَنْشُدُكَ اللَّهَ وَحَظَّنَا مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ قَالَ لَهُ عَلِيٌّ انْزِلْ ‏.‏ وَكَانَ شُقْرَانُ مَوْلاَهُ أَخَذَ قَطِيفَةً كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَلْبَسُهَا فَدَفَنَهَا فِي الْقَبْرِ وَقَالَ وَاللَّهِ لاَ يَلْبَسُهَا أَحَدٌ بَعْدَكَ أَبَدًا ‏.‏ فَدُفِنَتْ مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المسافرین ۲۶ (۷۶۵)، سنن ابی داود/الصلاة ۳۱۶ (۱۳۶۶)،(تحفة الأشراف:۳۷۵۳)، وقد أخرجہ: موطا امام مالک/صلاة اللیل ۲ (۱۳)، سنن الترمذی/الشمائل (۲۶۹)، مسند احمد (۵/۱۹۲),,It was\nnarrated that Ibn ‘Abbas said:,Chapters Regarding Funerals
1363,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الزُّبَيْرِ أَبُو الزُّبَيْرِ، حَدَّثَنَا ثَابِتٌ الْبُنَانِيُّ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ لَمَّا وَجَدَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ مِنْ كَرْبِ الْمَوْتِ مَا وَجَدَ قَالَتْ فَاطِمَةُ وَاكَرْبَ أَبَتَاهْ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ كَرْبَ عَلَى أَبِيكِ بَعْدَ الْيَوْمِ إِنَّهُ قَدْ حَضَرَ مِنْ أَبِيكِ مَا لَيْسَ بِتَارِكٍ مِنْهُ أَحَدًا الْمُوَافَاةُ يَوْمَ الْقِيَامَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الوضوء ۵ ۳۷ (۱۸۳)، الأذان ۵۸ (۶۹۸)،۷۷ (۷۲۶)،۱۶۱ (۸۵۹)، الوتر ۱ (۹۹۲)، العمل في الصلاة ۱ (۱۱۹۸)، الدعوات ۱۰ (۶۳۱۶)، التوحید ۲۷ (۷۴۵۲)، صحیح مسلم/المسافرین ۲۶ (۷۶۳)، سنن ابی داود/الصلاة ۳۱۶ (۱۳۶۷)، سنن الترمذی/الشمائل ۳۸ (۲۶۵)، سنن النسائی/الأذان ۴۱ (۶۸۷)، التطبیق ۶۳ (۱۱۲۲)، قیام اللیل ۹ (۱۶۲۱)،(تحفة الأشراف:۶۳۶۲)، وقد أخرجہ: موطا امام مالک/صلاة اللیل ۲ (۱۱)، مسند احمد (۱/۲۴۵،۳۴۳،۳۵۸),,It was\nnarrated that Anas bin Malik said:,Chapters Regarding Funerals
1364,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو أُسَامَةَ، حَدَّثَنِي حَمَّادُ بْنُ زَيْدٍ، حَدَّثَنِي ثَابِتٌ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَتْ لِي فَاطِمَةُ يَا أَنَسُ كَيْفَ سَخَتْ أَنْفُسُكُمْ أَنْ تَحْثُوا التُّرَابَ عَلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ وَحَدَّثَنَا ثَابِتٌ، عَنْ أَنَسٍ، أَنَّ فَاطِمَةَ، قَالَتْ حِينَ قُبِضَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَا أَبَتَاهْ إِلَى جِبْرَائِيلَ أَنْعَاهْ وَا أَبَتَاهْ مِنْ رَبِّهِ مَا أَدْنَاهْ وَا أَبَتَاهْ جَنَّةُ الْفِرْدَوْسِ مَأْوَاهْ وَا أَبَتَاهْ أَجَابَ رَبًّا دَعَاهْ ‏.‏ قَالَ حَمَّادٌ فَرَأَيْتُ ثَابِتًا حِينَ حَدَّثَ بِهَذَا الْحَدِيثِ بَكَى حَتَّى رَأَيْتُ أَضْلاَعَهُ تَخْتَلِفُ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۷۶۲، ومصباح الزجاجة:۴۷۸)، وقد أخرجہ: مسند احمد (۴/ ۱۱۱،۱۱۳،۱۱۴،۳۸۵),,It was\nnarrated that Anas bin Malik said:,Chapters Regarding Funerals
1365,حَدَّثَنَا بِشْرُ بْنُ هِلاَلٍ الصَّوَّافُ، حَدَّثَنَا جَعْفَرُ بْنُ سُلَيْمَانَ الضُّبَعِيُّ، حَدَّثَنَا ثَابِتٌ، عَنْ أَنَسٍ، قَالَ لَمَّا كَانَ الْيَوْمُ الَّذِي دَخَلَ فِيهِ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ الْمَدِينَةَ أَضَاءَ مِنْهَا كُلُّ شَىْءٍ فَلَمَّا كَانَ الْيَوْمُ الَّذِي مَاتَ فِيهِ أَظْلَمَ مِنْهَا كُلُّ شَىْءٍ ‏.‏ وَمَا نَفَضْنَا عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ الأَيْدِيَ حَتَّى أَنْكَرْنَا قُلُوبَنَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۰۱۷، ومصباح الزجاجة:۴۷۹)، وقد أخرجہ: صحیح البخاری/التہجد ۱۵ (۱۱۴۶)، صحیح مسلم/المسافرین ۱۷ (۷۳۹)، سنن النسائی/قیام اللیل ۱۵ (۱۶۴۱)، مسند احمد (۶/۱۰۲،۲۵۳),1365,It was\nnarrated that Anas said:,Chapters Regarding Funerals
1366,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، أَخْبَرَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، حَدَّثَنَا سُفْيَانُ، عَنْ عَبْدِ اللَّهِ بْنِ دِينَارٍ، عَنِ ابْنِ عُمَرَ، قَالَ كُنَّا نَتَّقِي الْكَلاَمَ وَالاِنْبِسَاطَ إِلَى نِسَائِنَا عَلَى عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ مَخَافَةَ أَنْ يُنْزَلَ فِينَا الْقُرْآنُ فَلَمَّا مَاتَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ تَكَلَّمْنَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/التہجد ۱۴ (۱۱۴۵)، صحیح مسلم/المسافرین ۲۴ (۷۵۸)، سنن ابی داود/السنة ۲۱ (۴۷۳۳)، سنن الترمذی/الصلاة ۲۱۲ (۴۴۶)،(تحفة الأشراف:۱۵۱۲۹)، وقد أخرجہ: موطا امام مالک/القرآن ۱ (۳۰)، مسند احمد (۲/۲۶۴،۲۶۷،۲۸۲،۴۱۹،۴۸۷،۵۰۴)، سنن الدارمی/الصلاة ۱۶۸ (۱۵۲۰),1366,It was\nnarrated that Ibn ‘Umar said:,Chapters Regarding Funerals
1367,حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، أَنْبَأَنَا عَبْدُ الْوَهَّابِ بْنُ عَطَاءٍ الْعِجْلِيُّ، عَنِ ابْنِ عَوْنٍ، عَنِ الْحَسَنِ، عَنْ أُبَىِّ بْنِ كَعْبٍ، قَالَ كُنَّا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَإِنَّمَا وَجْهُنَا وَاحِدٌ فَلَمَّا قُبِضَ نَظَرْنَا هَكَذَا وَهَكَذَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۶۱۱، ومصباح الزجاجة:۴۸۰)، وقد أخرجہ: مسند احمد (۴/۱۶)، سنن الدارمی/الصلاة ۱۶۸ (۱۵۲۲),1367,It was\nnarrated that Ubayy bin Ka’b said:,Chapters Regarding Funerals
1368,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، حَدَّثَنَا خَالِي، مُحَمَّدُ بْنُ إِبْرَاهِيمَ بْنِ الْمُطَّلِبِ بْنِ السَّائِبِ بْنِ أَبِي وَدَاعَةَ السَّهْمِيُّ حَدَّثَنِي مُوسَى بْنُ عَبْدِ اللَّهِ بْنِ أَبِي أُمَيَّةَ الْمَخْزُومِيُّ، حَدَّثَنِي مُصْعَبُ بْنُ عَبْدِ اللَّهِ، عَنْ أُمِّ سَلَمَةَ بِنْتِ أَبِي أُمَيَّةَ، زَوْجِ النَّبِيِّ ـ صلى الله عليه وسلم ـ أَنَّهَا قَالَتْ كَانَ النَّاسُ فِي عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ إِذَا قَامَ الْمُصَلِّي يُصَلِّي لَمْ يَعْدُ بَصَرُ أَحَدِهِمْ مَوْضِعَ قَدَمَيْهِ فَتُوُفِّيَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَكَانَ النَّاسُ إِذَا قَامَ أَحَدُهُمْ يُصَلِّي لَمْ يَعْدُ بَصَرُ أَحَدِهِمْ مَوْضِعَ جَبِينِهِ فَتُوُفِّيَ أَبُو بَكْرٍ وَكَانَ عُمَرُ فَكَانَ النَّاسُ إِذَا قَامَ أَحَدُهُمْ يُصَلِّي لَمْ يَعْدُ بَصَرُ أَحَدِهِمْ مَوْضِعَ الْقِبْلَةِ وَكَانَ عُثْمَانُ بْنُ عَفَّانَ فَكَانَتِ الْفِتْنَةُ فَتَلَفَّتَ النَّاسُ يَمِينًا وَشِمَالاً ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/المغازي ۱۲ (۴۰۰۸)، صحیح مسلم/المسافرین ۴۳ (۸۰۸)، سنن ابی داود/الصلاة ۳۲۶ (۱۳۹۷)، سنن الترمذی/فضائل القرآن ۴ (۲۸۸۱)،(تحفةالأشراف:۹۹۹۹،۱۰۰۰۰)، وقد أخرجہ: مسند احمد (۴/۱۱۸،۱۲۱،۱۲۲)، سنن الدارمی/الصلاة ۱۷۰ (۱۵۲۸),1368,"It was\nnarrated that Umm Salamah bint Abi Umayyah, the wife of the\nProphet\n(ﷺ), said:",Chapters Regarding Funerals
1369,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا عَمْرُو بْنُ عَاصِمٍ، حَدَّثَنَا سُلَيْمَانُ بْنُ الْمُغِيرَةِ، عَنْ ثَابِتٍ، عَنْ أَنَسٍ، قَالَ قَالَ أَبُو بَكْرٍ بَعْدَ وَفَاةِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ لِعُمَرَ انْطَلِقْ بِنَا إِلَى أُمِّ أَيْمَنَ نَزُورُهَا كَمَا كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يَزُورُهَا ‏.‏ قَالَ: فَلَمَّا انْتَهَيْنَا إِلَيْهَا بَكَتْ فَقَالاَ لَهَا: مَا يُبْكِيكِ؟ فَمَا عِنْدَ اللَّهِ خَيْرٌ لِرَسُولِهِ ‏.‏ قَالَتْ: إِنِّي لأَعْلَمُ أَنَّ مَا عِنْدَ اللَّهِ خَيْرٌ لِرَسُولِهِ وَلَكِنْ أَبْكِي أَنَّ الْوَحْىَ قَدِ انْقَطَعَ مِنَ السَّمَاءِ ‏.‏ قَالَ: فَهَيَّجَتْهُمَا عَلَى الْبُكَاءِ فَجَعَلاَ يَبْكِيَانِ مَعَهَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: انظر ما قبلہ,1369,It was\nnarrated that Anas said:,Chapters Regarding Funerals
1370,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا الْحُسَيْنُ بْنُ عَلِيٍّ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ يَزِيدَ بْنِ جَابِرٍ، عَنْ أَبِي الأَشْعَثِ الصَّنْعَانِيِّ، عَنْ أَوْسِ بْنِ أَوْسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ إِنَّ مِنْ أَفْضَلِ أَيَّامِكُمْ يَوْمَ الْجُمُعَةِ فِيهِ خُلِقَ آدَمُ وَفِيهِ النَّفْخَةُ وَفِيهِ الصَّعْقَةُ فَأَكْثِرُوا عَلَىَّ مِنَ الصَّلاَةِ فِيهِ فَإِنَّ صَلاَتَكُمْ مَعْرُوضَةٌ عَلَىَّ ‏.‏ فَقَالَ رَجُلٌ يَا رَسُولَ اللَّهِ كَيْفَ تُعْرَضُ صَلاَتُنَا عَلَيْكَ وَقَدْ أَرَمْتَ - يَعْنِي بَلِيتَ - قَالَ ‏""‏ إِنَّ اللَّهَ حَرَّمَ عَلَى الأَرْضِ أَنْ تَأْكُلَ أَجْسَادَ الأَنْبِيَاءِ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: حدیث أبي بکر بن أبي شیبة أخرجہ: صحیح مسلم/المسافرین ۳۱ (۷۸۶)،(تحفة الأشراف:۱۶۹۸۳)، وحدیث محمد بن عثمان العثمانی، تفرد بہ ابن ماجہ:(تحفة الأشراف:۱۷۰۲۹)، وقد أخرجہ: صحیح البخاری/الوضوء ۵۳ (۲۱۲)، سنن ابی داود/الصلا ۳۰۸ (۱۳۱۰)، سنن الترمذی/الصلاة ۱۴۶ (۳۵۵)، سنن النسائی/الطہارة ۱۱۷ (۱۶۲)، موطا امام مالک/صلاة اللیل ۱ (۳)، مسند احمد (۶/۵۶،۲۰۵)، دی/الصلاة ۱۰۷ (۱۴۲۳),1370,It was\nnarrated from Aws bin Aws that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1371,"حَدَّثَنَا عَمْرُو بْنُ سَوَّادٍ الْمِصْرِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، عَنْ عَمْرِو بْنِ الْحَارِثِ، عَنْ سَعِيدِ بْنِ أَبِي هِلاَلٍ، عَنْ زَيْدِ بْنِ أَيْمَنَ، عَنْ عُبَادَةَ بْنِ نُسَىٍّ، عَنْ أَبِي الدَّرْدَاءِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏""‏ أَكْثِرُوا الصَّلاَةَ عَلَىَّ يَوْمَ الْجُمُعَةِ فَإِنَّهُ مَشْهُودٌ تَشْهَدُهُ الْمَلاَئِكَةُ وَإِنَّ أَحَدًا لَنْ يُصَلِّيَ عَلَىَّ إِلاَّ عُرِضَتْ عَلَىَّ صَلاَتُهُ حَتَّى يَفْرُغَ مِنْهَا ‏""‏ ‏.‏ قَالَ قُلْتُ وَبَعْدَ الْمَوْتِ قَالَ ‏""‏ وَبَعْدَ الْمَوْتِ إِنَّ اللَّهَ حَرَّمَ عَلَى الأَرْضِ أَنْ تَأْكُلَ أَجْسَادَ الأَنْبِيَاءِ ‏""‏ ‏.‏ فَنَبِيُّ اللَّهِ حَىٌّ يُرْزَقُ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/التہجد ۱۸ (۱۱۵۰)، صحیح مسلم/المسافرین ۳۲ (۷۸۴)، سنن النسائی/قیام اللیل ۱۵ (۱۶۴۴)،(تحفة الأشراف:۱۰۳۳)، وقد أخرجہ: سنن ابی داود/الصلاة ۳۰۸ (۱۳۱۱)، مسند احمد (۳/۱۰۱،۱۸۴،۲۰۴،۲۵۶),1371,It was\nnarrated from Abu Darda’ that the Messenger of Allah (ﷺ)\nsaid:,Chapters Regarding Funerals
1433,حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْأَحْوَصِ، ‏‏‏‏‏‏عَنْ أَبِي إِسْحَاق،,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الأدب ۱ (۲۷۳۶)،(تحفة الأشراف:۱۰۰۴۴)، وقد أخرجہ: مسند احمد (۱/۸۸،۸۹،۲/۳۷۲،۴۱۲)، سنن الدارمی/الاستئذان ۵ (۲۶۷۵),1433,,Chapters Regarding Funerals
1434,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۹۷۹، ومصباح الزجاجة:۵۰۵)، مسند احمد (۵/۲۷۲),1434,,Chapters Regarding Funerals
1435,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، ‏‏‏‏‏‏عَنْ مُحَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۰۹۲، ومصباح الزجاجة:۵۰۶)، وقد أخرجہ: صحیح البخاری/الجنائز۲ (۱۲۴۰)، صحیح مسلم/السلام ۳ (۲۱۶۲)، سنن النسائی/الجنائز ۵۲ (۱۹۴۰)، مسند احمد (۲/۳۲۱،۳۳۲،۳۵۷،۳۷۲،۳۸۸),1435,,Chapters Regarding Funerals
1436,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الصَّنْعَانِيُّ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏قَالَ:‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الوضوء ۴۵ (۱۹۴)، التفسیر ۴ (۴۵۷۷)، المرضی ۵ (۵۶۵۱)، الفرائض ۱ (۶۷۲۳)، الاعتصام ۸ (۳۰۱۵)، صحیح مسلم/الفرائض ۲ (۱۶۱۶)، سنن ابی داود/الجنائز ۲ (۲۸۸۶)، سنن الترمذی/الفرائض ۷ (۲۰۹۷)، تفسیرالقرآن ۵ (۳۰۱۵)، سنن النسائی/الطہارة ۱۰۳ (۱۳۸)،(تحفة الأشراف:۳۰۲۸)، وقد أخرجہ: سنن الدارمی/الطہارة ۵۶ (۷۶۰)(یہ حدیث مکرر ہے، دیکھئے:۲۷۲۸),1436,,Chapters Regarding Funerals
1437,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مَسْلَمَةُ بْنُ عَلِيٍّ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ ج,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۱۸، و مصباح الزجاجة:۵۰۷),1437,,Chapters Regarding Funerals
1438,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عُقْبَةُ بْنُ خَالِدٍ السَّكُونِيُّ، ‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الطب ۳۵ (۰۸۷)،(تحفة الأشراف:۴۲۹۲),1438,,Chapters Regarding Funerals
1439,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، ‏‏‏‏‏‏حَدَّثَنَا صَفْوَانُ بْنُ هُبَيْرَةَ، ‏‏‏‏‏‏حَد,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۲۲۴، ومصباح الزجاجة:۵۰۸),1439,,Chapters Regarding Funerals
1440,حَدَّثَنَا سُفْيَانُ بْنُ وَكِيعٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو يَحْيَى الْحِمَّانِيُّ، ‏‏‏‏‏‏عَنِ الْأَعْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۸۳، ومصباح الزجاجة:۵۰۹),1440,,Chapters Regarding Funerals
1441,حَدَّثَنَا جَعْفَرُ بْنُ مُسَافِرٍ، ‏‏‏‏‏‏حَدَّثَنِي كَثِيرُ بْنُ هِشَامٍ، ‏‏‏‏‏‏حَدَّثَنَا جَعْفَرُ,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۶۴۹، ومصباح الزجاجة:۵۱۰),1441,,Chapters Regarding Funerals
1442,حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏حَدَّثَنَا الْأَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۲۱۱، ومصباح الزجاجة:۵۱۱)، وقد أخرجہ: سنن ابی داود/الجنائز ۷ (۳۰۹۸،۳۰۹۹)، سنن الترمذی/الجنائز ۲ (۹۶۹)، مسند احمد (۱/۹۷،۱۲۰),1442,,Chapters Regarding Funerals
1443,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا يُوسُفُ بْنُ يَعْقُوبَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/البروالصلة ۶۴ (۲۰۰۸)،(تحفة الأشراف:۱۴۱۳۳)، وقد أخرجہ: مسند احمد (۲/۳۲۶،۳۴۴،۳۵۴),1443,,Chapters Regarding Funerals
1444,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: مردوں سے مراد وہ بیمار ہیں جو مرنے کے بالکل قریب ہوں۔ ۲؎:تلقین سے مراد تذکیر ہے یعنی ان کے پاس پڑھ کر انہیں اس کی یاد دہانی کرائی جائے تاکہ سن کر وہ بھی پڑھنے لگیں,1444,,Chapters Regarding Funerals
1445,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، ‏‏‏‏‏‏عَنْ سُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الجنائز ۱ (۹۱۶)، سنن ابی داود/الجنائز ۲۰ (۳۱۱۷)، سنن الترمذی/الجنائز ۷ (۹۷۶)، سنن النسائی/الجنائز ۴ (۱۸۲۷)،(تحفة الأشراف:۴۴۰۳)، وقد أخرجہ: مسند احمد (۳/۳),1445,,Chapters Regarding Funerals
1446,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو عَامِرٍ، ‏‏‏‏‏‏حَدَّثَنَا كَثِيرُ بْنُ زَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۲۱۳، ومصباح الزجاجة:۵۱۲),1446,,Chapters Regarding Funerals
1447,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الجنائز ۳ (۹۱۹)، سنن ابی داود/الجنائز ۱۹ (۳۱۱۵)، سنن الترمذی/الجنائز ۷ (۹۷۷)سنن النسائی/الجنائز ۳ (۱۸۲۶)،(تحفة الأشراف:۱۸۱۶۲)، وقد أخرجہ: موطا امام مالک/الجنائز ۱۴ (۴۲)، مسند احمد (۶/۲۹۱،۳۰۶،۳۲۲),1447,,Chapters Regarding Funerals
1448,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَلِيُّ بْنُ الْحَسَنِ بْنِ شَقِيقٍ، ‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الجنائز ۲۴ (۳۱۲۱)(تحفة الأشراف:۱۱۴۷۹)، وقد أخرجہ: مسند احمد (۵/۲۶،۲۷),1448,,Chapters Regarding Funerals
1449,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ . ح وحَدَّثَنَا مُحَمَّدُ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/فضائل الجہاد ۱۳ (۱۶۴۱)، سنن النسائی/الجنائز ۱۱۷ (۲۰۷۵)،(تحفة الأشراف:۱۱۱۴۸)، وقد أخرجہ: موطا امام مالک/الجنائز ۱۶ (۴۹)، مسند احمد (۳/۴۵۵،۴۵۶،۴۶۰،۶/۳۸۶،۴۲۵),1449,,Chapters Regarding Funerals
1450,حَدَّثَنَا أَحْمَدُ بْنُ الْأَزْهَرِ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ عِيسَى، ‏‏‏‏‏‏حَدَّثَنَا يُوسُ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۰۹۵، ومصباح الزجاجة:۵۱۳)، وقد أخرجہ: مسند احمد (۳/۶۹),1450,,Chapters Regarding Funerals
1451,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، ‏‏‏‏‏‏حَدَّثَنَا الْأَو,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۳۸۳، ومصباح الزجاجة:۵۱۴),1451,,Chapters Regarding Funerals
1452,حَدَّثَنَا بَكْرُ بْنُ خَلَفٍ أَبُو بِشْرٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، ‏‏‏‏‏‏عَنِ الْمُث,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن الترمذی/الجنائز ۱۰ (۹۸۲)، سنن النسائی/الجنائز ۵ (۱۸۲۹)،(تحفة الأشراف:۱۹۹۲)، وقد أخرجہ:(حم ۵/۳۵۰،۳۵۷،۳۶۰),1452,,Chapters Regarding Funerals
1453,حَدَّثَنَا رَوْحُ بْنُ الْفَرَجِ، ‏‏‏‏‏‏حَدَّثَنَا نَصْرُ بْنُ حَمَّادٍ، ‏‏‏‏‏‏حَدَّثَنَا مُوسَى بْن,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۱۳۰، ومصباح الزجاجة:۵۱۵),1453,,Chapters Regarding Funerals
1454,حَدَّثَنَا إِسْمَاعِيل بْنُ أَسَدٍ، ‏‏‏‏‏‏حَدَّثَنَا مُعَاوِيَةُ بْنُ عَمْرٍو، ‏‏‏‏‏‏حَدَّثَنَا أَبُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الجنائز ۴ (۹۲۰)، سنن ابی داود/الجنائز ۲۱ (۳۱۱۸)،(تحفة الأشراف:۱۸۲۰۵)، مسند احمد (۶/۲۹۷),1454,,Chapters Regarding Funerals
1455,حَدَّثَنَا أَبُو دَاوُدَ سُلَيْمَانُ بْنُ تَوْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَاصِمُ بْنُ عَلِيٍّ، ‏‏‏‏‏‏حَد,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۸۲۸، ومصباح الزجاجة:۵۱۶)، وقد أخرجہ: مسند احمد (۴/۱۲۵),1455,,Chapters Regarding Funerals
1456,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الجنائز ۴۰ (۳۱۶۳)، سنن الترمذی/الجنائز ۱۴ (۹۸۹)،(تحفة الأشراف:۱۷۴۵۹)، وقد أخرجہ: مسند احمد (۶/۴۳،۵۵،۲۰۶۷),1456,,Chapters Regarding Funerals
1457,حَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، ‏‏‏‏‏‏ وَالْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ، ‏‏‏‏‏‏ وَسَهْلُ بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/المغازي ۸۳ (۴۴۵۵،۴۴۵۶)، الطب ۲۱ (۵۷۰۹)، سنن الترمذی/الشمائل ۵۳ (۳۷۳)، سنن النسائی/الجنائز ۱۱ ۱۸۴۱)،(تحفة الأشراف:۵۸۶۰،۱۶۳۱۶)، وقد أخرجہ: مسند احمد (۶/۵۵),1457,,Chapters Regarding Funerals
1458,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الوضوء ۳۱ (۱۶۷)، الجنائز ۸ (۱۲۵۳)،۹ (۱۲۵۴)،۱۰ (۱۲۵۵)،۱۱ (۱۲۵۶)،۱۲ (۱۲۵۷)،۱۳ (۱۲۵۸)،۱۴ (۱۲۶۰)،۱۵ (۱۲۶۱)،۱۶ (۱۲۶۲)،۱۷ (۱۲۶۳)، صحیح مسلم/الجنائز ۱۲ (۹۳۹)، سنن ابی داود/الجنائز ۳۳ (۳۱۴۶۳۱۴۲)، سنن النسائی/الجنائز ۲۸ (۱۸۸۲)،۳۰ (۱۸۸۴)،۳۶ (۱۸۹۵)،(تحفة الأشراف:۱۸۰۹۴)، وقد أخرجہ: سنن الترمذی/الجنائز ۱۵ (۹۹۰)، موطا امام مالک/الجنائز ۱ (۲)، مسند احمد (۶/۴۰۷،۴۰۸،۵/۸۴،۸۵،۴۰۷),1458,,Chapters Regarding Funerals
1459,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: صحیح البخاری/ الجنائز ۹ (۱۲۵۴)،۱۳ (۱۲۵۸)، صحیح مسلم/الجنائز ۱۲ (۹۳۹)، سنن النسائی/الجنائز ۳۴ (۱۸۸۹)،(تحفة الأشراف:۱۸۱۱۵),1459,,Chapters Regarding Funerals
1460,حَدَّثَنَا بِشْرُ بْنُ آدَمَ، ‏‏‏‏‏‏حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، ‏‏‏‏‏‏عَنْ ابْنِ جُرَيْجٍ، ‏‏‏,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الجنائز ۳۲ (۳۱۴۰)،(تحفة الأشراف:۱۰۱۳۳)، وقد أخرجہ: مسند احمد (۱/۱۴۶),1460,,Chapters Regarding Funerals
1461,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، ‏‏‏‏‏‏حَدَّثَنَا بَقِيَّةُ بْنُ الْوَلِيدِ، ‏‏‏‏,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Mawdu; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۷۳۹، ومصباح الزجاجة:۵۱۷),1461,,Chapters Regarding Funerals
1462,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِبِيُّ، ‏‏‏‏‏‏حَدَّث,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Sanad Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۱۳۴، ومصباح الزجاجة:۵۱۸),1462,,Chapters Regarding Funerals
1463,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن الترمذی/الجنائز ۱۷ (۹۹۳)،(تحفة الأشراف:۱۲۷۲۶)، وقد أخرجہ: سنن ابی داود/الجنائز ۳۹ (۳۱۶۱)، مسند احمد (۲/۲۷۲),1463,,Chapters Regarding Funerals
1464,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا أَحْمَدُ بْنُ خَالِدٍ الذَّهَبِيُّ، ‏‏‏‏‏‏حَدَّث,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۱۸۲، ومصباح الزجاجة:۵۱۹)، وقد أخرجہ: سنن ابی داود/الجنائز ۳۲ (۳۱۴۱)، مسند احمد (۶/۲۶۷),1464,,Chapters Regarding Funerals
1465,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا أَحْمَدُ بْنُ حَنْبَلٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۳۱۳، ومصباح الزجاجة:۵۲۰)، وقد أخرجہ: مسند احمد (۶/۲۲۸)، سنن الدارمی/المقدمة ۱۴ (۸۱),1465,,Chapters Regarding Funerals
1466,حَدَّثَنَا سَعِيدُ بْنُ يَحْيَى بْنِ الْأَزْهَرِ الْوَاسِطِيُّ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ،,Al-Albani: Munkar; Muhammad Fouad Abd al-Baqi: Munkar; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۹۴۲، ومصباح الزجاجة:۵۲۱),1466,,Chapters Regarding Funerals
1467,حَدَّثَنَا يَحْيَى بْنُ خِذَامٍ، ‏‏‏‏‏‏حَدَّثَنَا صَفْوَانُ بْنُ عِيسَى، ‏‏‏‏‏‏أَنْبَأَنَا مَعْمَرٌ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۱۱۵، ومصباح الزجاجة:۵۲۲),1467,,Chapters Regarding Funerals
1468,حَدَّثَنَا عَبَّادُ بْنُ يَعْقُوبَ، ‏‏‏‏‏‏حَدَّثَنَا الْحُسَيْنُ بْنُ زَيْدِ بْنِ عَلِيِّ بْنِ الْحُ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۱۶۴، ومصباح الزجاجة:۵۲۳),1468,,Chapters Regarding Funerals
1469,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، ‏‏‏‏‏‏عَنْ هِشَام,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح مسلم/الجنائز ۱۳ (۹۴۱)، سنن ابی داود/الجنائز ۳۴ (۳۱۵۲)، سنن الترمذی/الجنائز۲۰ (۹۹۶)، سنن النسائی/الجنائز ۳۹ (۱۹۰۰)،(تحفة الأشراف:۱۶۷۸۶)، وقد أخرجہ: صحیح البخاری/الجنائز ۱۸ (۱۲۶۴)،۲۳ (۱۲۷۱)،۲۴ (۱۲۷۲)،۹۴ (۱۳۸۷)، موطا امام مالک/الجنائز ۲ (۵)مسند احمد (۶/۴۰،۹۳،۱۱۸،۱۳۲،۱۶۵),1469,,Chapters Regarding Funerals
1470,حَدَّثَنَا مُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلَانِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَمْرُو بْنُ أَبِي سَلَمَةَ، ‏‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۶۷۶، ومصباح الزجاجة:۵۲۴),1470,,Chapters Regarding Funerals
1471,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، ‏‏‏‏‏‏عَنْ يَزِيد,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: حدیث یزید بن أبي زیاد عن الحکم تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۴۸۵)، وحدث یزید بن أبي زیاد عن مقسم أخرجہ، سنن ابی داود/الجنائز ۳۴ (۳۱۵۳)،(تحفة الأشراف:۶۴۹۶)، وقد أخرجہ: مسند احمد (۱/۲۲۲),1471,,Chapters Regarding Funerals
1472,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ رَجَاءٍ الْمَكِّيُّ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/اللباس ۱۶ (۴۰۶۱)، سنن الترمذی/الجنائز ۱۸ (۹۹۴)،(تحفة الأشراف:۵۵۳۴)، وقد أخرجہ: مسند احمد (۱/۲۳۱،۲۴۷،۲۷۴،۳۶۸،۳۵۵،۳۶۳)،(یہ حدیث مکرر ہے، دیکھئے:(۳۵۶۶),1472,,Chapters Regarding Funerals
1473,حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الْأَعْلَى، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ وَهْبٍ، ‏‏‏‏‏‏أَنْبَأَنَا هِشَامُ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الجنائز ۳۵ (۳۱۵۶)،(تحفة الأشراف:۵۱۱۷),1473,,Chapters Regarding Funerals
1474,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عُمَرُ بْنُ يُونُسَ، ‏‏‏‏‏‏حَدَّثَنَا عِكْرِمَة,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: سنن الترمذی/الجنائز ۱۹ (۹۹۵)،(تحفة الأشراف:۱۲۱۲۵),1474,,Chapters Regarding Funerals
1475,حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيل بْنِ سَمُرَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ الْحَسَنِ، ‏‏‏‏,Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۰۸، ومصباح الزجاجة:۵۲۵),1475,,Chapters Regarding Funerals
1476,حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، ‏‏‏‏‏‏عَنْ حَبِي,Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الجنائز ۱۲ (۹۸۶)،(تحفة الأشراف:۳۳۰۳)، وقد أخرجہ: مسند احمد (۵/۳۸۵،۴۰۶),1476,,Chapters Regarding Funerals
1477,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَهِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الجنائز ۵۱ (۱۳۱۵)، صحیح مسلم/الجنائز ۱۶ (۹۴۴)، سنن ابی داود/الجنائز۵۰ (۳۱۸۱)، سنن الترمذی/الجنائز۳۰ (۱۰۱۵)، سنن النسائی/الجنائز ۴۴ (۱۹۱۱)،(تحفة الأشراف:۱۳۱۲۴)، وقد أخرجہ: موطا امام مالک/الجنائز ۱۶ (۵۶)، مسند احمد (۲/۲۴۰),1477,,Chapters Regarding Funerals
1478,حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏عَنْ مَنْصُورٍ، ‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۶۱۲، ومصباح الزجاجة:۵۲۶),1478,,Chapters Regarding Funerals
1479,حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدِ بْنِ عَقِيلٍ، ‏‏‏‏‏‏حَدَّثَنَا بِشْرُ بْنُ ثَابِتٍ، ‏‏‏‏‏‏حَدَّثَ,Al-Albani: Munkar; Muhammad Fouad Abd al-Baqi: Munkar; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۱۲۹، ومصباح الزجاجة:۵۲۷)، وقد أخرجہ: مسند احمد (۴/۴۰۳،۴۰۶،۴۱۲),1479,,Chapters Regarding Funerals
1480,حَدَّثَنَا كَثِيرُ بْنُ عُبَيْدٍ الْحِمْصِيُّ، ‏‏‏‏‏‏حَدَّثَنَا بَقِيَّةُ بْنُ الْوَلِيدِ، ‏‏‏‏‏‏عَن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الجنائز ۲۸ (۱۰۱۲)،(تحفة الأشراف:۲۰۸۱)، وقد أخرجہ: سنن ابی داود/الجنائز۴۸ (۳۱۷۷),1480,,Chapters Regarding Funerals
1481,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، ‏‏‏‏‏‏حَدَّثَنَا سَعِيدُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الجنائز ۴۹ (۳۱۸۰)، سنن الترمذی/الجنائز ۴۲ (۱۰۳۱)، سنن النسائی/الجنائز ۵۵ (۱۹۴۴)،(تحفة الأشراف:۱۱۴۹۰)، وقد أخرجہ: مسند احمد (۴/۲۴۷،۲۴۸،۲۴۹،۲۵۲),1481,,Chapters Regarding Funerals
1482,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَهِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَسَهْلُ بْنُ أَبِي سَهْلٍ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الجنائز ۴۹ (۱۱۷۹)، سنن الترمذی/الجنائز ۲۶ (۱۰۰۷)، سنن النسائی/الجنائز ۵۶ (۱۹۴۶)،(تحفة الأشراف:۶۸۲۰)، وقد أخرجہ: موطا امام مالک/الجنائز ۳ (۸)، مسند احمد (۲/۸،۱۲۲),1482,,Chapters Regarding Funerals
1483,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، ‏‏‏‏‏‏ وَهَارُونُ بْنُ عَبْدِ اللَّهِ الْحَمَّالُ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: سنن الترمذی/الجنائز ۲۶ (۱۰۱۰)،(تحفة الأشراف:۱۵۶۲),1483,,Chapters Regarding Funerals
1484,حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ الْوَاحِدِ بْنُ زِيَادٍ، ‏‏‏‏‏‏عَنْ يَحْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الجنائز۵۰ (۳۱۸۴)، سنن الترمذی/الجنائز ۲۷ (۱۰۱۱)،(تحفة الأشراف:۹۶۳۷)، وقد أخرجہ: مسند احمد (۱/۳۷۸،۳۹۴،۴۱۵،۴۱۹،۴۳۲),1484,,Chapters Regarding Funerals
1485,حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، ‏‏‏‏‏‏أَخْبَرَنِي عَمْرُو بْنُ النُّعْمَانِ، ‏‏‏‏‏‏حَدَّثَنَا عَل,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۸۶۴،۱۱۶۰۲، ومصباح الزجاجة:۵۲۸),1485,,Chapters Regarding Funerals
1486,حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏أَخْبَرَنِي س,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih,takhreej: سنن الترمذی/الصلاة ۱۲۷ (۱۷۱)،(تحفة الأشراف:۱۰۲۵۱)، وقد أخرجہ: مسند احمد (۱/۱۰۵،۱۰۲۵۱),1486,,Chapters Regarding Funerals
1487,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْأَعْلَى الصَّنْعَانِيُّ، ‏‏‏‏‏‏أَنْبَأَنَا مُعْتَمِرُ بْنُ سُلَي,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۱۱۰، ومصباح الزجاجة:۵۲۹)، وقد أخرجہ: مسند احمد (۴/۳۹۷),1487,,Chapters Regarding Funerals
1488,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عُبَيْدُ اللَّهِ، ‏‏‏‏‏‏أَنْبَأَنَا شَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۴۱۲، ومصباح الزجاجة:۵۳۰),1488,,Chapters Regarding Funerals
1489,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، ‏‏‏‏‏‏حَدَّثَنَا بَكْرُ بْنُ سُلَيْمٍ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: صحیح مسلم/الجنائز ۱۹ (۹۴۸)، سنن ابی داود/الجنائز ۴۵ (۳۱۷۰)،(تحفة الأشراف:۶۳۵۴)، مسند احمد (۱/۲۷۷),1489,,Chapters Regarding Funerals
1490,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الجنائز ۴۳ (۳۱۶۶)، سنن الترمذی/الجنائز۴۰ (۱۰۲۸)،(تحفة الأشراف:۱۱۲۰۸)، وقد أخرجہ: مسند احمد (۴/۷۹),1490,,Chapters Regarding Funerals
1491,حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏عَنْ ثَابِتٍ، ‏‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الجنائز ۸۵ (۱۳۶۷)، الشہادات ۶ (۲۶۴۲)، صحیح مسلم/الجنائز ۲۰ (۹۴۹)،(تحفة الأشراف:۲۹۴)، وقد أخرجہ: سنن الترمذی/الجنائز ۶۴ (۱۰۵۸)، سنن النسائی/الجنائز۵۰ (۱۹۳۴)، مسند احمد (۳/۱۷۹،۱۸۶،۷ ۱۹،۲۴۵،۲۸۱),1491,,Chapters Regarding Funerals
1492,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، ‏‏‏‏‏‏عَنْ مُحَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۰۷۴، ومصباح الزجاجة:۵۳۱)، وقد أخرجہ: سنن ابی داود/الجنائز۸۰ (۳۲۳۳)، سنن النسائی/الجنائز ۵۰ (۱۹۳۵)، مسند احمد (۲/۲۶۱،۴۹۹),1492,,Chapters Regarding Funerals
1493,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ الْحُسَيْنُ بْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الحیض۲۹ (۳۳۲)، الجنائز۶۲ (۱۳۳۲)،۶۳ (۱۳۳۳)، صحیح مسلم/الجنائز۲۷ (۹۶۴)، سنن ابی داود/الجنائز ۵۷ (۳۱۹۵)، سنن الترمذی/الجنائز۴۵ (۱۰۳۵)، سنن النسائی/الحیض۲۵ (۳۹۳)، الجنائز۷۳ (۱۹۷۸)،(تحفة الأشراف:۴۶۲۵)، وقد أخرجہ: مسند احمد (۵/۱۴،۱۹),1493,,Chapters Regarding Funerals
1494,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، ‏‏‏‏‏‏حَدَّثَنَا سَعِيدُ بْنُ عَامِرٍ، ‏‏‏‏‏‏عَنْ هَم,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الجنائز۵۷ (۳۱۹۴)، سنن الترمذی/الجنائز۴۵ (۱۰۳۴)،(تحفة الأشراف:۱۶۲۱)، وقد أخرجہ: حم (۳/۱۱۸،۱۵۱،۲۰۴),1494,,Chapters Regarding Funerals
1495,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، ‏‏‏‏‏‏حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، ‏‏‏‏‏‏حَدَّثَنَا إِبْرَاه,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الجنائز۳۹ (۱۰۲۶)،(تحفة الأشراف:۶۴۶۸)، وقد أخرجہ: صحیح البخاری/الجنائز۶۵ (۱۲۳۵),1495,,Chapters Regarding Funerals
1496,حَدَّثَنَا عَمْرُو بْنُ أَبِي عَاصِمٍ النَّبِيلُ، ‏‏‏‏‏‏ وَإِبْرَاهِيمُ بْنُ الْمُسْتَمِرِّ، ‏‏‏‏‏‏ق,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۳۳۲، ومصباح الزجاجة:۵۳۲),1496,,Chapters Regarding Funerals
1497,حَدَّثَنَا أَبُو عُبَيْدٍ مُحَمَّدُ بْنُ عُبَيْدِ بْنِ مَيْمُونٍ الْمَدِينِيِّ، ‏‏‏‏‏‏حَدَّثَنَا مُح,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: ابی داود/الجنائز۶۰ (۳۱۹۹)،(تحفة الأشراف:۱۴۹۹۳),1497,,Chapters Regarding Funerals
1498,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ، ‏‏‏‏‏‏عَنْ مُحَمَّدِ بْنِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۹۹۴)، وقد أخرجہ: مسند احمد (۲/۳۶۸),1498,,Chapters Regarding Funerals
1499,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُس,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/الجنائز۶۰ (۳۲۰۲)،(تحفة الأشراف:۱۷۷۵۳)، وقد أخرجہ: مسند احمد (۳/۴۹۱),1499,,Chapters Regarding Funerals
1500,حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو دَاوُدَ الطَّيَالِسِيُّ، ‏‏‏‏‏‏حَدَّثَنَا فَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۹۰۷)، وقد أخرجہ: صحیح مسلم/الجنائز۲۶ (۹۶۳)، سنن الترمذی/الجنائز۳۸ (۱۰۲۵)، سنن النسائی/الطہارة۵۰ (۶۲)، الجنائز ۷۷ (۱۹۸۵)، مسند احمد (۶/۲۳،۲۸),1500,,Chapters Regarding Funerals
1501,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، ‏‏‏‏‏‏عَنْ حَجَّاجٍ، ‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۶۷۸، ومصباح الزجاجة:۵۳۳)، وقد أخرجہ: مسند احمد (۳/۳۵۷),1501,,Chapters Regarding Funerals
1502,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۸۲۸، ومصباح الزجاجة:۵۳۴),1502,,Chapters Regarding Funerals
1503,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِبِيُّ، ‏‏‏‏‏‏حَدَّث,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۱۵۲، ومصباح الزجاجة:۵۳۵)وقد أخرجہ: مسند احمد (۴/۳۵۶،۳۸۳),1503,,Chapters Regarding Funerals
1504,حَدَّثَنَا أَبُو هِشَامٍ الرِّفَاعِيُّ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏ وَأَبُو بَكْرِ ب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۸۹۱),1504,,Chapters Regarding Funerals
1505,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، ‏‏‏‏‏‏حَدَّثَنَا شُعْب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الجنائز۲۳ (۹۶۱)، سنن ابی داود/الجنائز۵۸ (۳۱۹۷)، سنن الترمذی/الجنائز۳۷ (۱۰۲۳)، سنن النسائی/الجنائز۷۶ (۱۹۸۴)،(تحفة الأشراف:۳۶۷۱)، وقد أخرجہ: مسند احمد (۴/۳۶۸،۳۷۰،۳۷۱،۳۷۲),1505,,Chapters Regarding Funerals
1506,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، ‏‏‏‏‏‏حَدَّثَنَا إِبْرَاهِيمُ بْنُ عَلِيٍّ ا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۷۸۲، ومصباح الزجاجة:۵۳۶),1506,,Chapters Regarding Funerals
1507,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا رَوْحُ بْنُ عُبَادَةَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/الجنائز ۴۹ (۳۱۸۰)، سنن الترمذی/الجنائز ۴۲ (۱۰۳۱)، سنن النسائی/الجنائز ۵۵ (۱۹۴۴)،۵۶ (۱۹۴۵)،(تحفة الأشراف:۱۱۴۹۰،۱۱۴۹۷)، وقد أخرجہ: مسند احمد (۴/۲۴۷،۲۴۸،۲۴۹،۲۵۲),1507,,Chapters Regarding Funerals
1508,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الرَّبِيعُ بْنُ بَدْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو ال,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۷۰۸)، و قد أخرجہ: سنن الترمذی/الجنائز ۴۳ (۱۰۳۲)، سنن الدارمی/الفرائض ۴۷ (۳۱۶۸),1508,,Chapters Regarding Funerals
1509,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْبَخْتَرِيُّ بْنُ عُبَيْدٍ، ‏‏‏‏‏‏عَنْ أَبِيهِ،,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۱۲۸، ومصباح الزجاجة:۵۳۷),1509,,Chapters Regarding Funerals
1510,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، ‏‏‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/الأدب ۱۰۹ (۶۱۹۴)،(تحفة الأشراف:۵۱۵۸)، وقد أخرجہ: مسند احمد (۴/۳۵۳),1510,,Chapters Regarding Funerals
1511,حَدَّثَنَا عَبْدُ الْقُدُّوسِ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا دَاوُدُ بْنُ شَبِيبٍ الْبَاهِلِيُّ، ‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۴۸۲، ومصباح الزجاجة:۵۳۸),1511,,Chapters Regarding Funerals
1512,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عِمْرَانَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو دَاوُدَ، ‏‏‏‏‏‏حَدَّثَنَا هِشَامُ ب,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۴۱۳، ومصباح الزجاجة:۵۳۹),1512,,Chapters Regarding Funerals
1513,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۴۹۷، ومصباح الزجاجة:۵۴۰),1513,,Chapters Regarding Funerals
1514,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنِ ابْنِ شِهَابٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/الجنائز۷۲ (۱۳۴۳)،۷۳ (۱۲۴۵)،۷۵ (۱۳۴۷)،۷۸ (۱۳۵۳)، المغازي ۱۲۶ (۴۰۷۹)، سنن ابی داود/ الجنائز ۳۱ (۳۱۳۸،۳۱۳۹)، سنن الترمذی/الجنائز۴۶ (۱۰۳۶)، سنن النسائی/الجنائز۶۲ (۱۹۵۷)،(تحفة الأشراف:۲۳۸۲),1514,,Chapters Regarding Funerals
1515,حَدَّثَنَا مُحَمَّدُ بْنُ زِيَادٍ، ‏‏‏‏‏‏حَدَّثَنَا عَلِيُّ بْنُ عَاصِمٍ، ‏‏‏‏‏‏عَنْ عَطَاءِ بْنِ ال,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الجنائز ۳۱ (۳۱۳۴)،(تحفة الأشراف:۵۵۷۰)، وقد أخرجہ: مسند احمد (۱/۲۴۷),1515,,Chapters Regarding Funerals
1516,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَسَهْلُ بْنُ أَبِي سَهْلٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا سُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الجنائز۴۲ (۳۱۶۵)، سنن الترمذی/الجہاد ۳۷ (۱۷۱۷)، سنن النسائی/الجنائز ۸۳ (۲۰۰۶)،(تحفة الأشراف:۳۱۱۷)، وقد أخرجہ: مسند احمد (۳/ ۲۹۷،۳۰۳،۳۰۸،۳۹۷)، سنن الدارمی/المقدمة ۷ (۴۶),1516,,Chapters Regarding Funerals
1517,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ ابْنِ أَبِي ذِئْبٍ، ‏‏‏‏‏‏عَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الجنائز ۵۴ (۳۱۹۱)،(تحفة الأشراف:۱۳۵۰۳)، وقد أخرجہ: مسند احمد (۲/۴۴۴،۴۵۵،۵۰۵),1517,,Chapters Regarding Funerals
1518,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الجنائز ۵۴ (۳۱۸۹)،(تحفة الأشراف:۱۶۱۷۴)، وقد أخرجہ: صحیح مسلم/الجنائز۳۴ (۹۷۳)، سنن الترمذی/الجنائز۴۴ (۱۰۳۳)، سنن النسائی/الجنائز۷۰ (۱۹۶۹)، موطا امام مالک/الجنائز۸ (۲۲)، مسند احمد (۶/۷۹،۱۳۳،۱۶۹),1518,,Chapters Regarding Funerals
1519,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ . ح وحَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/المسافرین ۵۱ (۸۳۱)، سنن ابی داود/الجنائز۵۵ (۳۱۹۲)، سنن الترمذی/الجنائز۴۱ (۱۰۳۰)، سنن النسائی/المواقیت ۳۰ (۵۶۱)،۳۳ (۵۶۶)، الجنائز۸۹ (۲۰۱۵)،(تحفة الأشراف:۹۹۳۹)، وقد أخرجہ: مسند احمد (۴/۱۵۲)، سنن الدارمی/الصلاة ۱۴۲ (۱۴۷۲),1519,,Chapters Regarding Funerals
1520,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏أَنْبَأَنَا يَحْيَى بْنُ الْيَمَانِ، ‏‏‏‏‏‏عَنْ مِنْهَا,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الجنائز ۶۳ (۱۰۵۷)،(تحفة الأشراف:۵۸۸۹),1520,,Chapters Regarding Funerals
1521,حَدَّثَنَا عَمْرُو بْنُ عَبْدِ اللَّهِ الْأَوْدِيُّ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ إِبْرَاهِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۶۵۳)، وقد أخرجہ: صحیح مسلم/الجنائز۱۵ (۹۴۳)، سنن ابی داود/الجنائز ۲۴ (۳۱۴۸)، سنن النسائی/الجنائز ۳۷ (۱۸۹۶)، مسند احمد (۳/۲۹۵),1521,,Chapters Regarding Funerals
1522,حَدَّثَنَا الْعَبَّاسُ بْنُ عُثْمَانَ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، ‏‏‏,Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۷۸۲، ومصباح الزجاجة:۵۴۲)وقد أخرجہ: مسند احمد (۳/۳۳۶،۳۴۹),1522,,Chapters Regarding Funerals
1523,حَدَّثَنَا أَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، ‏‏‏‏‏‏عَنْ عُبَيْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الجنائز۲۲ (۱۲۶۹)، تفسیرالتوبہ ۱۲ (۴۶۷۰)،۱۳ (۴۶۷۲)، اللباس ۸ (۵۷۹۶)، صحیح مسلم/فضائل الصحابة ۲ (۲۴۰۰)، صفات المنافقین ۳ (۲۷۷۴)، سنن الترمذی/تفسیر التوبة (۳۰۹۸)، سنن النسائی/الجنائز ۴۰ (۱۹۰۱)،(تحفة الأشراف:۸۱۳۹)، وقد أخرجہ: مسند احمد (۲/۱۸),1523,,Chapters Regarding Funerals
1524,حَدَّثَنَا عَمَّارُ بْنُ خَالِدٍ الْوَاسِطِيُّ، ‏‏‏‏‏‏ وَسَهْلُ بْنُ أَبِي سَهْلٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏,Al-Albani: Munkar; Muhammad Fouad Abd al-Baqi: Munkar; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۳۵۵),1524,,Chapters Regarding Funerals
1525,حَدَّثَنَا أَحْمَدُ بْنُ يُوسُفَ السُّلَمِيُّ، ‏‏‏‏‏‏حَدَّثَنَا مُسْلِمُ بْنُ إِبْرَاهِيمَ، ‏‏‏‏‏‏حَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۷۵۰، ومصباح الزجاجة:۵۴۲),1525,,Chapters Regarding Funerals
1526,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَامِرِ بْنِ زُرَارَةَ، ‏‏‏‏‏‏حَدَّثَنَا شَرِيكُ بْنُ عَبْدِ اللَّهِ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: سنن ابی داود/الجنائز ۵۱ (۳۱۸۵)، سنن الترمذی/الجنائز ۶۸ (۱۰۶۸)،(تحفة الأشراف:۲۱۷۴)، وقد أخر جہ: صحیح مسلم/الجنائز ۳۶ (۹۷۸)، سنن النسائی/الجنائز ۶۸ (۱۹۶۳)، مسند احمد (۵/۸۷،۹۲،۹۴،۹۶،۹۷),1526,,Chapters Regarding Funerals
1527,حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، ‏‏‏‏‏‏أَنْبَأَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏حَدَّثَنَا ثَابِتٌ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الصلاة ۷۴ (۴۵۸)، صحیح مسلم/الجنائز۲۳ (۹۵۶)، سنن ابی داود/الجنائز ۶۱ (۳۲۰۳)،(تحفة الأشراف:۱۴۶۵۰)، وقد أخرجہ: مسند احمد (۲/۳۵۳),1527,,Chapters Regarding Funerals
1528,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا هُشَيْمٌ، ‏‏‏‏‏‏حَدَّثَنَا عُثْمَانُ ب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الجنائز ۹۴ (۲۰۲۴)،(تحفة الأشراف:۱۱۸۲۴)، وقد أخرجہ: مسند احمد (۴/۳۸۸),1528,,Chapters Regarding Funerals
1529,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ ا,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۰۴۰، ومصباح الزجاجة:۵۴۳)، وقد أخرجہ: مسند احمد (۳/۴۴۴),1529,,Chapters Regarding Funerals
1530,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَنْ أَبِي إِسْحَاق الش,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: «صحیح البخاری/الأذان ۱۶۱ (۸۵۷)، الجنائز۵ (۱۲۴۷)،۵۴ (۱۳۲۱)،۵۵ (۱۳۲۲)،۵۹ (۱۳۲۶)،۶۶ (۱۳۳۶)،۶۹ (۱۳۴۰)، صحیح مسلم/الجنائز ۲۳ (۹۵۴)، سنن ابی داود/الجنائز ۵۸ (۳۱۹۶)، سنن الترمذی/الجنائز ۴۷ (۱۰۳۷)، سنن النسائی/الجنائز۹۴ (۲۰۲۵،۲۰۲۶)،(تحفة الأشراف:۵۷۶۶)، وقد أخرجہ: مسند احمد (۱/۲۲۴،۲۳۸،۳۳۸),1530,,Chapters Regarding Funerals
1531,حَدَّثَنَا الْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ الْعَنْبَرِيُّ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الجنائز ۲۳ (۹۵۵)،(تحفة الأشراف:۲۸۳)، وقد أخرجہ: مسند احمد (۲/۴۰۶،۳/۱۳۰),1531,,Chapters Regarding Funerals
1532,حَدَّثَنَا مُحَمَّدُ بْنُ حُمَيْدٍ، ‏‏‏‏‏‏حَدَّثَنَا مِهْرَانُ بْنُ أَبِي عُمَرَ، ‏‏‏‏‏‏عَنْ أَبِي س,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۹۴۳، ومصباح الزجاجة:۵۴۴),1532,,Chapters Regarding Funerals
1533,حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا سَعِيدُ بْنُ شُرَحْبِيلَ، ‏‏‏‏‏‏عَنِ ابْنِ لَهِيعَةَ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۰۶۹، ومصباح الزجاجة:۵۴۵),1533,,Chapters Regarding Funerals
1534,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْأَعْلَى، ‏‏‏‏‏‏عَنْ مَعْمَرٍ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: «صحیح البخاری/الجنائز ۴ (۱۲۴۵)،۵۴ (۱۳۱۸)،۶۰ (۱۳۳۴)، سنن الترمذی/الجنائز۳۷ (۱۰۲۲)،(تحفة الأشراف:۱۳۲۶۷)، وقد أخرجہ: سنن ابی داود/الجنائز ۶۲ (۳۲۰۴)، سنن النسائی/الجنائز ۷۲ (۱۹۷۳)، موطا امام مالک/الجنائز۵ (۱۴)، مسند احمد (۲/۲۳۰،۲۸۰،۴۳۸،۴۳۹),1534,,Chapters Regarding Funerals
1535,حَدَّثَنَا يَحْيَى بْنُ خَلَفٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ زِيَادٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا بِشْرُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «سنن الترمذی/الجنائز ۴۸ (۱۰۳۹)، سنن النسائی/الجنائز ۷۲ (۱۹۷۷)،(تحفة الأشراف:۱۰۸۸۹)، وقد أخرجہ: صحیح مسلم/الجنائز ۲۲ (۹۵۳)، مسند احمد (۴/۴۳۱،۴۳۳،۴۴۱),1535,,Chapters Regarding Funerals
1536,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ، ‏‏‏‏‏‏حَدَّث,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۲۱۶، و مصباح الزجاجة:۵۴۶),1536,,Chapters Regarding Funerals
1537,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، ‏‏‏‏‏‏عَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۳۰۰، ومصباح الزجاجة:۵۴۷)، مسند احمد (۴/۷),1537,,Chapters Regarding Funerals
1538,حَدَّثَنَا سَهْلُ بْنُ أَبِي سَهْلٍ، ‏‏‏‏‏‏حَدَّثَنَا مَكِّيُّ بْنُ إِبْرَاهِيمَ أَبُو السَّكَنِ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۴۰۰، ومصباح الزجاجة:۵۴۸),1538,,Chapters Regarding Funerals
1539,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْأَعْلَى، ‏‏‏‏‏‏عَنْ مَعْمَرٍ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: «صحیح البخاری/الأیمان ۳۵ (۴۷)، الجنائز ۵۸ (۱۳۲۵)، صحیح مسلم/الجنائز۱۷ (۹۴۵)، سنن النسائی/الجنائز۷۹ (۱۹۹۶)، الإیمان ۲۶ (۵۰۳۵)،(تحفة الأشراف:۱۳۲۶۶)، وقد أخرجہ: سنن ابی داود/الجنائز۴۵ (۳۱۶۸)، سنن الترمذی/الجنائز ۴۹ (۱۰۴۰)، مسند احمد (۲/۲،۲۳۳،۲۴۶،۲۸۰،۳۲۱،۳۸۷،۴۰۱،۴۳۰،۴۵۸،۴۷۵،۴۸۰،۴۹۳،۴۹۸،۵۰۳،۵۲۱،۵۳۱),1539,,Chapters Regarding Funerals
1540,حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، ‏‏‏‏‏‏حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، ‏‏‏‏‏‏حَدَّثَنَا سَعِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الجنائز ۱۷ (۹۴۶)،(تحفة الأشراف:۲۱۱۵)، مسند احمد (۵/۲۷۶،۲۷۷،۲۸۲،۲۸۳،۲۸۴),1540,,Chapters Regarding Funerals
1541,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ الْمُحَارِبِيُّ، ‏‏‏‏‏‏ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۳، ومصباح الزجاجة:۵۴۱)، وقد أخرجہ: مسند احمد (۵/۱۳۱),1541,,Chapters Regarding Funerals
1542,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنِ نَافِعٍ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: «صحیح البخاری/الجنائز ۴۶ (۱۳۰۷)،۴۷ (۱۳۰۸)، صحیح مسلم/الجنائز۲۴ (۹۵۸)، سنن ابی داود/الجنائز ۴۷ (۳۱۷۲)، سنن الترمذی/الجنائز ۵۱ (۱۰۴۲)، سنن النسائی/الجنائز ۴۵ (۱۹۱۶)،(تحفة الأشراف:۵۰۴۱)، مسند احمد (۳/۴۴۵،۴۴۶،۴۴۷),1542,,Chapters Regarding Funerals
1543,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَهَنَّادُ بْنُ السَّرِيِّ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۰۶۶، ومصباح الزجاجة:۵۵۰)، وقد أخرجہ: مسند احمد (۲/۲۸۷،۳۴۳),1543,,Chapters Regarding Funerals
1544,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ شُعْبَةَ، ‏‏‏‏‏‏عَنْ مُحَمَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الجنائز ۲۵ (۹۶۲)، سنن ابی داود/الجنائز ۴۷ (۳۱۷۵)، سنن الترمذی/الجنائز ۵۲ (۱۰۴۴)، سنن النسائی/الجنائز ۸۱ (۲۰۰۱)،(تحفة الأشراف:۱۹۲۷۶)، وقد أخرجہ: موطا امام مالک/الجنائز ۱۱ (۳۳)، مسند احمد (۱/۸۲،۸۳،۱۳۱،۱۳۸),1544,,Chapters Regarding Funerals
1545,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏ وَعُقْبَةُ بْنُ مُكْرَمٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا صَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الجنائز ۴۷ (۳۱۷۶)، سنن الترمذی/الجنائز ۳۵ (۱۰۲۰)،(تحفة الأشراف:۵۰۷۶),1545,,Chapters Regarding Funerals
1546,حَدَّثَنَا إِسْمَاعِيل بْنُ مُوسَى، ‏‏‏‏‏‏حَدَّثَنَا شَرِيكُ بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏عَنْ عَاصِمِ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,"Book 6, Hadith 114",1546,,Chapters Regarding Funerals
1547,حَدَّثَنَا مُحَمَّدُ بْنُ عَبَّادِ بْنِ آدَمَ، ‏‏‏‏‏‏حَدَّثَنَا أَحْمَدُ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الجنائز ۳۵ (۹۷۵)، سنن النسائی/الجنائز ۱۰۳ (۲۰۴۲)،(تحفة الأشراف:۱۹۳۰)، وقد أخرجہ: مسند احمد (۵/۳۵۳،۳۶۰),1547,,Chapters Regarding Funerals
1548,حَدَّثَنَا مُحَمَّدُ بْنُ زِيَادٍ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏عَنْ يُونُسَ بْنِ خَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الجنائز ۶۸ (۳۲۱۲)، السنة ۲۷ (۴۷۵۳،۳۷۵۴)، سنن النسائی/الجنائز۸۱ (۲۰۰۳)،(تحفة الأشراف:۱۷۵۸)، وقد أخرجہ: مسند احمد (۴/۲۸۷،۲۹۵،۲۹۷),1548,,Chapters Regarding Funerals
1549,حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ، ‏‏‏‏‏‏عَنْ عَمْرِو بْنِ قَيْس,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: انظر ما قبلہ،(تحفة الأشراف:۱۷۵۹),1549,,Chapters Regarding Funerals
1550,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ، ‏‏‏‏‏‏حَدَّثَنَا لَيْث,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «حدیث ہشام بن عمار تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۳۱۹)، وحدیث عبد اللہ بن سعید أخرجہ: سنن الترمذی/الجنائز ۵۴ (۱۰۴۶)،(تحفة الأشراف:۷۶۴۴)، وقد أخرجہ: سنن ابی داود/الجنائز ۶۹ (۳۲۱۳)، مسند احمد (۲/۲۷،۴۰،۵۹،۶۹،۱۲۷),1550,,Chapters Regarding Funerals
1551,حَدَّثَنَا عَبْدُ الْمَلِكِ بْنُ مُحَمَّدٍ الرَّقَاشِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ ال,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۰۱۴، ومصباح الزجاجة:۵۵۱),1551,,Chapters Regarding Funerals
1552,حَدَّثَنَا هَارُونُ بْنُ إِسْحَاق، ‏‏‏‏‏‏حَدَّثَنَا الْمُحَارِبِيُّ، ‏‏‏‏‏‏عَنْ عَمْرِو بْنِ قَيْسٍ،,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۲۱۸، ومصباح الزجاجة:۵۵۲),1552,,Chapters Regarding Funerals
1553,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ عَبْدِ الرَّحْمَنِ الْكَلْبِيُّ، ‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ (تحفة الأشراف:۷۰۸۴، ومصباح الزجاجة:۵۵۳),1553,,Chapters Regarding Funerals
1554,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا حَكَّامُ بْنُ سَلْمٍ الرَّا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الجنائز ۶۵ (۳۲۰۸)، سنن الترمذی/الجنائز ۵۳ (۱۰۴۵)، سنن النسائی/الجنائز۸۵ (۲۰۱۱)،(تحفة الأشراف:۵۵۴۲),1554,,Chapters Regarding Funerals
1555,حَدَّثَنَا إِسْمَاعِيل بْنُ مُوسَى السُّدِّيُّ، ‏‏‏‏‏‏حَدَّثَنَا شَرِيكٌ، ‏‏‏‏‏‏عَنْ أَبِي الْيَقْظَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۲۰۹، ومصباح الزجاجة:۵۵۴)، وقد أخرجہ: مسند احمد (۲/۳۵۷،۳۵۹،۳۶۲),1555,,Chapters Regarding Funerals
1556,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏حَدَّثَنَا أَبُو عَامِرٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الجنائز ۲۹ (۹۶۶)، سنن النسائی/الجنائز۸۵ (۲۰۱۰)،(تحفة الأشراف:۳۸۶۷)، وقد أخرجہ: مسند احمد (۱/۱۶۹،۱۷۳،۱۸۴),1556,,Chapters Regarding Funerals
1557,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، ‏‏‏‏‏‏حَدَّثَنَا هَاشِمُ بْنُ الْقَاسِمِ، ‏‏‏‏‏‏حَدَّثَنَا مُبَ,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۳۹، ومصباح الزجاجة:۵۵۵)، وقد أخرجہ: مسند احمد۳۰/۱۳۹),1557,,Chapters Regarding Funerals
1558,حَدَّثَنَا عُمَرُ بْنُ شَبَّةَ بْنِ عُبَيْدَةَ بْنِ زَيْدٍ، ‏‏‏‏‏‏حَدَّثَنَا عُبَيْدُ بْنُ طُفَيْلٍ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۲۴۶، ومصباح الزجاجة:۵۵۶),1558,,Chapters Regarding Funerals
1559,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، ‏‏‏‏‏‏حَدَّثَن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۱، ومصباح الزجاجة:۵۵۷),1559,,Chapters Regarding Funerals
1560,حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الجنائز۷۱ (۳۲۱۵،۳۲۱۶، سنن الترمذی/الجہاد ۳۳ (۱۷۱۳)، سنن النسائی/الجنائز ۸۶ (۲۰۱۲)،۸۷ (۲۰۱۳)،۹۰ (۲۰۱۷)،۹۱ (۲۰۲۰)،(تحفة الأشراف:۱۱۷۳۱)، وقد أخرجہ: مسند احمد (۴/۱۹،۲۰),1560,,Chapters Regarding Funerals
1561,حَدَّثَنَا الْعَبَّاسُ بْنُ جَعْفَرٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ أَيُّوبَ أَبُو هُرَيْرَةَ الْو,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۳۰، و مصباح الزجاجة:۵۵۸),1561,,Chapters Regarding Funerals
1562,حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ زِيَادٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الجنائز۳۲ (۹۷۰)، سنن ابی داود/الجنائز ۷۶ (۳۲۲۵)، سنن الترمذی/الجنائز ۵۸ (۱۰۵۲)، سنن النسائی/الجنائز ۹۶ (۲۰۲۹)،(تحفة الأشراف:۲۶۶۸)، وقد أخرجہ: مسند احمد (۳/۲۹۵،۳۳۲،۳۹۹),1562,,Chapters Regarding Funerals
1563,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، ‏‏‏‏‏‏عَنِ ابْنِ جُرَي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن النسائی/الجنائز ۹۶ (۲۰۲۹)،(تحفة الأشراف:۲۲۷۴)، وقد أخرجہ: سنن ابی داود/الجنائز ۷۶ (۳۲۲۶)، سنن الترمذی/الجنائز ۵۸ (۱۰۵۲),1563,,Chapters Regarding Funerals
1564,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الرَّقَاشِيُّ، ‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۲۷۷، ومصباح الزجاجة:۵۵۹),1564,,Chapters Regarding Funerals
1565,حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ صَالِحٍ، ‏‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۴۰۲، ومصباح الزجاجة:۵۶۰),1565,,Chapters Regarding Funerals
1566,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الجنائز ۳۳ (۹۷۱)، سنن ابی داود/الجنائز ۷۷ (۳۲۲۸)، سنن النسائی/الجنائز ۱۰۵ (۲۰۴۶)،(تحفة الأشراف:۱۲۶۹۶)، وقد أخرجہ: مسند احمد (۲/۳۱۱،۳۸۹،۴۴۴،۵۲۸),1566,,Chapters Regarding Funerals
1567,حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيل بْنِ سَمُرَةَ، ‏‏‏‏‏‏حَدَّثَنَا الْمُحَارِبِيُّ، ‏‏‏‏‏‏عَنِ ال,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۹۶۴، ومصباح الزجاجة:۵۶۱),1567,,Chapters Regarding Funerals
1568,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا الْأَسْوَدُ بْنُ شَيْب,Al-Albani: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Sahih,"Book 6, Hadith 136",1568,,Chapters Regarding Funerals
1569,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ، ‏‏‏‏‏‏عَنْ يَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الجنائز ۳۶ (۹۷۶)، سنن ابی داود/الجنائز۸۱ (۳۲۳۴)، سنن النسائی/الجنائز ۱۰۱ (۲۰۳۶)،(تحفة الأشراف:۱۳۴۳۹)، وقد أخرجہ: مسند احمد (۷/۴۴۱),1569,,Chapters Regarding Funerals
1570,حَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعِيدٍ الْجَوْهَرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا رَوْحٌ، ‏‏‏‏‏‏حَدَّثَنَا بِسْط,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۲۶۶، ومصباح الزجاجة:۵۶۲),1570,,Chapters Regarding Funerals
1571,حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الْأَعْلَى، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ وَهْبٍ، ‏‏‏‏‏‏أَنْبَأَنَا ابْنُ جُ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۵۶۲، ومصباح الزجاجة:۵۶۳)، وقد أخرجہ: مسند احمد (۱/۴۵۲),1571,,Chapters Regarding Funerals
1572,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ، ‏‏‏‏‏‏حَدَّثَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: صحیح مسلم/الجنائز ۳۶ (۹۷۶)، سنن ابی داود/الجنائز۸۱ (۳۲۳۴)، سنن النسائی/الجنائز ۱۰۱ (۲۰۳۶)،(تحفة الأشراف:۱۳۴۳۹)، وقد أخرجہ: مسند احمد (۲/۴۴۱),1572,,Chapters Regarding Funerals
1573,حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيل بْنِ الْبَخْتَرِيِّ الْوَاسِطِيُّ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۸۰۳، ومصباح الزجاجة:۵۶۴),1573,,Chapters Regarding Funerals
1574,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَأَبُو بِشْرٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا قَب,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۴۰۳، ومصباح الزجاجة:۵۶۵)، وقد أخرجہ: مسند احمد (۳/۴۴۲،۴۴۳),1574,,Chapters Regarding Funerals
1575,حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْوَارِثِ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ ب,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/الجنائز ۸۲ (۳۲۳۶)، سنن الترمذی/الصلاة ۱۲۲ (۳۲۰)، سنن النسائی/الجنائز۱۰۴ (۲۰۴۵)،(تحفة الأشراف:۵۳۷۰)، وقد أخرجہ: مسند احمد (۱/۲۲۹،۳۲۴،۳۳۷),1575,,Chapters Regarding Funerals
1576,حَدَّثَنَا مُحَمَّدُ بْنُ خَلَفٍ الْعَسْقَلَانِيُّ أَبُو نَصْرٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ طَا,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن الترمذی/الجنائز ۶۲ (۱۰۵۶)،(تحفة الأشراف:۱۴۹۸۰)، وقد أخرجہ: مسند احمد (۲/۳۳۷،۳۵۶),1576,,Chapters Regarding Funerals
1577,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ هِشَامٍ، ‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الجنائز۲۹ (۱۲۷۸)، صحیح مسلم/الجنائز۱۱ (۹۳۸)،(تحفة الأشراف:۱۸۱۳۹)، وقد أخرجہ: سنن ابی داود/الجنائز ۴۴ (۳۱۶۷)، مسند احمد (۶/۴۰۸),1577,,Chapters Regarding Funerals
1578,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، ‏‏‏‏‏‏حَدَّثَنَا أَحْمَدُ بْنُ خَالِدٍ، ‏‏‏‏‏‏حَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۲۶۹، ومصباح الزجاجة:۵۶۶),1578,,Chapters Regarding Funerals
1579,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ يَزِيدَ بْنِ عَبْد,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن الترمذی/تفسیر القرآن ۶۰ (۳۳۰۷)،(تحفة الأشراف:۱۵۷۶۹)، وقد أخرجہ: مسند احمد (۶/۳۲۰),1579,,Chapters Regarding Funerals
1580,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْد,Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۴۰۳، ومصباح الزجاجة:۵۶۷)، وقد أخرجہ: مسند احمد (۴/۱۰۱),1580,,Chapters Regarding Funerals
1581,حَدَّثَنَا الْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ الْعَنْبَرِيُّ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۱۶۰، ومصباح الزجاجة:۵۶۸)، وقد أخرجہ: صحیح مسلم/الجنائز۱۰ (۹۲۴)، مسند احمد (۵/۳۴۲),1581,,Chapters Regarding Funerals
1582,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، ‏‏‏‏‏‏حَدَّثَنَا عُمَرُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۲۴۷، ومصباح الزجاجة:۵۶۹),1582,,Chapters Regarding Funerals
1583,حَدَّثَنَا أَحْمَدُ بْنُ يُوسُفَ، ‏‏‏‏‏‏حَدَّثَنَا عُبَيْدُ اللَّهِ، ‏‏‏‏‏‏أَنْبَأَنَا إِسْرَائِيلُ،,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۴۰۵، ومصباح الزجاجة:۵۷۰)، وقد أخرجہ: مسند احمد (۲/۹۲),1583,,Chapters Regarding Funerals
1584,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ . ح وحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: حدیث علی بن محمد ومحمد بن بشار قد أخرجہ: صحیح البخاری/الجنائز ۳۵ (۱۲۵۴)، سنن الترمذی/الجنائز ۲۲ (۹۹۹)، سنن النسائی/الجنائز ۱۷ (۱۸۶۱)،(تحفة الأشراف:۹۵۵۹)، وحدیث علی بن محمد وابو بکربن خلاّد قد أخرجہ: صحیح البخاری/المناقب ۸ (۳۵۱۹)، الجنائز ۳۸ (۱۲۹۷)،۳۹ (۱۲۹۸)، صحیح مسلم/الإیمان ۴۴ (۱۰۳)، سنن النسائی/الجنائز ۱۷ (۱۸۶۱)،(تحفة الأشراف:۹۵۶۹)، وقد أخرجہ: مسند احمد (۱/۳۸۶،۴۳۲،۴۴۲،۴۶۵),1584,,Chapters Regarding Funerals
1585,حَدَّثَنَا مُحَمَّدُ بْنُ جَابِرٍ الْمُحَارِبِيُّ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ كَرَامَةَ، ‏‏‏‏‏‏قَالَا:‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۹۲۲، ومصباح الزجاجة:۵۷۱),1585,,Chapters Regarding Funerals
1586,حَدَّثَنَا أَحْمَدُ بْنُ عُثْمَانَ بْنِ حَكِيمٍ الْأَوْدِيُّ، ‏‏‏‏‏‏حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الإیمان ۴۴ (۱۰۴)، سنن النسائی/الجنائز۲۰ (۱۸۶۶)،(تحفة الأشراف:۹۰۲۰،۹۰۸۱)، وقد أخرجہ: سنن ابی داود/الجنائز۲۹ (۳۱۳۰)، مسند احمد (۴/۳۹۶،۴۰۴،۴۰۵،۴۱۱،۴۱۶),1586,,Chapters Regarding Funerals
1587,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن النسائی/الجنائز ۱۶ (۱۸۶۰)،(تحفة الأشراف:۱۳۴۷۵)، وقد أخرجہ: مسند احمد (۲/۱۱۰،۲۷۳،۳۳۳،۴۰۸،۴۴۴),1587,,Chapters Regarding Funerals
1588,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْوَاحِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الجنائز ۳۲ (۱۲۸۴)، المرضی ۹ (۵۶۵۵)، القدر ۴ (۶۶۰۲)، الأیمان والنذور ۹ (۶۶۵۵)، التوحید ۲ (۷۳۷۷)،۲۵ (۷۴۴۸)، صحیح مسلم/الجنائز ۶ (۹۲۳)، سنن ابی داود/الجنائز ۲۸ (۳۱۲۵)، سنن النسائی/الجنائز ۲۲ (۱۸۶۹)،(تحفة الأشراف:۹۸)، وقد أخرجہ: مسند احمد (۵/۲۰۴،۲۰۶،۲۰۷),1588,,Chapters Regarding Funerals
1589,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سُلَيْمٍ، ‏‏‏‏‏‏عَنْ ابْنِ خُثَيْمٍ،,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۷۷۲، ومصباح الزجاجة:۵۷۲),1589,,Chapters Regarding Funerals
1590,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا إِسْحَاق بْنُ مُحَمَّدٍ الْفَرْوِيُّ، ‏‏‏‏‏‏حَدّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۸۲۲ومصباح الزجاجة:۵۷۳),1590,,Chapters Regarding Funerals
1591,حَدَّثَنَا هَارُونُ بْنُ سَعِيدٍ الْمِصْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏أَ,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۴۹۱، ومصباح الزجاجة:۵۷۴)، وقد أخرجہ: مسند احمد (۲/۴۰،۸۴،۹۲),1591,,Chapters Regarding Funerals
1592,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنْ إِبْرَاهِيمَ الْهَجَرِيِّ،,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۱۵۳، ومصباح الزجاجة:۱۵۷۵),1592,,Chapters Regarding Funerals
1593,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا شَاذَانُ . ح وحَدَّثَنَا مُحَمَّدُ بْن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الجنائز ۳۳ (۱۲۹۲)، صحیح مسلم/الجنائز ۹ (۹۲۷)، سنن النسائی/الجنائز ۱۵ (۱۸۵۴)،(تحفة الأشراف:۱۰۵۳۶)، وقد أخرجہ: سنن الترمذی/الجنائز ۲۴ (۱۰۰۲)، مسند احمد (۱/۲۶،۳۶،۴۷،۵۰،۵۱،۵۴),1593,,Chapters Regarding Funerals
1594,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ ا,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۰۳۱، ومصباح الزجاجة:۵۷۶)، وقد أخرجہ: سنن الترمذی/الجنائز ۲۴ (۱۰۰۳)، مسند احمد (۴/ ۴۱۴),1594,,Chapters Regarding Funerals
1595,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ عَمْرٍو، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۲۵۹)، وقد أخرجہ: صحیح البخاری/الجنائز ۳۲ (۱۲۸۹)، صحیح مسلم/الجنائز۹ (۹۳۲)، سنن الترمذی/الجنائز ۲۵ (۱۰۰۴)، سنن النسائی/الجنائز۱۵ (۱۸۵۷)، موطا امام مالک/الجنائز۱۲ (۳۷)، مسند احمد (۶/۱۰۷،۲۵۵),1595,,Chapters Regarding Funerals
1596,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ يَزِيدَ بْنِ أ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن الترمذی/الجنائز ۱۳ (۹۸۸)،(تحفة الأشراف:۸۴۸)، وقد أخرجہ: صحیح البخاری/الجنائز ۳۱ (۱۲۸۳)،۴۲ (۱۳۰۲)، الأحکام ۱۱ (۷۱۵۴)، صحیح مسلم/الجنائز ۸ (۹۲۶)، سنن ابی داود/الجنائز ۲۷ (۳۱۲۴)، سنن النسائی/الجنائز ۲۲ (۱۸۷۰)، مسند احمد (۳/۱۳۰،۱۴۳،۲۱۷),1596,,Chapters Regarding Funerals
1597,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ، ‏‏‏‏‏‏حَدَّثَنَا ثَابِ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۹۱۱، ومصباح الزجاجة:۵۷۷)، وقد أخرجہ: مسند احمد (۵/۲۵۸),1597,,Chapters Regarding Funerals
1598,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏أَنْبَأَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: سنن الترمذی/الدعوات ۸۴ (۳۵۱۱)،(تحفة الأشراف:۶۵۷۷)، وقد أخرجہ: مسند احمد (۴/۲۷),1598,,Chapters Regarding Funerals
1599,حَدَّثَنَا الْوَلِيدُ بْنُ عَمْرِو بْنِ السُّكَيْنِ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو هَمَّامٍ، ‏‏‏‏‏‏حَدَّثَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۷۷۴، ومصباح الزجاجة:۵۷۸),1599,,Chapters Regarding Funerals
1600,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعُ بْنُ الْجَرَّاحِ، ‏‏‏‏‏‏عَنْ ه,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۴۱۴، ومصباح الزجاجة:۵۷۹)، وقد أخرجہ: مسند احمد (۱/۲۰۱),1600,,Chapters Regarding Funerals
1601,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، ‏‏‏‏‏‏حَدَّثَنِ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: (ابو عمارہ قیس میں کلام ہے، اور عبد اللہ بن أبی بکر بن محمد بن عمرو بن حزم عن أبیہ عن جدہ میں جد (دادا) محمد بن عمر و بن حزم ہیں، جن کو رویت حاصل ہے، لیکن صرف صحابہ کرام سے ہی سماع ہے، رسول اکرم ﷺ سے سماع نہیں ہے، لیکن انس رضی اللہ عنہ کے شاہد سے تقویت پاکر یہ حسن ہے، نیز ملاحظہ ہو: الإرواء:۷۶۴، وسلسلة الاحادیث الصحیحة، للالبانی:۱۹۵، تراجع الألبانی: رقم:۵۵),1601,,Chapters Regarding Funerals
1602,حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ عَاصِمٍ، ‏‏‏‏‏‏عَنْ مُحَمّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الجنائز ۷۲ (۱۰۷۳)،(تحفة الأشراف:۹۱۶۶),1602,,Chapters Regarding Funerals
1603,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الجنائز ۶ (۱۲۵۱)، الأیمان والنذور۹ (۶۶۵۶)، صحیح مسلم/البروالصلة ۴۷ (۲۶۳۲)،(تحفة الأشراف:۱۳۱۳۳)، وقد أخرجہ: سنن الترمذی/الجنائز ۶۴ (۱۰۶۰)، سنن النسائی/الجنائز ۲۵ (۱۸۷۶)، موطا امام مالک/الجنائز ۱۳ (۳۸)، مسند احمد (۲/۲۴۰،۲۷۶،۴۷۳،۴۷۹),1603,,Chapters Regarding Funerals
1604,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا إِسْحَاق بْنُ سُ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۷۵۴، ومصباح الزجاجة:۵۸۱)، وقد أخرجہ: مسند احمد (۴/۱۸۳،۱۸۴),1604,,Chapters Regarding Funerals
1605,حَدَّثَنَا يُوسُفُ بْنُ حَمَّادٍ الْمَعْنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/الجنائز ۶ (۱۲۴۸)،۹۱ (۱۳۸۱)، سنن النسائی/الجنائز ۲۵ (۱۸۷۴)،(تحفة الأشراف:۱۰۳۶)، وقد أخرجہ: مسند احمد (۳/۱۵۲),1605,,Chapters Regarding Funerals
1606,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، ‏‏‏‏‏‏حَدَّثَنَا إِسْحَاق بْنُ يُوسُفَ، ‏‏‏‏‏‏عَنِ ال,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الجنائز ۶۵ (۱۰۶۱)،(تحفة الأشراف:۹۶۳۴)، وقد أخرجہ: مسند احمد (۱/۳۷۵،۴۲۹،۴۵۱),1606,,Chapters Regarding Funerals
1607,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، ‏‏‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۸۳۱، ومصباح الزجاجة:۵۸۲),1607,,Chapters Regarding Funerals
1608,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ إِسْحَاق أَبُو بكر البكائي، ‏‏‏‏‏‏قَالَا:,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۱۳۲، ومصباح الزجاجة:۵۸۳),1608,,Chapters Regarding Funerals
1609,حَدَّثَنَا عَلِيُّ بْنُ هَاشِمِ بْنِ مَرْزُوقٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبِيدَةُ بْنُ حُمَيْدٍ، ‏‏‏‏‏‏حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۳۳۰، ومصباح الزجاجة:۵۸۴)، وقد أخرجہ: مسند احمد (۵/۲۴۱),1609,,Chapters Regarding Funerals
1610,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الجنائز ۲۶ (۳۱۳۲)، سنن الترمذی/الجنائز ۲۱ (۹۹۸)،(تحفة الأشراف:۵۲۱۷),1610,,Chapters Regarding Funerals
1611,حَدَّثَنَا يَحْيَى بْنُ خَلَفٍ أَبُو سَلَمَةَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَبْدُ الْأَعْلَى، ‏‏‏‏‏‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan Lighairihi; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۷۶، ومصباح الزجاجة:۵۸۵)، وقد أخرجہ: مسند احمد (۶/۳۷۰),1611,,Chapters Regarding Funerals
1612,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا سَعِيدُ بْنُ مَنْصُورٍ، ‏‏‏‏‏‏حَدَّثَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۲۳۰، ومصباح الزجاجة:۵۸۶)، مسند احمد (۲/۲۰۴),1612,,Chapters Regarding Funerals
1613,حَدَّثَنَا جَمِيلُ بْنُ الْحَسَنِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا أَبُو الْمُنْذِرِ الْهُذَيْلُ بْنُ ال,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۱۴۷، ومصباح الزجاجة:۵۸۷),1613,,Chapters Regarding Funerals
1614,حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏حَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن النسائی/الجنائز ۸ (۱۸۳۳)،(تحفة الأشراف:۸۸۵۶)، وقد أخرجہ: مسند احمد (۲/۱۷۷),1614,,Chapters Regarding Funerals
1615,حَدَّثَنَا أَحْمَدُ بْنُ يُوسُفَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أ,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Sanad Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۶۲۷، ومصباح الزجاجة:۵۸۸)، وقد أخرجہ: مسند احمد (۲/۴۰۴),1615,,Chapters Regarding Funerals
1616,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ الدَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الجنائز ۶۴ (۳۲۰۷)،(تحفة الأشراف:۱۷۸۹۳)، وقد أخرجہ: مسند احمد (۶/ ۵۸،۱۰۰،۱۰۵،۱۶۹،۲۰۰،۴۶۴),1616,,Chapters Regarding Funerals
1617,حَدَّثَنَا مُحَمَّدُ بْنُ مَعْمَرٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ بَكْرٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۲۷۷),1617,,Chapters Regarding Funerals
1618,حَدَّثَنَا سَهْلُ بْنُ أَبِي سَهْلٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنِ الزُّهْر,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الأذان ۳۹ (۶۶۵)،۴۶ (۶۷۹)،۴۷ (۶۸۳)،۵۱ (۶۸۷)،۶۷ (۷۱۲)،۶۸ (۷۱۳)،۷۰ (۷۹۶)، المغازي ۸۳ (۴۴۴۲)، الاعتصام ۵ (۷۳۰۳)، صحیح مسلم/الصلاة ۲۱ (۴۱۸)، سنن النسائی/الإمامة ۴۰ (۸۳۴)،(تحفة الأشراف:۱۶۳۰۹)، وقد أخرجہ: موطا امام مالک/قصرالصلاة ۲۴ (۸۳)، مسند احمد (۶/۳۴،۹۶،۹۷،۲۱۰،۲۲۴،۲۲۸،۲۴۹،۲۵۱)، دي الصلاة ۴۴ (۱۲۹۲),1618,,Chapters Regarding Funerals
1619,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَنْ الْأَعْم,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/المغازي ۸۴ (۴۴۳۷)، المرضی ۱۸ (۵۶۷۵)، الدعوات ۲۹ (۶۳۴۸)، صحیح مسلم/الطب ۱۹ (۲۱۹۱)، سنن الترمذی/ الدعوات ۷۷ (۳۴۹۶)،(تحفة الأشراف:۱۷۶۳۸)، وقد أخرجہ: موطا امام مالک/الجنائز ۱۶ (۴۶)، مسند احمد (۶/۴۴،۴۵،۱۰۹،۱۲۷)،(یہ حدیث مکرر ہے دیکھئے:۳۵۲۰),1619,,Chapters Regarding Funerals
1620,حَدَّثَنَا أَبُو مَرْوَانَ الْعُثْمَانِيُّ، ‏‏‏‏‏‏حَدَّثَنَا إِبْرَاهِيمُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ أَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/المغازي ۸۴ (۴۴۳۵،۴۴۳۶)، تفسیر سورة النساء ۱۳ (۴۵۸۶)، صحیح مسلم/فضائل الصحابة ۱۳ (۲۴۴۴)،(تحفة الأشراف:۱۶۳۳۸)، وقد أخرجہ: مسند احمد (۶/۱۷۶،۲۰۵،۲۶۹),1620,,Chapters Regarding Funerals
1621,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/المناقب ۲۵ (۳۶۲۳)، صحیح مسلم/فضائل الصحابة ۱۵ (۲۴۵۰)،(تحفة الأشراف:۱۷۶۱۵)، وقد أخرجہ: مسند احمد (۶/۲۸۲),1621,,Chapters Regarding Funerals
1622,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا مُصْعَبُ بْنُ الْمِقْدَامِ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/المرضی ۲ (۵۶۴۶)، صحیح مسلم/البروالصلة ۱۴ (۲۵۷۰)،(تحفة الأشراف:۱۷۶۰۹)، وقد أخرجہ: سنن الترمذی/الزہد ۵۶ (۲۳۹۷)، وقد أخرجہ: مسند احمد (۶/۱۸۱),1622,,Chapters Regarding Funerals
1623,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن الترمذی/الجنائز ۸ (۹۷۸)،(تحفة الأشراف:۱۷۵۵۶)، وقد أخرجہ: مسند احمد (۶/۶۴،۷۰،۷۷،۱۵۱),1623,,Chapters Regarding Funerals
1624,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنِ الزُّهْرِيّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح مسلم/الصلاة ۲۱ (۴۱۹)، سنن الترمذی/الشمائل ۵۳ (۳۸۵)، سنن النسائی/الجنائز ۷ (۱۸۳۲)،(تحفة الأشراف:۱۴۸۷)، وقد أخرجہ: مسند احمد (۳/۱۱۰،۱۶۳،۱۹۶،۱۹۷),1624,,Chapters Regarding Funerals
1625,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۱۵۴، ومصباح الزجاجة:۵۹۰)، وقد أخرجہ: مسند احمد (۶/۲۹۰،۳۱۱،۳۱۵،۳۲۱),1625,,Chapters Regarding Funerals
1626,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل ابْنُ عُلَيَّةَ، ‏‏‏‏‏‏عَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: صحیح البخاری/الوصایا ۱ (۲۷۴۱)، المغازي ۸۳ (۴۴۵۹)، صحیح مسلم/الوصیة ۵ (۱۶۳۶)، سنن الترمذی/الشمائل ۵۳ (۳۸۶)، سنن النسائی/الطہارة ۲۹ (۳۳)، الوصایا ۲ (۳۶۵۴)،(تحفة الأشراف:۱۵۹۷۰)، وقد أخرجہ: مسند احمد (۶/۲۲،۳۲),1626,,Chapters Regarding Funerals
1627,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَنْ عَبْدِ الرَّحْمَنِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: صحیح البخاری/الجنائز ۳ (۱۲۴۱)، المغازي ۸۳ (۴۴۵۲)، سنن النسائی/الجنائز ۱۱ (۱۸۴۲)،(تحفة الأشراف:۶۶۳۲)، وقد أخرجہ: مسند احمد (۶/۱۱۷),1627,,Chapters Regarding Funerals
1628,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، ‏‏‏‏‏‏أَنْبَأَنَا وَهْبُ بْنُ جَرِيرٍ، ‏‏‏‏‏‏حَدَّثَن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۰۲۲، ومصباح الزجاجة:۵۹۱)، وقد أخرجہ: مسند احمد (۱/۸،۲۶۰،۲۹۲),1628,,Chapters Regarding Funerals
1629,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ الزُّبَيْرِ أَبُو الزُّبَيْرِ،,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۵۰، ومصباح الزجاجة:۵۹۲)، وقد أخرجہ: صحیح البخاری/المغازي ۸۳ (۴۴۴۸)، مسند احمد (۳/۱۴۱),1629,,Chapters Regarding Funerals
1630,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏حَدَّثَنِي حَمَّادُ بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/المغازي ۸۳ (۴۴۴۸)،(تحفة الأشراف:۳۰۲)، وقد أخرجہ: سنن الدارمی/المقدمة ۱۴ (۸۸),1630,,Chapters Regarding Funerals
1631,حَدَّثَنَا بِشْرُ بْنُ هِلَالٍ الصَّوَّافُ، ‏‏‏‏‏‏حَدَّثَنَا جَعْفَرُ بْنُ سُلَيْمَانَ الضُّبَعِيُّ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن الترمذی/المناقب ۱ (۳۶۱۸)،(تحفة الأشراف:۲۶۸)، وقد أخرجہ: سنن الدارمی/المقدمة ۱۴ (۸۹),1631,,Chapters Regarding Funerals
1632,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، ‏‏‏‏‏‏حَدَّث,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/النکاح ۸۰ (۵۱۸۷)،(تحفة الأشراف:۷۱۵۶),1632,,Chapters Regarding Funerals
1633,حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ الْوَهَّابِ بْنُ عَطَاءٍ الْعِجْلِيُّ،,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱، ومصباح الزجاجة:۵۹۳),1633,,Chapters Regarding Funerals
1634,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، ‏‏‏‏‏‏حَدَّثَنَا خَالِي مُحَمَّدُ ابْنُ إِبْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۲۱۳، ومصباح الزجاجة:۵۹۴),1634,,Chapters Regarding Funerals
1635,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، ‏‏‏‏‏‏حَدَّثَنَا عَمْرُو بْنُ عَاصِمٍ، ‏‏‏‏‏‏حَدَّثَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۳۰۲، ومصباح الزجاجة:۵۹۵),1635,,Chapters Regarding Funerals
1636,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا الْحُسَيْنُ بْنُ عَلِيٍّ، ‏‏‏‏‏‏عَنْ ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الصلاة ۲۰۷ (۱۰۴۷)،۳۶۱ (۱۵۳۱)، سنن النسائی/الجمعة ۵ (۱۳۷۵)،(تحفة الأشراف:۱۷۳۶)، وقد أخرجہ: مسند احمد (۴/۸)، سنن الدارمی/الصلاة ۲۰۶ (۱۶۱۳),1636,,Chapters Regarding Funerals
1637,حَدَّثَنَا عَمْرُو بْنُ سَوَّادٍ الْمِصْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏عَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۹۴۷، ومصباح الزجاجة:۵۹۶),1637,,Chapters Regarding Funerals
