{"hadithnumber": "1711", "arabic": "[1711] سَمِعْتُ أَ بَا ہُرَیْرَۃَ یَقُولُ : قَالَ رَسُولُ اللّٰہِ  ﷺ  : مَنْ یُرِدِ اللّٰہُ بِہِ خَ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 50, Hadith 1", "international_number": "1711", "narrator_chain": ""}
{"hadithnumber": "1712", "arabic": "[1712] عَنْ یَحْیَی بْنِ سَعِیدٍ، أَنَّ رَجُلاً جَائَہُ الْمَوْتُ فِی زَمَانِ رَسُولِ اللّٰہِ  ﷺ ،", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 50, Hadith 2", "international_number": "1712", "narrator_chain": ""}
{"hadithnumber": "1713", "arabic": "[1713] عَنْ عُثْمَانَ بْنِ أبِی الْعَاصِ، أَ نَّہُ أَتَی رَسُولَ اللّٰہِ  ﷺ ، قَالَ عُثْمَانُ : و", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 50, Hadith 3", "international_number": "1713", "narrator_chain": ""}
{"hadithnumber": "1714", "arabic": "[1714] عَنْ عَائِشَۃَ : أَنَّ رَسُولَ اللّٰہِ  ﷺ  کَانَ إِذَا اشْتَکَی یَقْرَأُ عَلَی نَفْسِہِ بِا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 50, Hadith 4", "international_number": "1714", "narrator_chain": ""}
{"hadithnumber": "1715", "arabic": "[1715] عَنْ عَمْرَۃَ بِنْتِ عَبْدِ الرَّحْمَنِ : أَنَّ أَبَا بَکْرٍ الصِّدِّیقَ دَخَلَ عَلَی عَائِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 50, Hadith 5", "international_number": "1715", "narrator_chain": ""}
{"hadithnumber": "1716", "arabic": "[1716] عَنْ زَیْدِ بْنِ أَسْلَمَ : أَنَّ رَجُلاً فِی زَمَانِ رَسُولِ اللّٰہِ  ﷺ  أَصَابَہُ جُرْحٌ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 50, Hadith 6", "international_number": "1716", "narrator_chain": ""}
{"hadithnumber": "1717", "arabic": "[1717] عَنْ یَحْیَی بْنِ سَعِیدٍ، قَالَ : بَلَغَنِی أَنَّ أَسْعَدَ بْنَ زُرَارَۃَ اکْتَوَی فِی زَم", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 50, Hadith 7", "international_number": "1717", "narrator_chain": ""}
{"hadithnumber": "1718", "arabic": "[1718] عَنْ نَافِعٍ : أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ اکْتَوَی مِنَ اللَّقْوَۃِ، وَرُقِیَ مِنَ الْ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Daif'}", "reference": "Book 50, Hadith 8", "international_number": "1718", "narrator_chain": ""}
{"hadithnumber": "1719", "arabic": "[1719] عَنْ فَاطِمَۃَ بِنْتِ الْمُنْذِرِ، أَنَّ أَسْمَائَ بِنْتَ أبِی بَکْرٍ کَانَتْ إِذَا أُتِی", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 50, Hadith 9", "international_number": "1719", "narrator_chain": ""}
{"hadithnumber": "1720", "arabic": "[1720] عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ أَبِیہِ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ : إِنَّ الْحُمَّی", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 50, Hadith 10", "international_number": "1720", "narrator_chain": ""}
{"hadithnumber": "1721", "arabic": "[1721] وَحَدَّثَنِی مَالِکٌ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ: أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ: الْح", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 50, Hadith 11", "international_number": "1721", "narrator_chain": ""}
{"hadithnumber": "1722", "arabic": "[1722] عَنْ جَابِرِ بْنِ عَبْدِ اللّٰہِ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ : إِذَا عَادَ الرَّجُلُ ال", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Isnaad Daif'}", "reference": "Book 50, Hadith 12", "international_number": "1722", "narrator_chain": ""}
{"hadithnumber": "1723", "arabic": "[1723] عَنِ ابْنِ عَطِیَّۃَ : أَنَّ رَسُولَ اللّٰہِ  ﷺ  قَالَ : لَا عَدْوَی وَلَا ہَامَ وَلَا صَفَر", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih Lighairihi'}", "reference": "Book 50, Hadith 13", "international_number": "1723", "narrator_chain": ""}
{"hadithnumber": "1724", "arabic": "[1724] عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَنَّ رَسُولَ اللّٰہِ  ﷺ  أَمَرَ بِإِحْفَائِ الشَّوَارِبِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}", "reference": "Book 50, Hadith 14", "international_number": "1724", "narrator_chain": ""}
{"hadithnumber": "1725", "arabic": "[1725] عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ، أَنَّہُ سَمِعَ مُعَاوِیَۃَ بْنَ أبِی سُف", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 50, Hadith 15", "international_number": "1725", "narrator_chain": ""}
{"hadithnumber": "1726", "arabic": "[1726] عَنْ زِیَادِ بْنِ سَعْدٍ، عَنِ ابْنِ شِہَابٍ، أَ نَّہُ سَمِعَہُ یَقُولُ : سَدَلَ رَسُولُ الل", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 50, Hadith 16", "international_number": "1726", "narrator_chain": ""}
{"hadithnumber": "1727", "arabic": "[1727] عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَ نَّہُ کَانَ یَکْرَہُ الإِخْصَائَ وَیَقُولُ : فِیہِ تَمَا", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 50, Hadith 17", "international_number": "1727", "narrator_chain": ""}
{"hadithnumber": "1728", "arabic": "[1728] عَنْ صَفْوَانَ بْنِ سُلَیْمٍ، أَ نَّہُ بَلَغَہُ : أَنَّ النَّبِیَّ  ﷺ  قَالَ :أَنَا وَکَاف", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 50, Hadith 18", "international_number": "1728", "narrator_chain": ""}
{"hadithnumber": "1729", "arabic": "[1729] عَنْ یَحْیَی بْنِ سَعِیدٍ، أَنَّ أَ بَا قَتَادَۃَ الْأَنْصَارِیَّ قَالَ لِرَسُولِ اللّٰہِ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Daif'}", "reference": "Book 50, Hadith 19", "international_number": "1729", "narrator_chain": ""}
{"hadithnumber": "1838", "arabic": "وَحَدَّثَنِي يَحْيَى، عَنْ مَالِكٍ، عَنْ مُحَمَّدِ بْنِ أَبِي أُمَامَةَ بْنِ سَهْلِ بْنِ حُنَيْفٍ، أَنَّهُ سَمِعَ أَبَاهُ، يَقُولُ اغْتَسَلَ أَبِي سَهْلُ بْنُ حُنَيْفٍ بِالْخَرَّارِ فَنَزَعَ جُبَّةً كَانَتْ عَلَيْهِ وَعَامِرُ بْنُ رَبِيعَةَ يَنْظُرُ قَالَ وَكَانَ سَهْلٌ رَجُلاً أَبْيَضَ حَسَنَ الْجِلْدِ - قَالَ - فَقَالَ لَهُ عَامِرُ بْنُ رَبِيعَةَ مَا رَأَيْتُ كَالْيَوْمِ وَلاَ جِلْدَ عَذْرَاءَ ‏.‏ قَالَ فَوُعِكَ سَهْلٌ مَكَانَهُ وَاشْتَدَّ وَعْكُهُ فَأُتِيَ رَسُولُ اللَّهِ صلى الله عليه وسلم فَأُخْبِرَ أَنَّ سَهْلاً وُعِكَ وَأَنَّهُ غَيْرُ رَائِحٍ مَعَكَ يَا رَسُولَ اللَّهِ فَأَتَاهُ رَسُولُ اللَّهِ صلى الله عليه وسلم فَأَخْبَرَهُ سَهْلٌ بِالَّذِي كَانَ مِنْ شَأْنِ عَامِرٍ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ عَلاَمَ يَقْتُلُ أَحَدُكُمْ أَخَاهُ أَلاَّ بَرَّكْتَ إِنَّ الْعَيْنَ حَقٌّ تَوَضَّأْ لَهُ ‏\"\"‏ ‏.‏ فَتَوَضَّأَ لَهُ عَامِرٌ فَرَاحَ سَهْلٌ مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم لَيْسَ بِهِ بَأْسٌ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1839", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنِ ابْنِ شِهَابٍ، عَنْ أَبِي أُمَامَةَ بْنِ سَهْلِ بْنِ حُنَيْفٍ، أَنَّهُ قَالَ رَأَى عَامِرُ بْنُ رَبِيعَةَ سَهْلَ بْنَ حُنَيْفٍ يَغْتَسِلُ فَقَالَ مَا رَأَيْتُ كَالْيَوْمِ وَلاَ جِلْدَ مُخْبَأَةٍ ‏.‏ فَلُبِطَ سَهْلٌ فَأُتِيَ رَسُولُ اللَّهِ صلى الله عليه وسلم فَقِيلَ يَا رَسُولَ اللَّهِ هَلْ لَكَ فِي سَهْلِ بْنِ حُنَيْفٍ وَاللَّهِ مَا يَرْفَعُ رَأْسَهُ ‏.‏ فَقَالَ ‏\"‏ هَلْ تَتَّهِمُونَ لَهُ أَحَدًا ‏\"‏ قَالُوا نَتَّهِمُ عَامِرَ بْنَ رَبِيعَةَ ‏.‏ قَالَ فَدَعَا رَسُولُ اللَّهِ صلى الله عليه وسلم عَامِرًا فَتَغَيَّظَ عَلَيْهِ وَقَالَ ‏\"‏ عَلاَمَ يَقْتُلُ أَحَدُكُمْ أَخَاهُ أَلاَّ بَرَّكْتَ اغْتَسِلْ لَهُ ‏\"‏ ‏.‏ فَغَسَلَ عَامِرٌ وَجْهَهُ وَيَدَيْهِ وَمِرْفَقَيْهِ وَرُكْبَتَيْهِ وَأَطْرَافَ رِجْلَيْهِ وَدَاخِلَةَ إِزَارِهِ فِي قَدَحٍ ثُمَّ صُبَّ عَلَيْهِ فَرَاحَ سَهْلٌ مَعَ النَّاسِ لَيْسَ بِهِ بَأْسٌ ‏.‏", "grades": "", "reference": "", "international_number": "1839", "narrator_chain": ""}
{"hadithnumber": "1840", "arabic": "حَدَّثَنِي عَنْ مَالِكٍ، عَنْ حُمَيْدِ بْنِ قَيْسٍ الْمَكِّيِّ، أَنَّهُ قَالَ دُخِلَ عَلَى رَسُولِ اللَّهِ صلى الله عليه وسلم بِابْنَىْ جَعْفَرِ بْنِ أَبِي طَالِبٍ فَقَالَ لِحَاضِنَتِهِمَا ‏\"‏ مَا لِي أَرَاهُمَا ضَارِعَيْنِ ‏\"‏ ‏.‏ فَقَالَتْ حَاضِنَتُهُمَا يَا رَسُولَ اللَّهِ إِنَّهُ تَسْرَعُ إِلَيْهِمَا الْعَيْنُ وَلَمْ يَمْنَعْنَا أَنْ نَسْتَرْقِيَ لَهُمَا إِلاَّ أَنَّا لاَ نَدْرِي مَا يُوَافِقُكَ مِنْ ذَلِكَ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ اسْتَرْقُوا لَهُمَا فَإِنَّهُ لَوْ سَبَقَ شَىْءٌ الْقَدَرَ لَسَبَقَتْهُ الْعَيْنُ ‏\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "1840", "narrator_chain": ""}
{"hadithnumber": "1841", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ سُلَيْمَانَ بْنِ يَسَارٍ، أَنَّ عُرْوَةَ بْنَ الزُّبَيْرِ، حَدَّثَهُ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم دَخَلَ بَيْتَ أُمِّ سَلَمَةَ زَوْجِ النَّبِيِّ صلى الله عليه وسلم وَفِي الْبَيْتِ صَبِيٌّ يَبْكِي فَذَكَرُوا لَهُ أَنَّ بِهِ الْعَيْنَ - قَالَ عُرْوَةُ - فَقَالَ رَسُولُ اللَّهِ", "grades": "", "reference": "", "international_number": "1841", "narrator_chain": ""}
{"hadithnumber": "1842", "arabic": "حَدَّثَنِي عَنْ مَالِكٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، عَنْ عَطَاءِ بْنِ يَسَارٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا مَرِضَ الْعَبْدُ بَعَثَ اللَّهُ تَعَالَى إِلَيْهِ مَلَكَيْنِ فَقَالَ انْظُرَا مَاذَا يَقُولُ لِعُوَّادِهِ ‏.‏ فَإِنْ هُوَ - إِذَا جَاءُوهُ - حَمِدَ اللَّهَ وَأَثْنَى عَلَيْهِ رَفَعَا ذَلِكَ إِلَى اللَّهِ عَزَّ وَجَلَّ - وَهُوَ أَعْلَمُ - فَيَقُولُ لِعَبْدِي عَلَىَّ إِنْ تَوَفَّيْتُهُ أَنْ أُدْخِلَهُ الْجَنَّةَ وَإِنْ أَنَا شَفَيْتُهُ أَنْ أُبْدِلَ لَهُ لَحْمًا خَيْرًا مِنْ لَحْمِهِ وَدَمًا خَيْرًا مِنْ دَمِهِ وَأَنْ أُكَفِّرَ عَنْهُ سَيِّئَاتِهِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1843", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَزِيدَ بْنِ خُصَيْفَةَ، عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، أَنَّهُ قَالَ سَمِعْتُ عَائِشَةَ، زَوْجَ النَّبِيِّ صلى الله عليه وسلم تَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ يُصِيبُ الْمُؤْمِنَ مِنْ مُصِيبَةٍ حَتَّى الشَّوْكَةُ إِلاَّ قُصَّ بِهَا أَوْ كُفِّرَ بِهَا مِنْ خَطَايَاهُ ‏\"\"‏ ‏.‏ لاَ يَدْرِي يَزِيدُ أَيَّهُمَا قَالَ عُرْوَةُ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1844", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللَّهِ بْنِ أَبِي صَعْصَعَةَ، أَنَّهُ قَالَ سَمِعْتُ أَبَا الْحُبَابِ، سَعِيدَ بْنَ يَسَارٍ يَقُولُ سَمِعْتُ أَبَا هُرَيْرَةَ، يَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ يُرِدِ اللَّهُ بِهِ خَيْرًا يُصِبْ مِنْهُ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1845", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، أَنَّ رَجُلاً، جَاءَهُ الْمَوْتُ فِي زَمَانِ رَسُولِ اللَّهِ صلى الله عليه وسلم فَقَالَ رَجُلٌ هَنِيئًا لَهُ مَاتَ وَلَمْ يُبْتَلَ بِمَرَضٍ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ وَيْحَكَ وَمَا يُدْرِيكَ لَوْ أَنَّ اللَّهَ ابْتَلاَهُ بِمَرَضٍ يُكَفِّرُ بِهِ مِنْ سَيِّئَاتِهِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1846", "arabic": "حَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَزِيدَ بْنِ خُصَيْفَةَ، أَنَّ عَمْرَو بْنَ عَبْدِ اللَّهِ بْنِ كَعْبٍ السَّلَمِيَّ، أَخْبَرَهُ أَنَّ نَافِعَ بْنَ جُبَيْرٍ أَخْبَرَهُ عَنْ عُثْمَانَ بْنِ أَبِي الْعَاصِ، أَنَّهُ أَتَى رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ عُثْمَانُ وَبِي وَجَعٌ قَدْ كَادَ يُهْلِكُنِي ‏.‏ قَالَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ امْسَحْهُ بِيَمِينِكَ سَبْعَ مَرَّاتٍ وَقُلْ أَعُوذُ بِعِزَّةِ اللَّهِ وَقُدْرَتِهِ مِنْ شَرِّ مَا أَجِدُ ‏\"\"‏ ‏.‏ قَالَ فَقُلْتُ ذَلِكَ فَأَذْهَبَ اللَّهُ مَا كَانَ بِي فَلَمْ أَزَلْ آمُرُ بِهَا أَهْلِي وَغَيْرَهُمْ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1847", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم كَانَ إِذَا اشْتَكَى يَقْرَأُ عَلَى نَفْسِهِ بِالْمُعَوِّذَاتِ وَيَنْفِثُ ‏.‏ قَالَتْ فَلَمَّا اشْتَدَّ وَجَعُهُ كُنْتُ أَنَا أَقْرَأُ عَلَيْهِ وَأَمْسَحُ عَلَيْهِ بِيَمِينِهِ رَجَاءَ بَرَكَتِهَا ‏.‏", "grades": "", "reference": "", "international_number": "1847", "narrator_chain": ""}
{"hadithnumber": "1848", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ عَمْرَةَ بِنْتِ عَبْدِ الرَّحْمَنِ، أَنَّ أَبَا بَكْرٍ الصِّدِّيقَ، دَخَلَ عَلَى عَائِشَةَ وَهِيَ تَشْتَكِي وَيَهُودِيَّةٌ تَرْقِيهَا فَقَالَ أَبُو بَكْرٍ ارْقِيهَا بِكِتَابِ اللَّهِ ‏.‏", "grades": "", "reference": "", "international_number": "1848", "narrator_chain": ""}
{"hadithnumber": "1849", "arabic": "حَدَّثَنِي عَنْ مَالِكٍ، عَنْ زَيْدِ بْنِ أَسْلَمَ، أَنَّ رَجُلاً، فِي زَمَانِ رَسُولِ اللَّهِ صلى الله عليه وسلم أَصَابَهُ جُرْحٌ فَاحْتَقَنَ الْجُرْحُ الدَّمَ وَأَنَّ الرَّجُلَ دَعَا رَجُلَيْنِ مِنْ بَنِي أَنْمَارٍ فَنَظَرَا إِلَيْهِ فَزَعَمَا أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ لَهُمَا ‏\"‏ أَيُّكُمَا أَطَبُّ ‏\"‏ ‏.‏ فَقَالاَ أَوَ فِي الطِّبِّ خَيْرٌ يَا رَسُولَ اللَّهِ فَزَعَمَ زَيْدٌ أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏\"‏ أَنْزَلَ الدَّوَاءَ الَّذِي أَنْزَلَ الأَدْوَاءَ ‏\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "1849", "narrator_chain": ""}
{"hadithnumber": "1850", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، قَالَ بَلَغَنِي أَنَّ سَعْدَ بْنَ زُرَارَةَ، اكْتَوَى فِي زَمَانِ رَسُولِ اللَّهِ صلى الله عليه وسلم مِنَ الذُّبَحَةِ فَمَاتَ ‏.‏", "grades": "", "reference": "", "international_number": "1850", "narrator_chain": ""}
{"hadithnumber": "1851", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ نَافِعٍ، أَنَّ عَبْدَ اللَّهِ بْنَ عُمَرَ، اكْتَوَى مِنَ اللَّقْوَةِ وَرُقِيَ مِنَ الْعَقْرَبِ ‏.‏", "grades": "", "reference": "", "international_number": "1851", "narrator_chain": ""}
{"hadithnumber": "1852", "arabic": "حَدَّثَنِي عَنْ مَالِكٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ فَاطِمَةَ بِنْتِ الْمُنْذِرِ، أَنَّ أَسْمَاءَ بِنْتَ أَبِي بَكْرٍ، كَانَتْ إِذَا أُتِيَتْ بِالْمَرْأَةِ وَقَدْ حُمَّتْ تَدْعُو لَهَا أَخَذَتِ الْمَاءَ فَصَبَّتْهُ بَيْنَهَا وَبَيْنَ جَيْبِهَا وَقَالَتْ إِنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم كَانَ يَأْمُرُنَا أَنْ نُبْرِدَهَا بِالْمَاءِ ‏.‏", "grades": "", "reference": "", "international_number": "1852", "narrator_chain": ""}
{"hadithnumber": "1853", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِنَّ الْحُمَّى مِنْ فَيْحِ جَهَنَّمَ فَابْرُدُوهَا بِالْمَاءِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1854", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ الْحُمَّى مِنْ فَيْحِ جَهَنَّمَ فَأَطْفِئُوهَا بِالْمَاءِ ‏\"\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1855", "arabic": "حَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا عَادَ الرَّجُلُ الْمَرِيضَ خَاضَ الرَّحْمَةَ حَتَّى إِذَا قَعَدَ عِنْدَهُ قَرَّتْ فِيهِ ‏\"\"‏ ‏.‏ أَوْ نَحْوَ هَذَا ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": ""}
{"hadithnumber": "1856", "arabic": "وَحَدَّثَنِي عَنْ مَالِكٍ، أَنَّهُ بَلَغَهُ عَنْ بُكَيْرِ بْنِ عَبْدِ اللَّهِ بْنِ الأَشَجِّ، عَنِ ابْنِ عَطِيَّةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏\"‏ لاَ عَدْوَى وَلاَ هَامَ وَلاَ صَفَرَ وَلاَ يَحُلَّ الْمُمْرِضُ عَلَى الْمُصِحِّ وَلْيَحْلُلِ الْمُصِحُّ حَيْثُ شَاءَ ‏\"‏ ‏.‏ فَقَالُوا يَا رَسُولَ اللَّهِ وَمَا ذَاكَ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏\"‏ إِنَّهُ أَذًى ‏\"‏ ‏.‏", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Yahya related to me from Malik that he had heard from Bukayr ibn\\nAbdullah ibn al-Ashajj from Ibn Atiya that the Messenger of Allah, may\\nAllah bless him and grant him peace, said:"}
