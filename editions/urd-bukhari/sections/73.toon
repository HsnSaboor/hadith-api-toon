hadiths[30]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
5545,ہم سے محمد بن بشار نے بیان کیا، کہا ہم سے غندر نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے زبید ا,,,,,5545
5546,ہم سے مسدد نے بیان کیا، کہا ہم سے اسماعیل نے بیان کیا، ان سے ایوب نے، ان سے محمد بن سیرین نے اور ان ,,,,,5546
5547,ہم سے معاذ بن فضالہ نے بیان کیا، کہا ہم سے ہشام بن عروہ نے بیان کیا، ان سے یحییٰ نے اور ان سے بعجہ ا,,,,,5547
5548,ہم سے مسدد نے بیان کیا، ہم سے سفیان نے بیان کیا، ان سے عبدالرحمٰن بن قاسم نے، ان سے ان کے والد نے او,,,,,5548
5549,ہم سے صدقہ نے بیان کیا، کہا ہم کو ابن علیہ نے خبر دی، انہیں ایوب نے، انہیں محمد بن سیرین نے اور ان س,,,,,5549
5550,ہم سے محمد بن سلام نے بیان کیا، کہا ہم سے عبدالوہاب نے بیان کیا، کہا ہم سے ایوب سختیانی نے بیان کیا،,,,,,5550
5551,ہم سے محمد بن ابی بکر مقدمی نے بیان کیا، کہا ہم سے خالد بن حارث نے بیان کیا، کہا ہم سے عبیداللہ نے ب,,,,,5551
5552,ہم سے یحییٰ بن بکیر نے بیان کیا، کہا ہم سے لیث نے بیان کیا، ان سے کثیر بن فرقد نے، ان سے نافع نے اور,,,,,5552
5553,ہم سے آدم بن ابی ایاس نے بیان کیا، انہوں نے کہا ہم سے شعبہ نے بیان کیا، ان سے عبدالعزیز بن صہیب نے ب,,,,,5553
5554,ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے عبدالوہاب نے بیان کیا، ان سے ایوب نے، ان سے ابوقلابہ نے ا,,,,,5554
5555,ہم سے عمرو بن خالد نے بیان کیا، کہا ہم سے لیث نے بیان کیا، ان سے یزید نے، ان سے ابوالخیر نے اور ان س,,,,,5555
5556,ہم سے مسدد نے بیان کیا، کہا ہم سے خالد بن عبداللہ نے بیان کیا، کہا ہم سے مطرف نے بیان کیا، ان سے عام,,,,,5556
5557,ہم سے محمد بن بشار نے بیان کیا، کہا ہم سے محمد بن جعفر نے بیان کیا، ان سے شعبہ نے بیان کیا، ان سے سل,,,,,5557
5558,ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا ہم سے قتادہ نے بیان کیا، ان سے ان,,,,,5558
5559,ہم سے قتیبہ نے بیان کیا، کہا ہم سے سفیان نے بیان کیا، ان سے عبدالرحمٰن بن قاسم نے، ان سے ان کے والد ,,,,,5559
5560,ہم سے حجاج بن منہال نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا کہ مجھے زبید نے خبر دی، کہا کہ میں ,,,,,5560
5561,ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے اسماعیل بن ابراہیم نے بیان کیا، ان سے ایوب نے، ان سے محم,,,,,5561
5562,ہم سے آدم نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا ہم سے اسود بن قیس نے بیان کیا، کہا میں نے جند,,,,,5562
5563,ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے ابوعوانہ نے، ان سے فراس نے، ان سے عامر نے، ان سے براء ,,,,,5563
5564,ہم سے حجاج بن منہال نے بیان کیا، کہا ہم سے ہمام نے بیان کیا، ان سے قتادہ نے، انہوں نے کہا کہ ہم سے ا,,,,,5564
5565,ہم سے قتیبہ نے بیان کیا، کہا ہم سے ابوعوانہ نے بیان کیا، ان سے قتادہ نے اور ان سے انس رضی اللہ عنہ ن,,,,,5565
5566,ہم سے احمد بن محمد نے بیان کیا، کہا ہم کو عبداللہ نے خبر دی، انہیں اسماعیل نے خبر دی، انہیں شعبی نے،,,,,,5566
5567,ہم سے علی بن عبداللہ نے بیان کیا، ان سے سفیان نے بیان کیا کہ عمرو نے بیان کیا، انہیں عطاء نے خبر دی،,,,,,5567
5568,ہم سے اسماعیل نے بیان کیا، کہا کہ مجھ سے سلیمان نے بیان کیا، ان سے یحییٰ بن سعید نے، ان سے قاسم نے، ,,,,,5568
5569,ہم سے ابوعاصم نے بیان کیا، ان سے یزید بن ابی عبید نے اور ان سے سلمہ بن الاکوع رضی اللہ عنہ نے بیان ک,,,,,5569
5570,ہم سے اسماعیل بن عبداللہ نے بیان کیا، کہا کہ مجھ سے میرے بھائی نے بیان کیا، ان سے سلیمان نے اور ان س,,,,,5570
5571,ہم سے حبان بن موسیٰ نے بیان کیا، انہوں نے کہا ہم کو عبداللہ نے خبر دی، انہوں نے کہا کہ مجھے یونس نے ,,,,,5571
5572,ابو عبید نے بیان کیا کہ  پھر میں عثمان بن عفان رضی اللہ عنہ کے ساتھ  ( ان کی خلافت کے زمانہ میں عیدگ,,,,,5572
5573,ابوعبید نے بیان کیا کہ  پھر میں عید کی نماز میں علی بن ابی طالب رضی اللہ عنہ کے ساتھ آیا۔ انہوں نے ب,,,,,5573
5574,ہم سے محمد بن عبدالرحیم نے بیان کیا، انہوں نے کہا ہم کو یعقوب بن ابراہیم بن سعد نے خبر دی، انہیں ابن,,,,,5574
