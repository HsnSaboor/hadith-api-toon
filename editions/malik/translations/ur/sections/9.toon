{"hadithnumber": "404", "text": "ہشام بن عروہ رحمہ اللہ اپنے والد عروہ رحمہ اللہ سے روایت کرتے ہیں کہ رسول اللہ ﷺ نے فرمایا :’’ اپنی"}
{"hadithnumber": "405", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ کہا کرتے تھے کہ جب مریض سجدہ کرنے کی"}
{"hadithnumber": "406", "text": "ربیعہ بن ابی عبدالرحمن رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ جب مسجد میں آتے اور"}
{"hadithnumber": "407", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ ایک شخص کے پاس سے گزرے جو کہ نماز پڑھ"}
{"hadithnumber": "408", "text": "نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہ فرمایا کرتے تھے : جو شخص کوئی نماز ("}
{"hadithnumber": "409", "text": "واسع بن حبان رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں نماز پڑھ رہا تھا اور حضرت عبداللہ بن عمر رضی ال"}
{"hadithnumber": "410", "text": "ہشام بن عروہ اپنے والد سے ، اور وہ مہاجرین میں سے ایک شخص جس کے متعلق عروہ کوئی حرج محسوس نہیں کرتے"}
{"hadithnumber": "411", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے کہ انھوں نے پوچھا : وہ کون سی نماز ہے جس کی ہر رکعت میں بیٹھا جات"}
{"hadithnumber": "412", "text": "حضرت ابوقتادہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ اس حال میں نماز پڑھا لیا کرتے تھے کہ آپ ( اپنی"}
{"hadithnumber": "413", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ تمھارے اندر رات کے فرشتے اور دن"}
{"hadithnumber": "414", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے کہ رسول اللہ ﷺ نے ( اپنے مرض الوفات میں ) فرمایا"}
{"hadithnumber": "415", "text": "حضرت عبیداللہ بن عدی بن خیار رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ لوگوں کے درمیان تشریف فرما تھے"}
{"hadithnumber": "416", "text": "عطار بن یسار رحمہ اللہ سے روایت ہے کہ رسول اللہ ﷺ نے ( دعا مانگتے ہوئے ) فرمایا :’’ اے اللہ ! میری ق"}
{"hadithnumber": "417", "text": "حضرت محمود بن ربیع انصاری رضی اللہ عنہ سے روایت ہے کہ ( ایک بدری صحابی ) حضرت عتبان بن مالک رضی اللہ"}
{"hadithnumber": "418", "text": "عباد بن تمیم رحمہ اللہ اپنے چچا ( حضرت عبداللہ بن زید بن عاصم رضی اللہ عنہ ) سے روایت کرتے ہیں کہ ان"}
{"hadithnumber": "419", "text": "سعید بن مسیب سے روایت ہے کہ حضرت عمر بن خطاب رضی اللہ عنہ اور حضرت عثمان بن عفان رضی اللہ عنہ بھی اس"}
{"hadithnumber": "420", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن مسعود رضی اللہ عنہ نے ایک شخص سے فرمایا کہ بے"}
{"hadithnumber": "421", "text": "یحیی بن سعید سے روایت ہے ، ان کو یہ خبر پہنچی کہ بے شک بندے کے عمل میں سب سے پہلی وہ چیز جس کو دیکھا"}
{"hadithnumber": "422", "text": "سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے ، کہتی ہیں کہ رسول اللہ ﷺ کے نزدیک سب سے پسندیدہ"}
{"hadithnumber": "423", "text": "عامر بن سعد رحمہ اللہ اپنے والد حضرت سعد بن ابی وقاص رضی اللہ عنہ سے روایت کرتے ہیں ، انھوں نے کہا ک"}
{"hadithnumber": "424", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ عطاء بن یسار رحمہ اللہ کے پاس سے جب کوئی ایسا شخص گزرتا جو مس"}
{"hadithnumber": "425", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت عمر بن خطاب رضی اللہ عنہ نے مسجد نبوی کے ایک کونے میں ای"}
{"hadithnumber": "426", "text": "حضرت طلحہ بن عبید اللہ رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ ایک آدمی رسول اللہ ﷺ کی خدمت میں حاضر"}
{"hadithnumber": "427", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ جب تم میں سے کوئی شخص سو جاتا ہے"}
