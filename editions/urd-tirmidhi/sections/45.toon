hadiths[52]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
2875,ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم ابی بن کعب رضی الله عنہ کے پاس سے,,,,,2875
2876,ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے گنتی کے کچھ لشکری بھیجے  ( بھیجتے,,,,,2876
2877,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اپنے گھروں کو قبرستان",,,,,2877
2878,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ہر چیز کی ایک چوٹی ہوتی ",,,,,2878
2879,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے سورۃ مومن کی  ( اب",,,,,2879
2880,ابوایوب انصاری رضی الله عنہ سے روایت ہے کہ  ان کا اپنا ایک احاطہٰ تھا اس میں کھجوریں رکھی ہوئی تھیں۔,,,,,2880
2881,"ابومسعود انصاری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے رات میں سور",,,,,2881
2882,"نعمان بن بشیر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ نے ",,,,,2882
2883,"نواس بن سمعان رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”قرآن اور قرآن و",,,,,2883
2884,سفیان بن عیینہ سے روایت ہے،  وہ عبداللہ بن مسعود رضی الله عنہ کی اس حدیث «ما خلق الله من سماء ولا أر,,,,,2884
2885,براء رضی الله عنہ کہتے ہیں کہ  ایک آدمی سورۃ الکہف پڑھ رہا تھا کہ اسی دوران اس نے اپنے چوپائے  ( سو,,,,,2885
2886,"ابو الدرداء رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس نے سورۃ الکہف کی",,,,,2886
2887,"انس رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”ہر چیز کا ایک دل ہوتا ہے، اور ",,,,,2887
2888,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص سورۃ «حم الدخان» ",,,,,2888
2889,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص جمعہ کی رات میں «",,,,,2889
2890,عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  صحابہ میں سے کسی نے اپنا خیمہ ایک قبر پر نصب کر دیا ا,,,,,2890
2891,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”قرآن کی تیس آیتوں کی",,,,,2891
2892,جابر رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جب تک «الم تنزيل» اور «تبارك الذي بيده,,,,,2892
2893,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے سورۃ «إذا زلزلت",,,,,2893
2894,"عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: «إذا زلزلت»  ( ث",,,,,2894
2895,"انس بن مالک رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنے ایک صحابی سے فرمایا: ”",,,,,2895
2896,"ابوایوب انصاری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”کیا تم میں سے کوئی",,,,,2896
2897,ابوہریرہ رضی الله عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے ساتھ آیا، آپ نے وہاں ایک آدم,,,,,2897
2898,"انس بن مالک رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص ہر دن دو سو ",,,,,2898
2899,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: «قل هو الله أحد» ایک تہائ",,,,,2899
2900,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم سب اکٹھے ہو جاؤ کیون",,,,,2900
2901,انس بن مالک رضی الله عنہ کہتے ہیں کہ  مسجد قباء میں ایک انصاری شخص ان کی امامت کرتا تھا، اور اس کی ع,,,,,2901
2902,"عقبہ بن عامر جہنی رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ ن",,,,,2902
2903,عقبہ بن عامر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے حکم دیا کہ ہر نماز کے بع,,,,,2903
2904,"ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص قرآن پ",,,,,2904
2905,"علی بن ابی طالب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے قرآن پڑھا ",,,,,2905
2906,حارث اعور کہتے ہیں کہ  مسجد میں گیا تو کیا دیکھتا ہوں کہ لوگ گپ شپ اور قصہ کہانیوں میں مشغول ہیں، می,,,,,2906
2907,"عثمان بن عفان رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے بہتر و",,,,,2907
2908,"عثمان بن عفان رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سب سے بہتر ی",,,,,2908
2909,"علی ابن ابی طالب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سب سے بہت",,,,,2909
2910,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے کتاب اللہ ",,,,,2910
2911,"ابوامامہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ کسی بندے کی ک",,,,,2911
2912,"جبیر بن نفیر کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تم اللہ کی طرف رجوع کرنے کے لیے قر",,,,,2912
2913,"عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”وہ شخص جس کے دل",,,,,2913
2914,"عبداللہ بن عمرو رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ” ( قیامت کے د",,,,,2914
2915,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”قرآن قیامت کے دن پیش ",,,,,2915
2916,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میری امت کے نیک اعمال",,,,,2916
2917,عمران بن حصین رضی الله عنہ سے روایت ہے کہ  وہ ایک قصہ گو کے پاس سے گزرے جو قرآن پڑھ رہا تھا  ( پڑھ ,,,,,2917
2918,"صہیب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے قرآن کی حرام کی ہوئی ",,,,,2918
2919,"عقبہ بن عامر رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا ہے: ”ب",,,,,2919
2920,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم جب تک سورۃ بنی اسرائیل اور ,,,,,2920
2921,عرباض بن ساریہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سونے سے پہلے مسبحات پڑھتے تھے ۱,,,,,2921
2922,"معقل بن یسار رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص صبح کے وقت ",,,,,2922
2923,یعلیٰ بن مملک سے روایت ہے،  انہوں نے ام المؤمنین ام سلمہ رضی الله عنہ سے نبی اکرم صلی اللہ علیہ وسلم,,,,,2923
2924,عبداللہ بن ابی قیس بصریٰ کہتے ہیں کہ  میں نے ام المؤمنین عائشہ رضی الله عنہا سے رسول اللہ صلی اللہ ع,,,,,2924
2925,جابر رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم «موقف»  ( عرفات )  میں اپنے آپ کو لوگوں ک,,,,,2925
2926,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ عزوجل فرماتا ہ",,,,,2926
