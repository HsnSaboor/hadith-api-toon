1041,"توتوأصۄشۏأڬۄحەأۄۏڽأڬۄأؼثۏزتههۄأثىأؼثزتههۄأثىأؼحثۄأىەأودہەأۏۄأمظۄأثۏتىأڬۏتأۄەأهۏڬىأتضأوۏڽأذعشحأتثًۄشۏشۄأڬتأحسڬشۄأىۄۏڽأڬۏتأۗأتًشأتىأڬۏأشًتۏحأتىأتهلتػأځشأرحوأۄًأڲةۏأۄەأ=أحًأإځأىەأتځىۏأثمۏۄأىوتصأوڬوهأڬۏأۗ‛‛

[تخریج]: (1041) مؤطا امام مالک : 1 / 95 ۔ انظر الحدیث السابق ۔"
1042,"ذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأػۄشأۏتأؼظشأڬۏأىوتصأځڔہتةۏأ؏أتىأزًأوۏڽأضەأڬضۏأتۏڬأىوتصأوۏڽأإځأىەأزًأشڬؼحًڽأڬەأثؼزأضهتوأځہۏشأزۏتأحًأثىۏأصۄشۄأڬەأذهۏلأسًتهطوتهۏىأثىأؼثزأؼوشًأثىأىعهۄأتهرصتؼۏأىەأإځأضەأؼشعأڬۏأ=أتەأتههۄأڬەأشضًهأ$أڬۏتأىوتصأڬوأۄًأڲةۏأۄەأۏتأإځأثہًهأڲةەأۄۏڽأآأشضًهأتههۄأ﷽أىەألشوتۏتأ=أىۄأوۏڽأثہًهتأۄًڽأتًشأىۄأىوتصأڬوأۄًةۏأۄەأۗأسًتهطوتهۏىأىەأؼشعأڬۏأتضأوۏڽأضەأڬډہأعشًشأۄًتأۄەأ؏أځضأشضًهأتههۄأ﷽أىەأهًڲًڽأڬۏأغشلأوحًدۄأۄًأڬشأزشۏتلحأڬۏتأ=أڬۏتأسًتهۏزۏىأزشضحأڬۄۄأشۄتأۄەأآأتىۄًڽأىەأؼشعأڬۏأ$أدۏأۄتڽأ؏أتەأتههۄأڬەأشضًهأ=أحًأشضًهأتههۄأ﷽أڬہڔەأۄًةەأتًشأىوتصأوڬوهأڬۏأۗ‛‛أتوتوأصۄشۏأڬۄحەأۄۏڽأ=أ+أتثىأوضۏثأ؏أتثًضهوۄأ؏أتثًثڬشأثىأؼثزتهشذوىأتًشأؼثۏزتههۄأ,أتىأوۏڽأضەأڬضۏأىەأثہۏأودہەأۏۄأثۏتىأىۄۏڽأڬۏتأڬۄأشضًهأتههۄأ﷽أىەأتضأىوتصأ+أڬەأحطۄزأ,أوۏڽأثۏټہەأثۏټہەأزًأضدزەأڬۏەأحہەأۗأۄوتشەأرۏتهأوۏڽأۏۄأتضأهۏەأحہتأڬۄأهًڲًڽأىەأشضًهأتههۄأ﷽أڬًأ+أىوتصأوۏڽأثہًهأدتىەأڬتأ,أۏمۏىأزهتۏتأذحۏأڬۄأإځأڬًأۏمۏىأۄًأڲۏتأ+أحًأإځأىەأضدزەأڬۏەأۗأ,أًتههۄأتؼهوأۗ

[تخریج]: (1042) اسنادہ صحیح ، سنن الدارمی : 1497 ۔ من طریق ابی صالح بہذا الاسناد ، سنن ابی داود ، کتاب الصلاۃ ، باب السہو فی السجدتین ، حدیث : 1013 ۔ سنن نسائی : 1231 ، 1232 ۔"
1043,"ذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەأۄوۏڽأػۄشأۏتأؼظشأڬۏأىوتصأځڔہتةۏأ؏أدىتثأوذوزأثىأۏذۏۏٳأىەأثہۏأتثًظتهذأڬۏأغشذأذزۏخأثۏتىأڬۏأۄەأوڲشأتىۄًڽأىەأذزۏخأڬەأإرشأوۏڽأتوتوأصۄشۏأڬتأڬهتوأسڬشأىۄۏڽأڬۏتأۗ‛‛

