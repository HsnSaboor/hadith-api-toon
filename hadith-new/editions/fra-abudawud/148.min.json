{"metadata":{"name":"Sunan Abu Dawud","section":{"1":"Purification (Kitab Al-Taharah)"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":390,"arabicnumber_first":1,"arabicnumber_last":390}}},"hadiths":[{"hadithnumber":148,"arabicnumber":148,"text":"Rapporté par Al-Mustawrid ibn Shaddad رضي الله عنه : J’ai vu le Messager d’Allah ﷺ frotter ses orteils avec son petit doigt lorsqu’il faisait ses ablutions","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih Lighairihi"},{"name":"Zubair Ali Zai","grade":"Hasan"}],"reference":{"book":1,"hadith":148}}]}