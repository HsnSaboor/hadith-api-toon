hadiths[51]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
1619,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  کہا گیا: اللہ کے رسول! کون سا عمل  ( اجر و ثواب میں )  جہاد کے بر",,,,,1619
1620,"انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ عزوجل فرماتا ہے: اللہ کے",,,,,1620
1621,"فضالہ بن عبید رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ہر میت کے عمل کا",,,,,1621
1622,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص جہاد کرتے وقت ایک د",,,,,1622
1623,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”راہ جہاد میں کوئی ب",,,,,1623
1624,"ابوامامہ باہلی رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جہاد میں جو شخص ",,,,,1624
1625,"خریم بن فاتک رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے اللہ کے راس",,,,,1625
1626,"عدی بن حاتم طائی رضی الله عنہ سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے سوال کیا: کون",,,,,1626
1627,"ابوامامہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جہاد میں  ( مجاہدین کے ل",,,,,1627
1628,"زید بن خالد جہنی رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے اللہ کی",,,,,1628
1629,"زید بن خالد جہنی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے کسی مجاہد ",,,,,1629
1630,اس سند سے بھی  زید بن خالد جہنی سے اسی جیسی حدیث مروی ہے۔,,,,,1630
1631,"زید بن خالد جہنی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے کسی مجاہد ",,,,,1631
1632,یزید بن ابی مریم کہتے ہیں کہ  میں جمعہ کے لیے جا رہا تھا کہ مجھے عبایہ بن رفاعہ بن رافع ملے، انہوں ن,,,,,1632
1633,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ کے ڈر سے رونے والا ",,,,,1633
1634,"سالم بن ابی جعد سے روایت ہے، شرحبیل بن سمط نے کہا:  کعب بن مرہ رضی الله عنہ! ہم سے رسول اللہ صلی الل",,,,,1634
1635,"عمرو بن عبسہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص اللہ کی را",,,,,1635
1636,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”گھوڑے کی پیشانی میں قیام",,,,,1636
1637,عبداللہ بن عبدالرحمٰن ابن ابی الحسین رحمہ اللہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمای,,,,,1637
1638,ابونجیح عمرو بن عبسہ سلمی رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہو,,,,,1638
1639,"عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: ”دو ا",,,,,1639
1640,"انس رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ کی راہ میں شہادت  ( ش",,,,,1640
1641,"کعب بن مالک رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”شہداء کی روحیں  ( ",,,,,1641
1642,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میرے اوپر ان تین اشخا",,,,,1642
1643,"انس رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”مرنے والا کوئی ایسا بندہ نہ",,,,,1643
1644,"عمر بن خطاب رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”شہید ",,,,,1644
1645,انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ام حرام بنت ملحان کے گھر جب بھی ج,,,,,1645
1646,"ابوموسیٰ اشعری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے پوچھا گیا: ایک آدمی اظہار ",,,,,1646
1647,"عمر بن خطاب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اعمال کا دارومدار نیت",,,,,1647
1648,"سہل بن سعد ساعدی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”راہ جہاد کی ایک ",,,,,1648
1649,ابوہریرہ رضی الله عنہ اور عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم,,,,,1649
1650,ابوہریرہ رضی الله عنہ کہتے ہیں کہ  صحابہ میں سے ایک آدمی کسی پہاڑی کی گھاٹی سے گزرا جس میں میٹھے پا,,,,,1650
1651,"انس رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”راہ جہاد کی ایک صبح یا ایک",,,,,1651
1652,"عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”کیا میں تم لو",,,,,1652
1653,"سہل بن حنیف رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص سچے دل سے شہ",,,,,1653
1654,"معاذ بن جبل رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص سچے دل سے ال",,,,,1654
1655,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تین آدمیوں کی مدد اللہ ",,,,,1655
1656,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ کی راہ میں جو بھی ز",,,,,1656
1657,"معاذ بن جبل رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو مسلمان اللہ کی ر",,,,,1657
1658,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے پوچھا گیا: کون سا عمل افضل ہے، یا",,,,,1658
1659,"ابوبکر بن ابوموسیٰ اشعری کہتے ہیں کہ  میں نے دشمنوں کی موجودگی میں اپنے باپ کو کہتے ہوئے سنا: رسول ا",,,,,1659
1660,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے پوچھا گیا: کون آدمی افضل ہے",,,,,1660
1661,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”شہید کے علاوہ کوئی جن",,,,,1661
1662,"اس سند سے بھی  انس رضی الله عنہ سے اسی جیسی حدیث مروی ہے۔ \r\n\r\nامام ترمذی کہتے ہیں: یہ حدیث حسن صحیح ",,,,,1662
1663,"مقدام بن معدیکرب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ کے نزدیک شہ",,,,,1663
1664,"سہل بن سعد رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ کی راہ میں سرح",,,,,1664
1665,محمد بن منکدر کہتے ہیں کہ  سلمان فارسی رضی الله عنہ شرحبیل بن سمط کے پاس سے گزرے، وہ اپنے «مرابط»  (,,,,,1665
1666,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص جہاد کے کسی اثر ک",,,,,1666
1667,"ابوصالح مولیٰ عثمان کہتے ہیں کہ  میں نے منبر پر عثمان رضی الله عنہ کو کہتے سنا: میں نے تم لوگوں سے ا",,,,,1667
1668,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”شہید کو قتل سے صرف اتنی ",,,,,1668
1669,"ابوامامہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالیٰ کو دو قطرو",,,,,1669
