{"hadithnumber": "4222", "text": "ام کرز رضی اللہ عنہا کہتی ہیں کہ  میں حدیبیہ میں ہدی کے گوشت کے بارے میں پوچھنے کے لیے نبی اکرم صلی"}
{"hadithnumber": "4223", "text": "ام کرز رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”لڑکے کی طرف سے دو بکری"}
{"hadithnumber": "4224", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حسن اور حسین رضی اللہ عن"}
{"hadithnumber": "4225", "text": "سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ہر بچہ اپنے عقیقہ کے"}
{"hadithnumber": "4226", "text": "حبیب بن شہید کہتے ہیں کہ  مجھ سے محمد بن سیرین نے کہا: حسن  ( حسن بصری )  سے پوچھو، انہوں نے عقیقہ ک"}
{"hadithnumber": "4227", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”فرع اور عتیرہ واجب نہیں“"}
{"hadithnumber": "4228", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرع اور عتیرہ سے منع فرمایا  ( دو"}
{"hadithnumber": "4229", "text": "مخنف بن سلیم رضی اللہ عنہ کہتے ہیں کہ  ہم عرفہ میں نبی اکرم صلی اللہ علیہ وسلم کے ساتھ بیٹھے ہوئے تھ"}
{"hadithnumber": "4230", "text": "محمد بن عبداللہ بن عمرو اور زید بن اسلم سے روایت ہے  لوگوں  ( صحابہ )  نے عرض کیا: اللہ کے رسول! فرع"}
{"hadithnumber": "4231", "text": "حارث بن عمرو رضی اللہ عنہ کہتے ہیں کہ  میں حجۃ الوداع میں رسول اللہ صلی اللہ علیہ وسلم سے ملا، آپ اپ"}
{"hadithnumber": "4232", "text": "حارث بن عمرو رضی اللہ عنہ کہتے ہیں ہیں کہ  میں حجۃ الوداع میں رسول اللہ صلی اللہ علیہ وسلم سے ملا۔ ا"}
{"hadithnumber": "4233", "text": "نبیشہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سے بتایا گیا کہ ہم لوگ جاہلیت میں عتیرہ"}
{"hadithnumber": "4234", "text": "نبیشہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے منیٰ میں پکار کر کہا: اللہ کے رسول! ہم لوگ جاہلیت میں رجب"}
{"hadithnumber": "4235", "text": "بنی ہذیل کے  ایک شخص نبیشہ رضی اللہ عنہ کہتے ہیں کہ نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”ہم نے تم"}
{"hadithnumber": "4236", "text": "نبیشہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم کو پکار کر کہا: ہم لوگ عتیرہ"}
{"hadithnumber": "4237", "text": "نبیشہ ہذلی رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے کہا: اللہ کے رسول! ہم لوگ زمانہ جاہلیت میں عتیرہ ذبح"}
{"hadithnumber": "4238", "text": "ابورزین لقیط بن عامر عقیلی رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! ہم لوگ جاہلیت میں"}
{"hadithnumber": "4239", "text": "ام المؤمنین میمونہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کا گزر ایک پڑی ہوئی مرد"}
{"hadithnumber": "4240", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کا گزر ایک مردار بکری کے پا"}
{"hadithnumber": "4241", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک مردار بکری کو دیکھا"}
{"hadithnumber": "4242", "text": "ام المؤمنین میمونہ رضی اللہ عنہا کہتی ہیں کہ  ایک بکری مر گئی، نبی اکرم صلی اللہ علیہ وسلم نے فرمایا"}
{"hadithnumber": "4243", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ام المؤمنین میمونہ رضی اللہ"}
{"hadithnumber": "4244", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ایک مردار بکری کے پاس سے گزر"}
{"hadithnumber": "4245", "text": "ام المؤمنین سودہ رضی اللہ عنہا کہتی ہیں کہ  ہماری ایک بکری مر گئی تو ہم نے اس کی کھال کو دباغت دی، پ"}
{"hadithnumber": "4246", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس کھال کو دباغ"}
{"hadithnumber": "4247", "text": "عبدالرحمٰن بن وعلہ کہتے ہیں کہ  انہوں نے ابن عباس رضی اللہ عنہما سے پوچھا: ہم لوگ مغرب کے علاقہ میں"}
{"hadithnumber": "4248", "text": "سلمہ بن محبق رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے غزوہ تبوک میں ایک عورت کے پ"}
{"hadithnumber": "4249", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سے مردار کی کھال کے بارے می"}
{"hadithnumber": "4250", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے مردے کی کھالوں کے بارے"}
{"hadithnumber": "4251", "text": "ام المؤمنین عائشہ رضی اللہ عنہا روایت کرتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”مردار کی"}
{"hadithnumber": "4252", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مردار کی کھال"}
{"hadithnumber": "4253", "text": "ام المؤمنین میمونہ رضی اللہ عنہا بیان کرتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس سے قریش کے کچ"}
{"hadithnumber": "4254", "text": "عبداللہ بن عکیم جہنی کہتے ہیں کہ  ہمیں رسول اللہ صلی اللہ علیہ وسلم کا مکتوب گرامی پڑھ کر سنایا گیا"}
{"hadithnumber": "4255", "text": "عبداللہ بن عُکیم جہنی کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں لکھ بھیجا: ”تم لوگ مردار کی"}
{"hadithnumber": "4256", "text": "عبداللہ بن عُکیم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے قبیلہ جہینہ کے لوگوں کو لکھا: ”مردار ک"}
{"hadithnumber": "4257", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حکم دیا کہ مردار جانور"}
{"hadithnumber": "4258", "text": "ابوالملیح کے والد اسامہ بن عمیر رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے درندوں ک"}
{"hadithnumber": "4259", "text": "مقدام بن معد یکرب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ریشم، سونے اور چیتوں کی"}
{"hadithnumber": "4260", "text": "خالد بن معدان کہتے ہیں کہ  مقدام بن معد یکرب رضی اللہ عنہ معاویہ رضی اللہ عنہ کے پاس آئے اور ان سے ک"}
{"hadithnumber": "4261", "text": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  انہوں نے فتح مکہ کے سال مکہ میں رسول اللہ صلی اللہ عل"}
{"hadithnumber": "4262", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  عمر رضی اللہ عنہ کو خبر پہنچی کہ سمرہ رضی اللہ عنہ نے شر"}
