{"hadithnumber": "1040", "text": "ہم سے عمرو بن عون نے بیان کیا، انہوں نے کہا کہ ہم سے خالد بن عبداللہ نے یونس سے بیان کیا، ان سے امام"}
{"hadithnumber": "1041", "text": "ہم سے شہاب بن عباد نے بیان کیا، انہوں نے کہا کہ ہمیں ابراہیم بن حمید نے خبر دی، انہیں اسماعیل بن ابی"}
{"hadithnumber": "1042", "text": "ہم سے اصبغ بن فرح نے بیان کیا، انہوں نے کہا کہ مجھے عبداللہ بن وہب نے خبر دی، انہوں نے کہا کہ مجھے ع"}
{"hadithnumber": "1043", "text": "ہم سے عبداللہ بن محمد مسندی نے بیان کیا، انہوں نے کہا کہ ہم سے ہاشم بن قاسم نے بیان کیا، انہوں نے کہ"}
{"hadithnumber": "1044", "text": "ہم سے عبداللہ بن مسلمہ قعنبی نے بیان کیا، ان سے امام مالک نے بیان کیا، ان سے ہشام بن عروہ نے بیان کی"}
{"hadithnumber": "1045", "text": "ہم سے اسحاق بن منصور نے بیان کیا، انہوں نے کہا کہ ہمیں یحییٰ بن صالح نے خبر دی، انہوں نے کہا کہ ہم س"}
{"hadithnumber": "1046", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، انہوں نے کہا کہ مجھ سے لیث بن سعد نے بیان کیا، ان سے عقیل نے بیان ک"}
{"hadithnumber": "1047", "text": "ہم سے سعید بن عفیر نے بیان کیا، انہوں نے کہا کہ ہم سے لیث بن سعد نے بیان کیا، انہوں نے کہا کہ مجھ سے"}
{"hadithnumber": "1048", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا کہ ہم سے حماد بن زید نے بیان کیا، ان سے یونس بن عبید نے، ان سے"}
{"hadithnumber": "1050", "text": "پھر ایک مرتبہ صبح کو  ( کہیں جانے کے لیے )  رسول اللہ صلی اللہ علیہ وسلم سوار ہوئے اس کے بعد سورج گر"}
{"hadithnumber": "1051", "text": "ہم سے ابونعیم فضل بن دکین کوفی نے بیان کیا، انہوں نے کہا کہ ہم سے شیبان بن عبدالرحمٰن نے یحییٰ بن اب"}
{"hadithnumber": "1052", "text": "ہم سے عبداللہ بن مسلمہ قعنبی نے بیان کیا، ان سے امام مالک نے بیان کیا، ان سے زید بن اسلم نے بیان کیا"}
{"hadithnumber": "1053", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہوں نے کہا کہ ہمیں امام مالک رحمہ اللہ نے خبر دی، انہیں ہ"}
{"hadithnumber": "1054", "text": "ہم سے ربیع بن یحییٰ نے بیان کیا، کہا کہ ہم سے زائدہ نے ہشام سے بیان کیا، ان سے فاطمہ نے، ان سے اسماء"}
{"hadithnumber": "1056", "text": "پھر نبی کریم صلی اللہ علیہ وسلم ایک دن صبح کے وقت سوار ہوئے  ( کہیں جانے کے لیے )  ادھر سورج گرہن لگ"}
{"hadithnumber": "1057", "text": "ہم سے مسدد نے بیان کیا، کہا کہ ہم سے یحییٰ قطان نے اسماعیل بن ابی خالد سے بیان کیا، کہا کہ مجھ سے قی"}
{"hadithnumber": "1058", "text": "ہم سے عبداللہ بن محمد مسندی نے بیان کیا، انہوں نے کہا کہ ہم سے ہشام نے بیان کیا، انہوں نے کہا کہ ہمی"}
{"hadithnumber": "1059", "text": "ہم سے محمد بن علاء نے بیان کیا، کہا کہ ہم سے ابواسامہ نے بیان کیا، ان سے برید بن عبداللہ نے، ان سے ا"}
{"hadithnumber": "1060", "text": "ہم سے ابوالولید طیالسی نے بیان کیا، انہوں نے کہا کہ ہم سے زائدہ بن قدامہ نے بیان کیا، انہوں نے کہا ک"}
{"hadithnumber": "1061", "text": "اور ابواسامہ نے بیان کیا کہ ہم سے ہشام بن عروہ نے بیان کیا، انہوں نے کہا کہ مجھے فاطمہ بنت منذر نے خ"}
{"hadithnumber": "1062", "text": "ہم سے محمود بن غیلان نے بیان کیا، کہا کہ ہم سے سعید بن عامر نے بیان کیا، ان سے شعبہ نے، ان سے یونس ن"}
{"hadithnumber": "1063", "text": "ہم سے ابومعمر نے بیان کیا، کہا کہ ہم سے عبدالوارث نے بیان کیا، کہا کہ ہم سے یونس نے بیان کیا، ان سے"}
{"hadithnumber": "1064", "text": "ہم سے محمود بن غیلان نے بیان کیا، انہوں نے کہا کہ ہم سے ابواحمد محمد بن عبداللہ زبیری نے بیان کیا، ا"}
{"hadithnumber": "1066", "text": "اور امام اوزاعی رحمہ اللہ نے کہا کہ میں نے زہری سے سنا، انہوں نے عروہ سے اور عروہ نے عائشہ رضی اللہ"}
