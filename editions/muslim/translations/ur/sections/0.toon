{"hadithnumber": "1", "text": "جان تو! اللہ تجھ کو توفیق دے جو شخص صحیح اور ضعیف حدیث میں تمیز کرنے کی قدرت رکھتا ہو اور ثقہ (‏‏‏‏م"}
{"hadithnumber": "2", "text": "ابو بکر بن ابی شیبہ ،  نیز محمد بن مثنیٰ اور ابن بشار نے کہا :  ہم سے محمد بن جعفر  ( غندر )  نے شعب"}
{"hadithnumber": "3", "text": "حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  کہا :   مجھے تمہارے سامنے زیادہ احادیث بیان کرن"}
{"hadithnumber": "4", "text": "حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  کہا :  رسول اللہﷺ نے فرمایا :   ’’جس  نے عمداً مج"}
{"hadithnumber": "5", "text": "۔  سعید بن عبید نے کہا :  ہمیں علی بن ربیعہ والبی نے حدیث بیان ،  کہا :  میں مسجد میں آیا اور  ( اس"}
{"hadithnumber": "6", "text": "۔  محمد بن قیس اسدی نے علی بن ربیعہ اسدی سے ،  انہوں نے حضرت مغیرہ بن شعبہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے ،"}
{"hadithnumber": "7", "text": "عبیداللہ بن معاذ بن عنبری اور عبد الرحمن بن مہدی دونوں نے کہا :  ہم سے شعبہ نے بیان کیا ،  انہوں نے"}
{"hadithnumber": "8", "text": "۔  ابو بکر بن ابی شیبہ  ‘ علی بن حفص نے شعبہ سے ،  انہوں نے خبیب بن عبد الرحمٰن سے ،   انہوں نے حفص"}
{"hadithnumber": "9", "text": "یحییٰ بن یحییٰ  ‘ ہشیم ‘ سلیمان تیمی  ‘ ابو عثمان نہدی سے روایت ہے ،  کہا :  عمر بن خطاب ‌رضی ‌اللہ"}
{"hadithnumber": "10", "text": "ابن وہب نے خبر دی کہا :  مالک  ( بن انس ،  نے مجھ سے کہا :  مجھے معلوم ہے کہ ایسا آدمی  ( صحیح )  سا"}
{"hadithnumber": "11", "text": "محمد بن مثٰنی ‘ عبد الرحمٰن  ‘ سفیان   ‘ ابو اسحاق  ‘   ابو الاحوص نے عبد اللہ  ( بن مسعود ‌رضی ‌الل"}
{"hadithnumber": "12", "text": "۔  محمد بن مثنیٰ نے کہا :  میں نے عبد الرحمن بن مہدی سے سنا ،  کہہ رہے تھے :  آدمی اس وقت تک امام نہ"}
{"hadithnumber": "13", "text": "سفیان بن حسین سے روایت ہے کہ ایاس بن  معاویہ  مجھ سے مطالبہ کیا اور کہا میں تمہیں دیکھتا ہوں تم قرآن"}
{"hadithnumber": "14", "text": "ابو طاہر ‘ حرملہ بن یحییٰ  ‘ ابن وہب  ‘ یونس  ‘ ابن شہاب  ‘ عبیداللہ بن عبداللہ بن عتبہ ‘ حضرت عبد ا"}
{"hadithnumber": "15", "text": "محمد بن عبد اللہ بن نمیر ‘ زہیر بن حرب ‘ عبداللہ بن یزید ‘ سعد بن ابی ایوب ‘ ابوہانی نے ابو عثمان مس"}
{"hadithnumber": "16", "text": "۔  حرملہ بن یحییٰ ‘ عبد اللہ بن حرملہ بن عمران تجیبی ‘ ابن وہب ‘  شراحیل بن یزید کہتے ہیں :  مجھے مس"}
{"hadithnumber": "17", "text": "ابو سعید اشج ‘ وکیع  ‘ اعمش ‘ مسیب بن رافع ‘   عامر بن عبدہ سے روایت ہے ،  کہا :  حضرت عبد اللہ بن م"}
{"hadithnumber": "18", "text": "محمد بن رافع ‘ عبد الرزاق ‘ معمر ‘ ابن طاؤس ‘  طاؤس نے حضرت عبد اللہ بن عمرو بن عاص ‌رضی ‌اللہ ‌عنہ"}
{"hadithnumber": "19", "text": "محمد بن عباد ‘ سعید بن عمر   ‘ اشعثیٰ ‘ ابن عیینہ ‘ سعید  ‘ سفیان ‘    ہشام بن جحیر نے طاوس سے روایت"}
{"hadithnumber": "20", "text": "محمد بن رافع  ‘ عبد الرزاق ‘ ابن طاؤس  ‘ طاؤس کے بیٹے نے اپنےوالد  ( طاوس )  سے  ،  انہوں نے حضرت اب"}
{"hadithnumber": "21", "text": "مجاہد سے روایت ہے کہ بشیر بن کعب عدوی حضرت عبد اللہ بن عباسؓ کے پاس آیا اور اس نے احادیث بیان کرتے ہ"}
{"hadithnumber": "22", "text": "ابن ابی ملیکہ سے روایت ہے ،  کہا :  میں نے حضرت  عبد اللہ بن عباسؓ کی طرف لکھا اور ان سے درخواست کی"}
{"hadithnumber": "23", "text": "عمر وناقد ‘ سفیان بن عیینہ ‘ ہشام ‘ بن حجیر ‘  طاوس سے روایت ہے ،  کہا :  حضرت ابن عباس ‌رضی ‌اللہ ‌"}
{"hadithnumber": "24", "text": "حسن بن علی حلوانی  ‘ یحییٰ بن آدم ‘ ابن ادریس  ‘ اعمش ‘   ابو اسحاق سے روایت ہے ،  کہا :  جب  ( بظاہ"}
{"hadithnumber": "25", "text": "علی بن خشرم ‘  ابو بکر بن عیاش نے ہمیں بتایا ،  کہا :  میں نے مغیرہ سے سنا ،  فرماتے تھے :  حضرت علی"}
{"hadithnumber": "26", "text": "حسن بن  ربیع ‘ حماد بن زید ‘ ایوب  ‘ ہشام ‘ محمد ‘ ح ‘ فضیل ‘ ہشام ‘ مخلد بن حسین  ‘ ہشام  ،  انہوں"}
{"hadithnumber": "27", "text": "عاصم احول نے ابن سیرین سے روایت کی ،  کہا :   ( ابتدائی دور میں عالمان حدیث )  اسناد کے بارے میں کوئ"}
{"hadithnumber": "28", "text": "۔  اوزاعی نے سلیمان بن موسٰی  سے روایت کی  ‘ انھوں نے کہا .میں ظاوس  ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے ملا اور"}
{"hadithnumber": "29", "text": "سعید بن عبد العزیز نے سلیمان بن موسیٰ سے روایت کی ،  انہوں نے کہا :  میں نے طاوس  ‌رضی ‌اللہ ‌عنہ ‌"}
{"hadithnumber": "30", "text": "( عبد الرحمن )  بن ابی زناد نے اپنے والد سے روایت کی ،  کہا :  میں مدینہ میں سو  ( اہل علم )  سے ملا"}
{"hadithnumber": "31", "text": "۔  مسعر سے روایت ہے ،  کہا :  میں نے سعد بن ابراہیم  ( بن عبد الرحمن بن عوف )  سے سنا ،  کہہ رہے تھے"}
{"hadithnumber": "32", "text": "محمد بن عبد اللہ بن قہزاد نے  ( جو مرو کے باشندوں میں سے ہیں )  کہا :  میں نے عبدان بن عثمان سے سنا"}
{"hadithnumber": "33", "text": "۔  ابو نضر ہاشم بن قاسم نے حدیث بیان کی ،  کہا :  ہم نے بہیہ کے مولیٰ ابو عقیل  ( یحییٰ بن متوکل )"}
{"hadithnumber": "34", "text": "بشر بن حکم عبدی  نے مجھ سے بیان کیا ،  کہا :  میں نے سفیان بن عیینہ سے سنا ،  کہہ رہے تھے :  مجھے سے"}
{"hadithnumber": "35", "text": "یحییٰ بن سعید نے کہا :  میں نے سفیان ثوری ،  شعبہ ،  مالک اور ابن عیینہ سے ایسے آدمی کے بارے میں پوچ"}
{"hadithnumber": "36", "text": "۔  نضر کہتے ہیں کہ ابن عون سے شہر  ( بن حوشب )   کی حدیث کے بارے میں سوال کیا گیا ،   ( اس وقت )  وہ"}
{"hadithnumber": "37", "text": "ہمیں شبابہ نے بتایا  ،  کہا :  شعبہ نے  کہا :  میں شہر سے ملا لیکن  ( روایت حدیث کے حوالے سے )  میں"}
{"hadithnumber": "38", "text": "عبد اللہ بن مبارک نے کہا :  میں نے سفیان ثوری سے عرض کی :  بلاشبہ عباد بن کثیر ایسا  ہے جس کا حال آپ"}
{"hadithnumber": "39", "text": "فضل بن سہل نے بتایا ،  کہا :  میں نے معلیٰ رازی سے محمد بن سعید کے بارے میں ،  جس سے عباد بن کثیر نے"}
{"hadithnumber": "40", "text": "محمد بن ابی عتاب نے کہا :  مجھ سے عفان نے محمد بن یحییٰ بن سعید قطان سے حدیث بیان کی ،  انہوں نے اپن"}
{"hadithnumber": "41", "text": "خلیفہ بن موسیٰ نے خبر دی  ،  کہا :  میں غالب بن عبید اللہ کے ہاں آیا تو اس نے مجھے لکھوانا شروع کیا"}
{"hadithnumber": "42", "text": "مجھے محمد بن عبد اللہ قہزاذ نے حدیث سنائی ،  کہا :  میں نے عبد اللہ بن عثمان بن جبلہ سے سنا ،  کہہ ر"}
{"hadithnumber": "43", "text": "ابن قہزاذ نے کہا ،  میں نے وہب سے سنا ،  انہوں نے سفیان سے اور انہوں نے عبد اللہ بن مبارک سے روایت ک"}
{"hadithnumber": "44", "text": "قتیبہ بن سعید  ‘ جریر نے مغیرہ سے ،  انہوں نے شعبی سے روایت کی ،  کہا :  مجھے حارث اعور ہمدانی نے حد"}
{"hadithnumber": "45", "text": "ابو عامر عبداللہ بن براداشعری ‘ ابو اسامہ ‘  مفضل بن مغیرہ سے روایت کی ،  کہا :  میں نے شعبی کو کہتے"}
{"hadithnumber": "46", "text": "قتیبہ بن سعید ‘ جریر  ‘ مغیرہ نے ابراہیم سے روایت کی ،  کہا :  علقمہ نے کہا :  میں نے دو سال میں قرآ"}
{"hadithnumber": "47", "text": "حجاج بن شاعر  ‘ احمد بن یونس نے ابراہیم نخعی سے روایت کی کہ حارث  ( اعور )  نے کہا :  میں نے قرآن تی"}
{"hadithnumber": "48", "text": "۔  منصور اور مغیرہ نے ابراہیم سے روایت کی کہ حارث متہم راوی ہے"}
{"hadithnumber": "49", "text": "۔  حمزہ زیات سے روایت ہے ،  کہا :  مرہ ہمدانی نے حارث سے کوئی بات سنی تو اس سے کہا :  تم دروازے ہی پ"}
{"hadithnumber": "50", "text": "۔   ( عبد اللہ )  بن عون سے روایت ہے ،  کہا :   ابراہیم  ( نخعی )  نے ہم سے کہا :  تم لوگ مغیرہ بن س"}
{"hadithnumber": "51", "text": "ہمیں عاصم نے حدیث بیان کی ،  کہا :  ہم بالکل نو عمر لڑکے تھے جو ابو عبد الرحمن سلمی کے پاس حاضر ہوتے"}
{"hadithnumber": "52", "text": "جریر کہتے ہیں :  میں جابر  بن یزید جعفی سے ملا تو میں نے اس سے حدیث نہ لکھی ،  وہ رجعت پر ایمان رکھت"}
{"hadithnumber": "53", "text": "۔  مسعر نے کہا :  ہم سے جابر بن یزید  ( جعفی )  نے ان بدعتوں سے پہلے ،  جو اس نے گھڑیں ،  حدیث بیان"}
{"hadithnumber": "54", "text": "سفیان نے کہا :  جابر نے جس  ( عقیدے )  کا اظہار کیا اس کے اظہار سے پہلے لوگ اس سے حدیث لیتے تھے ،  ج"}
{"hadithnumber": "55", "text": "۔  جراح بن ملیح کہتے ہیں :  میں نے جابر بن یزید  ( جعفی )   کو یہ کہتے سنا :  میرے ابو جعفر  ( محمد"}
{"hadithnumber": "56", "text": "۔  زہیر کہتے ہیں :  جابر نے کہا یا میں نے جابر   ( بن یزید )  کو یہ کہتے سنا :  بلاشبہ میرے پاس پچاس"}
{"hadithnumber": "57", "text": "سلام بن ابی مطیع کہتے ہیں :  میں نے جابر جعفی کو یہ کہتے سنا :  میرے پاس رسول اللہﷺ سے  ( روایت کردہ"}
{"hadithnumber": "58", "text": "سفیان  ( بن عیینہ )  نے کہا :  میں نے ایک آدمی سے سنا ،  اس نے جابر سے ارشاد ربانی :  ﴿فلن أبرح الأر"}
{"hadithnumber": "59", "text": "سفیان سے روایت ہے ،  کہا :   میں نے جابر کو تقریباً تیس ہزار احادیث بیان کرتے ہوئے سنا ہے ۔  میں ان"}
{"hadithnumber": "60", "text": "عبد الرحمان بن مہدی نے حماد بن زید سے روایت کی ،  کہا :  ایوب نے ایک دن ایک شخص کا ذکر کیا اور کہا :"}
{"hadithnumber": "61", "text": "سلیمان بن حرب نے کہا :  ہمیں حماد بن زید نے بیان کیا ،  کہا :  ایوب نے کہا :  میرا ایک ہمسایہ ہے ،"}
{"hadithnumber": "62", "text": "معمر  نے کہا .’میں نے ایورب  کو کبھی  کسی کی پیٹھ پیچھے اسے  برا کہتے نہیں سنا ‘ سوائے  عبدالکریم  ‘"}
{"hadithnumber": "63", "text": "عفان بن مسلم نے کہا :  ہمام نے ہم سے بیان کیا ،  کہا :  ابو داود اعمیٰ ہمارے ہاں آیا اور یہ کہنا شرو"}
{"hadithnumber": "64", "text": "یزید بن ہارون نے کہا :  ہمیں ہمام نے خبر دی کہ ابو داود اعمیٰ قتادہ کے ہاں آیا ،  جب وہ کھڑا ہوا  ("}
{"hadithnumber": "65", "text": "جریر نے رقبہ  ( بن مسقلہ بن عبد اللہ عبدی کوفی  ‌رضی ‌اللہ ‌عنہ ‌ ‌  جلیل القدر تابعی )  سے روایت کی"}
{"hadithnumber": "66", "text": "ابو داود طیالسی نے شعبہ سے ،  انہوں نے یونس بن عبید سے روایت کرتے ہوئے بیان کیا ،   ( یونس نے )  کہا"}
{"hadithnumber": "67", "text": "معاذ بن معاذ کہتے ہیں :  میں نے عوف بن ابی جمیلہ سے کہا :  عمرو بن عبید نے حضرت حسن بصری سے  ( روایت"}
{"hadithnumber": "68", "text": "۔  عبید اللہ بن عمر قواریری نے کہا :  ہم سے حماد بن زید نے بیان کیا ،  کہا :  ایک آدمی تھا ،  وہ ایو"}
{"hadithnumber": "69", "text": "سلیمان بن حرب نے کہا :  ہم سے ابن زید ،  یعنی حماد نے بیان کیا ،  کہا : ایوب سے عرض کی گئی :  عمرو ب"}
{"hadithnumber": "70", "text": "سلام بن ابی مطیع کہتے ہیں.’جناب ایوب سختیانی  کو یہ خبر پہنچی  کہ میں عمرو  ( بن عبید ) کے ہاں ( درس"}
{"hadithnumber": "71", "text": "۔  سفیان نے بیان کیا ،  کہا :  میں نے ابو موسیٰ  ( اسرائیل بن موسیٰ بصری ،  نزیل ہند )  سے سنا ،  کہ"}
{"hadithnumber": "72", "text": "۔  معاذ عنبری نے کہا :  میں نے واسط کے قاضی ابو شیبہ کے بارے میں دریافت کرنے کے لیے شعبہ کی طرف لکھا"}
{"hadithnumber": "73", "text": "۔  عفان  ( بن مسلم )  نے کہا :  میں نے حماد بن سلمہ کو صالح مری کے واسطے سے ایک حدیث سنائی جو اس نے"}
{"hadithnumber": "74", "text": "ابو داود نے بیان کیا ،  کہا :  شعبہ نے مجھ سے کہا :  جریر بن حازم کے پاس جاؤ اور اس سے کہو :  تمہارے"}
{"hadithnumber": "75", "text": "۔  حسن حلوانی نے کہا :  میں نے یزید بن ہارون سے سنا ،  انہوں نے زیاد بن میمون کا ذکر کرتے ہوئے کہا :"}
{"hadithnumber": "76", "text": "۔  محمود بن غیلان نے کہا :  میں نے ابوداود طیالسی سے کہا :  آپ نے عباد بن منصور سے بہت زیادہ روایتیں"}
{"hadithnumber": "77", "text": "حسن حلوانی نے بیان کیا ،  کہا :  میں نے شبابہ سے سنا  ( کہا :  عبد القدوس ہمارے سامنے حدیث بیان کرتا"}
{"hadithnumber": "78", "text": "عفان نے کہا :  میں نے ابو عوانہ سے سنا ،  کہا :  مجھے حسن  ( بصری )  سے کوئی حدیث نہ پہنچی  مگر میں"}
{"hadithnumber": "79", "text": "علی بن مسہر نے بیان کیا ،  کہا :  میں نے اور حمزہ زیات نے ابان بن ابی عیاش سے تقریباً ایک ہزار احادی"}
{"hadithnumber": "80", "text": "زکریا بن عدی نے کہا :  مجھ سے ابو اسحاق فزاری نے کہا :  بقیہ سے وہی احادیث لکھو جو اس نے معروف لوگوں"}
{"hadithnumber": "81", "text": "اسحاق بن ابراہیم حنظلی نے بیان کیا ،  کہا :  میں نے عبد اللہ کے اصحاب  ( شاگردوں )  میں سے ایک سے سن"}
{"hadithnumber": "82", "text": "عبد الرزاق کہتے ہیں :  میں نے ابن مبارک کو  ( ایسا کرتے )  نہیں دیکھا کہ وہ کھل کر اپنی یہ بات  ( را"}
{"hadithnumber": "83", "text": "۔  عبد اللہ بن عبد الرحمن دارمی نے مجھ سے بیان  کیا ،  کہا :  میں نے ابو نعیم سے سنا  ( اور انہوں نے"}
{"hadithnumber": "84", "text": "۔  عفان بن مسلم سے روایت ہے ،  کہا :  ہم اسماعیل بن عُلیہ کے ہاں تھے  تو ایک آدمی  نے ایک دوسرے آدمی"}
{"hadithnumber": "85", "text": "بشر بن عمر بنے ہم سے بیان کیا ،  کہا :  میں نے امام مالک بن انس سے محمد بن عبد الرحمن کے بارے میں پو"}
{"hadithnumber": "86", "text": "ہم حجاج نے بیان کیا ،  کہا :  ہم سے ابن ابی ذئب نے شرحبیل بن سعد کے حوالے سے حدیث بیان کی اور وہ متہ"}
{"hadithnumber": "87", "text": "ابو اسحاق طالقانی کہتے ہیں :  میں نے عبد اللہ بن مبارک سے سنا ،  کہہ رہے تھے :   ( ایک وقت تھا )  اگ"}
{"hadithnumber": "88", "text": "۔  ولید بن صالح نے بیان کیا ابواسحاق  ،  کہا :  عبید اللہ بن عمرو نے کہا :  زید ،  یعنی ابن ابی انیس"}
{"hadithnumber": "89", "text": "عبد اللہ بن جعفر رقی نے عبید اللہ بن عمرو کے حوالے سے بیان کیا ،  کہا :  یحییٰ بن ابی انیسہ جھوٹا تھ"}
{"hadithnumber": "90", "text": "حماد بن زید سے روایت ہے ،  کہا :  ایوب سختیانی کے سامنے فرقد کا ذکر کیا گیا تو انہوں نے کہا :  فرقد"}
{"hadithnumber": "91", "text": "۔   مجھ سے عبد الرحمان بن بشر عبدی نے بیان کیا ،  کہا :  میں نے یحییٰ بن سعیدقطان سے سنا ،   جب ان ک"}
{"hadithnumber": "92", "text": "بشر بن حکم نے بیان کیا ،  کہا :  میں نے یحییٰ بن سعید قطان سے سنا ،  انہوں نے حکیم بن جبیر اور عبد ا"}
{"hadithnumber": "128", "text": "ابو زبیر نے حضر ت جابر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے فرمایا :  ’’مجھے حکم دیا"}
{"hadithnumber": "209", "text": "سفیان نے  ( سلیمان  )  اعمش کے حوالے سے خبر دی کہ ذکوان نےحضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روا"}
{"hadithnumber": "248", "text": "منصور بن ابی مزاحم اور محمد بن جعفر بن زیاد نے کہا  :  ہمیں ابراہیم بن سعد نے ابن شہاب سے حدیث سنائی"}
{"hadithnumber": "637", "text": "ابو معاویہ اور عیسیٰ بن یونس نے اعمش سے  ،  انہوں نے حکم سے  ،  انہوں نے عبد الرحمن بن ابی لیلیٰ سے"}
{"hadithnumber": "638", "text": "اور یہی روایت مجھ  (  امام مسلم )  کو سوید بن سعید نے علی بن مسہر سے اور انہو ں نے اعمش سے مذکورہ با"}
{"hadithnumber": "794", "text": "۔   ابن شہاب نے کہا :  مجھے علی بن عبد اللہ بن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے اپنے والد  ( عبد اللہ بن"}
{"hadithnumber": "852", "text": "عبدہ نے طلحہ بن یحییٰ  ( بن طلحہ بن عبید اللہ )  سے اور انہوں نے اپنے چچا  ( عیسیٰ بن طلحہ بن عبید ا"}
{"hadithnumber": "853", "text": "سفیان نے طلحہ بن یحییٰ سے اور انہوں نے  ( اپنے چچا )  عیسیٰ بن طلحہ سے روایت کی ،  کہا :  میں نے معا"}
{"hadithnumber": "881", "text": "و اویس نے کہا :  مجھے علاء  نے خبر دی ،  کہا :  میں نے اپنے والد سے اور ابو سائب  سے سنا ،  وہ دونوں"}
{"hadithnumber": "1220", "text": "یحییٰ بن سعید نے ہشام سے اسی سند کے ساتھ حضرت معیقیب رضی اللہ تعالیٰ عنہ سے روایت کی کہ لوگوں  نے نب"}
{"hadithnumber": "1221", "text": "خالد بن حارث نے کہا  :  ہمیں ہشام نے اسی سند سے حدیث سنائی اور  ( عن معیقیب  کے بجائے  )  حدثنی معیق"}
{"hadithnumber": "1222", "text": "ہشام کے بجائے  ) شیبان  نے یحییٰ سے باقی  ماندہ اسی سند کے ساتھ روایت کی کہ رسول اللہ ﷺ نے اس آدمی ک"}
{"hadithnumber": "1251", "text": "حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا  :  ’’جس نے اس پودے میں سے"}
{"hadithnumber": "1332", "text": "عبداللہ بن شقیق نے حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انھوں نے  نبی ﷺ سے روایت  کی کہ آپ ﷺ ق"}
{"hadithnumber": "1350", "text": "حمزہ زیات نے ہمیں حکم سے حدیث بیان کی  ،  انھوں نے عبدالرحمن بن ابی لیلیٰ سے  ،  انھوں نے حضرت کعب ب"}
{"hadithnumber": "1351", "text": "عمرو بن قیس ملائی نے حکم سے اسی سند کے ساتھ اسی کی مانند حدیث بیان کی  ۔"}
{"hadithnumber": "1354", "text": "جریر نےعمارہ بن قعقاع سے  ،  انھوں نے ابوزرعہ سے اور انھوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  س"}
{"hadithnumber": "1355", "text": "ابن فضیل اور عبدالواحد بن یاد دونوں نے  ،  عمارہ بن قعقاع سے  ،  اسی سند کے ساتھ  ، جریر کی حدیث کی"}
{"hadithnumber": "1365", "text": "محمد بن حاتم اور عبیداللہ بن سعید نےکہا  : ہمیں یحییٰ بن سعید نےحجاج صواف  سے حدیث سنائی ،  انھوں نے"}
{"hadithnumber": "1366", "text": "ابو بکر بن ابی شیبہ  نے کہا :  ہمیں سفیان بن عیینہ  نے معمر سے حدیث سنائی  ،  ابو بکر  ( بن ابی شبیہ"}
{"hadithnumber": "1428", "text": "فضیل بن مرزوق نے شقیق بن عقبہ سے اور  انھوں نے حضرت براء بن عازب  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی ک"}
{"hadithnumber": "1429", "text": "اسود بن قیس نے شقیق بن عبہ سے  ،  انہوں نے حضرت براء بن عازب  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی انھوں"}
{"hadithnumber": "1648", "text": "حماد بن زید نے ایوب سے روایت کی ، انھوں نے عمرو بن دینار سے انھوں نے عطاء بن یسار سے انہوں نے حضرت ا"}
{"hadithnumber": "1718", "text": "عمرو بن حارث نے ابن شہاب سے اسی سند کے ساتھ نبی اکر م صلی اللہ علیہ وسلم   کی زوجہ حضرت عائشہ  رضی ا"}
{"hadithnumber": "1719", "text": "حرملہ نے مجھے یہ حدیث بیان کی ( کہا ) ہمیں ابن وہب نے خبر دی ، انھوں نے کہا ، مجھے یونس نے ابن شہاب"}
{"hadithnumber": "1778", "text": "شعبہ نے ابو اسحاق سے اسی سند کے ساتھ مذکورہ حدیث بیان کی ، البتہ منصور کی روایت مکمل اور زیادہ  ( تف"}
{"hadithnumber": "2045", "text": "سفیان بن عیینہ نے کہا :  ہم سے ایوب نے حدیث بیان کی انھوں نے کہا میں نے عطاء سے سنا انھوں نے کہا میں"}
{"hadithnumber": "2046", "text": "حماد اور اسماعیل بن ابرا ہیم نے ایوب سے اسی سند کے ساتھ اسی طرح حدیث بیان کی ۔"}
{"hadithnumber": "2057", "text": "معاذ عنبری نے کہا : ہم سے شعبہ نے حدیث بیان کی ، انھوں نے عدی سے روایت کی ، انھوں نے سعید بن جبیر سے"}
{"hadithnumber": "2058", "text": "محمد بن ادریس اورغندر دونوں نے شعبہ سے اسی سند کے ساتھ اس ( مذکورہ بالا حدیث ) کے ہم معنی حدیث بیان"}
{"hadithnumber": "2093", "text": "عبدالرحمان بن نمر نے خبر دی کہ انھوں نے  ابن شہاب سے سنا ، وہ عروہ اور حضرت عائشہ  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "2100", "text": "اسماعیل ابن علیہ نے ہشام دستوائی سے روایت کی ، انھوں نے کہا : ہمیں ابو زبیر نے جابر بن عبداللہ سے حد"}
{"hadithnumber": "2101", "text": "عبدالملک بن صباح نے ہشام دستوائی سے اسی سند کےھ ساتھ اسی ( سابقہ حدیث )  کے مانند حدیث بیان کی ، مگر"}
{"hadithnumber": "2104", "text": "ابو اسامہ نے ہشام سے  ،  انھوں نے فاطمہ سے اور انھوں نے حضرت اسمارضی اللہ عنہا سے روایت کی  ،  انھوں"}
{"hadithnumber": "2105", "text": "عروہ سے روایت ہے  ،  انھوں نے کہا  :  سورج کے لیے کسف نہ کہو ،  بلکہ خسف کا لفظ استعمال کرو ۔  ( ارد"}
{"hadithnumber": "2149", "text": "ایوب نے عبد اللہ بن ابی ملیکہ سے روا یت کی ،  انھوں نے کہا :  میں حضرت ابن عمر رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2150", "text": "ابن جریج نے کہا :  مجھے عبد اللہ بن ابی ملیکہ نے خبر دی انھوں نے کہا :  حضرت عثمان بن عفان  رضی اللہ"}
{"hadithnumber": "2225", "text": "شعبہ نے عمرو بن مرہ سے اور انھوں نے ابن ابی لیلیٰ سے روایت کی کہ حضرت قیس بن سعد اور سہل بن حنیف  رض"}
{"hadithnumber": "2232", "text": "ابن وہب نے کہا : مجھے معاویہ بن صالح نے حبیب بن عبید سے خبر دی ، انھوں نے اس حدیث کو جبیر بن نفیر سے"}
{"hadithnumber": "2243", "text": "وکیع نے سفیان سے ، انھوں نے حبیب بن ابی ثابت سے ، انھوں نے ابو وائل سے اور انھوں نے ابو الہیاج اسدی"}
{"hadithnumber": "2295", "text": "بکیرنے ( ابو صالح )  ذکوان سے حدیث بیان کی ، انھوں نے حضرت ابوہریرۃ  رضی اللہ تعالیٰ عنہ  سے اور انھ"}
{"hadithnumber": "2339", "text": "سہیل کے والد  ( ابو صالح  )  نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روا یت کی کہ رسول اللہ  صلی ا"}
{"hadithnumber": "2381", "text": "امام ما لک نے خبیب بن عبد الرحمٰن سے انھوں نے حفص بن عاصم سے اور انھوں نے حضرت ابو سعید خدری رضی الل"}
{"hadithnumber": "2810", "text": "محمد بن بکر سے روایت ہے کہا مجھے ابن جریج نے خبر دی  ، کہا مجھے ابو زبیر نے خبر دی کہ انھوں نے جا بر"}
{"hadithnumber": "2892", "text": "حماد نے عمرو بن دینا ر اور ایوب سے انھوں نے سعید بن جبیر سے انھوں نے ابن عباس رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "2893", "text": "اسماعیل بن ابرا ہیم نے ایوب سے حدیث بیان کی  ۔ کہا مجھے سعید بن جبیر سے خبر دی گئی  ، انھوں نے ابن ع"}
{"hadithnumber": "2978", "text": "ہمام نے کہا :  ہمیں قتادہ نے مطرف کے واسطے سے حضرت عمران بن حصین رضی اللہ تعالیٰ عنہ  سے حدیث بیان ف"}
{"hadithnumber": "2979", "text": "محمد بن واسع نے مطرف بن عبد اللہ بن شخر سے ،  انھوں نے حضرت عمرا ن بن حصین رضی اللہ تعالیٰ عنہ سے یہ"}
{"hadithnumber": "3023", "text": "عبد الاعلی بن عبد الاعلی نے حدیث بیان کی  ،  ( کہا )  ہمیں داود نے ابو نضر ہ سے انھوں نے ابو سعید خد"}
{"hadithnumber": "3028", "text": "ہشیم نے یحییٰ بن ابی اسھاق عبد العزیز بن صہیب اور حمید سے خبر دی کہ ان سب نے حضرت انس  رضی اللہ تعال"}
{"hadithnumber": "3029", "text": "اسماعیل بن ابرا ہیم نے یحییٰ بن ابی اسھاق اور حمید طویل سے خبردی یحییٰ نے کہا  :  میں نے حضرت انس  ر"}
{"hadithnumber": "3038", "text": "ابن جریج نے کہا  :  مجھے عطا ء نے خبر دی کہا  :  میں نے ابن عباس  رضی اللہ تعالیٰ عنہ  سے سنا وہ ہمی"}
{"hadithnumber": "3039", "text": "حبیب معلم نے ہمیں حدیث سنا ئی  ، انھوں نے عطا ء سے انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے رو"}
{"hadithnumber": "3087", "text": "ابن عباس رضی اللہ تعالیٰ عنہ   کے آزاد کردہ غلام کریب نے حضرت اسامہ بن زید رضی اللہ تعالیٰ عنہ   سے"}
{"hadithnumber": "3092", "text": "ہشیم نے کہا  :  ہمیں حصین نے کثیر بن مدرک اشجعی سے خبر دی  ، انھوں نے عبد الرحمٰن بن یزید سے روایت ک"}
{"hadithnumber": "3093", "text": "سفیان نے ہمیں حصین سے اسی سند کے ساتھ  ( یہی )  حدیث بیان کی  ۔"}
{"hadithnumber": "3108", "text": "سلیمان بن بلال نے یحیٰٰ بن سعید سے روایت کی  ،  ( کہا :  )  مجھے عدی بن ثابت نے خبر دی کہ عبداللہ بن"}
{"hadithnumber": "3109", "text": "قتیبہ اور ابن رمح نے لیث بن سعد سے اور انھوں نے یحییٰ بن سعید سے اسی سند کے ساتھ بیان کی  ، ابن رمح"}
{"hadithnumber": "3222", "text": "۔  ہمیں لیث نے ابن شہاب سے حدیث بیان کی  ،  انھوں نے ابو سلمہ اور عروہ سے روایت کی کہ حضرت عائشہ رضی"}
{"hadithnumber": "3223", "text": "یونس نے ابن شہاب سے اسی سند کے ساتھ خبردی  ( حضرت عائشہ  رضی اللہ تعالیٰ عنہا   نے  )  کہا نبی  صلی"}
{"hadithnumber": "3224", "text": "عبد الرحمٰن بن قاسم نے اپنے والد  ( قاسم بن محمد بن ابی بکر  )  سے انھوں نے حضرت عائشہ رضی اللہ تعال"}
{"hadithnumber": "3225", "text": "افلح نے ہمیں قاسم بن محمد سے حدیث بیان کی انھوں نے حجرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی انھ"}
{"hadithnumber": "3226", "text": "عمرہ بنت عبد الرحمٰن  رضی اللہ تعالیٰ عنہا   نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی کہ انھ"}
{"hadithnumber": "3227", "text": "ابو سلمہ حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے حضرت صفی"}
{"hadithnumber": "3228", "text": "حکم نے ابرا ہیم سے انھوں نے اسود سے اور انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی انھوں"}
{"hadithnumber": "3229", "text": "اعمش اور منصور دونوں نے ابر اہیم سے انھوں نے اسود سے انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے ا"}
{"hadithnumber": "3262", "text": "شعبہ نے ہمیں عبد الملک بن عمیر سے حدیث بیان کی  ۔ کہا میں نے قزعہ سے سنا انھوں نے کہا میں نے ابو سعی"}
{"hadithnumber": "3463", "text": "ہمیں محمد بن مثنیٰ نے حدیث بیان کی ،  کہا :  ہمیں عبدالصمد نے حدیث سنائی ،  کہا :  ہمیں شعبہ نے اعمش"}
{"hadithnumber": "3499", "text": "حضرت ابوموسیٰ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے اس شخص کے"}
{"hadithnumber": "3525", "text": "زیاد بن سعد نے کہا :  میں نے ثابت  ( بن عیاض )  اعرج سے سنا ،  وہ حضرت ابوہریرہ رضی اللہ عنہ سے حدیث"}
{"hadithnumber": "3695", "text": "معمر نے زہری سے ،  انہوں نے عبیداللہ بن عبداللہ بن ابی ثور سے ،  انہوں نے حضرت ابن عباس رضی اللہ عنہ"}
{"hadithnumber": "3725", "text": "حمید بن نافع نے زینب بنت ابی سلمہ سے روایت کی کہ انہوں نے اِن  ( حمید )  کو یہ تین حدیثیں بیان کیں ،"}
{"hadithnumber": "3726", "text": "زینب  ( بنت ابی سلمہ رضی اللہ عنہا )  نے کہا :  پھر میں زینب بنت جحش رضی اللہ عنہا کے ہاں اس وقت گئی"}
{"hadithnumber": "3727", "text": "زینب رضی اللہ عنہا نے کہا :  میں نے اپنی والدہ ام سلمہ رضی اللہ عنہا سے سنا وہ کہہ رہی تھیں ،  ایک ع"}
{"hadithnumber": "3730", "text": "زینب نے انہیں  ( حمید کو )  اپنی والدہ  ( حضرت ام سلمہ رضی اللہ عنہا )  سے اور نبی صلی اللہ علیہ وسل"}
{"hadithnumber": "3792", "text": "زائدہ نے سلیمان  ( اعمش )  سے ،  انہوں نے ابوصالح سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور ا"}
{"hadithnumber": "3836", "text": "حماد نے ہمیں عمرو بن دینار سے حدیث بیان کی ،  انہوں نے طاوس سے اور انہوں نے حضرت ابن عباس رضی اللہ ع"}
{"hadithnumber": "3842", "text": "عبیداللہ نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "3845", "text": "عبداللہ بن دینار سے روایت ہے کہ انہوں نے حضرت ابن عمر رضی اللہ عنہ سے سنا ،  انہوں نے کہا :  رسول ال"}
{"hadithnumber": "4251", "text": "اوپر ‌والی ‌حدیث ‌اسی ‌سند ‌سے ‌مروی ‌ہے ‌."}
{"hadithnumber": "4252", "text": "رَوح بن عبادہ نے ہمیں حدیث بیان کی ،   ( کہا :   )  ہمیں ابن جریج نے حدیث سنائی ،   ( کہا :   )  مجھ"}
{"hadithnumber": "4435", "text": "لیث نے ابن شہاب سے ،  انہوں نے عبیداللہ بن عبداللہ بن عتبہ بن مسعود سے ،  انہوں نے حضرت ابوہریرہ اور"}
{"hadithnumber": "4436", "text": "یونس ،  صالح اور معمر سب نے زہری سے اسی سند کے ساتھ اسی طرح حدیث بیان کی"}
{"hadithnumber": "4504", "text": "مجھے عبداللہ بن وہب نے خبر دی ،  کہا :  مجھے ضحاک بن عثمان نے ابونضر سے حدیث بیان کی ،  انہوں نے بسر"}
{"hadithnumber": "4505", "text": "ابوبکر حنفی نے ضحاک بن عثمان سے اسی سند کے ساتھ حدیث بیان کی اور انہوں نے حدیث میں کہا :   \" اگر اسے"}
{"hadithnumber": "4521", "text": "ابوبکر بن ابی شیبہ نے کہا :  ہمیں وکیع بن جراح نے سفیان سے حدی بیان کی ،  نیز اسحاق بن ابراہیم نے کہ"}
{"hadithnumber": "4522", "text": "نیز عبداللہ بن ہاشم نے کہا  ۔  ۔  الفاظ انہی کے ہیں  ۔  ۔  مجھے عبدالرحمٰن بن مہدی نے حدیث بیان کی ،"}
{"hadithnumber": "4680", "text": "ثابت نے حضرت انس رضی اللہ عنہ سے روایت کی کہ حنین کے دن حضرت ام سلیم رضی اللہ عنہا نے ایک خنجر  ( اپ"}
{"hadithnumber": "4681", "text": "اسحاق بن عبداللہ بن ابی طلحہ نے  ( اپنے چچا )  حضرت انس بن مالک رضی اللہ عنہ سے  ( اپنی دادی )  ام س"}
{"hadithnumber": "4725", "text": "عبیداللہ بن عمر ،  ایوب ،  ضحاک بن عثمان اور اسامہ  ( بن زید لیثی )  سب نے نافع سے ،  انہوں نے ابن ع"}
{"hadithnumber": "4726", "text": "عبیداللہ  ( بن عمر بن حفص )  نے نافع سے ،  انہوں نے حضرت ابن عمر رضی اللہ عنہ سے اسی طرح حدیث بیان ک"}
{"hadithnumber": "4747", "text": "مغیرہ بن عبدالرحمان نے ابوزناد سے ،  انہوں نے اعرج سے ،  انہوں نے ابوہریرہ رضی اللہ عنہ سے ،  انہوں"}
{"hadithnumber": "4748", "text": "ابن عیینہ نے ابوزناد سے اسی سند کے ساتھ روایت کی ،  انہوں نے یہ بیان نہیں کیا :   \" جس نے امیر کی نا"}
{"hadithnumber": "4780", "text": "ہمیں خالد بن حارث نے حدیث بیان کی ،  کہا :  ہمیں شعبہ بن حجاج نے قتادہ سے حدیث سنائی ،  انہوں نے کہا"}
{"hadithnumber": "4781", "text": "معاذ نے شعبہ سے اسی سند کے ساتھ حدیث سنائی اور یہ نہیں کہا :  اس نے رسول اللہ صلی اللہ علیہ وسلم سے"}
{"hadithnumber": "4819", "text": "ابوعوانہ نے طارق سے ،  انہوں نے سعید بن مسیب سے روایت کی ،  کہا :  میرے والد بھی ان لوگوں میں سے تھے"}
{"hadithnumber": "4820", "text": "سفیان نے طارق بن عبدالرحمٰن سے حدیث بیان کی ،  انہوں نے سعید بن مسیب سے ،  انہوں نے اپنے والد سے روا"}
{"hadithnumber": "4905", "text": "حسین نے یحییٰ  ( بن ابی کثیر )  سے حدیث بیان کی ،  کہا :  مجھے مہری کے مولیٰ ابوسعید نے حدیث بیان کی"}
{"hadithnumber": "4906", "text": "شیبان نے یحییٰ سے اسی سند کے ساتھ اسی کے مانند روایت کی ۔"}
{"hadithnumber": "4968", "text": "روح نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "4969", "text": "وکیع نے سفیان سے ،  انہوں نے محارب سے ،  انہوں نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  کہا :  نبی ص"}
{"hadithnumber": "4970", "text": "عبدالرحمٰن نے کہا :  ہمیں سفیان نے اسی سند کے ساتھ حدیث بیان کی ۔  عبدالرحمٰن نے کہا :  سفیان نے کہا"}
{"hadithnumber": "4971", "text": "ہمیں شعبہ نے محارب سے حدیث بیان کی ،  انہوں نے حضرت جابر رضی اللہ عنہ سے ،  انہوں نے نبی اکرم صلی ال"}
{"hadithnumber": "5112", "text": "ابو مسہر نے کہا : ہمیں یحییٰ بن حمزہ نے حدیث بیان کی ، کہا : مجھے زبیدی نے عبدالرحمان بن جبیر بن نفی"}
{"hadithnumber": "5113", "text": "محمد بن مبارک نے کہا :  \" ہمیں یحییٰ بن حمزہ نے اسی سند کے ساتھ حدیث بیان کی اور  \" حجۃ الوداع میں "}
{"hadithnumber": "5204", "text": "ابو زبیر نے کہا  :  میں نے حضرت جا بر بن عبد اللہ  رضی اللہ تعالیٰ عنہ  کو کہتے ہو ئے سنا ،  رسول ال"}
{"hadithnumber": "5207", "text": "ضرار بن مرہ ابو سنان نے محارب بن دثار سے ،  انھوں نے عبد اللہ بن بریدہ سے ،  انھوں نے اپنے والد سے ر"}
{"hadithnumber": "5208", "text": "علقمہ بن مرثد نے ابن بریدہ سے انھوں نے اپنے والد سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر"}
{"hadithnumber": "5214", "text": "شعبہ نے سعید بن ابی بردہ سے انھوں نے اپنے والد سے انھوں نے حضرت ابو موسیٰ اشعری رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "5384", "text": "ابو حازم نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے انھوں نے نبی  صلی اللہ علیہ وسلم  سے اسی کے مانند"}
{"hadithnumber": "5393", "text": "ہمیں سفیان نے اشعث بن ابی شعثاء سے ان سب کی سند کے ساتھ حدیث بیان کی اور شک کے بغیر  \" سلام عام کرنے"}
{"hadithnumber": "5519", "text": "بنو نجار کے آزاد کردہ غلا م ابو حباب سعید بن یسار نے حضرت زید بن خالد جہنی سے ،  انھوں نے حضرت ابو ط"}
{"hadithnumber": "5521", "text": "اسماعیل بن ابراہیم نے داود سے ، انھوں نے عزرہ سے  ، انھوں نے حمید بن عبدالرحمان سے  ، انھوں نے سعد ب"}
{"hadithnumber": "5522", "text": "محمد بن مثنیٰ نے کہا : ہمیں ابن ابی عدی اور عبدالاعلیٰ نے اسی سند کے ساتھ ( داود سے )  حدیث بیان کی"}
{"hadithnumber": "5539", "text": "منصور نے مسلم بن صبیح  ( ابو ضحیٰ )  سے روایت کی ،  انھوں نے کہا  :  میں مسروق کے ساتھ ایک مکا ن میں"}
{"hadithnumber": "5540", "text": "امام مسلم نے کہا  :  میں نے نصر بن علی جہضمی کے ساتھ عبد الاعلی بن عبد الاعلیٰ سے حدیث پڑھی کہ ہمیں"}
{"hadithnumber": "5541", "text": "سعید بن ابی عروبہ نے نضر بن انس بن مالک رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  میں حضرت ابن عبا"}
{"hadithnumber": "5542", "text": "قتادہ نے نضر بن انس سے روایت کی کہ حضرت  ابن عباس  رضی اللہ تعالیٰ عنہ  کے پاس ایک شخص آیا  ۔  اور ا"}
{"hadithnumber": "5543", "text": "ابن فضیل نے عمارہ سے ، انھوں نے ابو زرعہ سے روایت کی ، انھوں نے کہا  :  میں حضرت ابو ہریرہ رضی اللہ"}
{"hadithnumber": "5544", "text": "جریر نے عمارہ سے ، انھوں نے ابو زرعہ سے روایت کی ،  کہا  :  میں اور حضرت ابو ہریرہ رضی اللہ تعالیٰ ع"}
{"hadithnumber": "5545", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے ،  کہا  :  رسول اللہ صلی اللہ علیہ وسلم  نے فرما یا"}
{"hadithnumber": "5556", "text": "یحییٰ بن سعید نے شعبہ سے روایت کی ،  کہا  :  مجھے ہشام بن زید نے حدیث بیان کی  ، انھوں نے کہا  :  می"}
{"hadithnumber": "5557", "text": "خالد بن حارث محمد  ( ابن جعفر غندر ) یحییٰ  ( بن سعید قطان )  اور عبد الرحمان  ( بن مہدی )  سب نے شع"}
{"hadithnumber": "5569", "text": "زید بن حباب نے ابراہیم بن نافع سے روایت کی  ، کہا : مجھے حسن بن مسلم بن یناق نے صفیہ بنت شیبہ سے خبر"}
{"hadithnumber": "5570", "text": "عبدالرحمان بن مہدی نے ابراہیم بن نافع سے اسی سند کے ساتھ حدیث بیان کی اور کہا :  \"  جوڑ لگانے والیوں"}
{"hadithnumber": "5571", "text": "عبیداللہ نے کہا : مجھے نافع نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے خبردی کہ ر سول اللہ  صلی اللہ عل"}
{"hadithnumber": "5572", "text": "صخر بن جویریہ نے نافع سے ، انھوں نے حضرت عبداللہ بن عمر رضی اللہ تعالیٰ عنہ  سے  ، انھوں نے نبی کریم"}
{"hadithnumber": "5637", "text": "نضر بن شمیل ابو عامر عقدی وہب بن جریر اور بہز  ، سب  نے شعبہ سے اسی سند کے ساتھ روایت کی ،  ان سب کی"}
{"hadithnumber": "5669", "text": "ابن نمیر نے کہا : ہشام نے ہمیں اسی سند کے ساتھ حدیث بیان کی اور کہا : وہ ایسی خاتون تھیں کہ ان کاجسم"}
{"hadithnumber": "5670", "text": "علی بن مسہر نے ہشام سے اسی سند کے ساتھ ہمیں حدیث بیان کی ۔"}
{"hadithnumber": "5762", "text": "سفیان بن عیینہ نے زہری سے  ، انھوں نے عبید اللہ بن عبد اللہ سے ،  انھوں نے عکا شہ بن محصن  رضی اللہ"}
{"hadithnumber": "5764", "text": "یونس بن یزید نے کہا کہ ابن شہاب نے انھیں بتا یا کہا  :  مجھے عبید اللہ بن عبد اللہ بن عتبہ بن مسعود"}
{"hadithnumber": "5826", "text": "زبیدی نے زہری سے روایت کی ، کہا  :  مجھے سالم بن عبد اللہ نے حضرت عبد اللہ بن عمر رضی اللہ تعالیٰ عن"}
{"hadithnumber": "5827", "text": "یونس معمر اور صالح سب نے ہمیں زہری سے ، اسی سند کے ساتھ حدیث سنائی  ، البتہ صالح نے کہا : یہاں تک کہ"}
{"hadithnumber": "5885", "text": "عمرو ناقد اور ابن ابی عمر ، دونوں نے ابن عیینہ سے روایت کی ۔ ابن ابی عمر نے کہا  :  ہمیں سفیان بن عی"}
{"hadithnumber": "5886", "text": "زہیر بن حرب اور احمد بن عبد ہ دونوں نے ابن عیینہ سے  ، انھوں نے ابرا ہیم بن میسرہ سے انھوں نے عمرو ب"}
{"hadithnumber": "5935", "text": "سیدنا ابن عباس رضی اللہ عنہما کہتے ہیں کہ مسیلمہ کذاب رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں مدین"}
{"hadithnumber": "5968", "text": "یعقوب بن عبدالرحمان القاری نے ابو حازم سے ر وایت کی ، انھوں نے کہا : میں نے حضرت سہل رضی اللہ تعالیٰ"}
{"hadithnumber": "5971", "text": "نافع بن عمر جحمی نے ابن ابی ملیکہ سے روایت کی  ، کہا : حضرت عبداللہ بن عمرو بن عاص  رضی اللہ تعالیٰ"}
{"hadithnumber": "5990", "text": "ہشام نے قتادہ سے ، انھوں نے سالم بن ابی جعد سے ، انھوں نے معدان بن ابی طلحہ یعمری سے ، انھوں نے حضرت"}
{"hadithnumber": "5991", "text": "شیبان نے قتادہ سے ہشام کی سند کے ساتھ اس کی حدیث کے مانند حدیث بیان کی ،  مگر اس نے اس طرح کہا  :  "}
{"hadithnumber": "5995", "text": "ابن شہاب سے روایت ہے کہ حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  نے انھیں حدیث بیان کی کہ رسول اللہ  ص"}
{"hadithnumber": "5996", "text": "عبد العزیز بن صہیب نے کہا  :  ہمیں حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  نے حدیث بیان کی کہ نبی  صل"}
{"hadithnumber": "5997", "text": "مختار بن فلفل نے حضرت انس  رضی اللہ تعالیٰ عنہ سے انھوں نے نبی  صلی اللہ علیہ وسلم  سے اسی مفہوم میں"}
{"hadithnumber": "5998", "text": "معتمر کے والد سلیمان نے کہا  :  ہمیں قتادہ نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  نے حدیث بیان کی"}
{"hadithnumber": "5999", "text": "ہشام اور ابو عوانہ دونوں نے قتادہ نے حضرت انس   رضی اللہ تعالیٰ عنہ  سے انھوں نے  نبی  صلی اللہ علیہ"}
{"hadithnumber": "6000", "text": "سعید نے قتادہ سے روایت کی ،  انھوں نےکہا :  حضرت انس   رضی اللہ تعالیٰ عنہ  نے کہا کہ اللہ کے   نبی"}
{"hadithnumber": "6001", "text": "شیبان نے قتادہ سے روایت کی کہا  :  ہمیں حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  نے حدیث سنائی کہ اللہ"}
{"hadithnumber": "6002", "text": "سماک بن حرب نے حضرت جا بربن سمرہ رضی اللہ تعالیٰ عنہ  سے انھوں نے رسول اللہ  صلی اللہ علیہ وسلم  سے"}
{"hadithnumber": "6003", "text": "عامر بن سعد بن ابی وقاص نے کہا  :  میں نے اپنے غلام نافع کے ہاتھ حضرت جابر بن سمرہ رضی اللہ تعالیٰ ع"}
{"hadithnumber": "6015", "text": "اسحٰق نے کہا  :  حضرت انس رضی اللہ تعالیٰ عنہ  نے کہا  :  رسول اللہ  صلی اللہ علیہ وسلم تمام انسانوں"}
{"hadithnumber": "6144", "text": "اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے ،  انھوں نے مضبوط سہارے کی پناہ لی ہو ئی تھی ۔"}
{"hadithnumber": "6179", "text": "عباد بن موسیٰ نے کہا ، ہمیں ابراہیم بن سعد نے حدیث بیان کی ، کہا : مجھے میرے والد نے محمد بن جبیر بن"}
{"hadithnumber": "6180", "text": "یعقوب بن ابراہیم نے کہا : ہمیں میرے والد نے اپنے والد سے حدیث بیان کی ، کہا : مجھے محمد بن جبیر بن م"}
{"hadithnumber": "6200", "text": "یونس نے کہا  :  ابن شہاب نے انھیں سعید بن مسیب سے خبر دی  ، انھوں نے ابو ہریرہ رضی اللہ تعالیٰ عنہ س"}
{"hadithnumber": "6201", "text": "صالح نے ابن شہاب سے اسی سند کے ساتھ اسی کے مانندروایت کی ۔"}
{"hadithnumber": "6410", "text": "بُرَید نے ابو بُردہ سے انھوں نے حضرت ابو موسیٰ اشعری رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا : ہمیں"}
{"hadithnumber": "6414", "text": "محمد بن جعفر اور عبد الرحمٰن بن مہدی نے کہا :  ہمیں شعبہ نے قتادہ سے حدیث بیان کی ، انھوں نے نضر بن"}
{"hadithnumber": "6415", "text": "خالد بن حارث نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ حدیث بیان کی ۔"}
{"hadithnumber": "6505", "text": "معاذ نے کہا :  ہمیں شعبہ نے حبیب سے حدیث بیان کی ،  انہوں نے کہا :  میں نے ابوعباس سے سنا ،  انہوں ن"}
{"hadithnumber": "6506", "text": "ابن بشر نے مسعر سے ،  ابواسحاق اور زائدہ دونوں نے اعمش سے ،  سب نے حبیب سے اسی سند کے ساتھ اسی کے ما"}
{"hadithnumber": "6527", "text": "محمد بن ولید زبیدی اور یونس نے ابن شہاب سے روایت کی ،  انہوں نے انس رضی اللہ عنہ سے اور انہوں نے نبی"}
{"hadithnumber": "6528", "text": "ابن عیینہ نے زہری سے اسی سند کے ساتھ روایت کی ،  نیز ابن عیینہ نے مزید یہ کہا :   \" اور ایک دوسرے سے"}
{"hadithnumber": "6529", "text": "یزید بن زریع اور عبدالرزاق ،  دونوں نے معمر سے ،  انہوں نے زہری سے اسی سند کے ساتھ حدیث بیان کی ۔ \\n\\n"}
{"hadithnumber": "6544", "text": ")   امام مالک بن انس نے سہیل  ( بن ابی صالح )  سے ،  انہوں نے اپنے والد سے ،  انہوں نے حضرت ابوہریرہ"}
{"hadithnumber": "6545", "text": "زہیر بن حرب نے کہا :  ہمیں جریر نے حدیث بیان کی ۔  قتیبہ بن سعید اور احمد بن عبدہ ضبی نے عبدالعزیز د"}
{"hadithnumber": "6625", "text": "حجاج بن محمد نے کہا :  ابن جریج نے کہا :  مجھے ابوزبیر نے بتایا ،  انہوں نے حضرت جابر بن عبداللہ رضی"}
{"hadithnumber": "6626", "text": "روح اور ابوعاصم دونوں نے ہمیں ابن جریج سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "6701", "text": "ہمیں سوید بن سعید اور محمد بن عبدالاعلیٰ نے حدیث بیان کی  ۔  ۔  دونوں کے الفاظ ملتے جلتے ہیں  ۔  ۔"}
{"hadithnumber": "6702", "text": "یحییٰ بن سعید نے تیمی سے اسی سند کے ساتھ روایت کی اور کہا :  آپ نے رسول اللہ صلی اللہ علیہ وسلم سے ک"}
{"hadithnumber": "6711", "text": "سفیان نے زہری سے ،  انہوں نے حضرت انس رضی اللہ عنہ سے روایت کی ،  کہا :  ایک شخص نے پوچھا :  اللہ کے"}
{"hadithnumber": "6712", "text": "معمر نے زہری سے روایت کی ،  انہوں نے کہا :  مجھے حضرت انس بن مالک رضی اللہ عنہ نے حدیث سنائی کہ رسول"}
{"hadithnumber": "6792", "text": "یونس نے ابن شہاب سے روایت کی ،  انہوں نے کہا :  مجھے حمید بن عبدالرحمٰن بن عوف نے حدیث بیان کی کہ حض"}
{"hadithnumber": "6844", "text": "ابواسحٰق نے عمرو بن میمون سے روایت کی ،  کہا :  جس شخص نے دس بار :   \"  لا اله الا لله وحده لا شريك"}
{"hadithnumber": "6845", "text": "شعبی نے ربیع بن خُثیم سے اسی کے مانند روایت کی ،  انہوں نے کہا :  میں نے ربیع سے پوچھا :  آپ نے یہ"}
{"hadithnumber": "6855", "text": ")   محمد بن جعفر نے کہا :  ہمیں شعبہ نے حدیث بیان کی ،  کہا :  میں نے ابواسحاق کو ابومسلم اغر سے حدی"}
{"hadithnumber": "6856", "text": "عبدالرحمٰن نے ہمیں حدیث بیان کی ،  کہا :  ہمیں شعبہ نے اسی سند سے اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "6879", "text": "عبداللہ بن وہب نے کہا :  ہمیں عمرو بن حارث نے خبر دی کہ یزید بن ابی حبیب اور حارث بن یعقوب نے انہیں"}
{"hadithnumber": "6918", "text": "روح بن قاسم نے سہیل سے ،  انہوں نے اپنے والد  ( ابوصالح )  سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عن"}
{"hadithnumber": "6919", "text": "وہیب نے کہا :  ہمیں سہیل نے اسی سند کے ساتھ  ( یہی )  حدیث بیان کی ۔"}
{"hadithnumber": "6929", "text": "عیسیٰ بن یونس نے کہا :  ہمیں عبدالملک بن ابی سلیمان نے ابوزبیر سے حدیث بیان کی ،  انہوں نے عبداللہ ب"}
{"hadithnumber": "6961", "text": "ہداب بن خالد نے کہا :  ہمیں ہمام نے حدیث بیان کی ،  انہوں نے کہا :  ہمیں قتادہ نے حضرت انس بن مالک ر"}
{"hadithnumber": "6962", "text": "حبان نے کہا :  ہمیں ہمام نے حدیث بیان کی ۔ کہا :  ہمیں قتادہ نے حدیث سنائی ،  کہا :  ہمیں حضرت انس ب"}
{"hadithnumber": "6981", "text": "معمر نے کہا :  زہری نے مجھ سے کہا :  کیا میں تمہیں دو عجیب حدیثیں نہ سناؤں؟  ( پھر )  زہری نے کہا :"}
{"hadithnumber": "6989", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے عمرہ بن مرہ سے حدیث بیان کی ،  انہوں نے کہا :  میں نے ابوعبید کو"}
{"hadithnumber": "6990", "text": "ابوداود نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "7016", "text": "یونس نے مجھے ابن شہاب سے خبر دی، کہا: پھر رسول اللہ صلی اللہ علیہ وسلم غزوہ تبوک لڑنے گئے اور آپ کا"}
{"hadithnumber": "7017", "text": "عُقیل بن ابن شہاب سے یونس کی سند کے ساتھ زہری سے بالکل اسی طرح روایت کی ۔"}
{"hadithnumber": "7018", "text": "زہری کے بھتیجے محمد بن عبداللہ بن مسلم نے ہمیں اپنے چچا محمد بن مسلم زہری سے حدیث بیان کی ،  انہوں ن"}
{"hadithnumber": "7020", "text": "حبان بن موسیٰ نے ہمیں حدیث بیان کی، انہوں نے کہا: ہمیں عبداللہ بن مبارک نے خبر دی، انہوں نے کہا: ہمی"}
{"hadithnumber": "7076", "text": "۔  شیبان نےکہا : ہمیں قتادہ نے حضرت انس رضی اللہ تعالیٰ عنہ  سے روایت کی کہ اہل مکہ نے  رسول اللہ  ص"}
{"hadithnumber": "7077", "text": "معمر نے  ہمیں قتادہ سے  ، انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے شیبان کی حدیث سے ہم معنی  روایت"}
{"hadithnumber": "7080", "text": "ابو بکر بن ابی شیبہ نے ہمیں حدیث بیان کی ، کہا : ہمیں ابو معاویہ اور ابو اسامہ نے اعمش سے حدیث بیان"}
{"hadithnumber": "7081", "text": "وکیع نے کہا : ہمیں اعمش نے حدیث بیان کی ، انھوں نے کہا : ہمیں سعید بن جبیر نے ابو عبدالرحمان سلمی سے"}
{"hadithnumber": "7111", "text": "لیث نے بکیر سے انھوں نے بسربن سعید سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے اور انھوں ن"}
{"hadithnumber": "7112", "text": "عمرو بن حارث نے بکیر بن اشج سے اسی سند کے ساتھ روایت کی مگر  ( اس میں  ) کہا  :  \" اپنی رحمت اور فضل"}
{"hadithnumber": "7138", "text": "ابوحازم نے  حضر ت سہل بن سعد رضی اللہ تعالیٰ عنہ  سے ، انھوں نے رسول اللہ  صلی اللہ علیہ وسلم  سے ر"}
{"hadithnumber": "7141", "text": "یعقوب بن عبدالرحمان القاری نے ہمیں ابوحازم سے حدیث بیان کی ، انھوں نے حضرت سہل بن سعد رضی اللہ تعالی"}
{"hadithnumber": "7144", "text": "عطاء بن یسار نے حضرت ابوسعید خدری رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "7256", "text": "معمر نے ہمام بن منبہ سے روایت کی کہا :  یہ احادیث ہیں جو حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے ہمیں"}
{"hadithnumber": "7301", "text": "اعرج نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم  نے  فرمایا"}
{"hadithnumber": "7302", "text": "ابو حازم نے حضرت ابوہریرۃ رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا : رسول اللہ  صلی اللہ علیہ وسلم  ن"}
{"hadithnumber": "7319", "text": "اور ابو معاویہ نے داؤد بن ابی ہندسے انھوں نے ابونضرہ سے انھوں نے حضرت ابو سعید  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "7325", "text": "ابو اسامہ نے ہمیں حدیث بیان کی کہا :  ہمیں شعبہ نے ابو تیاح سے حدیث بیان کی ،  انھوں نے کہا :  میں ن"}
{"hadithnumber": "7329", "text": "معمر نے ہمیں ہمام بن منبہ سے حدیث بیان کی  ، کہا : یہ احادیث ہیں جو حضرت ابوہریرۃ رضی اللہ تعالیٰ عن"}
{"hadithnumber": "7330", "text": "حضرت جابر بن سمرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے ، انھوں نے کہا کہ رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "7331", "text": "قتیبہ بن سعید اور ابو کامل جحدری نے کہا : ہمیں ابو عوانہ نے سماک بن حرب سے حدیث بیان کی ، انھوں نے ح"}
{"hadithnumber": "7332", "text": "شعبہ نے سماک بن حرب سے روایت کی ، انھوں نے کہا : میں نے حضرت جابر بن سمرہ رضی اللہ تعالیٰ عنہ  سے سن"}
{"hadithnumber": "7333", "text": "عبدالعزیز بن محمد نے ثور بن زید دیلی سے ، انھوں نے ابو الغیث سے اور انھوں نے حضرت ابوہریرۃ رضی اللہ"}
{"hadithnumber": "7334", "text": "سلیمان بن بلال نے کہا : ہمیں ثور بن زید دیلی نے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "7335", "text": "محمد بن بشیر نے کہا : ہمیں عبیداللہ نے نافع سے ، انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ   سے اور"}
{"hadithnumber": "7336", "text": "یحییٰ نے ہمیں عبیداللہ سے اسی سند کے ساتھ ر وایت کی اور اپنی حدیث میں کہا :  \" یہ یہودی میرے پیچھے ہ"}
{"hadithnumber": "7337", "text": "عمر بن حمزہ نے کہا : میں نے سالم کو کہتے ہوئے سنا : ہمیں حضرت عبداللہ بن عمر رضی اللہ تعالیٰ عنہ  نے"}
{"hadithnumber": "7338", "text": "ابن شہاب نے کہا : مجھے سالم بن عبداللہ نے حدیث بیان کی کہ حضرت عبداللہ بن عمر رضی اللہ تعالیٰ عنہ  ن"}
{"hadithnumber": "7339", "text": "حضرت ابو ہریرۃ رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :  \" قیا"}
{"hadithnumber": "7340", "text": "ابو الاحوص اور ابو عوانہ نے سماک سے اور انھوں نے ح ضرت جابر بن سمرۃ رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "7341", "text": "اور ابن مثنیٰ اور ابن بشار نے مجھے حدیث بیان کی ، دونوں نے کہا : ہمیں محمد بن جعفر نے حدیث بیان کی ،"}
{"hadithnumber": "7342", "text": "اعرج نے حضر ت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی کریم صلی اللہ علیہ وسلم  سے روایت ک"}
{"hadithnumber": "7343", "text": "ہمام بن منبہ نے حضر ت ابوہریرۃ رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی کریم صلی اللہ علیہ وسلم  سے"}
{"hadithnumber": "7354", "text": "یونس نے ابن شہاب سے ر وایت کی کہ سالم بن عبداللہ نے انھیں بتایا ، انھیں حضرت عبداللہ بن عمر رضی اللہ"}
{"hadithnumber": "7355", "text": "سالم بن عبداللہ نے کہا : میں نے  حضرت عبداللہ بن عمر رضی اللہ تعالیٰ عنہ  سے سنا ، وہ کہتے ہیں : اس"}
{"hadithnumber": "7368", "text": "محمد بن جعفرنے ہمیں حدیث بیان کی کہا :  ہمیں شعبہ نے عبدالملک بن عمیر سے حدیث بیان کی  ،  انھوں نےرب"}
{"hadithnumber": "7371", "text": "نعیم بن ابی ہند نے ربعی حراش سے روایت کی کہا :  ( ایک بارجب )  حضرت حذیفہ  رضی اللہ تعالیٰ عنہ نے کہ"}
{"hadithnumber": "7447", "text": "حفص بن غیاث نے ہمیں ہشام بن عروہ سے حدیث بیان کی ،  انھوں نے اپنے والد سے روایت کی ،  انھو ں نے کہا"}
{"hadithnumber": "7448", "text": "بلال بن حمید نے عروہ سے اور انھوں نے حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت کی ،  انھوں نے کہا :"}
{"hadithnumber": "7449", "text": "یحییٰ بن یمان نے کہا : ہمیں ہشام بن عروہ نے حدیث بیان کی ،  انھوں نے اپنے والد سے اورانھوں نے حضرت ع"}
{"hadithnumber": "7450", "text": "ابو بکر بن ابی شیبہ اور ابو کریب نے کہا : ہمیں ابو اسامہ اور ابن نمیر نے ہشام بن عروہ سے اسی سند کے"}
{"hadithnumber": "7451", "text": "حضرت عائشہ رضی اللہ تعالیٰ عنہا    سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  وفات پاگئے اور میرے"}
{"hadithnumber": "7452", "text": "یزید بن رومان نے عروہ سے اور انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا    سے روایت کی کہ آپ بتایا کر"}
{"hadithnumber": "7453", "text": "عروہ بن زبیر نے نبی  صلی اللہ علیہ وسلم  کی اہلیہ حضرت عائشہ رضی اللہ تعالیٰ عنہا    سے روایت کی کہا"}
{"hadithnumber": "7454", "text": "داؤد بن عبد الرحمٰن عطاء نے ہمیں خبر دی کہا : مجھے منصور بن عبد الرحمٰن یحییٰ نے اپنی والدہ صفیہ سے"}
{"hadithnumber": "7455", "text": "عبد الرحمٰن  ( بن مہدی ) نے ہمیں سفیان  ( ثوری ) سے حدیث بیان کی ،  انھوں نے منصور بن صفیہ سے انھوں"}
{"hadithnumber": "7456", "text": "( عبید اللہ بن عبد الرحمٰن  ) اشجعی اور ابو احمد دونوں نے سفیان سے اسی سند کے ساتھ حدیث بیان کی مگر"}
{"hadithnumber": "7457", "text": "محمد بن عباد اور ابن ابی عمر نے ہمیں حدیث بیان کی ،  کہا : ہمیں مروان فزاری نے یزید بن کیسان سے حدیث"}
{"hadithnumber": "7458", "text": "یحییٰ بن سعید نے ہمیں یزید بن کیسان سے حدیث بیان کی  ،  انھوں نےکہا : مجھے حازم نے حدیث بیان کی کہا"}
{"hadithnumber": "7459", "text": "قتیبہ بن سعید اور ابو بکر بن ابی شیبہ نے کہا :  ہمیں ابو احوص نے سماک بن حرب سے حدیث بیان کی ، انھوں"}
{"hadithnumber": "7460", "text": "زہیر اور اسرائیل دونوں نے سماک سے اسی سند کے ساتھ اسی کے مطابق حدیث بیان کی اور زہیر کی حدیث میں مزی"}
{"hadithnumber": "7461", "text": "شعبہ نے سماک بن حرب سے حدیث بیان کی  ، کہا : میں نے حضرت نعمان بن بشیر  رضی اللہ تعالیٰ عنہ   کو خطب"}
{"hadithnumber": "7462", "text": "ابو ہانی نے ابو عبد الرحمٰن کو کہتے ہوئے سنا  : میں نے حضرت عبداللہ بن عمرو بن عاص رضی اللہ تعالیٰ ع"}
{"hadithnumber": "7463", "text": "ابو عبد الرحمان نے کہا : حضرت عبد اللہ بن عمرو بن عاص رضی اللہ تعالیٰ عنہ  کے پاس تین شخص آئے جبکہ م"}
{"hadithnumber": "7498", "text": "عقیل نے زہری سے ، انھوں نے ابن مسیب سے  ، انھوں نے حضرت ابوہریرۃ رضی اللہ تعالیٰ عنہ   سے اور انھوں"}
{"hadithnumber": "7499", "text": "ابن شہاب کے بھتیجے نے اپنے چچاسے ، انھوں نے ابن مسیب سے ، انھوں نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "7512", "text": "ہارون بن معروف اور محمد بن عباد نے ہمیں حدیث بیان کی ، الفاظ دونوں سے ملتے جلتے ہیں جبکہ سیاق ہارون"}
{"hadithnumber": "7513", "text": "( عبادہ بن ولید نے )  کہا : میں نے ان سے کہا : چچاجان!اگر آپ اپنے غلام کی دھاری دار چادر لے لیتے اور"}
{"hadithnumber": "7514", "text": "پھر ہم  ( آگے  ) روانہ ہوئے یہاں تک کہ ہم حضرت جابر بن عبداللہ رضی اللہ تعالیٰ عنہ  کے پاس ان کی مسج"}
{"hadithnumber": "7515", "text": "( جابر رضی اللہ تعالیٰ عنہ   نے کہا ) ہم رسول اللہ  صلی اللہ علیہ وسلم  کے ساتھ وادی بواط کی جنگ میں"}
{"hadithnumber": "7516", "text": "ہم رسول اللہ  صلی اللہ علیہ وسلم  کے ساتھ روانہ ہوئے یہاں تک کہ جب کسی حد تک شام ہوگئی اور ہم عرب کے"}
{"hadithnumber": "7517", "text": "ہم رسول اللہ  صلی اللہ علیہ وسلم  کے ساتھ  ( ایک مہم پرگئے ۔ ہم میں سے ہر شخص کی خوراک روز کی ایک کھ"}
{"hadithnumber": "7518", "text": "ہم رسول اللہ  صلی اللہ علیہ وسلم  کے ساتھ  ( ایک مہم کے لیے )  روانہ ہوئے حتیٰ کہ ہم کشادہ وادی میں"}
{"hadithnumber": "7519", "text": "( حضرت جابر رضی اللہ تعالیٰ عنہ   نے )  کہا : پھر ہم لشکر کے پاس آئے تو رسول اللہ  صلی اللہ علیہ وسل"}
{"hadithnumber": "7555", "text": "سفیان نے اعمش سے انھوں نے ابراہیم سے ، انھوں نے ابو معمر سے اور انھوں نے حضرت  عبداللہ  رضی اللہ تعا"}
{"hadithnumber": "7557", "text": "عبداللہ بن عتبہ نے حضرت عبداللہ بن مسعود رضی اللہ تعالیٰ عنہ   سے ( اس آیت کے متعلق )   روایت کی :"}
