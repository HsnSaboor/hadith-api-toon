{"hadithnumber": "4020", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم جب کوئی نیا کپڑا پہنتے تو قمیص یا"}
{"hadithnumber": "4021", "text": "اس سند سے بھی جریری  سے اسی جیسی حدیث مروی ہے۔"}
{"hadithnumber": "4022", "text": "اس سند سے بھی جریری سے اسی مفہوم کی حدیث مروی ہے  ابوداؤد کہتے ہیں: عبدالوہاب ثقفی نے اس میں ابوسعید"}
{"hadithnumber": "4023", "text": "معاذ بن انس رضی اللہ عنہ روایت کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے کھانا کھا"}
{"hadithnumber": "4024", "text": "ام خالد بنت خالد بن سعید بن عاص رضی اللہ عنہا فرماتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس کچھ"}
{"hadithnumber": "4025", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں  کپڑوں میں رسول اللہ صلی اللہ علیہ وسلم کو سب سے زیادہ قم"}
{"hadithnumber": "4026", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں  رسول اللہ صلی اللہ علیہ وسلم کو قمیص سے زیادہ کوئی اور ک"}
{"hadithnumber": "4027", "text": "اسماء بنت یزید رضی اللہ عنہا کہتی ہیں  رسول اللہ صلی اللہ علیہ وسلم کے قمیص  ( کرتے )  کی آستین پہنچ"}
{"hadithnumber": "4028", "text": "مسور بن مخرمہ رضی اللہ عنہما کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے کچھ قبائیں تقسیم کیں اور مخرم"}
{"hadithnumber": "4029", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  جس نے شہرت اور ناموری کا لباس پہنا اللہ تعالیٰ قیامت کے د"}
{"hadithnumber": "4030", "text": "مسدد کا بیان ہے کہ  ابوعوانہ نے ہم سے بیان کیا ہے کہ آپ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ ا"}
{"hadithnumber": "4031", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے کسی قوم کی"}
{"hadithnumber": "4032", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نکلے، آپ پر ایک سیاہ بالوں"}
{"hadithnumber": "4033", "text": "ابوبردہ رضی اللہ عنہ کہتے ہیں کہ  مجھ سے میرے والد نے کہا: بیٹے! اگر تم ہمیں دیکھتے اور ہم اپنے نبی"}
{"hadithnumber": "4034", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  شاہ ذی یزن ۱؎ نے رسول اللہ صلی اللہ علیہ وسلم کو ایک جوڑا ہدیہ"}
{"hadithnumber": "4035", "text": "اسحاق بن عبداللہ بن حارث کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک جوڑا بیس سے کچھ زائد اونٹن"}
{"hadithnumber": "4036", "text": "ابوبردہ رضی اللہ عنہ کہتے ہیں  میں ام المؤمنین عائشہ رضی اللہ عنہا کے پاس آیا تو انہوں نے یمن کا بنا"}
{"hadithnumber": "4037", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  جب خوارج نکلے تو میں علی رضی اللہ عنہ کے پاس آیا تو آپ ن"}
{"hadithnumber": "4038", "text": "سعد بن عثمان کہتے ہیں کہ  میں نے ایک شخص کو بخارا میں ایک سفید خچر پر سوار دیکھا وہ سیاہ خز ۱؎ کا عم"}
{"hadithnumber": "4039", "text": "عبدالرحمٰن بن غنم اشعری کہتے ہیں  مجھ سے ابوعامر یا ابو مالک نے بیان کیا اور اللہ کی قسم انہوں نے جھ"}
{"hadithnumber": "4040", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے مسجد کے دروازے کے پاس ایک دھا"}
{"hadithnumber": "4041", "text": "اس سند سے بھی عبداللہ بن عمر رضی اللہ عنہما سے یہی واقعہ مروی ہے  لیکن اس میں  دھاری دار ریشمی جوڑے"}
{"hadithnumber": "4042", "text": "ابوعثمان نہدی کہتے ہیں کہ  عمر رضی اللہ عنہ نے عتبہ بن فرقد کو لکھا کہ نبی اکرم صلی اللہ علیہ وسلم ن"}
{"hadithnumber": "4043", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کو ایک ریشمی دھاری دار جوڑا ہدیہ دیا گیا"}
{"hadithnumber": "4044", "text": "علی بن ابی طالب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے قسی  ( ایک ریشمی کپڑا )  ا"}
{"hadithnumber": "4045", "text": "اس سند سے بھی بواسطہ  علی بن ابی طالب رضی اللہ عنہ نبی اکرم صلی اللہ علیہ وسلم سے یہی حدیث مروی ہے ا"}
{"hadithnumber": "4046", "text": "اس سند سے بھی ابراہیم بن عبداللہ سے یہی روایت مروی ہے  اور اس میں یہ اضافہ ہے کہ میں یہ نہیں کہتا کہ"}
{"hadithnumber": "4047", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  روم کے بادشاہ نے نبی اکرم صلی اللہ علیہ وسلم کو سندس  ( ایک با"}
{"hadithnumber": "4048", "text": "عمران بن حصین رضی اللہ عنہما کہتے ہیں کہ  اللہ کے نبی کریم صلی اللہ علیہ وسلم نے فرمایا:  میں سرخ گد"}
{"hadithnumber": "4049", "text": "ابوالحصین ہیثم بن شفی کہتے ہیں کہ  میں اور میرا ایک ساتھی جس کی کنیت ابوعامر تھی اور وہ قبیلہ معافر"}
{"hadithnumber": "4050", "text": "علی رضی اللہ عنہ کہتے ہیں  سرخ گدوں  ( زین پوشوں )  سے منع کیا گیا ہے۔"}
{"hadithnumber": "4051", "text": "علی رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے مجھے سونے کی انگوٹھی سے اور قسی ۱؎ پہننے"}
{"hadithnumber": "4052", "text": "ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک دھاری دار چادر می"}
{"hadithnumber": "4053", "text": "اس سند سے بھی ام المؤمنین عائشہ رضی اللہ عنہا سے  اسی جیسی حدیث مروی ہے اور پہلی روایت زیادہ کامل ہے"}
{"hadithnumber": "4054", "text": "عبداللہ ابوعمر مولی اسماء بنت ابی بکر کا بیان ہے  میں نے ابن عمر رضی اللہ عنہما کو بازار میں ایک شام"}
{"hadithnumber": "4055", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایسے کپڑے سے جو خالص ریش"}
{"hadithnumber": "4056", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے عبدالرحمٰن بن عوف اور زبیر بن عوام رضی"}
{"hadithnumber": "4057", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ریشم لے کر اسے اپنے داہنے ہاتھ میں رکھا"}
{"hadithnumber": "4058", "text": "انس بن مالک رضی اللہ عنہ کا بیان ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کی بیٹی ام کلثوم رضی ا"}
{"hadithnumber": "4059", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  ہم ریشمی کپڑوں کو لڑکوں سے چھین لیتے تھے اور لڑکیوں کو  ( اسے پہنے دی"}
{"hadithnumber": "4060", "text": "قتادہ کہتے ہیں  ہم نے انس بن مالک رضی اللہ عنہ سے پوچھا: رسول اللہ صلی اللہ علیہ وسلم کو کون سا لباس"}
{"hadithnumber": "4061", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم سفید کپڑے پہ"}
{"hadithnumber": "4062", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمارے پاس تشریف لائے آپ نے"}
{"hadithnumber": "4063", "text": "مالک بن نضلۃ الجشمی رضی اللہ عنہ کہتے ہیں  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک معمولی کپڑے می"}
{"hadithnumber": "4064", "text": "زید بن اسلم سے روایت ہے کہ  ابن عمر رضی اللہ عنہما اپنی داڑھی زرد  ( زعفرانی )  رنگ سے رنگتے تھے یہا"}
{"hadithnumber": "4065", "text": "ابورمثہ رضی اللہ عنہ کہتے ہیں کہ  میں اپنے والد کے ساتھ نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا تو می"}
{"hadithnumber": "4066", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ایک گھا"}
{"hadithnumber": "4067", "text": "ہشام بن غاز کہتے ہیں کہ  وہ مضرجہ  ( چادر )  ہوتی ہے جو درمیانی رنگ کی ہو نہ بہت زیادہ لال ہو اور نہ"}
{"hadithnumber": "4068", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے دیکھا، اس"}
{"hadithnumber": "4069", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس سے ایک شخص گزرا جس کے"}
{"hadithnumber": "4070", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ایک سفر میں نکلے آپ ن"}
{"hadithnumber": "4071", "text": "حریث بن ابح سلیحی کہتے ہیں کہ  بنی اسد کی ایک عورت کہتی ہے: میں ایک دن ام المؤمنین زینب رضی اللہ عنہ"}
{"hadithnumber": "4072", "text": "براء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے بال آپ کے دونوں کانوں کی لو تک پہنچتے"}
{"hadithnumber": "4073", "text": "عامر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو منیٰ میں ایک خچر پر خطبہ دیتے"}
{"hadithnumber": "4074", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کے لیے ایک سیاہ چاد"}
{"hadithnumber": "4075", "text": "جابر بن سلیم رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا تو آپ بحالت احتباء"}
{"hadithnumber": "4076", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم فتح کے سال مکہ میں داخل ہوئے اور آپ ا"}
{"hadithnumber": "4077", "text": "حریث رضی اللہ عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو منبر پر دیکھا، آپ کالی پگڑی بان"}
{"hadithnumber": "4078", "text": "محمد بن علی بن رکانہ روایت کرتے ہیں کہ  رکانہ رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے کشتی لڑ"}
{"hadithnumber": "4079", "text": "اہل مدینہ کے ایک شیخ کہتے ہیں  میں نے عبدالرحمٰن بن عوف رضی اللہ عنہ کو کہتے ہوئے سنا کہ رسول اللہ ص"}
{"hadithnumber": "4080", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے دو قسم کے لباس سے منع فرمایا ہے ا"}
{"hadithnumber": "4081", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک کپڑے میں صماء ۱؎ اور احتباء ۲؎ سے"}
{"hadithnumber": "4082", "text": "قرہ رضی اللہ عنہ کہتے ہیں کہ  میں قبیلہ مزینہ کی ایک جماعت کے ساتھ رسول اللہ صلی اللہ علیہ وسلم کے پ"}
{"hadithnumber": "4083", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں  ہم اپنے گھر میں گرمی میں عین دوپہر کے وقت بیٹھے تھے کہ اسی"}
{"hadithnumber": "4084", "text": "ابوجری جابر بن سلیم رضی اللہ عنہ کہتے ہیں کہ  میں نے ایک شخص کو دیکھا کہ لوگ اس کی رائے کو قبول کرتے"}
{"hadithnumber": "4085", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کوئی غرور اور"}
{"hadithnumber": "4086", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص اپنا تہ بند ٹخنوں سے نیچے لٹکائے نماز پڑھ رہا تھا کہ اسی"}
{"hadithnumber": "4087", "text": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تین شخص ایسے ہیں جن سے اللہ"}
{"hadithnumber": "4088", "text": "اس سند سے بھی ابوذر رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے یہی حدیث روایت کی ہے  اور پہلی رو"}
{"hadithnumber": "4089", "text": "قیس بن بشر تغلبی کہتے ہیں کہ  مجھے میرے والد نے خبر دی اور وہ ابوالدرداء رضی اللہ عنہ کے ساتھی تھے،"}
{"hadithnumber": "4090", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ عزوجل کا فرمان ہے:"}
{"hadithnumber": "4091", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  وہ شخص جنت میں د"}
{"hadithnumber": "4092", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا، وہ ایک خوبصورت آد"}
{"hadithnumber": "4093", "text": "عبدالرحمٰن کہتے ہیں  میں نے ابو سعید خدری رضی اللہ عنہ سے تہ بند کے متعلق پوچھا تو وہ کہنے لگے: اچھے"}
{"hadithnumber": "4094", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اسبال: تہ بند  ("}
{"hadithnumber": "4095", "text": "یزید بن ابی سمیہ کہتے ہیں کہ  میں نے ابن عمر رضی اللہ عنہما کو کہتے سنا کہ رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "4096", "text": "عکرمہ کا بیان ہے کہ  انہوں نے ابن عباس رضی اللہ عنہما کو دیکھا کہ وہ تہ بند باندھتے ہیں تو اپنے تہ ب"}
{"hadithnumber": "4097", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے مردوں سے مشابہت کرنے و"}
{"hadithnumber": "4098", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اس مرد پر جو عورتوں کا لباس پہنتا"}
{"hadithnumber": "4099", "text": "ابن ابی ملیکہ کہتے ہیں کہ  ام المؤمنین عائشہ رضی اللہ عنہا سے پوچھا گیا کہ عورت جوتا پہنتی ہے  ( جو"}
{"hadithnumber": "4100", "text": "ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  انہوں نے انصار کی عورتوں کا ذکر کیا تو ان کی تعریف کی"}
{"hadithnumber": "4101", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  جب آیت کریمہ «يدنين عليهن من جلابيبهن»  وہ اپنے اوپر"}
{"hadithnumber": "4102", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  اللہ تعالیٰ ابتدائے اسلام میں ہجرت کرنے والی عورتوں پر"}
{"hadithnumber": "4103", "text": "ابن سرح کہتے ہیں  میں نے اپنے ماموں کی کتاب میں «عقيل عن ابن شهاب» کے طریق سے اسی مفہوم کی روایت دیک"}
{"hadithnumber": "4104", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  اسماء بنت ابی بکر رضی اللہ عنہا رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "4105", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  ام المؤمنین ام سلمہ رضی اللہ عنہا نے رسول اللہ صلی اللہ علیہ وسلم سے"}
{"hadithnumber": "4106", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم فاطمہ رضی اللہ عنہا کے پاس ایک غلام لے کر"}
{"hadithnumber": "4107", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کی ازواج مطہرات کے پاس ایک"}
{"hadithnumber": "4108", "text": "اس سند سے بھی ام المؤمنین عائشہ رضی اللہ عنہا سے  اسی مفہوم کی  ( حدیث )  مروی ہے۔"}
{"hadithnumber": "4109", "text": "اس سند سے بھی ام المؤمنین عائشہ رضی اللہ عنہا سے یہی حدیث مروی ہے  اور اس میں اتنا اضافہ ہے:  آپ صلی"}
{"hadithnumber": "4110", "text": "اوزاعی سے اس واقعہ کے سلسلہ میں مروی ہے کہ  نبی اکرم صلی اللہ علیہ وسلم سے عرض کیا گیا: اللہ کے رسول"}
{"hadithnumber": "4111", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  آیت کریمہ «وقل للمؤمنات يغضضن من أبصارهن»  مسلمان عور"}
{"hadithnumber": "4112", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے پاس تھی، آپ کے پا"}
{"hadithnumber": "4113", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم م"}
{"hadithnumber": "4114", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہا کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم می"}
{"hadithnumber": "4115", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم ان کے پاس تشریف لائے ا"}
{"hadithnumber": "4116", "text": "دحیہ بن خلیفہ کلبی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس کچھ سفید اور باریک"}
{"hadithnumber": "4117", "text": "صفیہ بنت ابی عبید خبر دیتی ہیں کہ  ام المؤمنین ام سلمہ رضی اللہ عنہا نے رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "4118", "text": "اس سند سے بھی  نبی اکرم صلی اللہ علیہ وسلم سے یہی حدیث مرفوعاً مروی ہے۔"}
{"hadithnumber": "4119", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے امہات المؤمنین  ( رضی الل"}
{"hadithnumber": "4120", "text": "ام المؤمنین میمونہ رضی اللہ عنہا کہتی ہیں کہ  میری ایک لونڈی جسے میں نے آزاد کر دیا تھا کو صدقہ کی ا"}
{"hadithnumber": "4121", "text": "اس سند سے بھی زہری سے یہی حدیث مروی ہے  اس میں انہوں نے ام المؤمنین میمونہ رضی اللہ عنہا کا ذکر نہیں"}
{"hadithnumber": "4122", "text": "معمر کہتے ہیں  زہری دباغت کا انکار کرتے تھے اور کہتے تھے: اس سے ہر حال میں فائدہ اٹھایا جا سکتا ہے۔"}
{"hadithnumber": "4123", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جب چ"}
{"hadithnumber": "4124", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے مردار کی کھال سے جب"}
{"hadithnumber": "4125", "text": "سلمہ بن محبق رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم غزوہ تبوک میں ایک گھر میں تشر"}
{"hadithnumber": "4126", "text": "عالیہ بنت سبیع کہتی ہیں کہ  میری کچھ بکریاں احد پہاڑ پر تھیں وہ مرنے لگیں تو میں ام المؤمنین میمونہ"}
{"hadithnumber": "4127", "text": "عبداللہ بن عکیم کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم کا مکتوب جہینہ کی سر زمین میں ہمیں پڑھ کر سنا"}
{"hadithnumber": "4128", "text": "حکم بن عتیبہ سے روایت ہے کہ  وہ اور ان کے ساتھ کچھ اور لوگ عبداللہ بن عکیم کے پاس جو قبیلہ جہینہ کے"}
{"hadithnumber": "4129", "text": "امیر المؤمنین معاویہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ریشمی زینوں"}
{"hadithnumber": "4130", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  فرشتے ایسے لوگوں کے ساتھ"}
{"hadithnumber": "4131", "text": "خالد کہتے ہیں  مقدام بن معدی کرب، عمرو بن اسود اور بنی اسد کے قنسرین کے رہنے والے ایک شخص معاویہ بن"}
{"hadithnumber": "4132", "text": "اسامہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے درندوں کی کھالوں کے استعمال سے منع ف"}
{"hadithnumber": "4133", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے ساتھ ایک سفر میں تھے آپ نے فرمایا:"}
{"hadithnumber": "4134", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے ہر جوتے میں دو تسمے  ( فیتے )  لگے تھے"}
{"hadithnumber": "4135", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے کھڑے ہو کر جوتا پہننے سے منع فرمایا ہ"}
{"hadithnumber": "4136", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی ایک جوتا"}
{"hadithnumber": "4137", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کسی کے ایک جوتے"}
