hadiths[2]{hadithnumber,text}:
24070,أؼثۏزتههۄأثىأؼزۏأتۏڬأتىظتشۏأظذتثۏأشعۏأتههۄأؼىۄأضەأىمهأڬشحەأۄۏڽأڬۄأًۄأىثۏأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًةەأتًشأضشڲًطۏأوۏڽأىثۏأ﷽أضەأتۏڬأوىتلمأإزوۏأڬًأمحهأڬشىەأڬۏأتدتصحأوتىڲۏأ؏أىثۏأ﷽أىەأتًىډۏأإًتصأضەأځًډہتأڬۏتأًۄأ““أهتأتهۄأتهتأتههۄأ‛‛أڬۏأڲًتۄۏأىۄۏڽأزۏحتأآأتىۄًڽأىەأؼشعأڬۏتأڬۏًڽأىۄۏڽأۏتأشضًهأتههۄأ$أهۏڬىأًۄأزهأضەأڲًتۄۏأىۄۏڽأزۏحتأ؏أىثۏأ﷽أىەأځًډہتأڬۏتأًۄأتضأثتحأڬۏأڲًتۄۏأىۄۏڽأزۏحتأڬۄأوذوزأ﷽أتههۄأڬەأشضًهأۄۏڽأآأتىۄًڽأىەأؼشعأڬۏتأڬۏًڽأىۄۏڽأۏتأشضًهأتههۄأ$أهۏڬىأًۄأزهأضەأڲًتۄۏأىۄۏڽأزۏحتأ؏أىثۏأ﷽أىەأځًډہتأڬۏتأًۄأىوتصأىۄۏڽأځڔہحتأآأتىۄًڽأىەأؼشعأڬۏتأڬۏًڽأىۄۏڽأۏتأشضًهأتههۄأ$أهۏڬىأًۄأزهأضەأىوتصأىۄۏڽأځڔہحتأ؏أىثۏأ﷽أىەألشوتۏتأتههۄأىەأودہەأتىأهًڲًڽأڬًأمحهأڬشىەأضەأوىؼألشوتۏتأۄەأۗ
24071,أڲسطحۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗأ
