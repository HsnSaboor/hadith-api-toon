hadiths[198]{hadithnumber,text}:
3349,"ضۏٔزىتأتثىأؼثتضأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أًۄأإزوۏأدضەأڬډہأثہۏأمشإىأۏتزأىۄۏڽأتۏضەأۄەأدۏضەأًۏشتىأوڬتىأۗ‛‛

[تخریج]: !حسن: اخرجہ احمد1/223والترمذی،کتاب ثواب القران،با الذی لیس فی جوقہ قرآن کالبیت الخرب (2914) والحاکم فی المستدرک1/554"
3350,"ؼثزتههۄأضەأوشًۏأۄەأڬۄأتىۄًڽأىەأڬۄتأ=““أۏۄأمشإىأتههۄأڬۏأزؼًحأۄەأدضأمزشأۄًأضڬەأتضأوۏڽأضەأهًأتًشأوۏشەأرۏتهأوۏڽأتضأڲہشأضەأذمۏشأڬًةۏأډۏصأىۄۏڽأدضأوۏڽأڬډہأمشإىأىۄأۄًأتًشأًۄأزهأدضأوۏڽأمشإىأڬتأڬډہأذظۄأىۄأۄًأًۄأًۏشتىأوڬتىأڬۏأغشذأًۏشتىأۄەأدضەأڬًةۏأإثتزأڬشىەأًتهتأىۄۏڽأۗ‛‛

[تخریج]: ! صحیح: أخرجہ ابن ابی شیبہ10/486(10081) وعبدالرزاق(5998) والطبرانی فی الکبیر9/183(8642)"
3351,"تثًتذًظأڬۄحەأۄۏڽأؼثزتههۄأىەأڬۄتأ=““أمشإىأځڔہىتأضۏڬہًأڬۏًىڬۄأحوۄۏڽأتضأڬەأځڔہىەأوۏڽأۄشأذشلأڬەأثزهۄأوۏڽأزضأىۏڬۏتڽأۄًڽأڲۏأثهڬۄأتهلأ‛أهتوأ‛أتًشأوۏوأۄشأذشلأڬەأثزهۄأزضأىۏڬۏتڽأوهۏڽأڲۏأۗ‛‛

[تخریج]: @ صحیح: أخرجہ الطبرانی فی الکبیر(8649-8648) وعبدالرزاق(5993) وابن ابی شیبہ10/361(9981)"
3352,"ثەأطڬأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأحہەأڬۄأ=““أمشإىأځڔہىەأڬۏأًدۄأضەأڲہشأتضأڬەأتۄهأڬەأهةەأڬطتزۄأۄًأدتحتأۄەأتًشأتضأوۏڽألشطحەأذتعشأۄًحەأۄۏڽأ‛أطۏغتىأتضأڲہشأڬًأډہًڔأزۏحەأۄۏڽأتًشأتضأڬۏأرۏشأًأثشڬحأثڔہأدتحۏأۄەأتًشأمشإىأىۄأځڔہىەأڬۏأًدۄأضەأڲہشأتضأڬەأتۄهأڬەأهةەأحىڲأۄًأدتحتأۄەألشطحەأتضەأډہًڔأزۏحەأۄۏڽأتًشأطۏغتىأتضأوۏڽأثضۏشتأڬشأهۏحەأۄۏڽأتضأڬۏأرۏشأًأثشڬحأڬوأۄًأدتحۏأۄەأۗ‛‛

[تخریج]: # صحیح: أخرجہ ابن ابی شیبہ10/487(10076) وابن المبارک فی الزہد(790)"
3353,"ؼمثۄأثىأؼتوشأڬۄحەأۄۏڽأوۏڽأىەأشضًهأتههۄأ﷽أضەأضىتألشوتحەأحہەأ=““أتڲشأمشإىأډوڔەأوۏڽأشڬہأڬشأإڲأوۏڽأڋتهتأدتةەأحًأدهەأڲتأىۄۏڽأۗ‛‛

[تخریج]: !ضعیف: أخرجہ الطبرانی فی الکبیر17/308(850) والبیہقی فی شعب الإیمان(2699) وابن عدی فی الکامل 6/246"
3354,"تثًظتهذأڬۄحەأۄۏڽأوۏڽأىەأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأضىتأڬۄحەأحہەأ=““أمشإىأځڔہًأًۄأمۏتوحأڬەأزىأثۄحأتډہتأضلتشطۏأۄًأڲتأ‛أتًشأمۏتوحأڬەأزىأڬۄەأڲتأ=أتەأوۏشەأشثأ$أتضەأؼصحأڬتأصۏًشأځۄىتأۗأحًأتضەأؼصحأڬتأصۏًشأځۄىتۏتأدتةەأڲتأتەأوۏشەأشثأ$أتضەأؼصحأڬتأهثتضأځۄىتأتضەأؼصحأڬتأهثتضأځۄىتۏتأدتةەأڲتأۗأتەأوۏشەأشثأ$أتضەأؼصحأڬتأحتدأځۄىتأۗأتەأوۏشەأشثأ$أتضأضەأشتعۏأۄًأدتأڬۏًىڬۄأحۏشۏأشعتوىزۏأڬەأثؼزأڬضۏأډۏصأڬۏأذمۏمحأىۄۏڽأۗ‛‛

[تخریج]: @حسن: أخرجہ الترمذی،کتاب ثواب القرآن،باب الذی لیس فی جوفہ قران…(2916) والحاکم1/552والبیہقی فی شعب الإیمان(1997-1996)"
3355,"تثىأؼوشأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتىۄًڽأىەأڬۄتأ=““أمشإىأإأڬشأتځىەأځڔہىەأًتهەأڬۏأضلتشطأڬشەأڲتأڬۄەأڲتأ=““أتەأوۏشەأشثأ$أۄشأڬتوأڬشىەأًتهەأڬەأهةەأتضأڬەأڬتوأڬۏأوصزًشۏأۄەأوۏشۏأًدۄأضەأتضأڬۏأهسحأتًشأىۏىزأوۏڽأرههأإحتأحہتأهۄٳستأتضەأؼصحأزەأۗأڬۄتأدتةەأڲتأ=أتځىتأزتۏتڽأۄتحہأځہۏهتأ‛أحًأًۄأتههۄأڬۏأشعتأضەأثہشأزۏتأدتةەأڲتأۗأځہشأڬۄتأدتةەأڲتأتځىتأثتۏتڽأۄتحہأځہۏهتأ‛أحًأًۄأثہۏأتههۄأڬۏأشعتأضەأثہشأزۏتأدتةەأڲتأۗأتًشأؼصحأڬتأهثتضأځۄىتۏتأدتةەأڲتأۗأتًشأؼصحأڬتأصۏًشأځۄىتۏتأدتةەأڲتأۗأتًشأؼصحأڬتأحتدأځۄىتۏتأدتةەأڲتأۗ‛‛

[تخریج]: !حسن: أخرجہ ابن ابی شیبہ 10/497-496(10099-10098) وابن منصور1/113(22)"
3356,"تثًظتهذألشوتحەأۄۏڽأڬۄأ=““أمشإىأتځىەأظتذثأڬۏأضلتشطأڬشەأڲتأحًأتضەأؼصحأڬتأهثتضأځۄىتۏتأدتةەأڲتأۗأځہشأًۄأڬۄەأڲتأ=أتەأوۏشەأشثأ$أتضأڬًأصۏتزۄأزەأځہشأتضەأؼصحأڬتأحتدأځۄىتۏتأدتةەأڲتأۗأځہشأًۄأڬۄەأڲتأتەأوۏشەأشثأ$أتضەأصۏتزۄأتًشأتضأڬًأزۏحتأشۄأۗأحًأتههۄأحؼتهۏٳألشوتةەأڲتأ=““أوۏڽأتضەأتځىۏأشعتوىزۏأزۏحتأۄًڽأۗ‛‛أتثًوذوزأڬۄحەأۄۏڽأ=أًۄۏثأثىأًشزأىەأڬۄتأ=““أمشإىأڬۏأحهتًحأڬًأؼهوأثىتاأتًشأؼوهأوحأثىتاأۗ‛‛

[تخریج]: @جید: أخرجہ ابن ابی شیبہ10/495(10097)"
3357,"تثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أڬۏتأحوأوۏڽأضەأڬًةۏأتضأثتحأڬًأځضىزأڬشحتأۄەأڬۄأدثأًۄأتځىەأڲہشأإةەأحًأحۏىأتًىټىۏتڽأثډًڽأًتهۏأوًټۏأحتصۏأځتةەأۗأهًڲًڽأىەأڬۄتأ=أدۏأۄتڽأ‛أشضًهأتههۄأ$أإځأىەألشوتۏتأ=““أحۏىأإۏتحأتڲشأحوأځڔہأهًأحًأًۄأتىأضەأثۄحشأۄۏڽأۗ‛‛

[تخریج]: ! صحیح: أخرجہ مسلم،کتاب صلاۃ المسافرین،باب فضل قراۃ القران وتعلمہ(872)وابن ماجہ،کتاب الأدب،باب ثواب القران(8782 )"
3358,"تثًتذًظأڬۄحەأۄۏڽأؼثزتههۄأىەأڬۄتأ=““أمشإىأتههۄأڬۏأزؼًحأۄەأهۄٳستأدضأمزشأۄًأضڬەأتضأڬۏأزؼًحأضەأؼهوأذتظهأڬشأهًأۗأتًشأۏۄأمشإىأتههۄأڬۏأشضۏأۄەأشًطىأىًشأتًشألتةزۄأوىزأطلتأۄەأتضأطرظأڬەأهةەأذلتػحأڬتأثتؼخأۄەأدًأتضأځشأؼوهأڬشەأتًشأتضأطرظأڬەأهۏەأىدتحأڬتأثتؼخأۄەأدًأتضأڬۏأحتثؼزتشۏأڬشەأۗأىۄأټۏڔہتأۄًأڬۄأًۄأوؼتلۏأغهثأڬشەأىۄأټۏڔہتأۄًأڲتأڬۄأضۏزہتأڬۏتأدتةەأۗأتًشأتضأڬەأؼدتةثأرحوأىۄۏڽأۄًڽأڲەأۗأڬخشحأحڬشتشأڬەأثتًدًزأځشتىتأىۄۏڽأۄًأڲتأۗأهۄٳستأحوأتضەأځڔہًأڬۏًىڬۄأتضأڬۏأحهتًحأځشأتههۄأحؼتهۏٳأحوۄۏڽأۄشأذشلأځشأزضأىۏڬۏتڽأزەأڲتأۗأۏتزأشڬہًأوۏڽأۏۄأىۄۏڽأڬۄحتأڬۄأ®أتهوأ¾أڬەأثزهۄأزضأىۏڬۏتڽأۄۏڽأثهڬۄأتهلأ‛أهتوأتًشأوۏوأۄشأذشلأڬەأثزهۄأزضأىۏڬۏتڽأۄۏڽأۗ‛‛

[تخریج]: @ضعیف: ابراہیم ہجری ضعیف ہیں۔أخرجہ عبدالرزاق(6017)والبیہقی فی شعب الإیمان(1980) والحاکم 1/555"
3359,"صۏزأثىأتشموأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أرغثۄأزۏىەأڬەأهةەأڬہڔەأۄًةەأ‛أتههۄأڬۏأذوزأًأخىتؤأثۏتىأڬۏأځہشألشوتۏتأ=““أتەأهًڲًأ$أوۏڽأثہۏأإزوۏأۄًڽأمشۏثأۄەأڬۄأوۏشەأشثأڬتأمتظزأوۏشەأځتضأإةەأتًشأوۏڽأتضەأمثًهأڬشأهًڽأوۏڽأحوۄتشەأتىزشأزًأثہتشۏأډۏصۏڽأډہًڔحتأۄًڽأځۄهۏأډۏصأمشإىأۄەأتضأوۏڽأۄزتۏحأتًشأىًشأۄەأهۄٳستأحوأمشإىأڬًأوعثًغۏأضەأحہتوأهًأتًشأتضۏأڬًأترحۏتشأڬشًأۗأځہشأإځأىەأتضأڬەأوحؼهمأشؽثحأتًشأرًتۄطأزهتةۏأۗأځہشأإځأىەألشوتۏتأ=““أزًضشۏأډۏصأوۏشەأتۄهأثۏحأۄۏڽأوۏڽأحوۄۏڽأتځىەأتۄهأثۏحأڬەأوحؼهمأتههۄأڬتأًتضغۄأزهتحتأۄًڽأتضأغشذأإځأىەأحۏىأزلؼۄألشوتۏتأۗ‛‛

[تخریج]: ! صحیح: أخرجہ احمد4/367-366 ومسلم،کتاب فضائل الصحابہ،باب فضائل علی بن ابی طالب(2408)"
3360,"تثًًتةهأڬۄحەأۄۏڽأڬۄأؼثزتههۄأىەأڬۄتأ=““أۏۄأشتضحۄأوًدًزڲۏأڬۏأدڲۄأۄەأدۄتڽأطۏغتىأوًدًزأۄًحەأۄۏڽأًۄأځڬتشحەأۄۏڽأ=““أتەأتههۄأڬەأثىزەأ$أتضأشتضحۄأځشأإأ‛أهۄٳستأحوأتههۄأڬۏأشضۏأڬًأوعثًغۏأضەأحہتوأهًأتًشأتههۄأڬۏأشضۏأمشإىأۄەأۗ‛‛

[تخریج]: @صحیح: أخرجہ البیہقی فی شعب الإیمان(2025) والطبرانی فی الکبیر9/340(9031) وابن منصور 3/1083 (519)"
3361,"رتهزأثىأوؼزتىأضەأوشًۏأۄەأڬۄأتىۄًڽأتىأىەأڬۄتأ=““أمشإىأځڔہىەأًتهەأتًشأغتهثأؼهوأڬەأهةەألشطحەأثرططأڬۏأزؼتأڬشحەأشۄحەأۄۏڽأۗأذحۏأڬۄأًۄأضًشۆأرحوأڬشەأدثأحوأوۏڽأضەأڬًةۏأضًشۆأځڔہەأحًأتضأوۏڽأضەأزًأإۏتحأڬۏأحترۏشأڬشەأذحۏأڬۄأطتوأڬًأرحوأڬشەأۗأحتڬۄأځڔہىەأتًشأځڔہتىەأًتهەأڬەأهةەألشطحەأظثذأضەأطتوأحڬأثرططأڬۏأزؼتأڬشحەأشۄۏڽأۗ‛‛

[تخریج]: ! جید: أخرجہ ابن ابی شیبہ10/505(10128)"
3362,"تثًتوتوۄأضەأشًتۏحأۄەأۏمۏىتَأإځأڬۄحەأحہەأ=““أمشإىأځڔہًأ$أتًشأتىأهټڬەأۄًةەأمشإىًڽأڬەأزہًڬۄأوۏڽأىۄأشۄًأڬۏًىڬۄأتههۄأحؼتهۏٳأتضأزهأڬًأؼستثأىۄۏڽأڬشەأڲتأدضأىەأمشإىأۏتزأڬۏتأۄًأڲتأۗ‛‛

[تخریج]: @صحیح: أخرجہ ابن ابی شیبہ11/505(10128)"
3363,"تثًتوتوۄأضەأشًتۏحأۄەأۏمۏىتَأإځأڬۄحەأحہەأ=““أمشإىأځڔہًأتًشأتىأهټڬەأۄًةەأمشإىًڽأڬەأزہًڬۄأوۏڽأىۄأشۄًأۗأڬۏًىڬۄأتههۄأحؼتهۏٳأتضأزهأڬًأؼستثأىۄۏڽأڬشەأڲتأدضەأمشإىأۏتزأۄًأڲتأۗ‛‛

[تخریج]: !صحیح: سابقہ حدیث ہی مکرر آئی ہے۔"
3364,"تثىأوضؼًزأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتىۄًڽأىەأڬۄتأ=““أڬًةۏأتزثأضڬہتىەأًتهتأىۄۏڽأدًأتضأثتحأڬًأىتځضىزأڬشحتأۄًأڬۄأتضأڬەأتزثأځشأؼوهأڬۏتأدتةەأۗأتههۄأڬتأتزثأمشإىأۄەأۗ‛‛

[تخریج]: @ صحیح: یہ (3350) حدیث کی ایک طرف ہے۔"
3365,"ؼثزتههۄأڬۄحەأحہەأڬۄأ=““أۏۄأمشإىأتههۄأڬۏأزؼًحأۄەأ‛أدًأطرظأتضأوۏڽأزترهأۄًتأوذلًػأۄًأڲۏتأۗ‛‛

[تخریج]: # صحیح: سابقہ (3350) کا ایک کنارہ ہے۔"
3366,"ؼثزتههۄأضەأوشًۏأۄەأڬۄأتىۄًڽأىەأڬۄتأ=““أدضأڬًأمشإىأضەأوذثحأۄًأًۄأرًطأۄًأدتةەأۗ‛‛

[تخریج]: $ صحیح: أخرجہ ابن ابی شیبہ10/406(10129) وابن منصور1/12(3)"
3367,"ؼثزتههۄأضەأوشًۏأۄەأڬۄأتىۄًڽأىەأڬۄتأ=““أدضأڬًأمشإىأضەأوذثحأۄًأتضەأډتۄةەأڬۄأرًطأۄًأدتةەأۗ‛‛

[تخریج]: %صحیح: سابقہ حدیث ہی مکرر منقول ہے۔"
3368,"ۏمۏىتَأتثىأوضؼًزأشعۏأتههۄأؼىۄأڬۄحەأحہەأ=““أمشإىأمۏتوحأڬەأزىأإأڬشأتځىەأظتذثأڬۏأضلتشطأڬشەأڲتأتًشأتضەأدىحأڬۏأغشلأڬہۏىډأڬشأهەأدتةەأڲتأۗأتًشأتضأڬەأرهتلأڲًتۄۏأزەأڲتأتضەأزًصرأڬۏأغشلأۄتىڬأڬشأهەأدتةەأڲتأۗ‛‛

[تخریج]: ! حسن: أخرجہ ابن ابی شیبہ10/497(10102) وابن الضر یس فی فضائل القرآن (108)"
3369,"تىضأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أڬډہأهًڲأتههۄأڬەأهًڲأۄۏڽأځًډہتأڲۏتأ=أۏتأشضًهأتههۄأ$أًۄأڬًىأۄۏڽأآألشوتۏتأ=““أمشإىأځڔہىەأًتهەأۗ‛‛

[تخریج]: @ صحیح: أخرجہ ابن ماجہ فی المقدمۃ،باب فضل من تعلم القران وعلمہ(215) والحاکم/وابونعیم فی الحلیۃ9/40"
3370,"وؽۏخأڬۄحەأۄۏڽأڬؼثأىەأڬۄتأ=““أمشإىأڬًأهتصوأځڬڔًأڬۏًىڬۄأمشإىأؼمهأڬۏأحۏصۏأتًشأذڬوحأڬۏأشًطىۏأتًشأؼهوأڬتأډطوۄأۄەأۗأتًشأحوتوأڬحتثًڽأثۄأىضثحأتههۄأضەأىةۏأڬحتثأۄەأۗأتههۄأحؼتهۏٳأىەأحًشتحأوۏڽألشوتۏتأ=““أتەأوذوزأ$أوۏڽأحۏشەأځتضأىةۏأحًشتحأثہۏدحتأۄًڽأ‛أدًأتىزہۏأإىڬہًڽأثۄشەأڬتىًڽأتًشأثىزأزهًڽأڬًأڬہًهأزەأڲۏأۗ‛‛

[تخریج]: # حسن: أخرجہ ابو عبید فی فضائل القرآن(ص77)وابن ابی شیبہ11/481(11787)"
3371,"تثًڬىتىۄأڬۄحەأۄۏڽأتثًوًضۏٳأىەأڬۄتأ=““أمشإىأحوۄتشەأهةەأخًتثأڬتأثتؼخأتًشأسڬشأڬتأثتؼخأۄەأشًطىۏأ‛أتًشأؼستثأڬتأثتؼخأثہۏأۄەأ‛أمشإىأڬۏألشوتىثشزتشۏأڬشًأ‛أتضأڬًأتځىتألشوتىثشزتشأىۄأثىتاأۗأڬۏًىڬۄأدًأمشإىأڬۏألشوتىثشزتشۏأڬشەأڲتأًۄأدىحأڬەأثتؽًڽأوۏڽأتحتشتأدتةەأڲتأۗأتًشأدًأتضەألشوتىثشزتشأثىتةەأڲتأًۄأضشأڬەأثهأزہڬۏهأڬشأدۄىوأوۏڽأڋتهتأدتةەأڲتأۗ‛‛

[تخریج]: ! صحیح: ابو کنانہ شرط ابن حبان پر ہے۔ أخرجہ ابن ابی شیبہ10/484(10063)وابن منصور 1/49 (8) والبیہقی فی شعب الإیمان(2024-2023)"
3372,"تۏتضأثىأؼتوشأڬۄحەأحہەأڬۄأؼهۏأثىأتثًغتهثأشعۏأتههۄأؼىۄأىەأوۏشتأۄتحہأځڬڔأڬشأڬۄتأتڲشأحوأصىزۄأشۄەأحًأزۏڬہًأڲەأمشإىأڬًأحۏىأمضوأڬەأهًڲأځڔہۏڽأڲەأۗأتۏڬأتههۄأڬەأهۏەأ؏أزًضشەأدہڲڔىەأڬەأهۏەأ؏أتًشأحۏضشەأزىۏتأڬەأهۏەأتًشأتضأڬەأسشۏؼۄأضەأدًأحهتطأڬۏتأدتةەأڲتأًۄۏأوهەأڲتأۗ‛‛

[تخریج]: @ صحیح: (مسند علی)(734)"
3373,"تثًمهتثۄأضەأوشًۏأۄەأڬۄأتۏڬأإزوۏأىەأتثًزشزتؤأضەأڬۄتأ=““أتۄهأڬًلۄأضەأإځأڬەأتۄهأسڬشأثہتةۏأإځأڬًأضهتوأڬۄحەأۄۏڽأحًأتىۄًڽأىەأڬۄتأ=““أتىأځشأثہۏأضهتوأۄًأتًشأتىأضەأڬۄًأتځىۏأىڬۏهأمشإىأڬەأذًتهۄأڬشأزۏڽأ؏أڬۏًىڬۄأًۄأتىۄۏڽأوۏتىۄأشًۏأتًشأإضتىۏأضڬہتةەأڲتأۗأتًشأػهوأًأضرحۏأضەأثډتةەأڲتأۗ‛‛

[تخریج]: ! منقطع ضعیف: أخرجہ ابن ابی شیبہ10/527(10211)وعبدالرزاق(5996)"
3374,"ذتشخأڬۄحەأۄۏڽأوۏڽأوضدزأوۏڽأڲۏتأحًأهًڲأًۄتڽأثتحًڽأوۏڽأوطؽًهأحہەأۗأوۏڽأىەأؼهۏأشعۏأتههۄأؼىۄأضەأڬۄتأ=أإځأزۏڬہحەأىۄۏڽأڬۄأهًڲأوضدزأوۏڽأثتحۏڽأڬشأشۄەأۄۏڽأتىۄًڽأىەأڬۄتأ=أڬۏتأًۄأتۏضتأڬشحەأۄۏڽأآأوۏڽأىەأڬۄتأ=““أدۏأۄتڽأۗ‛‛أحًأتىۄًڽأىەأڬۄتأ=““أوۏڽأىەأشضًهأتههۄأ﷽أضەأضىتأإځألشوتحەأحہەأ=أؼىمشۏثأۄۏأثۄحأضەألحىەأۄًڽأڲەأۗأوۏڽأىەأڬۄتأ=أتىأضەأڬۏضەأثډتأدتةەأڲتأآألشوتۏتأ=أمشإىأضەأ‛أتضأوۏڽأحوۄتشەأثؼزأڬۏأتًشأځۄهەأڬۏأرثشأۄەأتًشأحوۄتشەأًتمؼتحأڬتألۏظهۄأۄەأۗأًۄألۏظهۄأڬىأۄەأوستمأىۄۏڽأۄەأۗأدًأدتثشأتضەأحشڬأڬشأزەأڲتأتههۄأتضەأحًڔەأڲتأۗأتًشأدًأتضەأډہًڔأڬشأڬۄۏڽأتًشأۄزتۏحأحهتطأڬشەأڲتأتههۄأحؼتهۏٳأتضەأڲوشتۄأڬشأزەأڲتأۗأًۄأتههۄأڬۏأوعثًغأشضۏأۄەأتًشأًۄأسڬشأذڬۏوأۄەأۗأتًشأًۄۏأضۏزہتأشتضحۄأۄەأۗأۏۄأًۄأۄەأدضأضەأرًتۄطتحأټۏڔہۏأىۄۏڽأۄًحۏڽأۗأتضأضەأصثتىۏڽأرهغأوهغأىۄۏڽأۄًحۏڽأۗأؼهوتؤأتضأضەأضۏشأىۄۏڽأۄًحەأڬخشحأحڬشتشأڬەأثتًدًزأځشتىتأىۄۏڽأۄًحتأۗأتضأڬەأؼدتةثتحأرحوأىۄۏڽأۄًحەأۗأۏۄأًۄأۄەأڬۄأدثأتضەأدىًڽأىەأضىتأحًأۏۄأثتحأڬۄەأثؽۏشأىۄأشۄأضڬەأڬۄأ=““أۄوأىەأحًأتۏڬأؼدثأمشإىأضىتأۄەأۗ‛‛أ+أضًشۆأتهدىأ=أ5أ,أۏۄأًۄأتذڬتوأڬۏأڬحتثأۄەأڬۄأدضأىەأتضأڬەأوغتثمأثتحأڬۏأتضأىەأضډأڬۄتأدضأىەأتضأڬەأسشۏؼۄألۏظهۄأڬۏتأتضأىەأؼزهأڬۏتأۗأدضأىەأتضأځشأؼوهأڬۏتأتدشأځتۏتأۗأدضأىەأتضأڬۏأغشلأثهتۏتأتضەأضۏزہتأشتضحۄأزڬہتۏتأڲۏتأۗأتەأتؼًشأ$أتىأثتحًڽأڬًأۏتزأشڬہأۗ‛‛

[تخریج]: ! ضعیف: اس میں ابو مختار اور ابن أخی الحارث مجہول ہیں۔ أخرجہ ابن ابی شیبہ 10/482 (10056) والترمذی، کتاب ثواب القران،باب ماجاء فی فضل القران(2908)والبیہقی فی شعب(1935)"
3375,"ضۏٔزىتأؼهۏأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأڬۄتأڲۏتأ=““أۏتأشضًهأتههۄأ$أإځأ﷽أڬەأثؼزأإځأڬۏأتوحألحىۄأوۏڽأځڔأدتةەأڲۏأۗأځہشأشضًهأتههۄأ﷽أضەأځًډہتأڲۏتأتضأضەأڬًىضۏأډۏصأثډتةەأڲۏأآأحًأإځأىەألشوتۏتأ=““أڬحتثأؼصۏصأ‛أدضأوۏڽأثتهڬهأۄۏأدہًټأىۄۏڽأىۄأإڲەأىۄأځۏډہەأًۄأذڬوحأتًشأحؼشۏلأًتهەأڬۏأغشلأضەأىتصهأطزۄأۄەأۗ‛‛أ+أضًشۆألظهحأ=أ75أ,أدًأتضأڬەأؼهتًۄأۄزتۏحأحهتطأڬشەأتضەأتههۄأحؼتهۏٳأڲوشتۄأڬشأزۏحتأۄەأتًشأدًأضشڬطأطرظأتضأڬەأؼهتًۄأڬضۏأتًشأډۏصأضەألۏظهۄأڬشەأتههۄأتضەأۄهتڬأڬشەأڲتأۗأًۄأسڬشأذڬۏوأۄەأۗأًتعذأىًشأۄەأۗأضۏزہتأشتضحۄأۄەأۗأتضأوۏڽأحوۄتشەأضەأځۄهەأتًشأثؼزأًتهًڽأڬۏأرثشۏڽأۄۏڽأتًشأحوۄتشەأإځضأڬەأوؼتوهۄأڬتألۏظهۄأۄەأۗأًۄألۏظهۄأڬىأثتحأۄەأوستمأىۄۏڽأۄەأۗأۏۄأًۄأۄەأدضەأدثأدىًڽأىەأضىتأحًأۏۄأڬۄەأثؽۏشأىۄأشۄأضڬەأڬۄأ=““أۄوأىەأؼدۏثأمشإىأضىتأۄەأدًأۄزتۏحأڬۏأغشلأشۄىوتةۏأڬشحتأۄەأۗ‛‛أ+أدىأ=أ4أ,أتًشأۏۄأڬخشحأحڬشتشأضەأځشتىتأىۄۏڽأۄًحتأۗأتضأڬۏأىظۏذحۏڽأتًشأتضأڬەأؼدتةثتحأرحوأىۄۏڽأۄًحەأۗأځہشأؼهۏأشعۏأتههۄأؼىۄأىەأذتشخأشعۏأتههۄأؼىۄأضەأڬۄتأ=““أتەأتؼًشأ$أتضەأۏتزأشڬہًأۗ‛‛

[تخریج]: ! حسن: أخرجہ الخطیب فی الفقیہ والمتفقہ1/55والرازی فی فضائل القران(35)"
3376,"تثشتۄۏوأضەأوشًۏأۄەأڬۄأإځأىەألشوتۏتأ=““أدًأذڬوحأزۏتأڲۏتأًۄأرۏشأڬخۏشأځتأڲۏتأۗ‛‛أ+أضًشۆأتهثمشۆأ=أ59<أ,أإۏحأڬۏأحلضۏشأڬشحەأۄًةەألشوتۏتأ=““أذڬوحأضەأوشتزألۄوأمشإىأۄەأۗ‛‛

[تخریج]: @ ضعیف: أخرجہ الطبری فی التفسیر3/90"
3377,"تثىأتثًىدۏذأڬۄحەأۄۏڽأڬۄأودتۄزأىەأ=““أ®ۏًْٕٗحٓۏٕأتهٕذٓڬٕوّۆٓأوّىٕأۏّٔطّتٖؤْ¾أ‛‛أڬۏأحلضۏشأوۏڽأڬۄتأ=““أتههۄأدضەأډتۄحتأۄەأمشإىأڬۏأټہۏڬأضودہأؼغتأڬشحتأۄەأۗ‛‛

[تخریج]: # صحیح: أخرجہ ابن ابی شیبہ7/231(3009)والطبری فی التفسیر3/90"
3378,"تؼوطأڬۄحەأۄۏڽأرۏخوۄأىەأتځىۏأثۏًۏأضەأڬۄتأ=““أوۏشەأڲہشأوۏڽأتۏضەأإزوۏأڬًأزترهأڬشىەأ+أتدتصحأزۏىەأ,أضەأثډىتأدًأطشتثأځۏحتأۄًأذتهتىڬۄأځۄهەأًۄتڽأمشإىأځڔہتأدتحتأحہتأۗ‛‛

[تخریج]: ! صحیح: أخرجہ الفسوی فی المعرقۃ والتاریخ3/143وابونعیم فی الحلیۃ4/115"
3379,"ومضوأڬۄحەأۄۏڽأڬۄأتثىأؼثتضأشعۏأتههۄأؼىۄأىەألشوتۏتأ=““أحوۄۏڽأتضأثتحأضەأڬًىأضۏأډۏصأشًڬحۏأۄەأڬۄأدثأثتصتشأضەأۏتأڬضۏأذتدحأضەأهًټًأحًأمشإىأڬۏأحۏىأإۏتحأځڔہأهۏتأڬشًأۗ‛‛

[تخریج]: @ صحیح: أخرجہ ابن المبارک فی الزہد(807)وابن عدی فی الکامل1/249والطبرانی فی الکبیر 11//398 والبیہقی فی شعب (2198-2003)"
3380,"ضۏٔزىتأؼهۏأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أحوأوۏڽأضەأثۄحشأًۄأۄەأ‛أدًأمشإىأضۏڬہەأتًشأضڬہتةەأۗ‛‛

[تخریج]: # صحیح: أخرجہ الترمذی،کتاب ثواب القران،باب فی تعلیم القرآن وابن ابی شیبہ10/503(10121)والخطیب فی تاریخ 10/459"
3381,"ضۏٔزىتأؼخوتىأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأىثۏأ﷽أىەألشوتۏتأ=““أحوأوۏڽأضەأثۄحشأًۄأۄەأدًأمشإىأضۏڬہحتأۄەأۏتأضڬہتحتأۄەأۗأتثًؼثزتهشذوىأىەأؼخوتىأشعۏأتههۄأؼىۄأڬۏأرهتلحأضەأذدتدأڬەأصوتىۄأحڬأمشإىأځڔہتۏتأتًشأڬۄتأ=““أودہەأتضأذزۏخأىەأتضأدڲۄأثټہتۏتأۗ‛‛

[تخریج]: !صحیح: أخرجہ النسائی فی فضائل القران(62-61)والبیہقی فی شعب(2206-2205)"
3382,"وظؼثأثىأضؼزأتځىەأًتهزأضەأىمهأڬشحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أحوأوۏڽأضەأثۄحشأًۄأۄەأدًأمشإىأضۏڬہحتأتًشأضڬہتحتأۄەأۗ‛‛أشتًۏأڬۄحتأۄەأ=““أتىۄًڽأىەأوۏشتأۄتحہأځڬڔأڬشأتضأدڲۄأثټہتأزۏتأحتڬۄأوۏڽأځڔہتاڽأۗ

[تخریج]: @صحیح بالشاہد: أخرجہ ابن منصور1/103(20)"
3383,"ضؼزأثىأؼثتزۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدًأإزوۏأمشإىأځڔہىەأڬەأثؼزأتضەأثہًهأدتةەأۗأًۄأمۏتوحأڬەأزىأتههۄأحؼتهۏٳأضەأڬًڔہۏأڬۏأذتهحأوۏڽأوهەأڲتأۗ‛‛أتثًوذوزأڬۄحەأۄۏڽأ=““أؼۏضۏٳأۗألتةزأڬەأثۏټەأۄۏڽأۗ‛‛

[تخریج]: #ضعیف: أخرجہ احمد5/285وابوداؤد،کتاب الصلاۃ،باب التشدید فیمن حفظ القران ثم نسیہ(1474)وابن ابی شیبہ 10/74(1044)"
3384,"ىتدۏۄأثىأؼثزتههۄأثىأؼحثۄأتځىەأًتهزأضەأىمهأڬشحەأۄۏڽأڬۄأؼثزتههۄأىەأڬۄتأ=““أڬخشحأضەأمشإىأڬۏأحهتًحأڬۏتأڬشًأتضأضەأځۄهەأڬۄأًۄأتټہتأهۏتأدتةەأۗ‛‛أهًڲًڽأىەأڬۄتأ=““أۏۄأوظذلأحًأتټہتأهةەأدتةۏڽأڲەأوڲشأضۏىًڽأضەأمشإىأڬۏضەأرحوأۄًأڲتأآأتىۄًڽأىەأڬۄتأ=““أشتحأڬًأهًڲأمشإىأځڔہۏڽأتًشأظثذأتىۄۏڽأڬډہأثہۏأۏتزأىۄۏڽأشۄەأڲتأتًشأًۄأڬهوۄأهتأتهۄأتهتأتههۄأځڔہىتأثہۏأثہًهأدتةۏڽأڲەأ‛أدتۄهۏحأڬۏأثتحًڽأتًشأطؼشًڽأوۏڽأځڔأدتةۏڽأڲەأۗأۏۄأتضأًمحأۄًأڲتأدثأتههۄأڬەأؼستثأڬتأًؼزۄأإأدتةەأڲتأۗ‛‛

[تخریج]: ! صحیح:أخرجہ ا بن منصور2/335(97)والحاکم4/504وعبدالرزاق(5981)والطبرانی فی الکبیر 9/153 (8698)"
3385,"تثىأتثًوغۏؼأڬۄحەأۄۏڽأڬۄأمحتزۄأشعۏأتههۄأؼىۄألشوتحەأحہەأ=““أمشإىأضەأتځىەأزهًڽأتًشأڲہشًڽأڬًأإثتزأشڬہًأۗ‛‛

[تخریج]: @ ضعیف:سلام کی قتادہ سے روایت متکلم فیہ ہے۔"
3386,"تثىأوضؼًزأضەأوشًۏأۄەأڬۄأإځأىەأڬۄتأ=““أ+أتۏڬأًمحأتۏضتأۄًأڲتأ,أشتحأڬًأهًڲأمشإىأځڔہۏڽأڲەأتًشأظثذأڬًأڬًةۏأإۏحأوظذلأوۏڽأىۄۏڽأډہًڔۏأدتةەأڲۏأتًشأىۄأۄۏأڬضۏأڬەأزهأوۏڽأثهڬۄأضثأتټہتأهۏأدتةۏڽأڲۏأۗ‛‛

[تخریج]: #حسن: أخرجہ ابن ابی شیبہ10/534(10242)وعبدالرزاق(5980)والبخاری فی خلق افعال العباد(ص86)"
3387,"ؼثزتههۄأثىأًتمزأڬۄحەأۄۏڽأڬۄأمحتزۄأشعۏأتههۄأؼىۄأىەألشوتۏتأ=““أڬًةۏأمشإىأڬەأمشۏثأىۄۏڽأثۏټہەأڲتأوڲشأًۄتڽأضەأىلؼأۏتأىمظتىأهەأڬشأتټہەأڲتأۗ‛‛أځہشأۏۄأإۏحأځڔہۏأ=““أتًشأۄوأىەأمشإىأىتصهأڬۏتأتضأوۏڽأوًوىۏىأڬەأهةەأطلتؤأتًشأشذوحأۄەأتًشأػتهوًڽأڬەأهةەأتضأوۏڽأرضتشۄأۄەأۗ‛‛

[تخریج]: ! ضعیف: محمد بن کثیر ضعیف ہے، أخرجہ ابو عبید فی فضائلہ(ص57-56)"
3388,"شلزۄأؽضتىۏأثۏتىأڬشحەأۄۏڽأڬۄأختثحأثىأؼدهتىأتىظتشۏأىەأڬۄتأ=““أذڬوحأضەأوشتزأمشإىأۄەأۗ‛‛

[تخریج]: @ضعیف: رفدہ بن قضاعۃ ضعیف ہے۔"
3389,"تۏڬأطرظأدىأڬۏأڬىۏحأتثًؼوشًأحہۏأثۏتىأڬشحەأۄۏڽأڬۄأوؼتسأثىأدثهأشعۏأتههۄأؼىۄأىەألشوتۏتأ=““أؼىمشۏثأمشإىأڬډہأهًڲًڽأڬەأزهًڽأوۏڽأځشتىتأۄًأدتةەأڲتأدضأغشذأڬځڔتأځشتىتأۄًحتأۄەأتًشأڲشأځڔحتأۄەأ؏أمشإىأحًأځڔہۏڽأڲەأوڲشأىۄأتضأڬۏأرًتۄطأۄًأڲۏأتًشأىۄأهسحأًۄأثہۏڔۏًڽأڬەأزهًڽأځشأثہۏڔأڬۏأڬہتهۏڽأځۄىۏڽأڲەأ+أتىأڬەأدضوأثہۏڔأڬۏأوتىىزأتًشأزهأثہۏڔةۏەأڬۏأوتىىزأۄًڽأڲەأ,أۗأتىأڬەأڬتوأهتهډأًتهەأۄًڽأڲەأ؏أدضأوۏڽأرًلأىۄأۄًأڲتأ؏أتڲشأڬًحتۄۏأڬشۏڽأڲەأحًأڬۄۏڽأڲەأ=““أتثہۏأڬشأهۏڽأڲەأۗ‛‛أتًشأتڲشأثشتةۏأڬشۏڽأڲەأحًأڬۄۏڽأڲەأ=أؼىمشۏثأۄوأثرطأزةۏەأدتةۏڽأڲەأۗأۄوأتههۄأڬەأضتحہأطشڬأحًأىۄۏڽأڬشحەأۗ‛‛

[تخریج]: !صحیح: یہ معاذ پر موقوف ہے۔"
3390,"ؼثزتههۄأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=““أۏۄأثشۏأثتحأۄەأڬۄأڬًةۏأڬۄەأ=أوۏڽألهتڽأإۏتحأثہًهأڲۏتأثهڬۄأًۄأثہهتأزۏتأڲۏتأۄەأۗأمشإىأڬًأۏتزأڬۏتأڬشًأڬۏًىڬۄأۏۄأضۏىًڽأوۏڽأضەأتضأضەأثہۏأدهزۏأىڬهأدتحتأۄەأدحىۏأدهزۏأدتىًشأتځىۏأشضۏأضەأىڬهحەأۄۏڽأۗ‛‛

[تخریج]: @متفق علیہ: أخرجہ البخاری،کتاب فضائل القران،باب استذکار القران وتعاہدہ(5032)ومسلم،کتاب صلاۃ المسافرین، باب فضائل القرآن وما یتعلق بہ (790)"
3391,"ؼمثۄأثىأؼتوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأڬۏأڬحتثأضۏڬہًأتًشأتضأڬۏأىڲۄزتطحأڬشًأ؏أتضەأځڔہًأ؏أتضأضەأرًطأتهذتىۏأضەأځڔہًأ؏أتضأستحأڬۏأمضوأدضأڬەأۄتحہأوۏڽأوۏشۏأدتىأۄەأۏتأتضأستحأڬۏأمضوأدضأڬۏأۄتحہأوۏڽأوذوزأ﷽أڬۏأدتىأۄەأ$أمشإىأذتوهۄأتًىټىۏأڬەأشضۏأضەأىڬهىەأضەأثہۏأدهزۏأضۏىًڽأضەأىڬهأدتحتأۄەأۗ‛‛

[تخریج]: #صحیح: أخرجہ احمد4/146والنسائی فی فضائل القرآن(60-59)"
3392,"ؼمثۄأثىأؼتوشأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأڬۏأڬحتثأضۏڬہًأ؏أتضأڬۏأذلتػحأڬشًأ؏أتضأضەأهڲتاأشڬہًأتًشأتضەأؽىتأڬەأضتحہأځڔہًأۗأتضأستحأڬۏأمضوأدضأڬەأۄتحہأوۏڽأوۏشۏأدتىأۄەأ$أمشإىأتضأضەأثہۏأدهزۏأضەأىڬهأدتحتأۄەأدحىۏأذتوهۄأتًىټىۏأشضۏأضەأىڬهحۏأۄەأۗ‛‛

[تخریج]: ! صحیح: أخرجہ النسائی،کتاب فضائل القران(60)والطبرانی فی الکبیر17/291-290(802-801-800)"
3393,"تثىأتثًوهۏڬۄأضەأوىمًهأۄەأڬۄأؼڬشوۄأثىأتثًدۄهأشعۏأتههۄأؼىۄأمشإىأڬًأتځىەأډۄشەأځشأشڬہحەأ+أإىڬہًڽأضەأهڲتحەأ,أحہەأتًشأڬۄحەأحہەأ=““أۏۄأوۏشەأشثأڬۏأڬحتثأۄەأ‛أۏۄأوۏشەأشثأڬۏأڬحتثأۄەأۗ‛‛

[تخریج]: @منقطع ضعیف: ابن ابی ملیکہ نے عکرمہ کو نہیں پایا۔ أخرجہ الحاکم3/243والبیہقی فی الشعب(2229)والطبرانی الکبیر 17/371(1018)"
3394,"ختثحأڬۄحەأۄۏڽأڬۄأؼثزتهشذوىأثىأتثًهۏهۏأدثأظثذأڬۏأىوتصأځڔہحەأحًأضًشدأغهًؼأۄًىەأحڬأمشإىأځڔہحەأشۄحەأۗأۄوتوأڬۄحەأۄۏڽأ=““أختثحأثہۏأتۏضتأۄۏأڬشحەأحہەأۗ‛‛

[تخریج]: #صحیح: أخرجہ ابن سعد فی الطبقات6/75"
3395,"ضؼۏزأضەأوىمًهأۄەأڬۄأمحتزۄأشعۏأتههۄأؼىۄأىەأڬۄتأمشإىأڬۏأتضأإۏحأ=““أًۄأهًڲأدًأتۏوتىأهتةەأدتىحەأۄۏڽأڬۄأۏۄأتىأڬەأشثأڬۏأغشلأضەأذمأۄەأۗ‛‛أ+أضًشۆأتهثمشۆأ=أ59أ,أڬۏأحلضۏشأڬشحەأۄًةەأڬۄتأ=““أوضهوتىأدتىحەأۄۏڽأڬۄأًۄأشذوىأڬتأڬهتوأۄەأۗ‛‛

[تخریج]: !صحیح: أخرجہ الطبرانی فی التفسیر1/180"
3396,"ؼغۏۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأحؼتهۏٳأڬەأىصزۏڬأتضأڬەأڬهتوأضەأثڔہأڬشأځۏتشتأڬًةۏأڬهتوأىۄۏڽأتًشأثىزەأتههۄأضەأتضأڬۏأڬهتوأضەأثڔہأڬشأڬًةۏأڬهتوأىۄۏڽأڬشحەأدًأتضەأوذثًثأۄًأۗ‛‛

[تخریج]: @ضعیف: أخرجہ البیہقی فی الأسماء والصفات(ص244)"
3397,"ضۏٔزىتأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄوتأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أذدأڬەأوًمؼأځشأوًملأوۏڽأهًڲًڽأڬەأځتضأدتأڬشأڬۄحەأحہەأ=““أڬًةۏأطرظأۄەأدًأودہەأتځىۏأمًوأڬەأځتضأهەأدتةەأۗأڬۏًىڬۄأمشۏطأىەأودہەأتځىەأشثأڬتأڬهتوأځۄىډتىەأضەأشًڬأزۏتأۄەأۗ‛‛

[تخریج]: # صحیح: أخرجہ احمد3/390وابن ابی شیبہ10/310(18431)وابوداؤد،کتاب السنۃ،باب فی القران (4734) والترمذی ، کتاب ثواب القران،باب حرض النبی صلی اللہ علیہ وسلم علی تبلیغ القران(2926)"
3398,"تثًصؼشتؤأڬۄحەأۄۏڽأڬۄأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأىەأڬۄتأ=““أۏۄأمشإىأتههۄأڬتأڬهتوأۄەأتضأهۏەأوۏڽأحوۄۏڽأتضأذتهحأوۏڽأىۄأزۏڬہًڽأڬۄأحوأىەأتضأڬًأتځىۏأرًتۄطتحأڬۏأغشلأوًڔأهۏتأۄًأۗ‛‛

[تخریج]: ! صحیح: أخرجہ الآجری فی الشریعۃ(ص78)والبیہقی فی الاسماء والصفات(282)"
3399,"ضۏٔزىتأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدًأطرظأمشإىأځڔہىەأڬۏأًدۄأضەأودہأضەأضًتهأڬشىەأتًشأوۏشتأسڬشأڬشىەأضەأوطؽًهأۄًأدتةەأوۏڽأتضەأضتةهۏىأضەأثڔہأڬشأخًتثأزًڽأڲتأتًشأتههۄأحؼتهۏٳأڬەأڬهتوأڬًأحوتوأڬهتوًڽأځشألعۏهحأۄەأدضأغشذأتههۄأحؼتهۏٳأڬًأتځىۏأحوتوأورهًمأځشألعۏهحأۄەأۗ‛‛

[تخریج]: @اسنادہ ضعیف لکن لہ شواہد: أخرجہ الترمذی،کتاب ثواب القران،باب من شغلہ القران أعطی أفضل العطایا،أخرجہ یحیی بن عبدالحمید الحمانی،فی مسندہ،قالہ الحافط فی الفتح9/66والقضاعی فی مسند الشہاب 2/326 (1455) وأخرجہ البخاری فی(خلق افعال العباد)(ص109)وفی الکبیر2/115وأخرجہ ابو نعیم فی الحلیۃ7/313 مزید شواہد کے لیے دیکھئے مصنف ابن ابی شیبہ10/237(9320)والشعب للبیہقی(574-573) واللالی المصنوعہ2/343-342"
3400,"ضۏٔزىتأطۄشأثىأذًطثأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأڬەأڬهتوأڬًأورهًمأڬەأڬهتوأځشأتۏضەأۄۏألعۏهحأۄەأدۏضەأتههۄأڬًأتځىۏأورهًمأځشأۗ‛‛

[تخریج]: ! مرسل،ضعیف: أخرجہ ابوداؤد فی المراسیل(535)وابن عدی فی الکامل5/1705"
3401,"ضۏٔزىتأؼثزتههۄأثىأؼوشًأشعۏأتههۄأؼىۄأضەأوىمًهأۄەأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأحؼتهۏٳأڬەأىصزۏڬأمشإىأصوۏىأًأإضوتىأتًشأتىأڬۏأحوتوأډۏصًڽأضەأوذثًثأۄەأۗ‛‛

[تخریج]: @ ضعیف جداً: أخرجہ الرازی،ضعیف القرآن وتلاوتہ(28)"
3402,"ضۏٔزىتأدىزثأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=““أدثأحڬأزهأڬشەأمشإىأځڔہًأ؏أدثأزهأتډتټأ+أثشزتطحۄأرتغشأ,أۄًأدتةەأحًأتټہأدتاأ+أځڔہىتأډہًڔأزًأ,أۗ‛‛

[تخریج]: # متفق علیہ: أخرجہ البخاری،کتاب فضائل القرآن ، باب اقرئوُا القران ماائتلف علیہ قلوبکم(5060)ومسلم،کتاب العلم، باب النہی عن اتباع متشابہ القران(2667)"
3403,"ضۏٔزىتأتثًؼوشتىأدًىۏأشذوۄأتههۄأڬۄحەأۄۏڽأڬۄأدىزثأشعۏأتههۄأؼىۄأىەأڬۄتأ=““أدثأحڬأحوۄتشتأزهأڬشەأمشإىأځڔہًأتًشأدثأزهأتډتټأۄًأدتةەأحًأځڔہىتأډہًڔأزًأۗ‛‛

[تخریج]: ! صحیح: سابقہ ولاحق ملاحظہ فرمائیں۔"
3404,"ضۏٔزىتأدىزثأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدثأحوۄتشتأزهأڬشەأمشإىأځڔہًأتًشأدثأزهأتډتټأۄًأدتةەأحًأځڔہىتأډہًڔأزًأۗ‛‛

[تخریج]: @ صحیح: (3402)ہی مکرر ہے۔"
3405,"ذتشخأڬۄحەأۄۏڽأڬۄأضۏٔزىتأؼهۏأشعۏأتههۄأؼىۄأىەألشوتۏتأ=““أڬډہأهًڲًڽأڬًأتۏوتىأزۏتأدتحتأۄەأمشإىأىۄۏڽأتًشأڬډہأڬًأمشإىأزۏتأدتحتأۄەأتۏوتىأىۄۏڽأتًشأثؼعأڬًأمشإىأتًشأتۏوتىأزًىًڽأزۏةەأدتحەأۄۏڽأۗأتًشأثؼعأڬًأىۄأمشإىأزۏتأدتحتأۄەأىۄأتۏوتىأځہشأتىأڬۏأوختهأثۏتىأڬۏأدىۄۏڽأتۏوتىأزۏتأڲۏتأمشإىأىۄۏڽأتۏضۏأۄەأدۏضەأڬہدًشأڬتأوصۄأوۏټہتأۄًأتًشأرًطثًأثتهڬهأىۄۏڽأۗأتًشأًۄأدضەأمشإىأزۏتأڲۏتأتۏوتىأىۄۏڽأتضأڬۏأوختهأتۏضۏأۄەأدۏضەأإضۄأڬۏأرًطثًأتډہۏأتًشأوصۄأڬڔًتأۄًحتأۄەأتًشأدضەأمشإىأًأتۏوتىأزًىًڽأزۏةەأڲةەأتضأڬۏأوختهأتۏضۏأۄەأدۏضەأىتشىڲۏأڬۏأرًطثًأثہۏأتډہۏأتًشأوصۄأثہۏأوۏټہتأۄًحتأۄەأتًشأدضەأمشإىأًأتۏوتىأزًىًڽأىۄۏڽأزۏةەأڲةەأتضأڬۏأوختهأتىزشتةىأڬۏأغشذأۄەأدضأوۏڽأرًطثًأثہۏأىۄۏڽأتًشأوصۄأثہۏأڬڔًتأۄًحتأۄەأۗ‛‛

[تخریج]: !صحیح: أخرجہ ابو عبید فی فضائل القران(ص387)وأخرجہ ابن ابی شیبہ مختصراً10/529(10220)"
3406,"ضۏٔزىتأتثًوًضۏٳأتطؼشۏأشعۏأتههۄأؼىۄأضەأوىمًهأۄەأىثۏأ﷽أىەألشوتۏتأ=““أمشإىأځڔہىەأًتهەأوًوىأڬۏأوختهأىتشىڲۏأڬۏأغشذأۄەأدضأڬتأوصۄأثہۏأتډہتأۄًحتأۄەأتًشأرًطثًأثہۏأ‛أمشإىأىۄأځڔہىەأًتهەأوًوىأڬۏأوختهأتضأڬہدًشأڬۏأغشذأۄەأدضأڬتأوصۄأوۏټہتأۄًأوڲشأرًطثًأىۄأۄًأۗأمشإىأځڔہىەأًتهەأوىتلمأڬۏأوختهأشۏذتىۄأڬۏأغشذأۄەأدضأڬۏأرًطثًأتډہۏأۄەأتًشأوصۄأڬڔًتأ‛أتًشأمشإىأىۄأځڔہىەأًتهەأوىتلمأڬۏأوختهأذىػهۄأڬۏأغشذأۄەأدضأوۏڽأرًطثًأىۄۏڽأۄًحۏأتًشأوصۄأثہۏأڬڔًتأۄًحتأۄەأۗ‛‛

[تخریج]: @متفق علیہ: أخرجہ البخاری،کتاب فضائل القران،باب فضل القران علی سائر الکلام(5020)ومسلم،کتاب صلاۃ المسافرین، باب فضیلۃ حافظ القران(797)"
3407,"ضۏٔزىتأذتشخأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأضۏٔزىتأؼهۏأشعۏأتههۄأؼىۄأىەأڬۄتأ=““أدضەأتۏوتىأزۏتأڲۏتأمشإىأىۄۏڽأتضأڬۏأوختهأتضأڬہدًشأڬۏأغشذأۄەأدضأڬتأوصۄأتډہتأۄەأتًشأرًطثًأثتهڬهأىۄۏڽأۄەأۗأتًشأدضەأمشإىأزۏتأڲۏتأتۏوتىأىۄۏڽأتضأڬۏأوختهأشۏذتىأ‛أإضۄأ+أىتصثًأ,أڬۏأغشذأۄەأدضأڬۏأرًطثًأتډہۏأۄەأتًشأوصۄأڬڔًتأ‛أتًشأدضەأمشإىأًأتۏوتىأزًىًڽأزۏةەأڲةەأتضأڬۏأوختهأىتشىڲۏأڬۏأغشذأۄەأدضأڬۏأرًطثًأثہۏأتډہۏأۄەأتًشأوصۄأثہۏأتډہتأۗأتًشأدضەأمشإىأتًشأتۏوتىأزًىًڽأىۄۏڽأزۏةەأڲةەأۗأتضأڬۏأوختهأتىزشتةىأ+أىۄتۏحأڬڔًتأځہهأ؏أحوۄأ,أڬۏأغشذأۄەأدضأڬۏأرًطثًأثہۏأثشۏأۄەأتًشأستةمۄأثہۏأثشتأۄەأۗ‛‛

[تخریج]: !صحیح: أخرجہ ابو عبید فی فضائلہ (ص387)"
3408,"ؼتوشأثىأًتخهۄأثۏتىأڬشحەأۄۏڽأڬۄأىتلؼأثىأؼثزتهذتشخأؼضلتىأوۏڽأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأضەأوهەأتًشأؼوشأشعۏأتههۄأؼىۄأڬۏأغشلأضەأًۄأوڬۄأڬەأڲًشىشأحہەأتىۄًڽأىەأؼوشأشعۏأتههۄأؼىۄأڬًأضهتوأڬۏتأۗأحًأؼوشأشعۏأتههۄأؼىۄأىەأڬۄتأ=““أإځأىەأوڬۄأوۏڽأتځىتأىتةثأڬضەأثىتۏتأۄەأآ‛‛أىتلؼأىەأڬۄتأ=““أوۏڽأىەأًۄتڽأتثىأتثصۏأڬًأىتةثأثىتۏتأۄەأۗ‛‛أؼوشأشعۏأتههۄأؼىۄأىەأڬۄتأ=أتثىأتثصۏأڬًىأۄەأآأڬۄتأ=““أۄوتشتأتۏڬأإصتزأڬشزۄأؽهتوأۄەأۗ‛‛أحًأؼوشأشعۏأتههۄأؼىۄأىەأڬۄتأ=أحوأىەأتىأځشأإصتزأڬشزۄأؽهتوأڬًأىتةثأثىتۏتأۄەأآأحًأىتلؼأىەأڬۄتأ=““أتەأتوۏشتهوًٗوىۏىأ$أًۄأتههۄأڬۏأڬحتثأڬتأمتشۏأ+أؼتهوأ,أۄەأ‛ألشتةعأدتىحتأۄەأۗ‛‛أؼوشأشعۏأتههۄأؼىۄأىەأڬۄتأ=أثەأطڬأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأحؼتهۏٳأمشإىأڬەأسشۏؼۄأضەأڬةۏأمًوًڽأڬًأؼصحأزۏحتأۄەأتًشأزًضشًڽأڬًأسهحأۗ‛‛

[تخریج]: !صحیح: أخرجہ مسلم،کتاب صلاۃالمسافرین،باب فضل من یقوم بالقران ویعلمہ(817)والبیہقی فی الصلاۃ باب امامۃ المولی3/89"
3409,"ؼثزۄأثۏتىأڬشحەأۄۏڽأڬۄأرتهزأثىأوؼزتىأىەأڬۄتأ=““أدًأمشإىأځڔہحتأۄەأتضأڬەأهةەأتۏڬأتدشأۄەأتًشأدًأضىحتأۄەأتضأڬەأهةەأزًأتدشأۄۏڽأۗ‛‛

[تخریج]: @عبدۃ بن خالد کا ترجمہ نہیں ملا۔"
3410,"ؼغتؤأڬۄحەأۄۏڽأتثىأؼثتضأشعۏأتههۄأؼىۄأىەأڬۄتأ=““أدًأمشإىأڬۏأتۏڬأإۏحأضىەأڲتأًۄأتضأڬەأهةەأشًطىۏأڬتأثتؼخأۄًأڲۏأۗ‛‛

[تخریج]: # ضعیف: أخرجہ عبدالرزاق(6012)"
3411,"ضۏٔزۄأؼتةطۄأشعۏأتههۄأؼىۄتأڬۄحۏأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=““أدًأطرظأمشإىأځڔہحتأۄەأتًشأًۄأتضەأځڔہىەأڬتأوتۄشأۄەأًۄأثصشڲأتًشأىۏڬًڬتشألشطحًڽأڬەأضتحہأۄًأڲتأۗأتًشأدًأطرظأمشإىأځڔہحتأۄەأتًشأًۄأزطًتشۏأضەأځڔہحتأۄەأتضأڬەأهةەأزًۄشتأتدشأۄًأڲتأۗ‛‛

[تخریج]: !صحیح: أخرجہ البخاری،کتاب التفسیر،باب سورۃ عبس(4937)ومسلم،کتاب صلاۃ المسافرین،باب الماہر بالقران والذی،یتعتع فیہ (798)"
3412,"تضوتؼۏهأثىأؼثۏزأشذوۄأتههۄأڬۄحەأۄۏڽأڬۄأًۄثأسوتشۏأشذوۄأتههۄأىەأڬۄتأ=أدضأڬًأتههۄأحؼتهۏٳأىەأمشإىأزۏتأتضأىەأشتحأزىأتضەأځڔہتأتًشأتضأځشأؼوهأڬۏتأۗأتًشأتغتؼحأ+أتضهتوأ,أځشألًحأۄًتأۗأتههۄأحؼتهۏٳأتضەأمۏتوحأڬەأزىألشطحًڽأتًشأىثۏًڽأڬەأضتحہأتټہتةەأڲتأۗأدًأطرظأمشإىأځڔہىەأڬۏأذشظأشڬہحتأۄەأ؏أوڲشأمشإىأتضەأۏتزأىۄۏڽأۄًحتأًۄأمشإىأڬًأډہًڔحتأىۄۏڽأتضەأزًۄشتأتدشأزۏتأدتةەأڲتأۗأدًأطرظأمشإىأڬۏأذشظأشڬہحتأۄەأ؏أوڲشأمشإىأتضەأۏتزأىۄۏڽأشۄحتأ+أتضهتوأ,أځشألًحأۄًأحًأًۄأؼصحأًتهًڽأضەأۄەأۗأًۄأحوتوأهًڲًڽأضەأتضۏأغشذأتلعهأۄەأدضأغشذأؼمتثأڬًأحوتوأځشىزًڽأځشألعهۏحأۄەأۗأتًشأدۏضەأضثصۄأصتشأتځىەأتشزڲشزأڬەأثتؽۏډًڽأضەأتلعهأۄەأۗأمۏتوحأڬەأزىأڬۄتأدتةەأڲتأ=أڬۄتڽأۄۏڽأًۄأهًڲأدًأوۏشۏأڬحتثأځڔہحەأحہەأآأدتىًشًڽأڬەأضتحہأشۄىەأڬەأثتًدًزأتضأضەأؽتلهأىۄأۄًةەأۗأتىۄۏڽأدىحأتًشأىؼوحأزۏأدتةەأڲۏأ؏أتڲشأتىأڬەأًتهزۏىأتضهتوأځشألًحأۄًةەأۄًڽأڲەأحًأتىأڬەأضشأځشأطتۄۏأحتدأشڬہتأدتةەأڲتأۗأًۄأڬۄۏڽأڲەأ=أۏتأشثأ$أۄوتشەأتؼوتهأحًأتضأزشدۄأڬەأىۄۏڽأحہەأآأتههۄألشوتةەأڲتأ=““أڬۏًڽأىۄۏڽأ؏أحوۄتشتأثۏټتأوۏشۏأڬحتثأځڔہحتأحہتأۗ‛‛

[تخریج]: !صحیح: وہب الدماری شرط ابن حبان پر ہے۔"
3413,"ؼثزتهوهڬأثىأؼوۏشأشعۏأتههۄأؼىۄوتأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أضًشۆألتحذۄأۄشأثۏوتشۏأڬۏأطلتأۄەأۗ‛‛

[تخریج]: @مرسل ضعیف: أخرجہ البیہقی فی الشعب(2370)"
3414,"تثًضؼۏزأثىأوؼهۏٳأتىظتشۏأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أوۏشەأځتضأضەأڲصشەأحًألشوتۏتأ=أڬۏتأتههۄأؼصًدهأىەأىۄۏڽألشوتۏتأ=““أتەأتۏوتىأًتهًأ$أتههۄأتًشأتضأڬتأشضًهأدثأحوۄۏڽأثهتةەأحًأتىۄۏڽأدًتثأزًأۗ‛‛أ+أضًشۆأتهتىلتهأ=أ57أ,ألشوتۏتأ=أوضدزأضەأىڬهىەأضەأمثهأحوۄۏڽأمشإىأڬۏأثڔۏأضًشحأىۄأضڬہتاڽأآأځہشأإځأىەأوضدزأضەأثتۄشأدتىەأڬتأتشتزۄأڬۏتأحًألشوتۏتأ=““أثڔۏأضًشۆأ““أ®تّهٕذّوٕزْأهٓهٔٳۄٓأشّثٓٔأتهٕؼّتهّوٓۏٕىّ¾أ‛‛أۄەأتًشأۏۄۏأضثؼأوختىۏأۄەأتًشأۏۄۏأؼػۏوأزشدۄأڬتأمشإىأۄەأدًأحوۄۏڽأزۏتأڲۏتأۄەأۗ‛‛

[تخریج]: !صحیح: أخرجہ البخاری،کتاب التفسیر،باب ماجاء فی فاتحۃ الکتاب(4474)والنسائی فی فضائل القرآن(35)"
3415,"ضۏٔزىتأتثۏأثىأڬؼثأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أضًشۆألتحذۄأۄۏأًۄأضتحأإۏتحأۄۏڽأدًأثتشأثتشأزۄشتةۏأدتحۏأۄۏڽأۗ‛‛

[تخریج]: @صحیح: أخرجہ البیہقی،کتاب الصلاۃ،باب تعلیق القراء ۃ المطلقۃ فیما روینا بالفاتحہ 2/376-375 والبخاری، کتاب التفسیر،باب ماجاء فی فاتحۃ الکتاب(4474)"
3416,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أشضًهأتههۄأ﷽أىەألشوتۏتأ=““أضًشۆألتحذۄأدۏضۏأڬًةۏأضًشۆأىۄأحًشتحأوۏڽأتحتشۏأڲةۏأتًشأىۄأتىدۏهأوۏڽأتًشأىۄأصثًشأوۏڽأتًشأىۄأمشإىأوۏڽأۄەأتًشأًۄأثتشأثتشأځڔہۏأدتىەأًتهۏأضتحأإۏتحأۄۏڽأتًشأًۄۏأؼػۏوأوشحثۄأًتهتأمشإىأۄەأدًأوۏڽأزۏتأڲۏتأۄًڽأۗ‛‛

[تخریج]: ! صحیح: أخرجہ الترمذی،کتاب ثواب القران،باب ماجاء فی فضل فاتحۃ الکتاب(2878)واسخاوی فی جمال القراء 1/116-115"
3417,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أضًشۆألتحذۄأۄۏأتظهأمشإىأۄەأتًشأتظهأڬحتثأۄەأًۄۏأضتحأإۏتحأۄۏڽأدًأثتشأثتشأځڔہۏأدتحۏأۄۏڽأۗ‛‛

[تخریج]: @صحیح: أخرجہ الترمذی،کتاب التفسیر،باب من سورۃ الحجر(3123)"
3418,"تثًتذًظأڬۄحەأۄۏڽأؼثزتههۄأىەأڬۄتأ=““أدضأڲہشأوۏڽأضًشۆأثمشۄأځڔہۏأدتةەأطۏغتىأتضأڲہشأضەأڲًصأوتشحتأۄًتأثہتڲأدتحتأۄەأۗ‛‛

[تخریج]: # صحیح: ’’ولہ خریط‘‘ کے الفاظ صحیح سند سے ثابت نہیں، أخرجہ ابن الضریس فی فضائل القرآن(175)والبیہقی فی شعب الإیمان(2379)"
3419,"ؼثزۄأثۏتىأڬشحەأۄۏڽأ‛أرتهزأثىأوؼزتىأىەأڬۄتأ=““أضًشۆأثمشۄأڬتأځڔہىتأثتؼخأثشڬحأۄەأ؏أتضأڬًأډہًڔىتأذضشحأۄەأتًشأدتزًڲشأتضەأىۄۏڽأځڔہأضڬحەأ‛أًۄأمشإىأڬتأرۏوۄأۄەأۗ‛‛

[تخریج]: $عمرۃ کے خیالات نہیں ملے’’مستطاط القران‘‘ کے الفاظ کے علاوہ بقیہ الفاظ کی مسلم،کتاب صلاۃ المسافرین،باب فضل قراء ۃ القرآن وسورۃ البقرۃ (804) سے شہادت ملتی ہے۔"
3420,"تثًتذًظأڬۄحەأۄۏڽأؼثزتههۄأىەأڬۄتأ=““أۄشأتۏڬأډۏصأوۏڽأتؼهۏٳأډۏصأۄًحۏأۄەأتًشأمشإىأڬۏأتؼهۏأډۏصأضًشۆأثمشۄأۄەأۗأۄشأډۏصأوۏڽأرتهظأډۏصأۄًحۏأۄەأۗأمشإىأڬۏأرتهظأډۏصأولظهأۄەأۗ‛‛أتثًوذوزأڬۄحەأۄۏڽأ‛أهثتثأڬەأوؼىۏأرتهظأۄۏڽأۗ

[تخریج]: !حسن: أخرجہ الطبرانی فی الکبیر9/138(8644)والحاکم(2060)جب کہ یہ الفاظ حاکم کے اسی حوالے سے مرفوعًا بھی ثابت ہیں۔"
3421,"ؼثزتهشذوىأثىأتضًزأڬۄحەأۄۏڽأ=أدضأىەأضًشۆأثمشۄأځڔہۏأتضەأدىحأوۏڽأحتدأځۄىتۏتأدتةەأڲتأۗ‛‛

[تخریج]: @صحیح: أخرجہ ابن الضریس فی فضائل القرآن (165)"
3422,"تثًتذًظأڬۄحەأۄۏڽأڬۄأؼثزتههۄأىەأڬۄتأ=““أطۏغتىأدثأضًشۆأثمشۄأضىحتأۄەأدًأڬضۏأڲہشأوۏڽأځڔہۏأدتأشۄۏأۄًأحًأًۄتڽأضەأثہتڲأدتحتأۄەأۗ‛‛

[تخریج]: # صحیح: أخرجہ الحاکم فی المستدرک (2062)"
3423,"تۏلؼأثىأؼثزڬهتؼۏأڬۄحەأۄۏڽأڬضۏأإزوۏأىەأڬۄتأ=““أۏتأشضًهأتههۄأ$أمشإىأڬۏأڬًىضۏأضًشۆأثڔەأزشدۄأڬۏأۄەأآ‛‛أإځأىەألشوتۏتأ=““أ®مهأۄًأتههۄأتذز¾أ‛‛أتضأىەأڬۄتأ=أمشإىأوۏڽأڬًىأضۏأإۏحأثڔۏأۄەأآأإځأىەألشوتۏتأ=““أإۏحأتهڬشضۏأ‛أتههۄأڬەأؼهتًۄأڬًةۏأوؼثًزأىۄۏڽأًۄأصىزۄأتًشأمتةوأشۄىەأًتهتأۄەأ=أ+أضًشۆأتهثمشۆأ=أ588أ,أتضأىەأڬۄتأ=أتەأتههۄأڬەأىثۏأ$أڬًىأضۏأإۏحأڬًأإځأصۏتزۄأځضىزأڬشحەأۄۏڽأڬۄأإځأڬًأتًشأإځأڬۏأتوحأڬًأًۄأوهأدتةەأآأإځأىەألشوتۏتأ=““أضًشۆأثمشۄأڬتأإرشأ‛أڬۏًىڬۄأًۄأتههۄأڬەأرصتىًڽأضەأۄەأۗأدًأتضأڬەأؼشطأڬەأىۏډەأۄەأ‛أتضأىەأۏۄأضًشحأتضأتوحأڬًأزۏأتًشأڬًةۏأزىۏتأتًشأإرشحأڬۏأثہهتةۏأىۄۏڽأډہًڔۏأدًأتضأوۏڽأطتوهأىۄأۄًأۗ‛‛

[تخریج]: ! ضعیف: حافظ ابن حجر اصابۃ میں کہتے ہیں 1/222 یہ دارمی نے کہا ہے کہ ایفع کی آیۃ الکرسی والی حدیث مرسل یا معضل ہے۔"
3424,"طؼثۏأثۏتىأڬشحەأۄۏڽأۗأڬۄأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأىەأڬۄتأ=““أوذوزأ﷽أڬەأظذتثۄأشعۏأتههۄأؼىۄوأضەأتۏڬأإزوۏأڬۏأدىأضەأوهتمتحأۄًةۏأحًأزًىًڽأوۏڽأڬطحۏأۄًةۏأۗأحًأإزوۏأىەأتضەأځډہتڔأهۏتأ؏أځہشأتضأإزوۏأىەأدىأضەأڬۄتأ=““أوۏڽأحوۄۏڽأڬوصًشأتًشأزثهتأزۏڬہحتأۄًڽأ؏أحۏشۏأډہًټۏأډہًټۏأڬهتةۏتڽأڬحەأڬۏأڬهتةۏًڽأڬۏأغشذأڬوصًشأۄۏڽأۗأحوأدىأهًڲأتۏضەأۄۏأۄًحەأۄًأۏتأځہشأحًأۄۏأتۏضتأۄەأآ‛‛أتضأىەأڬۄتأ=أىۄۏڽأ؏أتههۄأڬۏأمضوأ$أوۏشۏأځضهۏتڽأتىأضەأمًۏأۄۏڽأحوأودہأضەأزًثتشۄأهڔًأ؏أتڲشأحًأىەأودہەأڲشتأزۏتأحًأوۏڽأحوۄۏڽأتۏضۏأډۏصأثحتاڽأڲتأدًأحوۄۏڽأىلؼأزەأڲۏأ‛‛أځضأتضأىەأزًثتشۄأتضأضەأڬطحۏأڬۏأتًشأدىأڬًأځډہتڔأزۏتأتًشأڬۄتأڬۄأهتاأودہەأًۄأضڬہتاأ$أتضأىەأڬۄتأ=““أټہۏڬأۄەأ‛‛أڬۄتأ=أحًأۏۄأإۏحأځڔہحتأۄەأ=““أتههۄأڬەأؼهتًۄأڬًةۏأوؼثًزأىۄۏڽأ؏أًۄأۄوۏطۄأصىزۄأتًشأمتةوأشۄىەأًتهتأۄەأآ‛‛أڬۄتأ=أۄتڽأ؏أدىأىەأڬۄتأ=أحًأدضأڲہشأوۏڽأتضەأځڔہەأڲتأتضأڲہشأضەأطۏغتىأثہتڲأدتةەأڲتأ؏أتضأڬەأڲًصأڬشىەأڬۏأثزثًأڲزہەأڬەأڲًصأڬشىەأڬۏأثزثًأدۏضۏأۄًأڲۏأۗأځہشأًۄأتضأوۏڽأظثذأۄًىەأحڬأزترهأىۄۏڽأۄًأڲتأۗ‛‛

[تخریج]: ! منقطع، ضعیف: شعبی کا ابن مسعود رضی اللہ عنہ سے سماع ثابت نہیں، أخرجہ الطبرانی فی الکبیر 9/183۔184 (8826)"
3425,"طؼثۏأڬۄحەأۄۏڽأڬۄأؼثزتههۄأىەأڬۄتأ=““أدًأطرظأضًشۆأثمشۄأڬۏأزضأإۏتحأشتحأڬًأځڔہەأڲتأتضأشتحأظثذأحڬأطۏغتىأتضأڲہشأوۏڽأزترهأىۄۏڽأۄًأڲتأ‛أډتشأإۏتحأځۄهۏأتًشأإۏحأتهڬشضۏأتًشأزًأإۏتحأإۏحأتهڬشضۏأڬەأثؼزأًتهۏأ‛أحۏىأإرشۏأإۏتحأدىأڬتأطشًؼأۏۄأۄەأۗ‛‛أ““أ®هٓهٔٳۄٓأوّتألٓۏأتهضّٔوٳًّتحٓ¾أۗ‛‛أ+أضًشۆأتهثمشۆأ=أ4;7أ

[تخریج]: @ ضعیف: سابقہ کی طرح منقطع ہے، أخرجہ الطبرانی فی الکبیر 9/147 (8673)"
3426,"طؼثۏأڬۄحەأۄۏڽأتثىأوضؼًزأشعۏأتههۄأؼىۄأىەأڬۄتأ=““أدضأطرظأىەأضًشۆأثمشۄأڬۏأځۄهۏأډتشأإۏتحأځڔہۏڽأتًشأإۏحأتهڬشضۏأتًشأزًأإۏتحأإۏحأتهڬشضۏأڬەأثؼزأًتهۏأ‛أتًشأحۏىأضًشۆأتهثمشۆأڬەأإرشأضەأتضأزىأطۏغتىأتضأڬەأتًشأتضأڬەأڲہشأًتهًڽأڬەأمشۏثأىۄأإةەأڲتأتًشأىۄأڬًةۏأتًشأثشۏأډۏصأإةەأڲۏأۗأدضأزۏًتىەأځشأۏۄأإۏتحأځڔہۏأدتةۏڽأڲۏأًۄأتډہتأۄًأدتةەأڲتأۗ‛‛

[تخریج]: # ضعیف: سابقہ کی طرح منقطع ہے۔ أخرجہ البیہقی فی الشعب (2412)"
3427,"تۏڬأإزوۏأضەأوىمًهأۄەأدضأىەأضۏٔزىتأؼهۏأشعۏأتههۄأؼىۄأضەأضىتأًۄأڬۄحەأحہەأ=““أوۏشتأرۏتهأىۄۏڽأڬًةۏأؼمهأوىزأضًشۆأثمشۄأڬۏأإرشۏأإۏتحأڬًأځڔہەأثؽۏشأضًأدتةەأڲتأۗأڬۏًىڬۄأۏۄأإۏتحأتضأرصتىەأڬۏأۄۏڽأدًأؼشطأڬەأىۏډەأۄەأۗ‛‛

[تخریج]: !صحیح: أخرجہ ابن الضریس فی فضائل القرآن ( 176)"
3428,"تثًضىتىأڬۄحەأۄۏڽأوؽۏشۄأثىأضثۏؼأىەأڬۄتأدًأؼثزتههۄأڬەأضتحہۏًڽأضەأحہەأ=““أدًأطرظأضًحەأًمحأضًشۆأثمشۄأڬۏأزضأإۏتحأځڔہأهەأڲتأًۄأمشإىأڬًأىۄۏڽأثہًهەأڲتأۗأډتشأځۄهۏأإۏتحأ‛أإۏحأتهڬشضۏأ‛أزًأإۏحأتهڬشضۏأڬەأثؼزأًتهۏأتًشأحۏىأإرشۏأۗ‛‛أتثًتضذتمأڬۄحەأۄۏڽأ=أۏؼىۏأدًأڬډہأتضەأۏتزأۄًأڲتأًۄأىۄۏڽأثہًهەأڲتأۗ‛‛أتثًوذوزأڬۄحەأۄۏڽأ=أثؼعأهًڲأوؽۏشۄأثىأضوۏؼأڬۄحەأۄۏڽأۗ

[تخریج]: @ صحیح: أخرجہ البیہقی فی الشعب (2413) والترمذی، فی ثواب القرآن،باب،ماجاء فی سورۃ البقرۃ و آیۃ الکرسی (2881) وابونعیم فی ذکر أخبار أصبھان 1/233"
3429,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدًأطرظأإۏحأتهڬشضۏأتًشأضًشۄأذوأوًوىأڬتأطشًؼأًتهتأذظۄأ““أ®ًأتهۏۄأتهوظۏش¾أحڬأ‛‛أځڔہەأڲتأحًأًۄأڬًةۏأثشۏأډۏصأىۄۏڽأزۏڬہەأڲتأذحۏأڬۄأطتوأۄًأدتةەأڲۏأتًشأدًأطتوأڬەأًمحأځڔہەأڲتأًۄأظثذأحڬأڬًةۏأثشۏأډۏصأىۄۏڽأزۏڬہەأڲتأۗ‛‛

[تخریج]: ! ضعیف: عبدالرحمن بن ابی بکر ضعیف ہے۔"
3430,"ىؼوتىأثىأثطۏشأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأىەأإضوتىأتًشأصوۏىأځۏزتأڬشىەأضەأزًأۄصتشأثشضأځۄهەأتۏڬأڬحتثأهڬہۏأتضۏأوۏڽأضەأًۄأزًأإۏتحأتحتشۏڽأدًأضًشۆأثمشۄأڬەأإرشأوۏڽأۄۏڽأۗأۏۄأىۄۏڽأۄًأضڬحتأڬۄأۏۄأإۏحأحۏىأشتحۏڽأڬضۏأڲہشأوۏڽأځڔہۏأدتةۏڽأځہشأتضأوۏڽأطۏغتىأشۄەأۗ‛‛

[تخریج]: @ صحیح: أخرجہ ابوعبید فی فضائل القرآن (232) والحاکم 2065 والبیہقی فی الشعب (2400)"
3431,"ضۏٔزىتأتثًوضؼًزأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأىثۏأ﷽أىەألشوتۏتأ=““أدًأطرظأضًشۆأثمشۄأڬۏأإرشۏأزًأإۏتحأشتحأڬًأځڔہأهەأڲتأًۄأتضەأڬتلۏأۄًڽأڲۏأۗ‛‛

[تخریج]: #متفق علیہ: أخربہ البخاری، کتاب فضائل القرآن، باب فضل سورۃ البقرۃ (5009) ومسلم،کتاب صلاۃ المسافرین باب فضل الفاتحۃ وخواتیم سورۃ البقرہ (807)"
3432,"ضۏٔزىتأتضوتؤأثىحأۏصۏزأڬۄحۏأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=أتضوأتؼػوأتىأزًأإۏتحأوۏڽأۄەأ=““أ®تّههٔٳۄْأهّتأتٓهٳۄّأتٓهّٔتأۄًّْأتهٕذٍّْٔأتهٕمّۏًْٕٔوْ¾أۗ‛‛أ+أضًشۆأتهثمشۆأ=أ583أ,أۗأ““أ®تٓهٳہْڬْوٕأتٓهٳۄُأًّتذٓزُ¾أۗ‛‛أ+أضًشۆأتهثمشۆأ=أ588أ

[تخریج]: !حسن: أخرجہ ابوداؤد، کتاب الصلاۃ، باب الدعاء (1496) والترمذی، کتاب الدعوات، باب ماجاء عن جامع الدعوات عن رسول اللّٰہ ﷺ (3472) وابن ماجہ،کتاب الدعائ،باب اسم اللّٰہ الأعظم (3855)"
3433,"دثۏشأثىأىلۏشأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأحؼتهۏٳأىەأضًشۆأثمشۄأڬًأتۏضۏأزًأإۏتحأځشأرحوأڬۏتأدًأودہەأتۏضەأرصتىەأضەأزۏأڲةۏڽأدًأؼشطأڬەأىۏډەأۄەأهۄٳستأتىۄۏڽأضۏڬہًأتًشأتځىۏأؼًشحًڽأڬًأضڬہتاأۗأڬۏًىڬۄأًۄأىوتصأتًشأمشإىأتًشأزؼتأضثأڬډہأۄۏڽأۗ‛‛

[تخریج]: @مرسل، ضعیف: أخرجہ مسلم مفاہ، نیز امام حاکم نے (2066) اور بیہقی نے الشعب (3403) میں اسے موصولاً بھی بیان کیاہے۔"
3434,"ؼثزتههۄأثىأثشۏزۄأتځىەأًتهزأضەأثۏتىأڬشحەأۄۏڽأڬۄأوۏڽأىثۏأ﷽أڬەأځتضأثۏټہتأحہتأۗأوۏڽأىەأضىتأإځألشوتأشۄەأحہەأ=““أضًشۆأثمشۄأضۏڬہًأۏۄأثتؼخأثشڬحأۄەأۗأتضەأډہًڔىتأذضشحأۄەأۗأتًشأدتزًڲشأتضەأىۄۏڽأځڔہأضڬحەأۗأځہشأڬډہأزۏشأرتوًطأشۄەأتًشألشوتۏتأ=““أضًشۆأثمشۄأتًشأإهأؼوشتىأضۏڬہًأثەأطڬأًۄأىًشأۄۏڽأًۄأتځىەأضتحہۏأځشأمۏتوحأڬەأزىأضتۏۄأڬشۏڽأڲۏأۗأڲًۏتأڬۄأًۄأزًأثتزهأۄۏڽأۏتأزًأضتةثتىأۄۏڽأۏتأظلأثتىزہەأۄًةەأځشىزًڽأڬۏأټڬڔۏأۄەأۗأثەأطڬأمشإىأمۏتوحأڬەأزىأمثشأځہټحەأًمحأتځىەأضتحہۏأضەأځشۏطتىأإزوۏأڬۏأغشذأوهەأڲتأۗأتًشأتضەأڬۄەأڲتأۗأڬۏتأحًأودہەأځۄډتىحتأۄەأحًأًۄأڬۄەأڲتأ=أوۏڽأحۏشتأضتحہۏأمشإىأۄًڽأڲشوۏًڽأوۏڽأحًأدضأڬۏأًدۄأضەأځۏتضتأشۄتأتًشأشتحًڽأڬًأدتڲحتأشۄتأۗأۄشأحتدشأتځىۏأحدتشحأڬەأځۏډہەأۄًحتأۄەأحًأإدأۄشأحدتشحأضەأتهڲأۄەأتضأڬەأزتةۏڽأۄتحہأوۏڽأثتزطتۄحأتًشأثتةۏڽأۄتحہأوۏڽأۄوۏطۄأڬۏأدىحأزۏأدتةەأڲۏأۗأتًشأتضأڬەأضشأځشأؼصحأڬتأحتدأشڬہتأدتةەأڲتأۗأتًشأتضأڬەأًتهزۏىأڬًأتۏضتأهثتضأځۄىتۏتأدتةەأڲتأڬۄأتضأڬۏأمۏوحأحوتوأزىۏتأثہۏأىۄۏڽأۄًأضڬحۏأۗأًۄأڬۄۏڽأڲەأ=أۄوۏڽأۏۄأڬځڔەأڬۏًڽأځۄىتةەأۄۏڽأآأتىأضەأڬۄتأدتةەأڲتأ=أحوۄتشەأثۏټەأڬەأمشإىأځڔہىەأڬۏأًدۄأضەأۗأځہشأتضەأڬۄتأدتةەأڲتأ‛أځڔہًأتًشأدىحأڬەأثتهترتىەأتًشأزشدەأډڔہحەأدتاأۗأًۄأحۏصۏأضەأځڔہەأۏتأټہۄشأڬشأدثأحڬأځڔہحتأشۄەأڲتأډڔہحتأشۄەأڲتأۗ

[تخریج]: !حسن: أخرجہ ابن ابی شیبہ 10/492۔493 (10094) و احمد(5/348) والحاکم 2057:"
3435,"تثًۏذۏۏأضهۏوأثىأؼتوشأڬۄحەأۄۏڽأتىۄًڽأىەأتثًتوتوۄأضەأضىتأًۄأڬۄۄأشۄەأحہەأ=أحوۄتشەأڬضۏأثہتةۏأىەأرًتثأوۏڽأزۏڬہتأڬۄأهًڲأتۏڬأضرحأتًشأهوثەأځۄتڔأڬەأشتضحۄأځشأډهأشۄەأۄۏڽأتًشأځۄتڔأڬەأضشأځشأزًأضثصأزشرحأۄۏڽأدًأځڬتشأشۄەأۄۏڽأ=أڬۏتأحوأوۏڽأڬًةۏأضًشۆأثمشۄأځڔہىەأًتهتأۄەأآأڬۏتأحوأوۏڽأڬًةۏأضًشۆأإهأؼوشتىأځڔہىەأًتهتأۄەأآأدثأڬًةۏأإزوۏأڬۄحتأۄەأ=““أۄتڽأۗ‛‛أحًأًۄأتځىۏأطترۏڽأدہڬتأزۏحەأۄۏڽأًۄأتضأوۏڽأهټڬأدتحتأۄەأتًشأځۄتڔأځشأډڔہأدتحەأۄۏڽأۗأتثًوذوزأڬۄحەأۄۏڽأ=أتهتؼستمأ=أټۄىۏًڽأڬًأڬۄحەأۄۏڽأۗ‛‛

[تخریج]: !ضعیف: عبداللہ بن صالح ضعیف ہے، أخرجہ ابوعبید فی فضائل القرآن (ص236:)"
3436,"وضشًمأڬۄحەأۄۏڽأؼثزتههۄأڬەأځتضأتۏڬأإزوۏأىەأضًشۆأثمشۄأتًشأإهأؼوشتىأځڔہۏأحًأتىۄًڽأىەألشوتۏتأ=““أحًأىەأدًأضًشحۏڽأځڔہۏأۄۏڽأتىأوۏڽأتههۄأڬتأتضوأتؼػوأۄەأدثأتضأڬەأسشۏؼەأزؼتأڬۏأدتحۏأۄەأحًأمثًهأڬشحتأۄەأتًشأدثأتضأڬەأسشۏؼەأوتىڲتأدتحتأۄەأحًأزۏحتأۄەأۗ‛‛

[تخریج]: @صحیح بالشواھد: أخرجہ الطحاوی فی مشکل الآثار 1/63 والطبرانی فی الکبیر 8/282 (7925) والحاکم (1861)"
3437,"تثًؼغتلأضەأوىمًهأۄەأڬۄأڬؼثأىەأڬۄتأ=““أدًأضًشۆأثمشۄأتًشأإهأؼوشتىأځڔہەأڲتأحًأۏۄأزًىًڽأمۏتوحأڬەأزىأإأڬشأڬۄۏڽأڲۏأۗ‛‛أ““أۏتأشثأ$أتضەأؼستثأزۏىەأڬۏأڬًةۏأظًشحأىۄۏڽأۄەأۗ‛‛

[تخریج]: !ضعیف: عبدالسلام نے جریری سے آخر عمر میں سماع کیا۔"
3438,"ضهۏوأثىأذىػهۄأثڬشۏأڬۄحەأۄۏڽأؼثزتههۄأثىأوضؼًزأىەألشوتۏتأ=““أدضأىەأضًشۄأإهأؼوشتىأځڔہۏأًۄأوتهزتشأۄەأ‛أتًشأؼًشحۏڽأرًطۏأڬەأتضثتثأضەأۄۏڽأۗ‛‛أتثًوذوزأڬۄحەأۄۏڽأ=““أوّذٕثّشّۆُ¾أ‛‛أصۏىحأڬًأڬۄحەأۄۏڽأۗ‛‛

[تخریج]: @صحیح: أخرجہ ابوعبید فی فضائل القرآن ص (237۔238) والبیہقی فی الشعب (2615)"
3439,"تثًتهرۏشأڬۄحەأۄۏڽأؼخوتىأثىأؼلتىأشعۏأتههۄأؼىۄأىەألشوتۏتأ=““أدضأىەأشتحأڬًأضًشۄأإهأؼوشتىأڬتأإرشۏأذظۄأځڔہتأتضأڬەأهةەأشتحأڬتأمۏتوأهڬہتأدتحتأۄەأۗ‛‛

[تخریج]: #ضعیف: ابن لھیعہ ضعیف ہے، دیکھئے مشکاۃ المصابیح (2171)"
3440,"ۏذۏۏأثىأذتشخأڬۄحەأۄۏڽأڬۄأوڬذًهأىەألشوتۏتأ=““أدضأىەأدوؼۄأڬەأزىأضًشۄأإهأؼوشتىأځڔہۏأتضأڬەأهةەألشطحەأشتحأحڬأثرططأڬۏأزؼتأڬشحەأشۄحەأۄۏڽأۗ‛‛

[تخریج]: $صحیح: مشکاۃ المصابیح (2172)"
3441,"طؼثۏأڬۄحەأۄۏڽأؼثزتههۄأىەأڬۄتأ=““أإرشأشتحأڬًأحۄدزأوۏڽأضًشۆأإهأؼوشتىأڬتأځڔہىتأؽشۏثأڬەأهةەأرصتىۄأۄەأۗ‛‛

[تخریج]: ! صحیح: أخرجہ البیہقی فی الشعب (2616) وعبدالرزاق (6015)"
3442,"دشۏشۏأضەأوىمًهأۄەأڬۄأتثًضهۏهأىەأڬۄتأ=““أتۏڬأطرظأىەأمحهأڬشأڬەأًتزۏأودىۄأوۏڽأځىتۄأهۏأًۄتڽأدًأثہۏأدتحتأدىأتضأڬەأځتضأعشًشأإحەأتًشأًتزۏأڬەأڬىتشەأځشأزًأزشًۏطأشۄحەأحہەأدثأطتوأۄًةۏأحًأتىأوۏڽأضەأتۏڬأىەأتځىەأضتحہۏأضەأڬۄتأ=““أتههۄأڬۏأمضوأ$أۏۄأطرظأحًأۄهتڬأۄًأڲۏتأۗ‛‛أڬۄحەأۄۏڽأ=أتضأىەأضًشۆأإهأؼوشتىأځڔہىتأطشًؼأڬۏأحًأتىأزًىًڽأىەأڬۄتأ=““أۏۄأحًأځتڬۏصۄأضًشحأځڔہأشۄتأۄەأطتۏزأىدتحأځتأدتةەأڬۄحەأۄۏڽأ=أحًأًۄأشتحأڬًأظذۏذأضتهوأشۄتأۗأتثًوذوزأڬۄحەأۄۏڽأ=““أتثًتهضهۏهأعشۏثأثىأىمۏشأۄەأتًشأتثىأىلۏشأثہۏأڬۄتأدتحتأۄەأۗ‛‛

[تخریج]: @ضعیف: عبدالسلام کا ابواسحاق سے سماع متأخر ہے۔"
3443,"وضۏثأثىأشتلؼأڬۄحەأۄۏڽأؼثزتههۄأىەأڬۄتأ=““أضتحأهوثۏأضًشحۏڽأحًشتحأڬۏأوتىىزأۄۏڽأ‛أوةۏىأتىدۏهأڬۏأوتىىزأۄەأتًشأوختىۏأصثًشأڬۏأوتىىزأۄۏڽأتضأڬەأثؼزأحوتوأمشإىألعۏهحأًتهتأۄەأۗ‛‛

[تخریج]: ! منقطع، ضعیف: المسیب، ابن مسعود سے نہیں ملے، أخرجہ ابن ابی شیبہ 10/554( 10320)"
3444,"ؼثزتههۄأثىأرهۏلۄأضەأوىمًهأۄەأؼوشأشعۏأتههۄأؼىۄأىەأڬۄتأ=““أضًشۄأتىؼتوأمشإىأڬۏأرتظأضًشحًڽأوۏڽأضەأۄەأۗ‛‛

[تخریج]: @جید: أخرجہ ابوعبید فی فضائل القرآن (ص240:)"
3445,"ؼثزتههۄأثىأشثتذأڬۄحەأۄۏڽأ=أوۏڽأىەأڬؼثأضەأضىتأ؏أتىۄًڽأىەألشوتۏتأ=““أحًشتحأڬتأطشًؼأضًشۄأتىؼتوأۄەأتًشأتضأڬتأرحوأضًشۆأۄًزأۄەأۗ‛‛

[تخریج]: # صحیح: أخرجہ ابی شیبہ 10/555 (10323)"
3446,"ؼثزتههۄأثىأشثتذأڬۄحەأۄۏڽأىثۏأ﷽أىەألشوتۏتأ=““أدوؼۄأڬەأزىأضًشحأۄًزأځڔہًأۗ‛‛

[تخریج]: $ مرسل،ضعیف"
3447,"ڬؼثأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدوؼۄأڬەأزىأضًشحأۄًزأځڔہًأۗ‛‛

[تخریج]: % مرسل ضعیف: أخرجہ ابوداؤد، فی مراسیلہ (59) والبیہقی فی الشعب (2438) دیکھئے: الدرالمنشور 1/319"
3448,"ؼثزۄأڬۄحەأۄۏڽأرتهزأثىأوؼزتىأىەأڬۄتأ=““أدضأىەأضًشۆأڬۄلأڬۏأزضأإۏتحأځڔہۏڽأتضەأزدتهأڬتأرًلأىۄۏڽأۄًأڲتأۗ‛‛

[تخریج]: ! صحیح بالشاھد: أخرجہ مسلم، کتاب صلاۃ المسافرین، باب فضل سورۃ الکھف و آیۃ الکرسی (809) وابوعبید فی فضائل القرآن (ص245:)"
3449,"ؼثزۄأضەأوىمًهأۄەأڬۄأصشأثىأذثۏطأىەأڬۄتأ=““أشتحأڬۏأڬضۏأڲہڔۏأوۏڽأتټہىەأڬەأهةەأدًأطرظأضًشۆأڬۄلأڬتأإرشأځڔہەأڲتأًۄأتضۏأًمحأتټہەأڲتأۗ‛‛أؼثزۄأڬۄحەأۄۏڽأ=““أۄوأىەأتضەأإصوتۏتأحًأتۏضتأۄۏأځتۏتأۗ‛‛

[تخریج]: @ ضعیف: محمد بن کثیر ضعیف راوی ہے، أخرجہ ابوعبید فی فضائل القرآن (ص246:)"
3450,"مۏضأثىأؼثتزأضەأوىمًهأۄەأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأىەأڬۄتأ=““أدًأطرظأدوؼۄأڬۏأشتحأڬًأضًشۄأڬۄلأځڔہەأڲتأتضأڬەأهةەأثۏحأتهؼحۏمأحڬأشًطىۏأۄًأڲۏأۗ‛‛

[تخریج]: # صحیح: أخرجہ ابوعبید فی فضائل القرآن (ص244:) والبیہقی فی الشعب (2444) والنسائی فی عمل الیوم واللیلۃ (953) والحاکم (2072)"
3451,"ؼثزۄأثۏتىأڬشحەأۄۏڽأرتهزأثىأوؼزتىأىەأڬۄتأ=““أىدتحأزۏىەأًتهۏأضًشحأځڔہًأتًشأًۄأضًشحأضدزۄأۄەأڬۏًىڬۄأودہەأوؼهًوأۄًتأۄەأتۏڬأإزوۏأتضەأځڔہحتأحہتأتضأڬەأؼهتًۄأتًشأڬډہأىۄأځڔہحتأحہتأًۄأثۄحأڲىۄڲتشأحہتأۗأتضأضًشۆأىەأتځىەأثتصًأتضأځشأځہۏهتأڬشأڬۄتأ=““أتەأتههۄأ$أتضەأوؼتلأڬشأزەأ‛أڬۏًىڬۄأۏۄأودہەأڬخشحأضەأځڔہحتأحہتأۗ‛‛أتههۄأحؼتهۏٳأىەأتضأڬەأوحؼهمأتضأڬۏأضلتشطأمثًهأڬۏأتًشألشوتۏتأ=““أتضأڬەأهةەأۄشأڲىتۄأڬەأثزهۄأوۏڽأتۏڬأىۏڬۏأهڬہأزًأتًشأتضأڬەأزشدەأثهىزأڬشأزًأۗ‛‛

[تخریج]: !عبدۃ بنت خالد کا ترجمہ نہ مل سکا دیکھئے الدرالمنشور 5/170۔171"
3452,"ؼثزتههۄأثىأعوشۄأڬۄحەأۄۏڽأڬؼثأىەأڬۄتأ=““أدًأضًشۆأضدزۄأتًشأضًشۆأوهڬأځڔہەأڲتأتضأڬەأهةەأضحشأىۏڬۏتڽأهڬہۏأدتةۏڽأڲۏأتضأڬۏأضحشأثشتةۏتڽأوټتةۏأدتةۏڽأڲۏأتًشأتضأڬەأضحشأزشدەأثهىزأڬةەأدتةۏڽأڲەأۗ‛‛

[تخریج]: @ صحیح: أخرجہ ابن الضریس فی فضائل القرآن (213) دیکھئے الدر المنشور 5/170"
3453,"تثًرتهزأؼتوشأثىأدطۏثأتًشأثذۏشأثىأضؼزأثۏتىأڬشحەأۄۏڽأڬۄأرتهزأثىأوؼزتىأىەأڬۄتأ=““أضًشۆأضدزۄأتځىەأځڔہىەأًتهەأڬۏأغشلأضەأمثشأوۏڽأدہڲڔتأڬشەأڲۏأڬۄەأڲۏأ=““أتەأتههۄأ$أتڲشأوۏڽأحۏشۏأڬحتثأڬۏأضًشۆأۄًڽأحًأتضأڬەأهةەأوۏشۏأضلتشطأمثًهألشوتأتڲشأوۏڽأحۏشۏأڬحتثأڬۏأضًشۆأىۄۏڽأۄًڽأحًأودہەأتضأوۏڽأضەأوټتأزەأتًشأًۄأځشىزەأڬۏأغشذأتضأځشأتځىەأثتصًأځہۏهتةەأڲۏأۗ‛‛أحًأتضأڬەأهةەأتضأڬۏأضلتشطأمثًهأڬۏأدتةەأڲۏأتًشأتضأضەأمثشأڬتأؼستثأشًڬأزۏتأدتةەأڲتأتًشأضًشۆأوهڬأڬۏأثہۏأتضۏأغشذألعۏهحأۄەأۗ‛‛أتًشأرتهزأڬثہۏأتىأضًشحًڽأڬًأځڔہەأثؽۏشأضًحەأىۄۏڽأحہەأۗ

[تخریج]: ! ضعیف: عبداللہ بن صالح ضعیف ہے۔ امام ترمذی نے اسے مشکاۃ (2176) میں دارمی کے حوالے سے روایت کیا ہے۔ دیکھئے الدر المنشور 5/171"
3454,"ضۏٔزىتأدتثشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأىثۏأ﷽أضًشۆأضدزۄأتًشأضًشۆأوهڬأځڔہەأثؽۏشأىۄۏڽأضًحەأحہەأۗ

[تخریج]: @ صحیح اخرجہ البخاری، فی الأدب المفرد (1209) والحاکم (3545) والنسائی فی الکبریٰ (10542)"
3455,"هۏخأڬۄحەأۄۏڽأغتاضأىەأڬۄتأ=““أۏۄأضًشحۏڽأمشإىأڬۏأۄشأضًشحأضەأضتټہأزشدەأتلعهأۄۏڽأۗ‛‛

[تخریج]: # ضعیف: أخرجہ ابن الضریس فی فضائل القرآن (233) وعبدالرزاق (6035)"
3456,"ؼوشًأثىأوشۄأڬۄحەأۄۏڽأوۏڽأىەأتځىەأًتهزأضەأضىتأًۄأڬۄحەأحہەأ=““أتۏڬأإزوۏأڬۏأمثشأوۏڽألشطحەأإةەأۗأحًأًۄأمثشأڬەأڬىتشەأځشأۄًأڲۏتأۗأمشإىأڬۏأحۏضأإۏتحأتضأڬۏأغشلأضەأدہڲڔىەأهڲۏڽأوۏڽأىەأتًشأوضشًمأىەأزۏڬہتأضًشۆأوهڬأڬەأؼهتًۄأڬضۏأضًشۆأوۏڽأحۏضأإۏتحأىۄۏڽأۄۏڽأۗ‛‛

[تخریج]: !صحیح: أخرجہ ابن الضریس فی فضائل القرآن (234) وابوعبید فی فضائل القرآں (ص260:) والطبرانی فی الکبیر 9/140 (8651)"
3457,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأحؼتهۏٳأىەأإضوتىأًأصوۏىأځۏزتأڬشىەأضەأۄصتشأثشضأځۄهەأضًشۆأغۄأتًشأۏضۏىأځڔہۏألشطحًڽأىەأتضەأضىتأحًأڬۄتأ=““أتضأتوحأڬەأهةەأرًطرثشۏأۄەأدضأڬەأهةەأۏۄأىتصهأۄًأڲتأتًشأتىأځۏټًڽأڬەأهةەأرًطرثشۏأۄەأدًأتضەأتټہتةۏڽأڲەأتىأصثتىًڽأڬەأهةەأرًطرثشۏأۄەأدًأتضەأځڔہۏڽأڲۏأۗ‛‛

[تخریج]: @ ضعیف جدًا: ابن حبان وابن جوزی کہتے ہیں (ھذا متن موضوع) دیکھئے میزان الاعتدال 1/67، ومشکاۃ المصابیح (2148)"
3458,"وؼحوشأتځىەأًتهزأضەأثۏتىأڬشحەأۄۏڽأتىۄًڽأىەأڬۄتأ=أذضىأضەأوؼهًوأۄًتأتىۄًڽأىەأڬۄتأ=““أدًأتههۄأڬۏأشعتوىزۏأڬەأهةەأضًشۆأۏٳضۏىأځڔہەأڲتأًۄأثرطأزۏتأدتةەأڲتأتًشأودہەأۏۄأرثشأثہۏأځۄىډۏأڬۄأًۄأضتشەأمشإىأڬەأثشتثشأۄەأۗ‛‛

[تخریج]: ! منقطع،ضعیف: دیکھئے الدر المنشور 5/256"
3459,"ضۏٔزىتأتىضأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أۄشأډۏصأڬتأزهأۄەأتًشأمشإىأڬتأزهأضًشۆأۏضۏىأۄەأدًأتضەأځڔہەأڲتأڲًۏتأڬۄأتضأىەأزضأثتشأمشإىأځڔہتأۗ‛‛

[تخریج]: @ ضعیف: ہارون ابومحمد مجہول ہے۔ أخرجہ الترمذی، کتاب ثواب القرآن، باب ماجاء فی فضل یٰس (2889) والبیہقی فی الشعب (2460)"
3460,"ضۏٔزىتأتثًۄشۏشۄأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدًأطرظأتههۄأڬۏأشعتأذتظهأڬشىەأڬەأهةەأضًشۆأۏٳضۏىأځڔہەأڲتأتضەأتضۏأشتحأۄۏأثرطأزۏتأدتةەأڲتأۗ‛‛

[تخریج]: !منقطع، ضعیف"
3461,"ؼغتؤأثىأتثًشثتذأڬۄحەأۄۏڽأودہەأرثشأوهۏأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أدًأزىأڬەأطشًؼأوۏڽأضًشۆأۏضۏىأځڔہەأڲتأتضأڬۏأحوتوأذتدحۏڽأځًشۏأۄًڽأڲۏأۗ‛‛

[تخریج]: @ مرسل، ضعیف: أخرجہ البیہقی فی الشعب (2463) وابن حبان 2574"
3462,"طۄشأثىأذًطثأڬۄحەأۄۏڽأتثىأؼثتضأشعۏأتههۄأؼىۄأىەأڬۄتأ=““أدًأظثذأڬەأًمحأضًشۆأۏضۏىأځڔہەأڲتأطتوأحڬأًۄأزىأإضتىۏأضەأڲسشەأڲتأ‛أدًأشتحأڬًأتضەأځڔہەأڲتأظثذأحڬأتضأڬۏأشتحأإضتىۏأضەأڲسشەأڲۏأۗ‛‛

[تخریج]: # حسن: امام سیوطی الدرالمنشور میں کہتے ہیں۔ 5/257، أخرجہ الدارمی عن ابن عباس ، اور پھر اس حدیث کا ذکر کرتے ہیں۔"
3463,"ؼثزتههۄأثىأؼۏضۏٳأڬۄحەأۄۏڽأ=أودہەأرثشأزۏأڲةۏأڬۄأ““أدًأطرظأدوؼۄأڬۏأشتحأڬًأضًشۆأزرتىأتۏوتىأًأۏمۏىأضەأځڔہەأڲتأًۄأظثذأڬًأثرطتأۄًتأۄًأڲتأۗ‛‛

[تخریج]: $ صحیح: سیوطی الدرالمنشور میں کہتے ہیں 6/24۔25 ’’أخرج الدارمی‘‘ پھر اس حدیث کا تذکرہ کرتے ہیں نیز اس کی شاہد ’’ترمذی کتاب ثواب القرآن،باب ماجاء فی فضل حمٓ الدخان (2891) میں ہے۔"
3464,"ۏذۏۏأثىأذتشخأڬۄحەأۄۏڽأتثًشتلؼأىەأڬۄتأ=““أدًأطرظأدوؼۄأڬۏأشتحأڬًأضًشۆأزرتىأځڔہەأڲتأًۄأظثذأڬًأثرطتأۄًتأۄًأڲتأتًشأوًټۏأإىڬہًڽأًتهۏأذًشًڽأضەأتضأڬتأىڬتذأڬشأزۏتأدتةەأڲتأۗ‛‛

[تخریج]: ! صحیح: سیوطی الدرالمنشور6/24 میں دارمی کاحوالہ دیتے ہیں۔"
3465,"وضؼشأڬۄحەأۄۏڽأضؼزأثىأتثشتۄۏوأىەأڬۄتأ=““أذوأًتهۏأضًشحًڽأڬًأزهۄىۏڽأڬۄتأدتحتأحہتأۗ‛‛

[تخریج]: @ صحیح: أخرجہ ابن ابی شیبہ 10/557 (10333) والبیہقی فی الشعب (2482)"
3466,"ۄطتوأڬۄحەأۄۏڽأذضىأىەأڬۄتأ=““أدًأطرظأظثذأڬًأضًشۆأذطشأڬۏأإرشۏأحۏىأإۏتحأځڔہەأڲتأتڲشأًۄأتضأزىأوشأدتةەأڲتأحًأتضأځشأطۄزتؤأڬۏأوۄشأهڲتأزۏأدتةەأڲۏأتًشأتڲشأطتوأڬًأځڔہەأځہشأتضۏأشتحأوشأدتةەأحًأتضأځشأطۄزتؤأڬۏأوۄشأهڲتأزۏأدتةەأڲۏأۗ‛‛

[تخریج]: # صحیح: أخرجہ ابن الضریس فی فضائل القرآن (227) سیوطی اسے الدر المنشور میں 1/202اسے دارمی کی طرف منسوب کرتے ہیں۔"
3467,"رتهزأثىأوؼزتىأڬۄحەأۄۏڽأىثۏأ﷽أضًحەأًمحأوضثذتحأځڔہحەأحہەأۗأتًشألشوتحەأحہەأ=““أتضأوۏڽأتۏڬأإۏحأۄەأدًأۄصتشأإۏتحأڬەأثشتثشأۄەأۗ‛‛

[تخریج]: ! صحیح: أخرجہ احمد 4/128 والبیہقی فی الشعب (2503) وابوداؤد، کتاب الأدب، باب مایقول عندالنوم (5057)"
3468,"وؼمهأثىأۏضتشأڬۄحەأۄۏڽأىثۏأ﷽أىەألشوتۏتأ=““أدًأطرظأظثذأڬەأًمحأ®تّؼًْٕسْأثٓتههٔٳۄٓأتهضّٔوٓۏٕؼٓأتهٕؼّهٓۏٕوٓأوٓىّأتهطّٔۏٕغّتىٓأتهشّٔدٓۏٕوٓ¾أ‛‛أوۏڽأتههۄأحؼتهۏٳأضەأضىىەأتًشأدتىىەأڬۏأځىتۄأډتۄحتأۄًڽأطۏغتىأوشزًزأضەأ‛‛أځڔہأڬەأضًشۆأذطشأڬۏأإرشۏأحۏىأإۏتحأځڔہەأڲتأۗأتههۄأحؼتهۏٳأتضأڬەأهۏەأضحشأۄصتشألشطحەأومششأڬشەأڲتأدًأطتوأحڬأتضأڬەأهۏەأثرططأڬۏأزؼتأڬشحەأشۄۏڽأڲەأۗأتًشأتڲشأًۄأطتوأڬًأځڔہەأڲتأحًأظثذأحڬأتۏضەأۄۏأۄًأڲتأۗ‛‛

[تخریج]: @حسن: أخرجہ احمد 5/26، والترمذی، کتاب ثواب القرآن، باب فضل آخر سورۃ الحشر (2923)"
3469,"طؼثۄأثۏتىأڬشحەأۄۏڽأتثًذضىأوۄتدشأىەأڬۄتأ=““أصۏتزأڬەأصوتىۄأوۏڽأتۏڬأإزوۏأإۏتأوۏڽأىەأتضأضەأضىتأًۄأثۏتىأڬشحتأحہتأ=““أوۏڽأشضًهأتههۄأ﷽أڬەأضتحہأضلشأوۏڽأحہتأۗأوۏشتأڲہټىتأإځأڬەأڲہټىەأڬەأضتحہأوهتأۄًتأحہتأۗأإځأىەأتۏڬأإزوۏأڬًأضًشۆأڬتلشًىأځڔہحەأۄًةەأضىتأحًأإځأىەألشوتۏتأ=““أۏۄأطشڬأضەأثشۏأۄًأڲۏتأۗ‛‛أتًشأتۏڬأإزوۏأڬًأإځأىەأضًشۆأترهتظأځڔہحەأۄًةەأضىتأإځأىەألشوتۏتأ=““أتضەأثرطأزۏتأڲۏتأۗ‛‛

[تخریج]: !صحیح: جہالت صحابی قارح نہیں، أخرجہ ابن الضریس فی فضائل القرآن (305) والنسائی فی الکبریٰ (10540) احمد 4/63، 64،65"
3470,"لشًۄأثىأىًلهأتځىەأًتهزأضەأىمهأڬشحەأۄۏڽأ؏أتىۄًڽأىەأڬۄتأڬۄأشضًهأتههۄأ﷽أىەأڬضۏأإىەأًتهەأضەألشوتۏتأ=““أحوأڬضأهةەأإةەأۄًأآ‛‛أتضأىەأڬۄتأ=أتضأهةەأڬۄأإځأودہەأتۏضۏأډۏصأضڬہتةۏڽأدًأوۏڽأضًحەأًمحأځڔہًڽأإځأىەألشوتۏتأ=““أدثأحوأهۏټًأحًأضًشۆأڬتلشًىأځڔہأڬشأضًأدتاأۗأڬۏًىڬۄأتضأضەأطشڬأضەأثشتؤحأۄًحۏأۄەأۗ‛‛

[تخریج]: @ صحیح: أخرجہ ابوعبید فی فضائل القرآن (ص264:)"
3471,"تۏتضأثڬتهۏأثۏتىأڬشحەأۄۏڽأڬۄأىًلأثڬتهۏأىەأڬۄتأ=““أتههۄأحؼتهۏٳأىەأمشإىأڬەأحۏىأذظەأڬةەأۗأتًشأضًشۆأترهتظأڬًأمشإىأڬتأحۏضشتأذظۄأمشتشأزۏتأۗ‛‛

[تخریج]: ! ضعیف: ایاس اللبکائی مجہول ہے۔"
3472,"ضؼۏزأثىأوضۏثأڬۄحەأۄۏڽأتههۄأڬەأىثۏأ﷽أىەألشوتۏتأ=““أدًأطرظأضًشۆأترهتظأزضأوشحثۄأځڔہەأڲتأتضأڬەأهةەأدىحأوۏڽأتۏڬأوذهأثىتۏتأدتةەأڲتأۗأتًشأدًأطرظأحۏضأزلؼۄأځڔہەأڲتأتضأڬەأهةەأحۏىأوذهأثىتةەأدتةۏڽأڲەأۗ‛‛أضۏٔزىتأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأىەأڬۄتأ=أۏتأشضًهأتههۄأ$أتۏضتأۄۏأۄەأآأځہشأحًأۄوتشەأثۄحأضەأوذهأۄًأدتةۏڽأڲەأۗأشضًهأتههۄأ﷽أىەألشوتۏتأ=““أتههۄأحؼتهۏٳأتضأضەأثہۏأًضۏؼأڬشأضڬحتأۄەأۗ‛‛أتثًوذوزأڬۄحەأۄۏڽأ=““أتثًؼمۏهأصۄشۄأثىأوؼثزأۄۏڽأۗأهًڲأڬۄحەأحہەأًۄأتثزتهأضەأحہەأۗ‛‛

[تخریج]: @حسن لغیرہ: أخرجہ احمد3/437، وابن کثیر فی التفسیر 5/251 والطبرانی فی الکبیر20/185(397) و (398)"
3473,"ؼحثۄأثىأعوشۄأثىأذثۏثأتځىەأًتهزأضەأىمهأڬشحەأۄۏڽأڬۄأًۄأدثأڬًةۏأضًشحأځڔہحەأحہەأحًأتضأڬەأثؼزأضًشۆأترهتظأځڔہأهۏحەأحہەأۗ

[تخریج]: ! صحیح"
3474,"تثًزشزتؤأڬۄحەأۄۏڽأڬۄأشضًهأتههۄأ﷽أىەألشوتۏتأ=أڬۏتأحوۄتشتأڬًةۏأتضأضەأؼتدصأۄەأڬۄأڬًةۏأشتحأڬًأمشإىأڬتأحۄتةۏأذظۄأځڔہأهۏتأڬشەأآ““أهًڲًڽأىەأڬۄتأ=أۄوأڬوصًشأتًشأتضأضەأؼتدصأۄۏڽأۗ‛‛أډىتىډۄأإځأىەألشوتۏتأ=““أتههۄأحؼتهۏٳأىەأمشإىأڬًأحۏىأذظًڽأوۏڽأحمضۏوأڬۏتأتًشأضًشۆأترهتظأڬًأمشإىأڬتأحۄتةۏأذظۄأمشتشأزۏتأۗ‛‛

