hadiths[262]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}: 2131,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا الأَعْمَشُ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : حَدَّثَنَا أَصْحَابُ مُحَمَّد صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّ عَبْدَ اللہِ بْنَ زَیْدٍ الأَنْصَارِیَّ جَائَ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ , فَقَالَ : یَا رَسُولَ اللہِ ، رَأَیْتُ فِی الْمَنَامِ کَأَنَّ رَجُلاً قَامَ وَعَلَیْہِ بُرْدَانِ أَخْضَرَانِ عَلَی جِذْمَۃِ حَائِطٍ ، فَأَذَّنَ مَثْنَی ، وَأَقَامَ مَثْنَی ، وَقَعَدَ قَعْدَۃً ، قَالَ : فَسَمِعَ ذَلِکَ بِلاَلٌ ، فَقَامَ فَأَذَّنَ مَثْنَی ، وَأَقَامَ مَثْنَی ، وَقَعَدَ قَعْدَۃً۔ (ابوداؤد 507۔ ابن خزیمۃ 380)",,,2131 2132,"حَدَّثَنَا عَفَّانُ ، قَالَ حَدَّثَنَا ہَمَّامُ بْنُ یَحْیَی ، عَنْ عَامِرٍ الأَحْوَلِ ، أَنَّ مَکْحُولاً حَدَّثَہُ ، أَنَّ عَبْدَ اللہِ بْنَ مُحَیْرِیزٍ حَدَّثَہُ ، أَنَّ أَبَا مَحْذُورَۃَ حَدَّثَہُ ، قَالَ عَلَّمَنِی النَّبِیُّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ الأَذَانَ تِسْعَ عَشْرَۃَ کَلِمَۃً وَالإِقَامَۃَ سَبْعَ عَشْرَۃَ کَلِمَۃً ، الأَذَانُ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، حَیَّ عَلَی الصَّلاَۃِ ، حَیَّ عَلَی الصَّلاَۃِ ، حَیَّ عَلَی الْفَلاَحِ ، حَیَّ عَلَی الْفَلاَحِ ، اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إلَہَ إِلاَّ اللَّہُ۔\n\n وَالإِقَامَۃُ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ اللَّہُ أَکْبَرُ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، حَیَّ عَلَی الصَّلاَۃِ ، حَیَّ عَلَی الصَّلاَۃِ ، حَیَّ عَلَی الْفَلاَحِ ، حَیَّ عَلَی الْفَلاَحِ ، قَدْ قَامَتِ الصَّلاَۃُ ، قَدْ قَامَتِ الصَّلاَۃُ ، اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إلَہَ إِلاَّ اللَّہُ۔ (ابوداؤ9 503۔ ترمذی 192)",,,2132 2133,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ أَذَانُ ابْنِ عُمَرَ ، اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ، اللَّہُ أَکْبَرُ ، شَہِدْتُ أَنْ لاَ إِلَہَ إِلاَّ اللَّہُ ، شَہِدْتُ أَنْ لاَ إِلَہَ إِلاَّ اللَّہُ ، شَہِدْتُ أَنْ لاَ إِلَہَ إِلاَّ اللَّہُ ، ثَلاَثًا ، شَہِدْتُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ، شَہِدْتُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، شَہِدْتُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، ثَلاَثًا ، حَیَّ عَلَی الصَّلاۃِ، ثَلاَثًا ، حَیَّ عَلَی الْفَلاَحِ ، ثَلاَثًا ، اللَّہُ أَکْبَرُ ، أَحْسِبُہُ قَالَ : لاَ إِلَہَ إِلاَّ اللَّہُ۔",,,2133 2134,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ الأَذَانُ أَنْ یَقُولَ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، أَشْہَدُ أَنْ لاَ إِلَہَ إِلاَّ اللَّہُ ، أَشْہَدُ أَنْ لاَ إِلَہَ إِلاَّ اللَّہُ ، أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، حَیَّ عَلَی الصَّلاَۃِ ، حَیَّ عَلَی الصَّلاَۃِ ، حَیَّ عَلَی الْفَلاَحِ ، حَیَّ عَلَی الْفَلاَحِ ، اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ ، وَاللَّہُ أَکْبَرُ۔",,,2134 2135,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، قَالَ : کَانَ الْحَسَنُ ، یَقُولُ : اللَّہُ أَکْبَرُ ، أَشْہَدُ أَنْ لاَ إِلَہَ إِلاَّ اللَّہُ ، أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، حَیَّ عَلَی الصَّلاَۃِ ، حَیَّ عَلَی الْفَلاَحِ ، ثُمَّ یَرْجِعُ فَیَقُولُ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، أَشْہَدُ أَنْ لاَ إِلَہَ إِلاَّ اللَّہُ ، أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، حَیَّ عَلَی الصَّلاَۃِ ، حَیَّ عَلَی الْفَلاَحِ ، مَرَّتَیْنِ ، اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ۔",,,2135 2136,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخبرنَا سُلَیْمَانُ التَّیْمِیُّ ، عَنْ حَبِیبِ بْنِ قَیْسٍ ، عَنِ ابْنِ أَبِی مَحْذُورَۃَ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَخْفِضُ صَوْتَہُ بِالأَذَانِ مَرَّۃً مَرَّۃً ، حَتَّی إِذَا انْتَہَی إِلَی قَوْلِہِ : أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ، أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، رَجَعَ إِلَی قَوْلِہِ : أَشْہَدُ أَنْ لاَ إِلَہَ إِلاَّ اللَّہُ ، فَرَفَعَ بِہَا صَوْتَہُ مَرَّتَیْنِ مَرَّتَیْنِ ، حَتَّی إِذَا انْتَہَی إِلَی : حَیَّ عَلَی الصَّلاَۃِ ، قَالَ : الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ ، فِی الأَذَانِ الأَوَّلِ مِنَ الْفَجْرِ۔\n\n(ابوداؤد 502۔ احمد 3/409)",,,2136 2137,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : حَدَّثَنَا أَصْحَابُنَا ؛ أَنَّ رَجُلاً مِنَ الأَنْصَارِ جَائَ فَقَالَ : یَا رَسُولَ اللہِ ، إِنِّی لَمَّا رَجَعْتُ الْبَارِحَۃَ وَرَأَیْتُ مِنِ اہْتِمَامِکَ ، رَأَیْتُ کَأَنَّ رَجُلاً قَائِمًا عَلَی الْمَسْجِدِ عَلَیْہِ ثَوْبَانِ أَخْضَرَانِ فَأَذَّنَ ، ثُمَّ قَعَدَ قَعْدَۃً ، ثُمَّ قَامَ فَقَالَ مِثْلَہَا ، غَیْرَ أَنَّہُ قَالَ : قَدْ قَامَتِ الصَّلاَۃُ ، وَلَوْلاَ أَنْ تَقُولُوا لَقُلْتُ : إِنِّی کُنْتُ یَقْظَانًا غَیْرَ نَائِمٍ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَقَدْ أَرَاکَ اللَّہُ خَیْرًا ، فَقَالَ عُمَرُ : أَمَا إِنِّی قَدْ رَأَیْتُ مِثْلَ الَّذِی رَأَی ، غَیْرَ أَنِّی لَمَّا سُبِقْتُ اسْتَحْیَیْتُ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مُرُوا بِلاَلاً فَلْیُؤَذِّنْ۔ (ابوداؤد 507)",,,2137 2138,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بِنَحْوٍ مِنْہُ۔,,,2138 2139,حَدَّثَنَا جَرِیرٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ أَبِی مَحْذُورَۃَ ؛ أَنَّ أَذَانَہُ کَانَ مَثْنَی ، وَأَنَّ إِقَامَتَہُ کَانَتْ وَاحِدَۃً۔,,,2139 2140,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الْمُثَنَّی ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ بِلاَلٌ یَشْفَعُ الأَذَانَ ، وَیُوتِرُ الإِقَامَۃَ۔ (ابوداؤد 511۔ نسائی 1593)",,,2140 2141,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : أَظُنُّہُ عَنْ أَنَسٍ ، قَالَ : أُمِرَ بِلاَلٌ أَنْ یَشْفَعَ الأَذَانَ ، وَیُوتِرَ الإِقَامَۃَ۔ (مسلم 286۔ احمد 3/103)",,,2141 2142,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَنَسٍ ، قَالَ : أُمِرَ بِلاَلٌ أَنْ یَشْفَعَ الأَذَانَ ، وَیُوتِرَ الإِقَامَۃَ۔ (بخاری 607۔ مسلم 286)",,,2142 2143,حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ؛ أَنَّ أَبَاہُ کَانَ یَشْفَعُ الأَذَانَ ، وَیُوتِرُ الإِقَامَۃَ۔,,,2143 2144,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : الأَذَانُ مَثْنَی ، وَالإِقَامَۃُ وَاحِدَۃٌ۔",,,2144 2145,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، قَالَ : حدَّثَنِی رَجُلٌ فِی مَسْجِدِ الْکُوفَۃِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الإِقَامَۃُ وَاحِدَۃٌ ، قَالَ : کَذَلِکَ أَذَانُ بِلاَلٍ۔",,,2145 2146,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَقُولُ : الإِقَامَۃُ مَرَّۃً مَرَّۃً ، فَإِذَا قَالَ : قَدْ قَامَتِ الصَّلاَۃُ ، قَالَ : مَرَّتَیْنِ۔",,,2146 2147,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ مَکْحُولٍ ، قَالَ : أَقَمْتُ مَعَہُ بِدَابِقٍ ، فَلَمْ یَکُنْ یَزِیدُ عَلَی إِقَامَۃٍ ، وَلاَ یُؤَذِّنُ ، وَیَجْعَلُہَا وَاحِدَۃً۔",,,2147 2148,حَدَّثَنَا عَبْدَۃُ ، عَنْ إِسْمَاعِیلَ ، عَنْ أَبِی الْمُثَنَّی ؛ أَنَّ ابْنَ عُمَرَ کَانَ یَأْمُرُ الْمُؤَذِّنَ أَنْ یَشْفَعَ الأَذَانَ ، وَیُوتِرَ الإِقَامَۃَ ، لِیَعْلَمَ الْمَارُّ الأَذَانَ مِنَ الإِقَامَۃِ۔,,,2148 2149,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ عَبْدِ الرَّحْمَنِ بْنِ یَحْیَی ، عَنِ الہَجَنَّع بْنِ قَیْسٍ؛ أَنَّ عَلِیًّا کَانَ یَقُولُ: الأَذَانُ مَثْنَی وَالإِقَامَۃُ ، وَأَتَی عَلَی مُؤَذِّنٍ یُقِیمُ مَرَّۃً مَرَّۃً ، فَقَالَ : أَلاَ جَعَلْتَہَا مَثْنَی ؟ لاَ أُمَّ لِلْآخَرِ۔",,,2149 2150,حَدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ إسْمَاعِیلَ ، عَنْ عُبَیْدٍ مَوْلَی سَلَمَۃَ بْنِ الأَکْوَعِ ؛ أَنَّ سَلَمَۃَ بْنَ الأَکْوَعِ کَانَ یُثَنِّی الإِقَامَۃَ۔,,,2150 2151,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : کَانَ عَبْدُ اللہِ بْنُ زَیْدٍ الأَنْصَارِیُّ مُؤَذِّنُ النَّبِیِّ صَلَّی اللّٰہُ عَلَیْہِ وَسَلَّمَ یَشْفَعُ الأَذَانَ وَالإِقَامَۃَ۔\n\n(ترمذی 194۔ دار قطنی 241)",,,2151 2152,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، عَنْ شُعَیْبٍ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : إِذَا جَعَلْتَہَا إِقَامَۃً فَأَثْنِہَا۔",,,2152 2153,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ تَدَعُ أَنْ تُثَنِّیَ الإِقَامَۃَ۔",,,2153 2154,"حَدَّثَنَا عَفَّانُ ، قَالَ : حَدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِیَادٍ ، قَالَ : حَدَّثَنَا الْحَجَّاجُ بْنُ أَرْطَاۃَ ، قَالَ : حَدَّثَنَا أَبُو إِسْحَاقَ ، قَالَ : کَانَ أَصْحَابُ عَلِیٍّ ، وَأَصْحَابُ عَبْدِ اللہِ یَشْفَعُونَ الأَذَانَ وَالإِقَامَۃَ۔",,,2154 2155,"حَدَّثَنَا أَبُو أُسَامَۃُ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِنَّ بِلاَلاً کَانَ یُثَنِّی الأَذَانَ وَالإِقَامَۃَ۔\n\n(عبدالرزاق 1791۔ دار قطنی 35)",,,2155 2156,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : کَانَ آخِرُ أَذَانِ بِلاَلٍ : لاَ إِلَہَ إِلاَّ اللَّہُ۔ (نسائی 1615۔ دار قطنی 244)",,,2156 2157,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، وَالشَّعْبِیِّ ، قَالاَ : کَانَ آخِرُ أَذَانِ بِلاَلٍ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ۔",,,2157 2158,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی مَحْذُورَۃَ : أَنَّہُ أَذَّنَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، وَلأَبِی بَکْرٍ ، وَعُمَرَ ، وَکَانَ آخِرُ أَذَانِہِ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ۔",,,2158 2159,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، قَالَ : حَدَّثَنِی قَائِدُ أَبِی مَحْذُورَۃَ ، بِمِثْلِہِ",,,2159 2160,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَابِسٍ ، قَالَ : سَمِعْتُ أَبَا مَحْذُورَۃَ یَقُولُ فِی آخِرِ أَذَانِہِ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ ، إِلاَّ أَنَّ أَذَانَہُ کَانَ مَثْنَی ، وَأَنَّ إِقَامَتَہُ کَانَتْ وَاحِدَۃً ، وَخَاتِمَۃُ أَذَانِہِ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ۔",,,2160 2161,حَدَّثَنَا جَرِیرٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ أَبِی مَحْذُورَۃَ ، بِمِثْلِہِ۔,,,2161 2162,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَجْعَلُ آخِرَ أَذَانِہِ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ۔",,,2162 2163,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ عَابِسٍ ، قَالَ : سَمِعْتُ أَبَا مَحْذُورَۃَ ، یَقُولُ فِی آخِرِ أَذَانِہِ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ۔",,,2163 2164,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، قَالَ : سَمِعْتُ إِبْرَاہِیمَ ، یَقُولُ : آخِرَ الأَذَانِ اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ۔",,,2164 2165,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَزِیْدَ ، عَنْ أَبِی صَادِقٍ ؛ أَنَّہُ کَانَ یَجْعَلُ آخِرَ أَذَانِہِ : لاَ إِلَہَ إِلاَّ اللَّہُ ، وَاللَّہُ أَکْبَرُ ، وَقَالَ : ہَکَذَا کَانَ آخِرَ أَذَانِ بِلاَلٍ۔",,,2165 2166,"حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ ، عَنْ مُحَارِبِ بْنِ دِثَارٍ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ عَنْ أَبِی مَحْذُورَۃَ ، قَالَ : کَانَ آخِرُ الأَذَانِ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ۔ (نسائی 1616)",,,2166 2167,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ بِلاَلٍ ، قَالَ : کَانَ آخِرُ الأَذَانِ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ۔ (نسائی 1614)",,,2167 2168,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، قَالَ : کَانَ آخِرُ أَذَانِ أَبِی مَحْذُورَۃَ ، وَکَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَعَلَ لَہُ أَذَانَ مَکَّۃَ ، وَکَانَ آخِرُ أَذَانِہِ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ، لاَ إِلَہَ إِلاَّ اللَّہُ۔",,,2168 2169,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إِدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی سَہْلٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانَ آخِرُ أَذَانِ بِلاَلٍ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ۔",,,2169 2170,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی مَحْذُورَۃَ (ح) وَعَنْ طَلْحَۃَ ، عَنْ سُوَیْدٍ ، عَنْ بِلاَلٍ ؛ أَنَّہُ کَانَ آخِرُ تَثْوِیبِہِمَا : الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ۔ (ابوداؤد 505۔ ابن خزیمۃ)",,,2170 2171,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ سُوَیْدِ بْنِ غَفَلَۃَ ؛ أَنَّہُ أَرْسَلَ إِلَی مُؤَذِّنِہِ : إِذَا بَلَغْتَ حَیَّ عَلَی الْفَلاَحِ ، فَقُلِ : الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ ، فَإِنَّہُ أَذَانُ بِلاَلٍ۔",,,2171 2172,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ رَجُلٍ یُقَالُ لَہُ : إِسْمَاعِیلُ ، قَالَ : جَائَ الْمُؤَذِّنُ یُؤْذِن عُمَرَ بِصَلاَۃِ الصُّبْحِ ، فَقَالَ: الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ ، فَأُعْجِبَ بِہِ عُمَرُ ، وَقَالَ لِلْمُؤَذِّنِ : أَقِرَّہَا فِی أَذَانِکَ۔",,,2172 2173,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَقُولُ فِی أَذَانِہِ : الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ۔",,,2173 2174,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : قَالَ : لَیْسَ مِنَ السُّنَّۃِ أَنْ یَقُولَ فِی صَلاَۃِ الْفَجْرِ : الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ۔ (ابن خزیمۃ 386۔ دار قطنی 38)",,,2174 2175,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیِّبِ ، قَالَ : جَائَ بِلاَلٌ إِلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُؤْذِنُہُ بِالصَّلاَۃِ ، فَقِیلَ لَہُ : إِنَّہُ نَائِمٌ ، فَصَرَخَ بِلاَلٌ بِأَعْلَی صَوْتِہِ : الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ ، فَأُدْخِلَتْ فِی الأَذَانِ۔ (ابن ماجہ 716)",,,2175 2176,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ؛ أَنَّ أَبَاہُ کَانَ یَقُولُ فِی أَذَانِہِ : الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ ، الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ ، اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، لاَ إِلَہَ إِلاَّ اللَّہُ۔",,,2176 2177,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الْقَاسِمِ بْنِ أَبِی مُخَیْمِرَۃَ ، أَنَّہُ کَانَ یَقُولُ فِی أَذَانِہِ فِی التَّثْوِیبِ : الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ ، الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ۔",,,2177 2178,"حَدَّثَنَا ابْنُ إِدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ، قَالَ : کَانَ التَّثْوِیبُ عِنْدَہُمَا أَنْ یَقُولَ : حَیَّ عَلَی الصَّلاَۃِ ، الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ۔",,,2178 2179,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ حَکِیمِ بْنِ جُبَیْرٍ ، عَنْ عِمْرَانَ بْنِ أَبِی الْجَعْدِ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ؛ أَنَّہُ سَمِعَ مُؤَذِّنًا یَقُولُ فِی الْفَجْرِ : الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ ، فَقَالَ : لاَ تَزِیدنَّ فِی الأَذَانِ مَا لَیْسَ مِنْہُ۔",,,2179 2180,"حَدَّثَنَا أَبُوخَالِدٍ الأَحْمَرُ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی مَحْذُورَۃَ ؛ أَنَّہُ أَذَّنَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَلأَبِی بَکْرٍ ، وَعُمَرَ ، فَکَانَ یَقُولُ فِی أَذَانِہِ : الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ۔",,,2180 2181,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بَکْرٍ ، قَالَ : حَدَّثَنَا یَعلی بْنُ الْحَارِثِ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، قَالَ : سَمِعْتُ مُؤَذِّنَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، یَقُولُ : الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ۔",,,2181 2182,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زُبَیْدٍ ، عَنْ خَیْثَمَۃَ ، قَالَ : کَانُوا یُثَوِّبُونَ فِی الْعِشَائِ وَالْفَجْرِ۔",,,2182 2183,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ الأَصْبَہَانِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : مَا ابْتَدَعُوا بِدْعَۃً أَحَبَّ إِلَیَّ مِنَ التَّثْوِیبِ فِی الصَّلاَۃِ ، یَعْنِی : الْعِشَائَ وَالْفَجْرَ",,,2183 2184,حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی مَحْذُورَۃَ (ح) وَعَنْ طَلْحَۃَ ، عَنْ سُوَیْدٍ ، عَنْ بِلاَلٍ ؛ أَنَّہُمَا کَانَا لاَ یُثَوِّبَانِ إِلاَّ فِی الْفَجْرِ۔,,,2184 2185,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ سُوَیْدِ بْنِ غَفَلَۃَ ؛ أَنَّہُ أَرْسَلَ إِلَی مُؤَذِّنٍ لَہُ یُقَالُ لَہُ رَبَاحٌ : أَنْ لاَ یُثَوِّبَ إِلاَّ فِی الْفَجْرِ۔",,,2185 2186,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یُثَوِّبُونَ فِی الْعِشَائِ وَالْفَجْرِ۔",,,2186 2187,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ عِیسَی بْنِ أَبِی عَزَّۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : یُثَوَّبُ فِی الْعِشَائِ وَالْفَجْرِ۔",,,2187 2188,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یُثَوِّبُونَ فِی الْعَتَمَۃِ وَالْفَجْرِ ، وَکَانَ مُؤَذِّنُ إِبْرَاہِیمَ یُثَوِّبُ فِی الظُّہْرِ وَالْعَصْرِ ، فَلاَ یَنْہَاہُ۔",,,2188 2189,حَدَّثَنَا عَبَّادُ بْنُ العَوَّامٍ ، عَنْ حَجَّاجٍ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ بِلاَلاً رَکَزَ الْعَنَزَۃَ وَأَذَّنَ ، فَرَأَیْتُہُ یَدُورُ فِی أَذَانِہِ۔ (ترمذی 197۔ احمد 4/308),,,2189 2190,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : إذَا أَذَّنَ الْمُؤَذِّنُ اسْتَقْبَلَ الْقِبْلَۃَ ، وَکَانَ یَکْرَہُ أَنْ یَسْتَدِیرَ فِی الْمَنَارَۃِ\n\n وَکَانَ الْحَسَنُ یَقُولُ : یَسْتَقْبِلُ الْقِبْلَۃَ ، فَإذَا قَالَ : حَیَّ عَلَی الصَّلاَۃِ دَارَ ، فَإِذَا أَرَادَ أَنْ یَقُولَ : اللَّہُ أَکْبَرُ ، اسْتَقْبَلَ الْقِبْلَۃَ۔",,,2190 2191,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ (ح) وَعَنْ أَبِیہِ ، عَنِ الْمُغِیرَۃِ ، عَنْ إِبْرَاہِیمَ ، قَالاَ : الْمُؤَذِّنُ لاَ یُزِیلُ قَدَمَیْہِ۔",,,2191 2192,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ ، قَالَ : أَتَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالأَبْطَحِ ، فَخَرَجَ بِلاَلٌ فَأَذَّنَ ، قَالَ : فَکَأَنِّی أَنْظُرُ إِلَیْہِ یتبع فَاہُ ہَاہُنَا وَہَاہُنَا ، یَعْنِی : یَمِینًا وَشِمَالاً۔\n\n(بخاری 634۔ مسلم 360)",,,2192 2193,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ طَلْحَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یَسْتَقْبِلُ الْمُؤَذِّنُ بِالأَذَانِ وَالشَّہَادَۃِ وَالإِقَامَۃِ الْقِبْلَۃَ۔",,,2193 2194,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حُلاَّمِ بْنِ صَالِحٍ ، عَنْ فَائِدِ بْنِ بُکَیْرٍ ، قَالَ : خَرَجْتُ مَعَ حُذَیْفَۃَ إِلَی الْمَسْجِدِ صَلاَۃَ الْفَجْرِ ، وَابْنُ التَّیَّاحِ مُؤَذِّنُ الْوَلِیدِ بْنِ عُقْبَۃَ یُؤَذِّنُ ، وَہُوَ یَقُولُ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، أَشْہَدُ أَنْ لاَ إِلَہَ إِلاَّ اللَّہُ ، یَہْوِی بِأَذَانِہِ یَمِینًا وَشِمَالاً ، فَقَالَ حُذَیْفَۃُ : مَنْ یُرِدِ اللَّہُ أَنْ یَجْعَلَ رِزْقَہُ فِی صَوْتِہِ : فَعَلَ۔",,,2194 2195,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ قَالَ فِی الْمُؤَذِّنِ : یَضمُّ رِجْلَیْہِ ، وَیَسْتَقْبِلُ الْقِبْلَۃَ، فَإِذَا قَالَ : قَدْ قَامَتِ الصَّلاَۃُ ، قَالَ بِوَجْہِہِ عَنْ یَمِینِہِ وَشِمَالِہِ۔",,,2195 2196,حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ الحَجَّاجٍ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ بِلاَلاً ، رَکَزَ الْعَنَزَۃَ ، ثُمَّ أَذَّنَ ، وَوَضَعَ إِصْبَعَیْہِ فِی أُذُنَیْہِ۔,,,2196 2197,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : إِذَا أَذَّنَ الْمُؤَذِّنُ اسْتَقْبَلَ الْقِبْلَۃَ ، وَوَضَعَ إِصْبَعَیْہِ فِی أُذُنَیْہِ۔",,,2197 2198,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ نُسَیْرٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یُؤَذِّنُ عَلَی بَعِیرہ ، قَالَ سُفْیَانُ : قُلْتُ لَہُ: رَأَیْتُہُ یَجْعَلُ إِصْبَعَیْہِ فِی أُذُنَیْہِ ؟ قَالَ : لاَ۔",,,2198 2199,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ الأَذَانُ أَنْ یَقُولَ : اللَّہُ أَکْبَرُ ، اللَّہُ أَکْبَرُ ، ثُمَّ یَجْعَلُ إصْبَعَیْہِ فِی أُذُنَیْہِ ، وَأَوَّلُ مَنْ تَرَکَ إحْدَی إصْبَعَیْہِ فِی أُذُنَیْہِ ابْنُ الأَصَمِّ۔",,,2199 2200,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ إذَا أَذَّنَ اسْتَقْبَلَ الْقِبْلَۃَ فَأَرْسَلَ یَدَیْہِ ، فَإِذَا بَلَغَ : حَیَّ عَلَی الصَّلاَۃِ ، حَیَّ عَلَی الْفَلاَحِ ، أَدْخَلَ إصْبَعَیْہِ فِی أُذُنَیْہِ۔",,,2200 2201,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یُؤَذِّنَ عَلَی غَیْرِ وُضُوئٍ ، ثُمَّ یَنْزِلُ فَیَتَوَضَّأُ۔",,,2201 2202,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یُؤَذِّنَ عَلَی غَیْرِ وُضُوئٍ۔",,,2202 2203,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یُؤَذِّنَ الرَّجُلُ وَہُوَ عَلَی غَیْرِ وُضُوئٍ، فَإِذَا أَرَادَ أَنْ یُقِیمَ تَوَضَّأَ۔,,,2203 2204,حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ؛ أَنَّہُ کَانَ یُؤَذِّنُ عَلَی غَیْرِ وُضُوئٍ۔,,,2204 2205,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إِسْمَاعِیلَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ یُؤَذِّنَ غَیْرَ طَاہِرٍ ، وَیُقِیمَ وَہُوَ طَاہِرٌ۔",,,2205 2206,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَمْرِو بْنِ عُثْمَانَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا ، أَنْ یُؤَذِّنَ عَلَی غَیْرِ وُضُوئٍ۔,,,2206 2207,حَدَّثَنَا حِرْمِیُّ بْنُ عُمَارَۃَ بْنِ أَبِی حَفْصَۃَ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْخَالِقِ ، عَنْ حَمَّادٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یُؤَذِّنَ الرَّجُلُ وَہُوَ عَلَی غَیْرِ وُضُوئٍ۔,,,2207 2208,"حَدَّثَنَا عُمَرُ بْنُ ہَارُون، عَنِ الأَوْزَاعِیِّ، عَنِ الزُّہْرِیِّ، قَالَ: قَالَ أَبُو ہُرَیْرَۃَ : لاَ یُؤَذِّنُ الْمُؤَذِّنُ إِلاَّ مُتَوَضِّئًا۔",,,2208 2209,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ مَعْقِلِ بْنِ عُبَیْدِ اللہِ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَ أَنْ یُؤَذِّنَ الرَّجُلُ ، وَہُوَ عَلَی غَیْرِ وُضُوئٍ۔,,,2209 2210,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ ثُوَیْرٍ ، قَالَ : کُنْتُ مُؤَذِّنًا ، فَأَمَرَنِی مُجَاہِدٌ أَنْ لاَ أُؤَذِّنَ حَتَّی أَتَوَضَّأَ۔",,,2210 2211,حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ طَلْحَۃَ ، عَنْ أَبِی صَخْرَۃَ جَامِعِ بْنِ شَدَّادٍ ، عَنْ مُوسَی بْنِ عَبْدِ اللہِ بْنِ یَزِیدَ؛ أَنَّ سُلَیْمَانَ بْنِ صُرَدٍ ، کَانَتْ لَہُ صُحْبَۃٌ ، کَانَ یُؤَذِّنُ فِی الْعَسْکَرِ ، فَکَانَ یَأْمُرُ غُلاَمَہُ بِالْحَاجَۃِ فِی أَذَانِہِ۔,,,2211 2212,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، قَالَ : سَأَلْتُ یُونُسَ عَنِ الْکَلاَمِ فِی الأَذَانِ وَالإِقَامَۃِ ؟ فَقَالَ : حَدَّثَنِی عُبَیْدُ اللہِ بْنُ غَلاَّب ، عَنِ الْحَسَنِ ؛ أَنَّہُ لَمْ یَکُنْ یَرَی بِذَلِکَ بَأْسًا۔",,,2212 2213,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ (ح) وَحَجَّاجٍ ، عَنْ عَطَائٍ : أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا أَنْ یَتَکَلَّمَ الْمُؤَذِّنُ فِی أَذَانِہِ۔",,,2213 2214,"حَدَّثَنَا عَبَّادٌ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ، قَالَ: کَانَ قَتَادَۃُ، لاَ یَرَی بِذَلِکَ بَأْسًا، وَرُبَّمَا فَعَلَہُ فَتَکَلَّمَ فِی أَذَانِہِ۔",,,2214 2215,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَتَکَلَّمَ الْمُؤَذِّنُ فِی أَذَانِہِ ، وَلاَ بَیْنَ الأَذَانِ وَالإِقَامَۃِ۔,,,2215 2216,حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ؛ أَنَّ أَبَاہُ کَانَ یَتَکَلَّمُ فِی أَذَانِہِ۔,,,2216 2217,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، وَعَنْ أَبِی عَامِرٍ الْمُزَنِی ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُمَا کَرِہَا أَنْ یَتَکَلَّمَ حَتَّی یَفْرُغَ۔,,,2217 2218,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ یَکْرَہُ الْکَلاَمَ فِی الأَذَانِ۔,,,2218 2219,حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْمَاعِیلَ الأَزْرَقِ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَرِہَ الْکَلاَمَ فِی الأَذَانِ۔,,,2219 2220,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ أَنْ یَتَکَلَّمَ الْمُؤَذِّنُ فِی أَذَانِہِ ، حَتَّی یَفْرُغَ۔,,,2220 2221,"حَدَّثَنَا حَمَّادُ بْنُ مَعْقِلٍ ، عَنْ عُثْمَانَ بْنِ أَبِی رَوَّادٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : سَمِعْتُہُ یَقُولُ : إِذَا تَکَلَّمَ فِی إِقَامَتہ فَإِنَّہُ یُعِیدُ۔",,,2221 2222,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ أَنْ یَتَکَلَّمَ فِی أَذَانِہِ وَإِقَامَتِہِ حَتَّی یَفْرُغَ۔,,,2222 2223,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,2223 2224,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ یَتَکَلَّمَ الرَّجُلُ فِی إِقَامَتِہِ۔",,,2224 2225,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ نُسَیْر ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یُؤَذِّنُ عَلَی بَعِیرِہِ۔",,,2225 2226,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ السُّلَمِیِّ ، قَالَ : رَأَیْتُ رِبْعِیَّ بْنَ حِرَاشٍ یُؤَذِّنُ عَلَی بِرْذَوْنٍ۔",,,2226 2227,حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یُؤَذِّنَ الرَّجُلُ وَیُقِیمَ عَلَی رَاحِلَتِہِ ، ثُمَّ یَنْزِلَ فَیُصَلِّیَ۔,,,2227 2228,حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِاللہِ بْنِ عُمَرَ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ یُؤَذِّنُ عَلَی الْبَعِیرِ، وَیَنْزِلُ فَیُقِیمُ۔,,,2228 2229,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ الْخَیَّاطُ ، عَنِ الْعُمَرِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْمُجَبِّرِ ، قَالَ : رَأَیْتُ سَالِمًا یَقُومُ عَلَی غَرْزِ الرَّحْلِ فَیُؤَذِّنُ۔",,,2229 2230,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکِ الْہُنَائِیِّ ، عَنِ الْحَسَنِ الْعَبْدِیِّ ، قَالَ : رَأَیْتُ أَبَا زَیْدٍ ، صَاحِبَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَکَانَتْ رِجْلُہُ أُصِیبَتْ فِی سَبِیلِ اللہِ ، یُؤَذِّنُ وَہُوَ قَاعِدٌ۔",,,2230 2231,"حَدَّثَنَا حًفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یُؤَذِّنَ الرَّجُلَ وَہُوَ قَاعِدٌ۔",,,2231 2232,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَ أَنْ یُؤَذِّنَ وَہُوَ قَاعِدٌ ، إِلاَّ مِنْ عُذْرٍ۔,,,2232 2233,"حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لَہُ : یُؤَذِّنُ الرَّجُلُ وَہُوَ قَاعِدٌ ؟ قَالَ : لاَ، إِلاَّ مِنْ عِلَّۃٍ ، قُلْتُ : فَمِنْ نُعَاسٍ أَوْ کَسَلٍ ؟ قَالَ : لاَ۔",,,2233 2234,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ شَدَّادٍ مَوْلَی عِیَاضِ بْنِ عَامِرٍ ، عَنْ بِلاَلٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لاَ تُؤَذِّنْ حَتَّی تَرَی الْفَجْرَ ہَکَذَا ، وَمَدَّ یَدَیْہِ۔ (ابوداؤد 535۔ طبرانی 1121)",,,2234 2235,"حَدَّثَنَا أَبُو خَالِدٍ، عَنْ حَجَّاجٍ ، عَنْ طَلْحَۃَ ، عَنْ سُوَیْدٍ، عَنْ بِلاَلٍ، قَالَ: کَانَ لاَ یُؤَذِّنُ حَتَّی یَنْشَقَّ الْفَجْرُ۔",,,2235 2236,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی مَحْذُورَۃَ ؛ أَنَّہُ أَذَّنَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَلأَبِی بَکْرٍ ، وَعُمَرَ ، فَکَانَ لاَ یُؤَذِّنُ حَتَّی یَطْلُعَ الْفَجْرُ۔,,,2236 2237,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، قَالَتْ : مَا کَانُوا یُؤَذِّنُونَ حَتَّی یَنْفَجِرَ الْفَجْرُ۔",,,2237 2238,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَلِیِّ بْنِ عَلِیٍّ ، عَنْ إِبْرَاہِیمَ ، قَالَ : شَیَّعْنَا عَلْقَمَۃَ إِلَی مَکَّۃَ ، فَخَرَجْنَا بِلَیْلٍ ، فَسَمِعَ مُؤَذِّنًا یُؤَذِّنُ ، فَقَالَ : أَمَّا ہَذَا فَقَدْ خَالَفَ سُنَّۃَ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، لَوْ کَانَ نَائِمًا کَانَ أَخْیَرَ لَہُ ، فَإِذَا طَلَعَ الْفَجْرُ أَذَّنَ۔",,,2238 2239,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُلَیْمَانَ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ فُضَیْلِ بْنِ عَمْرٍو ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ أَنْ یُؤَذِّنَ قَبْلَ الْفَجْرِ۔,,,2239 2240,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ عُبید اللہ ، قَالَ : قُلْتُ لِنَافِعٍ : إِنَّہُمْ کَانُوا یُنَادُونَ قَبْلَ الْفَجْرِ ؟ قَالَ : مَا کَانَ النِّدَائُ إِلاَّ مَعَ الْفَجْرِ۔",,,2240 2241,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ، قَالَ: شَکُّوا فِی طُلُوعِ الْفَجْرِ فِی عَہْدِ ابْنِ عَبَّاسٍ، فَأَمَرَ مُؤَذِّنَہُ فَأَقَامَ الصَّلاَۃَ۔",,,2241 2242,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ شَرِیکٍ ، عَنِ ابْنِ سَالِمٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ یُؤَذِّنُ لِلصَّلاَۃِ حَتَّی یَدْخُلَ وَقْتُہَا۔",,,2242 2243,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ قَالاَ : إِذَا أَذَّنَ الْمُؤَذِّنُ اسْتَقْبَلَ الْقِبْلَۃَ۔",,,2243 2244,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ قَالَ فِی الْمُؤَذِّنِ : یَضُمُّ رِجْلَیْہِ وَیَسْتَقْبِلُ الْقِبْلَۃَ۔",,,2244 2245,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ حَجَّاجٍ ، عَنْ طَلْحَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یَسْتَقْبِلُ الْمُؤَذِّنُ بِأَوَّلِ أَذَانِہِ وَالشَّہَادَۃِ وَالإِقَامَۃِ : الْقِبْلَۃَ۔",,,2245 2246,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُ کَانَ یُعْجِبُہُمَا إِذَا أَذَّنَ الْمُؤَذِّنُ أَنْ یَسْتَقْبِلَ الْقِبْلَۃَ۔,,,2246 2247,"حَدَّثَنَا مَالِکُ بْنُ إِسْمَاعِیلَ ، قَالَ : حَدَّثَنَا زُہَیْرٌ ، قَالَ : حَدَّثَنَا أَبُو مَطَر الْجُعْفِیُّ ، قَالَ : أَذَّنْتُ مِرَارًا ، فَقَالَ لِی سُوَیْدٌ : إِذَا أَذَّنْتَ فَاسْتَقْبِلِ الْقِبْلَۃَ ، فَإِنَّہُ مِنَ السُّنَّۃِ۔",,,2247 2248,"حَدَّثَنَا مَرْحُومُ بْنُ عَبْدِ الْعَزِیزِ ، عَنْ أَبِیہِ ، عَنْ أَبِی الزُّبَیْرِ مُؤَذِّنِ بَیْتِ الْمَقْدِسِ ، قَالَ : جَائَنَا عُمَرُ بْنُ الْخَطَّابِ ، فَقَالَ : إِذَا أَذَّنْتَ فَتَرَسَّلْ ، وَإِذَا أَقَمْتَ فَاحْذِمْ۔",,,2248 2249,حَدَّثَنَا شَرِیکٌ ، عَنْ عُثْمَانَ ، عَنْ أَبِی جَعْفَرٍ ؛ أَنَّ ابْنَ عُمَرَ کَانَ یُرتِّل الأَذَانَ ، وَیَحْدُرُ الإِقَامَۃَ۔,,,2249 2250,"حَدَّثَنَا أَبُو أُسَامَۃَ ، وَعَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ، قَالَ : کَانَ یُعْجِبُہُمَا إِذَا أَخَذَ الْمُؤَذِّنُ فِی الإِقَامَۃِ أَنْ یَمْضِیَ وَلاَ یَتَرَسَّلُ۔",,,2250 2251,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی بَکْرِ بْنِ حَفْصٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَحْذِفُ الإِقَامَۃَ۔,,,2251 2252,"حَدَّثَنَا مَالِکٌ ، قَالَ : حَدَّثَنَا جعفر الأَحْمَرُ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یُرَتِّلُ فِی الأَذَانِ ، وَیُتْبِعُ الإِقَامَۃَ بَعْضَہَا بَعْضاً۔",,,2252 2253,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، وَمُسْلِمِ بْنِ أَبِی مَرْیَمَ ؛ أَنَّ عَلِیَّ بْنَ حُسَیْنٍ کَانَ یُؤَذِّنُ، فَإِذَا بَلَغَ : حَیَّ عَلَی الْفَلاَحِ ، قَالَ : حَیَّ عَلَی خَیْرِ الْعَمَلِ ، وَیَقُولُ : ہُوَ الأَذَانُ الأَوَّلُ۔",,,2253 2254,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَقُولُ فِی أَذَانِہِ : الصَّلاَۃُ خَیْرٌ مِنَ النَّوْمِ ، وَرُبَّمَا قَالَ : حَیَّ عَلَی خَیْرِ الْعَمَلِ۔",,,2254 2255,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ رُبَّمَا زَادَ فِی أَذَانِہِ : حَیَّ عَلَی خَیْرِ الْعَمَلِ۔",,,2255 2256,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، قَالَ : رَأَیْتُ أَبَا مَحْذُورَۃَ ، جَائَ وَقَدْ أَذَّنَ إِنْسَانٌ ، فَأَذَّنَ ہُوَ وَأَقَامَ۔",,,2256 2257,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ شَیْخٍ مِنْ أَہْلِ الْمَدِینَۃِ ، عَنْ بَعْضِ بَنِی مُؤَذِّنِی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : کَانَ ابْنُ أُمِّ مَکْتُومٍ یُؤَذِّنُ ، وَیُقِیمُ بِلاَلٌ ، وَرُبَّمَا أَذَّنَ بِلاَلٌ ، وَأَقَامَ ابْنُ أُمِّ مَکْتُومٍ۔ \n\n(ابن سعد 207)",,,2257 2258,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ یُؤَذِّنَ الرَّجُلُ ، وَیُقِیمَ غَیْرُہُ۔",,,2258 2259,"حَدَّثَنَا أَبُو أُسَامَۃُ ، عَنِ الْفَزَارِیِّ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّمَا یُقِیمُ مَنْ أَذَّنَ۔",,,2259 2260,"حَدَّثَنَا یَعْلَی ، قَالَ : حَدَّثَنَا الإِفْرِیقِیُّ ، عَنْ زِیَادِ بْنِ نُعَیْمٍ الْحَضْرَمِیِّ ، عَنْ زِیَادِ بْنِ الْحَارِثِ الصُّدَائِیِّ ، قَالَ : کُنْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَفَرٍ ، فَأَمَرَنِی فَأَذَّنْتُ ، فَأَرَادَ بِلاَلٌ أَنْ یُقِیمَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ أَخَا صُدَائٍ أَذَّنَ ، وَمَنْ أَذَّنَ فَہُوَ یُقِیمُ ، فَأَقَمْتُ۔ (ابوداؤد 515۔ ترمذی 199)",,,2260 2261,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ حَنْظَلَۃَ، عَنْ خَالِدٍ، قَالَ: کَانَ ابْنُ عُمَرَ إِذَا أَذَّنَ جَلَسَ، حَتَّی تَمَسَّ مَقْعَدَتُہُ الأَرْضَ۔",,,2261 2262,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا الأَعْمَشُ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : حَدَّثَنَا أَصْحَابُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّ بِلاَلاً أَذَّنَ مَثْنَی ، وَأَقَامَ مَثْنَی ، وَقَعَدَ قَعْدَۃً۔",,,2262 2263,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مَنْصُورِ بْنِ أَبِی الأَسْوَدِ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، قَالَ : یَقْعُدُ الْمُؤَذِّنُ فِی الْمَغْرِبِ فِیمَا بَیْنَ الأَذَانِ وَالإِقَامَۃِ۔",,,2263 2264,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ ابْنَ أُمِّ مَکْتُومٍ کَانَ یُؤَذِّنُ وَہُوَ أَعْمَی۔\n\n(مسلم 287۔ ابوداؤد 536)",,,2264 2265,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّ ابْنَ أُمِّ مَکْتُومٍ کَانَ یُؤَذِّنُ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ أَعْمَی۔,,,2265 2266,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ وَاصِلٍ الأَحْدَبِ ، عَنْ قَبِیصَۃَ بْنِ بُرْمَۃَ ، قَالَ : سَمِعْتُ ابْنَ مَسْعُودٍ ، یَقُولُ : مَا أُحِبُّ أَنْ یَکُونَ مُؤَذِّنُوکُمْ عُمْیَانَکُمْ ، قَالَ : وَحَسِبْتُہُ قَالَ ، وَلاَ قُرَّاؤُکُمْ",,,2266 2267,حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ عُقْبَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَرِہَ إِقَامَۃَ الأَعْمَی۔,,,2267 2268,حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ مَالِکِ بْنِ دِینَارٍ ، عَنْ أَبِی عَرُوبَۃَ ؛ أَنَّ ابْنَ الزُّبَیْرِ کَانَ یَکْرَہُ أَنْ یُؤَذِّنَ الْمُؤَذِّنُ وَہُوَ أَعْمَی۔,,,2268 2269,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُؤَذِّنَانِ : بِلاَلٌ ، وَابْنُ أُمِّ مَکْتُومٍ۔ (مسلم 287۔ دارمی 1191)",,,2269 2270,"حَدَّثَنَا یُونُسُ بْنُ محمد ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ مَنْصُورٍ ، قَالَ : کَانَ مُؤَذِّنُ إِبْرَاہِیمَ أَعْمَی۔",,,2270 2271,حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِیُّ ، عَنِ ابْنِ أَخِی الزُّہْرِیِّ ، عَنْ عَمِّہِ ، عَنْ مُحَمَّدِ بْنِ جُبَیْرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمْ یَکُنْ یُؤَذِّنُ فِی شَیْئٍ مِنَ الصَّلاَۃِ فِی السَّفَرِ إِلاَّ بِإِقَامَۃٍ ، إِلاَّ فِی صَلاَۃِ الصُّبْحِ، فَإِنَّہُ کَانَ یُؤَذِّنُ وَیُقِیمُ۔,,,2271 2272,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نافع ؛ أَنَّ ابْنَ عُمَرَ ، کَانَ یُقِیمُ فِی السَّفَرِ ، إِلاَّ فِی صَلاَۃِ الْفَجْرِ ، فَإِنَّہُ کَانَ یُؤَذِّنُ وَیُقِیمُ۔,,,2272 2273,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ مَالِکِ بْنِ الْحُوَیْرِثِ ، قَالَ : أَتَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمَعِی ابْنُ عَمٍّ لِی ، فَقَالَ : إِذَا سَافَرْتُمَا فَأَذِنَّا وَأَقِیمَا ، وَلْیَؤُمَّکُمَا أَکْبَرُکُمَا۔\n\n(بخاری 628۔ مسلم 293)",,,2273 2274,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یُؤْمَرُونَ فِی السَّفَرِ أَنْ یُؤَذِّنُوا وَیُقِیمُوا ، وَأَنْ یَؤُمَّہُمْ أَقْرَؤُہُمْ۔",,,2274 2275,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : تُجْزِئُہُ الإِقَامَۃُ إِلاَّ فِی الْفَجْرِ ، فَإِنَّہُمْ کَانُوا یَقُولُونَ : یُؤَذِّنُ وَیُقِیمُ۔",,,2275 2276,"حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِیلَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : قَالَ عُرْوَۃُ : إِذَا کُنْتَ فِی سَفَرٍ فَأَذِّنْ وَأَقِمْ ، وَإِنْ شِئْتَ فَأَقِمْ وَلاَ تُؤَذِّنْ۔",,,2276 2277,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : تُجْزِئُہُ الإِقَامَۃُ۔",,,2277 2278,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا کُنْتَ فِی بَیْتِکَ ، أَوْ فِی سَفَرِکَ أَجْزَأَتْکَ الإِقَامَۃُ ، وَإِنْ شِئْتَ أَذَّنْتَ ، غَیْرَ أَنْ لاَ تَدَعَ أَنْ تُثَنِّیَ الإِقَامَۃَ۔",,,2278 2279,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ سُئِلَ عَنِ الْمُسَافِرِینَ یُؤَذِّنُونَ وَیُقِیمُونَ ؟ قَالَ : تُجْزِئہُمُ الإِقَامَۃُ ، إِلاَّ أَنْ یَکُونُوا مُتَفَرِّقِینَ ، فَیُرِیدُ أَنْ یَجْمَعَہُمْ فَیُؤَذِّنُ وَیُقِیمُ۔",,,2279 2280,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، قَالَ : أَقَمْتُ مَعَ مَکْحُولٍ بِدَابِقٍ خَمْسَۃَ عَشَرَۃ ، فَلَمْ یَکُنْ یَزِیدُ عَلَی الإِقَامَۃِ وَلاَ یُؤَذِّنُ۔",,,2280 2281,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، قَالَ : إِذَا اجْتَمَعَ الْقَوْمُ فِی السَّفَرِ ، وَکَانَ مَنْزِلُہُمْ جَمِیعًا فَتُجْزِئہُمُ الإِقَامَۃُ۔",,,2281 2282,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الأَعْمَشِ ، عَنْ مَالِکِ بْنِ الْحَارِثِ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا مَعَ أَبِی مُوسَی ، بِعَیْنِ التَّمْرِ فِی دَارِ الْبَرِیدِ ، فَأَذَّنَ وَأَقَامَ ، فَقُلْنَا لَہُ : لو خَرَجْتَ إِلَی الْبَرِیَّۃِ ؟فَقَالَ : ذَاکَ وَذَا سَوَاء ٌ۔",,,2282 2283,"حَدَّثَنَا شَرِیکٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ؛ فِی رَجُلٍ نَسِیَ الإِقَامَۃَ فِی السَّفَرِ ، قَالَ : یُجْزِئُہُ ۔",,,2283 2284,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی مُسَافِرٍ نَسِیَ ، فَصَلَّی بِغَیْرِ أَذَانٍ وَلاَ إِقَامَۃٍ ، قَالَ : یُجْزِئُہُ، وَکَانَ یَقُولُ فِی الْمُقِیمِ مِثْلَ ذَلِکَ",,,2284 2285,"حَدَّثَنَا ابن فُضَیْلٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : إِذَا نَسِیَ الإِقَامَۃَ فِی السَّفَرِ أَجْزَأَہُ۔",,,2285 2286,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ عَطَائٍ ، قَالَ : إِذَا کُنْتَ فِی سَفَرٍ فَلَمْ تُؤَذِّنْ وَلَمْ تُقِمْ، فَأَعِدِ الصَّلاَۃَ۔",,,2286 2287,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لیث ، عَنْ مُجَاہِدٍ ، قَالَ : إِذَا نَسِیَ الإِقَامَۃَ فِی السَّفَرِ أَعَادَ۔",,,2287 2288,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إِسْمَاعِیلَ بْنِ أُمَیَّۃَ (ح) وَعَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ نَسِیَ الإِقَامَۃَ ، قَالَ : یُعِیدُ۔",,,2288 2289,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ صَلاَۃَ إِلاَّ بِإِقَامَۃِ۔",,,2289 2290,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، قَالَ : قَالَ عَلِیٌّ : أَیُّمَا رَجُلٍ خَرَجَ إِلَی أَرْضِ قِیٍّ ، فَحَضَرَتِ الصَّلاَۃُ ، فَلْیَتَخَیَّرْ أَطْیَبَ الْبِقَاعِ وَأَنْظَفَہَا ، فَإِنَّ کُلَّ بُقْعَۃٍ تُحِبُّ أَنْ یُذْکَرَ اللَّہُ فِیہَا ، فَإِنْ شَائَ أَذَّنَ وَأَقَامَ ، وَإِنْ شَائَ أَقَامَ إِقَامَۃً وَاحِدَۃً وَصَلَّی۔",,,2290 2291,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، عَنْ أَبِی عُثْمَانَ ، عَنْ سَلْمَانَ ، قَالَ : لاَ یَکُونُ رَجُلٌ بِأَرْضِ قِیٍّ فَیَتَوَضَّأُ ، فَإِنْ لَمْ یَجِدْ مَائً تَیَمَّمَ ، ثُمَّ یُنَادِی بِالصَّلاَۃِ ، ثُمَّ یُقِیمُہَا ، إِلاَّ أَمَّ مِنْ جُنُودِ اللہِ مَا لاَ یُرَی طَرَفَاہُ۔\n\n(بیہقی 406۔ عبدالرزاق 1955)",,,2291 2292,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَبِی ہَارُونَ الْغَنَوِیِّ ، قَالَ : حَدَّثَنَا أَبُو عُثْمَانَ ، قَالَ : قَالَ سَلْمَانُ : مَا کَانَ رَجُلٌ فِی أَرْضِ قِیٍّ فَأَذَّنَ وَأَقَامَ ، إِلاَّ صَلَّی خَلْفَہُ مِنْ خَلْقِ اللہِ مَا لاَ یُرَی طَرَفَاہُ۔",,,2292 2293,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ ؛ فِی الرَّجُلِ یُصَلِّی وَحْدَہُ : یُؤَذِّنُ وَیُقِیمُ۔\n\n وَقَالَ ابْنُ سِیرِینَ : عَنْ رَجُلٍ کَانَ یُفَقَّہُ : یُقِیمُ وَلاَ یُؤَذِّنُ إِلاَّ فِی صَلاَۃِ الصُّبْحِ ، فَإِنَّہُ یُؤَذِّنُ فِیہَا وَیُقِیمُ۔",,,2293 2294,"حَدَّثَنَا مُعْتَمِرٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : کَانُوا یَرَوْنَ إِذَا صَلَّی فِی الْمِصْرِ وَحْدَہُ ، فَإِنَّہُ تُجْزِئُہُ الإِقَامَۃُ ، إِلاَّ فِی الْفَجْرِ ، فَإِنَّہُ یُؤَذِّنُ وَیُقِیمُ۔\n\n قَالَ : وَکَانَ ابْنُ سِیرِینَ ، یَقُولُ مِثْلَ ذَلِکَ۔",,,2294 2295,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ عَطَائٍ ؛ أَنَّ رَجُلاً قَالَ لَہُ : إِذَا کُنْتُ وَحْدِی أُؤَذِّنُ وَأُقِیمُ ؟ قَالَ : نَعَمْ۔",,,2295 2296,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إِسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : سَأَلْتُہُ إِذَا کُنْتُ وَحْدِی عَلَیَّ أَذَانٌ ؟ قَالَ : نَعَمْ ، أَذِّنْ وَأَقِمْ۔",,,2296 2297,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ أَبِی یُؤَذِّنُ لِنَفْسِہِ وَیُقِیمُ۔",,,2297 2298,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی عَاصِمٍ الثَّقَفِیِّ ، قَالَ : حَدَّثَنَا عَطَائٌ ، قَالَ : دَخَلْتُ مَعَ عَلِیِّ بْنِ الْحُسَیْنِ عَلَی جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : فَحَضَرَتِ الصَّلاَۃُ فَأَذَّنَ وَأَقَامَ۔",,,2298 2299,"حَدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یُصَلِّی فِی بَیْتِہِ بِإِقَامَۃِ النَّاسِ۔",,,2299 2300,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : إِذَا صَلَّی الرَّجُلُ فِی بَیْتِہِ کَفَتْہُ الإِقَامَۃُ۔",,,2300 2301,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یُصَلِّی فِی بَیْتِہِ عَلَی غَیْرِ إِقَامَۃٍ ، قَالَ : إِنْ أَقَامَ فَہُوَ أَفضل ، وَإِنْ لَمْ یَفْعَلْ أَجْزَأَہُ۔",,,2301 2302,"حَدَّثَنَا شَبَابَۃُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : بَلَغَنَا أَنَّ رِجَالاً مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، کَانَ أَحَدُہُمْ إذَا صَلَّی فِی دَارِہِ أَذَّنَ بِالأَولَی ، وَالإِقَامَۃِ فِی کُلِّ صَلاَۃٍ۔",,,2302 2303,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، وَعَلْقَمَۃَ ، قَالاَ : أَتَیْنَا عَبْدَ اللہِ فِی دَارِہِ ، فَقَالَ : أَصَلَّی ہَؤُلاَئِ خَلْفَکُمْ ؟ قُلْنَا : لاَ ، قَالَ : فَقُومُوا فَصَلُّوا ، فَلَمْ یَأْمُرْ بِأَذَانٍ ، وَلاَ إقَامَۃٍ۔\n\n(مسلم 378۔ نسائی 618)",,,2303 2304,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ ، عَنْ عَبْدِ اللہِ بْنِ وَاقِدٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یُقِیمُ فِی أَرْضٍ تُقَامُ بِہَا الصَّلاَۃُ۔,,,2304 2305,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَلَمَۃَ أَبِی بِشْرٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : إذَا صَلَّیْت فِی مَنْزِلِکَ أَجْزَأَک مُؤَذِّنُ الْحَیِّ۔",,,2305 2306,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا کُنْتَ فِی مِصْرکَ ، أَجْزَأَک إقَامَتُہُمْ۔",,,2306 2307,"حَدَّثَنَا أَبُو سَلَمَۃَ ، عَنِ أَبِی الضُّحَی ، عَنِ الشَّعْبِیِّ ، قَالَ : یُجْزِئُہُ إقَامَۃُ الْمِصْرِ۔",,,2307 2308,حَدَّثَنَا وَکِیعٌ ، عَنْ دَلْہَمِ بْنِ صَالِحٍ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ فِی سَفَرٍ فَسَمِعَ إقَامَۃَ مُؤَذِّنٍ فَصَلَّی بِأَصْحَابِہِ۔,,,2308 2309,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ؛ أَنْ أَبَاہُ صَلَّی فِی بَیْتِہِ مِنْ عُذْرٍ بِإِقَامَۃِ النَّاسِ۔,,,2309 2310,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا سَمِعْتَ الإِقَامَۃَ وَأَنْتَ فِی بَیْتِکَ ، کَفَتْک إِنْ شِئْت۔",,,2310 2311,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنِ الْمُنْذِرِ بْنِ ثَعْلَبَۃَ ، قَالَ : سَأَلْتُ أَبَا مِجْلَزٍ فَقُلْتُ : أَنَا فِی قَرْیَۃٍ تُقَامُ فِیہَا الصَّلاَۃُ فِی جَمَاعَۃٍ ، فَإِنْ صَلَّیْت وَحْدِی أُؤَذِّنُ وَأُقِیمُ ؟ قَالَ : إِنْ شِئْتَ کَفَاکَ أَذَانُ الْعَامَّۃِ ، وَإِنْ شِئْتَ فَأَذِّنْ وَأَقِمْ۔",,,2311 2312,حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنِ الْجَعْدِ أَبِی عُثْمَانَ، عَنْ أَنَسٍ؛ أَنَّہُ دَخَلَ الْمَسْجِدَ وَقَدْ صَلَّوْا فَأَمَرَ رَجُلاً فَأَذَّنَ وَأَقَامَ۔,,,2312 2313,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، وَعَطَائٍ ، وَمُجَاہِدٍ قَالُوا : إذَا دَخَلْت مَسْجِدًا وَقَدْ أُقِیمَتْ فِیہِ الصَّلاَۃُ ، أَوْ لَمْ تَقُمْ ، فَأَقِمْ ثُمَّ صَلِّ۔",,,2313 2314,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنِ الزُّہْرِیِّ ، قَالَ : یُؤَذِّنُ وَیُقِیمُ۔",,,2314 2315,"حَدَّثَنَا أَبُو دَاوُد ، عَنْ مُحَمَّدِ بْنِ سُلَیْمٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الْقَوْمِ یَنْتَہُونَ إلَی الْمَسْجِدِ وَقَدْ صُلِّیَ فِیہِ ، قَالَ : یُؤَذِّنُونَ وَیُقِیمُونَ ، وَقَالَ : قتَادَۃُ : لاَ یَأْتِیک مِنْ شَہَادَۃِ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ وَأَنَّ مُحَمَّدًا رَسُولُ اللہِ إِلاَّ خَیْرٌ۔",,,2315 2316,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنْ یَزِیدَ ، عَنِ ابْنِ أَبِی لَیْلَی ؛ أَنَّہُ سَأَلَ رَجُلٌ قَالَ : دَخَلْتُ الْمَسْجِدَ وَقَدْ صَلَّی أَہْلُہُ ، أَأُؤَذِّنُ ؟ قَالَ : قَدْ کُفِیت ذَلِکَ۔",,,2316 2317,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ یَنْتَہِی إلَی الْمَسْجِدِ وَقَدْ صُلِّیَ فِیہِ ، قَالَ : لاَ یُؤَذِّنُ ، وَلاَ یُقِیمُ۔",,,2317 2318,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، قَالَ : دَخَلْت مَعَ إبْرَاہِیمَ مَسْجِدَ مُحَارِبٍ ، فَأَمَّنِی وَلَمْ یُؤَذِّنْ وَلَمْ یُقِمْ۔",,,2318 2319,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ؛ أَنَّ رَجُلاً جَائَ إلَی الْمَسْجِدِ وَقَدْ صَلَّوْا فَذَہَبَ یُقِیمُ ، فَقَالَ لَہُ عُرْوَۃُ : مَہْ ، فَإِنَّا قَدْ أَقَمْنَا۔",,,2319 2320,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرائِل ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَمُجَاہِدٍ ، وَعِکْرِمَۃَ قَالُوا : إذَا دَخَلَ الْمَسْجِدَ وَقَدْ صُلِّیَ فِیہِ فَلاَ یُؤَذِّنُ وَلاَ یُقِیمُ۔",,,2320 2321,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : أَذَّنَ بِلاَلٌ بِلَیْلٍ ، فَأَمَرَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُنَادِیَ : نَامَ الْعَبْدُ ، فَرَجَعَ فَنَادَی : نَامَ الْعَبْدُ ، وَہُوَ یَقُولُ : \n\nلَیْتَ بِلاَلاً لَمْ تَلِدْہُ أُمُّہُ\n\nوَابْتَلَّ مِنْ نَضْحِ دَمٍ جَبِینُہُ\n\nقَالَ : وَبَلَغَنَا أَنَّہُ أَمَرَہُ أَنْ یُعِیدَ الأَذَانَ۔ (دار قطنی 54۔ 55)",,,2321 2322,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی رَوَّادٍ ، عَنْ نَافِعٍ ؛ أَنَّ مُؤَذِّنًا لِعُمَرَ یُقَالُ لَہُ : مَسْرُوحٌ أَذَّنَ قَبْلَ الْفَجْرِ ، فَأَمَرَہُ عُمَرُ أَنْ یُعِیدَ۔",,,2322 2323,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ أَبِی مُوسَی ، قَالَ : کَانَ الْحَسَنُ إذَا ذُکِرَ عِنْدَہُ ہَؤُلاَئِ الَّذِینَ یُؤَذِّنُونَ بِلَیْلٍ، قَالَ : عُلُوجٌ فُرَّاغٌ لاَ یُصَلُّونَ إِلاَّ بِإِقَامَۃٍ ، لَوْ أَدْرَکَہُمْ عُمَرُ بْنُ الْخَطَّابِ لأَوْجَعَہُمْ ضَرْبًا ، أَوْ لأَوْجَعَ رُؤُوسَہُمْ۔",,,2323 2324,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، وَابْنُ نُمَیْرٍ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُؤَذِّنَانِ یُؤَذِّنَانِ ، زَادَ فِیہِ ابْنُ نُمَیْرٍ : ابْنُ أُمِّ مَکْتُومٍ وَبِلاَلٌ۔",,,2324 2325,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنِ السَّائِبِ بْنِ یَزِیدَ ابْنِ أُخْتِ نَمِرٍ ، قَالَ : مَا کَانَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلاَّ مُؤَذِّنٌ وَاحِدٌ ، یُؤَذِّنُ إذَا قَعَدَ عَلَی الْمِنْبَرِ وَیُقِیمُ إذَا نَزَلَ ، ثُمَّ أَبُو بَکْرٍ کَذَلِکَ ، ثُمَّ عُمَرُ کَذَلِکَ ، حَتَّی کَانَ عُثْمَانَ ، وَفَشَا النَّاسُ وَکَثُرُوا ، زَادَ النِّدَائَ الثَّالِثَ عِنْدَ الزَّوَالِ ، أَوِ الزَّوْرَائِ۔ (بخاری 912۔ ابوداؤد 1080)",,,2325 2326,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدِ بْنِ سِیرِینَ ، قَالاَ : لَیْسَ علَی النِّسَائِ أَذَانٌ ، وَلاَ إقَامَۃٌ۔",,,2326 2327,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ عَلَی النِّسَائِ أَذَانٌ ، وَلاَ إقَامَۃٌ۔",,,2327 2328,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ قَالُوا : لَیْسَ عَلَی النِّسَائِ أَذَانٌ ، وَلاَ إقَامَۃٌ۔",,,2328 2329,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَیْسَ عَلَی النِّسَائِ أَذَانٌ ، وَلاَ إقَامَۃٌ۔",,,2329 2330,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، مِثْلَ ذَلِکَ۔,,,2330 2331,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا نَسْأَلُ أَنَسًا ہَلْ عَلَی النِّسَائِ أَذَانٌ وَإِقَامَۃٌ ؟ قَالَ : لاَ ، وَإِنْ فَعَلْنَ فَہُوَ ذِکْرٌ۔",,,2331 2332,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ رَبِّہِ ، عَنِ امْرَأَۃٍ مِنْ أَہْلِ مَکَّۃَ ، قَالَتْ : قُلْتُ لِجَابِرِ بْنِ زَیْدٍ : ہَلْ عَلَیَّ إقَامَۃٌ ؟ قَالَ: لاَ۔",,,2332 2333,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لَیْسَ عَلَی النِّسَائِ أَذَانٌ ، وَلاَ إقَامَۃٌ۔",,,2333 2334,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ رَجُلٍ ، عَنْ عَلِیٍّ ، قَالَ : لاَ تُؤَذِّنُ ، وَلاَ تُقِیمُ۔",,,2334 2335,"حَدَّثَنَا حَرَمِیُّ بْنُ عُمَارَۃَ، عَنْ غَالِبِ بْنِ سُلَیْمَانَ، عَنِ الضَّحَّاکِ، قَالَ: لَیْسَ عَلَی النِّسَائِ أَذَانٌ، وَلاَ إقَامَۃٌ۔",,,2335 2336,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنْ عَائِشَۃَ ، أَنَّہَا کَانَتْ تُؤَذِّنُ وَتُقِیمُ۔,,,2336 2337,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ؛ مِثْلَہُ۔,,,2337 2338,"حَدَّثَنَا أَبُو خَالِدٍ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ وَہْبِ بْنِ کَیْسَانَ، قَالَ: سُئِلَ ابْنُ عُمَرَ ، ہَلْ عَلَی النِّسَائِ أَذَانٌ؟ فَغَضِبَ ، قَالَ : أَنَا أُنْہِی عَنْ ذِکْرِ اللہِ۔",,,2338 2339,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ ، عَنْ حَفْصَۃَ ، قَالَ : إِنَّہَا کَانَتْ تُقِیمُ إذَا صَلَّتْ۔",,,2339 2340,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی الأَسْلَمِیُّ ، وَابْنُ یَمَانٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : لَیْسَ عَلَی النِّسَائِ إقَامَۃٌ۔",,,2340 2341,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ وَطاووس ؛ أَنَّ عَائِشَۃَ کَانَتْ تُؤَذِّنُ وَتُقِیمُ۔,,,2341 2342,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ سَالِمٍ ، قَالَ : إِنْ شِئْنَ أَذَّنَّ۔",,,2342 2343,"حَدَّثَنَا مَالِکُ بْنُ إسْمَاعِیلَ ، قَالَ : حَدَّثَنَا ہُرَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : تُقِیمُ الْمَرْأَۃُ إِنْ شَائَتْ۔",,,2343 2344,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : أَمَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِلاَلاً أَنْ یُؤَذِّنَ یَوْمَ الْفَتْحِ فَوْقَ الْکَعْبَۃِ۔ (عبدالرزاق 19464)",,,2344 2345,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیْرِیِّ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ ، قَالَ : مِنَ السُّنَّۃِ الأَذَانُ فِی الْمَنَارَۃِ ، وَالإِقَامَۃُ فِی الْمَسْجِدِ ، وَکَانَ عَبْدُ اللہِ یَفْعَلُہُ۔",,,2345 2346,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ قَالَ : سَأَلْتُ عَنْ رَجُلٍ أَرَادَ أَنْ یُؤَذِّنَ فَأَقَامَ ؟ قَالَ : یُعِیدُ ، وَقَالَ سُفْیَانُ : یَجْعَلُہُ أَذَانًا وَیُقِیمُ۔",,,2346 2347,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَبِی کُدَیْنَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَرَادَ أَنْ یُؤَذِّنَ فَأَقَامَ ، قَالَ: یَرْجِعُ۔",,,2347 2348,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَیَانٍ ، عَنْ قَیْسٍ ، قَالَ : قَالَ عُمَرُ : لَوْ أَطَقْتُ الأَذَانَ مَعَ الْخِلِّیفَی لأَذَّنْتُ۔",,,2348 2349,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ ضِرَارٍ ، عَنْ زَاذَانَ ، قَالَ : لَوْ یَعْلَمُ النَّاسُ مَا فِی فَضْلِ الأَذَانِ لاَضْطَرَبُوا عَلَیْہِ بِالسُّیُوفِ۔",,,2349 2350,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ سَعْدٍ ، قَالَ : لأَنْ أَقْوَی عَلَی الأَذَانِ أَحَبُّ ، إلَیَّ مِنْ أَنْ أَحُجَّ وَأَعْتَمِرَ وَأُجَاہِدَ۔",,,2350 2351,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ مُصْعَبِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ کَعْبٍ ، قَالَ : مَنْ أَذَّنَ کُتِبَتْ لَہُ سَبْعُونَ حَسَنَۃً ، وَإِنْ أَقَامَ فَہُوَ أَفْضَلُ۔",,,2351 2352,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبَّادِ بْنِ إِسْحَاقَ ، عَنْ سُہَیْلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : اللَّہُمَّ أَرْشِدِ الأَئِمَّۃَ ، وَاغْفِرْ لِلْمُؤَذِّنِینَ۔ (عبدالرزاق 1839۔ احمد 419)",,,2352 2353,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ ، عَنْ یَحْیَی ، قَالَ : حُدِّثْتُ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَوْ عَلِمَ النَّاسُ مَا فِی الأَذَانِ لَتَجَارَوہُ ، قَالَ : وَکَانَ یُقَالُ : ابْتَدِرُوا الأَذَانَ ، وَلاَ تَبْتَدِرُوا الإِقَامَۃَ۔ (احمد 29)",,,2353 2354,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : الْمُؤَذِّنُ الْمُحْتَسِبُ أَوَّلُ مَنْ یُکْسَی۔",,,2354 2355,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، قَالَ : سَمِعْتُ عِیسَی بْنَ طَلْحَۃَ ، قَالَ : سَمِعْتُ مُعَاوِیَۃَ یَقُولُ : سَمِعْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إنَّ الْمُؤَذِّنِینَ أَطْوَلُ النَّاسِ أَعْنَاقًا یَوْمَ الْقِیَامَۃِ۔\n\n(مسلم 290۔ ابن ماجہ 725)",,,2355 2356,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، قَالَ : أَخْبَرَنَا ہِشَام، عَنِ الْحَسَنِ، قَالَ : أَہْلُ الصَّلاَحِ وَالْحِسْبَۃِ مِنَ الْمُؤَذِّنِینَ، أَوَّلُ مَنْ یُکْسَی یَوْمَ الْقِیَامَۃِ۔",,,2356 2357,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا شَیْخٌ مِنْ أَہْلِ الْبَصْرَۃِ ، قَالَ : أَخْبَرَنَا الْقَاسِمُ بْنُ عَوْفٍ الشَّیْبَانِیُّ ، عَنْ زَیْدِ بْنِ أَرْقَمَ ، قَالَ: قَالَ النَّبِیُّ صلی اللہ علیہ وسلم: بِلاَلٌ سَیِّدُ الْمُؤَذِّنِینَ یَوْمَ الْقِیَامَۃِ ، وَلاَ یَتْبَعُہُ إِلاَّ مُؤْمِنٌ، وَالْمُؤَذِّنُونَ أَطْوَلُ النَّاسِ أَعْنَاقًا یَوْمَ الْقِیَامَۃِ۔ (طبرانی 5118)",,,2357 2358,"حَدَّثَنَا یَزِیدُ، عَنِ الرَّبِیعِ بْنِ صَبِیحٍ، قَالَ: حَدَّثَنَا أَبُو فَاطِمَۃَ، رَجُلٌ قَدْ أَدْرَکَ أَصْحَابَ النَّبِیِّ صلی اللہ علیہ وسلم، قَالَ: قَالَ ابْنُ مَسْعُودٍ: لَوْ کُنْتُ مُؤَذِّنًا ، مَا بَالَیْتُ أَنْ لاَ أَحُجَّ ، وَلاَ أَغْزُوَ۔",,,2358 2359,"حَدَّثَنَا یَزِیدُ وَوَکِیعٌ ، قَالاَ : حدَّثَنَا إسْمَاعِیلُ ، عَنْ شُبَیْلِ بْنِ عَوْفٍ ، قَالَ : قَالَ عُمَرُ : مَنْ مُؤَذِّنُوکُمْ ؟ قَالُوا : عَبِیدُنَا وَمَوَالِینَا ، قَالَ : إنَّ ذَلِکَ لَنَقْصٌ بِکُمْ کَبِیرٌ۔ إِلاَّ أَنَّ وَکِیعًا قَالَ : کَثِیرٌ ، أَوْ کَبِیرٌ۔",,,2359 2360,"حَدَّثَنَا یَزِیدُ وَوَکِیعٌ ، عَنْ إسْمَاعِیلَ ، قَالَ : قَالَ قَیْسٌ : قَالَ عُمَرُ : لَوْ کُنْتُ أُطِیقُ الأَذَانَ مَعَ الْخِلِّیفَی لأَذَّنْتُ۔",,,2360 2361,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُبَیْدِ اللہِ بْنِ الْوَلِیدِ ، عَنْ عُبَدِ اللہِ بْنِ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : مَا أَرَی ہَذِہِ الآیَۃَ نَزَلَتْ إِلاَّ فِی الْمُؤَذِّنِینَ : {وَمَنْ أَحْسَنُ قَوْلاً مِمَّنْ دَعَا إلَی اللہِ وَعَمِلَ صَالِحًا وَقَالَ إنَّنِی مِنَ الْمُسْلِمِینَ}۔",,,2361 2362,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُبَیْدِ اللہِ بْنِ الْوَلِیدِ ، عَنْ مُحَمَّدِ بْنِ نَافِعٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : لاَ أَرَی ہَذِہِ الآیَۃَ نَزَلَتْ إِلاَّ فِی الْمُؤَذِّنِینَ: {وَمَنْ أَحْسَنُ قَوْلاً مِمَّنْ دَعَا إلَی اللہِ وَعَمِلَ صَالِحًا ، وَقَالَ إنَّنِی مِنَ الْمُسْلِمِینَ}۔",,,2362 2363,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ: حدَّثَنِی الْحَسَنُ بْنُ الْحَکَمِ ، قَالَ : حَدَّثَنِی یَحْیَی بْنُ عَبَّادٍ أَبُو ہُبَیْرَۃَ ، عَنْ شَیْخٍ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْمُؤَذِّنُ یُغْفَرُ لَہُ مَدَّ صَوْتِہِ وَیُصَدِّقُہُ کُلُّ رَطْبٍ وَیَابِسٍ۔ (احمد 2/411)",,,2363 2364,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا أَبُو العَنْبس سَعِیدُ بْنُ کَثِیرٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : ارْفَعْ صَوْتَکَ بِالأَذَانِ ، فَإِنَّہُ یَشْہَدُ لَکَ کُلُّ شَیْئٍ سَمِعَک۔",,,2364 2365,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، قَالَ : الْمُؤَذِّنُ یَشْہَدُ لَہُ کُلُّ شَیْئٍ رَطْبٍ وَیَابِسٍ سَمِعَہُ۔",,,2365 2366,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ رَجُلٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ قَالَ لِرَجُلٍ : مَا عَمَلُک ؟ قَالَ : الأَذَانُ ، قَالَ : نِعْمَ الْعَمَلُ عملُک ، یَشْہَدُ لَکَ کُلُّ شَیْئٍ سَمِعَک۔",,,2366 2367,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : خَرَجَ عَلْقَمَۃُ ، وَعَبْدُ الرَّحْمَنِ بْنُ أَبِی لَیْلَی إِلَی بَدْوٍ لَہُمْ ، قَالَ إبْرَاہِیمُ : فَکَانَ یُعْجِبُنِی أَنَّ عَبْدَ الرَّحْمَنِ بْنَ أَبِی لَیْلَی کَانَ یَأْمُرُ ابْنًا لَہُ غُلاَمًا یُؤَذِّنُ۔",,,2367 2368,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یُؤَذِّنَ الْغُلاَمُ قَبْلَ أَنْ یَحْتَلِمَ۔",,,2368 2369,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ الأَزْرَقِ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ بَأْسَ أَنْ یُؤَذِّنَ الْغُلاَمُ إذَا أَحْسَنَ الأَذَانَ قَبْلَ أَنْ یَحْتَلِمَ۔",,,2369 2370,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَن عِیسَی بْنِ طَلْحَۃَ ، قَالَ : دَخَلْنَا عَلَی مُعَاوِیَۃَ فَجَائَ الْمُؤَذِّنُ فَأَذَّنَ ، فَقَالَ : اللَّہُ أَکْبَرُ، اللَّہُ أَکْبَرُ ، فَقَالَ مُعَاوِیَۃُ بْنُ أَبِی سُفْیَانَ مِثْلَ ذَلِکَ ، فَقَالَ : أَشْہَدُ أَنْ لاَ إِلَہَ إِلاَّ اللَّہُ ، فَقَالَ مُعَاوِیَۃُ مِثْلَ ذَلِکَ ، فَقَالَ : أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، فَقَالَ : مُعَاوِیَۃُ مِثْلَ ذَلِکَ ، ثُمَّ قَالَ : ہَکَذَا سَمِعْتُ نَبِیَّکُمْ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ۔ (احمد 4/91۔ دارمی 1202)",,,2370 2371,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقْرِیء ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ ، قَالَ : حدَّثَنِی کَعْبُ بْنُ عَلْقَمَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ جُبَیْرٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا سَمِعْتُمَ الْمُؤَذِّنَ ، فَقُولُوا کَمَا یَقُولُ۔ (مسلم 288۔ ابوداؤد 524)",,,2371 2372,حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عَطَائِ بْنِ یَزِیدَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ مِثْلَ مَا یَقُولُ الْمُؤَذِّنُ۔ (ابوداؤد 525۔ ابن ماجہ 720),,,2372 2373,حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ أَبِی الْمَلِیحِ ، عَنْ أُمِّ حَبِیبَۃَ۔ (احمد 326۔ نسائی 9865),,,2373 2374,"(ح) وَحَدَّثَنَا عَفَّانُ ، قَالَ : أَخْبَرَنَا أَبُو عَوَانَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ أَبِی الْمَلِیحِ ، عَنْ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، عَنْ أُمِّ حَبِیبَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ کَانَ إذَا سَمِعَ الْمُؤَذِّنَ ، قَالَ کَمَا یَقُولُ حَتَّی یَسْکُتَ۔",,,2374 2375,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمِ بْنِ عُبَیْدِ اللہِ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ مِثْلَ مَا یَقُولُ الْمُؤَذِّنُ ، فَإِذَا بَلَغَ حَیَّ عَلَی الصَّلاَۃِ ، حَیَّ عَلَی الْفَلاَحِ، قَالَ : لاَ حَوْلَ وَلاَ قُوَّۃَ إِلاَّ بِاللَّہِ۔ (طبرانی 3266)",,,2375 2376,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ أَبِی جَعْفَرٍ مُحَمَّدِ بْنِ عَلِیٍّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا سَمِعَ صَوْتَ الْمُنَادِی یَقُولُ : أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، قَالَ : وَأَنَا ، وَإذَا قَالَ : أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ ، قَالَ : وَأَنَا۔",,,2376 2377,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا سَمِعَ الْمُؤَذِّنَ ، قَالَ : وَأَنَا ، وَأَنَا۔",,,2377 2378,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَمَّنْ أَخْبَرَہُ عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ إذَا قَالَ الْمُؤَذِّنُ : حَیَّ عَلَی الصَّلاَۃِ ، قَالَ : الْمُسْتَعَانُ اللَّہُ ، فَإذَا قَالَ : حَیَّ عَلَی الْفَلاَحِ ، قَالَ : لاَ حَوْلَ وَلاَ قُوَّۃَ إِلاَّ بِاللَّہِ۔",,,2378 2379,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : مَنْ قَالَ مِثْلَ مَا یَقُولُ الْمُؤَذِّنُ کَانَ لَہُ مِثْلُ أَجْرِہِ۔",,,2379 2380,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی حَمْزَۃَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا سَمِعْت الْمُؤَذِّنَ فَقُلْ کَمَا یَقُولُ ، فَإذَا قَالَ : حَیَّ عَلَی الصَّلاَۃِ ، فَقُلْ : لاَ حَوْلَ وَلاَ قُوَّۃَ إِلاَّ بِاللَّہِ ، فَإذَا قَالَ : قَدْ قَامَتِ الصَّلاَۃُ ، فَقُلِ : اللَّہُمَّ رَبَّ ہَذِہِ الدَّعْوَۃِ التَّامَّۃِ ، وَالصَّلاَۃِ الْقَائِمَۃِ ، أَعْطِ مُحَمَّدًا سُؤْلَہُ یَوْمَ الْقِیَامَۃِ ، فَلَنْ یَقُولَہَا رَجُلٌ حِینَ یُقِیمُ إِلاَّ أَدْخَلَہُ اللَّہُ فِی شَفَاعَۃِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ الْقِیَامَۃِ۔",,,2380 2381,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ عُثْمَانَ کَانَ إذَا سَمِعَ الْمُؤَذِّنَ یُؤَذِّنُ یَقُولُ کَمَا یَقُولُ فِی التَّشَہُّدِ وَالتَّکْبِیرِ کُلِّہِ ، فَإذَا قَالَ : حَیَّ عَلَی الصَّلاَۃِ ، قَالَ : مَا شَائَ اللَّہُ ، وَلاَ حَوْلَ وَلاَ قُوَّۃَ إِلاَّ بِاللَّہِ ، وَإذَا قَالَ : قَدْ قَامَتِ الصَّلاَۃُ ، قَالَ : مَرْحَبًا بِالْقَائِلِینَ عَدْلاً وَصدقًا ، وَبِالصَّلاَۃِ مَرْحَبًا وَأَہْلاً ، ثُمَّ یَنْہَضُ إلَی الصَّلاَۃِ۔",,,2381 2382,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ ، قَالَ : مِنَ الْجَفَائِ أَنْ تَسْمَعَ الْمؤَذِّنَ یَقُولُ : لاَ إلَہَ إِلاَّ اللَّہُ ، وَاللَّہُ أَکْبَرُ ، ثُمَّ لاَ تُجِیبَہُ۔",,,2382 2383,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : مِنَ الْجَفَائِ أَنْ تَسْمَعَ الأَذَانَ ، ثُمَّ لاَ تَقُولُ مِثْلَ مَا یَقُولُ۔",,,2383 2384,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشعثَ ، عَنِ الْحَسَنِ ، عَنْ عُثْمَانَ بْنِ أَبِی الْعَاصِ ، قَالَ : آخِرُ مَا عَہِدَ إلَیَّ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنِ اتَّخِذْ مُؤَذِّنًا لاَ یَأْخُذُ عَلَی أَذَانِہِ أَجْرًا۔ (ترمذی 209۔ ابوداؤد 532)",,,2384 2385,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ؛ أَنَّہُ کَرِہَ أَنْ یَأْخُذَ الْمُؤَذِّنُ عَلَی أَذَانِہِ جُعْلاً وَیَقُولُ : إِنْ أُعْطِیَ بِغَیْرِ مَسْأَلَۃٍ فَلاَ بَأْسَ۔",,,2385 2386,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَوْنِ بْنِ مُوسَی ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ قَالَ : کَانَ یُقَالُ : لاَ یُؤَذِّنُ لَکَ إِلاَّ مُحْتَسِبٌ۔",,,2386 2387,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَارَۃَ بْنِ زَاذَانَ ، عَنْ یَحْیَی الْبَکَّائِ ، قَالَ : کُنْتُ آخِذًا بِیَدِ ابْنِ عُمَرَ وَہُوَ یَطُوفُ بِالْکَعْبَۃِ ، فَلَقِیَہُ رَجُلٌ مِنْ مُؤَذِّنِی الْکَعْبَۃِ ، فَقَالَ : إنِّی لأُحِبُّک فِی اللہِ ، فَقَالَ ابْنُ عُمَرَ : إِنِّی لأبْغِضُک فِی اللہِ ، إنَّک تُحَسِّنُ صَوْتَکَ لأَخْذِ الدَّرَاہِمِ۔",,,2387 2388,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ، عَنْ أَبِی سُفْیَانَ، عَنْ جَابِرٍ، قَالَ: قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا نَادَی الْمُؤَذِّنُ بِالأَذَانِ ہَرَبَ الشَّیْطَانُ ، حَتَّی یَکُونَ بِالرَّوْحَائِ ، وَہِیَ ثَلاَثُونَ مِیلاً مِنَ الْمَدِینَۃِ۔ (مسلم 15)",,,2388 2389,"حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا نَادَی الْمُؤَذِّنُ بِالصَّلاَۃِ أَدْبَرَ الشَّیْطَانُ وَلَہُ ضُرَاطٌ ، فَإِذَا قَضَی أَمْسَکَ ، فَإِذَا ثَوَّبَ بِہَا أَدْبَرَ۔ (مسلم 398۔ احمد 2/522)",,,2389 2390,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُمَرَ بْنِ سَعِیدِ بْنِ أَبِی حُسَیْنٍ الْمَکِّیِّ ؛ أَنَّ مُؤَذِّنًا أَذَّنَ فَطَرَّبَ فِی أَذَانِہِ ، فَقَالَ لَہُ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : أَذِّنْ أَذَانًا سَمْحًا ، وَإِلا فَاعْتَزِلْنَا۔",,,2390 2391,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَلاَّمِ بْنِ صَالِحٍ ، عَنْ فَائِدِ بْنِ بُکَیْر ، عَنْ حُذَیْفَۃَ ، قَالَ : مَنْ شَائَ اللَّہُ أَنْ یَجْعَلَ رِزْقَہُ فِی صَوْتِہِ فَعَلَ۔",,,2391 2392,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : الأَذَانُ جَزْمٌ۔",,,2392
