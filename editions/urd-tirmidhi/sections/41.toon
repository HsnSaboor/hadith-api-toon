metadata:

hadiths[43]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
2645,"عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس کے ساتھ ا",,,,,2645
2646,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو علم حاصل کرنے کے اراد",,,,,2646
2647,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص علم حاصل کرنے ",,,,,2647
2648,"سخبرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو علم حاصل کرے گا تو یہ ",,,,,2648
2649,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس سے علم دین کی کوئی ای",,,,,2649
2650,ابوہارون کہتے ہیں کہ  ہم ابو سعید خدری رضی الله عنہ کے پاس  ( علم دین حاصل کرنے کے لیے )  آتے، تو و,,,,,2650
2651,"ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تمہارے پاس پورب س",,,,,2651
2652,"عبداللہ بن عمرو بن عاص رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ تعالی",,,,,2652
2653,ابو الدرداء رضی الله عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ تھے، اچانک آپ نے اپنی ,,,,,2653
2654,"کعب بن مالک رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”جو شخ",,,,,2654
2655,"عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس نے علم کو غ",,,,,2655
2656,ابان بن عثمان کہتے ہیں کہ  زید بن ثابت رضی الله عنہ دوپہر کے وقت مروان کے پاس سے نکلے  ( لوٹے ) ، ہم,,,,,2656
2657,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”ا",,,,,2657
2658,"عبداللہ بن مسعود رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اللہ اس شخص کو",,,,,2658
2659,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے جان بوجھ ک",,,,,2659
2660,"علی بن ابی طالب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مجھ پر جھوٹ نہ با",,,,,2660
2661,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے میرے متعلق جھوٹ",,,,,2661
2662,"مغیرہ بن شعبہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس نے میری طرف من",,,,,2662
2663,"ابورافع رضی الله عنہ وغیرہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میں تم میں سے کس",,,,,2663
2664,"مقدام بن معدیکرب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”خبردار رہو! قریب",,,,,2664
2665,ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  ہم نے  ( ابتداء اسلام میں )  نبی اکرم صلی اللہ علیہ وسلم سے ,,,,,2665
2666,ابوہریرہ رضی الله عنہ کہتے ہیں کہ  ایک انصاری شخص نبی اکرم صلی اللہ علیہ وسلم کی مجلس میں بیٹھا کرتا,,,,,2666
2667,ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے خطبہ دیا اور دوران خطبہ آپ نے ک,,,,,2667
2668,ہمام بن منبہ کہتے ہیں کہ  میں نے ابوہریرہ رضی الله عنہ کو فرماتے ہوئے سنا کہ رسول اللہ صلی اللہ علیہ,,,,,2668
2669,"عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میری طرف سے لوگ",,,,,2669
2670,انس بن مالک رضی الله عنہ کہتے ہیں کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کے پاس سواری مانگنے آیا، ,,,,,2670
2671,ابومسعود بدری رضی الله عنہ سے روایت ہے کہ  ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے پاس سواری مانگنے ,,,,,2671
2672,"ابوموسیٰ اشعری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”شفاعت  ( سفارش )",,,,,2672
2673,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ظلم سے جو بھی خو",,,,,2673
2674,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے لوگوں کو ہدایت کی ",,,,,2674
2675,"جریر بن عبداللہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے کوئی اچھا ط",,,,,2675
2676,عرباض بن ساریہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک دن ہمیں نماز فجر کے بعد,,,,,2676
2677,عمرو بن عوف رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے بلال بن حارث رضی الله عنہ سے,,,,,2677
2678,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  مجھ سے رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میرے بیٹے: اگر",,,,,2678
2679,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب تک میں تمہیں چھوڑے رک",,,,,2679
2680,ابوہریرہ رضی الله عنہ سے مرفوعاً روایت ہے  ”عنقریب ایسا وقت آئے گا کہ لوگ علم کی تلاش میں کثرت سے ل,,,,,2680
2681,"عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ایک فقیہ  ( عال",,,,,2681
2682,قیس بن کثیر کہتے ہیں کہ  ایک شخص مدینہ سے ابو الدرداء رضی الله عنہ کے پاس دمشق آیا، ابوالدرداء رضی ,,,,,2682
2683,"یزید بن سلمہ جعفی کہتے ہیں کہ  میں نے کہا: اللہ کے رسول! میں نے بہت سی حدیثیں آپ سے سنی ہیں، میں ڈرت",,,,,2683
2684,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”منافق میں دو خصلتیں  ( ص",,,,,2684
2685,ابوامامہ باہلی کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے سامنے دو آدمیوں کا ذکر کیا گیا، ان میں ,,,,,2685
2686,"ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مومن بھلائی سے ہ",,,,,2686
2687,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”حکمت کی بات مومن کی گمشد",,,,,2687
