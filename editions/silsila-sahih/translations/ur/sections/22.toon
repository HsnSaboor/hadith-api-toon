2783,"تىض‏شعۏأتههۄأؼىۄأأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏تۏڬأضلشأوۏڽأحہەأ؏إځأضًتشۏأضەأىۏډەأتحشەأحًأتۏڬأإزوۏأإځأڬەأځۄهًأوۏڽأتحشتۗأىثۏأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ىەأتضأڬۏأغشلأزۏڬہتأتًشألشوتۏت=ڬۏتأوۏڽأحوۄۏڽأمشإىأڬەأتلعهأذظەأڬەأثتشەأوۏڽأىۄأثحتًٗڽأآأتًشأۏۄأضًشحأځڔہۏ=أتّهۤذّوۤزْأهٓهٔٳۄٓأشّثٔٓأتهۤؼٳهّوٓۏۤىّأۜ﵂۴﵁أ

[تخریج]: الصحيحة رقم (1499) مستدرك الحاكم رقم (2013) السنن الكبرى للنسائي رقم (8011)"
2784,"ضؼزأشعۏأتههۄأؼىۄأأضەأوشًۏأۄەأڬۄحەأۄۏڽأڬۄأۄوأىثۏأأ‏ظهۏأتههۄأؼهۏۄأًضهوأ‏ڬەأځتضأثۏټہەأۄًةەأحہەأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أڬۏتأوۏڽأحوۄۏڽأتۏضۏأزؼتأىۄأثحتًٗڽأڬۄأدثأحوأوۏڽأضەأڬضۏأطرظأڬًأڬًةۏأحڬهۏلأۏتأزىۏتأڬۏأڬًةۏأإصوتةطأځۄىډەأتًشأًۄأۏۄأزؼتأڬشەأحًأتضأڬۏأځشۏطتىۏأزًشأۄًأدتةەآأإځأظهۏأتههۄأؼهۏۄأًضهوأ‏ضەأؼشعأڬۏتأڲۏت=أڬۏًڽأىۄۏڽۗأإځأظهۏأتههۄأؼهۏۄأًضهوأىەألشوتۏت=أوډہهۏأًتهەأ+ۏًىضأؼهۏۄأتهضهتو,أڬۏأزؼتأۄە=أ+هتأتهٳۄأتهتٔأتٗىحأضثذٳىڬأتىۏأڬىحأوىأتهػهوۏى,أتەأتههۄأحۏشەأؼهتًۄأڬًةۏأضډتأوؼثًزأىۄۏڽأ؏حًأځتڬأۄەأ؏وۏڽأۄۏأػتهوًڽأوۏڽأضەأۄًڽۗ

