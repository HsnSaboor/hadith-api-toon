{"hadithnumber": "3162", "text": "ام کرز رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  لڑکے کی ط"}
{"hadithnumber": "3163", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں حکم دیا: ہم لڑکے ک"}
{"hadithnumber": "3164", "text": "سلمان بن عامر رضی اللہ عنہ کہتے ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  لڑ"}
{"hadithnumber": "3165", "text": "سمرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ہر لڑکا اپنے عقیقہ میں گروی ہ"}
{"hadithnumber": "3166", "text": "یزید بن عبدالمزنی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  لڑکے کی طرف سے ع"}
{"hadithnumber": "3167", "text": "نبیشہ رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم کو آواز دی اور کہا: اللہ کے"}
{"hadithnumber": "3168", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  نہ «فرعہ» ہے اور نہ «عتیر"}
{"hadithnumber": "3169", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  نہ «فرعہ»  ( واجب"}
{"hadithnumber": "3170", "text": "شداد بن اوس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیشک اللہ عزوجل نے ہر"}
{"hadithnumber": "3171", "text": "ابو سعید خدری رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کا گزر ایک ایسے شخص پر ہوا جو"}
{"hadithnumber": "3172", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے چھری کو تیز کرنے، اور اسے"}
{"hadithnumber": "3173", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  وہ آیت کریمہ: «إن الشياطين ليوحون إلى أوليائهم»  ( س"}
{"hadithnumber": "3174", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  کچھ لوگوں نے عرض کیا: اللہ کے رسول! کچھ لوگ ہمارے پا"}
{"hadithnumber": "3175", "text": "محمد بن صیفی رضی اللہ عنہ کہتے ہیں کہ  میں نے ایک تیز دھار والے پتھر سے دو خرگوش ذبح کئے، پھر انہیں"}
{"hadithnumber": "3176", "text": "زید بن ثابت رضی اللہ عنہ سے روایت ہے کہ  بھیڑئیے نے ایک بکری میں دانت گاڑ دیئے، تو لوگوں نے اس بکری"}
{"hadithnumber": "3177", "text": "عدی بن حاتم رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! ہم شکار کرتے ہیں اور ہمیں ذبح کر"}
{"hadithnumber": "3178", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ایک سفر میں تھے،"}
{"hadithnumber": "3179", "text": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کا گزر ایک لڑکے کے پاس سے ہو"}
{"hadithnumber": "3180", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم ایک انصاری کے پاس تشریف لائے تو ا"}
{"hadithnumber": "3181", "text": "ابوبکر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان سے اور عمر رضی اللہ عنہ سے فر"}
{"hadithnumber": "3182", "text": "کعب بن مالک رضی اللہ عنہ سے روایت ہے کہ  ایک عورت نے ایک بکری کو پتھر سے ذبح کر دیا، پھر رسول اللہ ص"}
{"hadithnumber": "3183", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ ایک سفر میں نبی اکرم صلی اللہ علیہ وسلم کے ساتھ تھے کہ"}
{"hadithnumber": "3184", "text": "ابوالعشراء کے والد کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! کیا صرف حلق اور کوڑی کے بیچ ہی میں  ("}
{"hadithnumber": "3185", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہعلیہ وسلم  نے جانوروں کا مثلہ کرنے سے منع"}
{"hadithnumber": "3186", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے جانوروں کو باندھ کر نشانہ لگان"}
{"hadithnumber": "3187", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں ک  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایسی چیز کو جس م"}
{"hadithnumber": "3188", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے کسی جانور کو باندھ کر تی"}
{"hadithnumber": "3189", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے «جلالہ»  ( گندگی اور نجاس"}
{"hadithnumber": "3190", "text": "اسماء بنت ابی بکر رضی اللہ عنہما کہتی ہیں کہ  ہم نے رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ایک گھ"}
{"hadithnumber": "3191", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ہم نے خیبر کے زمانہ میں گھوڑے اور نیل گائے۔"}
{"hadithnumber": "3192", "text": "ابواسحاق شیبانی (سلیمان بن فیروز) کہتے ہیں کہ  میں نے عبداللہ بن ابی اوفی رضی اللہ عنہ سے پالتو گدھو"}
{"hadithnumber": "3193", "text": "مقدام بن معدیکرب رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے کئی چیزوں کو حرام قرار"}
{"hadithnumber": "3194", "text": "براء بن عازب رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں پالتو گدھے کا گوشت پھی"}
{"hadithnumber": "3195", "text": "سلمہ بن الاکوع رضی اللہ عنہ کہتے ہیں کہ  ہم نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ خیبر کی لڑائی لڑ"}
{"hadithnumber": "3196", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے منادی نے آواز لگائی: اللہ اور"}
{"hadithnumber": "3197", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ہم لوگ گھوڑے کا گوشت کھاتے تھے، میں نے کہا: اور خچروں کا"}
{"hadithnumber": "3198", "text": "خالد بن ولید رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے گھوڑ ے، خچر اور گدھے کے گوشت"}
{"hadithnumber": "3199", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  ہم نے رسول اللہ صلی اللہ علیہ وسلم سے جنین  ( ماں کے پیٹ کے"}
