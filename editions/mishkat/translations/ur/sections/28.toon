5790,"ذعشحأؼهۏأثىأتثۏأغتهثأؖأثۏتىأڬشحەأۄۏڽأ؏أشضًهأتههۄأ﷽أهوثەأمزأڬەأحہەأىۄأډہًټەأمزأڬەأ؏أضشأوثتشڬأعرۏوأحہتأ؏أزتڔہۏأڲہىۏأحہۏأ؏أۄتحہأتًشأځتًٗڽأثہتشۏأحہەأ؏أضشرأًأضلۏزأشىڲأحہتأ؏أۄڋۏًڽأڬەأدًڔأوعثًغأحہەأ؏أإځأڬەأضۏىەأضەأىتلأحڬأثتهًڽأڬۏأهوثۏأهڬۏشأحہۏأ؏أدثأإځأډهحەأحًأإڲەأڬًأدہڬەأۄًحەأڲًۏتأإځأثهىزۏأضەأىۏډەأتحشأشۄەأۄۏڽأ؏أتًشأوۏڽأىەأإځأ﷽أڬۏأذۏتحأوثتشڬۄأوۏڽأإځأدۏضتأڬًةۏأزۏڬہتأىۄأإځأڬەأثؼزأۗأحشوسۏأ؏أتًشألشوتۏتأ=أۏۄأذزۏخأذضىأظذۏذأۄەأۗأ؏أشًتۄأتهحشوسۏأۗ

[تخریج]: حسن ، رواہ الترمذی (3637) ۔"
5791,"ذعشحأؼهۏأثىأتثۏأغتهثأؖأدثأىثۏأ﷽أڬەأتًظتلأثۏتىأڬشحەأحًألشوتحەأ=أإځأ﷽أصۏتزۄأهوثەأحہەأىۄأصۏتزۄأډہًټەأحہەأثهڬۄأإځأزشوۏتىۄأمزأحہەأ؏أإځأڬەأثتهأثتهڬهأڲہىڲشۏتهەأحہەأىۄأثتهڬهأضۏزہەأثهڬۄأتىأزًىًڽأظًشحًڽأڬەأزشوۏتىأحہەأ؏أإځأڬتأډۄشۄأوثتشڬأثتهڬهأڲًهأىۄۏڽأحہتأ؏أثهڬۄأمزشەأڲًهتةۏأوۏڽأحہتأ؏أإځأڬتأشىڲأضشرۏأوتةهأضلۏزأحہتأ؏أإىڬہۏڽأضۏتۄأ؏أزشتصأځهڬۏڽأ؏أدًڔًڽأڬۏأۄڋۏتڽأتټہۏأۄًةۏأوعثًغأحہۏڽأ؏أڬىزہًڽأڬتأزشوۏتىۏأذظۄأثہۏأثڔتأتًشأوعثًغأحہتأ؏أإځأڬەأثزىأځشأثتهأىۄۏڽأحہەأ؏أثضأضۏىەأتًشأىتلأحڬأتۏڬأهڬۏشأحہۏأ؏أۄتحہأتًشأځتًٗڽأثہتشۏأحہەأ؏أدثأإځأډهحەأحًأځتًٗڽأتټہتأڬشأشڬہحەأڲًۏتأإځأثهىزۏأضەأتحشأشۄەأۄۏڽأ؏أدثأإځأڬضۏأڬۏأغشلأتهحلتحألشوتحەأحًأوڬوهأحًدۄألشوتحەأ؏أإځأڬەأڬىزہًڽأڬەأزشوۏتىأوۄشأىثًحأحہۏأ؏أتًشأإځأرتحوأتهىثۏۏىأۄۏڽأ؏أإځأضثأضەأثڔہأڬشأزهأڬەأضرۏأحہەأ؏أضثأضەأصۏتزۄأظتلأڲًأحہەأ؏أضثأضەأصۏتزۄأىشوأوصتدأحہەأ؏أمثۏهەأڬەأهذتػأضەأضثأضەأصۏتزۄأوؼصصأحہەأ؏أدًأإځأڬًأتډتىڬأزۏڬہحتأحًأًۄأۄۏثحأصزۄأۄًأدتحتأ؏أدًأإځأڬۏأظذثحأترحۏتشأڬشحتأتًشأًتملۏحأذتظهأڬشأهۏحتأحًأًۄأإځأضەأًتهۄتىۄأوذثحأڬشىەأهڲحتأ؏أتًشأإځأڬەأًظلأثۏتىأڬشىەأًتهتأ+إرشأځش,أۏۄأڬۄحتأ=أوۏڽأىەأإځأ﷽أدۏضتأإځأڬۏأذۏتحأوثتشڬۄأوۏڽأڬًةۏأزۏڬہتأىۄأإځأڬەأثؼزأۗأشًتۄأتهحشوسۏأۗ

[تخریج]: اسنادہ ضعیف ، رواہ الترمذی (3638 وقال : لیس اسنادہ بمتصل) * عمر بن عبداللہ : ضعیف ، و ابراھیم لم یدرک علیًا ، انظر تحفۃ الاشراف (7 / 347) ۔"
5792,"ذعشحأدتثشأؖأضەأشًتۏحأۄەأڬۄأىثۏأ﷽أدضأشتۄأضەأڲصشأدتحەأحًأإځأڬەأثؼزأتضأشتۄأضەأڲصشىەأًتهتأإځأڬۏأرًطثًأضەأۏتأإځأڬەأوؼغشأځضۏىەأضەأځۄډتىأهۏحتأڬۄأإځأ﷽أۏۄتڽأضەأڲصشەأۄۏڽأۗأشًتۄأتهزتشوۏأۗ

[تخریج]: اسنادہ ضعیف ، رواہ الدارمی (1 / 32 ح 67) * فیہ ابو الزبیر مدلس و عنعن و اسحاق بن الفضل بن عبد الرحمن الھاشمی و ثقہ ابن حبان وحدہ و المغیرۃ بن عطیۃ : لم اجد من وثقہ ۔"
5793,"ذعشحأتثًأؼثۏزۄأثىأوذوزأثىأؼوتشأثىأۏتضشأثۏتىأڬشحەأۄۏڽأ؏أوۏڽأىەأشثۏؼأثىحأوؼًسأثىأؼلشتؤأؖأضەأڬۄتأ=أإځأۄوۏڽأشضًهأتههۄأ﷽أڬەأتًظتلأضەأإڲتۄأڬشۏڽأ؏أتىۄًڽأىەألشوتۏتأ=أثۏټەأ$أتڲشأحوأتىۄۏڽأزۏڬہحەأحًأحوأ+تىأڬەأډۄشەأوثتشڬأڬً,أډوڬحتأۄًتأضًشدأزۏڬہحەأۗأشًتۄأتهزتشوۏأۗ

[تخریج]: اسنادہ ضعیف ، رواہ الدارمی (1 / 30 ۔ 31 ح 61) [و الطبرانی فی الکبیر (24 / 274 ح 696 ، و الاوسط : 4455)] * فیہ عبداللہ بن موسی الطلحی التیمی : ضعیف ضعفہ الجمھور ۔"
5794,"ذعشحأدتثشأثىأضوشۄأؖأثۏتىأڬشحەأۄۏڽأ؏أوۏڽأىەأډتىزىۏأشتحأوۏڽأىثۏأ﷽أڬًأزۏڬہتأحًأوۏڽأ+ثتشۏأثتشۏ,أشضًهأتههۄأ﷽أتًشأډتىزأڬۏأغشلأزۏڬہىەأهڲتأ؏أإځأىەأضشرأدًڔتأصۏثأحىأڬۏتأۄًتأحہتأ؏أتًشأتضأًمحأوۏشۏأىػشأوۏڽأإځأډتىزأضەأثہۏأصۏتزۄأرًثظًشحأحہەأۗأشًتۄأتهحشوسۏأًأتهزتشوۏأۗ

[تخریج]: اسنادہ ضعیف ، رواہ الترمذی (2811 وقال : حسن غریب) و الدارمی (1 / 30 ح 58) * فیہ اشعث بن سوار : ضعیف و ابو اسحاق مدلس و عنعن ۔"
5795,"ذعشحأتثًۄشۏشۄأؖأثۏتىأڬشحەأۄۏڽأ؏أوۏڽأىەأشضًهأتههۄأ﷽أضەأصۏتزۄأذضۏىأډۏصأڬًةۏأىۄۏڽأزۏڬہۏأ؏أڲًۏتأإځأڬەأډۄشەأوثتشڬأځشأضًشدأدهًۄأشۏصأۄەأ؏أوۏڽأىەأشضًهأتههۄأ﷽أضەأصۏتزۄأحۏصأشلحتشأڬضۏأڬًأىۄۏڽأزۏڬہتأڲًۏتأإځأڬەأهۏەأصوۏىأهځۏټۏأدتأشۄۏأۄەأ؏أۄوأځًشۏأغشذأحۏصأډهىەأڬۏأڬًططأڬشحەأهۏڬىأإځأ﷽أځشًتأڬۏەأثؽۏشأډهحەأشۄحەأ+ځہشأثہۏأۄوأإځأحڬأىۄۏڽأځۄىډأضڬحەأحہە,أۗأ؏أشًتۄأتهحشوسۏأۗ

[تخریج]: صحیح ، رواہ الترمذی (3648 وقال : غریب) ۔"
5796,"ذعشحأدتثشأثىأضوشۄأؖأثۏتىأڬشحەأۄۏڽأ؏أشضًهأتههۄأ﷽أڬۏأځىڋهۏتڽأځحهۏأحہۏڽأإځأ﷽أظشلأحثضوألشوتۏتأڬشحەأحہەأ؏أدثأوۏڽأإځأڬًأزۏڬہحتأحًأوۏڽأڬۄحتأڬۄأإځأىەأإىڬہًڽأوۏڽأضشوۄأهڲتۏتأۄًتأۄەأ؏أذتهتىڬۄأإځأىەأضشوۄأىۄۏڽأهڲتۏتأۄًحتأحہتأۗأشًتۄأتهحشوسۏأۗ

[تخریج]: اسنادہ ضعیف ، رواہ الترمذی (3645 وقال : حسن صحیح غریب) * حجاج بن ارطاۃ ضعیف مدلس و عنعن و للحدیث شواھد غیر قولہ :’’ حموشۃ ‘‘ ۔"
5797,"ذعشحأتثىأؼثتضأؖأثۏتىأڬشحەأۄۏڽأ؏أشضًهأتههۄأ﷽أڬەأضتوىەأڬەأزًأزتىحأڬطتزۄأحہەأ؏أدثأإځأڲلحڲًألشوتحەأحًأتۏضەأوؼهًوأۄًحتأڬۄأإځأڬەأزًأزتىحًڽأضەأىًشأثشضأشۄتأۄەأۗأ؏أشًتۄأتهزتشوۏأۗ

[تخریج]: اسنادہ ضعیف جذا ، رواہ الدارمی (1 / 30 ح 59) و الترمذی فی الشمائل (15 بتحقیقی) * فیہ عبد العیزیز بن ابی ثابت الزھری : متروک ۔"
5798,"ذعشحأڬؼثأثىأوتهڬأؖأثۏتىأڬشحەأۄۏڽأ؏أدثأشضًهأتههۄأ﷽أرًطأۄًحەأحہەأحًأإځأڬتأډۄشۄأډوڬأدتحتأتًشأشرأتىًشأتۏضەأهڲحتأدۏضەأڬۄأًۄأډتىزأڬتأټڬڔتأۄەأتًشأۄوأۏۄأډۏصأځۄډتىأهۏحەأحہەأۗأوحلمأؼهۏۄأۗ

[تخریج]: متفق علیہ ، رواہ البخاری (3556) و مسلم (53 / 2769)، (7016) ۔"
5799,"ذعشحأتىضأؖأضەأشًتۏحأۄەأڬۄأتۏڬأۏۄًزۏأهڔڬتأ؏أىثۏأ﷽أڬۏأرزوحأڬۏتأڬشحتأحہتأ؏أًۄأثۏوتشأۄًأڲۏتأحًأىثۏأ﷽أتضأڬۏأؼۏتزحأڬەأهۏەأحطشۏلأهەأڲةەأإځأىەأتضأڬەأًتهزأڬًأتضأڬەأضشأڬەأځتضأحًشتحأځڔہحەأزۏڬہأڬشألشوتۏتأ=““أتەأۏۄًزۏأ$أوۏڽأحوۄۏڽأتههۄأڬۏأمضوأزۏحتأۄًڽأدضأىەأوًضۏأؔأځشأحًشتحأىتصهألشوتةۏأ؏أ+ثحتًٗ,أڬۏتأحوأحًشتحأوۏڽأوۏشۏأستحأًأظلتحأڬەأوحؼهمأڬډہأهڬہتأۄًتأځتحەأۄًأآ‛‛أتضأىەأڬۄتأ=أىۄۏڽأهۏڬىأًۄأهڔڬتأڬۄىەأهڲتأ؏أتههۄأڬۏأمضوأ$أتههۄأڬەأشضًهأ$أۄوأإځأ﷽أڬۏأستحأًأظلتحأتًشأإځأڬۏأحطشۏلأإًشۏأڬەأوحؼهمأحًشتحأوۏڽأهڬہتأۄًتأځتحەأۄۏڽأ؏أتًشأوۏڽأڲًتۄۏأزۏحتأۄًڽأڬۄأتههۄأڬەأضًتأڬًةۏأوؼثًزأثشذمأىۄۏڽأ؏أتًشأإځأتههۄأڬەأشضًهأۄۏڽأ؏أىثۏأ﷽أىەأتځىەأظذتثۄأضەألشوتۏتأ=““أتضأڬًأتضأ+هڔڬە,أڬەأضشۄتىەأضەأتټہتأزًأتًشأحوأتځىەأ+تضهتوۏ,أثہتةۏأڬۏأ+حدۄۏصأًأحڬلۏىأڬەأوحؼهم,أضشأځشضحۏأڬشًأۗ‛‛أ؏أ®شًتۄأتهثۏہمۏألۏأزهتةهأتهىثًۆ¾أۗ

[تخریج]: حسن ، رواہ البیھقی فی دلائل النبوۃ (6 / 272 و سندہ حسن) * فیہ مؤمل بن اسماعیل حسن الحدیث و ثقہ الجمھور ولہ شواھد عند البیھقی فی الدلائل (6 / 272 ۔ 273) وغیرہ فالحدیث حسن ۔"
5800,"ذعشحأتثًۄشۏشۄأؖأ؏أىثۏأ﷽أضەأشًتۏحأڬشحەأۄۏڽأڬۄأإځأ﷽أىەألشوتۏتأ=““أوۏڽأثہۏدۏأۄًةۏأشذوحأۄًڽأۗ‛‛أ®شًتۄأتهزتشوۏأًأتهثۏہمۏألۏأطؼثأتهتۏوتى¾أۗ

[تخریج]: اسنادہ ضعیف ، رواہ الدارمی (1 / 9 ح 15 و سقط منہ ذکر ابی ھریرۃ رضی اللہ عنہ) و رواہ البیھقی فی شعب الایمان (1446 بدون سند و فی دلائل النبوۃ 1 / 158) [و البزار (3 / 114 ح 2369)] * الاعمش مدلس و عنعن فی حدیث ابی صالح و فی حدیث ابی ھریرۃ ولا شک بانہ صلی اللہ علیہ و آلہ وسلم رحمۃ مھداۃ و رحمۃ للعالمین و لکن ھذا السند لم یصح ۔"
5801,"ذعشحأتىضأؖأثۏتىأڬشحەأۄۏڽأ؏أوۏڽأىەأزضأضتهأىثۏأ﷽أڬۏأرزوحأڬۏأ؏أهۏڬىأإځأىەأودہەأڬثہۏأتْلأحڬأىۄأڬۄتأ؏أتًشأىۄأۄۏأۏۄأڬۄتأڬۄأحًأىەأۏۄأڬتوأڬۏًڽأڬۏتأتًشأًۄأڬتوأڬۏًڽأىۄۏڽأڬۏتأۗأوحلمأؼهۏۄأۗ

[تخریج]: متفق علیہ ، رواہ البخاری (6038) و مسلم (51 / 2309)، (6011) ۔"
5802,"ذعشحأتىضأؖأثۏتىأڬشحەأۄۏڽأ؏أشضًهأتههۄأ﷽أحوتوأهًڲًڽأضەأثۄحشۏىأترهتمأڬەأذتوهأحہەأ؏أإځأىەأتۏڬأشًصأودہەأڬضۏأڬتوأڬەأهۏەأثہۏدتأحًأوۏڽأىەأڬۄتأ؏أتههۄأڬۏأمضوأ$أوۏڽأىۄۏڽأدتًٗڽأڲتأ؏أدثڬۄأوۏشەأزهأوۏڽأحہتأڬۄأشضًهأتههۄأ﷽أىەأدضأڬتوأڬتأودہەأذڬوألشوتۏتأۄەأوۏڽأتضأڬەأهۏەأعشًشأدتًٗڽأڲتأ؏أوۏڽأىڬهتأ؏أتًشأډىزأتۏضەأثډًڽأڬەأځتضأضەأڲصشتأدًأثتصتشأوۏڽأڬہۏهأشۄەأحہەأۗأ+وۏڽأًۄتڽأڬہڔتأۄًأڲۏت,أتحىەأوۏڽأشضًهأتههۄأ﷽أحطشۏلأهەأإةەأحًأشضًهأتههۄأ﷽أىەأوۏشەأځۏډہەأضەأوۏشۏأڲزۏأځڬڔأهۏأ؏أًۄأثۏتىأڬشحەأۄۏڽأ؏أوۏڽأىەأإځأڬۏأغشلأزۏڬہتأحًأإځأۄىضأشۄەأحہەأ؏أإځأ﷽أىەألشوتۏتأ=““أتْىۏضأ$أدۄتڽأدتىەأڬەأوحؼهمأوۏڽأىەأحوۄۏڽأڬۄتأحہتأ؏أڬۏتأًۄتڽأڲةەأۄًأآ‛‛أوۏڽأىەأؼشعأڬۏتأ=أدۏأۄتڽأ؏أتههۄأڬەأشضًهأ$أوۏڽأدتأشۄتأۄًڽأۗأشًتۄأوضهوأۗ

[تخریج]: رواہ مسلم (54 / 2310)، (6015) ۔"
