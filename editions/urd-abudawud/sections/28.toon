hadiths[119]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
3736,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئ",,,,,3736
3737,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے اسی مفہوم کی حدیث بیان فرمائ,,,,,3737
3738,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں کوئی ا",,,,,3738
3739,اس سند سے بھی نافع سے ایوب کی  روایت جیسی حدیث مروی ہے۔,,,,,3739
3740,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کو دعوت دی جائے اسے دعوت ",,,,,3740
3741,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جسے دعوت دی گئی ",,,,,3741
3742,ابوہریرہ رضی اللہ عنہ کہتے تھے  سب سے برا کھانا اس ولیمہ کا کھانا ہے جس میں صرف مالدار بلائے جائیں ا,,,,,3742
3743,ثابت کہتے ہیں  انس بن مالک رضی اللہ عنہ کے پاس ام المؤمنین زینب بنت جحش رضی اللہ عنہا کے نکاح کا ذکر,,,,,3743
3744,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ام المؤمنین صفیہ رضی اللہ عنہا ,,,,,3744
3745,عبداللہ بن عثمان ثقفی بنو ثقیف کے ایک کانے شخص سے روایت کرتے ہیں   ( جسے اس کی بھلائیوں کی وجہ سے مع,,,,,3745
3746,اس سند سے بھی سعید بن مسیب سے یہی واقعہ مروی ہے اور اس میں یہ ہے کہ  پہلے اور دوسرے روز انہوں نے دعو,,,,,3746
3747,جابر رضی اللہ عنہ کہتے ہیں  جب نبی اکرم صلی اللہ علیہ وسلم مدینہ تشریف لائے تو آپ نے ایک اونٹ یا ایک,,,,,3747
3748,"ابوشریح کعبی رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص اللہ اور ق",,,,,3748
3749,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مہمانداری تین روز تک ہے، ",,,,,3749
3750,"ابوکریمہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر مسلمان پر مہمان کی ای",,,,,3750
3751,"ابوکریمہ مقدام بن معدیکرب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص ",,,,,3751
3752,"عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  ہم نے عرض کیا: اللہ کے رسول! آپ ہمیں  ( جہاد یا کسی دوسرے کام",,,,,3752
3753,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  آیت کریمہ: «لا تأكلوا أموالكم بينكم بالباطل إلا أن تكون ",,,,,3753
