37737,"ذعشحأدتثشأثىأؼثزتههۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أتځىەأإځأڬًأهًڲًڽأڬەأضتوىەأوًملأوۏڽأځۏطألشوتحەأ=أتًشأڬۄحەأ=أڬۏتأڬًةۏأتۏضتأطرظأۄەأدًأودہەأتځىۏأمًوأځشأځۏطأڬشەأۗأڬۏًىڬۄأمشۏطأىەأحًأودہەأتضأثتحأضەأوىؼأڬۏتأۄەأڬۄأوۏڽأتځىەأشثأڬەأڬهتوأڬۏأحثهۏؽأڬشًڽأۗأشتًۏأڬۄحەأۄۏڽأ=أځضأإځأ﷽أڬەأځتضأۄوزتىأڬتأتۏڬأإزوۏأذتعشأۄًتأۗأإځأ﷽أىەأځًډہتأ=أحوأڬضأضەأۄًأآأتضأىەأدًتثأزۏتأۗأۄوزتىأضەأۗأإځأ﷽أىەأځًډہتأ=أحوۄتشۏأمًوأڬەأځتضأوىؼۄأ+أمًحأًأطًڬحأ,أۄەأآأتضأإزوۏأىەأؼشعأڬۏتأۗأدۏأۄتڽأ$أشتًۏأڬۄحەأۄۏڽأ=أًۄأإزوۏأډهتأڲۏتأځہشأتضأڬًأۏۄأرًلأۄًتأڬۄأتضأڬۏأمًوأتضأڬەأضتحہأؼۄزأطڬىۏأڬشەأڲۏأۗأځضأًۄأإزوۏأإځأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأتًشأؼشعأڬۏتأۗأوۏڽأدتحتأۄًڽأتًشأوۏڽأتځىۏأمًوأځشأ+أإځأڬۏأستحأڬًأ,أځۏطأڬشًڽأڲتأځہشأوۏڽأإځأ﷽أڬەأځتضأإةىزۄأضتهأإاڽأڲتأۗأځہشأًۄأإزوۏأډهتأڲۏتأتًشأشدثأڬەأوۄۏىۄأوۏڽأتىظتشأڬەأًلزأذتعشأرزوحأۄًةەأۗ"
37738,ذعشحأؼوشًأثىأوشۄأشًتۏحأڬشحەأۄۏڽأڬۄأوۏڽأتثشتۄۏوأشذوۆأتههۄأؼهۏۄأڬۏأرزوحأوۏڽأذتعشأۄًتأتًشأوۏڽأىەأتىأضەأځًډہتأآأحًأتىہًڽأىەأدًتثأزۏتأۗأضثأضەأځۄهەأتثًثڬشأشعۏأتههۄأؼىۄأتضهتوأهتةەأۗ
37739,"ذعشحأؼتوشأشذوۆأتههۄأؼهۏۄأشًتۏحأڬشحەأۄۏڽأڬۄأوۏڽأىەأتثىأؼثتضأضەأځًډہتأ=أۏتألشوتۏتأ=أتثىأؼثتضأضەأضًتهأڬۏتأڲۏتأ=أڬۄأهًڲًڽأوۏڽأضەأضثأضەأځۄهەأتضهتوأڬًىأهتۏتأحہتأآأتىہًڽأىەأدًتثأزۏتأۗأڬۏتأحوأىەأذضتىأثىأختثحأشعۏأتههۄأؼىۄأڬتأمًهأىۄۏڽأضْىتأۗأ+أحشدوۄأ,أ†أدثأحدہەأتځىەأوؼحوزأثہتةۏأضەأځۄىډتأۄًتأؽوأۏتزأإةەأۗأحًأحًْأتځىەأثہتةۏأتثًثڬشأڬەأڬةەأۄًةەأڬًأۏتزأڬشىتأۗأدًأڬۄأورهًمأوۏڽأضەأثۄحشۏىأ؏أضثأضەأثڔتأوحمۏأتًشأؼتزهأۄەأۗأضًتةەأىثۏأڬەأ؏أتًشأتځىۏأسوۄأزتشۏأڬًأځًشتأڬشىەأًتهتأۄەأۗأتًشأزًضشتأ+أظتذثأتۏوتىأ,أځۏشًڬتشأۄەأ؏أتًشأتضأڬۏأڲًتۄۏأځضىزۏزۄأۄەأۗأتًشأهًڲًڽأوۏڽأضەأضثأضەأځۄهەأشضًهأڬۏأحظزۏمأڬشىەأًتهتأۄەأۗ‟"
37740,ذعشحأۄطتوأثىأؼشًۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأًۄأتځىەأًتهزأضەأشًتۏحأڬشحەأۄۏڽأۗأدضأزىأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأتضهتوأهتةەأحًأتىأڬەأځتضأډتهۏضأۄصتشأزشۄوأحہەأۗ
37741,"ذعشحأودتۄزأشذوۆأتههۄأؼهۏۄألشوتحەأۄۏڽأڬۄأطشًؼأوۏڽأتضهتوأڬتأتػۄتشأڬشىەأًتهەأضتحأهًڲأحہەأۗأشضًهأتههۄأ﷽أ؏أذعشحأتثًثڬشأ؏أذعشحأثهتهأ؏أذعشحأرثتثأ؏أذعشحأظۄۏثأ؏أذعشحأؼوتشأ؏أتوأؼوتشأذعشحأضوۏۄأشعۏأتههۄأؼىۄوأۗ
شضًهأتههۄأ﷽أضەأ+أڬلتشأڬەأهةەأ,أتىأڬەأډډتأوتىؼأثىأڲةەأتًشأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأڬۏأغشلأضەأ+أڬلتشأڬەأهةەأ,أتىأڬۏأمًوأوتىؼأثىأڲةۏأتًشأزۏڲشأهًڲأځڬڔأهۏەأڲةەأتًشأتىہۏڽأهًۄەأڬۏأموۏظۏڽأځۄىتةۏأڲةۏڽأۗأځہشأڬلتشأىەأتىأڬًأضًشدأوۏڽأحځىەأڬەأهۏەأډہًڔأزۏتأۗأذحۏأڬۄأتىأڬۏأوطمحأتىحۄتأزشدۄأڬًأځۄىډأڲةۏأحًأتىہًڽأىەأضًتهأڬۏتأتىأڬەأضًتهأڬًأځًشتأڬشأزۏتأۗأځضأتىأوۏڽأضەأۄشأإزوۏأڬۏأمًوأتضأڬەأځتضأإةۏأدضأوۏڽأځتىۏأحہتأتًشأتىہۏڽأتضأوۏڽأڋتهأزۏتأۗأځہشأتضأڬۏأتغشتلأضەأتټہتأهۏتأۗأضًتةەأذعشحأثهتهأشعۏأتههۄأؼىۄأڬەأۗأځہشأدثأشتحأۄًةۏأحًأتثًدۄهأإۏتأتًشأذعشحأضوۏٔۄأشعۏأتههۄأؼىۄتأڬًأضثٔأًأطحوأڬشىەأهڲتأځہشأتثًدۄهأىەأتىأڬًأىۏصۄأوتشتأتًشأمحهأڬشأزۏتأۗأځضأۏۄأتضهتوأوۏڽأطۄۏزأۄًىەأًتهۏأځۄهۏأطۄۏزۄأۄۏڽأۗأضًأذعشحأثهتهأشعۏأتههۄأؼىۄأىەأتځىۏأدتىأڬًأتههۄأڬەأهۏەأثەأًمؼحأضودہأهۏتأۗأۏۄتڽأحڬأڬۄأوطشڬۏىأثەأحتثأۄًأڲةەأتًشأتىہًڽأىەأإځأڬۏأڲشزىأوۏڽأشضۏأڋتهأزۏأځہشأوطشڬۏىأىەأتځىەأثډًڽأڬًأذڬوأزۏتأتًشأتىہًڽأىەأذعشحأثهتهأشعۏأتههۄأؼىۄأڬًأوڬۄأڬەأځۄتڔًڽأڬەأزشوۏتىأڲہضۏټىتأطشًؼأڬۏتأۗأتًشأذعشحأثهتهأشعۏأتههۄأؼىۄأىەأتذزُأتذزُأڬۄىتأطشًؼأڬۏتأۗ"
37742,ذعشحأودتۄزأشذوۆأتههۄأؼهۏۄأضەأثہۏأتۏضۏأشًتۏحأوىمًهأۄەأۗ
37743,"ذعشحأطؼثۏأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأذعشحأرثتثأشعۏأتههۄأؼىۄأڬەأضًتأثتمۏأىەأدًأضًتهأڬۏتأتضأڬًأتىہًڽأىەأځًشتأڬشأزۏتأۗأحًأوطشڬۏىأىەأذعشحأرثتثأشعۏأتههۄأؼىۄأڬۏأځطحأڬًأڲشوأځحہشًڽأځشأشڬہأزۏتأۏۄتڽأحڬأڬۄأتىأڬۏأڬوشأڬتأځتىۏأرحوأۄًأڲۏتأۗأ+أطتۏزأڬوشأڬۏأډشثۏأڬتأځڲہهىتأوشتزأۄەأ,"
37744,"ذعشحأمۏضأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأتثًثڬشأشعۏأتههۄأؼىۄأىەأذعشحأثهتهأشعۏأتههۄأؼىۄأڬًأځتىډأتًمۏۄأڬەأؼًعأرشۏزتأدثڬۄأًۄأځحہشًڽأڬەأىۏډەأزثەأۄًةەأحہەأۗأوطشڬۏىأىەأڬۄتأڬۄأتڲشأإځأتضأڬًأتۏڬأتًمۏۄأځشأرشۏزىەأڬەأهۏەأحۏتشأۄًأدتةۏڽأحًأۄوأ+أحثأثہۏأ,أۏۄأإځأڬًأثۏډأزۏڽأڲەأۗأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أتڲشأحوأضًأتًمۏۄأځشأثۏډىەأڬەأهۏەأحۏتشأۄًأدتاأحًأوۏڽأ+أحثأثہۏأ,أتضأڬًأرشۏزًڽأڲتأۗ"
37745,ذعشحأغتشمأثىأطۄتثأشذوۆأتههۄأؼهۏۄأضەأشًتۏحأۄەأڬۄأذعشحأرثتثأشعۏأتههۄأؼىۄأوۄتدشۏىأوۏڽأضەأحہەأتًشأتىأتلشتزأوۏڽأضەأحہەأدىۄۏڽأتههۄأڬەأهۏەأؼستثأزۏتأڲۏتأۗ
37746,تثىألعۏهأتځىەأًتهزأضەأشًتۏحأڬشحەأۄۏڽأڬۄأوۏڽأىەأڬشزًضأڬًأڬۄحەأضْىتأڬۄأذعشحأرثتثأثىأتهتشحأشعۏأتههۄأؼىۄأډہټەأىوثشأځشأتضهتوأهتةەأتًشأإځأڬتأتضهتوأوۏڽأډہټتأذظۄأحہتأۗ
37747,ذعشحأتثًهۏهۏٳأڬىزۏأڬۄحەأۄۏڽأڬۄأذعشحأرثتثأشعۏأتههۄأؼىۄأ؏أذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأځتضأحطشۏلأهتةەأحًأذعشحأؼوشأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أمشۏثأۄًأدتةۏەأڬۏًىڬۄأوۏڽأتضأىطضحأڬتأإځأضەأصۏتزۄأذمأزتشأذعشحأؼوتشأشعۏأتههۄأؼىۄأڬەأضًتأڬضۏأڬًأىۄۏڽأځتحتأۗأشتًۏأڬۄحەأۄۏڽأ=أځضأذعشحأرثتثأشعۏأتههۄأؼىۄأذعشحأؼوشأشعۏأتههۄأؼىۄأڬًأوطشڬۏىأڬۏأغشلأضەأزۏةەأڲةەأؼستثأڬەأتځىۏأځطحأځشأتخشتحأزڬہتىەأهڲەأۗ
37748,"ذعشحأؼثزتههۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأضثأضەأځۄهەأدىۄًڽأىەأتځىەأتضهتوأڬًأػتۄشأڬۏتأًۄأضتحأتلشتزأحہەأۗأشضًهأتههۄأ﷽أ؏أذعشحأتثًثڬشأ؏أذعشحأؼوتشأ؏أتىأڬۏأًتهزۄأذعشحأضْوۏٔۄأ؏أذعشحأثهتهأ؏أذعشحأظۄۏثأذعشحأومزتزأشعۏأتههۄأؼىۄوأ؏أځضأشضًهأتههۄأ﷽أڬًأتههۄأحؼتهۏٳأىەأتىأڬەأډډتأتثًغتهثأڬەأسشۏؼۄأ+أوطشڬۏىأضەأ,أثډتۏتأتًشأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأڬًأتههۄأحؼتهۏٳأىەأتىأڬۏأمًوأڬەأسشۏؼۄأضەأ+أوطشڬۏىأضەأ,أثډتۏتأۗأتًشأدًأثتمۏأذعشتحأحہەأتىہۏڽأوطشڬۏىأىەأځڬڔأهۏتأتًشأتىہۏڽأوطشڬۏىأىەأهًۄەأڬۏأموۏعۏڽأځۄىتأزۏڽأتًشأتىہۏڽأضًشدأوۏڽأدهىەأڬەأهۏەأډہًڔأزۏتأۗأځہشأتىأوۏڽأضەأضًتةەأذعشحأثهتهأشعۏأتههۄأؼىۄأڬەأڬًةۏأىۄۏڽأحہتأوڲشأۏۄأڬۄأتضأىەأوطشڬۏىأڬەأتشتزۄأڬۏأوًتلمحأڬشأهۏأۗأذعشحأثهتهأشعۏأتههۄأؼىۄأىەأتځىۏأدتىأڬًأتههۄأڬەأهۏەأثەأًمؼحأضودہأهۏتأۗأتًشأۏۄأتځىۏأمًوأځشأثہۏأثەأًمؼحأحہەأۗأځضأوطشڬۏىأىەأذعشحأثهتهأشعۏأتههۄأؼىۄأڬًأثډًڽأڬەأضځشزأڬشأزۏتأتًشأتىہًڽأىەأإځأڬًأڲہتټۏًڽأوۏڽأځہشتىتأطشًؼأڬۏتأتًشأذعشحأثهتهأشعۏأتههۄأؼىۄأڬۄحەأدتأشۄەأحہەأۗأتذزُأتذزُأۗ"
37749,ذعشحأصۏزأثىأتشموأضەأشًتۏحأۄەأڬۄأضثأضەأځۄهەأدًأطرظأشضًهأتههۄأ﷽أڬەأۄوشتۄأتضهتوأهتۏتأًۄأذعشحأؼهۏأشعۏأتههۄأؼىۄأحہەأۗ
37750,ذعشحأضتهوأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأوۏڽأىەأتثىأتهذىلۏۄأضەأځًډہتأۗأهًڲًڽأوۏڽأضەأضثأضەأځۄهەأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأتضهتوأهتةەأحہەأآأتىہًڽأىەألشوتۏتأ=أىۄۏڽأ$أوۏڽأىەأؼشعأڬۏتأ=أځہشأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأڬضأثىۏتزأځشأؼتهۏأوشحثۄأذتظهأڬۏتأۗأتًشأضثمحأهەأڲةەأۏۄتڽأحڬأڬۄأذعشحأتثًثڬشأظزۏمأشعۏأتههۄأؼىۄأڬەأؼهتًۄأڬضۏأڬتأسڬشأۄۏأىۄۏڽأۄًحتأآأتىہًڽأىەأدًتثأزۏتأڬۄأذعشحأتثًثڬشأظزۏمأشعۏأتههۄأؼىۄأدثأتضهتوأهتةەأحًأًۄأهًڲًڽأوۏڽأضەأضثأضەأتلعهأتضهتوأهتىەأًتهەأحہەأحتإىڬۄأًۄأتځىەأځشًشزڲتشأضەأدتأوهەأۗ
37751,ذعشحأۏصۏزأثىأؼوشًأوؼتلشۏأڬۄحەأۄۏڽأڬۄأوۏڽأىەأتثًخًشألۄوۏأڬًأڬۄحەأضْىتأۗأۄوتشەأځتضأذعشحأؼثزتهشذوىأثىأؼزۏضأثهًۏأۗأۏۄأتىأهًڲًڽأوۏڽأضەأحہەأدىۄًڽأىەأإځأ﷽أڬۏأزشرحأڬەأىۏډەأثۏؼحأڬۏأحہۏأۗأحطشۏلأهتةەأۗأوىثشأځشأډڔہەأتًشأتههۄأحؼتهۏٳأڬۏأذوزأًأخىتأثۏتىأڬۏأځہشأذعشحأؼخوتىأشعۏأتههۄأؼىۄأڬتأسڬشألشوتۏتأ=أذعشحأتثًخًشألشوتحەأۄۏڽأڬۄأوۏڽأذعشحأؼخوتىأڬەأځتضأذتعشأۄًتأدثڬۄأًۄأوذظًشأحہەأۗأحًأتىہًڽأىەألشوتۏتأ=أوۏڽأډًحہتأتضهتوأمثًهأڬشىەأًتهتأۄًڽأۗ
37752,ذعشحأۄطتوأثىأؼشًۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأذعشحأصثۏشأشعۏأتههۄأؼىۄأتضهتوأهتةەأدثڬۄأتىأڬۏأؼوشأضًهۄأضتهأڬۏأحہۏأتًشأًۄأڬضۏأتۏضەأؽصًۄأضەأځۏډہەأىۄۏڽأشۄەأدضأوۏڽأشضًهأتههۄأ﷽أىەأدۄتزألشوتۏتأۄەأۗ
37753,"ذعشحأتثًسشأشعۏأتههۄأؼىۄأثۏتىألشوتحەأۄۏڽأڬۄأوۏڽأ؏أوۏشتأثہتةۏأتْىۏضأتًشأوۏشۏأًتهزۄأۄوأتځىۏأمًوأؽلتشأضەأىڬهەأۗأمًوأًتهەأذشوحأًتهەأوۄۏىًڽأڬًأذهتهأضودہحەأحہەأۗأځضأۄوأډهأزۏةەأۏۄتڽأحڬأڬۄأۄوأتځىەأتۏڬأوتهزتشأتًشأتډہۏأذتهحأًتهەأوتوًڽأڬەأۄتڽأتحشەأۗألشوتحەأۄۏڽأ=أتىہًڽأىەأۄوتشتأتڬشتوأڬۏتأتًشأۄوتشەأضتحہأتډہتأوؼتوهۄأڬۏتأۗأتىأڬۏأمًوأۄوأضەأذضزأڬشىەأهڲۏأتًشأتىہًڽأىەأڬۄتأۗأتڲشأحوأتځىەأتۄهأرتىۄأضەأىڬهًأحًأتىۏضأتىأڬەأضتحہأحوۄتشەأ+أوؼتوهۄأڬەأ,أثشرهتلأوؼتوهۄأڬشەأڲتأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأځضأۄوتشەأوتوًڽأۄوتشەأځتضأإةەأتًشأدًأتىہۏڽأڬۄتأڲۏتأحہتأتىہًڽأىەأًۄأۄوۏڽأثۏتىأڬشأزۏتأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أوۏڽأىەأڬۄتأ=أإځأىەأځۄهەأدًأتډہتأڬتوأڬۏتأحہتأ+أتڬشتوأتًشأتذضتىأ,أإځأىەأ+أتثأ,أتضأڬًأوڬزشأڬشأزۏتأۄەأ+أۄوأ,أإځأڬەأځتضأتثأڬەأثؼزأدوؼأىۄۏڽأۄًڽأڲەأۗألشوتحەأۄۏڽأڬۄأۄوأتځىەأتًىټًڽأڬەأمشۏثأۄًةەأتًشأۄوأتىأځشأضًتشأۄًأڲةەأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأتىہًڽأىەأ+أوتوًڽأىەأ,أتځىتأضشأڋہتىځأهۏتأتًشأشًىتأطشًؼأڬشأزۏتأۗ
5أۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أۄوأډهحەأشۄەأۏۄتڽأحڬأڬۄأۄوأطۄشأوڬۄأوۏڽأإأڬشأتحشەأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأځضأتىۏضأىەأتځىەأتًىټًڽأڬەأڲهۄأتًشأًۏضەأۄۏأزًضشەأتًىټًڽأڬەأڲهۄأڬەأزشوۏتىأولترشحأڬۏأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأځہشأًۄأزًىًڽأ+أتْىۏضأتًشأزًضشەأڲهۄأڬتأوتهڬأ,أتۏڬأڬتۄىأڬەأځتضأڲةەأحًأتضأىەأتىۏضأڬًأزشضحأمشتشأزۏتأۗألشوتحەأۄۏڽأڬۄأځہشأتىۏضأۄوتشەأځتضأتځىەأتًىټًڽأڬتأڲهۄأتًشأتضۏأدۏضتأتۏڬأتًشأڲهۄأهەأڬشأإةەأۗ
6أۗأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أتەأثہحۏدەأ$أحذمۏمأوۏڽأىەأشضًهأتههۄأ﷽أڬەأضتحہأوهتمتحأڬشىەأضەأحۏىأضتهأمثهأىوتصأځڔہۏأۄەأۗأشتًۏأڬۄحەأۄۏڽأ=أوۏڽأىەأؼشعأڬۏتأۗأ+أإځأىەأ,أڬضأڬەأهۏەأىوتصأځڔہۏأآأتىہًڽأىەألشوتۏتأ=أتههۄأڬەأهةەأۗأشتًۏأڬۄحەأۄۏڽأ=أوۏڽأىەأؼشعأڬۏتأ=أإځأڬضأغشلأشْرأڬشحەأحہەأآأتىہًڽأىەألشوتۏتأ=أدضأغشلأتههۄأحؼتهۏٳأوۏشتأشْرألشوتأزۏحەأوۏڽأؼطتؤأځڔہأهۏحتأۗأۏۄتڽأحڬأڬۄأدثأشتحأڬتأإرشۏأذظۄأۄًحتأحًأوۏڽأۏًڽأځتۏتأدتحتأدۏضتأڬۄأوۏڽأډتزشأۄًڽأۏۄتڽأحڬأڬۄأودہأځشأضًشدأثهىزأۄًحتأۗ
7أۗأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأ+أودہەأ,أتْىۏضأىەأڬۄتأ=أودہەأوڬۄأوۏڽأڬتوأۄەأځضأحوأوۏشەأًتځضأإىەأحڬأوۏشۏأسوۄأزتشۏتڽأىثہتاأۗألشوتحەأۄۏڽأ=أځضأًۄأډهەأڲةەأتًشأتىہًڽأىەأزۏشأڬشأزۏأۗأوۏشەأځتضأإةەأتًشأوۏڽأىەأڬۄتأ=أحوۄۏڽأڬضأډۏصأىەأشًڬەأشڬہتأآأتىہًڽأىەأڬۄتأ=أوۏڽأىەأوڬۄأوۏڽأتۏڬأإزوۏأضەأوهتمتحأڬۏأۄەأدًأحۏشەأ+أًتهەأ,أزۏىأځشأۄەأتًشأتضأڬتأرۏتهأۏۄأۄەأڬۄأتههۄأحؼتهۏٳأىەأتضأڬًأشضًهأثىتۏتأۄەأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأوۏڽأىەأځًډہتأ=أهًڲأتىہۏڽأڬۏتأڬۄحەأۄۏڽأآأتْىۏضأىەأڬۄتأ=أهًڲًڽأڬتأڲوتىأۏۄأۄەأڬۄأًۄأدتزًڲشأۄەأ؏أًۄأڬتۄىأۄەأ؏أتًشأًۄأطتؼشأۄەأۗأتْىۏضأىەأڬۄتأ=أثرزتأ$أوۏڽأىەأڬتۄىًڽأڬتأڬهتوأضْىتأ+أۄًتأ,أۄەأهۏڬىأًۄأ+أڬهتوأ,أڬتۄىًڽأڬتأڬهتوأىۄۏڽأۄەأۗأتًشأوۏڽأىەأتىأڬەأڬهتوأڬًأطؼشأڬۏأتىًتؼأوۏڽأشڬہأڬشأزۏڬہتأۄەأحًأًۄأڬضۏأڬۏأصثتىأضەأ+أثہۏأ,أطؼشأڬەأغًشأځشأتزتؤأۄًىتأوطڬهأۄەأۗأثرزتأ$أًۄأإزوۏأضډتأۄەأتًشأهًڲأدہًټەأۄۏڽأۗأذعشحأتىۏضأشعۏأتههۄأؼىۄأطتؼشأ+أثہۏأ,أحہەأۗ
8أۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أوۏڽأىەأڬۄتأ=أحوأوۏشۏأدڲۄأڬلتۏحأ+أسوۄأزتشۏأ,أڬشًأۗأوۏڽأدتأڬشأزۏڬہحتأۄًڽأۗأثہتةۏأىەأڬۄتأ=أټہۏڬأۄەأۗأهۏڬىأتۄهأوڬۄأضەأثډأڬشأشۄىتأڬۏًىڬۄأًۄأتضأإزوۏأڬًأىتځضىزأڬشحەأۄۏڽأتًشأتىأڬەأضتحہأثزڬهتوۏأضەأځۏطأإحەأۄۏڽأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأۗأوۏڽأډهأزۏتأۏۄتڽأحڬأڬۄأوۏڽأوڬۄأوۏڽأځۄىډتأۗألشوتحەأۄۏڽأۗأوۏڽأتىأوۏڽأضەأتۏڬأإزوۏأڬەأځتضأوۄوتىأثىأڲۏتأۗألشوتحەأۄۏڽأوۏڽأىەأځًډہتأ=أًۄأطرظأڬۄتڽأۄەأدضأڬًأحوأظتثۏأڬۄۄأڬشأځڬتشحەأۄًأۗأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أتضأىەأ+أهًڲًڽأڬًأ,أوۏشۏأغشلأتطتشۄأڬشحەأۄًةەأڬۄتأۗأ+أځڬڔًأتضأ,أظتثۏأڬًأۗأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأځضأتۄهأًتزۏأىەأودہأځشأوټۏأڬەأڋہۏهەأتًشأهًۄەأًؽۏشۄأۄشأډۏصأڬەأضتحہأثشضأځڔەأۏۄتڽأحڬأڬۄأوۏڽأثەأۄًطأۄشأڬشأڲشأځڔتأۗألشوتحەأۄۏڽأ=أځضأدثأودہأضەأتټہتأڲۏتأۗأوۏڽأتټہتأۗأحًأ+أودہەأۏًڽأهڲتأ,أڲًۏتأڬۄأوۏڽأضْشرأحظًۏشأۄًڽأۗأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأۗأځضأوۏڽأصوصوأڬەأځتضأإۏتأتًشأوۏڽأىەأرًزأضەأرًىأڬًأزہًۏتأتًشأوتؤٓأصوصوأڬًأځۏتأۗ
9أۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أځضأتۏڬأشًطىأًأظتلأډتىزىۏأشتحأڬًأتههۄأحؼتهۏٳأىەأتۄهأوڬۄأځشأىۏىزأغتشۏأڬشأزۏأۗألشوتحەأۄۏڽأ=أتۄهأوڬٔۄأوۏڽأضەأزًأؼًشحًڽأڬەأضًتأڬًةۏأثۏحأتههۄأڬتأغًتلأڬشىەأىۄأإۏتأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أًۄأزًىًڽأؼًشحۏڽأوۏشەأځتضأإةۏڽأدثڬۄأًۄأتضتلأتًشأىتةهۄأڬًأځڬتشأشۄۏأحہۏڽأۗأوۏڽأىەأڬۄتأ=أتىأزًىًڽأوۏڽأضەأتۏڬأڬتأىڬتذأزًضشەأضەأڬشأزًأۗألشوتحەأۄۏڽأ=أۏۄأثتحأ+أثہۏأ,أتىہۏڽأتىأڬۏأڲلحڲًأضەأىۄأشًڬأضڬۏأۗألشوتحەأۄۏڽأ=أځہشأزًىًڽأوۏشەأځتضأإةۏڽأحًأوۏڽأىەأڬۄتأ=أهڬڔۏأڬۏأغشذأۄۏڽأۗأۏۄأثتحأوۏڽأىەأظتلأظتلأڬۄۄأزۏأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أځضأًۄأزًىًڽأؼًشحۏڽأډهأځڔۏڽأۗأډۏرأًأځڬتشأڬشحۏأۄًةۏأڬۄحۏأدتأشۄۏأحہۏڽأۗأتڲشأۏۄتڽأځشأۄوتشۏأمًوأوۏڽأضەأڬًةۏأۄًحتأحًأۗۗۗ :أۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أتىأؼًشحًڽأڬًأإڲەأضەأشضًهأتههۄأ﷽أتًشأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأوهەأدثڬۄأۏۄأؼًشحۏڽأځۄتڔأضەأتحشأشۄۏأحہۏڽأۗأتىہًڽأىەأځًډہتأۗأحوۄۏڽأڬۏتأۄًتأۄەأآأؼًشحًڽأىەأدًتثأزۏتأۗأتۏڬأظتثۏأڬؼثۄأڬەأځشزًڽأوۏڽأوًدًزأۄەأۗأتىہًڽأىەأځًډہتأ=أتضأىەأحوۄۏڽأڬۏتأڬۄتأۄەأآأؼًشحًڽأىەأدًتثأزۏتأ=أتضأىەأتۏضۏأثتحأڬۄۏأۄەأدضأضەأوىۄأثہشأدتحتأۄەأۗ
;أۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أشضًهأتههۄأ﷽أحطشۏلأهتةەأۏۄتڽأحڬأڬۄأإځأ﷽أذدشأتضًزأڬەأځتضأځۄىډەأځہشأإځأ﷽أىەأتًشأتثًثڬشأشعۏأتههۄأؼىۄأىەأذدشأتضًزأڬتأتضحهتوأڬۏتأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أإځأ﷽أىەأثۏحأتههۄأڬتأغًتلأڬۏتأځہشأإځأ﷽أىەأىوتصأځڔہۏأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأدثأإځأ﷽أىەأتځىۏأىوتصأوڬوهأڬشأهۏأحًأوۏڽأإځأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أوۏڽأځۄهتأطرظأحہتأدضأىەأإځأ﷽أڬًأتضهتوأڬتأضهتوأځۏطأڬۏتأحہتأۗأإځأ﷽أىەأدًتثتَألشوتۏتأ=أحوأځشأثہۏأضهتوأتًشأتههۄأڬۏأشذوحأۄًأۗأحوأڬضأ+أمثۏهۄأ,أضەأۄًأآأوۏڽأىەأؼشعأڬۏتأ=أؽلتشأضەأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أإځأ﷽أىەأتځىتأزضحأوثتشڬأضەأتځىەأضشأڬۏأغشلأتطتشۄأڬۏتأۗألشوتحەأۄۏڽأ=أوۏڽأىەأزهأوۏڽأڬۄتأ=أإځأ﷽أىەأوۏشۏأمثۏهۄأؽلتشأڬۏأىضثحأڬشىەأڬًأىتځضىزأڬۏتأۄەأۗأڬۄحەأۄۏڽأ=أوۏڽأإځأ﷽أڬتأۄتحہأځڬڔىەأڬەأهۏەأثڔہتأۗأحًأإځأ﷽أڬەأظذتثۏأ+أتثًثڬشأشعۏأتههۄأؼىۄأ,أىەأودہەأإځأ﷽أضەأشًڬأزۏتأۗأًۄأودہأضەأصۏتزۄأإځأ﷽أضەأًتملأحہەأۗأځہشأإځأ﷽أىەأتځىتأضشأوثتشڬأتټہتۏتأتًشأڬۄتأ=أحوأۏۄتڽأځشأڬثأضەأۄًأآألشوتحەأۄۏڽأ=أوۏڽأىەأڬۄتأۗأوۏشەأۏۄتڽأمۏتوأڬۏأشتحأ؏أزىأوهتأڬشأزضأڬۏأڲىحۏأځًشۏأۄًأډڬۏأۄەأۗأإځأ﷽أىەأځًډہتأ=أحوۄۏڽأڬہتىتأڬًىأڬہهتحتأحہتأآألشوتحەأۄۏڽأ=أوۏڽأىەأؼشعأڬۏتأۗأصوصوأڬەأځتىۏأڬەأضًتأوۏشەأهۏەأڬًةۏأڬہتىتأىۄۏڽأۄەأۗأوۏڽأ+أتضأڬەأتضحؼوتهأضەأ,أوًټتأۄًأڲۏتأۄًڽأۏۄتڽأحڬأڬۄأوۏشەأځۏټأڬۏأضهًټۏڽأټًټأڲةۏأۄۏڽأۗأتًشأودہەأثہًڬأڬۏأًدۄأضەأتځىەأڬهۏدۄأوۏڽأڬوصًشۏأوذضًضأىۄۏڽأۄًحۏأۗأإځأ﷽أىەأتشطتزألشوتۏتأ=أۏۄأثتثشڬحأځتىۏأۄەأۏۄأځتىۏأرًشتڬأًتهتأڬہتىتأۄەأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأځہشأإځأ﷽أڬەأضتحہۏأىەأڬۄتأۗأإځأودہەأتضأڬۏأوۄوتىأىًتصۏأڬۏأإدأشتحأڬەأهۏەأتدتصحأؼىتۏحألشوتأزۏڽأۗ <أۗأځہشأشضًهأتههۄأ﷽أتًشأتثًثڬشأشعۏأتههۄأؼىۄأډهأځڔەأتًشأوۏڽأثہۏأتىأڬەأۄوشتۄأډهأځڔتأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأځہشأتثًثڬشأشعۏأتههۄأؼىۄأىەأتۏڬأزًشًتصۄأڬہًهتأتًشأوۏشەأهۏەأغتةلأڬتأڬطوطأځڬڔتأۗأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأۗأۏۄأوۏشتأځۄهتأڬہتىتأحہتأدًأوۏڽأىەأوڬۄأوۏڽأڬہتۏتأۗألشوتحەأۄۏڽأ=أځہشأوۏڽأټہۄشتأدحىتأټہۄشتأۗأۏتألشوتۏتأ=أدحىتأټہۄشىتأحہتأۗأځہشأوۏڽأىەأشضًهأتههۄأ﷽أضەأوهتمتحأڬۏأحًأإځأ﷽أىەأتشطتزألشوتۏتأ=أثهتطثۄأحذمۏمأودہەأتۏڬأڬہدًشًڽأًتهۏأصوۏىأڬۏأغشلأوحًدۄأڬۏتأۄەأۗأتًشأوۏشەأڲوتىأڬەأوغتثمأًۄأۏخشثأۄۏأۄەأۗأځضأڬۏتأحوأتځىۏأمًوأڬًأوۏشۏأغشلأضەأحثهۏؽأڬشًأڲەأآأۄًأضڬحتأۄەأتههۄأحؼتهۏٳأتىأڬًأإځأڬەأسشۏؼۄأضەأىلؼأزۏڽأتًشأإځأڬتأتىأڬًأتدشأزۏڽأآأوۏڽأىەأؼشعأڬۏتأ=أدۏأۄتڽأ$
43أۗأځہشأوۏڽأډهأځڔتأۏۄتڽأحڬأڬۄأوۏڽأ+أثہتةۏأ,أتْىۏضأڬەأځتضأځۄىډتأۗأتىہًڽأىەأځًډہتأ=أحوأىەأڬۏتأڬۏتأۄەأآأوۏڽأىەأڬۄتأۗأوۏڽأىەأۏۄأڬۏتأۄەأڬۄأتضهتوأهەأإۏتأۄًڽأتًشأحظزۏمأ+أشضتهحأ,أڬۏأۄەأۗأتْىۏضأىەأڬۄتأۗأودہەأحوۄتشەأزۏىأضەأڬًةۏأتؼشتعأىۄۏڽأۄەأۗأوۏڽأثہۏأتضهتوأهەأإۏتأۄًڽأتًشأوۏڽأىەأثہۏأحظزۏمأڬشأزۏأۄەأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأځضأۄوأتځىۏأًتهزۄأڬۏأرزوحأوۏڽأذتعشأۄًةەأحًأًتهزۄأىەأ+أثہۏأ,أڬۄتأۗأودہەأحوأزًىًڽأڬەأزۏىأضەأڬًةۏأتؼشتعأىۄۏڽأۄەأۗأوۏڽأثہۏأتضهتوأهتأډڬۏأۄًڽأتًشأوۏڽأىەأثہۏأحظزۏمأڬشأزۏأۄەأۗأتثًسشأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أځہشأۄوأهًڲأضًتشۏًڽأځشأضًتشأۄًةەأۏۄتڽأحڬأڬۄأۄوأتځىۏأمًوأؽلتشأوۏڽأځۄىډەأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأثؼعأمًوأؽلتشأڬەأهًڲأىثۏأڬشۏوأ﷽أڬەأوزۏىۄأحطشۏلأهتىەأضەأځۄهەأتضهتوأهەأإةەأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأتىأوضهوتىًڽأڬًأتٗۏوتؤأثىأشّرّظۄأ؏أدًأڬۄأمًوأڬەأضشزتشأحہەأۗأتوتوحأڬشًتحەأحہەأۗألشوتحەأۄۏڽأ=أثتمۏأهًڲًڽأىەأڬۄتأ=أدثأتههۄأڬەأشضًهأ﷽أحطشۏلأهتةۏڽأڲەأحًأۄوأتضهتوأهەأإةۏڽأڲەأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أځہشأشضًهأتههۄأ﷽أوزۏىۄأوىًشۄأحطشۏلأهتةەأحًأثمۏۄأهًڲأثہۏأوضهوتىأۄًأڲةەأۗ
44أۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أمثۏهۄأتضهوأإۏتأحًأتىہًڽأىەأڬۄتأ=أ+أحوأ,أۄوتشەأثہتةۏأۄًأۗأدًأهًڲأإځأ﷽أځشأتضهتوأهتةەأۄۏڽأۄوأتىأځشأضهتوحۏأ+أڬۏأزؼتأ,أڬشحەأۄۏڽأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أځہشأحوتوأهًڲأوضهوتىأۄًأڲةەأۗأتثًسشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أځہشأشضًهأتههۄأ﷽أحطشۏلأهتةەأحًألشوتۏتأ=أ+أمثۏهۄأ,أؽلتشأآأتههۄأتضأڬۏأوؽلشحأڬشەأۗأتًشأ+أمثۏهۄأ,أتضهوأ$أتههۄأتضأڬًأضهتوحأشڬہەأۗ"
37754,"ذعشحأدتثشأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأڬەأتضهتوأڬتأتًٔهأ+أصوتىۄأ,أحہتأۗألشوتحەأۄۏڽأۗأذعشحأؼوشأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأۗأتۏڬأشتحأوۏشۏأثۄىأڬًأتًىټىۏأىەأوتشتأحًأودہەأڲہشأضەأىڬتهأزۏتأڲۏتأۗأځضأوۏڽأتۏڬأټہىڋۏأشتحأڬًأڬؼثۄأڬەأځشزًڽأوۏڽأزترهأۄًتأۗأذعشحأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأځضأىثۏأڬشۏوأ﷽أحطشۏلأهتةەأتًشأإځأذدشأتضًزأځشأزترهأۄًةەأدثڬۄأإځأ﷽أىەأدًحەأځۄىەأۄًةەأحہەأۗأإځأ﷽أىەأىوتصأځڔہۏأدحىۏأزۏشأتههۄأحؼتهۏٳأىەأډتۄتأځہشأإځأ﷽أًتځضأوڔەأۗأذعشحأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأۗأوۏڽأىەأتۏضۏأطةۏأضْىۏأدضأڬۏأوخهأوۏڽأىەأ+أځۄهەأ,أىۄۏڽأضْىۏأحہۏأۗأځضأوۏڽأىڬهتأتًشأإځأ﷽أڬەأځۏډہەأۄًأهۏتأۗأإځأ﷽أىەأځًډہتأ=أۏۄأڬًىأۄەأآأوۏڽأىەأؼشعأڬۏتأۗأؼوشأۄەأۗأإځأ﷽أىەألشوتۏتأ=أتەأؼوشأ$أحًأودہەأزىأڬًأډہًڔحتأۄەأتًشأىۄأۄۏأشتحأڬًأۗأذعشحأؼوشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أودہەأتضأثتحأڬتأرًلأۄًتأڬۄأإځأ﷽أوۏشەأهۏەأثززؼتأڬشأزۏڽأڲەأۗألشوتحەأۄۏڽأ=أوۏڽأىەأڬۄتأ=أوۏڽأڲًتۄۏأزۏحتأۄًڽأڬۄأتههۄأڬەأضًتأڬًةۏأوؼثًزأىۄۏڽأۄەأتًشأثهتطثۄأإځأتههۄأڬەأشضًهأۄۏڽأۗألشوتحەأۄۏڽأۗأإځأ﷽أىەألشوتۏتأ=أتەأؼوشأ$أتضأڬًأډہځتاأۗألشوتحەأۄۏڽأ=أوۏڽأىەأؼشعأڬۏتأۗأمضوأتضأستحأڬۏأ$أدضأىەأإځأڬًأذمأڬەأضتحہأوثؼًخأڬۏتأۄەأۗأتهثحۄأوۏڽأعشًشأثتهعشًشأتضأڬتأۏًڽأۄۏأتؼهتىأڬشًڽأڲتأدۏضتأڬۄأوۏڽأىەأطشڬأڬتأتؼهتىأڬۏتأحہتأۗ"
37755,ذعشحأۄهتهأثىأۏضتلأضەأشًتۏحأۄەأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأډتهۏضأوشزًڽأتًشأڲۏتشۄأؼًشحًڽأڬەأثؼزأتضهتوأهتةەأحہەأۗ
