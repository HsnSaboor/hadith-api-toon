hadiths[1]{hadithnumber,text}:
27674,أذعشحأضهوۏأثىحأمۏضأشعۏأتههۄأؼىۄتأ““أدًأڬۄأىثۏأ﷽أڬۏأتۏڬأرتهۄأتًشأمثهحۏىأڬۏأغشلأىوتصأځڔہىەأًتهًڽأوۏڽأضەأحہۏڽأ‛‛أضەأوشًۏأۄەأڬۄأوۏڽأڬډہأوضهوتىأرًتحۏىأڬەأضتحہأىثۏأ﷽أڬۏأرزوحأوۏڽأثۏؼحأڬەأهةەأذتعشأۄًةۏأتًشأىثۏأ﷽أىەأۏۄأطشغأهڲتةۏأڬۄأتههۄأڬەأضتحہأڬضۏأڬًأطشۏڬأىۄۏڽأټہۄشتاأڲۏأ؏أډًشۏأىۄۏڽأڬشًأڲۏأ؏أثزڬتشۏأىۄۏڽأڬشًأڲۏأ؏أتځىۏأتًهتزأڬًأمحهأىۄۏڽأڬشًأڲۏأ؏أڬًةۏأثۄحتىأتځىەأۄتحہًڽأځۏشًڽأڬەأزشوۏتىأىۄۏڽأڲہڔًأڲۏأ؏أتًشأڬضۏأىۏڬۏأڬەأڬتوأوۏڽأإځأڬۏأىتلشوتىۏأىۄۏڽأڬشًأڲۏأتًشأتځىەأطًۄشًڽأڬًأزہًڬۄأىۄۏڽأزًأڲۏأ؏أۄوأىەأىثۏأ﷽أضەأتىأطشتةغأځشأثۏؼحأڬشأهۏأ؏أدثأۄوأًتځضأدتىەأهڲەأحًأتىأوۏڽأضەأتۏڬأؼًشحأڬۄىەأهڲۏأڬۄأدتأڬشأىثۏأ﷽أضەأځًډہًأڬۄأطًۄشأڬًأزہًڬۄأزۏىەأضەأڬۏتأوشتزأۄەأآأډىتىډۄأضًتهأڬشىەأځشأىثۏأ﷽أىەألشوتۏتأتضأڬتأوتهأهەأڬشأؽۏشأځشأتىظتلأضەأۄټأڬشأرشډأڬشىتأۗ
