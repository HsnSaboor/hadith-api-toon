hadiths[28]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
3641,کثیر بن قیس کہتے ہیں کہ  میں ابو الدرداء رضی اللہ عنہ کے ساتھ دمشق کی مسجد میں بیٹھا تھا کہ اتنے میں,,,,,3641
3642,اس سند سے بھی ابو الدرداء رضی اللہ عنہ سے  اسی مفہوم کی حدیث مرفوعاً مروی ہے۔,,,,,3642
3643,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص حصول علم کے لیے ک",,,,,3643
3644,ابونملہ انصاری رضی اللہ عنہ کہتے ہیں کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کے پاس بیٹھے ہوئے تھے اور آ,,,,,3644
3645,زید بن ثابت رضی اللہ عنہ کہتے ہیں  اللہ کے رسول صلی اللہ علیہ وسلم نے مجھے حکم دیا تو میں نے آپ کی خ,,,,,3645
3646,عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں  میں ہر اس حدیث کو جو رسول اللہ صلی اللہ علیہ وسلم سے سنتا ی,,,,,3646
3647,مطلب بن عبداللہ بن حنطب کہتے ہیں کہ  زید بن ثابت رضی اللہ عنہ معاویہ رضی اللہ عنہ کے پاس آئے اور ان ,,,,,3647
3648,ابو سعید خدری رضی اللہ عنہ کہتے ہیں  ہم لوگ تشہد اور قرآن کے علاوہ کچھ نہیں لکھتے تھے۔,,,,,3648
3649,ابوہریرہ رضی اللہ عنہ کہتے ہیں  جب مکہ فتح ہوا تو نبی اکرم صلی اللہ علیہ وسلم کھڑے ہوئے، پھر انہوں ن,,,,,3649
3650,"ولید (ولید بن مزید) کہتے ہیں  میں نے ابوعمرو  ( اوزاعی )  سے کہا:  وہ لوگ لکھ دیں  سے کیا مراد ہے؟ ا",,,,,3650
3651,"عبداللہ بن زبیر رضی اللہ عنہما کہتے ہیں کہ  میں نے زبیر رضی اللہ عنہ سے پوچھا: آپ رسول اللہ صلی اللہ",,,,,3651
3652,"جندب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے اللہ تعالیٰ کی کتاب می",,,,,3652
3653,ابو سلام ایک شخص سے جس نے نبی اکرم صلی اللہ علیہ وسلم کی خدمت کی ہے روایت کرتے ہیں، وہ کہتے ہیں کہ  ,,,,,3653
3654,عروہ کہتے ہیں  ابوہریرہ رضی اللہ عنہ ام المؤمنین عائشہ رضی اللہ عنہا کے حجرے کے بغل میں بیٹھے تھے او,,,,,3654
3655,"عروہ بن زبیر کہتے ہیں کہ  ام المؤمنین عائشہ رضی اللہ عنہا نے کہا: کیا تمہیں ابوہریرہ رضی اللہ عنہ پر",,,,,3655
3656,معاویہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایسی باتوں سے منع فرمایا ہے جس میں ب,,,,,3656
3657,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے فتوی دیا  اور سلیم",,,,,3657
3658,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس سے کوئی دین کا مسئلہ ",,,,,3658
3659,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ  ( علم د",,,,,3659
3660,"زید بن ثابت رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  اللہ ",,,,,3660
3661,"سہل بن سعد رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قسم اللہ کی، اگر تیر",,,,,3661
3662,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بنی اسرائیل سے روایت کرو",,,,,3662
3663,عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ہم سے بنی اسرائیل کی باتیں ا,,,,,3663
3664,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے ایسا علم صرف د",,,,,3664
3665,"عوف بن مالک اشجعی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ",,,,,3665
3666,ابو سعید خدری رضی اللہ عنہ کہتے ہیں  میں غریب و خستہ حال مہاجرین کی جماعت میں جا بیٹھا، ان میں بعض ب,,,,,3666
3667,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میرا ایسی قوم کے ساتھ",,,,,3667
3668,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیںمجھ سے رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم مجھ پر سورۃ",,,,,3668
