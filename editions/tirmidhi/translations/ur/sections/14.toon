{"hadithnumber": "1282", "text": "ابوامامہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”گانے والی لونڈیوں کو"}
{"hadithnumber": "1283", "text": "ابوایوب انصاری رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: ”جو شخص"}
{"hadithnumber": "1284", "text": "علی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے دو غلام دیئے جو آپس میں بھائی تھ"}
{"hadithnumber": "1285", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فیصلہ کیا کہ فائدے کا ا"}
{"hadithnumber": "1286", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فیصلہ کیا کہ فائدہ کا اس"}
{"hadithnumber": "1287", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص کسی باغ"}
{"hadithnumber": "1288", "text": "رافع بن عمرو رضی الله عنہما کہتے ہیں کہ  میں انصار کے کھجور کے درختوں پر پتھر مارتا تھا، ان لوگوں نے"}
{"hadithnumber": "1289", "text": "عبداللہ بن عمرو رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سے لٹکے ہوئے پھل کے بارے میں"}
{"hadithnumber": "1290", "text": "جابر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے محاقلہ، مزابنہ ۱؎ مخابرہ ۲؎ اور بیع م"}
{"hadithnumber": "1291", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص غلہ خر"}
{"hadithnumber": "1292", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے کوئی"}
{"hadithnumber": "1293", "text": "ابوطلحہ رضی الله عنہ کہتے ہیں کہ  انہوں نے عرض کیا: اللہ کے نبی! میں نے ان یتیموں کے لیے شراب خریدی"}
{"hadithnumber": "1294", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سے پوچھا گیا: کیا شراب کا سرکہ بنا"}
{"hadithnumber": "1295", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے شراب کی وجہ سے ”دس آدمیوں پر"}
{"hadithnumber": "1296", "text": "سمرہ بن جندب رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جب تم میں سے کوئی"}
{"hadithnumber": "1297", "text": "جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  انہوں نے فتح مکہ کے سال مکہ کے اندر رسول اللہ صلی اللہ ع"}
{"hadithnumber": "1298", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”بری مثال ہمارے"}
{"hadithnumber": "1299", "text": "عبداللہ بن عمر اور ابن عباس رضی الله عنہم سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”کس"}
{"hadithnumber": "1300", "text": "زید بن ثابت رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے محاقلہ اور مزابنہ سے منع فرمایا"}
{"hadithnumber": "1301", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے پانچ وسق سے کم میں عرایا کے بیچنے"}
{"hadithnumber": "1302", "text": "زید بن ثابت رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اندازہ لگا کر عرایا کو بیچنے ک"}
{"hadithnumber": "1303", "text": "رافع بن خدیج اور سہل بن ابی حثمہ رضی الله عنہما کا بیان ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے بیع م"}
{"hadithnumber": "1304", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم نجش نہ کرو“۔ \\r\\n\\r\\nامام"}
{"hadithnumber": "1305", "text": "سوید بن قیس رضی الله عنہ کہتے ہیں کہ  میں اور مخرمہ عبدی دونوں مقام ہجر سے ایک کپڑا لے آئے، نبی اکر"}
{"hadithnumber": "1306", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص کسی تنگ دست  ( قر"}
{"hadithnumber": "1307", "text": "ابومسعود انصاری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم سے پہلی امتوں"}
{"hadithnumber": "1308", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم فرمایا: ”مالدار آدمی کا قرض کی اد"}
{"hadithnumber": "1309", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”مالدار آدمی ک"}
{"hadithnumber": "1310", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بیع منابذہ اور بیع ملامسہ سے منع"}
{"hadithnumber": "1311", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مدینہ تشریف لائے اور اہل مد"}
{"hadithnumber": "1312", "text": "جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس آدمی کے باغ"}
{"hadithnumber": "1313", "text": "جابر رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے بیع محاقلہ، مزابنہ ۱؎، مخابرہ ۲؎ اور م"}
{"hadithnumber": "1314", "text": "انس رضی الله عنہ کہتے ہیں کہ  ایک بار رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں  ( غلہ وغیرہ کا )  ن"}
{"hadithnumber": "1315", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک غلہ کے ڈھیر سے گزرے، تو آپ نے اس"}
{"hadithnumber": "1316", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک جوان اونٹ قرض لیا اور آپ نے ا"}
