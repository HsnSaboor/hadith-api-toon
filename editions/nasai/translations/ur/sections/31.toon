{"hadithnumber": "3672", "text": "عمرو بن خارجہ رضی الله عنہ نے ذکر کیا کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کے اس خطبہ میں موجود تھے ج"}
{"hadithnumber": "3673", "text": "عمرو بن خارجہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ عزوجل نے ہر صا"}
{"hadithnumber": "3674", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  جب آیت: «وأنذر عشيرتك الأقربين» نازل ہوئی تو رسول اللہ صلی اللہ ع"}
{"hadithnumber": "3675", "text": "موسیٰ بن طلحہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اے بنی عبد مناف! اپ"}
{"hadithnumber": "3676", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم پر جب آیت: «وأنذر عشيرتك الأقربين» ”"}
{"hadithnumber": "3677", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  جب آیت کریمہ: «وأنذر عشيرتك الأقربين» ”اے محمد! اپنے قریبی رشتہ د"}
{"hadithnumber": "3678", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  جب آیت کریمہ: «وأنذر عشيرتك الأقربين» نازل ہوئی تو رسول"}
{"hadithnumber": "3679", "text": "ام المؤمنین عائشہ رضی الله عنہا سے روایت ہے کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم سے کہ: میری"}
{"hadithnumber": "3680", "text": "سعد بن عبادہ رضی الله عنہ سے روایت ہے کہ  وہ ایک غزوہ میں نبی اکرم صلی اللہ علیہ وسلم کے ساتھ تھے کہ"}
{"hadithnumber": "3681", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب انسان مر جاتا ہے ت"}
{"hadithnumber": "3682", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم سے کہا:  ( اللہ کے رسول"}
{"hadithnumber": "3683", "text": "شرید بن سوید ثقفی رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کے پاس آ کر آپ سے عر"}
{"hadithnumber": "3684", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  سعد رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے پو"}
{"hadithnumber": "3685", "text": "عبداللہ بن عباس رضی الله عنہا سے روایت ہے کہ  ایک شخص نے کہا: اللہ کے رسول! میری ماں کا انتقال ہو گی"}
{"hadithnumber": "3686", "text": "سعد بن عبادہ رضی الله عنہ سے روایت ہے کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ کر کہا: میری"}
{"hadithnumber": "3687", "text": "سعد بن عبادہ رضی الله عنہ سے روایت ہے کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم سے اس نذر کے متعلق مس"}
