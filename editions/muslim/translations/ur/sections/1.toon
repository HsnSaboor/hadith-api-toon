{"hadithnumber": "333", "text": "مسعر  ، ہشام اور شیبان سب نے قتادہ سے سابقہ سند کے ساتھ اسی حدیث کی طرح روایت کی  ۔"}
{"hadithnumber": "334", "text": "اعرج نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا  :  رسول اللہ ﷺ نے فرمایا  :"}
{"hadithnumber": "335", "text": "علاء کے والد عبد الرحمن بن یعقوب نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے رسول  اللہ"}
{"hadithnumber": "336", "text": "ہمام بن منبہ نے روایت کرتے ہوئے کہا  :  یہ وہ حدیثیں ہیں جو ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ہمیں م"}
{"hadithnumber": "337", "text": "ابن سیرین نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا  :  رسول اللہ ﷺ نے فرم"}
{"hadithnumber": "338", "text": "عبدالوارث نے جعد ابو عثمان سے حدیث سنائی  ،  انہوں نےکہا  :  ہمیں ابو رجاء عطاردی نے حضرت ابن عباس"}
{"hadithnumber": "339", "text": "جعفر بن سلیمان نے جعد ابوعثمان سے عبد الوارث کی حدیث کے ہم معنی روایت کی اور یہ اضافہ کیا  :  ’’یا ا"}
{"hadithnumber": "340", "text": "سہیل نے اپنے والد سے  ،  انہوں نے ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا :  نبی"}
{"hadithnumber": "341", "text": "اعمش نے ابو صالح سے  ،  انہوں نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے بنی ﷺ سے یہ حدیث"}
{"hadithnumber": "342", "text": "حضرت عبد اللہ  ( بن مسعود (   ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا کہ نبی ﷺ سے وسوسے کے"}
{"hadithnumber": "343", "text": "سفیان نے ہشام سے حدیث سنائی  ،  انہوں نے اپنےوالد  ( عروہ )  سے  ،  انہوں نے حضرت ابوہریرہ  ‌رضی ‌ال"}
{"hadithnumber": "344", "text": "ابو سعید مؤدب نے ہشام بن عروہ سے اسی سند کے ساتھ روایت کی کہ رسول ا للہ ﷺ نے فرمایا  : ’’ تم میں سے"}
{"hadithnumber": "345", "text": "ابن شہاب کے بھتیجے  (  محمد بن عبد اللہ بن مسلم  )  نے اپنے چچا  (  محمد بن مسلم زہری  )  سے حدیث سن"}
{"hadithnumber": "346", "text": "عقیل بن خالد نے کہاکہ ابن شہاب نے کہا  :  مجھے عروہ بن زبیر نے خبر دی کہ حضرت ابوہریرہ  ‌رضی ‌اللہ ‌"}
{"hadithnumber": "347", "text": "عبد الوارث بن عبد ا لصمد کے دادا عبد الوارث بن سعید نے ایوب سے  ،  انہوں نے محمد بن سیرین سے  ،  انہ"}
{"hadithnumber": "348", "text": "اسماعیل بن علیہ نے ایوب سے  ،  انہوں نے محمد سے روایت کی کہ حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ک"}
{"hadithnumber": "349", "text": "ابو سلمہ نے حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا  : مجھ سے رسول اللہ ﷺ ن"}
{"hadithnumber": "350", "text": "یزید بن اصم نے کہا  :  میں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا  ،  وہ کہتے تھے  :  رسول ا"}
{"hadithnumber": "351", "text": "محمد بن فضیل نے مختار بن فلفل سے  ،  انہوں نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے  ،  انہوں نے"}
{"hadithnumber": "352", "text": "اسحق بن ابراہیم نے کہا :  ہمیں جریر نے خبر دی  ،  نیز ابو بکر بن ابی شیبہ نے کہا  :  ہمیں حسن بن علی"}
{"hadithnumber": "353", "text": "معبد بن کعب سلمی نے اپنے بھائی عبد اللہ بن کعب سے  ،  انہوں نے حضرت ابو امامہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "354", "text": "محمد بن کعب سے روایت ہے  ،  انہوں نےاپنے بھائی عبد اللہ بن کعب سےسنا  ،  وہ بیان کر تے تھے کہ ابو ام"}
{"hadithnumber": "355", "text": "اعمش نے ابو وائل سے  ،  انہوں نے حضرت عبد اللہ  (  بن مسعود )   ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے"}
{"hadithnumber": "356", "text": "( اعمش کے بجائے  )  منصور نے ابووائل سے اور انہوں نے عبداللہ بن مسعود ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت"}
{"hadithnumber": "357", "text": "جامع بن ابی راشد اور عبد المالک بن اعین نے  ( ابو وائل )  شقیق بن سلمہ سے سنا  ،  کہہ رہے تھے  : میں"}
{"hadithnumber": "358", "text": "سماک نے علقمہ بن وائل سے  ،  انہوں نے اپنے والد (  حضرت وائل بن حجر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  )  سے روای"}
{"hadithnumber": "359", "text": "زہیر بن حرب اور اسحاق بن ابراہیم دونوں نے ابو ولید سے حدیث سنائی  ( زہیر نے عن أبى الولید کے بجائے ح"}
{"hadithnumber": "360", "text": "حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا  :  ایک آدمی رسول اللہ ﷺ کی خدمت می"}
{"hadithnumber": "361", "text": "عبد الرزاق نے کہا  :  ہمیں ابن جریج نے خبر دی ،  انہوں نے کہا  :  مجھے سلیمان احول نے خبر دی کہ عمر"}
{"hadithnumber": "362", "text": "( ابن جریج کے دوسرے شاگردوں  )  محمد بن بکر اور ابو عاصم نےاسی مذکورہ سند کے ساتھ  (  سابقہ حدیث  )"}
{"hadithnumber": "363", "text": "ابو اشہب نے حسن ( بصری )  سے حدیث بیان کی  ،  انہوں نے کہا  : عبید اللہ بن زیاد نےحضرت معقل بن یسار"}
{"hadithnumber": "364", "text": "( ابو اشہب کے بجائے  )  یونس نے حسن سے روایت کی  ،  انہوں نےکہا :  عبید اللہ بن زیاد حضرت معقل بن یس"}
{"hadithnumber": "365", "text": "(  ایک اور سند سے  )  ہشام سے روایت ہے  ،  انہوں نےکہا :  حسن نے کہا  :  ہم معقل بن یسار ‌رضی ‌اللہ"}
{"hadithnumber": "366", "text": "ابو ملیح  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ عبید اللہ بن زیاد نےمعقل بن یسار ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "367", "text": "ابو معاویہ اور وکیع نے اعمش سے حدیث سنائی  ،  انہوں نے زید بن وہب سے اور انہوں نے حضرت حذیفہ  ‌رضی ‌"}
{"hadithnumber": "368", "text": "( اعمش کےدوسرے شاگردوں  )  عبد اللہ بن نمیر  ،  وکیع اور عیسیٰ بن یونس نے بھی اسی سند کے ساتھ مذکورہ"}
{"hadithnumber": "369", "text": "ابو خالد سلیمان بن حیان نے سعد بن طارق سے حدیث سنائی ،  انہوں نے ربعی سے اور انہوں نے حضرت  حذیفہ  ‌"}
{"hadithnumber": "370", "text": "مروان فزاری نے کہا  :  ہمیں ابو مالک اشجعی نے حضرت ربعی سے حدیث سنائی  ،  انہوں نےکہا : جب حذیفہ  ‌ر"}
{"hadithnumber": "371", "text": "نعیم بن ابی ہند نے ربعی بن حراش سے اور انہوں نےحضرت حذیفہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ حضرت"}
{"hadithnumber": "372", "text": "حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ،  انہوں نے کہا  :  رسو ل اللہ ﷺ نے فرمایا  :  ’’اس"}
{"hadithnumber": "373", "text": "سیدنا عبداللہ بن عمر ؓ سے روایت ہے ، رسول اللہ ﷺ نے فرمایا : ” اسلام شروع ہوا غربت میں اور پھر غریب"}
{"hadithnumber": "374", "text": "حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسو ل اللہ ﷺ نے فرمایا  :  ’’ بلاشبہ ایمان مدینہ"}
{"hadithnumber": "375", "text": "حماد نے کہا :  ہمیں ثابت نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث سنائی کہ رسول اللہ ﷺ نے فرمایا :"}
{"hadithnumber": "376", "text": "معمر نے ثابت سے خبر دی  ،  انہوں نے حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا کہ ر"}
{"hadithnumber": "377", "text": "حضرت حذیفہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت ہے ،  انہوں نے کہا  :  ہم رسو ل اللہ ﷺ کے ساتھ تھے ،  آپ نے"}
{"hadithnumber": "378", "text": "سفیان نے زہری سے حدیث بیان کی ،  انہوں نے عامر بن سعد (  بن ابی وقاص )  سے اور انہوں نے اپنے والد سے"}
{"hadithnumber": "379", "text": "ابن شہاب  ( زہری )  کے بھتیجے نے اپنے چچا سے حدیث بیان کی  ، انہوں نے کہا  :  مجھے عامر بن سعد بن اب"}
{"hadithnumber": "380", "text": "صالح نے ابن شہاب سے روایت کی  ،  انہوں نے کہا  :  مجھے عامر بن سعد نے اپنے والد  ( حضرت  )  سعد ‌رضی"}
{"hadithnumber": "381", "text": "( عامر بن سعد کے بھائی )  محمد بن سعد یہ حدیث بیان کرتے ہیں  ،  انہوں نے اپنی حدیث میں کہا :  رسول"}
{"hadithnumber": "382", "text": "یونس نے ابن شہاب زہری سے خبر دی ،  انہوں نے ابو سلمہ بن عبد الرحمن اور سعید بن مسیب سے روایت کی  ،"}
{"hadithnumber": "383", "text": "مالک نے زہری سے روایت کی کہ سعید بن  مسیب اور ابوعبیدہ نے انہیں حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "385", "text": "حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسو ل اللہ ﷺ نے فرمایا :  ’’ انبیاء میں سے ہر ای"}
{"hadithnumber": "386", "text": "حضرت ‌ابو ‌ہریرہ ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌نے ‌فرمایا ‌. ‌ق"}
{"hadithnumber": "387", "text": "ہشیم نے صالح بن صالح ہمدانی سے خبر دی  ،  انہوں نے شعبی سےروایت کی  ،  انہوں نے کہا :  میں نے اہل خر"}
{"hadithnumber": "389", "text": "لیث نے ابن شہاب سے حدیث سنائی  انہوں نے ابن مسیب  سے انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  س"}
{"hadithnumber": "390", "text": "سفیان بن عیینہ  ،  یونس اور صالح نے  (  ابن شہاب )  زہری سے  ( ان کی  )  اسی سند سے روایت نقل کی  ۔"}
{"hadithnumber": "391", "text": "عطاء بن میناء نے حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے بیان کیا کہ رسول اللہ ﷺ نے فرمایا  :  ’’ الل"}
{"hadithnumber": "392", "text": "یونس نے ابن شہاب سے روایت کی  ،  انہوں نے کہا  :  ابوقتادہ انصاری  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے آزاد کردہ"}
{"hadithnumber": "393", "text": "ابن شہاب کے بھتیجے نے اپنے چچا  (  ابن شہاب  )  کے سابقہ سند کے ساتھ حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ"}
{"hadithnumber": "394", "text": "ابن ابی ذئب نے ابن شہاب سے سابقہ سند کے ساتھ حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسو"}
{"hadithnumber": "395", "text": "حضرت  جابر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  بیان کرتے ہیں  ،  میں نے رسول اللہ ﷺ کو فرماتے ہوئے سنا"}
{"hadithnumber": "396", "text": "علاء بن عبد الرحمن نے اپنے والد سے اور انہوں نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رس"}
{"hadithnumber": "397", "text": "ابو زرعہ  ،  عبدالرحمن اعرج اور ہمام بن منبہ سے بھی حضرت ابوہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اسی جیسی"}
{"hadithnumber": "398", "text": "ابو حازم نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے فرمایا : ’’ تین چیزیں ہ"}
{"hadithnumber": "399", "text": "اسماعیل  )  ابن علیہ نے کہا :  ہمیں یونس نے ابراہیم بن یزید تیمی کے حوالے سے حدیث سنائی  ،  میرے علم"}
{"hadithnumber": "400", "text": "خالد بن عبد اللہ نے یونس سے سابقہ سند کے ساتھ حضرت ابو ذر ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ  ایک د"}
{"hadithnumber": "401", "text": "ابو معاویہ نے کہا :  ہمیں اعمش نے ابراہیم تیمی سے سابقہ سند کے ساتھ حضرت ابو ذر  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "402", "text": "وکیع نے اعمش سے سابقہ سند کے ساتھ حضرت ابو ذر ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ میں نے رسول اللہ ﷺ"}
{"hadithnumber": "403", "text": "یونس نے ابن شہاب  ( زہری )  سے خبر دی  ،  انہوں نے کہا :  مجھے عروہ بن زبیر نے حدیث سنائی کہ حضرت عا"}
{"hadithnumber": "404", "text": "ہمیں معمر نے خبر دی کہ انہوں نے کہا :  مجھے عروہ نے حضرت عائشہ ؓ سے خبر دی کہ انہوں نے کہا :  رسو ل"}
{"hadithnumber": "405", "text": "عقیل بن خالد نے بیان کیا کہ ابن شہاب نے کہا :  میں نے عروہ بن زبیر کو یہ کہتے ہوئے سنا :  نبی ﷺ کی ز"}
{"hadithnumber": "406", "text": "یونس نے  ( اپنی سند کے ساتھ )  ابن شہاب سے بیان کیا  ،  انہوں نے کہا  :  مجھے ابو سلمہ بن عبد الرحمن"}
{"hadithnumber": "407", "text": "عقیل بن خالد نے ابن شہاب سے بیان کیا ،  انہوں نے کہا  :  میں نے ابو سلمہ بن عبد الرحمن کو یہ کہتے ہو"}
{"hadithnumber": "408", "text": "معمر نے زہری سے اسی سند کےساتھ یونس کی طرح حدیث بیان کی  ( اس میں یہ  )  کہا  : تو اللہ تبارک وتعالی"}
{"hadithnumber": "409", "text": "اوزاعی نے کہا :  میں نے یحییٰ سے سنا ،  کہتے تھے :  میں نے ابوسلمہ سے سوال کیا  :  ’’ قرآن کا کون سا"}
{"hadithnumber": "410", "text": "علی بن مبارک نے بھی یحییٰ بن ابی کثیر سے اسی سند کے ساتھ روایت کی اور کہا : ’’ تو وہ آسمان و زمین کے"}
{"hadithnumber": "411", "text": "سیدنا انس بن مالک رضی اللہ عنہ سے روایت ہے، رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میرے سامنے براق"}
{"hadithnumber": "412", "text": "سلیمان بن مغیرہ نے کہا :  ہمیں ثابت نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث بیان کی  ،  انہ"}
{"hadithnumber": "413", "text": "( سلیمان بن مغیرہ کے بجائے  )  حماد بن سلمہ نے ثابت کے واسطے سے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "414", "text": "شریک بن عبد اللہ بن ابی نمر نے حدیث سنائی  ( کہا )  :  میں نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "415", "text": "ابن شہاب نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا :  حضرت ابوذر ‌رضی ‌ا"}
{"hadithnumber": "416", "text": "سعید نے قتادہ سے اور انہوں نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  (  انہوں نے غالباً"}
{"hadithnumber": "417", "text": "ہشام نے قتادہ سے حدیث سنائی ،   (  انہوں نے کہا :  ) ہمیں انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے حضرت م"}
{"hadithnumber": "418", "text": "شعبہ نے ا بو قتادہ سے حدیث سنائی  ،  انہوں نے کہا :  میں نے ابو عالیہ سے سنا  ، وہ کہہ رہے تھے  :  م"}
{"hadithnumber": "419", "text": "شیبان بن عبد الرحمن نے قتادہ کے حوالے سے سابقہ سند کے ساتھ حدیث سنائی کہ ہمیں تمہارے نبی ﷺ کے چچازاد"}
{"hadithnumber": "420", "text": "احمد بن حنبل اور سریج بن یونس نے کہا :  ہمیں ہشیم نے حدیث سنائی  ،  انہوں نے کہا  :  ہمیں داؤد بن اب"}
{"hadithnumber": "421", "text": "ابن ابی عدی نے داؤد سے حدیث سنائی  ،  انہوں نےابو عالیہ سے اور انہوں نے حضرت ابن عباس ‌رضی ‌اللہ ‌عن"}
{"hadithnumber": "422", "text": "مجاہد سے روایت ہے کہ انہوں نے کہا :  ہم ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے پاس تھے تو لوگوں نے دجال کا"}
{"hadithnumber": "423", "text": "قتیبہ بن سعید اور محمد بن رمح نے لیث سے انہوں نے ابو زبیر سے اور انہوں نے حضرت جابر  ‌رضی ‌اللہ ‌عنہ"}
{"hadithnumber": "424", "text": "حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے  ، کا  :  نبی کریم ﷺ نے فرمایا : ’’جب مجھے اسراء کر"}
{"hadithnumber": "425", "text": "مالک (  بن انس )  نے نافع سے اور ا نہوں نے حضرت عبد اللہ بن عمر ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے روایت کی کہ ر"}
{"hadithnumber": "426", "text": "موسیٰ بن عقبہ نے نافع سے روایت کی  ،  انہوں نے کہا :  حضرت عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے"}
{"hadithnumber": "427", "text": "حنظلہ نے سالم کے واسطے سے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث سنائی کہ رسول اللہ ﷺ نے فرمایا"}
{"hadithnumber": "428", "text": "حضرت جابر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسو ل اللہ ﷺ نے فرمایا : ’’ جب قریش نے مج"}
{"hadithnumber": "429", "text": "ابن شہاب نےسالم بن عبد اللہ بن عمر سے  ،  انہوں نے اپنے والد حضرت عبد اللہ بن عمر  ‌رضی ‌اللہ ‌عنہ ‌"}
{"hadithnumber": "430", "text": "حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ سے روایت ہے کہ رسو ل اللہ ﷺ نے فرمایا : ’’ میں نے اپنے آپ کو حجر ("}
{"hadithnumber": "431", "text": "حضرت عبد اللہ  (  بن مسعود )   ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت ہے  ،  انہوں نے کہا :  جب رسول اللہ ﷺ کو"}
{"hadithnumber": "432", "text": "عباد بن عوام نے کہا :  ہمیں شیبانی نے خبر دی ،  انہوں نے کہا :  میں نے زربن حبیش سے اللہ تعالیٰ کے ا"}
{"hadithnumber": "433", "text": "حفص بن غیاث نے شیبانی سے حدیث سنائی ،  انہوں نے زر سے  ،  انہوں نے حضرت عبداللہ  (  بن مسعود )   ‌رض"}
{"hadithnumber": "434", "text": "شعبہ نے سلیمان شیبانی سے حدیث بیان کی ،  انہوں نے زربن حبیش سے سنا کہا کہ حضرت عبداللہ  (  بن مسعود"}
{"hadithnumber": "435", "text": "حضرت ابو ھریرہ رضی اللہ عنہ سے روایت ہے کہ  ( اللہ کے فرمان ) آپ ﷺنے اسے ایک اور بار اترتےہوئے دیکھا"}
{"hadithnumber": "436", "text": "عطاء نے حضرت ابن عباس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا :  آپ ﷺ نے اسے  ( رب تعالیٰ"}
{"hadithnumber": "437", "text": "وکیع نے کہا :  ہمیں اعمش نے زیاد بن حصین ابو جہمہ سے حدیث سنائی  ،  انہوں نے ابو عالیہ سے اور انہوں"}
{"hadithnumber": "438", "text": "( وکیع کے بجائے )  حفص ابن غیاث نے اعمش سے حدیث سنائی ،  انہوں نے کہا :  ہمیں ابو جہمہ  ( زیاد بن حص"}
{"hadithnumber": "439", "text": "اسماعیل بن ابراہیم نے داود سے  ،  انہوں نے شعبی سے اور انہوں نے مسروق سے روایت کی  ،  کہا  :  میں حض"}
{"hadithnumber": "440", "text": "( اسماعیل کے بجائے  )  عبدالوہاب نے کہا :  ہمیں داود نے اسی طرح حدیث سنائی  (  اسماعیل بن ابراہیم  )"}
{"hadithnumber": "441", "text": "اسماعیل  ( بن ابی خالد )  نے  (  عامر بن شراحیل  )  شعبی سے حدیث بیان کی  ،  انہوں نے مسروق سے روایت"}
{"hadithnumber": "442", "text": "( سعید بن عمرو )  ابن اشوع نے عامر ( شعبی )  سے ،  انہوں نے مسروق سے روایت کی  ،  انہوں نے کہا :  می"}
{"hadithnumber": "443", "text": "یزید بن ابراہیم نے قتادہ سے  ،  انہوں نے عبد اللہ بن شقیق سے اور انہوں نے حضرت ابو ذر ‌رضی ‌اللہ ‌عن"}
{"hadithnumber": "444", "text": "ہشام او رہمام دونوں نے دو مختلف سندوں کے ساتھ قتادہ سے حدیث بیان کی  ،  انہوں نے عبد اللہ بن شقیق سے"}
{"hadithnumber": "445", "text": "ابو بکر بن ابی شیبہ اور ابو کریب نے کہا :  ہمیں ابو معاویہ نےحدیث بیان کی  ،  انہوں نے کہا :  ہمیں ا"}
{"hadithnumber": "446", "text": "اعمش کے ایک اور شاگرد جریر نے اسی  (  مذکورہ )  سند سے روایت کی ،  کہا :  رسول اللہ ﷺ ہمارے درمیان ک"}
{"hadithnumber": "447", "text": "شعبہ نے عمرو بن مرہ کے حوالے سے ابو عبیدہ سےاور انہوں نے حضرت ابو موسیٰ اشعری  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "448", "text": "عبد اللہ بن قیس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ نبی ﷺ نے فرمایا : ’’دو جنتیں چاندی کی ہیں  ،  ا"}
{"hadithnumber": "449", "text": "عبد الرحمن بن مہدی نے کہا :  ہمیں حماد بن سلمہ نے ثابت بنانی سے حدیث بیان کی  ،  انہوں نے عبد الرحمن"}
{"hadithnumber": "450", "text": "( عبد الرحمن بن مہدی کےبجائے )  یزید بن ہارون نے حماد بن سلمہ سے اسی سند کے ساتھ حدیث بیان کی  ۔  اس"}
{"hadithnumber": "451", "text": "یعقوب بن ابراہیم نے حدیث بیان کی  ،  کہا :  میرے والد نے ہمیں ابن شہاب زہری سے حدیث سنائی  ،  انہوں"}
{"hadithnumber": "452", "text": "شعیب نے ابن شہاب زہری سے خبر دی  ،  انہوں نے کہا :  عطاء اور سعید بن مسیب نے مجھے خبر دی کہ حضرت ابو"}
{"hadithnumber": "453", "text": "ہمام بن منبہ سے روایت ہے  ،  انہوں نے کہا :  یہ احادیث ہیں جو حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  ن"}
{"hadithnumber": "454", "text": "حفص بن میسرہ نے زید بن اسلم سے  ،  انہوں نے عطاء بن یسار سے اور انہوں نے حضرت ابو سعید خدری ‌رضی ‌ال"}
{"hadithnumber": "455", "text": "امام مسلم نے کہا :  میں نے شفاعت کے بارے میں یہ حدیث عیسیٰ بن حماد زغبہ مصری کے سامنے پڑھی اور ان سے"}
{"hadithnumber": "456", "text": "زید بن اسلم کے ایک اور شاگرد ہشام بن سعد نے بھی ان دونوں  ( حفص اور سعید )  کی مذکورہ سندوں کے ساتھ"}
{"hadithnumber": "457", "text": "مالک بن انس نے عمرو بن یحییٰ بن عمارہ سے خبر دی ،  انہوں نے کہا :  میرے والد نے مجھے حضرت ابوسعید خد"}
{"hadithnumber": "458", "text": "وہیب اور خالد دونوں نے عمرو بن یحییٰ سے اسی سند کے ساتھ یہی روایت بیان کی  ۔  اس میں ہے  : ’’انہیں ا"}
{"hadithnumber": "459", "text": "بشر بن مفضل نے ابو مسلمہ سے حدیث سنائی ،  انہوں نے ابو نضرہ سے  ،  انہوں نے حضرت ابو سعید ‌رضی ‌اللہ"}
{"hadithnumber": "460", "text": "( بشر کےبجائے )  شعبہ نے ابومسلمہ سے حدیث سنائی کہا ،  میں نے ابونضرہ سے سنا ،   ( انہوں نے )  حضرت"}
{"hadithnumber": "461", "text": "منصور نے ابراہیم سے  ،  انہوں نے عبیدہ سے ،  انہوں نے حضرت عبد اللہ بن مسعود  ‌رضی ‌اللہ ‌عنہ ‌ ‌  س"}
{"hadithnumber": "462", "text": "( منصور کے بجائے )  اعمش نے ابراہیم سے ،  سابقہ سند کے ساتھ  ،  عبد ہ اللہ بن مسعود  ‌رضی ‌اللہ ‌عنہ"}
{"hadithnumber": "463", "text": "انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نےحضرت ابن مسعود ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے فرمایا"}
{"hadithnumber": "464", "text": "حضرت ابو سعید خدری ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا : ’’اہل جنت میں سب سے ک"}
{"hadithnumber": "465", "text": "ہمیں سعید بن عمر و اشعثی نے حدیث بیان سنائی ،  کہا :  ہمیں سفیان بن عیینہ نے حدیث سنائی  ،  انہوں نے"}
{"hadithnumber": "466", "text": "ہا :  میں نے شعبی سے سنا ،  انہوں نے کہا :  میں نے مغیرہ بن شعبہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا ،  وہ"}
{"hadithnumber": "467", "text": "محمد بن عبد اللہ بن نمیر نے ہمیں اپنے والد سے حدیث بیان کی  ،  کہا :  ہمیں اعمش نے معرور بن سوید سے"}
{"hadithnumber": "468", "text": "اعمش کے دوشاگردوں ابو معاویہ اور وکیع نے اپنی اپنی سند کے ساتھ مذکورہ بالا روایت بیان کی  ۔"}
{"hadithnumber": "469", "text": "ابو زبیر نے بتایا کہ انہوں نے حضرت جابر بن عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا ،  ان سے  ( جنت اور"}
{"hadithnumber": "470", "text": "سفیان بن عیینہ نے عمر  (  بن دینار )  سے روایت کی کہ انہوں نے حضرت جابر ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا"}
{"hadithnumber": "471", "text": "حماد بن زید نے کہا :  میں نے عمر وبن دینارسے پوچھا :  کیا آپ نے جابربن عبداللہ ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "472", "text": "قیس بن سلیم عنبری سے کہا :  یزید الفقیر نے مجھے حدیث بیان کی کہ حضرت جابربن عبد اللہ  ‌رضی ‌اللہ ‌عن"}
{"hadithnumber": "473", "text": "م  ، یعنی محمد بن ابی ایوب نے کہا :  مجھے یزید الفقیر نےحدیث سنائی ،  انہوں نے کہا :  کہ خارجیوں کے"}
{"hadithnumber": "474", "text": "ابو عمران  اور ثابت نے حضرت انس بن مالک  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہ ﷺ نے فرمایا :"}
{"hadithnumber": "475", "text": "ابو کامل فضیل بن حسین جحدری اور محمد بن عبید غبری نے کہا :   ( الفاظ ابو کامل کے ہیں  )  ہمیں ابو عو"}
{"hadithnumber": "476", "text": "دوسری سند سے جس میں  (  ابو عوانہ کے بجائے )  سعید نے قتادہ سے اور انہوں نے حضرت انس  ‌رضی ‌اللہ ‌عن"}
{"hadithnumber": "477", "text": "معاذ بن ہشام نے کہا :  میرے والد نے مجھے قتادہ کے حوالے سے حدیث سنائی اور انہوں نے حضرت انس بن مالک"}
{"hadithnumber": "478", "text": "محمد بن منہال الضریر  ( نابینا )  نے کہا :  ہمیں یزید بن زریع نے حدیث سنائی  ،  انہوں نے کہا :  ہمیں"}
{"hadithnumber": "479", "text": "معبد بن ہلال عنزی نے کہا :  ہم لوگ انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  کے پاس گئے اور ثابت  ( البنانی )"}
{"hadithnumber": "480", "text": "ابو حیان نے ابو زرعہ سے اور انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نےکہ"}
{"hadithnumber": "481", "text": "ایک دوسرے سند سے  )  عمارہ بن قعقاع نے ابو زرعہ سے  ،  انہوں نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "482", "text": "محمد بن فضیل  نے کہا :  ہمیں ابو مالک اشجعی نے حدیث سنائی  ،  انہوں نے ابو حازم سے اور انہوں نے حضرت"}
{"hadithnumber": "483", "text": "جریر نےمختار بن فلفل سے  ، انہوں نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نےکہ"}
{"hadithnumber": "484", "text": "وَحَدَّثَنَا أَبُو كُرَيْبٍ مُحَمَّدُ بْنُ الْعَلَاءِ ،  حَدَّثَنَا مُعَاوِيَةُ بْنُ هِشَامٍ ،  عَنْ"}
{"hadithnumber": "485", "text": "زائدہ نےمختار بن فلفل سے روایت کی  ،  انہوں نے کہا :  حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا ک"}
{"hadithnumber": "486", "text": "ثابت نے حضرت  انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث بیان کی  ،  انہوں نے کہا کہ رسول اللہ ﷺ نے فر"}
{"hadithnumber": "487", "text": "مالک بن انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے ابن شہاب سے خبر دی  ،  انہوں نے ابو سلمہ بن  عبد الرحمن سے اور"}
{"hadithnumber": "488", "text": "( مالک بن ا نس کے بجائے  )  ابن شہاب کے بھتیجے نے ابن شہاب سے حدیث سنائی ،  انہوں نے کہا  :  مجھے اب"}
{"hadithnumber": "489", "text": "ابن شہاب کے بھتیجے نے ابن شہاب سے اور انہوں نے  (  ابو سلمہ کے بجائے )  عمرو بن ابی سفیان بن اسید بن"}
{"hadithnumber": "490", "text": "یونس نے ابن شہاب سے خبر دی کہ عمرو بن ابی سفیان ثقفی نےخبر دی کہ حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "491", "text": "ابو صالح نےحضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی  ،  انہوں نے کہا کہ رسول اللہ ﷺ نے فرمایا"}
{"hadithnumber": "492", "text": "ابو زرعہ ے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌ سے روایت کی  ،  انہوں نے کہا کہ رسول اللہ ﷺ نے فرمایا"}
{"hadithnumber": "493", "text": "محمد بن زیاد نے کہا :  میں نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا  ،  وہ کہہ رہے تھے کہ رسو ل"}
{"hadithnumber": "494", "text": "ہشام نے قتادہ سے روایت کی  ،  انہوں نے کہا :  ہمیں انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  نےحدیث سنائی کہ"}
{"hadithnumber": "495", "text": "مذکورہ بالا روایت  (  ہشام کے بجائے )  شعبہ نے قتادہ سےباقی ماندہ اسی سند کے ساتھ بیان کی  ۔"}
{"hadithnumber": "496", "text": "وکیع اور ابو اسامہ نےمسعر سے حدیث سنائی ،  انہوں نےقتادہ سے اسی سند کے ساتھ یہی روایت بیان کی  ،  ات"}
{"hadithnumber": "497", "text": "معتمر کے والد سلیمان بن طرخان نےحضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ اللہ کے نبی ﷺ نے فرمای"}
{"hadithnumber": "498", "text": "حضرت جابر نے عبد اللہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نبی کریم ﷺ سے روایت بیان کرتے ہیں کہ ’’ہر نبی کے لیے ایک"}
{"hadithnumber": "499", "text": "حضرت عبد اللہ بن عمرو بن عاص ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت کہ نبیﷺ نےابراہیم علیہ السلام  کے بارے میں"}
{"hadithnumber": "500", "text": "حضرت انس  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ ایک آدمی نے پوچھا : اے اللہ کے رسول ! میرا باپ کہاں ہے"}
{"hadithnumber": "501", "text": "جریر نےعبد الملک بن عمیر سے حدیث سنائی ،  انہوں نے موسیٰ بن طلحہ اور انہوں نے حضرت ابوہریرہ ‌رضی ‌ال"}
{"hadithnumber": "502", "text": "عبدالملک سے  ( جریر کے علاوہ )  ابوعوانہ نے بھی یہ حدیث اسی سند کے ساتھ بیان کی  ۔  لیکن جریر کی روا"}
{"hadithnumber": "503", "text": "حضرت عائشہ ؓ سے روایت ہے  ،  انہوں نے کہا کہ جب آیت  : ’’ اور اپنے قریبی رشتہ داروں کو ڈرائیے ‘  ‘"}
{"hadithnumber": "504", "text": "ابن مسیب اور ابوسلمہ بن عبد الرحمن نے بتایا کہ حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہاکہ جب رسول ا"}
{"hadithnumber": "505", "text": "ایک اور سند سے اعرج نےحضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے اور انہوں نے نبی ﷺ سے اسی طرح روایت کی"}
{"hadithnumber": "506", "text": "یزید بن زریع نے  ( سلیمان )  تیمی سے  ،  انہوں نے ابو عثمان کے واسطے سے حضرت قبیصہ بن مخارق اور حضرت"}
{"hadithnumber": "507", "text": "( یزید بن زریع کے بجائے )  معتمر نے اپنے والد  ( سلیمان  )  کے حوالے سے باقی ماندہ سابقہ سند کے ساتھ"}
{"hadithnumber": "508", "text": "ابو اسامہ نے اعمش سے حدیث سنائی ،  انہوں نے عمرو بن مرہ سے  ،  انہوں نے سعید بن جبیر سے اور انہوں نے"}
{"hadithnumber": "509", "text": "اعمش شے  (  ابو اسامہ کے بجائے )  ابو معاویہ نے اسی  ( سابقہ )  سند کے ساتھ بیان کیا  کہ رسول اللہ ﷺ"}
{"hadithnumber": "510", "text": "ابو عوانہ نے عبدالملک بن عمیر سے حدیث بیان کی  ،  انہوں نے عبداللہ بن حارث بن نوفل سے اور انہوں نے ح"}
{"hadithnumber": "511", "text": "سفیان  (  بن عیینہ  )  نے عبد الملک بن عمیر سے حدیث سنائی ،  انہوں نے عبد اللہ بن حارث سے روایت کی"}
{"hadithnumber": "512", "text": "سفیان  ( ثوری )  نے اسی سند کے ساتھ نبیﷺ سے اسی طرح حدیث بیان کی ابو عوانہ نے بیان کی  ۔"}
{"hadithnumber": "513", "text": "حضرت ابو سعید خدری ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ کےسامنے آپ کے چچا ابو طالب کا تذک"}
{"hadithnumber": "514", "text": "حضرت ابو سعیدخدری ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا : ’’ اہل جہنم میں سے سب"}
{"hadithnumber": "515", "text": "حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا : ’’ دوزخیوں میں سے سب سے ہل"}
{"hadithnumber": "516", "text": "شعبہ نے ابو اسحاق سے سن کر حدیث بیان کی ،  انہوں نےکہا :  میں نے حضرت نعمان بن بشیر  ‌رضی ‌اللہ ‌عنہ"}
{"hadithnumber": "517", "text": "شعبہ کے بجائے )  اعمش نے ابو اسحاق سے  ،  انہو ں نے حضرت نعمان بن بشیر ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت"}
{"hadithnumber": "518", "text": "حضرت عائشہ ؓ سے روایت ہے کہ میں نے پوچھا :  اے اللہ کےرسول! ابن جدعان جاہلیت کےدور میں صلہ رحمی کرتا"}
{"hadithnumber": "519", "text": "حضرت عمرو بن عاص ‌رضی ‌اللہ ‌عنہ ‌ ‌  سےروایت ہے  ،  انہوں نے کہا کہ میں نے رسول اللہ ﷺ کو بلند آواز"}
{"hadithnumber": "520", "text": "ربیع بن مسلم نے محمد بن زیاد کے واسطے سے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث بیان کی کہ نبی"}
{"hadithnumber": "521", "text": "ششعبہ نے کہا :  میں نے محمد بن زیاد سے حدیث سنی ،  انہوں نے کہا :  میں نے حضرت ابو ہریرہ  سے سنی ،"}
{"hadithnumber": "522", "text": "سعید بن مسیب نے حدیث سنائی کہ انہیں ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  نےحدیث بیان کی  ،  انہوں نے کہا :"}
{"hadithnumber": "523", "text": "( سعید بن مسیب کے بجائے )  ابو یونس نے حضرت ابو ہریرہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث بیان کی کہ رسول"}
{"hadithnumber": "524", "text": "محمد بن سیرین نے کہا کہ حضرت عمران  ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے مجھے یہ حدیث سنائی  ،  انہوں نے کہا کہ ن"}
{"hadithnumber": "525", "text": "حکم بن اعرج نے حضرت عمران بن حصین ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے حدیث سنائی کہ رسو ل اللہ ﷺ نے فرمایا : ’’"}
{"hadithnumber": "526", "text": "حضرت سہل بن سعد ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ رسو ل اللہ ﷺ نے فرمایا : ’’میری امت میں سے ستر ہ"}
{"hadithnumber": "527", "text": "ہشیم نے کہا :  ہمیں حصین بن عبد الرحمن نے خبر دی ،  کہا کہ میں سعید بن جبیر کے پاس موجود تھا ،  انہو"}
{"hadithnumber": "528", "text": "حصین بن عبد الرحمن سے  (  ہشیم کے بجائے )  محمد بن فضیل نے سعید بن جبیر کے حوالے سے حدیث سنائی ،  ان"}
{"hadithnumber": "529", "text": "ابو احوص نے ابو اسحاق سے حدیث سنائی  ،  انہوں نےعمرو بن میمون سے اور انہوں نے حضرت عبد اللہ ‌رضی ‌ال"}
{"hadithnumber": "530", "text": "ابو اسحاق سے  (  ابو احوص کے بجائے )  شعبہ نے حدیث سنائی ،  انہو ں نے عمرو بن میمون سے ا ور انہوں نے"}
{"hadithnumber": "531", "text": "مالک بن مغول نے ابو اسحاق کےواسطے سے عمرو بن میمون سے حدیث سنائی انہوں نے حضرت عبد اللہ  ‌رضی ‌اللہ"}
{"hadithnumber": "532", "text": "جریر نے اعمش سے حدیث سنائی ،  انہوں نے ابو صالح سے اور انہوں نے حضرت ابوسعید ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے"}
{"hadithnumber": "533", "text": "( جریر کے بجائے  )  اعمش کے دو شاگردوں وکیع اور ابو معاویہ نےاسی سند کے ساتھ روایت کی ،  لیکن دونوں"}
