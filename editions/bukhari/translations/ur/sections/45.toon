{"hadithnumber": "2426", "text": "ہم سے آدم نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا (دوسری سند) اور مجھ سے محمد بن بشار نے بیان کیا، ا"}
{"hadithnumber": "2427", "text": "ہم سے عمرو بن عباس نے بیان کیا، کہا کہ ہم سے عبدالرحمٰن بن مہدی نے بیان کیا، کہا ہم سے سفیان نے، ان"}
{"hadithnumber": "2428", "text": "ہم سے اسماعیل بن عبداللہ نے بیان کیا، کہا کہ مجھ سے سلیمان تیمی نے بیان کیا، ان سے یحییٰ بن سعید انص"}
{"hadithnumber": "2429", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا کہ ہم کو امام مالک نے خبر دی، انہیں ربیعہ بن ابی عبدالرحمٰن ن"}
{"hadithnumber": "2430", "text": "اور لیث بن سعد نے بیان کیا کہ مجھ سے جعفر بن ربیعہ نے بیان کیا، ان سے عبدالرحمٰن بن ہرمز نے اور ان س"}
{"hadithnumber": "2431", "text": "ہم سے محمد بن یوسف نے بیان کیا، کہا کہ ہم سے سفیان ثوری نے بیان کیا، ان سے منصور بن معتمر نے، ان سے"}
{"hadithnumber": "2432", "text": "اور یحییٰ بن سعید قطان نے بیان کیا، کہ ہم سے سفیان ثوری نے بیان کیا، کہا مجھ سے منصور نے بیان کیا، ا"}
{"hadithnumber": "2433", "text": "اور احمد بن سعد نے کہا، ان سے روح نے بیان کیا، ان سے زکریا نے بیان کیا، ان سے عمرو بن دینار نے بیان"}
{"hadithnumber": "2434", "text": "ہم سے یحییٰ بن موسیٰ نے بیان کیا، ان سے ولید بن مسلم نے بیان کیا، ان سے امام اوزاعی نے بیان کیا، کہا"}
{"hadithnumber": "2435", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا کہ ہم کو امام مالک نے خبر دی نافع سے اور انہیں عبداللہ بن عمر"}
{"hadithnumber": "2436", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا کہ ہم سے اسماعیل بن جعفر نے بیان کیا، ان سے ربیعہ بن عبدالرحمٰن"}
{"hadithnumber": "2437", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، ان سے سلمہ بن کہیل نے بیان کیا کہ می"}
{"hadithnumber": "2437", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، ان سے سلمہ بن کہیل نے بیان کیا کہ می"}
{"hadithnumber": "2438", "text": "ہم سے محمد بن یوسف نے بیان کیا، کہا کہ ہم سے سفیان ثوری نے بیان کیا ربیعہ سے، ان سے منبعث کے غلام یز"}
{"hadithnumber": "2439", "text": "ہم سے اسحاق بن ابراہیم نے بیان کیا، کہا کہ ہم کو نضر نے خبر دی، کہا کہ ہم کو اسرائیل نے خبر دی ابواس"}
