{"hadithnumber": "1504", "text": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  سورج گرہن لگا تو رسول اللہ صلی اللہ علیہ وسلم گھبرا کر کھڑے"}
{"hadithnumber": "1505", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ایک آدمی رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا، اور اس نے عر"}
{"hadithnumber": "1506", "text": "عبداللہ بن زید رضی اللہ عنہ (جنہیں خواب میں اذان دکھائی گئی تھی) کہتے ہیں کہ  رسول اللہ صلی اللہ علی"}
{"hadithnumber": "1507", "text": "اسحاق بن عبداللہ بن کنانہ کہتے ہیں کہ  فلاں نے مجھے ابن عباس رضی اللہ عنہم کے پاس بھیجا کہ میں ان سے"}
{"hadithnumber": "1508", "text": "عبداللہ بن زید رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے استسقاء کی نماز پڑھی، او"}
{"hadithnumber": "1509", "text": "اسحاق بن عبداللہ بن کنانہ کہتے ہیں کہ  میں نے ابن عباس رضی اللہ عنہم سے رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "1510", "text": "عباد بن تمیم کے چچا عبداللہ بن زید رضی اللہ عنہ کہتے ہیں کہ  وہ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ"}
{"hadithnumber": "1511", "text": "عباد بن تمیم کے چچا عبداللہ بن زید رضی اللہ عنہ روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم استسق"}
{"hadithnumber": "1512", "text": "عبداللہ بن زید رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم  ( جائے نماز کی طرف )  نکلے، ت"}
{"hadithnumber": "1513", "text": "عباد بن تمیم کے چچا عبداللہ بن زید رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم ک"}
{"hadithnumber": "1514", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سوائے استسقاء کے اپنے دونوں ہاتھ کسی دعا"}
{"hadithnumber": "1515", "text": "آبی اللحم رضی اللہ عنہ سے روایت ہے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو احجار الزیت کے پاس د"}
{"hadithnumber": "1516", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ جمعہ کے روز مسجد میں تھے، اور رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "1517", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے دعا کی: «اللہم اسقنا»  اے ال"}
{"hadithnumber": "1518", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم جمعہ کا خطبہ دے رہے تھے کہ کچھ لوگ آپ کی ط"}
{"hadithnumber": "1519", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  ایک آدمی مسجد میں داخل ہوا، اور رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "1520", "text": "عباد بن تمیم کے چچا عبداللہ بن زید رضی اللہ عنہ کہتے ہیں کہ  ایک دن رسول اللہ صلی اللہ علیہ وسلم است"}
{"hadithnumber": "1521", "text": "عبداللہ بن زید رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم اللہ تعالیٰ سے بارش طلب کرنے"}
{"hadithnumber": "1522", "text": "اسحاق بن عبداللہ بن کنانہ کہتے ہیں کہ  امراء میں سے ایک امیر نے مجھے ابن عباس رضی اللہ عنہم کے پاس ب"}
{"hadithnumber": "1523", "text": "عباد بن تمیم کے چچا عبداللہ بن زید رضی اللہ عنہ روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم استسق"}
{"hadithnumber": "1524", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم جب بارش ہوتی تو کہتے: «"}
{"hadithnumber": "1525", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ فرماتا ہے: ج"}
{"hadithnumber": "1526", "text": "زید بن خالد جہنی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے زمانے میں بارش ہوئی تو آپ"}
{"hadithnumber": "1527", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اگر اللہ تعالیٰ اپن"}
{"hadithnumber": "1528", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  ایک سال بارش نہیں ہوئی تو کچھ مسلمان جمعہ کے دن نبی اکرم صلی اللہ علیہ"}
