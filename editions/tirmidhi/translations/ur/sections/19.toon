{"hadithnumber": "1493", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”قربانی کے دن ا"}
{"hadithnumber": "1494", "text": "انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے سینگ والے دو چتکبرے مینڈھوں کی"}
{"hadithnumber": "1495", "text": "علی رضی الله عنہ سے روایت ہے کہ  وہ دو مینڈھوں کی قربانی کرتے تھے، ایک نبی اکرم صلی اللہ علیہ وسلم ک"}
{"hadithnumber": "1496", "text": "ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے سینگ والے ایک نر مینڈھے کی ق"}
{"hadithnumber": "1497", "text": "براء بن عازب رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”ایسے لنگڑے جانور"}
{"hadithnumber": "1498", "text": "علی بن ابی طالب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں حکم دیا کہ  ( قربانی"}
{"hadithnumber": "1499", "text": "ابوکباش کہتے ہیں کہ  میں مدینہ میں تجارت کے لیے جذع یعنی دنبہ کے چھوٹے بچے لایا اور بازار مندا ہو گی"}
{"hadithnumber": "1500", "text": "عقبہ بن عامر رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے انہیں بکریاں دیں تاکہ وہ ق"}
{"hadithnumber": "1501", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ایک سفر میں"}
{"hadithnumber": "1502", "text": "جابر رضی الله عنہ کہتے ہیں کہ  ہم لوگوں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ حدیبیہ کے موقع پر او"}
{"hadithnumber": "1503", "text": "حجیہ بن عدی سے روایت ہے کہ  علی رضی الله عنہ نے کہا: گائے کی قربانی سات آدمیوں کی طرف سے کی جائے گی"}
{"hadithnumber": "1504", "text": "علی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان جانوروں کی قربانی کرنے سے منع فرمای"}
{"hadithnumber": "1505", "text": "عطاء بن یسار کہتے ہیں کہ  میں نے ابوایوب انصاری رضی الله عنہ سے پوچھا: رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "1506", "text": "جبلہ بن سحیم سے روایت ہے کہ  ایک آدمی نے ابن عمر رضی الله عنہما سے قربانی کے بارے میں پوچھا: کیا یہ"}
{"hadithnumber": "1507", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مدینہ میں دس سال مقیم رہے او"}
{"hadithnumber": "1508", "text": "براء بن عازب رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے قربانی کے دن ہمیں خطبہ دیا،"}
{"hadithnumber": "1509", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے کوئی"}
{"hadithnumber": "1510", "text": "بریدہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”میں نے تم لوگوں کو تین دن س"}
{"hadithnumber": "1511", "text": "عابس بن ربیعہ کہتے ہیں کہ  میں نے ام المؤمنین سے کہا: کیا رسول اللہ صلی اللہ علیہ وسلم قربانی کا گوش"}
{"hadithnumber": "1512", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ” ( اسلام میں )  نہ «فرع»"}
{"hadithnumber": "1513", "text": "یوسف بن ماہک سے روایت ہے کہ  لوگ حفصہ بنت عبدالرحمٰن کے پاس گئے اور ان سے عقیقہ کے بارے میں پوچھا تو"}
{"hadithnumber": "1514", "text": "ابورافع رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو دیکھا کہ حسن بن علی جب فاطم"}
{"hadithnumber": "1515", "text": "سلمان بن عامر ضبی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”لڑکے کی پیدائش"}
{"hadithnumber": "1516", "text": "ام کرز رضی الله عنہا کہتی ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے عقیقہ کے بارے میں پوچھا ت"}
{"hadithnumber": "1517", "text": "ابوامامہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”قربانی کے جانوروں میں سب"}
{"hadithnumber": "1518", "text": "مخنف بن سلیم رضی الله عنہ کہتے ہیں کہ  ہم لوگ نبی اکرم صلی اللہ علیہ وسلم کے ساتھ میدان عرفات میں ٹھ"}
{"hadithnumber": "1519", "text": "علی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حسن کی طرف سے ایک بکری عقیقہ کیا، اور"}
{"hadithnumber": "1520", "text": "ابوبکرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے خطبہ دیا، پھر  ( منبر سے )  اترے پھ"}
{"hadithnumber": "1521", "text": "جابر بن عبداللہ رضی الله عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے ساتھ عید الاضحی کے دن ع"}
{"hadithnumber": "1522", "text": "سمرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ہر بچہ عقیقہ کے بدلے گروی رک"}
{"hadithnumber": "1523", "text": "ام المؤمنین ام سلمہ رضی الله عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو ماہ ذی"}
