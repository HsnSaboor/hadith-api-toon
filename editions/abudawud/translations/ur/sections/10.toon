{"hadithnumber": "1701", "text": "سوید بن غفلہ رضی اللہ عنہ کہتے ہیں  میں نے زید بن صوحان اور سلیمان بن ربیعہ کے ساتھ جہاد کیا، مجھے ا"}
{"hadithnumber": "1702", "text": "اس سند سے بھی شعبہ سے اسی مفہوم کی حدیث مروی ہے  وہ کہتے ہیں: «عرفها حولا» تین بار کہا، البتہ مجھے ی"}
{"hadithnumber": "1703", "text": "حماد کہتے ہیں سلمہ بن کہیل نے ہم سے اسی سند سے اور اسی مفہوم کی حدیث بیان کی  کی اس میں ہے: آپ صلی ا"}
{"hadithnumber": "1704", "text": "زید بن خالد جہنی رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم سے لقطہٰ  ( پڑی ہ"}
{"hadithnumber": "1705", "text": "اس سند سے بھی مالک سے اسی طریق سے اسی مفہوم کی روایت مروی ہے  البتہ اس میں اتنا اضافہ ہے کہ:  وہ اپن"}
{"hadithnumber": "1706", "text": "زید بن خالد جہنی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے لقطہٰ کے بارے میں پوچھا گ"}
{"hadithnumber": "1707", "text": "زید بن خالد جہنی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے  ( لقطے کے متعلق )  پوچھا"}
{"hadithnumber": "1708", "text": "یحییٰ بن سعید اور ربیعہ سے قتیبہ کی سند سے اسی مفہوم کی حدیث مروی ہے  اس میں اتنا اضافہ ہے:  اگر اس"}
{"hadithnumber": "1709", "text": "عیاض بن حمار رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جسے لقطہٰ ملے تو وہ"}
{"hadithnumber": "1710", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم سے درخت پر لٹکت"}
{"hadithnumber": "1711", "text": "اس طریق سے بھی عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے یہی حدیث مروی ہے  البتہ اس میں ہے کہ گمشدہ"}
{"hadithnumber": "1712", "text": "اس طریق سے بھی عبداللہ بن عمرو رضی اللہ عنہما سے یہی حدیث مروی ہے  اس میں ہے:  گمشدہ بکری کے متعلق آ"}
{"hadithnumber": "1713", "text": "اس سند سے بھی عبداللہ بن عمرو رضی اللہ عنہما سے یہی حدیث مروی ہے  اس میں ہے:  گمشدہ بکری کے متعلق آپ"}
{"hadithnumber": "1714", "text": "ابوسعید خدری رضی اللہ عنہ سے روایت ہے کہ  علی بن ابی طالب رضی اللہ عنہ کو ایک دینار ملا تو وہ اسے لے"}
{"hadithnumber": "1715", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  انہیں ایک دینار پڑا ملا، جس سے انہوں نے آٹا خریدا، آٹے والے نے انہیں پ"}
{"hadithnumber": "1716", "text": "ابوحازم کہتے ہیں کہ سہل بن سعد رضی اللہ عنہ نے ان سے بتایا کہ  علی بن ابی طالب رضی اللہ عنہ فاطمہ رض"}
{"hadithnumber": "1717", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں لکڑی، کوڑے، رسی اور"}
{"hadithnumber": "1718", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  گمشدہ اونٹ اگر چھپا دیا ج"}
{"hadithnumber": "1719", "text": "عبدالرحمٰن بن عثمان تیمی رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے حاجی کے لقطے س"}
{"hadithnumber": "1720", "text": "منذر بن جریر کہتے ہیں  میں جریر کے ساتھ بوازیج ۱؎ میں تھا کہ چرواہا گائیں لے کر آیا تو ان میں ایک گا"}
