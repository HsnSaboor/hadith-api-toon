hadiths[936]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
8959,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، قَالَ : سَمِعْتُ أَیُّوبَ یُحَدِّثُ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یُبَشِّرُ أَصْحَابَہُ : قَدْ جَائَکُمْ رَمَضَانُ شَہْرٌ مُبَارَکٌ ، اُفْتُرِضَ عَلَیْکُمْ صِیَامُہُ ، تُفْتَحُ فِیہِ أَبْوَابُ الْجَنَّۃِ ، وَتُغْلَقُ فِیہِ أَبْوَابُ الْجَحِیمِ ، وَتُغَلُّ فِیہِ الشَّیَاطِینُ ، فِیہِ لَیْلَۃُ الْقَدْرِ خَیْرٌ مِنْ أَلْفِ شَہْرٍ ، مَنْ حُرِمَ خَیْرَہَا فَقَدْ حُرِمَ۔ (مسلم 758۔ احمد 2/230)",,,8959,,
8960,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ عَرْفَجَۃَ ، قَالَ : کُنْتُ عِنْدَ عُتْبَۃَ بْنِ فَرْقَدٍ وَہُوَ یُحَدِّثُنَا عَنْ فَضْلِ رَمَضَانَ ، فَدَخَلَ عَلَیْنَا رَجُلٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَسَکَتَ عُتْبَۃُ وَکَأَنَّہُ ہَابَہُ ، فَلَمَّا جَلَسَ ، قَالَ لَہُ عُتْبَۃُ : یَا أَبَا فُلاَنٍ ، حَدِّثْنَا بِمَا سَمِعْت مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی رَمَضَانَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : تُفْتَحُ فِیہِ أَبْوَابُ الْجَنَّۃِ ، وَتُغْلَقُ فِیہِ أَبْوَابُ النَّارِ ، وَتُصَفَّدُ فِیہِ الشَّیَاطِینُ ، وَیُنَادِی مُنَادٍ فِی کُلِّ لَیْلَۃٍ : یَا بَاغِیَ الْخَیْرِ ہَلُمَّ ، وَیَا بَاغِیَ الشَّرِّ أَقْصِرْ۔ (احمد 5/411)",,,8960,,
8961,"حَدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُرَغِّبُ فِی قِیَامِ رَمَضَانَ مِنْ غَیْرِ عَزِیمَۃٍ ، وَقَالَ : إذَا دَخَلَ رَمَضَانُ فُتِّحَتْ أَبْوَابُ الْجَنَّۃِ ، وَغُلِّقَتْ أَبْوَابُ الْجَحِیمِ ، وَسُلْسِلَتِ الشَّیَاطِینُ۔ (بخاری 1898۔ مسلم 523)",,,8961,,
8962,"حَدَّثَنَا وَکِیعٌ ، عَنْ نَضْرِ بْنِ عَلِیٍّ ، عَنْ نَضْرِ بْنِ شَیْبَانَ ، قَالَ : سَأَلْتُ أَبَا سَلَمَۃَ بْنَ عَبْدِ الرَّحْمَنِ ، فَذَکَر عَنْ أَبِیہِ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَامَہُ إیمَانًا وَاحْتِسَابًا ، غُفِرَ لَہُ مَا تَقَدَّمَ مِنْ ذَنْبِہِ۔",,,8962,,
8963,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الْفَضْلِ الرَّقَاشِیِّ ، عَنْ عَمِّہِ ، عَنْ أَنَسٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: ہَذَا رَمَضَانُ قَدْ جَائَ تُفْتَحُ فِیہِ أَبْوَابُ الْجِنَانِ، وَتُغْلَقُ فِیہِ أَبْوَابُ النَّارِ ، وَتُغَلُّ فِیہِ الشَّیَاطِینُ ، بُعْدًا لِمَنْ أَدْرَکَ رَمَضَانَ لَمْ یُغْفَرْ لَہُ فِیہِ ، إذَا لَمْ یُغْفَرْ لَہُ فِیہِ فَمَتَی ؟ (طبرانی 7623)",,,8963,,
8964,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُجَالِدٌ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یَخْطُبُ إذَا حَضَرَ رَمَضَانُ یَقُولُ: ہَذَا الشَّہْرُ الْمُبَارَکُ الَّذِی افْتَرَضَ اللَّہُ عَلَیْکُمْ صِیَامَہُ ، وَلَمْ یَفْتَرِضْ عَلَیْکُمْ قِیَامَہُ۔",,,8964,,
8965,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُجَالِدٌ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ؛ أَنَّ عُمَرَ کَانَ یَقُولُ مِثْلَ ذَلِکَ۔",,,8965,,
8966,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیْرِیِّ ، عَنْ مُسْلِمِ بْنِ الْعَلاِء ، عَنْ رَجُلٍ مِنْ قُرَیْشٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ: أَوَّلُ مَا یُصِیبُ صَاحِبُ رَمَضَانَ الَّذِی یُحْسِنُ قِیَامَہُ وَصِیَامَہُ ، أَنْ یَفْرُغَ مِنْہُ وَہُوَ کَیَوْمِ وَلَدَتْہُ أُمُّہُ مِنَ الذُّنُوبِ۔",,,8966,,
8967,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَحْیَی بْنِ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَامَ رَمَضَانَ إیمَانًا وَاحْتِسَابًا ، غُفِرَ لَہُ مَا تَقَدَّمَ مِنْ ذَنْبِہِ۔ (بخاری 2014۔ مسلم 175)",,,8967,,
8968,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، قَالَ : حدَّثَنَا کَثِیرُ بْنُ زَیْدٍ ، عَنْ عَمْرِو بْنِ تَمِیمٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَظَلَّکُمْ شَہْرُکُمْ ہَذَا بِمَحْلُوفِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَا دَخَلَ عَلَی الْمُسْلِمِینَ شَہْرٌ خَیْرٌ لَہُمْ مِنْہُ ، وَلاَ دَخَلَ عَلَی الْمُنَافِقِینَ شَہْرٌ شَرٌّ لَہُمْ مِنْہُ ۔ بِمَحْلُوفِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، إنَّ اللَّہَ یَکْتُبُ أَجْرَہُ وَنَوَافِلَہُ مِنْ قَبْلِ أَنْ یُوجِبَہُ ، وَیَکْتُبُ وِزْرَہُ وَشَقَائَ ہُ قَبْلَ أَنْ یُدْخِلَہُ ، وَذَلِکَ أَنَّ الْمُؤْمِنَ یُعِدُّ لَہُ مِنَ النَّفَقَۃِ فِی الْقُوَّۃِ وَالْعِبَادَۃِ ، وَیُعِدُّ لَہُ الْمُنَافِقُ اتِّبَاعَ غَفَلاَتِ الْمُسْلِمِین ، وَاتِّبَاعَ عَوْرَاتِہِمْ ، فَہُوَ غُنْمٌ لِلْمُؤْمِنِ ، وَنِقْمَۃٌ لِلْفَاجِرِ ، أَوَ قَالَ : یَغْتَنِمُہُ الْفَاجِرُ۔ (احمد 524۔ ابن خزیمۃ 1884)",,,8968,,
8969,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، قَالَ : أَخْبَرَنَا إبْرَاہِیمُ بْنُ إسْمَاعِیلَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ قَالَتْ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَامَ رَمَضَانَ إیمَانًا وَاحْتِسَابًا ، غُفِرَ لَہُ مَا مَضَی مِنْ عَمَلِہِ۔ (نسائی 2502)",,,8969,,
8970,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعُمَیْسِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ، عَنْ أَبِی صَالِحٍ الْحَنَفِیِّ ، عَنْ أَخِیہِ طَلِیقِ بْنِ قَیْسٍ، قَالَ : قَالَ أَبُو ذَرٍّ : إذَا صُمْتَ فَتَحَفَّظْ مَا اسْتَطَعْت ، فَکَانَ طَلِیقٌ إذَا کَانَ یَوْمُ صَوْمِہِ دَخَلَ فَلَمْ یَخْرُجْ إِلاَّ لِصَلاَۃٍ۔",,,8970,,
8971,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا کَانَ یَوْمُ صَوْمِ أَحَدِکُمْ فَلاَ یَرْفُثْ ، وَلاَ یَجْہَلْ ، فَإِنْ جَہَلَ عَلَیْہِ أَحَدٌ فَلْیَقُلْ : إنِّی امْرُؤٌ صَائِمٌ۔",,,8971,,
8972,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا کَانَ یَوْمُ صَوْمِ أَحَدِکُمْ فَلاَ یَرْفُثْ ، وَلاَ یَجْہَلْ ، فَإِنْ جَہِلَ عَلَیْہِ أَحَدٌ فَلْیَقُلْ : إنِّی امْرُؤٌ صَائِمٌ۔ (بخاری 1904۔ مسلم 857)",,,8972,,
8973,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : قَالَ جَابِرٌ : إذَا صُمْتَ فَلْیَصُمْ سَمْعُک وَبَصَرُک وَلِسَانُک عَنِ الْکَذِبِ وَالْمَإْثَمِ ، وَدَعْ أَذَی الْخَادِمِ ، وَلْیَکُنْ عَلَیْک وَقَارٌ وَسَکِینَۃٌ یَوْمَ صِیَامِکَ، وَلاَ تَجْعَلْ یَوْمَ فِطْرِکَ وَیَوْمَ صِیَامِکَ سَوَائً۔",,,8973,,
8974,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ مُسْلِمٍ ، عَنْ أَبِی الْمُتَوَکِّلِ ؛ أَنَّ أَبَا ہُرَیْرَۃَ وَأَصْحَابَہُ کَانُوا إذَا صَامُوا جَلَسُوا فِی الْمَسْجِدِ۔,,,8974,,
8975,"حَدَّثَنَا حَفْصٌ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ عُمَرُ : لَیْسَ الصِّیَامُ مِنَ الطَّعَامِ وَالشَّرَابِ وَحْدَہُ ، وَلَکِنَّہُ مِنَ الْکَذِبِ وَالْبَاطِلِ وَاللَّغْوِ وَالْحَلِفِ۔",,,8975,,
8976,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ، عَنْ جَعْفَرٍ، قَالَ: سَمِعْتُ مَیْمُونًا یَقُولُ: إنَّ أَہْوَنَ الصَّوْمِ تَرْکُ الطَّعَامِ وَالشَّرَابِ",,,8976,,
8977,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا مُجَالِدٌ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ قَالَ : إِنَّ الصِّیَامَ لَیْسَ مِنَ الطَّعَامِ وَالشَّرَابِ، وَلَکِنْ مِنَ الْکَذِبِ وَالْبَاطِلِ وَاللَّغْوِ۔",,,8977,,
8978,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُجَالِدٌ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ؛ أَنَّ عُمَرَ قَالَ مِثْلَ ذَلِکَ۔",,,8978,,
8979,"حَدَّثَنَا وَکِیعٌ ، وَمُحَمَّدُ بْنُ بِشْرٍ ، عَنْ مِسْعَرٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی الْبَخْتَرِیِّ ؛ أَنَّ امْرَأَۃً کَانَتْ تَصُومُ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی لِسَانِہَا ، فَقَالَ : مَا صَامَتْ فَتَحَفَّظَتْ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : قَدْ کَادَتْ ، ثُمَّ تَحَفَّظَتْ ، فَقَالَ : الآنَ۔",,,8979,,
8980,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ، قَالَ: خَصْلَتَانِ مَنْ حَفِظَہُمَا سَلِمَ لَہُ صَوْمُہُ؛ الْغِیبَۃُ وَالْکَذِبُ۔",,,8980,,
8981,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَقُولُونَ : الْکَذِبُ یُفْطِرُ الصَّائِمَ۔",,,8981,,
8982,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ ہِشَامٍ، عَنْ حَفْصَۃَ، عَنْ أَبِی الْعَالِیَۃِ، قَالَ: الصَّائِمُ فِی عِبَادَۃٍ مَا لَمْ یَغْتَبْ۔",,,8982,,
8983,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنْ یَزِیدَ بْنِ أَبَانَ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا صَامَ مَنْ ظَلَّ یَأْکُلُ لُحُومَ النَّاسِ۔",,,8983,,
8984,"حَدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ أَبِی ہِنْدٍ ، قَالَ : حدَّثَنَا مُطَرِّفُ بْنُ عَبْدِ اللہِ بْنِ الشِّخِّیرِ ، قَالَ : أَتَیْتُ عُثْمَانَ بْنَ أَبِی الْعَاصِ فَدَعَا لِی بِلَبَنِ لَقْحَۃٍ ، فَقُلْتُ : إنِّی صَائِمٌ ، فَقَالَ : أَمَا إنِّی سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : الصِّیَامُ جُنَّۃٌ مِنَ النَّارِ ، کَجُنَّۃِ أَحَدِکُمْ مِنَ الْقِتَالِ ، وَصِیَامٌ حَسَنٌ صِیَامُ ثَلاَثَۃِ أَیَّامٍ مِنْ کُلِّ شَہْرٍ۔ (نسائی 2539۔ احمد 4/21)",,,8984,,
8985,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : الصَّوْمُ جُنَّۃٌ مِنَ النَّارِ کَجُنَّۃِ الرَّجُلِ إذَا حَمَلَ مِنَ السِّلاَحِ مَا أَطَاقَ۔",,,8985,,
8986,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی سِنَانٍ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، وَأَبِی سَعِیدٍ قَالاَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ اللَّہَ یَقُولُ : إنَّ الصَّوْمَ لِی وَأَنَا أَجْزِی بِہِ ، إِنَّ لِلصَّائِمِ فَرْحَتَیْنِ ؛ إذَا أَفْطَرَ فَرِحَ ، وَإِذَا لَقِیَ اللَّہَ فَرِحَ ، وَالَّذِی نَفْسُ مُحَمَّدٍ بِیَدِہِ لَخُلُوفُ فَمِ الصَّائِمِ أَطْیَبُ عِنْدَ اللہِ مِنْ رِیحِ الْمِسْکِ۔ (مسلم 807۔ احمد 3/5)",,,8986,,
8987,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُلُّ عَمَلِ ابْنِ آدَمَ یُضَاعَفُ الْحَسَنَۃُ عَشْرُ أَمْثَالِہَا إلَی سَبْعِمِئَۃِ ضِعْفٍ ، قَالَ اللَّہُ تَعَالَی : إِلاَّ الصَّوْمَ فَإِنَّہُ لِی وَأَنَا أَجْزِی بِہِ ، یَدَعُ طَعَامَہُ وَشَرَابَہُ وَشَہْوَتَہُ مِنْ أَجْلِی ، لِلصَّائِمِ فَرْحَتَانِ ؛ فَرْحَۃٌ عِنْدَ فِطْرِہِ، وَفَرْحَۃٌ عِنْدَ لِقَائِ رَبِّہِ ، وَلَخُلُوفُ فِیِہِ أَطْیَبُ عِنْدَ اللہِ مِنْ رِیحِ الْمِسْکِ ، الصَّوْمُ جُنَّۃٌ ، الصَّوْمُ جُنَّۃٌ۔ (مسلم 164۔ احمد 2/443)",,,8987,,
8988,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مَہْدِیِّ بْنِ مَیْمُونٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی یَعْقُوبَ ، عَنْ رَجَائِ بْنِ حَیْوَۃَ ، عَنْ أَبِی أُمَامَۃَ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، مُرْنِی بِعَمَلٍ أَدْخُلْ بِہِ الْجَنَّۃَ ، أَوْ نَحْوَ ذَلِکَ ، فَقَالَ : عَلَیْک بِالصَّوْمِ، فَإِنَّہُ لاَ مِثْلَ لَہُ ، قَالَ : فَکَانَ أَبُو أُمَامَۃَ لاَ یُرَی فِی بَیْتِہِ الدُّخَانُ نَہَارًا إِلاَّ إذَا نَزَلَ بِہِ ضَیْفٌ۔ (نسائی 2530۔ احمد 5/249)",,,8988,,
8989,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَازِمٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ السَّاعِدِیِّ ، قَالَ : لِلْجَنَّۃِ بَابٌ یُدْعَی الرَّیَّانُ یَدْخُلُ فِیہِ الصَّائِمُونَ ، قَالَ : فَإِذَا دَخَلَ آخِرُہُمْ أُغْلِقَ۔ (طبرانی 6۔ ابن حبان 3421)",,,8989,,
8990,حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ سُلَیْمَانَ بْنِ بِلاَلٍ ، عَنْ أَبِی حَازِمٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ السَّاعِدِیِّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، مِثْلَہُ۔ (بخاری 1896۔ مسلم 166),,,8990,,
8991,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ وَاصِلٍ ، عَنْ بَشََّارِ بْنِ أَبِی سَیْفٍ ، عَنِ الْوَلِیدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عِیَاضِ بْنِ غُطَیْفٍ ، قَالَ : دَخَلْنَا عَلَی أَبِی عُبَیْدَۃَ ، فَقَالَ : الصَّوْمُ جُنَّۃٌ مَا لَمْ تَخْرِقہ۔",,,8991,,
8992,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا جَرِیرُ بْنُ حَازِمٍ ، قَال : حَدَّثَنَا بَشَّارُ بْنِ أَبِی سَیْف ، عَنِ الْوَلِیدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عِیَاضِ بْنِ غُطَیْفٍ ، قَالَ : دَخَلْنَا عَلَی أَبِی عُبَیْدَۃَ بْنِ الْجَرَّاحِ فِی مَرَضِہِ ، فَقَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : الصَّوْمُ جُنَّۃٌ مَا لَمْ یَخْرِقْہَا۔ (احمد 1/196۔ بیہقی 171)",,,8992,,
8993,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ثَابِتٍ ، عَنْ عَبْدِ اللہِ بْنِ رَبَاحٍ ، قَالَ : خَرَجْنَا وَفْدًا إلَی مُعَاوِیَۃَ ، فَمَرَرْنَا بِرَاہِبٍ یَجِیئُ بِالطَّعَامِ فَأَکَلَ الْقَوْمُ ، وَلَمْ آکُلْ ، فَقَالَ لِی : مَا لَکَ لاَ تَأْکُلُ ؟ فَقُلْتُ : إنِّی صَائِمٌ ، قَالَ : أَلاَ أُلْسِمُکَ عَلَی صَوْمِکَ ، تُوضَعُ الْمَوَائِدُ فَأَوَّلُ مَنْ یَأْکُلُ مِنْہَا الصَّائِمُونَ۔",,,8993,,
8994,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، وَأَبُو أُسَامَۃَ قَالَ : أَخْبَرَنَا ہِشَامُ بْنُ حَسَّانَ ، عَنْ وَاصِلٍ مَوْلَی أَبِی عُیَیْنَۃَ ، قَالَ : حَدَّثَنِی لَقِیطٌ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِی مُوسَی ، قَالَ : کُنَّا فِی الْبَحْرِ فَبَیْنَا نَحْنُ نَسِیرُ وَقَدْ رَفَعْنَا الشِّرَاعَ ، وَلاَ نَرَی جَزِیرَۃً ، وَلاَ شَیْئًا إذْ سَمِعْنَا مُنَادِیًا یُنَادِی : یَا أَہْلَ السَّفِینَۃِ ، قِفُوا أُخْبِرْکُمْ فَقُمْنَا نَنْظُرُ فَلَمْ نَرَ شَیْئًا، فَنَادَی سَبْعًا ، فَلَمَّا کَانَتِ السَّابِعَۃُ قُمْتُ فَقُلْتُ : یَا ہَذَا ، أَخْبِرْنَا مَا تُرِیدُ أَنْ تُخْبِرَنَا بِہِ فَإِنَّک تَرَی حَالَنَا ، وَلاَ نَسْتَطِیعُ أَنْ نَقِفَ عَلَیکَ ، قَالَ : أَلاَ أُخْبِرُکُمْ بِقَضَائٍ قَضَاہُ اللَّہُ عَلَی نَفْسِہِ ؟ أَیُّمَا عَبْدٍ أَظْمَأَ نَفْسَہُ فِی اللہِ فِی یَوْمٍ حَارٍّ أَرْوَاہُ اللَّہُ یَوْمَ الْقِیَامَۃِ ۔ زَادَ أَبُو أُسَامَۃَ : فَکُنْتَ لاَ تَشَائُ أَنْ تَرَی أَبَا مُوسَی صَائِمًا فِی یَوْمٍ بَعِیدٍ مَا بَیْنَ الطَّرَفَیْنِ إِلاَّ رَأَیْتَہُ۔",,,8994,,
8995,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعْدَانَ الْجُہَنِیِّ ، عَنْ سَعْدٍ أَبِی مُجَاہِدٍ الطَّائِیِّ ، عَنْ أَبِی مُدِلَّۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الصَّائِمُ لاَ تُرَدُّ دَعْوَتُہُ۔ (ابن ماجہ 1752۔ احمد 2/445)",,,8995,,
8996,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِکُلِّ أَہْلِ عَمَلٍ بَابٌ مِنْ أَبْوَابِ الْجَنَّۃِ یُدْعَوْنَ مِنْہُ بِذَلِکَ الْعَمَلِ ، وَلأَہْلِ الصِّیَامِ بَابٌ یُقَالُ لَہُ : الرَّیَّانُ۔ (بخاری 1897۔ مسلم 85)",,,8996,,
8997,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّ أَبَا طَلْحَۃَ کَانَ یُکْثِرُ الصَّوْمَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَکَانَ لاَ یُفْطِرُ بَعْدَہُ إِلاَّ مِنْ وَجَعٍ۔,,,8997,,
8998,حَدَّثَنَا عَبْدُالْوَہَّابِ، عَنْ أَیُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ لاَ یَکَادُ یُفْطِرُ فِی الْحَضَرِ إِلاَّ أَنْ یَمْرَضَ۔,,,8998,,
8999,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ قُرَّۃَ ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ ، قَالَ : کَانَ مِمَّنْ یُکْثِرُ الصَّوْمَ ؛ ابْنُ عُمَرَ ، وَعَائِشَۃُ ، وَسَعِیدُ بْنُ الْمُسَیَّبِ۔",,,8999,,
9000,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ عُمَرَ سَرَدَ الصَّوْمَ قَبْلَ مَوْتِہِ بِسَنَتَیْنِ۔,,,9000,,
9001,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ جُمْہَانَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ : رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِکُلِّ شَیْئٍ زَکَاۃٌ ، وَزَکَاۃُ الْجَسَدِ الصَّوْمُ۔ (ابن ماجہ 1745)",,,9001,,
9002,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیق ، قَالَ : قِیلَ لِعَبْدِ اللہِ : إنَّک تُقِلُّ الصَّوْمَ ، فَقَالَ : إنِّی أَخَافُ أَنْ یَمْنَعَنِی مِنْ قِرَائَۃِ الْقُرْآنِ ، وَقِرَائَۃُ الْقُرْآنِ أَحَبُّ إلَیَّ مِنَ الصَّوْمِ۔",,,9002,,
9003,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ عَنْ مُہَاجِرٍ ، قَالَ : کَانُوا یَرَوْنَ أَنَّ الصَّوْمَ أَقَلُّ الأَنْوَاعِ أَجْرًا۔",,,9003,,
9004,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا عَمْرُو بْنُ مَیْمُونٍ ، عَنْ أَبِیہِ ؛ أَنَّ رَجُلاً قَالَ لأَبِی ذَرٍّ : الصِّیَامُ ، لاَ أَسْمَعُک ذَکَرْتہ ؟ فَقَالَ أَبُو ذَرٍّ : قُرْبَۃٌ ، وَلَیْسَ ہُنَالِکَ۔",,,9004,,
9005,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، قَالَ : کَانَ مِنْ أَقَلِّ أَعْمَالِہِمَ الصَّوْمُ۔",,,9005,,
9006,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَسَحَّرُوا ، فَإِنَّ فِی السَّحُورِ بَرَکَۃً۔ (مسلم 770۔ بخاری 1923)",,,9006,,
9007,"حَدَّثَنَا وَکِیعٌ ، وَعَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسلَّمَ : تَسَحَّرُوا ، فَإِنَّ فِی السُّحُورِ بَرَکَۃً۔ (احمد 2/477۔ ابو یعلی 6366",,,9007,,
9008,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُلَیٍّ ، عَنْ أَبِیہِ ، عَنْ أَبِی قَیْسٍ مَوْلَی عَمْرِو بْنِ الْعَاصِ ، عَنْ عمْرِو بْنِ الْعَاصِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : فَصْلُ مَا بَیْنَ صِیَامِکُمْ وَصِیَامِ أَہْلِ الْکِتَابِ أَکْلَۃُ السَّحَرِ۔ (مسلم 771۔ احمد 4/197)",,,9008,,
9009,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ شَرِیکٍ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ جَابِرٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ: مَنْ أَرَادَ أَنْ یَصُومَ فَلْیَتَسَحَّرْ ، وَلَوْ بِشَیْئٍ۔(ابویعلی 1926۔ احمد 3/367)",,,9009,,
9010,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ خَالِدٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنْ رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : تَسَحَّرُوا وَلَوْ حَسْوَۃً مِنْ مَائٍ۔ (ابن حبان 3476۔ ابویعلی 3340)",,,9010,,
9011,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : کَانَتْ تُرْجَی بَرَکَۃُ السُّحُورِ۔",,,9011,,
9012,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ ہِشَامٍ ، عَنْ حَفْصَۃَ ، قالَتْ : تَسَحَّرُوا وَلَوْ بِشَرْبَۃٍ مِنْ مَائٍ ، فَإِنَّہَا قَدْ ذُکِرَتْ فِیہِ دَعْوَۃٌ۔",,,9012,,
9013,"حَدَّثَنَا مُطَّلِبُ بْنُ زِیَادٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطِیَّۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَسَحَّرُوا ، فَإِنَّ فِی السُّحُورِ بَرَکَۃً۔ (احمد 3/32)",,,9013,,
9014,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، عَنْ مُوَرِّقٍ الْعِجْلِیّ ، عَنْ أَبِی الدَّرْدَائِ ، قَالَ : مِنْ أَخْلاَقِ النَّبِیِّینَ الإِبْلاَغَ فِی السُّحُورِ۔",,,9014,,
9015,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنِی مُعَاوِیَۃُ بْنُ صَالِحٍ ، قَالَ : حَدَّثَنِی یُونُسُ بْنُ سَیْفٍ الْعَنْسِیُّ ، عَنِ الْحَارِثِ بْنِ زِیَادٍ ، عَنْ أَبِی رُہْمٍ السَّمَاعِیِّ ، أَنَّہُ سَمِعَ عِرْبَاضَ بْنَ سَارِیَۃَ یَقُولُ : دَعَانَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی شَہْرِ رَمَضَانَ إلَی السَّحُورِ ، فَقَالَ : ہَلُمُّوا إلَی الْغَدَائِ الْمُبَارَکِ۔ (ابوداؤد 2337۔ احمد 4/126)",,,9015,,
9016,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ: إنَّ بِلاَلاً یُؤَذِّنُ بِلَیْلٍ ، فَکُلُوا وَاشْرَبُوا حَتَّی یُؤَذِّنَ ابْنُ أُمِّ مَکْتُومٍ۔ (بخاری 617۔ ترمذی 203)",,,9016,,
9017,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَمْنَعَنَّ أَحَدَکُمْ أَذَانُ بِلاَلٍ مِنْ سَحُورِہِ ، فَإِنَّہُ یُنَادِی ، أَوْ یُؤَذِّنُ بِلَیْلٍ ، فَیَنْتَبِہُ نَائِمُکُمْ ، وَیَرْجعُ قَائِمُکُمْ۔ (بخاری 621۔ ابوداؤد 2339)",,,9017,,
9018,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ (ح) وَعَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، عَنْ عَائِشَۃَ ؛ أَنَّ بِلاَلاً کَانَ یُؤَذِّنُ بِلَیْلٍ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُلُوا وَاشْرَبُوا حَتَّی یُؤَذِّنَ ابْنُ أُمِّ مَکْتُومٍ۔ (بخاری 1919۔ مسلم 768)",,,9018,,
9019,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یمنعُکم أَذَانُ بِلاَلٍ مِنْ سُحُورِکُمْ ، فَإِنَّ فِی بَصَرِہِ شَیْئًا۔ (احمد 3/140۔ ابویعلی 2910)",,,9019,,
9020,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی ہِلاَلٍ ، قَالَ : حدَّثَنَا سَوَادَۃُ بْنُ حَنْظَلَۃَ الْہِلاَلِیُّ ، عَنْ سَمُرَۃََ بْنِ جُنْدُبٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَمْنَعَنَّکُمْ مِنَ السُّحُورِ أَذَانُ بِلاَلٍ ، وَلاَ الصُّبْحُ الْمُسْتَطِیلُ ، وَلَکِنِ الصُّبْحُ الْمُسْتَطِیرُ فِی الأفُقِ۔ (ترمذی 706۔ احمد 5/13)",,,9020,,
9021,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : تَسَحَّرْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ قُمْنَا إلَی الصَّلاَۃِ ، قُلْنَا : کَمْ کَانَ بَیْنَہُمَا ؟ قَالَ : قِرَائَۃُ خَمْسِینَ آیَۃً۔ (مسلم 771۔ ترمذی 704)",,,9021,,
9022,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلِ بْنِ یَسَاف ، عَنْ سَالِمِ بْنِ عُبَیْدٍ الأَشْجَعِیِّ ، قَالَ : کُنْتُ مَعَ أَبِی بَکْرٍ ، فَقَالَ : قُمْ فَاسْتُرْنِی مِنَ الْفَجْرِ ، ثُمَّ أَکَلَ۔",,,9022,,
9023,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ شَبِیبِ بْنِ غَرْقَدَۃَ ، عَنْ أَبِی عَقِیلٍ ، قَالَ : تَسَحَّرْت مَعَ عَلِیٍّ ، ثُمَّ أَمَرَ الْمُؤَذِّنَ أَنْ یُقِیمَ۔",,,9023,,
9024,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ جَبَلَۃَ بْنِ سُحَیْمٍ ، عَنْ عَامِرِ بْنِ مَطَرٍ ، قَالَ : أَتَیْتُ عَبْدَ اللہِ فِی دَارِہِ فَأَخْرَجَ لَنَا فَضْلَ سُحُورِہِ فَتَسَحَّرْنَا مَعَہُ ، فَأُقِیمَتِ الصَّلاَۃُ ، فَخَرَجْنَا فَصَلَّیْنَا مَعَہُ۔",,,9024,,
9025,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرٍو ، یَعْنِی ابْنَ حُرَیْثٍ ، قَالَ : کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَعْجَلَ النَّاسِ إفْطَارًا ، وَأَبْطَأَہَمُ سُحُورًا۔",,,9025,,
9026,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ أَبِی یَعْفُورٍ ، قَالَ: سَمِعْتُ أَبَا الشَّعْثَائِ جَابِرَ بْنَ زَیْدٍ یَقُولُ: کَانُوا یَتَسَحَّرُونَ حِینَ۔",,,9026,,
9027,"حَدَّثَنَا وَکِیعٌ، عَنْ عَمْرِو بْنِ مَرْوَانَ أَبِی الْعَنْبَسِ، قَالَ: سَمِعْتُ إبْرَاہِیمَ یَقُولُ: مِنَ السُّنَّۃِ تَأْخِیرُ السُّحُورِ۔",,,9027,,
9028,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا الْوَلِیدُ بْنُ جُمَیع، قَالَ: حَدَّثَنَا أَبُو الطُّفَیْلِ؛ أَنَّہُ تَسَحَّرَ فِی أَہْلِہِ فِی الْجَبَّانَۃِ ، ثُمَّ جَائَ إلَی حُذَیْفَۃَ وَہُوَ فِی دَارِ الْحَارِثِ بْنِ أَبِی رَبِیعَۃَ فَوَجَدَہُ ، فَحَلَبَ لَہُ نَاقَۃً فَنَاوَلَہُ ، فَقَالَ: إنِّی أُرِیدُ الصَّوْمَ، فَقَالَ: وَأَنَا أُرِیدُ الصَّوْمَ، فَشَرِبَ حُذَیْفَۃُ، وَأَخَذَ بِیَدِہِ فَدَفَعَ إلَی الْمَسْجِدِ حِینَ أُقِیمَتِ الصَّلاَۃُ۔",,,9028,,
9029,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ التَّیْمِیِّ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : یَکُونُ بَیْنَ سُحُورِ الرَّجُلِ وَبَیْنَ إقَامَۃِ الْمُؤَذِّنِ قَدْرُ مَا یَقْرَأُ سُورَۃَ یُوسُفَ۔",,,9029,,
9030,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، قَالَ : خَرَجْت مَعَ حُذَیْفَۃَ إلَی الْمَدَائِنِ فِی رَمَضَانَ ، فَلَمَّا طَلَعَ الْفَجْرُ ، قَالَ : ہَلْ کَانَ أَحَدٌ مِنْکُمْ آکِلاً ، أَوْ شَارِبًا ؟ قُلْنَا : أَما رَجُلٌ یُرِیدُ الصَّوْمَ فَلاَ ، ثُمَّ سِرْنَا حَتَّی اسْتَبْطَأْنَاہُ فِی الصَّلاَۃِ ، ثُمَّ نَزَلَ فَصَلَّی۔",,,9030,,
9031,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : مِنْ أَخْلاَقِ الأَنْبِیَائِ تَأْخِیرُ السُّحُورِ۔",,,9031,,
9032,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ ابْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ حُذَیْفَۃُ یُعَجِّلُ بَعْضَ سحُورِہِ لِیُدْرِکَ الصَّلاَۃَ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَبَلَغَ ذَلِکَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَکَانَ یُرْسِلُ إلَیْہِ فَیَأْکُلُ مَعَہُ حَتَّی یَخْرُجَا إلَی الصَّلاَۃِ جَمِیعًا۔",,,9032,,
9033,"حَدَّثَنَا عَفَّانُ ، قَالَ : حَدَّثَنَا شُعْبَۃُ ، عَنْ خُبَیبِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : سَمِعْتُ عَمَّتِی تَقُولُ ، وَکَانَتْ حَجَّتْ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إنَّ ابْنَ أُمِّ مَکْتُومٍ یُنَادِی بِلَیْلٍ ، فَکُلُوا وَاشْرَبُوا حَتَّی یُنَادِیَ بِلاَلٌ ، وَإِنَّ بِلاَلاً یُؤَذِّنُ بِلَیْلٍ فَکُلُوا وَاشْرَبُوا حَتَّی یُنَادِیَ ابْنُ أُمِّ مَکْتُومٍ ، قَالَتْ : وَکَانَ یَصْعَدُ ہَذَا وَیَنْزِلُ ہَذَا ، فَکُنَّا نَتَعَلَّقُ بِہِ فَنَقُولُ : کَمَا أَنْتَ حَتَّی نَتَسَحَّرَ۔\n\n(طیالسی 1661۔ طبرانی 481)",,,9033,,
9034,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، وَوَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ أَبِیہِ ، عَنْ عَاصِمِ بْنِ عُمَرَ ، عَنْ عُمَرَ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا جَائَ اللَّیْلُ مِنْ ہَاہُنَا ، وَذَہَبَ النَّہَارُ مِنْ ہَاہُنَا فَقَدْ أَفْطَرَ الصَّائِمُ۔ (ابوداؤد 2343۔ احمد 1/28)",,,9034,,
9035,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ الشَّیْبَانِیِّ ، عَنِ ابْنِ أَبِی أَوْفَی ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَفَرٍ وَہُوَ صَائِمٌ ، فَلَمَّا غَابَتِ الشَّمْسُ ، قَالَ : یَا فُلاَنُ انْزِلْ فَاجْدَحْ لَنَا ، قَالَ : یَا رَسُولَ اللہِ ، إنَّ عَلَیْک نَہَارًا ، قَالَ : انْزِلْ فَاجْدَحْ لَنَا ، قَالَہَا ثَلاَثًا ، فَنَزَلَ فَجَدَحَ فَشَرِبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ قَالَ : إذَا رَأَیْتُمُ اللَّیْلَ قَدْ أَقْبَلَ مِنْ ہَاہُنَا فَقَدْ أَفْطَرَ الصَّائِمُ۔\n\nقُلْت : وَأَنْتَ مَعَہُ ؟ قَالَ : نَعَمْ۔ (بخاری 1941۔ مسلم 773)",,,9035,,
9036,حَدَّثَنَا زِیَادُ بْنُ الرَّبِیعِ ، وَکَانَ ثِقَۃً ، عَنْ أَبِی جَمْرَۃَ الضُّبَعِیِّ ؛ أَنَّہُ کَانَ یُفْطِرُ مَعَ ابْنِ عَبَّاسٍ فِی رَمَضَانَ ، فَکَانَ إذَا أَمْسَی بَعَثَ رَبِیبۃ لَہُ تَصْعَدُ ظَہْرَ الدَّارِ ، فَإِذَا غَابَت الشَّمْسُ أَذَّنَ ، فَیَأْکُلَ وَنَأْکُلَ ، فَإِذَا فَرَغَ أُقِیمَتِ الصَّلاَۃُ فَیَقُومَ یُصَلِّی وَنُصَلِّیَ مَعَہُ۔,,,9036,,
9037,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، حَدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَزَالُ الدِّینُ ظَاہِرًا مَا عَجَّلَ النَّاسُ الْفِطْرَ ، إنَّ الْیَہُودَ وَالنَّصَارَی یُؤَخِّرُونَ۔ (ابوداؤد 2345۔ احمد 2/450)",,,9037,,
9038,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، أَنَّہُ سَمِعَہُ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَزَالُ النَّاسُ بِخَیْرٍ مَا عَجَّلُوا إفْطَارَہُمْ ، وَلَمْ یُؤَخِّرُوہُ تَأْخِیرَ أَہْلِ الْمَشْرِقِ۔ (بخاری 1957۔ ترمذی 699)",,,9038,,
9039,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ طَارِقٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : کَانَ عُمَرُ یَکْتُبُ إلَی أُمَرَائِہِ أَنْ لاَ تَکُونُوا مِنَ الْمُسوِفِینَ لِفِطْرِکُمْ ، وَلاَ تَنْتَظِرُوا بِصَلاَتِکُمُ اشْتِبَاکَ النُّجُومِ۔",,,9039,,
9040,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سِمَاک ، عَنْ ثَرْوَانَ بْنِ مِلْحَانَ التَّیْمِیِّ ، قَالَ : قَالَ رَجُلٌ لِعَمَّار بْنِ یَاسِرٍ : إنَّ أَبَا مُوسَی قَالَ : لاَ تُفْطِرُوا حِینَ تَبْدُو الْکَوَاکِبُ ، فَإِنَّ ذَلِکَ فِعْلُ الْیَہُودِ۔",,,9040,,
9041,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : أُتِیَ عَبْدُ اللہِ بِجَفْنَۃٍ ، فَقَالَ لِلْقَوْمِ : اُدْنُوْا فَکُلُوا ، فَاعْتَزَلَ رَجُلٌ مِنْہُمْ ، فَقَالَ لَہُ عَبْدُ اللہِ : مَا لَکَ ؟ قَالَ : إنِّی صَائِمٌ ، فَقَالَ عَبْدُ اللہِ : ہَذَا وَالَّذِی لاَ إلَہَ غَیْرُہُ حِینَ حَلَّ الطَّعَامُ لآکِلٍ۔",,,9041,,
9042,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ أَیْمَنَ ، عَنْ أَبِیہِ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : دَخَلْت عَلَیْہِ فَأَفْطَرَ عَلَی عِرْقٍ، وَأَنا أَرَی الشَّمْسَ لَمْ تَغْرُبْ۔",,,9042,,
9043,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، قَالَ : إنِّی کُنْت لآتِیَ ابْنَ عُمَرَ بِفِطْرِہِ ، فَأُغَطِّیہِ اسْتِحْیَائً مِنَ النَّاسِ أَنْ یَرَوْہُ۔",,,9043,,
9044,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنِ الْہَجَرِیِّ ، عَنْ رَجُلٍ مِنْ بَنِی سَوَادَۃَ ، قَالَ : انْطَلَقْت إلَی حُذَیْفَۃَ ، فَنَزَلْت مَعَہُ ، فَکَانَ إذَا غَابَتِ الشَّمْسُ نَزَلَ حُذَیْفَۃُ وَأَصْحَابُہُ ، لَمْ یَلْبَثْ إِلاَّ قَلِیلاً حَتَّی یُفْطِرَ۔",,,9044,,
9045,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُسْلِمِ بْنِ یَزِیدَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ عَلِیُّ بْنُ أَبِی طَالِبٍ یَقُولُ لاِبْنِ النَّبَّاحِ : غَرَبَتِ الشَّمْسُ ؟ فَیَقُولُ : لاَ تَعْجَلْ ، فَیَقُولُ : غَرَبَتِ الشَّمْسُ ؟ فَیَقُولُ : لاَ تَعْجَلْ ، فَیَقُولُ : غَرَبَتِ الشَّمْسُ ؟ فَإذَا قَالَ : نَعَمْ ، أَفْطَرَ ، ثُمَّ نَزَلَ فَصَلَّی۔",,,9045,,
9046,"حَدَّثَنَا عُمَرُ بْنُ سَعدٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَازِمٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَزَالُ ہَذِہِ الأُمَّۃُ بِخَیْرٍ مَا عَجَّلُوا الإِفْطَارَ۔ (مسلم 771۔ ترمذی 699)",,,9046,,
9047,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إذَا رَأَیْت أَنَّ الْعَصْرَ قَدْ فَاتَتْک فَاشْرَبْ۔",,,9047,,
9048,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعَنْبَسِ عَمْرِو بْنِ مَرْوَانَ ، قَالَ : سَمِعْتُ إبْرَاہِیمَ یَقُولُ : إنَّ مِنَ السُّنَّۃِ تَعْجِیلَ الإِفْطَارِ۔",,,9048,,
9049,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُوسَی بْنِ أَنَسٍ ؛ أَنَّ أَنَسًا کَانَ یُصْعِدُ الْجَارِیَۃَ فَوْقَ الْبَیْتِ فَیَقُولُ : إذَا اسْتَوَی الأُفُقُ فَآذِنِینِی۔",,,9049,,
9050,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، عَنْ مُوَرِّقٍ الْعِجْلِیّ ، عَنْ أَبِی الدَّرْدَائِ ، قَالَ : ثَلاث مِنْ أَخْلاَقِ النَّبِیِّین؛ التَّبْکِیرُ فِی الإِفْطَارِ ، وَالإِبْلاَغُ فِی السُّحُورِ ، وَوَضْعُ الْیَمِینِ عَلَی الشِّمَالِ فِی الصَّلاَۃِ",,,9050,,
9051,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَیَانٍ ، عَنْ قَیْسٍ ، قَالَ : نَاوَلَ عُمَرُ رَجُلاً إنَائً إلَی جَنْبِہِ حِینَ غَرَبَتِ الشَّمْسُ ، فَقَالَ لَہُ : اشْرَبْ ، ثُمَّ قَالَ : لَعَلَّک مِنَ الْمُسَوِّفِینَ بِفِطْرِہِ ؛ سَوف سَوف۔",,,9051,,
9052,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ صَفْوَانَ بْنِ عَبْدِ اللہِ ، عَنْ أُمِّ الدَّرْدَائِ ، عَنْ کَعْبِ بْنِ عَاصِمٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ مِنَ الْبِرِّ الصِّیَامُ فِی السَّفَرِ۔ (ابن ماجہ 1664۔ احمد 434)",,,9052,,
9053,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ سَعدٍ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو بْنِ الْحَسَنِ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَفَرٍ ، فَرَأَی رَجُلاً قَدِ اجْتَمَعَ النَّاسُ عَلَیْہِ ، وَقَدْ ظُلِّلَ عَلَیْہِ ، فَقَالَ : مَا لَہُ ؟ قَالُوا : رَجُلٌ صَائِمٌ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ مِنَ الْبِرِّ أَنْ تَصُومُوا فِی السَّفَرِ۔ (بخاری 1946۔ مسلم 92)",,,9053,,
9054,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ مُوَرِّقٍ ، عَنْ أَنَسٍ ، قَالَ : کُنَّا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَفَرٍ ، فَمِنَّا الصَّائِمُ وَمِنَّا الْمُفْطِرُ ، فَقَامَ الْمُفْطِرُونَ فَضَرَبُوا الأَبْنِیَۃَ وَسَقَوا الرِّکَابَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ذَہَبَ الْمُفْطِرُونَ الْیَوْمَ بِالأَجْرِ۔ (مسلم 788۔ بیہقی 243)",,,9054,,
9055,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، قَالَ : الصَّائِمُ فِی السَّفَرِ کَالْمُفْطِرِ فِی الْحَضَرِ۔",,,9055,,
9056,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی جَمْرَۃَ ، قَالَ : سَأَلْتُ ابْنَ عَبَّاسٍ عَنِ الصَّوْمِ فِی السَّفَرِ ؟ فَقَالَ : عُسْرٌ وَیُسْرٌ ، خُذْ بِیُسْرِ اللہِ عَلَیْک۔",,,9056,,
9057,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ زَکَرِیَّا ، عَنْ عَامِرٍ ؛ أَنَّہُ کَانَ لاَ یَصُومُ فِی السَّفَرِ۔,,,9057,,
9058,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ عَوْفٍ ، قَالَ : بَلَغَنِی أَنَّ الْحَسَنَ کَانَ یَقُولُ : الإِفْطَارُ فِی السَّفَرِ ، وَالْحَضَرُ رُخْصََۃ۔",,,9058,,
9059,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، حَدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، أَنَّ ابْنَ عَبَّاسٍ قَالَ : الإِفْطَارُ فِی السَّفَرِ عَزِیمَۃٌ۔",,,9059,,
9060,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الإِفْطَارُ فِی السَّفَرِ صَدَقَۃٌ تَصَدَّقَ اللَّہُ بِہَا عَلَی عِبَادِہِ۔",,,9060,,
9061,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبیدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَامَ عَامَ الْفَتْحِ حَتَّی بَلَغَ الْکَدِیدَ ، ثُمَّ أَفْطَرَ ، وَإِنَّمَا یُؤْخَذُ بِالآخَرِ مِنْ فِعْلِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (بخاری 2953۔ احمد 219),,,9061,,
9062,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعُمَیْسِ ، قَالَ : سَأَلْتُ أَبَا جَعْدٍ عَنِ الصَّوْمِ فِی السَّفَرِ ؟ فَقَالَ : لاَ تَصُومَنَّ۔",,,9062,,
9063,حَدَّثَنَا وَکِیعٌ، عَنْ عَبْدِاللہِ بْنِ حُمَیْدٍ، عَنْ عَبْدِاللہِ بْنِ ذَکْوَانَ؛ أَنَّ ابْنَ عُمَرَ أَقَامَ بِالشَّامِ رَمَضَانَیْنِ فَأَفْطَرَ۔,,,9063,,
9064,"حَدَّثَنَا أَبُوخَالِدٍ الأَحْمَرِِ، عَنْ مَنْصُورِ بْنِ حَیَّانَ، قَالَ: قَالَ سَعِیدُ بْنُ جُبَیْرٍ : مَنْ صَحِبَنِی فِی سَفَرٍ فَلاَ یَصُومَنَّ۔",,,9064,,
9065,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُضَرِّسِ بْنِ عَبْدِ اللہِ ، قَالَ : قُلْتُ لِلشَّعْبِیِّ : إنِّی أُقِیمُ بِالرَّیِّ ، قَالَ : صَلِّ رَکْعَتَیْنِ ، قُلْتُ : فَالصَّوْمُ ؟ قَالَ : لاَ تَصُمْ ، أَفْطِرْ وَإِنْ أَقَمْت عَشْرَ سِنِینَ۔",,,9065,,
9066,"حَدَّثَنَا أَبُو دَاوُدَ عُمَرُ بْنُ سَعْدٍ ، عَنْ سُفْیَانَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ فِی سَفَرٍ ، وَمَعَہُ أَبُو بَکْرٍ وَعُمَرُ ، فَأُتِیَ بِطَعَامٍ ، فَقَالَ لَہُمَا : اُدْنُوَا فَکُلاَ ، فَقَالاَ : یَا رَسُولَ اللہِ ، إنَّا صَائِمَانِ ، فَقَالَ : ارْحلُوا لِصَاحِبَیْکُمْ ، اعْمَلُوا لِصَاحِبَیْکُم ، اُدْنُوَا فَکُلاَ۔(نسائی 2572۔ احمد 2/336)",,,9066,,
9067,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَمَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، قَالَ : سُئِلَ أَنَسٌ عَنِ الصَّوْمِ فِی السَّفَرِ ؟ فَقَالَ : مَنْ أَفْطَرَ فَرُخْصَۃٌ ، وَمَنْ صَامَ فَالصَّوْمُ أَفْضَلُ۔",,,9067,,
9068,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : صَحِبْت عَائِشَۃَ فِی السَّفَرِ ، فَمَا أَفْطَرَتْ حَتَّی دَخَلَتْ مَکَّۃَ۔",,,9068,,
9069,حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، عَنِ النَّضْرِ بْنِ عَبْدِ اللہِ الْقَیْسِیِّ ، عَنْ قَیْسِ بْنِ عُبَادٍ؛ أَنَّہُ کَانَ یَصُومُ فِی السَّفَرِ وَیُفْطِرُ,,,9069,,
9070,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُوسَی مَوْلَی ابْنِ عَامِرٍ ، قَالَ : سَأَلْتُ أَنَسًا عَنِ الصَّوْمِ فِی السَّفَرِ ؟ فَقَالَ : کُنَّا مَعَ أَبِی مُوسَی فِی السَّفَرِ فَصَامَ وَصُمْنَا۔",,,9070,,
9071,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی خَالِدٍ ، عَنِ ابْنِ الأَسْوَد ؛ أَنَّ أَبَاہُ کَانَ یَصُومُ فِی السَّفَرِ۔,,,9071,,
9072,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یَصُومُ فِی السَّفَرِ",,,9072,,
9073,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنِ ابْنِ عَوْنٍ، عَنِ الْقَاسِمِ، قَالَ: قَدْ رَأَیْت عَائِشَۃَ تَصُومُ فِی السَّفَرِ: حَتَّی أَذْلَقَہَا السَّمُومُ۔",,,9073,,
9074,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ عُثْمَانَ بْنُ أَبِی الْعَاصِ یَقُولُ فِی ذَلِکَ مِثْلَ قَوْلِ أَنَسِ بْنِ مَالِکٍ۔",,,9074,,
9075,حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَخْرُجُ إلَی الْغَابَۃِ فَلاَ یُفْطِرُ ، وَلاَ یَقْصُرُ۔,,,9075,,
9076,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، أَنَّ عُثْمَانَ بْنَ أَبِی الْعَاصِ ، قَالَ : الصَّوْمُ فِی السَّفَرِ أَفْضَلُ ، وَالْفِطْرُ رُخْصَۃٌ۔",,,9076,,
9077,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ کَہْمَسٍ ، قَالَ : سُئِلَ سَالِمٌ ، أَوْ سَأَلْتُہُ عَنِ الصَّوْمِ فِی السَّفَرِ ؟ فَقَالَ : إِنْ صُمْتُمْ فَقَدْ أَجْزَأَ عَنْکُمْ ، وَإِنْ أَفْطَرْتُمْ فَقَدْ رُخِّصَ لَکُمْ۔",,,9077,,
9078,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ؛ أَنَّ حَمْزَۃَ الأَسْلَمِیَّ سَأَلَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الصَّوْمِ فِی السَّفَرِ ؟ فَقَالَ : صُمْ إِنْ شِئْتَ ، وَأَفْطِرْ إِنْ شِئْت۔ (بخاری 1943۔ مسلم 103)",,,9078,,
9079,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ الْعَوَّامِ ، قَالَ : قُلْتُ لِمُجَاہِدٍ : أَیُّ ذَلِکَ أَعْجَبُ إلَیْک ؟ قَالَ : إِذَا کُنْتَ تُطِیقُ الصَّوْمَ فَالصَّوْمُ أَعْجَبُ إلَیَّ۔",,,9079,,
9080,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَشْعَثِ بْنِ أَبِی الشَّعْثَائِ ، قَالَ : صَحِبْت أَبِی ، وَعَمْرَو بْنَ مَیْمُونٍ ، وَالأَسْوَد بْنَ یَزِیدَ ، وَأَبَا وَائِلٍ فَکَانُوا یَصُومُونَ رَمَضَانَ وَغَیْرَہُ فِی السَّفَرِ",,,9080,,
9081,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، قَالَ : اسْتَأْذَنْت حُذَیْفَۃَ بِالْمَدَائِنِ ، فَقَالَ لِی حُذَیْفَۃُ : بشرط عَلَی أَنْ لاَ تَقْصُرَ ، وَلاَ تُفْطِرَ۔",,,9081,,
9082,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : خَرَجْنَا مَعَ نَبِیِّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِن مَکَۃَ إلَی حُنَیْنٍ ، فِی اثْنَتَیْ عَشْرَۃَ بَقِیَتْ مِنْ رَمَضَانَ ، فَصَامَ طَائِفَۃٌ مِنْ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَفْطَرَ آخَرُونَ ، فَلَمْ یَعِبْ ذَلِکَ۔ (مسلم 94۔ احمد 3/92)",,,9082,,
9083,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : کُنَّا نَغْزُو مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَمِنَّا الصَّائِمُ وَمِنَّا الْمُفْطِرُ ، فَلاَ یَعِیبُ الصَّائِمُ عَلَی الْمُفْطِرِ ، وَلاَ الْمُفْطِرُ عَلَی الصَّائِمِ۔",,,9083,,
9084,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حُمَیْدٍ ، قَالَ : خَرَجْت فَصُمْت ، فَقَالُوا لِی : أَعِدْ ، قَالَ : فَقُلْتُ : إنَّ أَنَسًا أَخْبَرَنِی أَنَّ أَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانُوا یُسَافِرُونَ ، فَلاَ یَعِیبُ الصَّائِمُ عَلَی الْمُفْطِرِ ، وَلاَ الْمُفْطِرُ عَلَی الصَّائِمِ ، فَلَقِیتُ ابْنَ أَبِی مُلَیْکَۃَ فَأَخْبَرَنِی عَنْ عَائِشَۃَ ، بِمِثْلِہِ۔",,,9084,,
9085,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، وَالْحَسَنِ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ قَالُوا : کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُسَافِرُونَ فَیَصُومُ الصَّائِمُ ، وَیُفْطِرُ الْمُفْطِرُ ، فَلاَ یَعِیبُ الصَّائِمُ عَلَی الْمُفْطِرِ ، وَلاَ الْمُفْطِرُ عَلَی الصَّائِمِ۔",,,9085,,
9086,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمِ الأَحْوَلِ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ جَابِرٍ ، قَالَ : کُنَّا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَمِنَّا الصَّائِمُ وَمِنَّا الْمُفْطِرُ ، فَلَمْ یَکُنْ یَعِیبُ بَعْضُنَا عَلَی بَعْضٍ",,,9086,,
9087,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، حَدَّثَنَا الأَعْمَش ، عَنْ شَقِیقٍ ، قَالَ : کُنَّا مَعَ أَصْحَابِ عَبْدِ اللہِ فِی سَفَرٍ ، فَصَامَ بَعْضُہُمْ وَأَفْطَرَ بَعْضُہُمْ۔",,,9087,,
9088,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ عِمْرَانَ الْقَطَّانِ ، عَنْ عَمَّارٍ مَوْلَی بَنِی ہَاشِمٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ صَامَ رَمَضَانَ فِی سَفَرٍ ؟ فَقَالَ : لاَ یُجْزِیہِ۔",,,9088,,
9089,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ زُہَیْرٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَطَائٍ ، عَنِ الْمُحَرَّر بْنِ أَبِی ہُرَیْرَۃَ ، قَالَ : صُمْت رَمَضَانَ فِی السَّفَرِ ، فَأَمَرَنِی أَبُو ہُرَیْرَۃَ أَنْ أُعِیدَ الصِّیَامَ فِی أَہْلِی۔",,,9089,,
9090,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی الْفَیْضِ ، قَالَ : کُنَّا فِی غَزْوَۃٍ فَکَانَ عَلَیْنَا أَمِیرٌ ، فَقَالَ : لاَ تَصُومَنَّ ، فَمَنْ صَامَ فَلْیُفْطِرْ ، قَالَ أَبُو الْفَیْضِ : فَلَقِیتُ أَبَا قِرْصَافَۃَ ، رَجُلاً مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَسَأَلْتُہُ عَنْ ذَلِکَ ؟ فَقَالَ : لَوْ صُمْتُ ثُمَّ صُمْتُ مَا قَضَیْتُ۔",,,9090,,
9091,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ رَجُلٍ ، عَنْ أَبِیہِ ؛ أَنَّ رَجُلاً صَامَ رَمَضَانَ فِی السَّفَرِ ، فَأَمَرَہُ عُمَرُ رَحِمَہُ اللَّہُ أَنْ یُعِیدَ۔,,,9091,,
9092,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَبِیْدَۃَ ، قَالَ : سَأَلْتُُہُ عَنْ قَوْلِہِ تَعَالَی : {فَمَنْ شَہِدَ مِنْکُمُ الشَّہْرَ فَلْیَصُمْہُ} ؟ قَالَ : مَنْ شَہِدَ أَوَّلَہُ فَلْیَصُمْ آخِرَہُ ، أَلاَ تَرَی إلَی قَوْلِہِ تَعَالَی : {فَمَنْ شَہِدَ مِنْکُمُ الشَّہْرَ فَلْیَصُمْہُ}۔",,,9092,,
9093,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : إذَا دَخَلَ شَہْرُ رَمَضَانَ فَلاَ یَخْرُجُ ، فَإِنْ أَبَی إِلاَّ أَنْ یَخْرُجَ فَلْیُتِمَّ صَوْمَہُ۔",,,9093,,
9094,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عَلِیٍّ رحمہ اللہ تَعَالَی ، قَالَ : إذَا أَدْرَکَہُ رَمَضَانُ وَہُوَ مُقِیمٌ ثُمَّ سَافَرَ فَلْیَصُمْ۔",,,9094,,
9095,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، أَخْبَرَنَا عَمْرُو بْنُ مُرَّۃَ ، قَالَ : سَمِعْتُ أَبَا الْبَخْتَرِیِّ یُحَدِّثُ ، عَنْ عُبَیْدَۃَ ، أَنَّہُ قَالَ فِی الرَّجُلِ یَصُومُ مِنْ رَمَضَانَ أَیَّامًا ، ثُمَّ یَخْرُجُ ، قَالَ : یَصُومُ ۔ وَقَالَ ابْنُ عَبَّاسٍ : إِنْ شَائَ صَامَ : وَإِنْ شَائَ أَفْطَرَ۔",,,9095,,
9096,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْحَجَّاجِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ خَرَجَ فِی رَمَضَانَ فَأَفْطَرَ۔,,,9096,,
9097,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ عَاصِمٍ، عَنِ الْحَسَنِ، أَنَّہُ قَالَ: لاَ بَأْسَ فِی السَّفَرِ فِی رَمَضَانَ، وَیُفْطِرُ إِنْ شَائَ۔",,,9097,,
9098,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَامَ عَامَ الْفَتْحِ حَتَّی بَلَغَ الْکَدِیدَ ، ثُمَّ أَفْطَرَ۔,,,9098,,
9099,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : سَأَلْتُ عَبِیْدَۃَ: أُسَافِرُ فِی رَمَضَانَ؟ فَقَالَ: لاَ۔",,,9099,,
9100,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ سُفْیَانَ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ عَلِیِّ بْنِ حُسَیْنٍ ؛ أَنَّہُ سُئِلَ عَنْ قَوْمٍ سَافَرُوا فِی رَمَضَانَ ؟ قَالَ : یَصُومُونَ۔",,,9100,,
9101,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ؛ فِی قولہ تعالی : {وَعَلَی الَّذِینَ یُطِیقُونَہُ فِدْیَۃٌ طَعَامُ مِسْکِینٍ} قَالَ : نَسَخَتْہَا {فَمَنْ شَہِدَ مِنْکُمُ الشَّہْرَ فَلْیَصُمْہُ}۔",,,9101,,
9102,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إِنَّہَا قَدْ نَسَخَتْ ہَذِہِ الآیَۃَ : {فَمَنْ شَہِدَ مِنْکُمُ الشَّہْرَ فَلْیَصُمْہُ} الآیَۃُ الَّتِی بَعْدَہَا",,,9102,,
9103,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ ، عَنْ أَبِی یَزِیدَ ، عَنْ أُمِّ ذَرَّۃَ قَالَتْ : أَتَیْتُ عَائِشَۃَ ، فَقَالَتْ : مِنْ أَیْنَ جِئْت؟ فَقُلْتُ: مِنْ عِنْدِ أَخِی ، فَقَالَتْ : مَا شَأْنُہُ ؟ قُلْتُ : وَدَّعْتُہُ یُرِیدُ أَنْ یَرْتَحِلَ ۔ قَالَتْ : فَأَقْرِئِیہِ مِنِّی السَّلاَمَ، وَمُرِیہِ فَلْیَقُمْ ، فَلَوْ أَدْرَکَنِی وَأَنَا بِبَعْضِ الطَّرِیقِ لأَقَمْتُ ، یَعْنِی رَمَضَانَ۔",,,9103,,
9104,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : خَرَجَ أَبُو مَیْسَرَۃَ فِی رَمَضَانَ مُسَافِرًا ، فَمَرَّ بِالْفُرَاتِ وَہُوَ صَائِمٌ فَأَخَذَ مِنْہُ حَسْوَۃً ، فَشَرِبَہُ وَأَفْطَرَ۔",,,9104,,
9105,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ قَالاَ : یُفْطِرُ إِنْ شَائَ۔",,,9105,,
9106,"حَدَّثَنَا أَبُو بَکْرٍ حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی الْوَرْدِ بْنِ ثُمَامَۃَ ، عَنِ اللَّجْلاَجِ ، قَالَ: کُنَّا نُسَافِرُ مَعَ عُمَرَ رضی اللَّہُ عَنْہُ ثَلاَثَۃَ أَمْیَالٍ ، فَیَتَجَوَّزُ فِی الصَّلاَۃِ وَیُفْطِرُ۔",,,9106,,
9107,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ : أُقْصِرُ الصَّلاَۃَ وَأُفْطِرُ إلَی رِیمٍ ؟ قَالَ : نَعَمْ ، وَہُوَ بَرِیدان مِنَ الْمَدِینَۃِ۔",,,9107,,
9108,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : الصِّیَامُ فِی السَّفَرِ مِثْلُ الصَّلاَۃِ ، تَقْصُرُ إذَا أَفْطَرْت ، وَتَصُومُ إذَا وَفَّیْتَ الصَّلاَۃَ۔",,,9108,,
9109,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : سَأَلْتُ الزُّہْرِیَّ : فِی کَمْ تُقْصَرُ الصَّلاَۃُ ؟ قَالَ : فِی السَّفَرِ الْمُمْعِنِ ، قَالَ : قُلْتُ : وَمَا الإِمْعَانُ فِی نَفْسِکَ ؟ قَالَ : یَوْمَیْنِ۔",,,9109,,
9110,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ مَعَ حُذَیْفَۃَ بِالْمَدَائِنِ ، قَالَ: فَاسْتَأْذَنْتُہُ بِالرُّجُوعِ إلَی أَہْلِی ، فَقَالَ : لاَ آذَنُ لَکَ إِلاَّ عَلَی أَنْ تَعْزِمَ أَلاَّ تُفْطِرَ حَتَّی تَدْخُلَ ، قَالَ : وَذَلِکَ فِی رَمَضَانَ ، قُلْتُ : وَأَنَا أَعْزِمُ عَلَی نَفْسِی أَنْ لاَ أُفْطِرَ ، وَلاَ أَقْصُرَ حَتَّی آتِیَ أَہْلِی۔",,,9110,,
9111,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مَرْثَدٍ ؛ أَنَّ أَبَا مَیْسَرَۃَ سَافَرَ فِی رَمَضَانَ ، فَأَفْطَرَ عِنْدَ بَابِ الْجِسْرِ۔,,,9111,,
9112,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَصُومُوا قَبْلَ رَمَضَانَ ، صُومُوا لِرُؤْیَتِہِ وَأَفْطِرُوا لِرُؤْیَتِہِ ، فَإِنْ حَالَتْ دُونَہُ غَیَایَۃٌ فَکَمِّلُوا ثَلاَثِینَ۔ (ترمذی 688۔ ابویعلی 2355)",,,9112,,
9113,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مَنْصُورٍ ، عَنْ رِبْعِیٍّ ، عَنْ رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَقَدَّمُوا الشَّہْرَ إِلاَّ أَنْ تَرَوُا الْہِلاَلَ ، أَوْ تُکْمِلُوا الْعِدَّۃَ ، وَلاَ تُفْطِرُوا حَتَّی تَرَوُا الْہِلاَلَ ، أَوْ تُکْمِلُوا الْعِدَّۃَ۔ (ابوداؤد 2320۔ نسائی 2436)",,,9113,,
9114,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ ، قَالَ : صُومُوا لِرُؤْیَتِہِ وَأَفْطِرُوا لِرُؤْیَتِہِ ، فَإِنْ غُمَّ عَلَیْکُمْ فَأَتموا ثَلاَثِینَ",,,9114,,
9115,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ تَصِلُوا رَمَضَانَ بِشَیْئٍ ، وَلاَ تَقَدَّمُوا قَبْلَہُ بِیَوْمٍ ، وَلاَ بِیَوْمَیْنِ۔",,,9115,,
9116,"حَدَّثَنَا أَبُو أُسَامَۃَ ، حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَکَرَ رَمَضَانَ ، فَقَالَ : صُومُوا لِرُؤْیَتِہِ وَأَفْطِرُوا لِرُؤْیَتِہِ ، فَإِنْ أُغْمِی عَلَیْکُمْ فَاقْدُرُوا لَہُ۔ (مسلم 5۔ احمد 2/13)",,,9116,,
9117,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، حَدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ أَبِی الزِّنَادِ ، عَنِ الأَعْرَجِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : ذَکَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْہِلاَلَ ، فَقَالَ : إذَا رَأَیْتُمُوہُ فَصُومُوا ، وَإِذَا رَأَیْتُمُوہُ فَأَفْطِرُوا ، فَإِنْ أُغْمِی عَلَیْکُمْ فَعُدُّوا ثَلاَثِینَ۔ (مسلم 20۔ ابویعلی 6252)",,,9117,,
9118,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : نُہِیَ أَنْ یُتَعَجَّلَ قَبْلَ رَمَضَانَ بِیَوْمٍ ، أَوْ یَوْمَیْنِ۔",,,9118,,
9119,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعُمَیْسِ ، عَنِ الْعَلاَئِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ یَعْقُوبَ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا کَانَ النِّصْفُ مِنْ شَعْبَانَ ، فَأَمْسِکُوا حَتَّی یَکُونَ رَمَضَانُ۔ (ترمذی 738۔ ابوداؤد 2330)",,,9119,,
9120,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی الْبَخْتَرِیِّ ، قَالَ : خَرَجْنَا لِلْعُمْرَۃِ ، فَلَمَّا نَزَلْنَا بِبَطْنِ نَخْلَۃَ ، قَالَ : تَرَائَیْنَا الْہِلاَلَ ، قَالَ بَعْضُ الْقَوْمِ : ہُوَ ابْنُ ثَلاَثٍ ، وَقَالَ بَعْضُ الْقَوْمِ : ہُوَ ابْنُ لَیْلَتَیْنِ، فَلَقِینَا ابْنَ عَبَّاسٍ فَقُلْنَا : إنَّا رَأَیْنَا الْہِلاَلَ ، فَقَالَ بَعْضُ الْقَوْمِ : ہُوَ ابْنُ ثَلاَثٍ ، وَقَالَ بَعْضُ الْقَوْمِ : ہُوَ ابْنُ لَیْلَتَیْنِ ، فَقَالَ : أَیُّ لَیْلَۃٍ رَأَیْتُمُوہُ ؟ قَالَ : فَقُلْنَا : لَیْلَۃَ کَذَا وَکَذَا ، فَقَالَ : إنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّ اللَّہَ مَدَّہُ لِلرُّؤْیَۃِ ، فَہُوَ لِلَیْلَۃٍ رَأَیْتُمُوہُ۔ (مسلم 29۔ طبرانی 12687)",,,9120,,
9121,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : سَمِعْتُ أَبَا الْبَخْتَرِیِّ ، قَالَ : أَہْلَلْنَا رَمَضَانَ وَنَحْنُ بِذَاتِ عِرْقٍ ، فَأَرْسَلْنَا رَجُلاً إلَی ابْنِ عَبَّاسٍ یَسْأَلُہُ ؟ فَقَالَ ابْنُ عَبَّاسٍ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: إنَّ اللَّہَ قَدْ أَمَدَّہُ لِرُؤْیَتِہِ ، فَإِنْ أُغْمِیَ عَلَیْکُمْ فَأَکْمِلُوا الْعِدَّۃَ۔ (مسلم 30 احمد 1/327)",,,9121,,
9122,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ أَخْبَرَنَا مُجَالِدٌ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یَخْطُبُ إذَا حَضَرَ رَمَضَانُ فَیَقُولُ : أَلاَ لاَ تَقَدَّمُوا الشَّہْرَ ، إذَا رَأَیْتُمُ الْہِلاَلَ فَصُومُوا ، وَإِذَا رَأَیْتُمُ الْہِلاَلَ فَأَفْطِرُوا ، فَإِنْ أُغْمِیَ عَلَیْکُمْ فَأَتِمُّوا الْعِدَّۃَ ، قَالَ : کَانَ یَقُولُ ذَلِکَ بَعْدَ صَلاَۃِ الْعَصْرِ ، وَبَعْدَ صَلاَۃِ الْفَجْرِ۔",,,9122,,
9123,حَدَّثَنَا ہُشَیْمٌ ، أَخْبَرَنَا مُجَالِدٌ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، عَنْ عُمَرَ ، مِثْلَ ذَلِکَ۔,,,9123,,
9124,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ قَالاَ : نُہِیَ أَنْ یُتَقَدَّمَ بَیْنَ یَدَیْ رَمَضَانَ بِصَوْمٍ۔",,,9124,,
9125,حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، وَعَطَائٍ ؛ أَنَّہُمَا کَرِہَا التَّعْجِیلَ قَبْلَ رَمَضَانَ۔,,,9125,,
9126,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الرَّجُلِ یَصُومُ فَیَحْضُرُ رَمَضَانُ ، قَالَ : یَفْصِلُ بَیْنَہُ وَبَیْنَ رَمَضَانَ بِأَیَّامٍ۔",,,9126,,
9127,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : کَانُوا یَنْظُرُونَ إلَی الْہِلاَلِ فَإنْ رَأَوْہُ صَامُوا، وَإِنْ لَمْ یَرَوْہُ نَظَرُوا مَا یَقُولُ إمَامُہُمْ۔",,,9127,,
9128,حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أُمِّ سَلَمَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَصِلُ شَعْبَانَ بِرَمَضَانَ۔ (ترمذی 736۔ احمد 6/300),,,9128,,
9129,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَقَدَّمُوا رَمَضَانَ بِصَوْمِ یَوْمٍ ، وَلاَ یَوْمَیْنِ إِلاَّ رَجُلٌ کَانَ یَصُومُ صَوْمًا فَلْیَصُمْہُ۔ (مسلم 21۔ ترمذی 685)",,,9129,,
9130,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا کَانَ رَجُلٌ یُدِیمُ الصَّوْمَ فَلاَ بَأْسَ أَنْ یَصِلَہُ۔",,,9130,,
9131,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَلِیٍّ ، عَنِ ابْنِ عَوْنٍ ؛ أَنَّ مُحَمَّدًا تَسَحَّرَ وَہُوَ یَرَی أَنَّ عَلَیْہِ لَیْلاً ، ثُمَّ اسْتَبَانَ لَہُ أَنَّہُ تَسَحَّرَ بَعْدَ مَا أَصْبَحَ ، فَقَالَ : أَمَّا أَنَا الْیَوْمَ فَمُفْطِرٌ۔",,,9131,,
9132,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ فِیمَنْ تَسَحَّرَ وَہُوَ یَرَی أَنَّ عَلَیْہِ لَیْلاً ، فَبَانَ أَنَّہُ تَسَحَّرَ وَقَدْ طَلَعَ الْفَجْرُ ؟ فَلْیُتِمَّ صِیَامَہُ۔,,,9132,,
9133,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ عَنِ الرَّجُلِ یَتَسَحَّرُ وَہُوَ یَرَی أَنَّ عَلَیْہِ لَیْلاً ؟ قَالَ : یُتِمُّ صوَمَہُ۔",,,9133,,
9134,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حُصَیْنٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إذَا أَکَلَ بَعْدَ طُلُوعِ الْفَجْرِ مَضَی عَلَی صِیَامِہِ ، وَقَضَی یَوْمًا مَکَانَہُ۔",,,9134,,
9135,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ؛ فِی رَجُلٍ تَسَحَّرَ وَہُوَ یَرَی أَنَّ عَلَیْہِ لَیْلاً، قَالَ: یُتِمُّ صَوْمَہُ۔",,,9135,,
9136,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : یُتِمُّ صَوْمَہُ۔",,,9136,,
9137,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ أَکَلَ أَوَّلَ النَّہَارِ فَلْیَأْکُلْ آخِرَہُ۔",,,9137,,
9138,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ جَبَلَۃَ بْنِ سُحَیْمٍ ، عَنْ عَلِیِّ بْنِ حَنْظَلَۃَ ، عَنْ أَبِیہِ ، قَالَ : شَہِدْتُ عُمَرَ بْنَ الْخَطَّابِ فِی رَمَضَانَ ، وَقُرِّبَ إلَیْہِ شَرَابٌ ، فَشَرِبَ بَعْضُ الْقَوْمِ وَہُمْ یَرَوْنَ أَنَّ الشَّمْسَ قَدْ غَرَبَتْ ، ثُمَّ ارْتَقَی الْمُؤَذِّنُ ، فَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، وَاللَّہِ لَلشَّمْسُ طَالِعَۃٌ لَمْ تَغْرُبْ ، فَقَالَ عُمَرُ : مَنَعَنَا اللَّہُ مِنْ شَرِّکَ مَرَّتَیْنِ ، أَوْ ثَلاَثَۃً ، یَا ہَؤُلاَئِ ، مَنْ کَانَ أَفْطَرَ فَلْیَصُمْ یَوْمًا مَکَانَ یَوْمٍ ، وَمَنْ لَمْ یَکُنْ أَفْطَرَ فَلْیُتِمَّ حَتَّی تَغْرُبَ الشَّمْسُ۔",,,9138,,
9139,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَبَلَۃَ بْنِ سُحَیْمٍ ، عَنْ عَلِیِّ بْنِ حَنْظَلَۃَ ، عَنْ أَبِیہِ ، عَنْ عُمَرَ ، نَحْوِہِ ، إِلاَّ أَنَّ سُفْیَانَ قَالَ : إنَّا لَمْ نَبْعَثکَ رَاعِیًا ، إنَّمَا بَعَثْنَاکَ دَاعِیًا ، وَقَدِ اجْتَہَدْنَا وَقَضَائُ یَوْمٍ یَسِیرٌ۔",,,9139,,
9140,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ ، عَمَّنْ سَمِعَ بِشْرَ بْنَ قَیْسٍ ؛ أَنَّ عُمَرَ رحمہ اللہ أَمَرَہُمْ بِالْقَضَائِ۔,,,9140,,
9141,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ فَاطِمَۃَ بِنْتِ الْمُنْذِرِ ، عَنْ أَسْمَائَ ؛ أَنَّہُمْ أَفْطَرُوا عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی یَوْمِ غَیْمٍ ، ثُمَّ طَلَعَتِ الشَّمْسُ۔\n\nقَالَ أَبُو أُسَامَۃَ: فَقُلْتُ لِہِشَامٍ : فَأُمِرُوا بِالْقَضَائِ ؟ قَالَ : وَمِنْ ذَلِکَ بُدٌّ ؟ (ابوداؤد 2351۔ احمد 6/346)",,,9141,,
9142,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْن أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : یَقْضِی ، لأَنَّ اللَّہَ تَعَالَی یَقُولُ : {أَتِمُّوا الصِّیَامَ إلَی اللَّیْلِ}۔",,,9142,,
9143,حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، حَدَّثَنَا مَنْصُورُ بْنُ أَبِی الأَسْوَد ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنْ عُمَرَ ، بِنَحْوٍ مِنْ حَدِیثِ أَبِی مُعَاوِیَۃَ الَّذِی یَأْتِی۔,,,9143,,
9144,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، قَالَ : کَانَ الْحَسَنُ یَقُولُ فِیمَنْ أَفْطَرَ وَہُوَ یَرَی أَنَّ الشَّمْسَ قَدْ غَابَتْ ، ثُمَّ اسْتَبَانَ لَہُ أَنَّہَا لَمْ تَغِبْ ، قَالَ : کَانَ یَقُولُ : أَجْزَأَ عَنْہُ۔",,,9144,,
9145,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، قَالَ : أُخْرِجَتْ عِسَاسٌ مِنْ بَیْتِ حَفْصَۃَ وَعَلَی السَّمَائِ سَحَابٌ ، فَظَنُّوا أَنَّ الشَّمْسَ قَدْ غَابَتْ فَأَفْطَرُوا ، فَلَمْ یَلْبَثُوا أَنْ تَجَلَّی السَّحَابُ فَإِذَا الشَّمْسُ طَالِعَۃٌ ، فَقَالَ عُمَرُ : مَا تَجَانَفْنَا مِنْ إِثْمٍ۔",,,9145,,
9146,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ سَعِیدِ بْنِ قَطَنٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ عِنْدَ مُعَاوِیَۃَ فِی رَمَضَانَ فَأَفْطَرُوا ثُمَّ طَلَعَتِ الشَّمْسُ ، فَأَمَرَہُمْ أَنْ یَقْضُوا۔",,,9146,,
9147,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ: قُلْتُ: أَفْطَرْتُ فِی یَوْمٍ مُغَیِّمٍ فِی شَہْرِ رَمَضَانَ، وَأَنَا أَحْسِبُہُ اللَّیْلَ ، ثُمَّ بَدَتِ الشَّمْسُ ، أَفَأَقْضِی ذَلِکَ الْیَوْمَ قَطُّ ، وَلاَ أُکَفِّرُ ؟ قَالَ : نَعَمْ۔",,,9147,,
9148,"حَدَّثَنَا أَبُو أُسَامَۃَ ، حَدَّثَنَا زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : غَزَوْت مَعَ زِیَادِ بْنِ النَّضْرِ أَرْضَ الرُّومِ ، قَالَ: فَأَہْلَلْنَا رَمَضَانَ فَصَامَ النَّاسُ وَفِیہِمْ أَصْحَابُ عَبْدِ اللہِ ؛ عَامِرِ بْنِ سَعْدٍ ، وَسُمَیْعٌ ، وَأَبُو عَبْدِ اللہِ ، وَأَبُو مَعْمَرٍ ، وَأَبُو مُسَافِعٍ فَأَفْطَرَ النَّاسُ یَوْمًا وَالسَّمَائُ مُتَغَیِّمَۃٌ ، وَنَحْنُ بَیْنَ جَبَلَیْنِ ؛ الْحَارِثِ وَالْحُوَیْرِثِ ، وَلَمْ أُفْطِرْ أَنَا حَتَّی تبدّی اللَّیْل ، ثُمَّ إنَّ الشَّمْسَ خَرَجَتْ فَأَبْصَرْنَاہَا عَلَی الْجَبَلِ ، فَقَالَ زِیَادٌ : أَمَّا ہَذَا الْیَوْمُ فَسَوْفَ نَقْضِیہِ ، وَلَمْ نَتَعَمَّدْ فِطْرَہُ۔",,,9148,,
9149,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن أَخِیہِ ، عَنْ أَبِیہِ ؛ أَفْطَرَ عُمَرُ فِی شَہْرِ رَمَضَانَ فَقِیلَ لَہُ : قَدْ طَلَعَتِ الشَّمْسُ ، فَقَالَ : خَطْبٌ یَسِیرٌ ، قَدْ کُنَّا جَاہِدِینِ۔",,,9149,,
9150,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، قَالَ : جَائَ رَجُلٌ إلَی ابْنِ عَبَّاسٍ یَسْأَلُہُ عَنِ السُّحُورِ ؟ فَقَالَ لَہُ رَجُلٌ مِنْ جُلَسَائِہِ : کُلْ حَتَّی لاَ تَشُکَّ ، فَقَالَ لَہُ ابْنُ عَبَّاسٍ : إنَّ ہَذَا لاَ یَقُولُ شَیْئًا ، کُلْ مَا شَکَکْت حَتَّی لاَ تَشُکَّ۔",,,9150,,
9151,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْوَلِیدِ ، قَالَ : حدَّثَنَا عَوْنُ بْنُ عَبْدِ اللہِ ، قَالَ : دَخَلَ رَجُلاَنِ عَلَی أَبِی بَکْرٍ وَہُوَ یَتَسَحَّرُ ، فَقَالَ أَحَدُہُمَا : قَدْ طَلَعَ الْفَجْرُ ، وَقَالَ الآخَرُ : لَمْ یَطْلُعْ بَعْدُ ، قَالَ أَبُو بَکْرٍ : کُلْ قَدِ اخْتَلَفَا۔",,,9151,,
9152,حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ الْوَلِیدِ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی بَکْرٍ ، بِنَحْوِہِ۔,,,9152,,
9153,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَارَۃَ بْنِ زَاذَانَ ، عَنْ مَکْحُولٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ أَخَذَ دَلْوًا مِنْ زَمْزَمَ ، فَقَالَ لِرَجُلَیْنِ : أَطَلَعَ الْفَجْرُ ؟ فَقَالَ أَحَدُہُمَا : لاَ ، وَقَالَ الآخَرُ : نَعَمْ ، قَالَ : فَشَرِبَ۔",,,9153,,
9154,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کُلْ حَتَّی تَرَاہُ مُعْتَرِضًا۔",,,9154,,
9155,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : کُلْ حَتَّی تَرَاہُ مِثْلَ شِقِّ الطَّیْلَسَانِ۔",,,9155,,
9156,"حَدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ لِغُلاَمَیْنِ لَہُ ، وَہُوَ فِی دَارِ أُمِّ ہَانِیئٍ فِی شَہْرِ رَمَضَانَ وَہُوَ یَتَسَحَّرُ ، فَقَالَ أَحَدُہُمَا : قَدْ طَلَعَ الْفَجْرُ ، وَقَالَ الآخَرُ : لَمْ یَطْلُعْ ، قَالَ : اِسْقِیَانِی۔",,,9156,,
9157,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَر ، قَالَ : کُلْ حَتَّی یَتَبَیَّنَ لَکَ الْفَجْرُ۔",,,9157,,
9158,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ یَزِیدَ بْنِ زَیْدٍ ، قَالَ : سَمِعْتُ الْحَسَنَ وَقَالَ لَہُ رَجُلٌ : أَتَسَحَّرُ وَأَمْتَرِی فِی الصُّبْحِ ؟ فَقَالَ : کُلْ مَا امْتَرَیْت ، إِنَّہُ وَاللَّہِ لَیْسَ بِالصُّبْحِ خَفَائٌ۔",,,9158,,
9159,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْفَضْلِ بْنِ دَلْہَمٍ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ عُمَرُ : إذَا شَکَّ الرَّجُلاَنِ فِی الْفَجْرِ ، فَلْیَأْکُلاَ حَتَّی یَسْتَیْقِنَا۔",,,9159,,
9160,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنِ الأَعْمَشِ، عَنْ مُسْلِمِ بْنِ صُبَیْحٍ، قَالَ: جَائَ رَجُلٌ إلَی ابْنِ عَبَّاسٍ، فَقَالَ: مَتَی أَدَعُ السُّحُورَ ؟ فَقَالَ رَجُلٌ جَالِسٌ عِنْدَہُ : کُلْ حَتَّی إذَا شَکَکْت فَدَعْہُ ، فَقَالَ : کُلْ مَا شَکَکْت حَتَّی لاَ تَشُکَّ۔",,,9160,,
9161,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنِ ابْنِ عَوْنٍ، قَالَ: قَالَ مُحَمَّدٌ: وَضَعْتُ الإِنَائَ عَلَی یَدَیَّ، فَجَعَلْتُ أَنْظُرُ ہَلْ طَلَعَ الْفَجْرُ؟",,,9161,,
9162,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرٍو ، عَنْ عَبْدِ اللہِ بْنِ النُّعْمَانِ ، عَنْ قَیْسِ بْنِ طَلْقٍ ، قَالَ : حدَّثَنَا أَبِی طَلْقُ بْنُ عَلِیٍّ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : کُلُوا وَاشْرَبُوا ، وَلاَ یَہِیدَنَّکُمُ السَّاطِعُ الْمُصْعِدُ ، کُلُوا وَاشْرَبُوا حَتَّی یَعْتَرِضَ لَکُمُ الأَحْمَرُ ، وَقَالَ ہَکَذَا بِیَدِہِ۔ (ترمذی 705۔ ابوداؤد 2340)",,,9162,,
9163,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی ہِلاَلٍ ، قَالَ : حدَّثَنَا سَوَادَۃُ بْنُ حَنْظَلَۃَ الْہِلاَلِیُّ ، عَنْ سَمُرَۃََ بْنِ جُنْدُبٍ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَمْنَعَنَّکُمْ أَذَانُ بِلاَلٍ مِنَ السُّحُورِ ، وَلاَ الصُّبْحُ الْمُسْتَطِیلُ ، وَلَکِنِ الصُّبْحُ الْمُسْتَطِیرُ فِی الأُفُقِ۔",,,9163,,
9164,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ خَالہ ، عَنْ ثَوْبَانَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْفَجْرُ فَجْرَانِ ؛ فَأَمَّا الَّذِی کَأَنَّہُ ذَنَبُ السِّرْحَانِ ، فَإِنَّہُ لاَ یُحِلُّ شَیْئًا ، وَلاَ یُحَرِّمُہُ ، وَلَکِنِ الْمُسْتَطِیرُ۔ (دار قطنی 2۔ بیہقی 215)",,,9164,,
9165,"حَدَّثَنَا وَکِیعٌ ، عَنْ ثَابِتِ بْنِ عُمَارَۃَ ، عَنْ غُنَیْمِ بْنِ قَیْسٍ ، عَنْ أَبِی مُوسَی ، قَالَ : لَیْسَ الْفَجْرُ الَّذِی ہَکَذَا ، یَعْنِی الْمُسْتَطِیلَ ، وَلَکِنِ الْفَجْرُ الَّذِی ہَکَذَا ، یَعْنِی الْمُعْتَرِضَ۔",,,9165,,
9166,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَوْشَبِ بْنِ عَقِیلٍ ، عَنْ جَعْفَرِ بْنِ نَہَارٍ ، قَالَ : سَأَلْتُ الْقَاسِمَ : أَہُوَ السَّاطِعُ ، أَمِ الْمُعْتَرِضُ ؟ قَالَ : الْمُعْتَرِضُ ، وَالسَّاطِعُ : الصُّبْحُ الْکَاذِبُ۔",,,9166,,
9167,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : السَّاطِعُ ذَلِکَ الصُّبْحُ الْکَاذِبُ ، وَلَکِنْ إذَا انْفَضَحَ الصُّبْحُ فِی الأُفُقِ۔",,,9167,,
9168,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، قَالَ : لَمْ یَکُونُوا یَعُدُّونَ الْفَجْرَ فَجْرَکُمْ ہَذَا ، إِنَّمَا کَانُوا یَعُدُّونَ الْفَجْرَ الَّذِی یَمْلأُ الْبُیُوتَ وَالطُّرُقَ۔",,,9168,,
9169,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، قَالَ : اخْتَلَفْنَا فِی الْفَجْرِ فَأَتَیْنَا إبْرَاہِیمَ ، فَقَالَ : الْفَجْرُ فَجْرَانِ ؛ فَأَمَّا أَحَدُہُمَا فَالْفَجْرُ السَّاطِعُ فَلاَ یُحِلُّ الصَّلاَۃَ وَلاَ یُحَرِّمُ الطَّعَامَ ، وَأَمَّا الْفَجْرُ الْمُعْتَرِضُ الأَحْمَر ، فَإِنَّہُ یُحِلُّ الصَّلاَۃَ وَیُحَرِّمُ الطَّعَامَ وَالشَّرَابَ۔",,,9169,,
9170,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ عَامِرٍ، وَعَطَائٍ قَالاَ: الْفَجْرُ الْمُعْتَرِضُ الَّذِی إلَی جَنْبِہِ حُمْرَۃٌ۔",,,9170,,
9171,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : سَأَلْتُ الزُّہْرِیَّ وَمَیْمُونًا ، فَقُلْتُ : أُرِیدُ الصَّوْمَ ، فَأَرَی عَمُودَ الصُّبْحِ السَّاطِعِ ؟ فَقَالاَ جَمِیعًا : کُلْ وَاشْرَبْ حَتَّی تَرَاہُ فِی أُفُقِ السَّمَائِ مُعْتَرِضًا۔",,,9171,,
9172,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَدِیِّ بْنِ حَاتِمٍ ، قَالَ : لَمَّا نَزَلَتْ : {حَتَّی یَتَبَیَّنَ لَکُمُ الْخَیْطُ الأَبْیَضُ مِنَ الْخَیْطِ الأَسْوَد} ، قَالَ : قَالَ عَدِیٌّ : یَا رَسُولَ اللہِ ، إنِّی أَجْعَلُ تَحْتَ وِسَادَتِی عِقَالَیْنِ؛ عِقَالاً أَسْوَدَ وَعِقَالاً أَبْیَضَ ، فَأَعْرِفُ اللَّیْلَ مِنَ النَّہَارِ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ وِسَادَک لَطَوِیلٌ عَرِیضٌ ، إنَّمَا ہُوَ سَوَادُ اللَّیْلِ وَبَیَاضُ النَّہَارِ۔ (بخاری 1916۔ ابوداؤد 2341)",,,9172,,
9173,"حَدَّثَنَا مُعْتَمِرُ بْنُ إسْمَاعِیلَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الصَّائِمُ بِالْخِیَارِ ، مَا بَیْنَہُ وَبَیْنَ نِصْفِ النَّہَارِ۔",,,9173,,
9174,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنِ ابْنِ عُمَرَ قَالَ : الصَّائِمُ بِالْخِیَارِ مَا بَیْنَہُ وَبَیْنَ نِصْفِ النَّہَارِ۔",,,9174,,
9175,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : مَنْ حَدَّثَ نَفْسَہُ بِالصِّیَامِ فَہُوَ بِالْخِیَارِ ، مَا لَمْ یَتَکَلَّمْ حَتَّی یَمْتَدَّ النَّہَارُ۔",,,9175,,
9176,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا أَصْبَحْت وَأَنْتَ تُرِیدُ الصَّوْمَ فَأَنْتَ بِالْخِیَارِ ، إِنْ شِئْتَ صُمْت وَإِنْ شِئْتَ أَفْطَرْت ، إِلاَّ أَنْ تَفْرِضَ عَلَی نَفْسِکَ الصَّوْمَ مِنَ اللَّیْلِ۔",,,9176,,
9177,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ أَبِی الأَحْوَصِ ، قَالَ : قَالَ عَبْدُ اللہِ : أَحَدُکُمْ بأَحَد النَّظَرَیْنِ مَا لَمْ یَأْکُلْ ، أَوْ یَشْرَبْ۔",,,9177,,
9178,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : قُلْتُ لإبْرَاہِیمَ : الرَّجُلُ فِی صِیَامِ التَّطَوُّعِ بِالْخِیَارِ مَا بَیْنَہُ وَبَیْنَ نِصْفِ النَّہَارِ ؟ قَالَ : نَعَمْ۔",,,9178,,
9179,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الصَّائِمُ بِالْخِیَارِ مَا بَیْنَہُ وَبَیْنَ نِصْفِ النَّہَارِ ، فَإِذَا جَاوَزَ ذَلِکَ فَإِنَّمَا لَہُ بِقَدْرِ مَا بَقِیَ مِنَ النَّہَارِ۔",,,9179,,
9180,حَدَّثَنَا مُعْتَمِرٌ، عَنْ یُونُسَ، عَنِ الْحَسَنِ، فِی الصَّوْمِ؛ یُتَخَیَّرُ مَا لَمْ یُصْبِحْ صَائِمًا، فَإِذَا أَصْبَحَ صَائِمًا صَامَ۔,,,9180,,
9181,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی مَالِکٍ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الرَّجُلُ بِالْخِیَارِ مَا لَمْ یَطْعَمْ إلَی نِصْفِ النَّہَارِ ، فَإِنْ بَدَا لَہُ أَنْ یَطْعَمَ طَعِمَ ، وَإِنْ بَدَا لَہُ أَنْ یَجْعَلَہُ صَوْمًا کَانَ صَائِمًا۔",,,9181,,
9182,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یُرِیدُ الصَّوْمَ ؟ قَالَ : ہُوَ بِالْخِیَارِ إلَی نِصْفِ النَّہَارِ۔",,,9182,,
9183,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا تَسَحَّرَ الرَّجُلُ فَقَدْ وَجَبَ عَلَیْہِ الصَّوْمُ ، فَإِنْ أَفْطَرَ فَعَلَیْہِ الْقَضَائُ ، وَإِنْ ہَمَّ بِالصَّوْمِ فَہُوَ بِالْخِیَارِ ، إِنْ شَائَ صَامَ ، وَإِنْ شَائَ أَفْطَرَ ، وَإِنْ سَأَلَہُ إنْسَانٌ ، فَقَالَ: أَنْتَ صَائِمٌ ؟ فَقَالَ : نَعَمْ ، فَقَدْ وَجَبَ عَلَیْہِ الصَّوْمُ إِلاَّ أَنْ یَقُولَ إِنْ شَائَ اللَّہُ ، فَإِنْ قَالَ فَہُوَ بِالْخِیَارِ ، إِنْ شَائَ صَامَ ، وَإِنْ شَائَ أَفْطَرَ۔",,,9183,,
9184,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ طَلْحَۃَ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّ حُذَیْفَۃَ بَدَا لَہُ فِی الصَّوْمِ بَعْدَ مَا زَالَتِ الشَّمْسُ فَصَامَ۔,,,9184,,
9185,حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ خُصَیْفٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّ عَائِشَۃَ وَحَفْصَۃَ أَصْبَحَتَا صَائِمَتَیْنِ فَأَفْطَرَتَا، فَأَمَرَہُمَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِقَضَائِہِ۔,,,9185,,
9186,حَدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن عُثْمَانَ البَتِّی ، عَنْ أَنَسِ بْنِ سِیرِینَ؛ أَنَّہُ صَامَ یَوْمَ عَرَفَۃَ فَعَطِشَ عَطَشًا شَدِیدًا فَأَفْطَرَ ، فَسَأَلَ عِدَّۃً مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَأَمَرُوہُ أَنْ یَقْضِیَ یَوْمًا مَکَانَہُ۔,,,9186,,
9187,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ حَبِیبٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یَقْضِی یَوْمًا مَکَانَہُ۔",,,9187,,
9188,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بن جَابِرٍ ، قَالَ : سَأَلْتُ مَکْحُولاً عَنْ رَجُلٍ أَصْبَحَ صَائِمًا ، عَزَمَتْ عَلَیْہِ أُمُّہُ أَنْ یُفْطِرَ ؟ قَالَ : کَأَنَّہُ کَرِہَ ذَلِکَ ، وَقَالَ : یَقْضِی یَوْمًا مَکَانَہُ۔",,,9188,,
9189,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا تَسَحَّرَ الرَّجُلُ فَقَدْ وَجَبَ عَلَیْہِ الصَّوْمُ ، فَإِنْ أَفْطَرَ فَعَلَیْہِ الْقَضَائُ۔",,,9189,,
9190,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، عَنْ عَطَائٍ وَمُجَاہِدٍ ؛ أَنَّہُمَا کَانَا إذَا زَارَا رَجُلاً وَ دُعِیَا إلَی طَعَامٍ ، وَہُمَا صَائِمَانِ ، إِنْ سَأَلَہُمَا أَنْ یُفْطِرَا أَفْطَرَا ، کَانَا یَقُولاَنِ : نَقْضِی یَوْمًا مَکَانَہُ۔",,,9190,,
9191,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَن ابن أُمِّ ہَانِیئٍ ، عَن أُمِّ ہَانِیئٍ قَالَتْ : کُنْت قَاعِدَۃً عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأُتِیَ بِشَرَابٍ فَشَرِبَ مِنْہُ ، ثُمَّ نَاوَلَنِیہِ فَشَرِبْت قَالَتْ : فَقُلْتُ : یَا رَسُولَ اللہِ ، قَدْ أَذْنَبْت فَاسْتَغْفِرْ لِی ، قَالَ : وَمَا ذَاکَ ؟ قَالَتْ : کُنْت صَائِمَۃً فَأَفْطَرْت ، قَالَ : أَمِنْ قَضَائٍ کُنْت تَقْضِینَہُ ؟ قَالَتْ : لاَ ، قَالَ : لاَ یَضُرُّک۔ (ترمذی 731۔ احمد 6/343)",,,9191,,
9192,"حَدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ سِمَاکٍ، عَنْ عِکْرِمَۃَ، قَالَ: کَانَ ابْنُ عَبَّاسٍ یُفْطِرُ مِنْ صَوْمِ التَّطَوُّعِ، وَلاَ یُبَالِی۔",,,9192,,
9193,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ یُوسُفَ بْنِ مَاہَکَ الْمَکِّیِّ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ وَطِیئَ جَارِیَۃً لَہُ وَہُوَ صَائِمٌ ، قَالَ : فَقِیلَ لَہُ : وَطِئْتہَا وَأَنْتَ صَائِمٌ ؟ قَالَ : ہِیَ جَارِیَتِی أَعْجَبَتْنِی ، وَإِنَّمَا ہُوَ تَطَوُّعٌ۔",,,9193,,
9194,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ مُجَالِدٍ، عَنِ الشَّعْبِیِّ، قَالَ: کَانَ لاَ یَرَی بَأْسًا أَنْ یُصْبِحَ الرَّجُلُ صَائِمًا، ثُمَّ یُفْطِرَ",,,9194,,
9195,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ اللہِ ، عَنْ مُجَاہِدٍ ، عَنْ عَائِشَۃَ قَالَتْ : رُبَّمَا أُہْدِیَتْ لَنَا الطَّرْفَۃُ ، فَنَقُولُ : لَوْلاَ صَوْمُک قَرَّبْنَاہَا إلَیْکَ ، فَیَدْعُو بِہَا فَنُفْطِرُ عَلَیْہَا۔",,,9195,,
9196,"حَدَّثَنَا عَبِیْدَۃُ ، عَنْ أَبِی مِسْکِینٍ ، قَالَ : کَانَ إبْرَاہِیمُ وَسَعِیدُ بْنُ جُبَیْرٍ فِی دَعْوَۃٍ ، فَقَالَ سَعِیدٌ : إنِّی کُنْت حَدَّثَتْنِی نَفْسِی بِالصَّوْمِ ، ثُمَّ أَکل ۔ وَقَالَ إبْرَاہِیمُ : مَا یُعْجِبُنِی۔",,,9196,,
9197,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَیَانٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَصْبَحَ وَہُوَ صَائِمٌ فَلاَ یُفْطِرُ۔",,,9197,,
9198,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ اللہِ ، عَنْ مُجَاہِدٍ ، عَنْ عَائِشَۃَ قَالَتْ : رُبَّمَا دَعَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِغَدَائِہِ فَلاَ یَجِدُہُ ، فَیَفْرِضُ عَلَیْہِ صَوْمَ ذَلِکَ الْیَوْمَ۔",,,9198,,
9199,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، عَنْ أُمِّ الدَّرْدَائِ ، عَنْ أَبِی الدَّرْدَائِ ؛ أَنَّہُ کَانَ رُبَّمَا دَعَا بِالْغَدَائِ فَلاَ یَجِدُہُ ، فَیَفْرِضُ الصَّوْمَ عَلَیْہِ ذَلِکَ الْیَوْمَ۔,,,9199,,
9200,"حَدَّثَنَا الثَّقَفِیُّ ، وَیَزِیدُ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّ أَبَا طَلْحَۃَ کَانَ یَأْتِی أَہْلَہُ فَیَقُولُ : ہَلْ عِنْدَکُمْ مِنْ غَدَائٍ ؟ فَإِنْ قَالُوا لاَ ، قَالَ : فَإِنِّی صَائِمٌ ۔ زَادَ الثَّقَفِیُّ : إِنْ کَانَ عِنْدَہُمْ أَفْطَرَ۔",,,9200,,
9201,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنِ الْعَلاَئِ بْنِ الْحَارِثِ ، عَنْ مُعَاذٍ ؛ أَنَّہُ کَانَ یَأْتِی أَہْلَہُ بَعْدَ الزَّوَالِ فَیَقُولُ : عِنْدَکُمْ غَدَائٌ ؟ فَیَعْتَذِرُونَ إلَیْہِ ، فَیَقُولُ : إنِّی صَائِمٌ بَقِیَّۃَ یَوْمِی ، فَیُقَالُ لَہُ : تَصُومُ آخِرَ النَّہَارِ! فَیَقُولُ : مَنْ لَمْ یَصُمْ آخِرَہُ ، لَمْ یَصُمْ أَوَّلَہُ۔",,,9201,,
9202,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أُمِّ الدَّرْدَائِ قَالَتْ : کَانَ أَبُو الدَّرْدَائِ یَغْدُو أَحْیَانًا، فَیَجِیئُ فَیَسْأَلُ الْغَدَائَ ، فَرُبَّمَا لَمْ یُوَافِقْہُ عِنْدَنَا ، فَیَقُولُ : إنِّی إذًا صَائِمٌ۔",,,9202,,
9203,"حَدَّثَنَا الْفَضْلُ ، عَنْ أَبِی قَحْذَمٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الأَشْعَثِ ، قَالَ : کَانَ مُعَاذٌ یَأْتِی أَہْلَہُ بَعْدَ مَا یُضْحی فَیَسْأَلُہُمْ فَیَقُولُ : عِنْدَکُمْ شَیْئٌ ؟ فَإِذَا قَالُوا لاَ ، صَامَ ذَلِکَ الْیَوْمَ۔",,,9203,,
9204,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ إِسْحَاقَ بْنِ حَازِمٍ ، قَالَ : حدَّثَنِی عَبْدُ اللہِ بْنُ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ حَزْمٍ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، عَنْ حَفْصَۃَ قَالَتْ ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ صِیَامَ لِمَنْ لَمْ یُوَرِّضْہُ بِاللَّیْلِ۔ (ترمذی 730۔ ابوداؤد 2446)",,,9204,,
9205,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ حَمْزَۃَ بْنِ عَبْدِ اللہِ بْنِ عُمَرَ ، عَنْ حَفْصَۃَ ، أَنَّہَا قَالَتْ : لاَ صِیَامَ لِمَنْ لَمْ یُجْمِعِ الصِّیَامَ قَبْلَ الْفَجْرِ۔",,,9205,,
9206,"حَدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ الطَّائِفِیُّ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، عَنْ مُحَمَّدِ بْنِ الْمُنْکَدِرِ ، قَالَ : بَلَغَنِی أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ عَنْ تَقْطِیعِ قَضَائِ رَمَضَانَ ؟ فَقَالَ : ذَاکَ إلَیْک ، فَقَالَ : أَرَأَیْت لَوْ کَانَ عَلَی أَحَدِکُمْ دَیْنٌ ، فَقَضَی الدِّرْہَمَ وَالدِّرْہَمَیْنِ ، أَلَمْ یَکُ قَضَی ؟ وَاللَّہُ أَحَقّ أَنْ یَعْفُوَ وَیَغْفِرَ۔ (دارقطنی 77)",,,9206,,
9207,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، وَأَبِی ہُرَیْرَۃَ قَالاَ : لاَ بَأْسَ بِقَضَائِ رَمَضَانَ مُتَفَرِّقًا۔",,,9207,,
9208,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ، عَنْ أَبِیہِ، قَالَ: أَنْبَأَنِی بَکْرٌ ، عَنْ أَنَسٍ ، قَالَ : إِنْ شِئْتَ فَاقْضِ رَمَضَانَ مُتَتَابِعًا، وَإِنْ شِئْتَ مُتَفَرِّقًا۔",,,9208,,
9209,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ عَطَائٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ؛ فِی قَضَائِ رَمَضَانَ ، قَالَ : إِنْ شَائَ فَرَّقَ۔",,,9209,,
9210,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنِ ابْنِ مُحَیْرِیزٍ ، أَنَّہُ قَالَ فِی قَضَائِ رَمَضَانَ ، قَالَ : أَحْصِ الْعِدَّۃَ ، وَصُمْ کَیْفَ شِئْت۔",,,9210,,
9211,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنْ مُوسَی بْنِ یَزِیدَ بْنِ مَوْہَبٍ ، عَنْ أَبِیہِ ، عَنْ مَالِکِ بْنِ یُخَامِرَ ، عَنْ مُعَاذِ بْنِ جَبَلٍ ؛ أَنَّہُ سُئِلَ عَنْ قَضَائِ رَمَضَانَ ؟ فَقَالَ : أَحْصِ الْعِدَّۃَ ، وَصُمْ کَیْفَ شِئْت۔",,,9211,,
9212,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ رَافِعِ بْنِ خَدِیجٍ ، عَنْ جَدَّتِہِ ، أَنَّ رَافِعًا کَانَ یَقُولُ : أَحْصِ الْعِدَّۃَ وَصُمْ کَیْفَ شِئْت۔",,,9212,,
9213,"حَدَّثَنَا مُعَمَّرُ بْنُ سُلَیْمَانَ الرَّقِّیُّ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : جَائَتِ امْرَأَۃٌ إلَی ابْنِ عَبَّاسٍ تسْأَلُہُ عَنْ قَضَائِ صِیَامِ رَمَضَانَ ؟ فَقَالَ : أَحْصِی الْعِدَّۃَ وَفَرِّقِی ، قَالَ : وَکَانَ سَعِیدُ بْنُ جُبَیْرٍ وَعِکْرِمَۃُ یَقُولاَنِ ذَلِکَ",,,9213,,
9214,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَمُجَاہِدٍ ، وَطَاوُسٍ ، وَسَعِیدِ بْنِ جُبَیْرٍ قَالُوا : إِنْ شِئْتَ فَاقْضِ رَمَضَانَ مُتَتَابِعًا ، أَوْ مُتَفَرِّقًا۔",,,9214,,
9215,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، وَعَطَائٍ ، وَمُجَاہِدٍ ، وَطَاوُسٍ ؛ أَنَّہُمْ کَانُوا لاَ یَرَوْنَ بَأْسًا بِتَفْرِیقِ قَضَائِ رَمَضَانَ,,,9215,,
9216,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مُجَاہِدٍ ؛ فِی الرَّجُلِ یَکُونُ عَلَیْہِ صَوْمٌ مِنْ رَمَضَانَ ، فَیُفَرِّقُ صِیَامَہُ ، أَوْ یَصِلُہُ ، قَالَ : إنَّ اللَّہَ أَرَادَ بِعِبَادِہِ الْیُسْرَ ، فَلْیَنْظُرْ أَیْسَرَ ذَلِکَ عَلَیْہِ ، إِنْ شَائَ وَصَلَہُ ، وَإِنْ شَائَ فَرَّقَ۔",,,9216,,
9217,حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ زُہَیْرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ زُہَیْرٍ مِنْ أَصْحَابِ أَبِی مَیْسَرَۃَ ؛ أَنَّ أَبَا مَیْسَرَۃَ کَانَ یُقَطِّعُ قَضَائَ رَمَضَانَ۔,,,9217,,
9218,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِنْ شَقَّ عَلَیْک أَنْ تَقْضِیَ مُتَتَابِعًا ، فَرِّقْ فَإنَّمَا ہِیَ عِدَّۃٌ مِنْ أَیَّامٍ أُخَرَ۔",,,9218,,
9219,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنْ عِکْرِمَۃَ ؛ {فَعِدَّۃٌ مِنْ أَیَّامٍ أُخَرَ} ، قَالَ : إِنْ شَائَ وَصَلَ ، وَإِنْ شَائَ فَرَّقَ۔",,,9219,,
9220,"حَدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ، قَالَ : کَانَ لاَ یَرَی بِقَضَائِ رَمَضَانَ مُتَقَطِّعًا بَأْسًا۔",,,9220,,
9221,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ؛ فِی قَضَائِ رَمَضَانَ ، إِنْ شِئْتَ مُتَتَابِعًا ، وَإِنْ شِئْتَ مُتَفَرِّقًا۔,,,9221,,
9222,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ مَیْمُونٍ ، قَالَ : قَضَائُ رَمَضَانَ عِدَّۃٌ مِنْ أَیَّامٍ أُخَرَ۔",,,9222,,
9223,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إسْمَاعِیلَ الْمَکِّیِّ ، عَنْ رَبِیعَۃَ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، قَالَ : لاَ بَأْسَ أَنْ یُفرّق قَضَاء رَمَضَانَ۔",,,9223,,
9224,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی قَضَائِ رَمَضَانَ ، صُمْہُ کَیْفَ شِئْت ، وَقَالَ ابْنُ عُمَرَ : صُمْہُ کَمَا أَفْطَرْتہ۔",,,9224,,
9225,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ، حَدَّثَنِی مُعَاوِیَۃُ بْنُ صَالِحٍ، حَدَّثَنَا أَزْہَرُ بْنُ سَعِیدٍ، عَنْ أَبِی عَامِرٍ الْہَوْزَنِیِّ، قَالَ: سَمِعْتُ أَبَا عُبَیْدَۃَ بْنَ الْجَرَّاحِ ، وَسُئِلَ عَنْ قَضَائِ رَمَضَانَ مُتَفَرِّقًا ؟ قَالَ : أَحْصِ الْعِدَّۃَ ، وَصُمْ کَیْفَ شِئْت۔",,,9225,,
9226,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ فِی قَضَائِ رَمَضَانَ : یُتَابِعُ بَیْنَہُ۔",,,9226,,
9227,حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَأْمُرُ بِقَضَائِ رَمَضَانَ مُتَتَابِعًا۔,,,9227,,
9228,"حَدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ، قَالَ: مَنْ کَانَ عَلَیْہِ صَوْمٌ مِنْ رَمَضَانَ، فَلْیَصُمْہُ مُتَّصِلاً ، وَلاَ یُفَرِّقْہُ۔",,,9228,,
9229,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : یُواتِر قَضَاء رَمَضَانَ۔",,,9229,,
9230,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، أَنَّہُ قَالَ : لاَ یَقْطَعُہُ إذَا کَانَ صَحِیحًا۔",,,9230,,
9231,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَقُولُونَ : قَضَاء رَمَضَانَ تِبَاعًا۔",,,9231,,
9232,"حَدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : یَقْضِیہ کَہَیْئَتِہِ۔",,,9232,,
9233,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ الْحَسَنُ یُحِبُّ أَنْ یُتَابَعَ بَیْنَ قَضَائِ رَمَضَانَ۔",,,9233,,
9234,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَحَبُّ إلَیَّ أَنْ یَقْضِیَہُ کَمَا أَفْطَرَہُ۔",,,9234,,
9235,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ فِی قَضَائِ رَمَضَانَ : أَحَبَّ إلَیَّ أَنْ یَصُومَہُ کَمَا أَفْطَرَہُ۔",,,9235,,
9236,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ الْحَکَمِ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عُقْبَۃَ بْنِ الْحَارِثِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : یُوَاتِرُہُ إِنْ شَائَ۔",,,9236,,
9237,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : سَأَلْتُہُ عَنْ قَضَائِ رَمَضَانَ ؟ قَالَ : مُتَتَابِعٌ أَحَبَّ إلَیَّ۔",,,9237,,
9238,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : صُمْہُ مُتَتَابِعًا إِلاَّ أَنْ یُقْطَعَ بِکَ کَمَا قَطَعَ بِکَ فِیہِ۔",,,9238,,
9239,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ عَطَائٍ ، قَالَ : یَقْضِیہ مُتَتَابِعًا أَحَبَّ إلَیَّ، وَإِنْ فَرَّقَ أَجْزَأَہُ",,,9239,,
9240,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَاصِمٍ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرِ بْنِ رَبِیعَۃَ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْتَاکُ وَہُوَ صَائِمٌ۔ (ابوداؤد 2356۔ دارقطنی 2)",,,9240,,
9241,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ لَمْ یَکُنْ یَرَی بَأْسًا بِالسِّوَاکِ لِلصَّائِمِ۔,,,9241,,
9242,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، وَسُفْیَانَ ، عَنْ أَبِی نَہِیکٍ ، عَنْ زِیَادِ بْنِ حُدَیْرٍ ، قَالَ : مَا رَأَیْت أَحَدًا أَدْوَمَ سِوَاکًا وَہُوَ صَائِمٌ مِنْ عُمَرَ بْنِ الْخَطَّابِ۔",,,9242,,
9243,حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ أَبِی نَہِیکٍ ، عَنْ زِیَادِ بْنِ حُدَیْرٍ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ رَضِیَ اللَّہُ عَنْہُ ، بِنَحْوِہِ۔,,,9243,,
9244,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَدَّادِ أَبِی طَلْحَۃَ ، عَنِ امْرَأَۃٍ مِنْہُمْ یُقَالُ لَہَا : کَبْشَۃُ قَالَتْ : جِئْت إلَی عَائِشَۃَ فَسَأَلْت عَنِ السِّوَاکِ لِلصَّائِمِ ؟ قَالَتْ : ہَذَا سِوَاکِی فِی یَدِی وَأَنَا صَائِمَۃٌ۔",,,9244,,
9245,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ عَبْدِ الْجَلِیلِ ، قَالَ : حدَّثَنِی شَہْرُ بْنُ حَوْشَبٍ ، قَالَ : سُئِلَ ابْنُ عَبَّاسٍ عَنِ السِّوَاکِ لِلصَّائِمِ ؟ فَقَالَ : نِعْمَ الطَّہُورُ ، اسْتَکْ عَلَی کُلِّ حَالٍ۔",,,9245,,
9246,حَدَّثَنَا ابْنُ الْمُبَارَک ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَسْتَاکُ مَرَّتَیْنِ ، غَدْوَۃً وَعَشِیَّۃً وَہُوَ صَائِمٌ۔,,,9246,,
9247,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، عَنْ عَطَائٍ ، قَالَ : اسْتَکْ أَوَّلَ النَّہَارِ ، وَلاَ تَسْتَکْ آخِرَہُ إذَا کُنْتَ صَائِمًا ، قُلْتُ : لِمَ لاَ أَسْتَاکُ فِی آخِرِ النَّہَارِ ؟ قَالَ : إنَّ خُلُوفَ الصَّائِمِ أَطْیَبُ عِنْدَ اللہِ مِنْ رِیحِ الْمِسْکِ۔",,,9247,,
9248,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یَسْتَاکُ مِنْ أَوَّلِ النَّہَارِ ، وَیَکْرَہہُ مِنْ آخِرِہِ۔",,,9248,,
9249,حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَسْتَاکُ إذَا أَرَادَ أَنْ یَدفع إلَی الظُّہْرِ وَہُوَ صَائِمٌ۔,,,9249,,
9250,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالسِّوَاکِ لِلصَّائِمِ",,,9250,,
9251,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حُصَیْنٍ ، عَنْ سَالِمٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِالسِّوَاکِ لِلصَّائِمِ ، إِلاَّ عِنْدَ اصْفِرَارِ الشَّمْسِ۔,,,9251,,
9252,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَرِہَ السِّوَاکَ لِلصَّائِمِ بَعْدَ الظُّہْرِ۔,,,9252,,
9253,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یَسْتَاکُ الصَّائِمُ أَیَّ النَّہَارِ شَائَ۔",,,9253,,
9254,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ بَشِیرٍ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّہُ سُئِلَ عَنِ السِّوَاکِ لِلصَّائِمِ ، فَقَالَ: أدْمَیْت فَمِی الْیَوْمَ مَرَّتَیْنِ۔",,,9254,,
9255,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِالسِّوَاکِ لِلصَّائِمِ مِنْ أَوَّلِ النَّہَارِ ، وَقَالَ : إنَّمَا کُرِہَ لَہُ آخِرَ النَّہَارِ ، بَعْدَ مَا یَخلف فُوہُ یستحب أَنْ یَرْجِعَ فِی جَوْفِہِ۔",,,9255,,
9256,"حَدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، قَالَ : سُئِلَ سَعِیدُ بْنُ الْمُسَیَّبِ عَنِ السِّوَاکِ لِلصَّائِمِ؟ فَقَالَ: لاَ بَأْسَ بِہِ۔",,,9256,,
9257,حَدَّثَنَا أَبُو مُعَاوِیَۃَ، وَوَکِیعٍ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ أَبِیہِ؛ أَنَّہُ کَانَ یَسْتَاکُ بِالسِّوَاکِ الرَّطْبِ وَہُوَ صَائِمٌ۔,,,9257,,
9258,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ بِالسِّوَاکِ الرَّطْبِ لِلصَّائِمِ۔",,,9258,,
9259,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ بِالسِّوَاکِ الرَّطْبِ لِلصَّائِمِ",,,9259,,
9260,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِالسِّوَاکِ الرَّطْبِ وَہُوَ صَائِمٌ۔,,,9260,,
9261,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِالسِّوَاکِ الرَّطْبِ لِلصَّائِمِ۔",,,9261,,
9262,"حَدَّثَنَا عُبَیْدُ بْنُ سَہْلٍ الْغُدَّانِیُّ ، عَنْ عُقْبَۃَ بْنِ أَبِی جَسْرۃ الْمَازِنِیِّ ، قَالَ : أَتَی ابْنَ سِیرِینَ رَجُلٌ ، فَقَالَ: مَا تَرَی فِی السِّوَاکِ لِلصَّائِمِ؟ قَالَ: لاَ بَأْسَ بِہِ، قَالَ: إِنَّہُ جَرِیدَۃٌ وَلَہُ طَعْمٌ، قَالَ: وَالْمَائُ لَہُ طَعْمٌ وَأَنْتَ تَمَضْمَضُ۔",,,9262,,
9263,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ؟ قَالَ : لاَ بَأْسَ أَنْ یَسْتَاکَ بِالْعُودِ الرَّطْبِ وَہُوَ صَائِمٌ۔",,,9263,,
9264,"حَدَّثَنَا عَلِیُّ بْنُ الْحَسَنِ بْنِ شَقِیقٍ ، أَخْبَرَنَا أَبُو حَمْزَۃَ ، عَنْ إبْرَاہِیمَ الصَّائِغِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ بَأْسَ أَنْ یَسْتَاکَ الصَّائِمُ بِالسِّوَاکِ الرَّطْبِ وَالْیَابِسِ۔",,,9264,,
9265,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ ، عَنِ الضَّحَّاکِ ؛ أَنَّہُ کَرِہَہُ وَقَالَ : ہُوَ حُلْوٌ وَمُرٌّ۔",,,9265,,
9266,حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنِ الْحَکَمِ ؛ أَنَّہُ کَرِہَ السِّوَاکَ الرَّطْبَ لِلصَّائِمِ۔,,,9266,,
9267,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، وَابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ، عَنْ أَبِی مَیْسَرَۃَ؛ أَنَّہُ کَرِہَ السِّوَاکَ الرَّطْبَ لِلصَّائِمِ۔,,,9267,,
9268,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ کَانَ یَابِسًا فَبُلَّہُ۔",,,9268,,
9269,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : یَسْتَاکُ ، وَلاَ یَبُلُّہُ۔",,,9269,,
9270,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ رَخَّصَ فِی مَضْغِ الْعِلْکِ لِلصَّائِمِ ، مَا لَمْ یدخل حَلْقَہُ۔,,,9270,,
9271,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ بَأْسَ بِالْعِلْکِ لِلصَّائِمِ مَا لَمْ یَبْلَعْ رِیقَہُ۔",,,9271,,
9272,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَتْ عَائِشَۃُ لاَ تَرَی بَأْسًا فِی مَضْغِ الْعِلْکِ لِلصَّائِمِ ، إِلاَّ الْقَارَ ، وَکَانَتْ تُرَخِّصُ فِی الْقَارِ وَحْدَہُ۔",,,9272,,
9273,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیِّ ، عَنْ زَائِدَۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَمْضُغَ الصَّائِمُ الْعِلْکَ ، وَلاَ یَبْلَعُ رِیقَہُ۔",,,9273,,
9274,حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَرِہَہ لِلصَّائِمِ۔,,,9274,,
9275,حَدَّثَنَا حُمَیْدٌ بْنُ عَبْدِالرَّحْمَنِ، عَنْ حَسَنٍ، عَنْ عِیسَی، عَنِ الشَّعْبِیِّ؛ أَنَّہُ کَرِہَ لِلصَّائِمِ أَنْ یَمْضُغَ الْعلکَ۔,,,9275,,
9276,"حَدَّثَنَا أَبُو خَالِد الأَحْمَرِِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَہُ ، وَقَالَ : ہُوَ مَرْوَاۃٌ۔",,,9276,,
9277,حَدَّثَنَا وَکِیعٌ ، عَنْ أبِی عَبْدِ الْمَلِکِ ، رَجُلٌ مِنْ أَہْلِ الشَّامِ ، عَنْ رَجُلٍ قَدْ سَمَّاہُ ، عَنْ أَبِیہِ ، عَنْ أُمِّ حَبِیبَۃَ زَوْجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہَا کَرِہَتْ مَضْغَ الْعلکِ لِلصَّائِمِ۔,,,9277,,
9278,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا ذَرَعَہُ الْقَیْئُ فَلَیْسَ عَلَیْہِ الْقَضَائُ ، وَإِذَا اسْتَقَائَ فَعَلَیْہِ الْقَضَائُ۔",,,9278,,
9279,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَقُولُ : مَنْ ذَرَعَہُ الْقَیْئُ وَہُوَ صَائِمٌ فَلاَ یُفْطِرْ ، وَمَنْ تَقَیَّأَ فَقَدْ أَفْطَرَ۔",,,9279,,
9280,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَنْ جَدِّہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا اسْتَقَائَ الصَّائِمُ أَعَادَ۔ (ابوداؤد 2372۔ احمد 2/498)",,,9280,,
9281,"حَدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ قَالاَ : إذَا ذرَعَ الصَّائِمَ الْقَیْئُ فَلاَ یُفْطِرُ، وَإِذَا تَقَیَّأَ أَفْطَرَ۔",,,9281,,
9282,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الصَّائِمِ یَقِیئُ ، قَالَ : إِنْ کَانَ اسْتَقَائَ فَعَلَیْہِ أَنْ یَقْضِیَ ، وَإِنْ کَانَ ذَرَعَہُ فَلَیْسَ عَلَیْہِ أَنْ یَقْضِیَ۔",,,9282,,
9283,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا ذَرَعَہُ الْقَیْئُ فَلاَ إعَادَۃَ عَلَیْہِ ، وَإِنْ تَہَوَّعَ فَعَلَیْہِ الإِعَادَۃُ۔",,,9283,,
9284,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَبَّانَ السُّلَمِیِّ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، قَالَ: الصَّائِمُ إذَا ذَرَعَہُ الْقَیْئُ فَلَیْسَ عَلَیْہِ الْقَضَائُ ، وَإِنْ قَائَ مُتَعَمِّدًا فَعَلَیْہِ الْقَضَائُ۔",,,9284,,
9285,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَید ، عَنْ یَعْقُوبَ بْنِ قَیْسٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الرَّجُلِ یَسْبِقُہُ الْقَیْئُ وَہُوَ صَائِمٌ ، أَیَقْضِی ذَلِکَ الْیَوْمَ ؟ قَالَ : لاَ۔",,,9285,,
9286,حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ ؛ إذَا تَقَیَّأَ مُتَعَمِّدًا فَقَدْ أَفْطَرَ۔,,,9286,,
9287,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرِ ، عَنْ طَلْحَۃَ ، عَنِ الضَّحَّاکِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا تَقَیَّأَ الصَّائِمُ فَقَدْ أَفْطَرَ۔",,,9287,,
9288,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : إذَا تَقَیَّأَ الرَّجُلُ وَہُوَ صَائِمٌ فَعَلَیْہِ الْقَضَائُ ، وَإِنْ ذَرَعَہُ الْقَیْئُ فَلَیْسَ عَلَیْہِ الْقَضَائُ۔",,,9288,,
9289,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ إسْمَاعِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا تَقَیَّأَ الصَّائِمُ مُتَعَمِّدًا أَفْطَرَ ، وَإِذَا ذَرَعَہُ الْقَیْئُ فَلاَ شَیْئَ عَلَیْہِ۔",,,9289,,
9290,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، مِثْلَہُ۔,,,9290,,
9291,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی الْجَوْدِیِّ ، عَنْ بَلْجٍ الْمَہْرِیِّ ، عَنْ أَبِی شَیْبَۃَ الْمَہْرِیِّ ، قَالَ : قِیلَ لِثَوْبَانَ : حَدِّثْنَا عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَائَ فَأَفْطَرَ۔ (احمد 283۔ طحاوی 96)",,,9291,,
9292,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ یعیش بْنِ الْوَلِیدِ بْنِ ہِشَامٍ، أَنَّ مَعْدَانَ أَخْبَرَہُ ، أَنَّ أَبَا الدَّرْدَائِ أَخْبَرَہُ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَائَ فَأَفْطَرَ ، قَالَ : فَلَقِیتُ ثَوْبَانَ ، فَقَالَ : أَنَا صَبَبْت لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَضُوئَہُ۔ (ترمذی 87۔ ابوداؤد 2373)",,,9292,,
9293,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : الإِفْطَارُ مِمَّا دَخَلَ ، وَلَیْسَ مِمَّا خَرَجَ۔",,,9293,,
9294,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، قَالَ : سُئِلَ عَامِرٌ عَنِ الصَّائِمِ یَقِیئُ ؟ قَالَ : إذَا فَجَأَہُ الْقَیْئُ فَلاَ یَقْضِی ، وَإِنْ کَانَ تَقَیَّأَ عَمْدًا فَقَدْ أَفْطَرَ۔",,,9294,,
9295,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، قَالَ : قَالَ أَبُو ہُرَیْرَۃَ : إذَا أَفْطَرَ الصَّائِمُ فَتَمَضْمَضَ ، فَلاَ یَمُجَّہُ ، وَلَکِنْ یَستَرطُہ۔",,,9295,,
9296,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَن ذَلِکَ ؟ فَقَالَ : لاَ بَأْسَ بِہِ أَنْ یَمُجَّہُ۔",,,9296,,
9297,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنْ عَطَائٍ ، قَالَ : قَالَ عُمَرُ رضی اللَّہُ عَنْہُ : لاَ تَزَالُ ہَذِہِ الأُمَّۃُ بِخَیْرٍ مَا عَجَّلُوا الْفِطْرَ ، فَإِذَا کَانَ یَوْمُ صَوْمِ أَحَدِکُمْ فَمَضْمَضَ فَلاَ یَمُجَّہُ ، وَلَکِنْ لِیَشْرَبْہُ ، فَإِنَّ خَیْرَہُ أَوَّلُہُ۔",,,9297,,
9298,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُمَضْمضَ عِنْدَ الإِفْطَارِ۔,,,9298,,
9299,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ بَأْسَ بِالْمَضْمَضَۃِ عِنْدَ الإِفْطَارِ۔",,,9299,,
9300,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُمَضْمضَ الرَّجُلُ إذَا أَفْطَرَ ، إذَا أَرَادَ أَنْ یَشْرَبَ,,,9300,,
9301,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ أَنَّہُ سُئِلَ عَنِ الصَّائِمِ یُمَضْمِضَ ؟ فَکَرِہَ ذَلِکَ۔,,,9301,,
9302,حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ مَالِکِ بْنِ مِغْوَلٍ، عَنْ أَبِی إِسْحَاقَ، عَنِ الشعبی؛ أَنَّہُ کَرِہَ لِلصَّائِمِ أَنْ یُمَضْمِضَ۔,,,9302,,
9303,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی عُثْمَانَ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ وَہُوَ صَائِمٌ یَبُلُّ الثَّوْبَ ، ثُمَّ یُلْقِیہِ عَلَیْہِ",,,9303,,
9304,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُکْرَہُ لِلصَّائِمِ أَنْ یَنْضَحَ فِرَاشَہُ بِالْمَائِ ، ثُمَّ یَنَامَ عَلَیْہِ۔",,,9304,,
9305,"حَدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ ابْنُ سِیرِینَ لاَ یَرَی بَأْسًا أَنْ یَبُلَّ الثَّوْبَ ، ثُمَّ یُلْقِیَہُ عَلَی وَجْہِہِ۔",,,9305,,
9306,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُثْمَانَ بْنِ أَبِی الْعَاصِ ؛ أَنَّہُ کَانَ یَصُبُّ عَلَیْہِ الْمَائَ ، وَیُرَوِّحُ عَنْہُ وَہُوَ صَائِمٌ عَشِیَّۃَ عَرَفَۃَ ، أَوْ یَوْمَ عَرَفَۃَ۔,,,9306,,
9307,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : رَأَیْتُ عَبْدَ الرَّحْمَن بْنَ الأَسْوَد یَنْقَعُ رِجْلَیْہِ فِی الْمَائِ وَہُوَ صَائِمٌ۔",,,9307,,
9308,حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ سُمَیٍّ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ ، عَنْ رَجُلٍ رَأَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَصُبُّ عَلَی رَأْسِہِ الْمَائَ وَہُوَ صَائِمٌ ، فِی یَوْمٍ صَائِفٍ۔ (ابوداؤد 2357۔ احمد 3/43),,,9308,,
9309,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُکْرَہُ لِلصَّائِمِ أَنْ یَبُلَّ ثَوْبَہُ بِالْمَائِ ، ثُمَّ یَلْبَسَہُ۔",,,9309,,
9310,حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَمْ یَصُمِ الْعَشْرَ قَطُّ۔,,,9310,,
9311,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَد ، عَنْ عَائِشَۃَ قَالَتْ : مَا رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَامَ الْعَشْرَ قَطُّ۔ (مسلم 10۔ ابوداؤد 2431)",,,9311,,
9312,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یَصُومُ الْعَشْرَ ، عَشْرَ ذِی الْحِجَّۃِ کُلِّہِ ، فَإِذَا مَضَی الْعَشْرُ وَمَضَتْ أَیَّامُ التَّشْرِیقِ ، أَفْطَرَ تِسْعَۃَ أَیَّامٍ مِثْلَ مَا صَامَ۔",,,9312,,
9313,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ لَیْثٍ ، قَالَ : کَانَ مُجَاہِدٌ یَصُومُ الْعَشْرَ ، قَالَ : وَکَانَ عَطَائٌ یَتَکَلَّفُہَا۔",,,9313,,
9314,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ النُّعْمَانِ بْنِ سَعْدٍ ، قَالَ : أَتَی عَلِیًّا رَجُلٌ ، فَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، أَخْبِرْنِی بِشَہْرٍ أَصُومُہُ بَعْدَ رَمَضَانَ ، فَقَالَ : لَقَدْ سَأَلْتنِی عَنْ شَیْئٍ مَا سَمِعْت أَحَدًا یَسْأَلُ عَنْہُ، بَعْدَ رَجُلٍ سَمِعْتُہُ یَسْأَلُ عَنْہُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ لَہُ : إِنْ کُنْت صَائِمًا شَہْرًا بَعْدَ رَمَضَانَ فَصُمِ الْمُحَرَّمَ ، فَإِنَّہُ شَہْرُ اللہِ ، وَفِیہِ یَوْمٌ تَابَ فِیہِ قَوْمٌ ، وَیُتَابُ فِیہِ عَلَی آخَرِینَ۔ (ترمذی 741۔ دارمی 1756)",,,9314,,
9315,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَصُومُ أَشْہُرَ الْحُرُمِ۔,,,9315,,
9316,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ خَالِدِ بْنِ أَبِی عُثْمَانَ ، عَنْ أَیُّوبَ ، عَنْ عَبْدِ اللہِ بْنِ یَسَارٍ ، وَسَلِیطٍ أَخِیہِ قَالاَ : کَانَ ابْنُ عُمَرَ بِمَکَّۃَ یَصُومُ أَشْہُرَ الْحُرُمِ۔",,,9316,,
9317,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ الْحِمْیَرِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، أَیُّ الصِّیَامِ أَفْضَلُ بَعْدَ رَمَضَانَ ؟ فَقَالَ : شَہْرُ اللہِ الَّذِی تَدْعُونَہُ الْمُحَرَّمَ۔ (مسلم 203۔ ابوداؤد 2421)",,,9317,,
9318,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِیہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَصُومُ الاِثْنَیْن وَالْخَمِیسَ۔,,,9318,,
9319,حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَاصِمٍ ، عَنِ الْمُسَیَّبِ ، عَنْ حَفْصَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَصُومُ الاِثْنَیْن وَالْخَمِیس۔ (ابوداؤد 2443۔ احمد 6/287),,,9319,,
9320,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سُلَیْمَانَ الْعَبْسِیِّ ، عَنْ مُجَاہِدٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَصُومُ الاِثْنَیْن وَالْخَمِیسَ۔,,,9320,,
9321,"حَدَّثَنَا عُثْمَانُ بْنُ مَطَر ، عَنْ ثَابِتٍ الْبُنَانِیِّ ، عَنْ أَبِی عُقْبَۃَ ، قَالَ: کَانَ أَبُو ہُرَیْرَۃَ یَصُومُ الاِثْنَیْن وَالْخَمِیسَ۔",,,9321,,
9322,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ کَانَ یَصُومُ الاِثْنَیْن وَالْخَمِیسَ۔,,,9322,,
9323,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : سَأَلْتُہُ عَنْ صَوْمِ الاِثْنَیْنِ وَالْخَمِیسِ ؟ فَقَالَ : لاَ أَعْلَمُ بِہِ بَأْسًا۔",,,9323,,
9324,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَانَ یَصُومُ الاِثْنَیْنِ وَالْخَمِیسَ۔,,,9324,,
9325,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عََنِ الحَکَمِ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَصُومُ الاِثْنَیْنِ وَالْخَمِیسَ، ثُمَّ کَرِہَ ذَلِکَ۔,,,9325,,
9326,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عُمَرَ بْنِ الْحَکَمِ بْنِ ثَوْبَانَ ، أَنَّ مَوْلَی قُدَامَۃَ حَدَّثَہُ : أَنَّ مَوْلَی أُسَامَۃَ حَدَّثَہُ : أَنَّ أُسَامَۃَ کَانَ یَخْرُجُ إلَی مَالٍ لَہُ بِوَادِی الْقُرَی ، فَیَصُومُ الاِثْنَیْنِ وَالْخَمِیسَ ، فَقُلْتُ لَہُ : لِمَ تَصُومُ الاِثْنَیْنِ وَالْخَمِیسَ وَأَنْتَ شَیْخٌ کَبِیرٌ ؟ فَقَالَ : رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَصُومُہُمَا ، فَقُلْتُ لَہُ : لِمَ تَصُومُ الاِثْنَیْنِ وَالْخَمِیسَ ؟ فَقَالَ : إنَّہُمَا یَوْمَانِ تُعْرَضُ فِیہِمَا الأَعْمَالُ۔ (ابوداؤد 2428۔ احمد 5/200)",,,9326,,
9327,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ قَالَ : کَانَ أُسَامَۃُ بْنُ زَیْدٍ یَصُومُ أَیَّامًا مِنَ الْجُمُعَۃِ ، یُتَابِعُ بَیْنہُنَّ ، فَقِیلَ لَہُ : أَیْنَ أَنْتَ مِنَ الاِثْنَیْنِ وَالْخَمِیسِ ؟ قَالَ : فَکَانَ یَصُومُہُمَا",,,9327,,
9328,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ، عَنْ قَیْسٍ، عَنْ عَاصِمٍ، عَنْ زِرٍّ، عَنْ عَبْدِاللہِ؛ أَنَّہُ کَانَ یَصُومُ الاِثْنَیْنِ وَالْخَمِیسَ۔,,,9328,,
9329,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ سُئِلَ عَنْ صَوْمِ یَوْمِ الاِثْنَیْنِ وَالْخَمِیسِ ؟ فَقَالَ : یُکْرَہُ أَنْ یُوَقِّتَ یَوْمًا یَصُومُہُ ۔ إِلاَّ أَنَّ یَزیدَ قَالَ : یَنْصِبُ یَوْمًا إذَا جَائَ ذَلِکَ الْیَوْمُ صَامَہُ۔",,,9329,,
9330,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ؛ أَنَّ عَلِیًّا کَانَ یَصُومُ الاِثْنَیْنِ وَالْخَمِیسَ۔,,,9330,,
9331,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سُلَیْمَانَ الْعَبْسِیِّ ، عَنْ مُجَاہِدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَصُومُ الاِثْنَیْنِ وَالْخَمِیسَ۔,,,9331,,
9332,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَصُم أَحَدُکُمْ یَوْمَ الْجُمُعَۃِ إِلاَّ أَنْ یَصُومَ قَبْلَہُ ، أَوْ یَصُومَ بَعْدَہُ۔ (مسلم 148۔ ابوداؤد 2412)",,,9332,,
9333,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : دَخَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی جُوَیْرِیَۃَ بِنْتِ الْحَارِثِ یَوْمَ الْجُمُعَۃِ وَہِیَ صَائِمَۃٌ ، قَالَ : فَقَالَ : صُمْت أَمْسِ ؟ قَالَتْ : لاَ ، قَالَ : تُرِیدِینَ أَنْ تَصُومِی غَدًا ؟ قَالَتْ : لاَ ، قَالَ : فَأَفْطِرِی إذًا۔ (احمد 2/189۔ ابن حبان 3611)",,,9333,,
9334,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ مَرْثَدِ بْنِ عَبْدِ اللہِ الْیَزَنِیِّ ، عَنْ حُذَیْفَۃَ الأَزْدِیِّ ، عَنْ جُنَادَۃَ الأَزْدِیِّ ؛ دَخَلْتُ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَبْعَۃِ نَفَرٍ مِنَ الأَزْدِ ، أَنَا ثَامِنُہُمْ یَوْمَ الْجُمُعَۃِ وَنَحْنُ صِیَامٌ ، فَدَعَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی طَعَامٍ بَیْنَ یَدَیْہِ فَقُلْنَا : إنَّا صِیَامٌ ، قَالَ : ہَلْ صُمْتُمْ أَمْسِ ؟ قُلْنَا : لاَ ، قَالَ : فَہَلْ تَصُومُونَ غَدًا ؟ قُلْنَا : لاَ ، قَالَ : فَأَفْطِرُوا ، ثُمَّ خَرَجَ إلَی الْجُمُعَۃِ ، فَلَمَّا جَلَسَ عَلَی الْمِنْبَرِ دَعَا بِإِنَائٍ مِنْ مَائٍ فَشَرِبَہُ ، وَالنَّاسُ یَنْظُرُونَ إلَیْہِ ، لِیُعَلِّمَہُمْ أَنَّہُ لاَ یَصُومُ یَوْمَ الْجُمُعَۃِ۔ (نسائی 2774۔ حاکم 608)",,,9334,,
9335,"حَدَّثَنَا ابْنُ عُیَینَۃَ ، عَنْ عِمْرَانَ بْنِ ظَبْیَانَ ، عَنْ حَکِیمِ بْنِ سَعْدٍ ، عَنْ عَلِیِّ بْنِ أَبِی طَالِبٍ رَحْمَۃُ اللہِ عَلَیْہِ، قَالَ: مَنْ کَانَ مِنْکُمْ مُتَطَوِّعًا مِنَ الشَّہْرِ أَیَّامًا فَلْیَکُنْ فِی صَوْمِہِ یَوْم الْخَمِیسِ، وَلاَ یَصُومُ یَوْمَ الْجُمُعَۃِ، فَإِنَّہُ یَوْمُ طَعَامٍ وَشَرَابٍ وَذِکْرٍ ، فَیَجْمَعُ للہِ یَوْمَیْنِ صَالِحَیْنِ ، یَوْمَ صِیَامِہِ وَیَوْمَ نُسُکِہِ مَعَ الْمُسْلِمِینَ۔",,,9335,,
9336,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ قَیْسِ بْنِ سَکَنٍ ، قَالَ : مَرَّ نَاسٌ مِنْ أَصْحَابِ عَبْدِ اللہِ عَلَی أَبِی ذَرٍّ یَوْمَ الْجُمُعَۃِ وَہُمْ صِیَامٌ ، فَقَالَ : أَقْسَمْت عَلَیْکُمْ لَتَفْطُرُنَّ ، فَإِنَّہُ یَوْمُ عِیدٍ۔",,,9336,,
9337,"حَدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ أَبِی إِسْحَاقَ، عَنِ الْحَارِثِ، عَنْ عَلِیٍّ، قَالَ: لاَ تَصَومُ یَوْمَ الْجُمُعَۃِ مُتَعَمِّدًا لَہُ۔",,,9337,,
9338,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : لاَ تَصَومُ یَوْمَ الْجُمُعَۃِ إِلاَّ أَنْ تَصُومَ یَوْمًا قَبْلَہُ ، أَوْ بَعْدَہُ۔",,,9338,,
9339,حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَرِہَ أَنْ یَصُومَ یَوْمَ الْجُمُعَۃِ ، یَتَعَمَّدُہ وَحْدَہُ۔,,,9339,,
9340,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُمْ کَرِہُوا صَوْمَ یَوْمِ الْجُمُعَۃِ لِیَتَقَوَّوْا بِہِ عَلَی الصَّلاَۃِ۔,,,9340,,
9341,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی أَیُّوبَ الْعَتَکِیِّ ، عَنْ جُوَیْرِیَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دَخَلَ عَلَیْہَا وَہِیَ صَائِمَۃٌ یَوْمَ الْجُمُعَۃِ ، فَقَالَ : أَصُمْتِ أَمْسِ ؟ قَالَتْ : لاَ ، قَالَ : فَتَصُومِینَ غَدًا ؟ قَالَتْ : لاَ ، قَالَ : فَأَفْطِرِی۔ (بخاری 1986۔ احمد 6/430)",,,9341,,
9342,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ زِیَادٍ الْحَارِثِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ لَہُ رَجُلٌ : أَنْتَ الَّذِی تَنْہَی عَنْ صَوْمِ یَوْمِ الْجُمُعَۃِ ؟ قَالَ : لاَ ، وَرَبِّ ہَذِہِ الْحُرْمَۃِ ، أَوْ ہَذِہِ الْبُنْیَۃِ ، مَا أَنَا نَہَیْت عَنْہُ ، مُحَمَّدٌ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَہُ۔ (نسائی 2744۔ احمد 2/526)",,,9342,,
9343,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْوَلِیدِ بْنِ مُسْلِمٍ ، عَنْ حُصَیْنِ بْنِ أَبِی الْحُرِّ ، عَنْ عِمْرَانَ بْنِ حُصَیْنِ ؟ قَالَ : لاَ تَصُمْ یَوْمًا تَجْعَلُ صَوْمَہُ عَلَیْک حَتْمًا ، لَیْسَ مِنْ رَمَضَانَ۔",,,9343,,
9344,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، قَالَ : کَانَ ابْنُ عَبَّاسٍ یَنْہَی عَنِ افْتِرَادِ الْیَوْمِ کُلَّ مَا مَرَّ بِالإِنْسَان ، وَعَنْ صِیَامِ الأَیَّامِ الْمَعْلُومَۃِ ، وَکَانَ یَنْہَی عَنْ صِیَامِ الأَشْہُرِ لاَ یُخْطَأْنَ۔",,,9344,,
9345,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یَفْرِضُوا عَلَی أَنْفُسِہِمْ شَیْئًا لَمْ یُفْتَرَضْ عَلَیْہِمْ۔",,,9345,,
9346,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ؟ قَالَ : لاَ تَخُصُّوا یَوْمَ الْجُمُعَۃِ بِصَوْمٍ بَیْنَ الأَیَّامِ ، وَلاَ لَیْلَۃَ الْجُمُعَۃِ بِقِیَامٍ بَیْنَ اللَّیَالِیِ۔",,,9346,,
9347,حَدَّثَنَا أَبُو دَاوُدَ، عَنْ زَمْعَۃَ، عَنِ ابْنِ طَاوُوس، عَنْ أَبِیہِ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَتَحَرَّی شَہْرًا، أَوْ یَوْمًا یَصُومُہُ۔,,,9347,,
9348,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یَخُصُّوا یَوْمَ الْجُمُعَۃِ وَاللَّیْلَۃَ کَذَلِکَ بِالصَّلاَۃِ۔",,,9348,,
9349,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ (ح) وعَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُمَا کَرِہَا أَنْ یَصُومَا یَومًا یُُوَقِّتَانِہِ۔,,,9349,,
9350,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَد ، عَنْ مُجَاہِدٍ ؟ قَالَ : لاَ تَصُومُوا شَہْرًا کُلَّہُ تُضَاہُونَ بِہِ شَہْرَ رَمَضَانَ ، وَلاَ تَصُومُوا یَوْمًا وَاحِدًا مِنَ الْجُمُعَۃِ فَتَتَّخِذُونَہُ عِیدًا ، إِلاَّ أَنْ تَصُومُوا قَبْلَہُ ، أَوْ بَعْدَہُ یَوْمًا۔",,,9350,,
9351,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَا رَأَیْتُہُ مُفْطِرًا یَوْمَ جُمُعَۃٍ قَطُّ۔",,,9351,,
9352,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عُمَیْرِ بْنِ أَبِی عُمَیْرٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَا رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُفْطِرًا یَوْمَ الْجُمُعَۃِ قَطُّ۔ (ابویعلی 5709)",,,9352,,
9353,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ شَیْبَانَ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَبْدِ اللہِ ، قَالَ : مَا کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُفْطِرُ یَوْمَ الْجُمُعَۃِ۔ (ترمذی 742۔ ابوداؤد 2442)",,,9353,,
9354,"حَدَّثَنَا شَرِیکٌ ، عَنِ الْقَعْقَاعِ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ عَنِ السَّعُوطِ بِالصَّبِرِ لِلصَّائِمِ ؟ فَلَمْ یَرَ بِہِ بَأْسًا۔",,,9354,,
9355,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالسَّعُوطِ لِلصَّائِمِ ، وَکَرِہَ الصَّبَّ فِی الأُذنِ۔",,,9355,,
9356,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَرِہَ لِلصَّائِمِ أَنْ یَسْتَسْعِطَ۔,,,9356,,
9357,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حُرَیْثٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَرِہَ السَّعُوطَ لِلصَّائِمِ۔,,,9357,,
9358,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، قَالَ: قُلْتُ لِعَطَائٍ: الصَّبِرُ یَکْتَحِلُ بِہِ الصَّائِمُ؟ قَالَ: نَعَمْ، إِنْ شَائَ۔",,,9358,,
9359,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِالْکُحْلِ لِلصَّائِمِ۔",,,9359,,
9360,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالْکُحْلِ لِلصَّائِمِ۔",,,9360,,
9361,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِالْکُحْلِ لِلصَّائِمِ مَا لَمْ یَجِدْ طَعْمَہُ۔",,,9361,,
9362,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَمُحَمَّدِ بْنِ عَلِیٍّ ، وَعَطَائٍ ؛ أَنَّہُمْ کَانُوا یَکْتَحِلُونَ بِالإِثْمدِ وَہُمْ صِیَامٌ ، لاَ یَرَوْنَ بِہِ بَأْسًا۔,,,9362,,
9363,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ ، عَنِ الْحَسَنِ (ح) وَعَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِالْکُحْلِ لِلصَّائِمِ۔",,,9363,,
9364,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَبِی مُعَاذٍ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی بَکْرٍ ، عَنْ أَنَسٍ ؛ أَنَّہُ کَانَ یَکْتَحِلُ وَہُوَ صَائِمٌ,,,9364,,
9365,حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، وَأَبِی ہِلاَلٍ ، وَقَتَادَۃَ ؛ أَنَّہُمْ کَرِہُوا الْکُحْلَ لِلصَّائِمِ۔,,,9365,,
9366,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لاَ یَرَی بَأْسًا أَنْ یَکْتَحِلَ الرَّجُلُ وَہُوَ صَائِمٌ۔",,,9366,,
9367,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ بَأْسَ بِالْکُحْلِ لِلصَّائِمِ۔",,,9367,,
9368,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، أَوْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یَتَطَعَّمَ الصَّائِمُ مِنَ الْقِدْرِ۔",,,9368,,
9369,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ أَنْ یَذُوقَ الْخَلَّ ، أَوِ الشَّیْئَ مَا لَمْ یَدْخُلْ حَلْقَہُ وَہُوَ صَائِمٌ۔",,,9369,,
9370,"حَدَّثَنَا شَرِیکٌ ، عَنْ سُلَیْمَانَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ أَنْ یَتَطَاعَمَ الصَّائِمُ مِنَ الْقِدْرِ۔",,,9370,,
9371,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَتَطَاعَمَ الصَّائِمُ الْعَسَلَ وَالسَّمْنَ وَنَحْوَہُ ، ثُمَّ یَمُجَّہُ۔,,,9371,,
9372,"حَدَّثَنَا أَبُو بَکْرٍ الْحَنَفِیُّ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ ، قَالَ : رَأَیْتُ عُرْوَۃَ بْنَ الزُّبَیْرِ صَائِمًا أَیَّامَ مِنًی ، وَہُوَ یَذُوقُ عَسَلاً۔",,,9372,,
9373,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ عَنِ الصَّائِمِ یَلْحَسُ الأَنْقَاسَ ؟ قَالَ : لاَ بَأْسَ بِہِ۔",,,9373,,
9374,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مَسْرُوقٍ ، قَالَ : أَتَیْتُ عَائِشَۃَ أَنَا وَرَجُلٌ مَعِی، وَذَلِکَ یَوْمُ عَرَفَۃَ فَدَعَتْ لَنَا بِشَرَابٍ ، ثُمَّ قَالَتْ : لَوْلاَ أَنِّی صَائِمَۃٌ لَذُقْتُہُ۔",,,9374,,
9375,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : لاَ بَأْسَ أَنْ یُدَاوِیَ الصَّائِمُ لِثَتَہُ۔",,,9375,,
9376,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَکُونُ بِفِیہِ الْجُرْحُ وَالْعِلَّۃُ ، قَالَ : لاَ بَأْسَ أَنْ یَضَعَ عَلَیْہِ الْحُضُضَ وَأَشْبَاہَہُ مِنَ الدَّوَائِ۔",,,9376,,
9377,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ یَحْیَی بْنِ عَتِیقٍ ، عَنِ ابْنِ سِیرِینَ ؛ فِی رَجُلٍ أَصَابَہُ سُلاَقٌ فِی شَفَتَیْہِ ، قَالَ : لاَ بَأْسَ بِالْحُضُضِ۔",,,9377,,
9378,"حَدَّثَنَا أَبُوبَکْرٍ الْحَنَفِیُّ، عَنْ قَتَادَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: لاَ یَتَطَوَّعُ الرَّجُلُ بِصَوْمٍ وَعَلَیْہِ شَیْئٌ مِنْ رَمَضَانَ۔",,,9378,,
9379,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ؛ أَنَّہُ کَرِہَ أَنْ یَتَطَوَّعَ بِصِیَامٍ وَعَلَیْہِ قَضَائٌ مِنْ رَمَضَانَ، إِلاَّ الْعَشْرَ۔,,,9379,,
9380,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : مَثَلُ الَّذِی یَتَطَوَّعُ وَعَلَیْہِ قَضَائٌ مِنْ رَمَضَانَ ، مَثَلُ الَّذِی یُسَبِّحُ وَہُوَ یَخَافُ أَنْ تَفُوتَہُ الْمَکْتُوبَۃُ۔",,,9380,,
9381,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، قَالَ : سُئِلَ سُلَیْمَانُ بْنُ یَسَارٍ وَسَعِیدُ بْنُ الْمُسَیَّبِ عَنْ رَجُلٍ تَطَوَّعَ وَعَلَیْہِ قَضَائٌ مِنْ رَمَضَانَ ؟ فَکَرِہَا ذَلِکَ۔",,,9381,,
9382,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا کَانَ عَلَی الرَّجُلِ قَضَائٌ مِنْ رَمَضَانَ فَتَطَوَّعَ ، فَہُوَ قَضَاؤُہُ ، وَإِنْ لَمْ یُرِدْہُ۔",,,9382,,
9383,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَأَلَ مُغِیثٌ عَطَائٍ : أَیَسْتَدْخِلُ الرَّجُلُ الشَّیْئَ ؟ قَالَ : لاَ۔",,,9383,,
9384,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ أَنَّہُ سُئِلَ عَنِ الْحُقْنَۃِ لِلصَّائِمِ ؟ فَقَالَ : إنِّی لأَکْرَہُہَا لِلْمُفْطِرِ ، فَکَیْفَ لِلصَّائِمِ۔",,,9384,,
9385,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ تَمْضُغَ الْمَرْأَۃُ لِصَبِیِّہَا وَہِیَ صَائِمَۃٌ ، مَا لَمْ یَدْخُلْ حَلْقَہَا۔",,,9385,,
9386,"حَدَّثَنَا وَکِیعٌ، عَنْ شَرِیکٍ، عَنْ سُلَیْمَانَ، عَنْ عِکْرِمَۃَ، قَالَ: لاَ بَأْسَ أَنْ تَمْضُغَ الْمَرْأَۃُ لِصَبِیِّہَا وَہِیَ صَائِمَۃٌ",,,9386,,
9387,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَبِی سُفْیَانَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَذُرَّ الصَّائِمُ عَیْنَہُ بِالذَّرُورِ,,,9387,,
9388,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِالذَّرُورِ لِلصَّائِمِ۔",,,9388,,
9389,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : شَہِدَ عِنْدِی نَفَرٌ مِنْ أَہْلِ الْبَصْرَۃِ ، مِنْہُمُ الْحَسَنُ بْنُ أَبِی الْحَسَنِ الْبَصْرِیُّ ، عَنْ مَعْقِلِ بْنِ سِنَان الأَشْجَعِیِّ ، قَالَ : مَرَّ عَلَیَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَنَا أَحْتَجِمُ فِی ثَمَانِ عَشْرَۃَ مِنْ رَمَضَانَ ، فَقَالَ : أَفْطَرَ الْحَاجِمُ وَالْمَحْجُومُ۔ (طحاوی 98۔ احمد 3/474)",,,9389,,
9390,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا عَاصِمٌ الأَحْوَلُ ، عَنْ عَبْدِ اللہِ بْنِ زَیْدٍ وَہُوَ أَبُو قِلاَبَۃَ ، عَنْ أَبِی الأَشْعَثِ الصَّنْعَانِیِّ ، عَنْ أَبِی أَسْمَائَ الرَّحَبِیِّ ، عَنْ شَدَّادِ بْنِ أَوْسٍ ، قَالَ : مَرَرْت مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی ثَمَانِ عَشْرَۃَ خَلَتْ مِنْ رَمَضَانَ ، فَأَبْصَرَ رَجُلاً احْتَجَمَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَفْطَرَ الْحَاجِمُ وَالْمَحْجُومُ۔ (ابوداؤد 2361۔ احمد 4/124)",,,9390,,
9391,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ عَبْدِ اللہِ بْنِ زَیْدٍ ، عَنْ أَبِی الأَشْعَثِ ، عَنْ أَبِی أَسْمَائَ الرَّحَبِیِّ ، عَنْ شَدَّادِ بْنِ أَوْسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، مِثْلَہُ۔ (احمد 4/124),,,9391,,
9392,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَمَّنْ حَدَّثَہُ ، عَنْ شَدَّادِ بْنِ أَوْسٍ ، قَالَ : أَتَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی رَجُلٍ یَحْتَجِمُ بِالْبَقِیعِ ، وَہُوَ آخِذٌ بِیَدَیَّ لِثَمَانِ عَشْرَۃَ خَلَتْ مِنْ رَمَضَانَ ، فَقَالَ: أَفْطَرَ الْحَاجِمُ وَالْمَحْجُومُ۔ (ابوداؤد 2361۔ احمد 4/125)",,,9392,,
9393,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ مَکْحُولٍ ، قَالَ : أَخْبَرَنِی رَجُلٌ مِنَ الْحَیِّ مُصَدَّقٌ ، عَنْ ثَوْبَانَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أَفْطَرَ الْحَاجِمُ وَالْمَحْجُومُ۔ (ابوداؤد 2362۔ احمد 5/282)",,,9393,,
9394,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا أَیُّوبُ أَبُو الْعَلاَئِ ، عَنْ قَتَادَۃَ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، عَنْ بِلاَلٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَفْطَر الْحَاجِمُ وَالْمَحْجُومُ۔ (احمد 6/12۔ طبرانی 1122)",,,9394,,
9395,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، عَنْ أَبِی ہُرَیْرَۃَ رَضِیَ اللَّہُ تَعَالَی عَنْہُ ، أَنَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیہِ وَسَلَّمَ ، قَالَ : أَفْطَرَ الْحَاجِمُ وَالْمَحْجُومُ۔ (نسائی 3172۔ احمد 6/364",,,9395,,
9396,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قَالَ أَبُو ہُرَیْرَۃَ : إنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أَفْطَرَ الْحَاجِمُ وَالْمَحْجُومُ۔ (نسائی 3182۔ ابویعلی 6365)",,,9396,,
9397,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنِ ابْنِ أَبِی عَرُوبَۃَ، عَنْ مَطَرٍ، عَنِ الْحَسَنِ، قَالَ: قَالَ عَلِیٌّ: أَفْطَرَ الْحَاجِمُ وَالْمَحْجُومُ۔",,,9397,,
9398,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : یُکْرَہُ لِلْحَاجِمِ وَالْمَحْجُومِ۔",,,9398,,
9399,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : دَخَلْتُ عَلَی أَبِی مُوسَی وَہُوَ أَمِیرُ الْبَصْرَۃِ مُمْسِیًا، فَوَجَدْتُہُ یَأْکُلُ تَمْرًا وَکَامَخًا ، وَقَدِ احْتَجَمَ ، فَقُلْتُ لَہُ : أَلاَ تَحْتَجِمُ بِنَہَارٍ ؟ فَقَالَ : أَتَأْمُرُنِی أَنْ أُہْرِیقَ دَمِی وَأَنَا صَائِمٌ",,,9399,,
9400,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ طَلْقِ بْنِ حَبِیبٍ ، قَالَ : أَفْطَرَ الْحَاجِمُ وَالْمَحْجُومُ۔",,,9400,,
9401,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : لاَ یَحْتَجِمُ الصَّائِمُ۔",,,9401,,
9402,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی، عَنْ شَیْبَانَ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، عَنْ عَائِشَۃَ قَالَتْ: أَفْطَرَ الْحَاجِمُ وَالْمَحْجُومُ۔",,,9402,,
9403,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی ، عَنْ مَنْصُورٍ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ، قَالَ : لاَ یَحْتَجِمُ الصَّائِمُ۔",,,9403,,
9404,حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ یَزِیدَ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ احْتَجَمَ بَیْنَ مَکَّۃَ إِلَی الْمَدِینَۃِ ، مُحْرِمًا صَائِمًا۔ (ترمذی 777۔ ابوداؤد 2365),,,9404,,
9405,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ احْتَجَمَ وَہُوَ صَائِمٌ۔,,,9405,,
9406,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ احْتَجَمَ صَائِمًا۔ (نسائی 3224۔ احمد 1/286),,,9406,,
9407,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ احْتَجَمَ وَہُوَ صَائِمٌ۔ (نسائی 3222۔ عبدالرزاق 7536),,,9407,,
9408,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَطَائِ بْنِ یَسَارٍ رَفَعَہُ ، قَالَ : ثَلاَثٌ لاَ یُفْطرن الصَّائِمَ ؛ الْحِجَامَۃُ ، وَالْقَیْئُ ، وَالاِحْتِلاَمُ۔ (عبدالرزاق 7539۔ ابن خزیمۃ 1976)",,,9408,,
9409,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبَانَ بْنِ صَالِحٍ ، عَنْ مُسْلِمِ بْنِ سَعِیدٍ ، قَالَ : سُئِلَ ابْنُ مَسْعُودٍ عَنِ الْحِجَامَۃِ لِلصَّائِمِ ؟ فَقَالَ : لاَ بَأْسَ بِہَا۔",,,9409,,
9410,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ حُمَیْدٍ ، قَالَ : سُئِلَ أَنَسٌ عَنِ الْحِجَامَۃِ لِلصَّائِمِ ؟ فَقَالَ : مَا کُنَّا نَحْسِبُ یُکْرَہُ مِنْ ذَلِکَ إِلاَّ جُہْدُہُ۔",,,9410,,
9411,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی ظَبْیَانَ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الْحِجَامَۃِ لِلصَّائِمِ ، قَالَ : الْفِطْرُ مِمَّا دَخَلَ ، وَلَیْسَ مِمَّا یَخْرُجُ۔",,,9411,,
9412,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنَ عُمَرَ ، قَالَ : کَانَ یَحْتَجِمُ وَہُوَ صَائِمٌ ، ثُمَّ تَرَکَہَا بَعْدُ ، فَکَانَ یَحْتَجِمُ لَیْلاً۔",,,9412,,
9413,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ بن الغَاز ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَحْتَجِمُ عِنْدَ اللَّیْلِ وَہُوَ صَائِمٌ,,,9413,,
9414,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حُمَیْدٍ ، عَنْ أَبِی الْمُتَوَکِّلِ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : لاَ بَأْسَ بِالْحِجَامَۃِ لِلصَّائِمِ۔",,,9414,,
9415,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی الْمُتَوَکِّلِ ، عَنْ أَبِی سَعِیدٍ ؛ أَنَّہُ کَرِہَ الْحِجَامَۃَ لِلصَّائِمِ مِنْ أَجْلِ الضَّعْفِ۔,,,9415,,
9416,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ یُونُسَ بْنِ عَبْدِ اللہِ الْجَرْمِیِّ ، عَنْ دِینَارٍ ، قَالَ : حَجَمْت زَیْدَ بْنَ أَرْقَمَ وَہُوَ صَائِمٌ۔",,,9416,,
9417,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ أَبِی أُسَامَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : احْتَجَمَ الْحُسَیْنُ بْنُ عَلِیٍّ وَہُوَ صَائِمٌ۔",,,9417,,
9418,حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَطَاوُسٍ ؛ أَنَّہُمَا لَمْ یَکُونَا یَرَیَانِ بِالْحِجَامَۃِ لِلصَّائِمِ بَأْسًا۔,,,9418,,
9419,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عَبْدِ الأَعْلَی ، قَالَ : رَأَیْتُ أَبَا عَبْدِ الرَّحْمَنِ السُّلَمِیَّ احْتَجَمَ وَہُوَ صَائِمٌ عِنْدَ غُرُوبِ الشَّمْسِ ، نَحْوًا مِمَّا یُوَافِقُ شَرْطُہُ فِطْرَہُ ، فَقُلْتُ لَہُ : یَا أَبَا عَبْدِ الرَّحْمَنِ ؛ إنَّمَا تُکْرَہُ الْحِجَامَۃُ لِلصَّائِمِ ، قَالَ : إنَّمَا تُکْرَہُ لَہُ مَخَافَۃَ الضَّعْفِ۔",,,9419,,
9420,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبَّاسٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالُوا : إنَّمَا نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْحِجَامَۃِ لِلصَّائِمِ ، وَالْوِصَالِ فِی الصِّیَامِ إبْقَائً عَلَی أَصْحَابِہِ۔ (ابوداؤد 2366۔ احمد 4/314)",,,9420,,
9421,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ مِسْعَرٍ ، عَنْ بُزَیْعٍ ، قَالَ : سَأَلْتُ أَبَا وَائِلٍ عَنِ الْحِجَامَۃِ لِلصَّائِمِ ؟ فَقَالَ : إنَّمَا یُکْرَہُ ذَلِکَ لِلضَّعْفِ۔",,,9421,,
9422,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الأَحْوَصِ بْنِ حَکِیمٍ ، عَنْ أَبِی الزَّاہِرِیَّۃِ ، عَنْ جُبَیْرِ بْنِ نُفَیْرٍ ؛ أَنَّ مُعَاذًا احْتَجَمَ وَہُوَ صَائِمٌ۔,,,9422,,
9423,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، عَنْ عَطَائٍ ، وَسَعِیدِ بْنِ جُبَیْرٍ قَالاَ : لاَ بَأْسَ بِالْحِجَامَۃِ لِلصَّائِمِ مَا لَمْ یَخَفْ ضَعْفًا۔",,,9423,,
9424,حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، وَسَالِمٍ ، مِثْلَہُ۔,,,9424,,
9425,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : سَأَلَ رَجُلٌ عِکْرِمَۃَ عَنِ الْحِجَامَۃِ لِلصَّائِمِ ؟ فَقَالَ : لاَ بَأْسَ بِہَا ، إنَّمَا ہِیَ مِثْلُ کَذَا وَکَذَا یَخْرُجُ مِنْکَ ، ذَکَرَ الْحَاجَۃَ۔",,,9425,,
9426,حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، وَأَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَحْتَجِمُ وَہُوَ صَائِمٌ,,,9426,,
9427,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا سُفْیَانُ ، عَنْ فُرَاتٍ ، عَنْ مَوْلًی لأُمِّ سَلَمَۃَ ؛ أَنَّہُ رَأَی أُمَّ سَلَمَۃَ تَحْتَجِمُ وَہِیَ صَائِمَۃٌ۔",,,9427,,
9428,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ یَزِیدَ ، وَعُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَحْتَجِمُ وَہُوَ صَائِمٌ ، ثُمَّ تَرَکَ ذَلِکَ ، فَلاَ أَدْرِی لأَیِّ شَیْئٍ تَرَکَہُ ؟ کَرِہَہُ ، أَوْ لِلضَّعْفِ۔,,,9428,,
9429,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الْوَارِث ، عَنْ أَنَسٍ ، قَالَ : مَرَّ بِنَا أَبُو طیبۃَ ، فَقَالَ : حجَمْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ صَائِمٌ۔ (ترمذی 366۔ ابویعلی 4210",,,9429,,
9430,حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْمَرٍ ، عَنْ أَبِی جَعْفَرٍ ؛ إنَّمَا کُرِہَ الْحِجَامَۃُ لِلصَّائِمِ مَخَافَۃَ الضَّعْفِ۔,,,9430,,
9431,"حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَک ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الْمَرْأَۃِ تَحِیضُ أَوَّلَ النَّہَارِ فِی شَہْرِ رَمَضَانَ ، فَقَالَ : تَأْکُلُ وَتَشْرَبُ۔",,,9431,,
9432,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الْمَرْأَۃِ حَاضَتْ بَعْدَ مَا اصْفَرَّتِ الشَّمْسُ فِی رَمَضَانَ ، قَالَ : تُفْطِرُ ، قَالَ : وَإِنْ أَصْبَحَتْ حَائِضًا ، فَطَہُرَتْ بَعْدَ طُلُوعِ الْفَجْرِ ؟ قَالَ : لاَ تَأْکُلُ بَقِیَّۃَ یَوْمِہَا۔",,,9432,,
9433,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی الْمَرْأَۃِ تُصْبِحُ صَائِمَۃً أَوَّلَ النَّہَارِ ، ثُمَّ تَحِیضُ ، قَالَ : تَأْکُلُ۔",,,9433,,
9434,حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الْحَائِضِ تَطْہُرُ فَلاَ تَأْکُلُ شَیْئًا، کَرَاہَۃ أَنْ تُشْبِہَ الْمُشْرِکِینَ إلَی اللَّیْلِ۔,,,9434,,
9435,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ أَکَلَ أَوَّلَ النَّہَارِ فَلْیَأْکُلْ آخِرَہُ۔",,,9435,,
9436,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : فِی رَجُلٍ قَدِمَ فِی رَمَضَانَ أَوَّلَ النَّہَارِ وَقَدْ أَکَلَ ، قَالَ : لاَ یَأْکُلُ بَقِیَّۃَ یَوْمِہِ۔",,,9436,,
9437,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الْمُسَافِرِ یَقْدَمُ وَقَدْ کَانَ أَکَلَ؟ قَالَ : لاَ یَأْکُلُ بَقِیَّۃَ یَوْمِہِ۔ حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : لاَ یَأْکُلُ کَرَاہِیَۃَ أَنْ یَتَشَبَّہَ بِالْمُشْرِکِینَ ، إلَی اللَّیْلِ۔",,,9437,,
9438,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حُرَیْثٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا دَخَلَ الْمُسَافِرُ الْمِصْرَ لَمْ یَطْعَمْ شَیْئًا ، وَإِنْ کَانَ أَکَلَ قَبْلَ أَنْ یَقْدَمَ۔",,,9438,,
9439,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لِرَجُلٍ وَقَعَ عَلَی أَہْلِہِ فِی رَمَضَانَ : إِنْ کَانَ فَجَرَ ظَہْرُک ، فَلاَ یَفْجُرْ بَطْنُک۔",,,9439,,
9440,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الَّذِی یُصِیبُ أَہْلَہُ ، یَعْنِی فِی شَہْرِ رَمَضَانَ ، قَالَ : إِنْ شَائَ أَکَلَ وَشَرِبَ۔",,,9440,,
9441,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَمْرِو بْنِ دِینَارٍ : أَلَیْسَ کَذَا یُقَالُ فِی الَّذِی یُصِیبُ أَہْلَہُ فِی رَمَضَانَ ، لِیُتِمَّ ذَلِکَ الْیَوْمَ وَیَقْضِیہ ؟ قَالَ : نَعَمْ",,,9441,,
9442,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ، عَنْ عَمْرٍو، عَنِ الْحَسَنِ، قَالَ: کَانَ یَقُولُ: إذَا غَشِیَ لاَ یُبَالِی أَکَلَ، أَوْ لَمْ یَأْکُلْ۔",,,9442,,
9443,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مُحَمَّدِ بْنِ صَیْفِیٍّ ، قَالَ : قَالَ لَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ عَاشُورَائَ : مِنْکُمْ أَحَدٌ طَعِمَ الْیَوْمَ ؟ فَقُلْنَا : مِنَّا مَنْ طَعِمَ ، وَمِنَّا مَنْ لَمْ یَطْعَمْ ، قَالَ : فَقَالَ : أَتِمُّوا بَقِیَّۃَ یَوْمِکُمْ ، مَنْ کَانَ طَعِمَ ، وَمَنْ لَمْ یَطْعَمْ ، وَأَرْسِلُوا إلَی أَہْلِ الْعَرُوضِ فَلْیُتِمُّوا بَقِیَّۃَ یَوْمِہِمْ ، یَعْنِی أَہْلَ الْعَرُوضِ مِنْ حَوْلِ الْمَدِینَۃِ۔ (نسائی 2629)",,,9443,,
9444,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، عَنْ أَبِی مُوسَی ، قَالَ: یَوْمُ عَاشُورَائَ یَوْمٌ تُعَظِّمُہُ الْیَہُودُ تَتَّخِذُہُ عِیدًا ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صُومُوہُ أََنْتُم۔ (بخاری 2005۔ مسلم 130)",,,9444,,
9445,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ بْنِ الزُّبَیْرِ الأَسَدِیُّ ، عَنْ شَرِیکٍ ، عَنْ مجزأۃ بْنِ زاہر، عَنْ أَبِیہِ ، قَالَ : أَمَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِصَوْمِ یَوْمِ عَاشُورَائَ۔",,,9445,,
9446,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الْہَجَرِیِّ ، عَنْ أَبِی عِیَاضٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَوْمُ عَاشُورَائَ یَوْمٌ کَانَتْ تَصُومُہُ الأَنْبِیَائُ ، فَصُومُوہُ أَنْتُمْ۔ (بزار 1046)",,,9446,,
9447,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ أَہْلَ الْجَاہِلِیَّۃِ کَانُوا یَصُومُونَ یَوْمَ عَاشُورَائَ ، وَأَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَامَہُ وَالْمُسْلِمُونَ قَبْلَ أَنْ یُفْتَرَضَ رَمَضَانُ ، فَلَمَّا افْتُرِضَ رَمَضَانُ ، قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّ عَاشُورَائَ یَوْم مِنْ أَیَّامِ اللہِ ، فَمَنْ شَائَ صَامَہُ ، وَمَنْ شَائَ تَرَکَہُ۔ (بخاری 4501۔ مسلم 792)",,,9447,,
9448,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ قَالَتْ : کَانَ عَاشُورَائُ یَوْمًا تَصُومُہُ قُرَیْشٌ فِی الْجَاہِلِیَّۃِ ، فَلَمَّا قَدِمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَدِینَۃَ صَامَہُ ، وَأَمَرَ بِصِیَامِہِ ، فَلَمَّا فُرِضَ رَمَضَانُ کَانَ رَمَضَانُ ہُوَ الْفَرِیضَۃَ ، وَتَرَکَ عَاشُورَائَ ، فَمَنْ شَائَ صَامَہُ وَمَنْ شَائَ تَرَکَہُ۔\n\n(مسلم 792۔ ابوداؤد 2434)",,,9448,,
9449,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : أَخْبَرَنَا شَیْبَانُ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ جَعْفَرِ بْنِ أَبِی ثَوْرٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَأْمُرُنَا بِصِیَامِ عَاشُورَائَ وَیَحُثُّنَا عَلَیْہِ ، أَوْ یَتَعَاہَدُنَا عِنْدَہُ ، فَلَمَّا فُرِضَ رَمَضَانُ لَمْ یَأْمُرْنَا ، وَلَمْ یَنْہَنَا عَنْہُ ، وَلَمْ یَتَعَاہَدْنَا عِنْدَہُ۔ \n\n(مسلم 125۔ احمد 5/105)",,,9449,,
9450,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَمَّا قَدِمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَدِینَۃَ وَالْیَہُودُ یَصُومُونَ یَوْمَ عَاشُورَائَ فَسَأَلَہُمْ عَنْ ذَلِکَ ؟ فَقَالُوا : ہُوَ الْیَوْمُ الَّذِی ظْہَرَ فِیہِ مُوسَی عَلَی فِرْعَوْنَ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لأَنْتُمْ أَوْلَی بِمُوسَی مِنْہُمْ ، فَصُومُوہُ۔ (بخاری 4737۔ مسلم 796)",,,9450,,
9451,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : دَخَلَ الأَشْعَثُ بْنُ قَیْسٍ عَلَی عَبْدِ اللہِ وَہُوَ یَتَغَدَّی ، فَقَالَ : یَا أَبَا مُحَمَّدٍ ، اُدْنُ إلَی الْغَدَاء ، فَقَالَ : أَوَلَیْسَ الْیَوْمُ یَوْمَ عَاشُورَائَ ؟ فَقَالَ : وَہَلْ تَدْرِی مَا یَوْمُ عَاشُورَائَ ؟ قَالَ : وَمَا ہوَُ ؟ قَالَ : إنَّمَا ہُوَ یَوْمٌ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَصُومُہُ قَبْلَ أَنْ یُنَزَّلَ شَہْرُ رَمَضَانَ ، فَلَمَّا نَزَلَ شَہْرُ رَمَضَانَ تُرِکَ۔ (مسلم 122۔ احمد 1/424)",,,9451,,
9452,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَد ، قَالَ : مَا رَأَیْتُ أَحَدًا کَانَ آمَرَ بِصِیَامِ یَوْمِ عَاشُورَائَ مِنْ عَلِیِّ بْنِ أَبِی طَالِبٍ ، وَأَبِی مُوسَی۔",,,9452,,
9453,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، وَعَلِیِّ بْنِ صَالِحٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَد ، قَالَ : مَا رَأَیْتُ أَحَدًا آمَرَ بِصَوْمِ یَوْمِ عَاشُورَائَ مِنْ عَلِیِّ بْنِ أَبِی طَالِبٍ ، وَأَبِی مُوسَی۔",,,9453,,
9454,حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یَأْمُرُ بِصَوْمِ یَوْمِ عَاشُورَائَ۔,,,9454,,
9455,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَبْدُ الْمَلِکِ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ ؛ أَنَّ عُمَرَ أَرْسَلَ إلَی عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ مَسَائَ لَیْلَۃِ عَاشُورَائَ : أَنْ تَسَحَّروا ، وَأَصبحَ صَائِمًا ، وَأَصْبَحَ عَبْدُ الرَّحْمَنِ صَائِمًا۔",,,9455,,
9456,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنِ الْقَاسِمِ ؛ أَنَّہُ کَانَ یَصُومُ عَاشُورَائَ۔,,,9456,,
9457,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْقَاسِمِ بْنِ مُخَیْمِرَۃَ ، عَنْ أَبِی عَمَّارٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، قَالَ : أَمَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِصِیَامِ یَوْمِ عَاشُورَائَ۔ (احمد 421۔ نسائی 3/2841)",,,9457,,
9458,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْقَاسِمِ ؛ فَلَمَّا نَزَلَ رَمَضَانُ لَمْ یَأْمُرْنَا ، وَلَمْ یَنْہَنَا ، وَنَحْنُ نَفْعَلُہُ۔,,,9458,,
9459,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ رَجُلاً مِنْ أَسْلَمَ یَوْمَ عَاشُورَائَ ، فَقَالَ : ائْتِ قَوْمَک فَمُرْہُمْ فَلْیَصُومُوا ہَذَا الْیَوْمَ ، فَقَالَ : مَا أَرَانِی آتِیہِمْ حَتَّی یَصْطَبِحُوا ، فَقَالَ : مُرْ مَنِ اصْطَبَحَ منْہُمْ أَنْ یَصُومَ بَقِیَّۃَ یَوْمِہِ ، وَمَنْ لَمْ یَصْطَبِحْ مِنْہُمْ أَنْ یَصُومَ۔ (عبدالرزاق 7834)",,,9459,,
9460,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَہُمْ بِصَوْمِہِ۔,,,9460,,
9461,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُعْجِبُہُ صَوْمُ یَوْم عَاشُورَائَ۔,,,9461,,
9462,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنْ سُفْیَانَ، عَنْ زُبَیْدٍ، عَنْ عُمَارَۃَ، عَنْ قَیْسِ بْنِ سَکَنٍ؛ أَنَّ الأَشْعَثَ دَخَلَ عَلَی عَبْدِاللہِ یَوْمَ عَاشُورَائَ وَہُوَ یَطْعَمُ، فَقَالَ: اُدْنُ فَکُلْ، فَقَالَ: إنِّی صَائِمٌ، فَقَالَ: إنَّمَا کَانَ ہَذَا قَبْلَ أَنْ یُنَزَّلَ رَمَضَانُ۔",,,9462,,
9463,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ؛ أَنَّ عُمَرَ کَانَ لاَ یَصُومُہُ۔,,,9463,,
9464,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زُبَیْدٍ ، عَنْ عُمَارَۃَ ، عَنْ قَیْسِ بْنِ سَکَنٍ الأَسَدِیِّ ، عَنْ عَبْدِ اللہِ ، مِثْلَہُ ، إِلاَّ أَنَّہُ قَالَ : اُدْنُ فَکُلْ۔",,,9464,,
9465,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی یَحْیَی بْنُ عَبْدِ اللہِ بْنِ صَیْفِیٍّ ، أَنَّ عَمْرو بْنَ أَبِی یُوسُفَ ، أَخَا بَنِی نوفل ، أَخْبَرَہُ ، أَنَّہُ سَمِعَ مُعَاوِیَۃَ یَقُولُ عَلَی الْمِنْبَرِ: إنَّ یَوْمَ عَاشُورَائَ یَوْمُ عِیدٍ، فَمَنْ شَائَ صَامَ، وَقَدْ کَانَ یُصَامُ ، وَمَنْ شَائَ تَرَکَہُ ، وَلاَ حَرَجَ۔",,,9465,,
9466,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ عُمَرَ بْنِ الْوَلِیدِ ، قَالَ : سُئِلَ عِکْرِمَۃُ عَنْ صِیَامِ یَوْمِ عَاشُورَائَ وَیَوْمِ عَرَفَۃَ ؟ فَقَالَ : لاَ یَصْلُحُ لِرَجُلٍ یَصُومُ یَوْمًا یَرَی أَنَّہُ عَلَیْہِ وَاجِبٌ إِلاَّ رَمَضَانُ۔",,,9466,,
9467,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی بِشْرٍ ، قَالَ : سَمِعْتُ عَلِیًّا یَأْمُرُ بِصَوْمِ عَاشُورَائَ۔",,,9467,,
9468,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : أَخْبَرَنِی أَبُو ماویَّۃ ، قَالَ : سَمِعْتُ علیًّا یَقُولُ فِی صَوْمِ عَاشُورَاء : فَمَنْ کَانَ بَدَأَ فَلْیُتِمَّ ، وَمَنْ کَانَ أَکَلَ فَلْیَصُم۔",,,9468,,
9469,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطائَ ، عَنْ أَبِی الْخَلِیلِ ، عَنْ أَبِی قَتَادَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَوْمُ عَاشُورَائَ کَفَّارۃ سَنَۃٍ ، وَصَوْمُ یَوْمِ عَرَفَۃَ کَفَّارۃ سَنَتَیْن ؛ سَنَۃٍ مَاضِۃٍ ، وَسَنَۃٍ مُسْتَقْبَلَۃٍ۔ (نسائی 2809۔ احمد 5/307)",,,9469,,
9470,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدٍ ، سَمِعَ ابْنَ عَبَّاسٍ سئُلَ عَنْ صِیَامِ عَاشُورائَ ؟ فَقَالَ : مَا عَلِمْتُ أَنِی رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَامَ یَوْمًا قَطُّ ، یَطْلُبُ فَضْلَہُ عَنِ الأَیَامِ إِلاَّ ہَذَا الْیَوْمِ ، وَلاَ شَہْرًا إِلاَّ ہَذَا ، یَعْنِی رَمَضان۔ (بخاری 2006۔ مسلم 131)",,,9470,,
9471,حَدَّثَنَا زَیْدُ بْنُ حُبابٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ طَاووسٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَصُومُ قَبْلَہُ وَبَعْدَہُ یَوْمًا ، مَخَافَۃَ أَنْ یَفُوتَہُ۔,,,9471,,
9472,"حَدَّثَنَا وَکِیعُ بْنُ الجَّرَاح ، عَنْ حَاجِبِ بْن عُمَرَ ، عَنِ الحَکَم بْن الأَعْرَجِ ، قَالَ : انْتَہیتُ إِلی ابْنِ عَبَّاسٍ وَہُو مُتَوسِّدٌ رِدَائَہ فِی زَمزَم ، فَقُلتُ : أَخْبِرنِی عَنْ صَومِ عَاشورائَ ؟ فَقَالَ : إِذَا رَأَیْتَ ہِلالَ الْمُحَرَّم فاعْدُدْ، وَأَصبِحْ صَائِماً التَاسِع ، قُلْتُ : ہَکَذَا کَانَ مُحَمَّدٌ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَصُومُہُ ؟ قَالَ : نَعَمْ۔\n\n(مسلم 132۔ ترمذی 754)",,,9472,,
9473,"حَدَّثَنَا وَکِیعُ بْنُ الجَّرَاح ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ القَاسِم بْنِ عَبَّاسٍ ، عَنْ عَبْدِ اللہ بْنِ عُمَیرٍ ، عَنِ ابْنِ عَبَّاسٍ قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَئِن بَقَیتُ إِلی قَابِلٍ لأَصُومَنَّ التَاسِعَ ، یَعنی یَوْمَ عَاشوراء ۔ (مسلم 133۔ احمد 224)",,,9473,,
9474,"حَدَّثَنَا عَبْدُ الْوَہَّاب ، عَنْ أَیوب ، عَنْ أَبِی سُلَیْمان مَوْلَی یَحْیَی بْنِ یَعْمَُرَ ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ : یَوْمَ عَاشوراء صَبِیحتُہُ تَاسِعۃَ لَیْلَۃَ عَشْرٍ۔",,,9474,,
9475,"حَدَّثَنَا وَکِیعٌ ، وَابن نُمَیْرٍ ، عَنْ سَلِمَۃَ ، عَنِ الضَّحَّاک ، قَالَ : عَاشورائُ یَوْمُ التَّاسِع۔",,,9475,,
9476,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ قَالاَ : عَاشُورَائُ یَوْمُ الْعَاشِرِ",,,9476,,
9477,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ ، وَعِکْرِمَۃَ قَالُوا : عَاشُورَائُ یَوْمُ الْعَاشِرِ",,,9477,,
9478,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : یَوْمُ الْعَاشِرِ۔",,,9478,,
9479,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْجُرَیْرِیِّ ، عَنِ الْحَکَمِ بْنِ الأَعْرَجِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : ہُوَ یَوْمُ التَّاسِعِ۔",,,9479,,
9480,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنِی ابْنُ أَبِی ذِئْبٍ ، عَنْ شُعْبَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَصُومُ یَوْمَ عَاشُورَائَ فِی السَّفَرِ ، وَیُوَالِی بَیْنَ الْیَوْمَیْنِ مَخَافَۃَ أَنْ یَفُوتَہُ۔",,,9480,,
9481,"حَدَّثَنَا یَزِیدُ ، عَنِ الْجُرَیْرِیِّ ، عَنِ الْحَسَنِ ، قَالَ : عَاشُورَائُ یَوْمُ الْعَاشِرِ۔",,,9481,,
9482,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، عَنْ عَائِشَۃَ قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُقَبِّلُ فِی شَہْرِ الصَّوْمِ۔ (مسلم 778۔ ابوداؤد 2375)",,,9482,,
9483,"حَدَّثَنَا شَرِیکٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُقَبِّلُ بَعْضَ نِسَائِہِ وَہُوَ صَائِمٌ ، فَضَحِکَتْ ، فَظَنَنَّا أَنَّہَا ہِیَ۔ (مسلم 69)",,,9483,,
9484,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَد ، وَعَلْقَمَۃَ ، عَنْ عَائِشَۃَ قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُقَبِّلُ وَہُوَ صَائِمٌ ، وَیُبَاشِرُ وَہُوَ صَائِمٌ ، وَلَکِنَّہُ کَانَ أَمْلَکَکُمْ لأرْبہِ۔ (بخاری 1927۔ مسلم 68)",,,9484,,
9485,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ قَابُوسَ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : لاَ بَأْسَ بِالْقُبْلَۃِ لِلصَّائِمِ۔",,,9485,,
9486,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ مُبَشِّرٍ ، عَنْ زَیْدٍ أَبِی عَتَّاب ، قَالَ : سُئِلَ سَعْدٌ عَنِ الْقُبْلَۃِ لِلصَّائِمِ ؟ فَقَالَ: إنِّی لآخذْتہُ مِنْہَا وَأَنَا صَائِمٌ۔",,,9486,,
9487,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ أَبِی الْمُتَوَکِّلِ ، عَنْ أَبِی سَعِیدٍ ؛ أَنَّہُ سُئِلَ عَنِ الْقُبْلَۃِ لِلصَّائِمِ ؟ فَقَالَ : لاَ بَأْسَ بِہَا ، مَا لَمْ یَعْدُ ذَلِکَ۔",,,9487,,
9488,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عن أَبِی الضُّحَی ، عَنْ شُتَیْرِ بْنِ شَکَلٍ ، عَنْ حَفْصَۃَ بِنْتِ عُمَرَ قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُقَبِّلُ وَہُوَ صَائِمٌ۔ (مسلم 779۔ طبرانی 393)",,,9488,,
9489,"حَدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، عَنْ عَبْدِ اللہِ بْنِ فَرُّوخَ ، عَنْ أُمِّ سَلَمَۃَ قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُقَبِّلُنِی وَأَنَا صَائِمَۃٌ ، وَہُوَ صَائِمٌ۔ (طبرانی 654۔ احمد 6/320)",,,9489,,
9490,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ حَبِیبِ بْنِ شِہَابٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : سُئِلَ عَنِ الْقُبْلَۃِ لِلصَّائِمِ ؟ فَقَالَ : إنِّی أُحِبّ أَنْ أَرفَّ شفَتَیْہَا وَأَنَا صَائِمٌ۔",,,9490,,
9491,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ زَیْنَبَ بِنْتِ أُمِّ سَلَمَۃَ ، عَنْ أُمِّ سَلَمَۃَ قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُقَبِّلُہَا وَہُوَ صَائِمٌ۔",,,9491,,
9492,"حَدَّثَنَا حَفْصٌ، عَنْ عَبْدِالْمَلِکِ، عَنْ عَطَائٍ، عَنِ ابْنِ عَبَّاسٍ؛ أَنَّہُ سُئِلَ عَنِ الْقُبْلَۃِ لِلصَّائِمِ؟ فَقَالَ: لاَ بَأْسَ بِہَا۔",,,9492,,
9493,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنْ مُوَرِّقٍ ، قَالَ : سَأَلْتُ ابْنَ عَبَّاسٍ عَنِ الْقُبْلَۃِ لِلصَّائِمِ ؟ فَرَخَّصَ فِیہَا۔",,,9493,,
9494,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : سَأَلْتُ عِکْرِمَۃَ ، وَالشَّعْبِیَّ عَنِ الْقُبْلَۃِ وَالْمُبَاشَرَۃِ لِلصَّائِمِ ؟ فَرَخَّصَا فِیہِمَا۔",,,9494,,
9495,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الْقُبْلَۃِ لِلصَّائِمِ ؟ فَقَالَ : لاَ بَأْسَ بِہَا ، وَإِنَّہَا لَبَرِیدُ سُوئٍ۔",,,9495,,
9496,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْوَلِیدِ بْنِ عَبْدِ اللہِ بْنِ جُمَیْعٍ ، قَالَ : سَأَلْتُ أبا سَلَمَۃَ عَنِ الْقُبْلَۃِ لِلصَّائِمِ ؟ فَقَالَ : إنِّی لأُقَبِّلُ الْکَلْبِیَّۃَ وَأَنَا صَائِمٌ۔",,,9496,,
9497,"حَدَّثَنَا وَکِیعٌ، عَنْ زَکَرِیَّا، عَنِ الْعَبَّاسِ بْنِ ذُرَیْحٍ ، عَنْ عَامِرٍ ، عَنْ مُحَمَّدِ بْنِ الأَشْعَثِ ، عَنْ عَائِشَۃَ قَالَتْ: کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یَمْتَنِعُ مِنْ وَجْہِی وَأَنَا صَائِمَۃٌ۔ (احمد 6/213)",,,9497,,
9498,"حَدَّثَنَا شَبَابَۃُ ، عَنْ لَیْثٍ ، عَنْ بُکَیْرِ بْنِ الأَشَجِّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ سَعِیدٍ الأَنْصَارِیِّ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ، قَالَ : ہَشَشْتُ إلَی الْمَرْأَۃِ فَقَبَّلْتُہَا وَأَنَا صَائِمٌ ، قَالَ : فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَرَأَیْتَ لَوْ تَمَضْمَضْتَ بِمَائٍ وَأَنْتَ صَائِمٌ ؟ قَالَ : قُلْتُ : لاَ بَأْسَ ، قَالَ : فَفِیمَ ؟ (ابوداؤد 2377۔ احمد 1/52)",,,9498,,
9499,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مِسْعَرٌ قَالَ : حَدَّثَنَا سَعِیدُ بْنُ مَرْدانبۃ ، عَنْ أَبِی کَثِیرٍ ، عَنْ أُمِّ سَلَمَۃَ زَوْجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہَا قَالَتْ لَہُ : لَوْ دَنَوْت ، لَوْ قَبَّلْت ، وَکَانَ تَزَوَّجَ فِی رَمَضَانَ۔",,,9499,,
9500,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَبِی بَکْرٍ بْنِ مُحَمَّدٍ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْدِ اللہِ بْنِ عُمَرَ؛ أنَّ عَاتِکَۃَ بِنْتَ زَیْدٍ امْرَأَۃَ عُمَرَ بْنِ الْخَطَّابِ قَبَّلَتْہُ وَہُوَ صَائِمٌ ، فَلَمْ یَنْہَہَا۔",,,9500,,
9501,"حَدَّثَنَا حُمَیْدٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ أَبِیہِ ، عَنِ الشَّعْبِیِّ ، عَنْ مُسْلِمِ بْنِ حَیَّانَ ، عَنْ مَسْرُوقٍ ؛ فِی الْقُبْلَۃِ لِلصَّائِمِ ، فَقَالَ : مَا أُبَالِی قَبَّلْتُہَا ، أَوْ قَبَّلْتُ یَدِی۔",,,9501,,
9502,حَدَّثَنَا وَکِیعٌ، عَنِ ابْنِ أَبِی ذِئْبٍ، عَنِ الزُّہْرِیِّ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ؛ أَنَّ عُمَرَ نَہَی عَنِ الْقُبْلَۃِ لِلصَّائِمِ۔,,,9502,,
9503,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عُبَیْدِ بْنِ عَمْرٍو قَالَ : قَالَ رَجُلٌ لِعَلِیٍّ : أَیُقَبِّلُ الرَّجُلُ امْرَأَتَہُ وَہُوَ صَائِمٌ ؟ فَقَالَ عَلِیٌّ : وَمَا إرْبُکَ إلَی خُلُوفِ فَمِ امْرَأَتِکَ ؟",,,9503,,
9504,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنِ الْہَزْہَازِ ؛ أَنَّ رَجُلاً لَقِیَ ابْنَ مَسْعُودٍ وَہُوَ بِالتَّمَّارِینِ ، فَسَأَلَہُ عَنْ صَائِمٍ قَبَّلَ ؟ فَقَالَ : أَفْطَرَ۔",,,9504,,
9505,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ زَاذَانَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : أَفَلا تُقَبِِّل جَمْرَۃ",,,9505,,
9506,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنْ مُوَرِّق قَالَ : سَأَلتُ ابْنَ عُمَرَ عَنِ الْقُبْلَۃِ لِلصَّائِمِ ؟ فَنَہَی عَنْہَا۔",,,9506,,
9507,حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُقَبِّلَ الرَّجُلُ امْرَأَتَہُ وَہُوَ صَائِمٌ۔,,,9507,,
9508,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : سَأَلْتُ ابْنَ مُغَفَّلٍ ؟ فَکَرِہَہَا۔",,,9508,,
9509,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ (ح) وَجَرِیرٌ ، وَوَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، کِلاَہُمَا عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ، قَالَ : سُئِلَ عَنِ الْقُبْلَۃِ لِلصَّائِمِ ؟ فَقَالَ : یَتَّقِی اللَّہَ وَلاَ یَعُودُ۔",,,9509,,
9510,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ قَالَ فِی الْقُبْلَۃِ لِلصَّائِمِ: یَنْقُصُ صِیَامہُ ، وَلاَ یُفْطِرُ بِہَا۔",,,9510,,
9511,"حَدَّثَنَا شَبَابَۃُ ، عَنْ ہِشَامِ بْنِ الْغَازِ ، قَالَ : سَمِعْتُ مَکْحُولاً ، وَأَتَاہُ رَجُلٌ شَابٌّ ، فَقَالَ : إنِّی أُقَبِّلُ فِی شَہْرِ رَمَضَانَ وَأَنَا صَائِمٌ ، فَقَالَ : یَا بُنَیَّ ، أَمَّا أَنَا فَأَفْعَلُ ذَلِکَ ، وَأَمَّا أَنْتَ فَلاَ تَفْعَلْہُ۔",,,9511,,
9512,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ ابْنِ شُبْرُمَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : الْقُبْلَۃُ تَنْقُضُ الْوُضُوئَ ، وَتَجْرَحُ الصَّوْمَ۔",,,9512,,
9513,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنْ حَبِیبٍ، قَالَ: سَأَلْتُ أَبَا قِلاَبَۃَ عَنِ الْقُبْلَۃِ لِلصَّائِمِ ؟ قَالَ: لاَ تُقَبِّلْ وَأَنْتَ صَائِمٌ۔",,,9513,,
9514,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ؛ أَنَّہُ سُئِلَ عَنِ الْقُبْلَۃِ لِلصَّائِمِ ؟ فَقَالَ : مَا تَصْنَعُ بِخُلُوفِ فِیہَا ؟",,,9514,,
9515,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ یَکْرَہُ الْقُبْلَۃَ لِلصَّائِمِ۔",,,9515,,
9516,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُمَرِ بْنِ حَمْزَۃَ ، قَالَ : أَخْبَرَنِی سَالِمٌ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ عُمَر : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْمَنَامِ ، فَرَأَیْتُہُ لاَ یَنْظُرْنِی ، فَقُلْتُ : یَا رَسُولَ اللہِ ، مَا شَأْنِی ؟ فَقَالَ : أَلَسْتَ الَّذِی تُقَبِّلُ وَأَنْتَ صَائِمٌ ؟ قَالَ : فَوَالَّذِی بَعَثَکَ بِالْحَقِّ ، لاَ أُقَبِّلُ بَعْدَہَا وَأَنَا صَائِمٌ۔",,,9516,,
9517,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ سَالِمِ بْنِ أَبِی حَفْصَۃَ ، عَنْ أَبِی یَعْلَی ، عَنْ مُحَمَّدِ بْنِ الْحَنَفِیَّۃِ ، قَالَ : إنَّمَا الصَّوْمُ مِنَ الشَّہْوَۃِ ، وَالْقُبْلَۃُ مِنَ الشَّہْوَۃِ۔",,,9517,,
9518,"حَدَّثَنَا شَبَابَۃُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ ثَعْلَبَۃَ بْنِ عَبْدِ اللہِ بْنِ أَبِی صُعَیْرٍ ، قَالَ : رَأَیْتُ أَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُمْ یَنْہَوْنَ عَنِ الْقُبْلَۃِ لِلصَّائِمِ۔",,,9518,,
9519,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ زَیْدِ بْنِ جُبَیْرٍ ، عَنْ أَبِی یَزِیدَ الضَّنِّی ، عَنْ مَیْمُونَۃَ مَوْلاَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ عَنْ صَائِمٍ قَبَّلَ ؟ فَقَالَ : أَفْطَرَ۔ (احمد 6/463۔ طبرانی 57)",,,9519,,
9520,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ إبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، عَنْ مَسْرُوقٍ ؛ أَنَّہُ سُئِلَ عَنِ الْقُبْلَۃِ لِلصَّائِمِ ؟ فَقَالَ : اللَّیْلُ قَرِیبٌ۔",,,9520,,
9521,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، وَالأَسْوَد ، عَنْ عَائِشَۃَ قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُبَاشِرُ وَہُوَ صَائِمٌ ، وَلَکِنَّہُ کَانَ أَمْلَکَکُمْ لأَرْبِہِ۔",,,9521,,
9522,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ سَالِمٍ الأَوْسِیِّ ، قَالَ : قَالَ رَجُلٌ لِسَعْدٍ : یَا أَبَا إِسْحَاقَ ، أَتُبَاشِرُ وَأَنْتَ صَائِمٌ ؟ قَالَ : نَعَمْ ، وَآخُذُ بِجَہَازِہَا۔",,,9522,,
9523,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہر ، ووَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، عَنْ أَبِی مَیْسَرَۃَ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : کَانَ یُبَاشِرُ امْرَأَتَہُ بِنِصْفِ النَّہَارِ وَہُوَ صَائِمٌ۔",,,9523,,
9524,"حَدَّثَنَا حَفْصٌ ، عَنْ دَاوُدَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَعْرَابِیٌّ أَتَاہُ فَسَأَلَہُ ؟ فَرَخَّصَ لَہُ فِی الْقُبْلَۃِ وَالْمُبَاشَرَۃِ وَوَضْعِ الْیَدِ ، مَا لَمْ یَعْدُہ إلَی غَیْرِہِ۔",,,9524,,
9525,"حَدَّثَنَا وَکِیعٌ، عَنْ أَبِی مَکِینٍ، عَنْ عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لاَ بَأْسَ لِلشَّیْخِ أَنْ یُبَاشِرَ، یَعْنِی وَہُوَ صَائِمٌ۔",,,9525,,
9526,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ الشَّیْبَانِیِّ ، قَالَ : سَأَلْتُ عِکْرِمَۃَ ، وَالشَّعْبِیَّ عَنِ الْمُبَاشَرَۃِ ؟ فَرَخَّصَا فِیہَا ، وَسَأَلْتُ ابْنَ مُغَفَّلٍ ؟ فَکَرِہَہَا۔",,,9526,,
9527,"حَدَّثَنَا عَبْدَۃ بْنُ سُلَیْمَانَ ، عَنْ مُجَالِدٍ ، عَنْ وَبَرَۃَ ، قَالَ : جَائَ رَجُلٌ إلَی ابْنِ عُمَرَ ، فَقَالَ : أُبَاشِرُ امْرَأَتِی وَأَنَا صَائِمٌ ؟ فَقَالَ : لاَ ، ثُمَّ جَائَ آخَرُ ، فَقَالَ : أُبَاشِرُ امْرَأَتِی وَأَنَا صَائِمٌ ؟ قَالَ : نَعَمْ ، فَقِیلَ لَہُ : یَا أَبَا عَبْدِ الرَّحْمَنِ ، قُلْتَ لِہَذَا نَعَمْ ، وَقُلْتَ لِہَذَا لاَ ؟ فَقَالَ : إنَّ ہَذَا شَیْخٌ وَہَذَا شَابٌّ۔",,,9527,,
9528,"حَدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : قِیلَ لِاِبْنِ عَبَّاسٍ : الْمُبَاشَرَۃُ ؟ قَالَ : أَعِفُّوا صَوْمَکُمْ۔",,,9528,,
9529,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَکْرَہُ الْقُبْلَۃَ وَالْمُبَاشَرَۃَ۔,,,9529,,
9530,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، قَالَ : أَخْبَرَنَا حَنْظَلَۃُ بْنُ سَبْرَۃَ بْنِ الْمُسَیَّبِ بْنِ نَجَبَۃَ الْفَزَارِیِّ ، عَنْ عَمَّتِہِ جُمَانَۃَ بِنْتِ الْمُسَیَّبِ ، وَکَانَتْ عِنْدَ حُذَیْفَۃَ بْنِ الْیَمَانِ ، فَکَانَ إذَا صَلَّی الْفَجْرَ فِی رَمَضَانَ ، دَخَلَ مَعَہَا فِی لِحَافِہَا فَیُوَلِّیہَا ظَہْرَہُ لِیَسْتَدْفِئُ بِقُرْبِہَا ، وَلاَ یُقْبِلُ عَلَیْہَا۔",,,9530,,
9531,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی الزِّنَادِ ، عَنِ الأَعْرَجِ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّہُ قَالَ : إذَا دُعِیَ أَحَدُکُمْ إلَی طَعَامٍ وَہُوَ صَائِمٌ فَلْیَقُلْ : إِنِّی صَائِمٌ۔",,,9531,,
9532,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : دَخَلْتُ عَلَی قَیْسِ بْنِ أَبِی حَازِمٍ فَدَعَا لِی بِشَرَابٍ ، فَقَالَ : اشْرَبْ ، فَقُلْتُ : لاَ أُرِیدُ ، قَالَ : صَائِمٌ أَنْتَ ؟ قُلْتُ : نَعَمْ ، قَالَ : فَإِنِّی سَمِعْتُ عَبْدَ اللہِ یَقُولُ : إذَا عُرِضَ عَلَی أَحَدِکُمْ طَعَامٌ ، أَوْ شَرَابٌ وَہُوَ صَائِمٌ ، فَلْیَقُلْ : إنِّی صَائِمٌ۔",,,9532,,
9533,"حَدَّثَنَا وَکِیعٌ ، وَیَزِیدُ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا سُئِلَ أَحَدُکُمْ وَہُوَ صَائِمٌ ، فَلْیَقُلْ : إنِّی صَائِمٌ۔",,,9533,,
9534,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ ابْنُ عُمَرَ إذَا دُعِیَ إلَی طَعَامٍ وَہُوَ صَائِمٌ أَجَابَ ، فَإِذَا جَاؤُوا بِالْمَائِدَۃِ وَعَلَیْہَا الطَّعَامُ مَدَّ یَدَہُ ، ثُمَّ قَالَ : خُذُوا بِسْمِ اللہِ ، فَإِذَا أَہْوَی الْقَوْمُ کَفَّ یَدَہُ۔",,,9534,,
9535,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ قَیْسِ بْنِ أَبِی حَازِمٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا عُرِضَ عَلَی أَحَدِکُمْ طَعَامٌ ، أَوْ شَرَابٌ وَہُوَ صَائِمٌ فَلْیَقُلْ : إنِّی صَائِمٌ۔",,,9535,,
9536,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ ثَابِتٍ ، قَالَ : أُتِیَ أَنَسٌ بِطَعَامٍ ، فَقَالَ لِی : اُدْنُ ، فَقُلْتُ : لاَ أَطْعَمُ ، فَقَالَ : ما : لاَ أَطْعَمُ ؟ قُلْ : إنِّی صَائِمٌ۔",,,9536,,
9537,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَبِی الْمُہَزِّمِ ، قَالَ : قَالَ أَبُو ہُرَیْرَۃَ : إذَا سُئِلَ أَحَدُکُمْ : صَائِمٌ أَنْتَ ؟ فَلْیَقُلْ : إنِّی صَائِمٌ ، فَأَمَّا الْمُؤْمِنُ فَیَدْعُو لَہُ بِخَیْرٍ ، وَأَمَّا الْمُنَافِقُ فَیَقُولُ : مُرَائِی۔",,,9537,,
9538,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا عِمْرَانُ بْنُ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : دَخَلْتُ عَلَیْہِ وَہُوَ یَأْکُلُ ، فَقَالَ : اُدْنُ فَکُلْ ، قَالَ : قُلْتُ : إنِّی صَائِمٌ ، قَالَ : فَلَعَلَّک مِمَّنْ یَزْعُمُ أَنَّہُ صَائِمٌ وَلَیْسَ بِصَائِمٍ ، قُلْتُ : سُبْحَانَ اللہِ ، قَالَ : قَدْ کَانَ مَنْ ہُوَ خَیْرٌ مِنْک یَصُومُ ثَلاَثَۃَ أَیَامٍ مِنْ کُلِّ شَہْرٍ ، ثُمَّ یَقُولُ : إنِّی صَائِمٌ۔",,,9538,,
9539,"حَدَّثَنَا أَبُو الأَحْوَصِِ سَلاَّمُ بْنِ سُلَیْمٍ ، عَنْ أَبِی إِسْحَاقَ، قَالَ: رَأَیْتُ الشَّعْبِیَّ یَدْخُلُ الْحَمَّامَ وَہُوَ صَائِمٌ۔",,,9539,,
9540,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَاصِمٍ ، قَالَ : سَأَلْتُ أَبَا الْعَالِیَۃِ : أَدْخُلُ الْحَمَّامَ وَأَنَا صَائِمٌ ؟ قَالَ : أَتُحِبُّ أَنْ تَنْظُرَ إلَی عَوْرتکَ وَأَنْتَ صَائِمٌ ؟ قَالَ : قُلْتُ : أَدْخُلُ الْحَمَّامَ بِمِئْزَرٍ ؟ قَالَ : أَتُحِبُّ أَنْ تَنْظُرَ إلَی عَوْرَۃِ غَیْرِکَ وَأَنْتَ صَائِمٌ ؟ قَالَ : قُلْتُ : لاَ۔",,,9540,,
9541,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : لاَ تَدْخُلِ الْحَمَّامَ وَأَنْتَ صَائِمٌ۔",,,9541,,
9542,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یَحْیَی بْنِ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ الْہِلاَلَ ، ہِلاَلَ الْفِطْرِ قَرِیبًا مِنْ صَلاَۃِ الظُّہْرِ ، فَأَفْطَرَ نَاسٌ ، فَأَتَیْنَا أَنَسَ بْنَ مَالِکٍ ، فَذَکَرْنَا لَہُ رُؤْیَۃَ الْہِلاَلِ وَإِفْطَارَ مَنْ أَفْطَرَ ، قَالَ : وَأَمَّا أَنَا فَمُتِمّ یَوْمِی ہَذَا إلَی اللَّیْلِ۔",,,9542,,
9543,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ؛ فِی الْہِلاَلِ یُرَی بِالنَّہَارِ : لاَ تُفْطِرُوا حَتَّی تَرَوْہُ مِنْ حَیْثُ یُرَی۔",,,9543,,
9544,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ الزِّبْرِقَانِ ، قَالَ : أَفْطَرَ النَّاسُ ، فَأَتَیْت أَبَا وَائِلٍ ، فَقُلْتُ : إنِّی رَأَیْتُ الْہِلاَلَ نِصْفَ النَّہَارِ ، فَقَالَ : {أَتِمُّوا الصِّیَامَ إلَی اللَّیْلِ}۔",,,9544,,
9545,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ؛ أَنَّ النَّاسَ رَأَوْا ہِلاَلَ الْفِطْرِ حِینَ زَاغَتِ الشَّمْسُ ، فَأَفْطَرَ بَعْضُہُمْ ، فَذَکَرْتُ ذَلِکَ لِسَعِیدِ بْنِ الْمُسَیَّبِ ، فَقَالَ : رَآہُ النَّاسُ فِی زَمَنِ عُثْمَانَ فَأَفْطَرَ بَعْضُہُمْ ، فَقَامَ عُثْمَانُ فَقَالَ : أَمَّا أَنَا فَمُتِمّ صِیَامِی إلَی اللَّیْلِ ، قَالَ : وَرُئِیَ فِی زَمَنِ مَرْوَانَ ، فَتَوَعَّدَ مَرْوَانُ مَنْ أَفْطَرَ ، قَالَ سَعِیدٌ : فَأَصَابَ مَرْوَانُ۔",,,9545,,
9546,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : قَالَ عَبْدُ اللہِ : إذَا رَأَیْتُمُ الْہِلاَلَ نَہَارًا فَلاَ تُفْطِرُوا ، فَإِنَّ مَجْرَاہُ فِی السَّمَائِ ، لَعَلَّہُ أَنْ یَکُونَ أَہَلَّ سَاعَتئذ۔",,,9546,,
9547,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنْ أَبِی الْحَسَنِ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا رَأَیْتُمُ الْہِلاَلَ أَوَّلَ النَّہَارِ فَلاَ تُفْطِرُوا ، وَإِذَا رَأَیْتُمُوہُ مِنْ آخِرِ النَّہَارِ فَأَفْطِرُوا۔",,,9547,,
9548,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ سُفْیَانَ ، عَنِ الرُّکَیْنِ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا مَعَ سَلْمَانَ بْنِ رَبِیعَۃَ بِبَلنْجَرَ ، فَرَأَیْنَا ہِلاَلَ شَوَّالٍ یَوْمَ تِسْعٍ وَعِشْرِینَ ضُحًی ، فَقَالَ : أَرِنِیہِ ، فَأَرَیْتُہُ ، فَأَمَرَ النَّاسَ فَأَفْطَرُوا۔",,,9548,,
9549,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ عُمَرَ بْنِ فَرُّوخَ ، عَنْ صَالِحٍ الدَّہَّانِ ، قَالَ : رُئِیَ الْہِلاَلُ آخِرَ رَمَضَانَ نَہَارًا ، فَوَقَعَ النَّاسُ فِی الطَّعَامِ وَالشَّرَابِ ، وَنَفَرٌ مِنَ الأَزْدِ مُعْتَکِفِینَ ، فَقَالُوا : یَا صَالِحُ ، أَنْتَ رَسُولُنَا إلَی جَابِرِ بْنِ زَیْدٍ ، فَأَتَیْتُ جَابِرَ بْنَ زَیْدٍ فَذَکَرْت ذَلِکَ لَہُ ، فَقَالَ : أَنْتَ مِمَّنْ رَأَیْتَہُ ؟ قُلْتُ : نَعَمْ ، قَالَ : أَبَیْنَ یَدَیِ الشَّمْسِ رَأَیْتَہُ ، أَمْ رَأَیْتَہُ خَلْفَہَا ؟ قُلْتُ : لاَ ، بَیْنَ یَدَیْہَا ، قَالَ : فَإِنَّ یَوْمَکُمْ ہَذَا مِنْ رَمَضَانَ ، إنَّمَا رَأَیْتُمُوہُ فِی مَسِیرِہِ ، فَمُرْ أَصْحَابَک یُتِمُّونَ صَوْمَہُمْ وَاعْتِکَافَہُمْ۔",,,9549,,
9550,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عُتْبَۃُ بْنُ فَرْقَدٍ غَائِبًا بِالسَّوَادِ ، فَأَبْصَرُوا الْہِلاَلَ مِنْ آخِرِ النَّہَارِ ، فَأَفْطَرُوا ، فَبَلَغَ ذَلِکَ عُمَرَ ، فَکَتَبَ إلَیْہِ : إِنَّ الْہِلاَلَ إذَا رُئِیَ مِنْ أَوَّلِ النَّہَارِ ، فَإِنَّہُ لِلْیَوْمِ الْمَاضِی ، فَأَفْطِرُوا ، وَإِذَا رُئِیَ مِنْ آخِرِ النَّہَارِ ، فَإِنَّہُ لِلْیَوْمِ الْجَائِی فَأَتِمُّوا الصِّیَامَ۔",,,9550,,
9551,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکر ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ: کَانَ عَطَائٌ یَقُولُ: إِنْ رُئِیَ ہِلاَلُ شَوَّالٍ نَہَارًا ، فَلاَ تُفْطِرُوا، وَیَتْلُو : {ثُمَّ أَتِمُّوا الصِّیَامَ إلَی اللَّیْلِ}۔",,,9551,,
9552,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الْحَسَنِ بْنِ عُبَیدِ اللہِ ، قَالَ : رَأَیْتُ الْہِلاَلَ قَبْلَ نِصْفِ النَّہَارِ ، فَأَتَیْتُ أَبَا بُرْدَۃَ ، فَأَمَرَنِی أَنْ أُتِمَّ صَوْمِی۔",,,9552,,
9553,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی وَائِلٍ ، قَالَ : أَتَانَا کِتَابُ عُمَرَ وَنَحْنُ بِخَانقِینَ ؛ أَنَّ الأَہِلَّۃَ بَعْضُہَا أَکْبَرُ مِنْ بَعْضٍ ، فَإِذَا رَأَیْتُمُ الْہِلاَلَ نَہَارًا فَلاَ تُفْطِرُوا ، حَتَّی یَشْہَدَ رَجُلاَنِ مُسْلِمَانِ أَنَّہُمَا أَہَلاَّہُ بِالأَمْسِ۔",,,9553,,
9554,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ أَبِی بِشْرٍ ، عَنْ أَبِی عُمَیْرِ بْنِ أَنَسٍ ، قَالَ : حَدَّثَنِی عُمُومَتِی مِنَ الأَنْصَارِ قَالُوا : أُغمِیَ عَلَیْنَا ہِلاَلُ شَوَّالٍ ، فَأَصْبَحْنَا صِیاماً ، فَجَائَ رَکْبٌ آخِرَ النَّہَارِ ، فَشَہِدُوا عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّہُمْ رَأَوُا الْہِلاَلَ بِالأَمْسِ ، فَأَمَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ النَّاسَ أَنْ یُفْطِرُوا ، وَیَخْرُجُوا إلَی عِیدِہِمْ مِنَ الْغَدِ۔ (ابوداؤد 1150۔ احمد 5/57)",,,9554,,
9555,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ أَبِی یَعْفُورٍ ، عَنْ أَبِیہِ ، قَالَ : رُئِیَ ہِلاَلُ رَمَضَانَ وَالْمُغِیرَۃُ بن شُعْبَۃَ عَلَی الْکُوفَۃِ ، فَلَم یَخْرُجْ حَتَّی کَانَ مِنَ الْغَدِ ، فَخَرَجَ فَخَطَبَ النَّاسَ عَلَی بَعِیرٍ ، ثُمَّ انْصَرَفَ۔",,,9555,,
9556,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : شُہِدَ عِنْدَ ابْنِ عُمَرَ أَنَّہُمْ رَأَوُا الْہِلاَلَ ، فَقَالَ : اُخْرُجُوا إلَی عِیدِکُمْ مِنَ الْغَدِ ، وَقَدْ مَضَی مِنَ النَّہَارِ مَا شَائَ اللَّہُ۔",,,9556,,
9557,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ أَعْرَابِیًّا شَہِدَ عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی رُؤْیَۃِ الْہِلاَلِ ، فَقَالَ : أَتَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ وَأَنِّی رَسُولُ اللہِ ؟ قَالَ : نَعَمْ ، قَالَ : فَأُمِرَ النَّاسُ أَنْ یَصُومُوا۔ (ابوداؤد 2334۔ نسائی 2424)",,,9557,,
9558,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفیان ، عَنْ عَبْدِ الأَعْلَی ، عَنِ ابْنِ أَبِی لَیْلَی ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ أَجَازَ شَہَادَۃَ رَجُلٍ فِی الْہِلاَلِ۔,,,9558,,
9559,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، قَالَ : شَہِدْتُ الْمَدِینَۃَ فِی ہِلاَلِ صَوْمٍ ، أَوْ إفْطَارٍ ، فَلَمْ یَشْہَدْ عَلَی الْہِلاَلِ إِلاَّ رَجُلٌ ، فَأَمَرَہُمُ ابْنُ عُمَرَ فَقَبِلُوا شَہَادَتَہُ۔",,,9559,,
9560,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جَائَ أَعْرَابِیٌّ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، إنِّی رَأَیْتُ الْہِلاَلَ اللَّیْلَۃَ ، قَالَ : تَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ، وَأَنَّ مُحَمَّدًا عبْدُہُ وَرَسُولُہُ ؟ قَالَ : نَعَمْ ، قَالَ : یَا بِلاَلُ ، نَادِ فِی النَّاسِ ، فَلیَصُومُوا غَدًا۔ (ترمذی 691۔ ابوداؤد 233)",,,9560,,
9561,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : قَدِمَ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاَن وَافِدَان أَعْرَابِیَّان ، فَقَالَ لَہُمَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَمُسْلِمَانِ أَنْتُمَا ؟ قَالاَ : نَعَمْ ، فَقَالَ لَہُمَا : أَہْلَلْتُمَا ؟ قَالاَ : نَعَمْ ، فَأَمَرَ النَّاسَ فَفطِرُوا ، أَوْ صَامُوا۔ (دارقطنی 167)",,,9561,,
9562,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ فِی الْہِلاَلِ قَالَ : إذَا شَہِدَ رَجُلاَنِ ذَوَا عَدْلٍ عَلَی رُؤْیَۃِ الْہِلاَلِ فَأَفْطِرُوا۔",,,9562,,
9563,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : أَبَی عُثْمَانُ أَنْ یُجِیزَ شَہَادَۃَ ہَاشِمِ بْنِ عُتبۃَ ، أَوْ غَیْرِہِ ، عَلَی رُؤْیَۃِ الْہِلاَلِ۔",,,9563,,
9564,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ فِی الرَّجُلِ یَرَی الْہِلاَلَ وَحْدَہُ قَبْلَ النَّاسِ ، قَالَ : لاَ یَصُومُ إِلاَّ مَعَ النَّاسِ ، وَلاَ یُفْطِرُ إِلاَّ مَعَ النَّاسِ۔",,,9564,,
9565,"حَدَّثَنَا الضَّحَّاکُ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ؛ فِی رَجُلٍ شَہِدَ عَلَی رُؤْیَۃِ الْہِلاَلِ وَحْدَہُ، قَالَ: لاَ یُلْتَفَتُ إلَیْہِ۔",,,9565,,
9566,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی وَائِلٍ ، قَالَ : کُنَّا بِخَانِقِینَ ، فَأَہْلَلْنَا ہِلاَلَ رَمَضَانَ ، فَمِنَّا مَنْ صَامَ وَمِنَّا مَنْ أَفْطَرَ ، فَأَتَانَا کِتَابُ عُمَرَ : أَنَّ الأَہِلَّۃَ بَعْضُہَا أَکْبَرُ مِنْ بَعْضٍ ، فَإِذَا رَأَیْتُمُ الْہِلاَلَ نَہَارًا فَلاَ تُفْطِرُوا ، إِلاَّ أَنْ یَشْہَدَ رَجُلاَنِ مُسْلِمَانِ أَنَّہُمَا أَہَلاَّہُ بِالأَمْسِ۔",,,9566,,
9567,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَمْرِو بْنِ مُہَاجِرٍ ؛ أَنَّ مُحَمَّدَ بْنَ سُوَیْد الْفِہْرِیَّ أَفْطَرَ ، أَوْ ضَحَّی قَبْلَ النَّاسِ بِیَوْمٍ ، فَکَتَبَ إلَیْہِ عُمَرُ بْنُ عَبْدِالْعَزِیزِ: مَا حَمَلَک عَلَی أَنْ أَفْطَرْت قَبْلَ النَّاسِ؟ فَکَتَبَ إلَیْہِ مُحَمَّدٌ: إِنَّہُ شَہِدَ عِنْدِی حِزَامُ بْنُ حَکِیمٍ الْقُرَشِیُّ أَنَّہُ رَأَی الْہِلاَلَ ، فَکَتَبَ إلَیْہِ عُمَرُ: أَوْ أَحَدُ النَّاسِ، أَوْ ذُو الْیَدَیْنِ: ہُوَ۔",,,9567,,
9568,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ أَنَّ قَوْمًا شَہِدُوا عَلَی ہِلاَلِ رَمَضَانَ بَعْدَ مَا أَصْبَحَ النَّاسُ ، فَقَالَ : مَنْ لَمْ یَأْکُلْ فَلْیُتِمَّ صَوْمَہُ ، وَمَنْ أَکَلَ فَلْیَصُمْ بَقِیَّۃَ یَوْمِہِ۔",,,9568,,
9569,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : أَرَأَیْتَ إِنْ أَصْبَحَ أَہْلُ مَکَّۃَ مُفْطِرِینَ ، أَوْ رَجُلٌ ، أَوْ رَجُلاَنِ ، ثُمَّ جَائَہُمْ أَنْ قَدْ رُئِیَ الْہِلاَلُ ، فَجَائَہُمُ الْخَبَرُ بِذَلِکَ مِنْ أَوَّلِ النَّہَارِ ، أَوْ مِنْ آخِرِ النَّہَارِ، کَانُوا یَصُومُونَ بَقِیَّۃَ یَوْمِہِمْ ، أَوْ یَقْضُونَہُ بَعْدُ ؟ قَالَ : یَأْکُلُونَ وَیَشْرَبُونَ إِنْ شَاؤُوا ، وَلَمْ یُوجِبْ عَلَیْہِمْ أَنْ یَصُومُوا بَقِیَّتہ۔",,,9569,,
9570,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا أَمْنَی الصَّائِمُ فَقَدْ أَفْطَرَ۔",,,9570,,
9571,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا أَمْنَی الصَّائِمُ أَفْطَرَ ، قُلْتُ : یُکَفِّرُ کَفَّارَۃَ الْمَنِیِّ ؟ قَالَ : نَعَمْ۔",,,9571,,
9572,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا قَبَّلَ ، أَوْ لَمَسَ وَہُوَ صَائِمٌ فَأَمْنَی ، فَہُوَ بِمَنْزِلَۃِ الْمُجَامِعِ۔",,,9572,,
9573,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ عَنْ رَجُلٍ نَظَرَ إلَی امْرَأَتِہِ فِی رَمَضَانَ ، فَأَمْنَی مِنْ شَہْوَتِہَا ، ہَلْ یُفْطِرُ ؟ قَالَ : لاَ ، وَیُتِمُّ صَوْمَہُ۔",,,9573,,
9574,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی الصَّائِمِ یُلاَعِبُ امْرَأَتَہُ حَتَّی یُمْذِیَ ، أَوْ یُودِیَ ، قَالَ : لاَ یُوجِبُ عَلَیْہِ الْقَضَائَ إِلاَّ مَا أَوْجَبَ عَلَیْہِ الْغُسْلَ۔",,,9574,,
9575,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ أَمْنَی الصَّائِمُ أَفْطَرَ۔",,,9575,,
9576,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، قَالَ مَرَّۃً : عَنِ ابْنِ عَبَّاسٍ (ح) وَعَنْ حُرَیْثٍ ، عَنِ الشَّعْبِیِّ، قَالاَ : إِنْ کَانَ لِغَیْرِ الصَّلاَۃِ قَضَی ، وَإِنْ کَانَ لِلصَّلاَۃِ فَلاَ قَضَائَ عَلَیْہِ۔",,,9576,,
9577,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : إذَا مَضْمَضَ وَہُوَ صَائِمٌ ، فَدَخَلَ حَلْقَہُ شَیْئٌ لَمْ یَتَعَمَّدْہُ فَلَیْسَ عَلَیْہِ شَیْئٌ ، یُتِمُّ صَوْمَہُ۔",,,9577,,
9578,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الخَالِق ، عَنْ حَمَّادٍ ؛ فِی الصَّائِمِ یُمَضْمِضَ ، فَدَخَلَ الْمَائُ حَلْقَہُ ، قَالَ : إِنْ کَانَ وُضُوء اً وَاجِبًا فَلَیْسَ عَلَیْہِ شَیْئٌ ، وَإِنْ کَانَ مَضْمَضَ عَنْ غَیْرِہِ فَإِنَّہُ یُعِیدُ۔",,,9578,,
9579,"حَدَّثَنَا مَخْلَدٌ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ إنْسَانٌ لِعَطَائٍ : اسْتَنْثرتُ فَدَخَلَ الْمَائُ حَلْقِی ، فَلاَ بَأْسَ ؟ قَالَ : لاَ بَأْسَ ، لَمْ تَمْلِکْ۔",,,9579,,
9580,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الصَّائِمِ یَتَوَضَّأُ فَیَدْخُلُ حَلْقَہُ مِنْ وَضُوئِہِ ، قَالَ : إِنْ کَانَ ذَاکِرًا لِصَوْمِہِ فَعَلَیْہِ الْقَضَائُ ، وَإِنْ کَانَ نَاسِیًا فَلاَ شَیْئَ عَلَیْہِ۔",,,9580,,
9581,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ عَنْ رَجُلٍ کَانَ صَائِمًا فَتَوَضَّأَ ، فَسَبَقَہُ الْمَائُ إلَی حَلْقِہِ ، یُفْطِرُ ؟ قَالَ : لاَ ، وَلْیُتِمَّ صِیَامَہُ۔",,,9581,,
9582,"حَدَّثَنَا حَفْصٌ ، عَنْ مُجَالِدٍ ، عَنْ عَامِرٍ ، قَالَ : کَانَ عَلِیٌّ ، وَعُمَرُ یَنْہَیَانِ عَنْ صَوْمِ الیَوْمٍ الَّذِی یُشَکُّ فِیہِ مِنْ رَمَضَانَ۔",,,9582,,
9583,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الضَّرِیسِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَابِسٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عَبْدُ اللہِ : لأَنْ أُفْطِرَ یَوْمًا مِنْ رَمَضَانَ ، ثُمَّ أَقْضِیَہُ ، أَحَبُّ إلَیَّ مِنْ أَنْ أَزِیدَ فِیہِ مَا لَیْسَ مِنہ۔",,,9583,,
9584,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ حَکِیمٍ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُول : لَوْ صُمْت السَّنَۃَ کُلَّہَا لأَفْطَرْتُ الْیَوْمَ الَّذِی یُشَکُّ فِیہِ۔",,,9584,,
9585,"حَدَّثَنَا حَفْصٌ ، وَعَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ الضَّحَّاکُ بْنُ قَیْسٍ : لَوْ صُمْتُ السَّنَۃَ کُلَّہَا ، مَا صُمْتُ الْیَوْمَ الَّذِی یُشَکُّ فِیہِ مِنْ رَمَضَانَ۔",,,9585,,
9586,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ مَوْلاَۃٍ لِسَلَمَۃَ بِنْتِ حُذَیْفَۃَ ، عَنْ بِنْتِ حُذَیْفَۃَ قَالَتْ : کَانَ حُذَیْفَۃُ یَنْہَی عَنْ صَوْمِ الیَوْمِ الَّذِی یُشَکُّ فِیہِ۔",,,9586,,
9587,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَہْدِیِّ بْنِ مَیْمُونٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : أَصْبَحْنَا یَوْمًا بِالْبَصْرَۃِ ، وَلَسْنَا نَدْرِی عَلَی مَا نَحْنُ فِیہِ مِنْ صَوْمِنَا فِی الْیَوْمِ الَّذِی یُشَکُّ فِیہِ ، فَأَتَیْنَا أَنَسَ بْنَ مَالِکٍ ، فَإِذَا ہُوَ قَدْ أَخَذَ خزیرۃ کَانَ یَأْخُذُہَا قَبْلَ أَنْ یَغْدُوَ ، ثُمَّ غَدَوْا ، ثُمَّ أَتَیْتُ أَبَا السَّوَّارِ الْعَتَکِیَّ فَدَعَا بِغَدَائِہِ ، ثُمَّ تَغَدَّی ، ثُمَّ أَتَیْتُ مُسْلِمَ بْنَ یَسَارٍ فَوَجَدْتُہُ مُفْطِرًا۔",,,9587,,
9588,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، وَالشَّعْبِیِّ ، أَنَّہُمَا قَالاَ : لاَ تَصُمْ إِلاَّ مَعَ جَمَاعَۃِ النَّاسِ۔",,,9588,,
9589,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَا مِنْ یَوْمٍ أَصُومُہُ أَبْغَضُ إلَیَّ مِنْ یَوْمٍ یَخْتَلِفُ النَّاسُ فِیہِ۔",,,9589,,
9590,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ امْرَأَۃٍ مِنْہُمْ ، یُقَالُ لَہَا : حَفْصَۃُ ، عَنْ بِنْتٍ أَوْ أُخْتٍ لِحُذَیْفَۃَ ، قَالَتْ : کَانَ حُذَیْفَۃُ یَنْہَی عَنْ صَوْمِ الیَوْمِ الَّذِی یُشَکُّ فِیہِ۔",,,9590,,
9591,"حَدَّثَنَا وَکِیعٌ ، عَنِ أَبِی الْعَیْزَارِ ، قَالَ : أَتَیْتُ إبْرَاہِیمَ فِی الْیَوْمِ الَّذِی یُشَکُّ فِیہِ ، فَقَالَ : لَعَلَّک صَائِمٌ ، لاَ تَصُمْ إِلاَّ مَعَ الْجَمَاعَۃِ۔",,,9591,,
9592,"حَدَّثَنَا وَکِیعٌ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، قَالَ : قُلْتُ لِلْقَاسِمِ : أَتَکْرَہُ صَوْمَ آخِرِ یَوْمِ شَعْبَانَ الَّذِی یَلِی رَمَضَانَ؟ قَالَ : لاَ ، إِلاَّ أَنْ یُغمَّی الْہِلاَلُ۔",,,9592,,
9593,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَصُومُہُ فِیمَا بَیْنَہُ وَبَیْنَ نِصْفِ النَّہَارِ لِشَہَادَۃِ شَاہِدٍ، أَوْ مَجِیئِ غَائِبٍ ، فَإِنْ جَائَ ، وَإِلاَّ أَفْطَرَ۔",,,9593,,
9594,حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی الْمُعَلَّی ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَصُومَ الْیَوْمَ الَّذِی یُخْتَلَفُ فِیہِ مِنْ رَمَضَانَ۔,,,9594,,
9595,"حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ عَبْدِ الصَّمَدِ الْعَمِّیُّ ، عَنْ مَنْصُورٍ ، عَنْ رِبْعِیٍّ ، أَنَّ عَمَّارَ بْنَ یَاسِرٍ وَنَاسًا مَعَہُ أَتَوْہُمْ بِمَسْلُوخَۃٍ مَشْوِیَّۃٍ فِی الْیَوْمِ الَّذِی یُشَکُّ فِیہِ أَنَّہُ مِنْ رَمَضَانَ ، أَوْ لَیْسَ مِنْ رَمَضَانَ ، فَاجْتَمَعُوا وَاعْتَزَلَہُمْ رَجُلٌ ، فَقَالَ لَہُ عَمَّارٌ : تَعَالَ فَکُلْ ، قَالَ : فَإِنِّی صَائِمٌ ، فَقَالَ لَہُ عَمَّارٌ : إِنْ کُنْت تُؤْمِنُ بِاللَّہِ وَالْیَوْمِ الآخِرِ فَتَعَالَ فَکُلْ۔",,,9595,,
9596,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : مَنْ صَامَ الْیَوْمَ الَّذِی یُشَکُّ فِیہِ فَقَدْ عَصَی رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (ابوداؤد 2327۔ دارمی 1682)",,,9596,,
9597,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَیَان ، عَنْ عَامِرٍ ، قَالَ : مَا مِنْ یَوْمٍ أَبْغَضُ إلَیَّ أَنْ أَصُومَہُ مِنَ الْیَوْمِ الَّذِی یُشَکُّ فِیہِ مِنْ رَمَضَانَ۔",,,9597,,
9598,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ ؛ فِی الْیَوْمِ الَّذِی یَقُولُ النَّاسُ إِنَّہُ مِنْ رَمَضَانَ ، قَالَ : فَقَالَ : لاَ تَصُومَنَّ إِلاَّ مَعَ الإِمَامِ ، فَإِنَّمَا کَانَتْ أَوَّلُ الْفُرْقَۃِ فِی مِثْلِ ہَذَا۔",,,9598,,
9599,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ قَالَ : مَا مِنْ یَوْمٍ أَبْغَضُ إلَیَّ أَنْ أَصُومَہُ ، مِنَ الْیَوْمِ الَّذِی یُشَکُّ فِیہِ مِنْ رَمَضَانَ۔",,,9599,,
9600,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : قَالَ عُمَرُ : لِیَتَّقِ أَحَدُکُمْ أَنْ یَصُومَ یَوْمًا مِنْ شَعْبَانَ ، أَوْ یُفْطِرَ یَوْمًا مِنْ رَمَضَانَ ، فإِنْ تَقَدَّمَ قَبْلَ النَّاسِ ، فَلْیُفْطِرْ إذَا أَفْطَرَ النَّاسُ۔",,,9600,,
9601,حَدَّثَنَا یَزِیدُ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ؛ أَنَّہُ کَانَ یَصُومُ یَوْمَ الَّذِی یُشَکُّ فِیہِ مِنْ رَمَضَانَ۔,,,9601,,
9602,"حَدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ أَبِی یَعْفُورٍ، عَنْ أَبِی الصَّلْتِ، عَنْ أَبِی عَقْرَبٍ الأَسَدِیِّ، قَالَ: أَتَیْنَا ابْنَ مَسْعُودٍ فِی دَارِہِ فَوَجَدْنَاہُ فَوْقَ الْبَیْتِ ، فَسَمِعَنَاہُ یَقُولُ قَبْلَ أَنْ یَنْزِلَ : صَدَقَ اللَّہُ وَرَسُولُہُ ، فَلَمَّا نَزَلَ قُلْنَا : یَا أَبَا عَبْدِ الرَّحْمَنِ ، سَمِعْنَاک تَقُولُ: صَدَقَ اللَّہُ وَرَسُولُہُ ، فَقَالَ: لَیْلَۃُ الْقَدْرِ فِی السَّبْعِ مِنَ النِّصْفِ الآخِرِ، وَذَلِکَ أَنَّ الشَّمْسَ تَطْلُعُ یَوْمَئِذٍ بَیْضَائَ لاَ شُعَاعَ لَہَا ، فَنَظَرْتُ إلَی الشَّمْسِ فَوَجَدْتُہَا کَمَا حُدِّثْتُ ، فَکَبَّرْت۔",,,9602,,
9603,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ عُمَرَ ، قَالَ : لَقَدْ عَلِمْتُمْ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ فِی لَیْلَۃِ الْقَدْرِ : اُطْلُبُوہَا فِی الْعَشْرِ الأَوَاخِرِ۔",,,9603,,
9604,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، عَنْ عُبَادَۃَ بْنِ الصَّامِتِ ، قَالَ : خَرَجَ عَلَیْنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یُرِیدُ أَنْ یُخْبِرَنَا بِلَیْلَۃِ الْقَدْرِ ، فَتَلاَحَی رَجُلاَنِ ، فَقَالَ : إنِّی خَرَجْت وَأَنَا أُرِیدُ أَنْ أُخْبِرَکُمْ بِلَیْلَۃِ الْقَدْرِ فَتَلاَحَی فُلاَنٌ وَفُلاَنٌ ، لَعَلَّ ذَلِکَ أَنْ یَکُونَ خَیْرًا ، الْتَمِسُوہَا فِی التَّاسِعَۃِ ، وَالسَّابِعَۃِ ، وَالْخَامِسَۃِ۔",,,9604,,
9605,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ خُبِیبٍ ، عَنْ عَبْدِ اللہِ بْنِ أَنُیسٍ صَاحِبِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ سُئِلَ عَنْ لَیْلَۃِ الْقَدْرِ ؟ فَقَالَ: إنِّی سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : الْتَمِسُوہَا اللَّیْلَۃَ ، وَتِلْکَ اللَّیْلَۃُ لَیْلَۃُ ثَلاَثٍ وَعِشْرِینَ۔",,,9605,,
9606,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ مَرْثَدِ بْنِ أَبِی مَرْثَدٍ ، عَنْ أَبِیہِ ؛ قَالَ : کُنْتُ مَعَ أَبِی ذَرٍّ عِنْدَ الْجَمْرَۃِ الْوُسْطَی ، فَسَأَلْتُہُ عَنْ لَیْلَۃِ الْقَدْرِ ؟ فَقَالَ : کَانَ أَسْأَلَ النَّاسِ عَنْہَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَا ، قُلْتُ : یَا رَسُولَ اللہِ ، أَخْبِرْنَا بِہَا ، فَقَالَ : لَوْ أُذِنَ لِی فِیہَا لأَخْبَرْتُکُمْ ، وَلَکِنِ الْتَمِسُوہَا فِی إحْدَی السَّبْعَیْنَ، ثُمَّ لاَ تَسْأَلْنِی عَنْہَا بَعْدَ مُقَامِکَ ، أَوْ مُقَامِی ہَذَا۔",,,9606,,
9607,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ قَنَّان بْنِ عَبْدِ اللہِ النَّہْمِیِّ ، قَالَ : سَأَلَتْ زِرَّ بْنَ حُبَیْشٍ عَنْ لَیْلَۃِ الْقَدْرِ ؟ فَقَالَ : کَانَ عُمَرُ ، وَحُذَیْفَۃُ ، وَنَاسٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یَشُکُّونَ فِیہَا أَنَّہَا لَیْلَۃُ سَبْعٍ وَعِشْرِینَ ، قَالَ زِرٌّ : فَوَاصِلْہَا۔",,,9607,,
9608,"حَدَّثَنَا شَرِیکٌ ، عَنِ الأَسْوَد بْنِ قَیْسٍ ، عَنْ أَبِیہِ ، عَنْ عُمَرَ ، قَالَ : لاَ بَأْسَ بِقَضَائِ رَمَضَانَ فِی الْعَشْرِ۔",,,9608,,
9609,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : مَنْ کَانَ عَلَیْہِ صَوْمٌ مِنْ رَمَضَانَ فَلاَ یَقْضِیہ فِی ذِی الْحِجَّۃِ ، فَإِنَّہُ شَہْرُ نُسُکٍ۔",,,9609,,
9610,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُثْمَانَ بْنِ مَوْہَبٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : اِبْدَأ بِالْفَرِیضَۃِ لاَ بَأْسَ أَنْ تَصُومَہَا فِی الْعَشْرِ۔",,,9610,,
9611,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ (ح) وَعَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالاَ : یَبْدَأُ بِالْفَرِیضَۃِ ، لاَ بَأْسَ أَنْ یَصُومَہَا فِی الْعَشْرِ۔",,,9611,,
9612,حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَقْضِی رَمَضَانَ فِی الْعَشْرِ۔,,,9612,,
9613,"حَدَّثَنَا غُنْدَرٌ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِقَضَائِ رَمَضَانَ فِی الْعَشْرِ۔",,,9613,,
9614,"حَدَّثَنَا إسْمَاعِیلُ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُسٍ ، وَمُجَاہِدٍ قَالُوا : اقْضِ رَمَضَانَ مَتَی شِئْتَ ، وَقَالَ سَعِیدُ بْنُ جُبَیْرٍ : لاَ بَأْسَ بِہِ۔",,,9614,,
9615,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَرِہَہُ۔,,,9615,,
9616,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أُتیتُ فِی رَمَضَانَ وَأَنَا نَائِمٌ فَقِیلَ: إنَّ اللَّیْلَۃَ لَیْلَۃُ الْقَدْرِ، قَالَ: فَقُمْتُ وَأَنَا نَاعِسٌ فَتَعَلَّقْت بِبَعْضِ أَطْنَابِ فُسْطَاطِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فَأَتَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یُصَلِّی، فَنَظَرْت فِی اللَّیْلَۃِ فَإِذَا ہِیَ لَیْلَۃُ ثَلاَثٍ وَعِشْرِینَ، قَالَ: وَقَالَ ابْنُ عَبَّاسٍ: الشَّیْطَانُ یَطْلُعُ مَعَ الشَّمْسِ کُلَّ یَوْمٍ إِلاَّ لَیْلَۃَ الْقَدْرِ، قَالَ: وَذَلِکَ أَنَّہَا تَطْلُعُ یَوْمَئِذٍ لاَ شُعَاعَ لَہَا۔",,,9616,,
9617,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ جَبَلَۃَ ، وَمُحَارِبٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَحَیَّنُوا لَیْلَۃَ الْقَدْرِ فِی الْعَشْرِ الأَوَاخِرِ ، أَوْ قَالَ : فِی السَّبْعِ الأَوَاخِرِ۔",,,9617,,
9618,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَحَرَّوْا لَیْلَۃَ الْقَدْرِ فِی الْعَشْرِ الأَوَاخِرِ۔ (مسلم 219۔ احمد 6/204)",,,9618,,
9619,"حَدَّثَنَا عَبْدُ الأَعْلَی ، وَابْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ مَرْثَدِ بْنِ عَبْدِ اللہِ الْیَزَنِیِّ ، عَنِ الصُّنَابِحِیِّ ، قَالَ : سَأَلْتُ بِلاَلاً عَنْ لَیْلَۃِ الْقَدْرِ ؟ فَقَالَ : لَیْلَۃُ ثَلاَثٍ وَعِشْرِینَ۔",,,9619,,
9620,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمٍ ، عَنْ أَبِیہِ ، عَنْ خَالِہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنِّی أُرِیتُ لَیْلَۃ الْقَدْرِ فَأُنْسِیتہَا ، فَاطْلُبُوہَا فِی الْعَشْرِ الأَوَاخِرِ ، وِتْرًا۔",,,9620,,
9621,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : فِی رَمَضَانَ۔",,,9621,,
9622,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَد ، عَنْ عَبْدِ اللہِ ، قَالَ : تَحَرَّوْا لَیْلَۃَ الْقَدْرِ لِسَبْعٍ تَبْقَی ، تَحَرَّوْہَا لِتِسْعٍ تَبْقَی ، تَحَرَّوہا لإِحْدَی عَشْرَۃَ تَبْقَی ، صَبِیحَۃَ بَدْرٍ ، فَإِنَّ الشَّمْسَ تَطْلُعُ کُلَّ یَوْمٍ بَیْنَ قَرْنَیْ شَیْطَانٍ إِلاَّ صَبِیحَۃَ بَدْرٍ۔",,,9622,,
9623,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ ابْنِ أَبِی خَالِدٍ ، عَنْ زِرٍّ ، قَالَ : سَمِعْتُ أُبَیَّ بْنَ کَعْبٍ یَقُولُ : لَیْلَۃُ الْقَدْرِ لَیْلَۃُ سَبْعٍ وَعِشْرِینَ۔",,,9623,,
9624,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْمَسْعُودِیِّ ، عَنْ حَوْطٍ الْخُزَاعِیِّ ، قَالَ : سَأَلْتُ زَیْدَ بْنَ أَرْقَمَ عْن لَیْلَۃِ الْقَدْرِ ؟ قَالَ : فَمَا تماری وَلاَ شَکَّ ، قَالَ : لَیْلَۃُ تِسْعَ عَشْرَۃَ ، لَیْلَۃُ الْفُرْقَانِ لَیْلَۃُ الْتَقَی الْجَمْعَانِ۔",,,9624,,
9625,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ أَبِی بَکْرَۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : الْتَمِسُوا لَیْلَۃَ الْقَدْرِ فِی الْعَشْرِ مِنْ رَمَضَانَ ؛ لِتِسْعٍ تَبْقَیْنَ ، أَوْ لِسَبْعٍ تَبْقَیْنَ ، أَوْ لِخَمْسٍ ، أَوْ لِثَلاَثٍ ، أَوْ لآخِرِ لَیْلَۃٍ۔",,,9625,,
9626,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَجْلَحِ ، عَنِ الشَّعْبِیِّ ، عَنْ زِرِّ بْنِ حُبَیْشٍ ، قَالَ : سَمِعْتُ أُبَیًّا یَقُولُ : لَیْلَۃُ الْقَدْرِ ہِیَ لَیْلَۃُ سَبْعٍ وَعِشْرینَ ، ہِیَ اللَّیْلَۃُ الَّتِی أَخْبَرَنَا بِہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّ الشَّمْسَ تَطْلُعُ بَیْضَائَ ، تَرَقْرَقُ۔",,,9626,,
9627,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعَۃَ بْنِ کُلْثُومٍ ، قَالَ : سَمِعْتُ الْحَسَنَ یَقُولُ : لَیْلَۃُ الْقَدْرِ فِی کُلِّ رَمَضَانَ۔",,,9627,,
9628,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : لَیْلَۃُ الْقَدْرِ تَحَوَّلُ فِی لَیَالِیِ الْعَشْرِ کُلِّہَا۔",,,9628,,
9629,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، ووَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ شَرِیکٍ ، قَالَ : سَمِعْتُ زِرًّا یَقُولُ : لَیْلَۃُ الْقَدْرِ لَیْلَۃُ سَبْعٍ وَعِشْرِینَ ، فَإِذَا کَانَ تِلْکَ اللَّیْلَۃَ فَلْیَغْتَسِلْ أَحَدُکُمْ ، وَلْیُفْطِرْ عَلَی لَبَنٍ ، وَلْیُؤَخِّرْ فِطْرَہُ إلَی السَّحَرِ۔",,,9629,,
9630,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ قَتَادَۃَ ، عَنْ مُطَرِّفٍ ، عَنْ مُعَاوِیَۃَ ، قَالَ : لَیْلَۃُ الْقَدْرِ لَیْلَۃُ ثَلاَثٍ وَعِشْرِینَ",,,9630,,
9631,"حَدَّثَنَا عَمْرُو بْنُ حَمَّادِ بْنِ طَلْحَۃَ ، عَنْ أَسْبَاطِ بْنِ نَصْرٍ ، عَنْ سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْتَمِسُوا لَیْلَۃَ الْقَدْرِ فِی الْعَشْرِ الأَوَاخِرِ۔",,,9631,,
9632,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إنِّی أُرِیتُ لَیْلَۃَ الْقَدْرِ فَأُنْسِیتہَا ، أَوْ نُسِّیتُہَا ، فَالْتَمِسُوہَا فِی الْعَشْرِ الأَوَاخِرِ ، فِی الْوِتْرِ۔ (بخاری 813۔ ابوداؤد 1377)",,,9632,,
9633,حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَد ؛ أَنَّ عَائِشَۃَ کَانَتْ تُوقِظُ أَہْلَہَا لَیْلَۃَ ثَلاَثٍ وَعِشْرِینَ۔,,,9633,,
9634,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ یَرُشُّ عَلَی أَہْلِہِ مَائً لَیْلَۃَ ثَلاَثٍ وَعِشْرِینَ۔",,,9634,,
9635,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَحَرَّوْا لَیْلَۃَ الْقَدْرِ فِی الْعَشْرِ الأَوَاخِرِ مِنْ رَمَضَانَ۔",,,9635,,
9636,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْلَۃُ الْقَدْرِ لَیْلَۃٌ بَلْجَۃٌ سَمْحَۃٌ ، تَطْلُعُ شَمْسُہَا لَیْسَ لَہَا شُعَاعٌ۔",,,9636,,
9637,"حَدَّثَنَا أَبُوبَکْرِ بْنُ عَیَّاشٍ، عَنْ أَبِی إِسْحَاقَ، عَنْ ہُبَیْرَۃَ، عَنْ عَلِیٍّ، قَالَ: کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا دَخَلَتِ الْعَشْرُ الأَوَاخِرُ أَیْقَظَ أَہْلَہُ وَرَفَعَ الْمِئْزَرَ ، قِیلَ لأَبِی بَکْرٍ : مَا رَفْعُ الْمِئْزَرِ؟ قَالَ: اعْتِزَالُ النِّسَائِ۔",,,9637,,
9638,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ یُوقِظُ أَہْلَہُ فِی الْعَشْرِ الأَوَاخِرِ۔",,,9638,,
9639,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَابِطٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُوقِظُ أَہْلَہُ فِی الْعَشْرِ الأَوَاخِرِ مِنْ رَمَضَانَ ، وَیُشَمِّرُ فِیہِنَّ۔",,,9639,,
9640,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُیَیْنَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، قَالَ : کَانَ أَبُو بَکْرۃَ یُصَلِّی فِی رَمَضَانَ کَصَلاَتِہِ فِی سَائِرِ السَّنَۃِ ، فَإِذَا دَخَلَتِ الْعَشْرُ اجْتَہَدَ۔",,,9640,,
9641,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِیَادٍ ، قَالَ : حَدَّثَنَا الْحَسَنُ بْنُ عُبَیْدِ اللہِ ، قَالَ : حدَّثَنَا إبْرَاہِیمُ ، عَنِ الأَسْوَد ، عَنْ عَائِشَۃَ قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَجْتَہِدُ فِی الْعَشْرِ اجْتِہَادًا ، لاَ یَجْتَہِدُہ فِی غَیْرِہِ۔",,,9641,,
9642,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ، وَأَبِی مَیْسَرَۃَ ، قَالاََ : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، رَجُلٌ صَامَ الأَبَدَ ؟ قَالَ : لاَ صَامَ ، وَلاَ أَفْطَرَ۔",,,9642,,
9643,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، وَسُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ أَبِی الْعَبَّاسِ الْمَکِّیِّ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ صَامَ مَنْ صَامَ الأَبَدَ۔ (بخاری 1979۔ مسلم 187)",,,9643,,
9644,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَہْدِیِّ بْنِ مَیْمُونٍ ، عَنْ غَیْلاَنَ بْنِ جَرِیرٍ ، عَنْ عَبْدِ اللہِ بْنِ مَعْبَدٍ الزِّمَّانِیْ ، عَنْ أَبِی قَتَادَۃَ ، قَالَ : قَالَ رَجُلٌ : یَا رَسُولَ اللہِ ، أَرَأَیْت رَجُلاً یَصُومُ الدَّہْرَ کُلَّہُ ؟ قَالَ : لاَ صَامَ وَلاَ أَفْطَرَ ، أَوْ مَا صَامَ وَلاَ أَفْطَرَ۔ (مسلم 818۔ ابوداؤد 2418)",,,9644,,
9645,"حَدَّثَنَا عُبَیْدُ بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ مُطَرِّفِ بْنِ عَبْدِ اللہِ بْنِ الشِّخِّیرِ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَامَ الأَبَدَ فَلاَ صَامَ ، وَلاَ أَفْطَرَ۔ (ابن ماجہ 1705۔ طیالسی 1147)",,,9645,,
9646,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی تَمِیمَۃَ الْہُجَیْمِیِّ ، عَنْ أَبِی مُوسَی ، قَالَ : مَنْ صَامَ الدَّہْرَ ضُیِّقَتْ عَلَیْہِ جَہَنَّمُ ہَکَذَا ، وَطَبَّقَ بِکَفِّہِ۔",,,9646,,
9647,حَدَّثَنَا وَکِیعٌ ، عَنِ الضَّحَّاکِ بْنِ یَسَارٍ ، سَمِعَہُ مِنْ أَبِی تَمِیمَۃَ ، عَنْ أَبِی مُوسَی ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، بِمِثْلِہِ۔ (احمد 4/414۔ ابن حبان 3584,,,9647,,
9648,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی عَمَّارٍ الْہَمْدَانِیِّ ، عَنْ عَمْرِو بْنِ شُرَحْبِیلَ ، قَالَ : قَالَ رَجُلٌ : یَا رَسُولَ اللہِ ، أَرَأَیْتَ رَجُلاً یَصُومُ الدَّہْرَ کُلَّہُ ؟ قَالَ : وَدِدْتُ أَنَّہُ لاَ یَطْعَمُ الدَّہْرَ کُلَّہُ ، قَالَ : ثُلُثَیْہِ ؟ قَالَ : أَکْثَرُ ، قَالَ : نِصْفَہُ ؟ قَالَ : أَکْثَرُ ، ثُمَّ قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَلاَ أُنَبِّئُکُمْ مَا یُذْہِبُ وَحْر الصَّدْرِ : صِیَامُ ثَلاَثَۃِ أَیَّامٍ مِنْ کُلِّ شَہْرٍ۔",,,9648,,
9649,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی خَالِدٍ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، قَالَ : بَلَغَ عُمَرَ أَنَّ رَجُلاً یَصُومُ الدَّہْرَ ، فَعَلاَہُ بِالدِّرَّۃِ وَجَعَلَ یَقُولُ : کُلْ یَا دَہْرُ ، کُلْ یَا دَہْرُ۔",,,9649,,
9650,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، قَالَ : ذُکِرَ لِلشَّعْبِیِّ أَنَّ عُبَیْدًا الْمُکْتِبَ یَصُومُ الدَّہْرَ کُلَّہُ ، فَکَرِہَ ذَلِکَ۔",,,9650,,
9651,حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنِ الْحَسَنِ بْنِ یَزِیدَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ سُئِلَ عَنْ صَوْمِ الدَّہْرِ ؟ فَکَرِہَہُ۔,,,9651,,
9652,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ، قَالَ: لَمْ یَکُنْ سَالِمٌ، وَالْقَاسِمُ، وَعُبَیْدُاللہِ یَصُومُونَ الدَّہْرَ۔",,,9652,,
9653,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی جَعْفَرٍ الْفَرَّائِ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ، قَالَ : قَالَ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ صَامَ مَنْ صَامَ الدَّہْرَ۔",,,9653,,
9654,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ أَنَّ الأَسْوَد کَانَ یَصُومُ الدَّہْرَ۔,,,9654,,
9655,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ عَبْدِ الْوَاحِدِ ، قَالَ : کَانَ عُرْوَۃُ یَصُومُ الدَّہْرَ فِی السَّفَرِ وَغَیْرِہِ۔",,,9655,,
9656,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ الزُّبَیْرِ بْنِ عَبْدِ اللہِ بْنِ رُہَیْمَۃَ ، عَنْ جَدَّتِہِ ، قَالَتْ : کَانَ عُثْمَانَ یَصُومُ الدَّہْرَ، وَیَقُومُ اللَّیْلَ إِلاَّ ہَجْعَۃً مِنْ أَوَّلِہِ۔",,,9656,,
9657,حَدَّثَنَا عَبْدَۃُ ، وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ عُمَرَ سَرَدَ الصَّوْمَ قَبْلَ مَوْتِہِ بِسَنَتَیْنِ۔,,,9657,,
9658,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، قَالَ : ذَکَرُوا بِالْمَدِینَۃِ رُؤْیَۃَ الْہِلاَلِ وَقَالُوا : إنَّ أَہْلَ إِسْتَارَۃَ قَدْ رَأَوْہُ ، فَقَالَ الْقَاسِمُ ، وَسَالِمٌ : مَا لَنَا وَلأَہْلِ إِسْتَارَۃَ۔",,,9658,,
9659,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَبِیتُ جُنُبًا ، فَیَأْتِیہِ بِلاَلٌ فَیُؤْذِنُہُ بِالصَّلاَۃِ ، فَیَقُومُ فَیَغْتَسِلُ ، فَأَنْظُرُ إلَی تَحَدُّرِ الْمَائِ مِنْ رَأْسِہِ ، ثُمَّ یَخْرُجُ فَأَسْمَعُ صَوْتَہُ فِی صَلاَۃِ الْفَجْرِ ، ثُمَّ یَظَلُّ صَائِمًا ، قَالَ مُطَرِّفٌ : فَقُلْتُ لِعَامِرٍ : فِی رَمَضَانَ ؟ قَالَ : نَعَمْ ، سَوَائٌ رَمَضَانُ وَغَیْرُہُ۔ (احمد 6/254۔ ابن حبان 3490)",,,9659,,
9660,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصْبِحُ جُنُبًا ، ثُمَّ یَغْتَسِلُ ، ثُمَّ یُتِمُّ صَوْمَہُ۔ (بخاری 1925۔ ترمذی 779)",,,9660,,
9661,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عَائِشَۃَ ، قَالَتْ: کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصْبِحُ جُنُبًا ، ثُمَّ یَغْتَسِلُ فَیَخْرُجُ مِنْ مُغْتَسَلِہِ ، فَیُصَلِّی بِالنَّاسِ ، وَیَصُومُ ذَلِکَ الْیَوْمَ۔ (نسائی 2981۔ احمد 6/203)",,,9661,,
9662,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ أُمِّ سَلَمَۃَ قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصْبِحُ جُنُبًا مِنْ غَیْرِ احْتِلاَمٍ ، ثُمَّ یَغْتَسِلُ وَیَمْضِی عَلَی صَوْمِہِ۔ (مسلم 80۔ احمد 6/306)",,,9662,,
9663,"حَدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عِرَاکِ بْنِ مَالِکٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی بَکْرٍ ؛ أَنَّ أُمَّ سَلَمَۃَ زَوْجَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَتْ تَقُولُ : إِنْ کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَیُصْبِحُ جُنُبًا مِنْ غَیْرِ احْتِلاَمٍ ، ثُمَّ یُصْبِحُ صَائِمًا۔ (احمد 6/313۔ ابن حبان 3486)",,,9663,,
9664,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ جَامِعِ بْنِ شَدَّادٍ ، عَنِ الأَسْوَد بْنِ ہِلاَلٍ ، قَالَ : جَائَ عبْدُ اللہِ بْنُ مِرْدَاسٍ إلَی عَبْدِ اللہِ بْنِ مَسْعُودٍ ، فَقَالَ : إنِّی أَصْبَحْتُ وَأَنَا جُنُبٌ ، فَأُتِمُّ صَوْمِی ؟ قَالَ عَبْدُ اللہِ : أَصْبَحْتَ فَحَلَّ لَکَ الصَّلاَۃُ ، وَحَلَّ لَکَ الصِّیَامُ ، اغْتَسِلْ وَأَتِمَّ صَوْمَک۔",,,9664,,
9665,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنْ أَبِی عَطِیَّۃَ الْوَادِعِیِّ ، قَالَ : تَدَارَأ رَجُلاَنِ فِی الْمَسْجِدِ فِی رَجُلٍ یُصْبِحُ وَہُوَ جُنُبٌ ، فَانْطَلَقَا إلَی عَبْدِ اللہِ ، فَانْطَلَقْت مَعَہُمَا ، فَسَأَلَہُ أَحَدُہُمَا فَقَالَ : أَیَصُومُ ؟ قَالَ : نَعَمْ ، قَالَ : فَإِنْ کَانَ مِنَ النِّسَائِ ؟ قَالَ : وَإِنْ کَانَ مِنَ النِّسَائِ ، قَالَ : وَإِنْ نَامَ مُتَعَمِّدًا ؟ قَالَ : وَإِنْ نَامَ مُتَعَمِّدًا۔",,,9665,,
9666,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ أَبِی عَطِیَّۃَ ، عَنْ عَبْدِ اللہِ ؛ بِنَحْوٍ مِنْہُ۔,,,9666,,
9667,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا أَصْبَحَ الرَّجُلُ وَہُوَ جُنُبٌ فَأَرَادَ أَنْ یَصُومَ ، فَلْیَصُمْ إِنْ شَائَ۔",,,9667,,
9668,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَمَّارٍ مَوْلَی بَنِی ہَاشِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، وَزَیْدِ بْنِ ثَابِتٍ ، وَابْنِ عَبَّاسٍ ؛ فِی الرَّجُلِ یُصْبِحُ وَہُوَ جُنُبٌ ، قَالُوا : یَمْضِی عَلَی صَوْمِہِ۔",,,9668,,
9669,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَنْ عَطَائِ بْنِ عَبْدِ اللہِ ، قَالَ : قَالَ أَبُو ذَرٍّ : لَوْ أَصْبَحْت جُنُبًا مِنِ امْرَأَتِی لَصُمْتُ۔",,,9669,,
9670,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنِ ابْنِ شِہَابٍ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ ، قَالَ : أَخْبَرَتْنِی عَائِشَۃُ ، وَأُمُّ سَلَمَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُدْرِکُہُ الْفَجْرُ وَہُوَ جُنُبٌ مِنْ أَہْلِہِ ، ثُمَّ یَغْتَسِلُ وَیَصُومُ۔ (بخاری 1931۔ ترمذی 779)",,,9670,,
9671,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا ہِشَام بْنُ الْغَازِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَوْ نَادَی الْمُنَادِی وَأَنَا بَیْنَ رِجْلَیْہَا لَقُمْتُ فَأَتْمَمْتُ الصِّیَامَ ، صِیَامَ رَمَضَانَ کَانَ ، أَوْ غَیْرَہُ۔",,,9671,,
9672,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ رَبِیعٍ ، عَنِ الْحَسَنِ ، قَالَ : یُجْزِیہِ فِی التَّطَوُّعِ ، وَیَقْضِیہِ فِی الْفَرِیضَۃِ۔",,,9672,,
9673,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : عَلَیْہِ الْقَضَائُ۔",,,9673,,
9674,حَدَّثَنَا یَزِیدُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ؛ أَنَّ أَبَا ہُرَیْرَۃَ رَجَعَ عَنْ فُتْیَاہُ ؛ مَنْ أَصْبَحَ جُنُبًا فَلاَ صَوْمَ لَہُ۔,,,9674,,
9675,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : حدَّثَنَا إبْرَاہِیمُ بْنُ نَافِعٍ ، قَالَ : سَمِعْتُ ابْنَ طَاوُوس یَذْکُرُ ، عَنْ طَاوُوسٍ ، قَالَ : إِنْ أَصَابَتْہُ جَنَابَۃٌ فِی شَہْرِ رَمَضَانَ ، فَإِن اسْتَیْقَظَ وَلَمْ یَغْتَسِلْ حَتَّی یُصْبِحَ ، فَإِنَّہُ یُتِمُّ ذَلِکَ الْیَوْمَ وَیَصُومُ یَوْمًا مَکَانَہُ ، فَإِنْ لَمْ یَسْتَیْقِظْ فَلَیْسَ عَلَیْہِ بَدَلٌ۔",,,9675,,
9676,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، وَأَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : قَالَ عَبْدُ اللہِ : لَوْ أَذَّنَ الْمُؤَذِّنُ وَأَنَا بَیْنَ رِجْلَیِ امْرَأَتِی ، لاَغْتَسَلْتُ ثُمَّ صُمْتُ۔",,,9676,,
9677,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : قَالَ عُمَرُ : لَوْ أَدْرَکَنِی النِّدَائُ وَأَنَا بَیْنَ رِجْلَیْہَا لَصُمْتُ ، أَوَ قَالَ : مَا أَفْطَرْت۔",,,9677,,
9678,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : وَاصَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَوَاصَلْنَا، فَبَلَغَ ذَلِکَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : لَوْ أَنَّ الشَّہْرَ مُدَّ لِی لَوَاصَلْتُ وِصَالاً یَدَعُ الْمُتَعَمِّقُونَ تَعَمُّقَہُمْ ، إنِّی لَسْتُ مِثْلَکُمْ ، إنِّی أَظَلُّ یُطْعِمُنِی رَبِّی وَیَسْقِینِی۔ (بخاری 1961۔ ترمذی 778)",,,9678,,
9679,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : وَاصَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَبَلَغَ ذَلِکَ النَّاسَ فَوَاصَلُوا ، فَبَلَغَ ذَلِکَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَنَہَاہُمْ ، فَقَالَ : إنِّی لَسْتُ مِثْلَکُمْ ، إنِّی أَظَلُّ عِنْدَ رَبِّی فَیُطْعِمُنِی وَیَسْقِینِی۔ (بخاری 1965۔ مسلم 775)",,,9679,,
9680,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَاصَلَ فِی رَمَضَانَ ، فَوَاصَلَ النَّاسُ فَنَہَاہُمْ ، فَقِیلَ لَہُ : إنَّک تُوَاصِلُ ؟ فَقَالَ : إنِّی لَسْتُ مِثْلَکُمْ ، إنِّی أُطْعَمُ وَأُسْقَی۔ (مسلم 56۔ احمد 2/143)",,,9680,,
9681,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ بِشْرِ بْنِ حَرْبٍ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْوِصَالِ ، وَہَذِہِ أُخْتِی تُوَاصِلُ ، وَأَنَا أَنْہَاہَا۔ (بخاری 1963۔ ابوداؤد 2353)",,,9681,,
9682,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیٍّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَاصَلَ إلَی السَّحَرِ۔ (طبرانی 185۔ احمد 1/91),,,9682,,
9683,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَابِسٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالُوا : إنَّمَا نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الْوِصَالِ فِی الصِّیَامِ ، وَالْحِجَامَۃِ لِلصَّائِمِ ، إبْقَائً عَلَی أَصْحَابِہِ۔",,,9683,,
9684,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَاہُمْ عَنِ الْوِصَالِ، فَقَالُوا : یَا رَسُولَ اللہِ ، إنَّک تُوَاصِلُ ؟ فَقَالَ : إنِّی لَسْتُ مِثْلَکُمْ ، إنِّی أَبِیت یُطْعِمُنِی رَبِّی وَیَسْقِینِی ، فَإِنْ أَبَیْتُمْ فَمِنَ السَّحَرِ إلَی السَّحَرِ۔",,,9684,,
9685,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنِ الْوِصَالِ فِی الصِّیَامِ ، فَقَالُوا : إنَّک تُوَاصِلُ ؟ فَقَالَ : إنِّی لَسْتُ مِثْلَکُمْ ، إنِّی أَبِیت یُطْعِمُنِی رَبِّی وَیَسْقِینِی ، أَوْ نَحْوَ ہَذَا۔",,,9685,,
9686,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : لاَ أُوَاصِلُ أَبَدًا۔",,,9686,,
9687,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی جَنَابٍ ، عَنْ إسْمَاعِیلَ بْنِ رَجَائٍ ، عَنِ النَّزَّالِ بْنِ سَبْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : لاَ وِصَالَ فِی صِیَامٍ۔",,,9687,,
9688,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عُمَارَۃَ بْنِ الْقَعْقَاعِ ، عَنْ أَبِی زُرْعَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : سَمِعْتُہُ یَقُولُ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إیَّاکُمْ وَالْوِصَالَ ثَلاَثَ مَرَّاتٍ ، فَقَالُوا : إنَّک تُوَاصِلُ یَا رَسُولَ اللہِ ، قَالَ : لَسْتُمْ فِی ذَالِکُمْ مِثْلِی ، إنِّی أَبِیت یُطْعِمُنِی رَبِّی وَیَسْقِینِی ، فَاکْلفُوا مِنَ الأَعْمَالِ مَا تُطِیقُونَ۔\n\n(بخاری 1966۔ احمد 2/231)",,,9688,,
9689,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ قُدَامَۃَ ، قَالَ : قَالَتْ عَائِشَۃُ : (ثُمَّ أَتِمُّوا الصِّیَامَ إلَی اللَّیْلِ) مَعْنَاہَا عَلَی أَنَّہَا کَرِہَتِ الْوِصَالَ۔",,,9689,,
9690,"حَدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن دَاوُدَ ، عَنْ أَبِی الْعَالِیَۃِ ؛ أَنَّہُ قَالَ فِی الْوِصَالِ فِی الصِّیَامِ : قَالَ اللَّہُ تَبَارَکَ وَتَعَالَی : (ثُمَّ أَتِمُّوا الصِّیَامَ إلَی اللَّیْلِ) ، فَإِذَا جَائَ اللَّیْلُ فَہُوَ مُفْطِرٌ ، ثُمَّ إِنْ شَائَ صَامَ ، وَإِنْ شَائَ تَرَکَ۔",,,9690,,
9691,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ بُکَیرِ بْنِ عَامِرٍ ، قَالَ : کَانَ ابْنُ أَبِی نُعْمٍ یُوَاصِلُ خَمْسَۃَ عَشَرَ یَوْمًا حَتَّی نَعُودَہُ۔",,,9691,,
9692,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَسْوَد بْنِ شَیْبَانَ ، عَنْ أَبِی نَوْفَلِ بْنِ أَبِی عَقْرَبٍ ، قَالَ : دَخَلْتُ عَلَی ابْنِ الزُّبَیْرِ صَبِیحَۃَ خَمْسَۃَ عَشَرَ مِنَ الشَّہْرِ ، وَہُوَ مُوَاصِلٌ۔",,,9692,,
9693,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنْ أَبِی خَالِدٍ ، قَالَ : حدَّثَنِی مُحَمَّدُ بْنُ سَعْدِ ، عَنْ سَعْدِ بْنِ أَبِی وَقَّاصٍ ، قَالَ : ضَرَبَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِیَدِہِ عَلَی الأُخْرَی ، ثُمَّ قَالَ : الشَّہْرُ ہَکَذَا وَہَکَذَا ، ثُمَّ نَقَصَ فِی الثَّالِثَۃِ إِصْبَعًا۔ (مسلم 764۔ احمد 1/184)",,,9693,,
9694,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ رَجُلٍ مِنْ بَنِی سُلَیْمٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ عُمَرَ ، قَالَ : اعْتَزَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نِسَائَہُ شَہْرًا ، فَلَمَّا مَضَی تِسْعٌ وَعِشْرُونَ أَتَاہُ جِبْرِیلُ ، فَقَالَ : إنَّ الشَّہْرَ قَدْ تَمَّ ، وَقَدْ بَرَرْت۔",,,9694,,
9695,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کَمْ مَضَی مِنَ الشَّہْرِ ؟ قُلْنَا : مَضَی اثْنَانِ وَعِشْرُونَ یَوْمًا ، وَبَقِیَتْ ثَمَان ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : بَلْ مَضَتَ ثنَتَانِ وَعِشْرُونَ ، وَبَقِیَتْ سَبْعٌ ، الْتَمِسُوہَا اللَّیْلَۃَ ، ثُمَّ قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الشَّہْرُ ہَکَذَا ، وَالشَّہْرُ ہَکَذَا ، ثَلاَثَ مَرَّاتٍ ، وَأَمْسَکَ وَاحِدَۃً۔ (احمد 2/251۔ ابن حبان 3450)",,,9695,,
9696,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ أَبِی الزُّبَیْرِ، عَنْ جَابِرٍ، قَالَ: حَلَفَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، أَوْ أَقْسَمَ شَہْرًا، فَصَعِدَ عُلیۃ، فَلَمَّا کَانَ تِسْعٌ وَعِشْرُونَ جَائَہُ جِبْرِیلُ، فَقَالَ: انْزِلْ، فَقَدْ تَمَّ الشَّہْرُ۔",,,9696,,
9697,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الأَسْوَد بْنِ قَیْسٍ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ عَمْرٍو یُحَدِّثُ ، أَنَّہُ سَمِعَ ابْنَ عُمَرَ یُحَدِّثُ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّا أُمَّۃٌ أُمِّیَّۃٌ ، لاَ نَکْتُبُ وَلاَ نَحْسُبُ ، الشَّہْرُ ہَکَذَا ، وَہَکَذَا ، وَہَکَذَا ، وَعَقَدَ الإِبْہَامَ فِی الثَّالِثَۃِ ؟ وَالشَّہْرُ ہَکَذَا ، وَہَکَذَا ، وَہَکَذَا ، یَعْنِی : تَمَامَ الثَّلاَثِینَ۔ (بخاری 1913۔ مسلم 761)",,,9697,,
9698,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ: الشَّہْرُ ہَکَذَا، وَہَکَذَا، وَہَکَذَا، ثُمَّ نقص إبْہَامَہُ ، یَعْنِی: تِسْعًا وَعِشْرِینَ۔(مسلم 759۔ ابوداؤد 2314)",,,9698,,
9699,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ آلَی مِنْ نِسَائِہِ شَہْرًا ، فَقَعَدَ فِی مَشْرُبَۃٍ لَہُ ، ثُمَّ نَزَلَ فِی تِسْعٍ وَعِشْرِینَ ، فَقَالُوا : یَا رَسُولَ اللہِ ، إنَّک آلَیْتَ شَہْرًا ؟ فَقَالَ : إنَّ الشَّہْرَ تِسْعٌ وَعِشْرُونَ۔ (بخاری 1911)",,,9699,,
9700,"حَدَّثَنَا عَبِیدَۃُ بْنُ حُمَیْدٍ ، عَنِ الأَسْوَد بْنِ قَیْسٍ ، عَنْ سَعِیدِ بْنِ عَمْرٍو ، أَنَّ عَبْدَ اللہِ بْنَ عُمَرَ حَدَّثَہُمْ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّا أُمَّۃٌ أُمِّیَّۃٌ ، لاَ نَکْتُبُ وَلاَ نَحْسُبُ ، الشَّہْرُ کَذَا ، وَکَذَا ، وَضَرَبَ بِیَدِہِ ثَلاَثًا ، ثُمَّ نَقَصَ وَاحِدَۃً۔ (احمد 2/129)",,,9700,,
9701,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ یَحْیَی بْنِ عَبْدِ الرَّحْمَنِ بْنِ حَاطِبٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الشَّہْرُ تِسْعٌ وَعِشْرُونَ ، ثُمَّ طَبَّقَ بَیْنَ کَفَّیْہِ مَرَّتَیْنِ ، وَطَبَّقَ الثَّالِثَۃَ ، وَقَبَضَ الإِبْہَامَ ، فَقَالَتْ عَائِشَۃُ : غَفَرَ اللَّہُ لأَبِی عَبْدِ الرَّحْمَنِ ، إنَّمَا ہَجَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نِسَائَہُ شَہْرًا ، فَنَزَلَ لِتِسْعٍ وَعِشْرِینَ ، فَقَالُوا : یَا رَسُولَ اللہِ ، إنَّک آلَیْتَ شَہْرًا ؟ فَقَالَ : وَإنَّ الشَّہْرَ یَکُونُ تِسْعًا وَعِشْرِینَ۔ (احمد 2/31)",,,9701,,
9702,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنِ الرُّکَیْنِ ، عَنْ حُصَیْنِ بْنِ قَبِیصَۃَ ، عَنْ عَلِیٍّ ، قَالَ : شَہْرٌ تِسْعٌ وَعِشْرُونَ ، وَشَہْرٌ ثَلاَثُونَ۔",,,9702,,
9703,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ دَاوُدَ بْنِ یَزِیدَ ، عَنِ الشَّعْبِیِّ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : سَمِعْتُ عُمَرَ یَقُولُ : الشہُور ؛ شَہْرٌ ثَلاَثُونَ ، وَشَہْرٌ تِسْعٌ وَعِشْرُونَ۔",,,9703,,
9704,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنِ الْجُرَیْرِیِّ، عَنْ أَبِی مُصْعَبٍ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: رَمَضَانُ تِسْعٌ وَعِشْرُونَ۔",,,9704,,
9705,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ حُمَیْدٍ ، عَنِ الْوَلِیدِ بْنِ عُیینۃَ ، قَالَ : صُمْنَا رَمَضَانَ فِی عَہْدِ عَلِیٍّ عَلَی غَیْرِ رُؤْیَۃِ ، ثَمَانِیَۃ وَعِشْرِینَ یَوْمًا ، فَلَمَّا کَانَ یَوْمُ الْفِطْرِ أَمَرَنَا أَنْ نَقْضِیَ یَوْمًا۔",,,9705,,
9706,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، قَالَ : مَا صُمْنَا تِسْعًا وَعِشْرِینَ ، أَکْثَرَ مِمَّا صُمْنَا ثَلاَثِینَ۔",,,9706,,
9707,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ ذَرٍّ ، عَنْ یَزِیدَ بْنِ حُلَیْلٍ ، قَالَ : الصَّائِمُ إذَا أُکِلَ عِنْدَہُ الطَّعَامُ ، سَبَّحَتْ مَفَاصِلُہُ۔",,,9707,,
9708,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ حَبِیبِ بْنِ زَیْدٍ ، عَنِ امْرَأَۃٍ یُقَالُ لَہَا : لَیْلَی ، عَنْ أُمِّ عُمَارَۃَ ، قَالَتْ : أتَانَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقُرِّبَ إلَیْہِ طَعَامٌ ، فَکَانَ بَعْضُ مَنْ عِنْدَہُ صِیَامًا ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ الصَّائِمَ إذَا أُکِلَ عِنْدَہُ الطَّعَامُ ، صَلَّتْ عَلَیْہِ الْمَلاَئِکَۃُ۔ (ترمذی 786۔ احمد 6/365)",,,9708,,
9709,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إسْمَاعِیلَ بْنِ سَالِمٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الصَّائِمُ إذَا أُکِلَ عِنْدَہُ سَبَّحَتْ مَفَاصِلُہُ۔",,,9709,,
9710,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی أَیُّوبَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : الصَّائِمُ إذَا أُکِلَ عِنْدَہُ صَلَّتْ عَلَیْہِ الْمَلاَئِکَۃُ۔",,,9710,,
9711,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ أَبِی فَاخِتَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْمُعْتَکِفُ عَلَیْہِ الصَّوْمُ۔",,,9711,,
9712,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : لاَ اعْتِکَافَ إِلاَّ بِصَوْمٍ۔",,,9712,,
9713,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، عَنْ مِقسَم ، عَنِ ابْنِ عَبَّاسٍ ، وَعَائِشَۃَ ، قَالاَ : لاَ اعْتِکَافَ إِلاَّ بِصَوْمٍ ، وَقَالَ عَلِیٌّ ، وَابْنُ مَسْعُودٍ : لَیْسَ عَلَیْہِ صَوْمٌ ، إِلاَّ أَنْ یَفْرِضَہُ ہُوَ عَلَی نَفْسِہِ۔",,,9713,,
9714,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ اعْتِکَافَ إِلاَّ بِصوم",,,9714,,
9715,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ؛ بِمِثْلِہِ۔,,,9715,,
9716,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ، قَالاَ : الْمُعْتَکِفُ لَیْسَ عَلَیْہِ صَوْمٌ ، إِلاَّ أَنْ یَشْتَرِطَ ذَلِکَ عَلَی نَفْسِہِ۔",,,9716,,
9717,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الصَّوْمُ عَلَیْہِ وَاجِبٌ۔",,,9717,,
9718,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : لاَ اعْتِکَافَ إِلاَّ بِصَوْمٍ۔",,,9718,,
9719,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَمْ یَکُنْ یُرَی اعْتِکَافٌ إِلاَّ بِصَوْمٍ۔",,,9719,,
9720,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : قَالَ عَلِیٌّ : عَلَی الْمُعْتَکِفِ الصَّوْمُ ، وَإِنْ لَمْ یَفْرِضْہُ عَلَی نَفْسِہِ۔",,,9720,,
9721,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ قَالَ : لَیْسَ عَلَیْہِ صَوْمٌ ، إِلاَّ أَنْ یَکُونَ أَوْجَبَ ذَلِکَ عَلَی نَفْسِہِ۔",,,9721,,
9722,حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِید ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ مِثْل قَوْلِ إبْرَاہِیمَ۔,,,9722,,
9723,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ اعْتِکَافَ إِلاَّ بِصَوْمٍ۔",,,9723,,
9724,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : إِذَا اعْتَکَفَ الرَّجُلُ فَلْیَشْہَد الْجُمُعَۃَ ، وَلْیَعُد الْمَرِیضَ ، وَلْیَحْضَر الْجِنَازَۃَ ، وَلْیَأْتِ أَہْلَہُ ، وَلْیَأْمُرْہُمْ بِالْحَاجَۃِ وَہُوَ قَائِمٌ۔",,,9724,,
9725,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخْبَرَنَا الشَّیْبَانِیُّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ قَالَ: یَشْہَد الْجُمُعَۃَ ، وَیَعُود الْمَرِیضَ، وَیُجِیب الإِمَامَ۔",,,9725,,
9726,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الزُّہْرِیِّ ، قَالَ : حَدَّثَتْنَا عَمْرَۃُ ، عَنْ عَائِشَۃَ ؛ کَانَتْ لاَ تَعُودُ الْمَرِیضَ مِنْ أَہْلِہَا وَہِیَ مُعْتَکِفَۃٌ ، إِلاَّ وَہِیَ مَارَّۃٌ۔",,,9726,,
9727,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یَشْہَدُ الْجُمُعَۃَ ، وَیَعُودُ الْمَرِیضَ ، وَیَشْہَدُ الْجِنَازَۃَ ، وَیَخْرُجُ إلَی الْحَاجَۃِ ، وَیُجِیبُ الإِمَامَ ، وَذَلِکَ أَنَّ عَمْرَو بْنَ حُرَیْثٍ أرْسلَ إلَیْہِ وَہُوَ مُعْتَکِفٌ فَلَمْ یَأْتِہِ ، فَأَرْسَلَ إلَیْہِ فَأَتَاہُ۔",,,9727,,
9728,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُحِبُّونَ لِلْمُعْتَکِفِ أَنْ یَشْتَرِطَ ہَذِہِ الْخِصَالَ وَہِیَ لَہُ وَإِنْ لَمْ یَشْتَرِطْ ؛ عِیَادَۃَ الْمَرِیضِ ، وَأَنْ یَتَّبِعَ الْجِنَازَۃَ ، وَیَشْہَدَ الْجُمُعَۃَ۔",,,9728,,
9729,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : یَخْرُجُ إلَی الْغَائِطِ ، وَیَعُودُ الْمَرِیضَ ، وَیَأْتِی الْجُمُعَۃَ ، وَیَقُومُ عَلَی الْبَابِ۔",,,9729,,
9730,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : یَأْتِی الْجُمُعَۃَ۔",,,9730,,
9731,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی ، عَنْ أَبِی سَلَمَۃَ ، قَالَ : الْمُعْتَکِفُ یَعُودُ الْمَرِیضَ ، وَیَشْہَدُ الْجُمُعَۃَ ، وَیَقُومُ مَعَ الرَّجُلِ فِی الطَّرِیقِ یُسائلہ۔",,,9731,,
9732,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ ، عَنِ الْحَسَنِ ، قَالَ : یَأْتِی الْغَائِطَ ، وَیَتَّبِعُ الْجِنَازَۃَ ، وَیَعُودُ الْمَرِیضَ۔",,,9732,,
9733,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یَشْہَدُ الْجُمُعَۃَ ، وَیَعُودُ الْمَرِیضَ ، وَیَحْضُرُ الْجِنَازَۃَ ، قَالَ مَرَّۃً : وَیُجِیبُ الإِمَامَ۔",,,9733,,
9734,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخبرنَا سُفْیَانُ بْنُ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ: کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا کَانَ مُعْتَکِفًا لَمْ یَدْخُلِ الْبَیْتَ ، إِلاَّ لِحَاجَۃٍ۔ (بخاری 2029۔ احمد 6/235)",,,9734,,
9735,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، عَنْ عَمْرَۃَ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ تَمُرُّ بِالْمَرِیضِ مِنْ أَہْلِہَا وَہِیَ مُعْتَکِفَۃٌ ، فَلاَ تَعْرِضُ لَہُ۔,,,9735,,
9736,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ (ح) وَعَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالاَ : الْمُعْتَکِفُ لاَ یَشْہَدُ جِنَازَۃً ، وَلاَ یَعُودُ مَرِیضًا۔",,,9736,,
9737,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ، قَالَ: لاَ یَتَّبِعُ جِنَازَۃً، وَلاَ یَعُودُ مَرِیضًا، وَلاَ یُجِیبُ دَعْوَۃً۔",,,9737,,
9738,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الْمُعْتَکِفُ لاَ یَتَّبِعُ جِنَازَۃً ، وَلاَ یَعُودُ مَرِیضًا۔",,,9738,,
9739,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : لاَ یُجِیبُ دَعْوَۃً ، وَلاَ یَعُودُ مَرِیضًا ، وَلاَ یَحْضُرُ جِنَازَۃً۔",,,9739,,
9740,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَمْرَۃَ ، عَنْ عَائِشَۃَ قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا أَرَادَ أَنْ یَعْتَکِفَ صَلَّی الصُّبْحَ ، ثُمَّ دَخَلَ الْمَکَانَ الَّذِی یَعْتَکِفُ فِیہِ۔(مسلم 831۔ ابوداؤد 2456)",,,9740,,
9741,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَرَادَ الرَّجُل أَنْ یَعْتَکِفَ ، فَلْتَغْرُبْ لَہُ الشَّمْسُ مِنَ اللَّیْلَۃِ الَّتِی یُرِیدُ أَنْ یَعْتَکِفَ فِیہَا وَہُوَ فِی الْمَسْجِدِ۔",,,9741,,
9742,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ فِی الْمُعْتَکِفِ یَشْتَرِطُ أَنْ یَعْتَکِفَ بِالنَّہَارِ وَیَأْتِیَ أَہْلَہُ بِاللَّیْلِ ، قَالَ : لَیْسَ ہَذَا بِاعْتِکَافٍ۔",,,9742,,
9743,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا لِلْمُعْتَکِفِ أَنْ یَشْتَرِطَ أَنْ یَتَعَشَّی فِی أَہْلِہِ وَیَتَسَحَّرَ۔,,,9743,,
9744,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِنْ شَائَ اشْتَرَطَ أَنْ یَتَعَشَّی فِی أَہْلِہِ ، وَلاَ یَدْخُلُ ظِلَّہُ ، وَلَکِنْ یُؤْتَی بِعَشَائِہِ فِی فِنَائِ دَارِہِ۔",,,9744,,
9745,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ یَعْلَی بْنِ أُمَیَّۃَ ؛ أَنَّہُ کَانَ یَقُولُ لِصَاحِبِہِ : انْطَلِقْ بِنَا إلَی الْمَسْجِدِ فَنَعْتَکِفُ فِیہِ سَاعَۃً۔",,,9745,,
9746,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : کَانَ ابْنُ عُمَرَ إذَا أَرَادَ أَنْ یَعْتَکِفَ ضَرَبَ خِبَائً ، أَوْ فُسْطَاطًا فَقَضَی فِیہِ حَاجَتَہُ ، وَلاَ یَأْتِی أَہْلَہُ ، وَلاَ یَدْخُلُ سَقْفًا۔",,,9746,,
9747,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ ، عَنْ عَمِّہِ قُطْبَۃَ بْنِ مَالِکٍ ؛ أَنَّ عُمَرَ رَأَی قَوْمًا اعْتَکَفُوا فِی الْمَسْجِدِ ، وَقَدْ سُتِرُوا فَأَنْکَرَہُ ، وَقَالَ : مَا ہَذَا ؟ قَالُوا : إنَّمَا نَسْتُرُہُ عَلَی طَعَامِنَا ، قَالَ : فَاسْتُرُوہُ ، فَإِذَا طَعِمْتُمْ فَاہْتِکُوہُ۔",,,9747,,
9748,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَّائٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ، قَالَ : الْمُعْتَکِفُ لاَ یَدْخُلُ بَیْتًا مُسَقَّفًا۔",,,9748,,
9749,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یَدْخُلُ سَقْفًا۔",,,9749,,
9750,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی ، عَنْ أَبِی سَلَمَۃَ ، قَالَ : لاَ یَدْخُلُ دَارًا۔",,,9750,,
9751,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ یَدْخُلُ بَیْتًا۔",,,9751,,
9752,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یَدْخُلُ بَیْتًا۔",,,9752,,
9753,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ؛ أَنَّ أَبَا قِلاَبَۃَ اعْتَکَفَ فِی مَسْجِدِ قَوْمِہِ۔,,,9753,,
9754,حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ؛ أَنَّ أَبَا قِلاَبَۃَ فَعَلَہُ۔,,,9754,,
9755,حَدَّثَنَا ہُشَیْمٌ ، عَنِ الشَّیْبَانِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ اعْتَکَفَ فِی مَسْجِدِ قَوْمِہِ۔,,,9755,,
9756,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ اعْتَکَفَ فِی مَسْجِدِ قَوْمِہِ۔,,,9756,,
9757,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ ہَمَّامِ بْنِ الْحَارِثِ ؛ أَنَّہُ اعْتَکَفَ فِی مَسْجِدِ قَوْمِہِ۔,,,9757,,
9758,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالاِعْتِکَافِ فِی مَسَاجِدِ الْقَبَائِلِ۔",,,9758,,
9759,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنْ یَحْیَی ، عَنْ أَبِی سَلَمَۃَ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَعْتَکِفَ فِی مَسْجِدٍ یُصَلَّی فِیہِ۔,,,9759,,
9760,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزَّعْرَائِ ؛ أَنَّ أَبَا الأَحْوَصِ اعْتَکَفَ فِی مَسْجِدِ قَوْمِہِ۔,,,9760,,
9761,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إِنْ شَائَ اعْتَکَفَ فِی مَسْجِدِ قَوْمِہِ۔",,,9761,,
9762,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ وَاصِلٍ الأَحْدَبِ ، عَنْ إبْرَاہِیمَ ، قَالَ : جَائَ حُذَیْفَۃُ إلَی عَبْدِ اللہِ ، فَقَالَ: أَلاَ أَعْجَبَک مِنْ قَوْمٍ عُکُوفٍ بَیْنَ دَارِکَ وَبَیْنَ دَارِ الأَشْعَرِیِّ، یَعْنِی: الْمَسْجِدَ؟ قَالَ عَبْدُ اللہِ :فَلَعَلَّہُمْ أَصَابُوا وَأَخْطَأْت ، فَقَالَ حُذَیْفَۃُ : أَمَا عَلِمْت أَنَّہُ لاَ اعْتِکَافَ إِلاَّ فِی ثَلاَثَۃِ مَسَاجِدَ ؛ الْمَسْجِدِ الْحَرَامِ ، وَالْمَسْجِدِ الأَقْصَی ، وَمَسْجِدِ الرَّسُولِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَمَا أُبَالِی اعْتَکَفْتُ فِیہِ ، أَوْ فِی سُوقِکُمْ ہَذِہِ۔",,,9762,,
9763,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ (ح) وَعَنْ جَابِرٍ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیٍّ ، قَالَ : لاَ اعْتِکَافَ إِلاَّ فِی مِصْرٍ جَامِعٍ۔",,,9763,,
9764,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، عَنْ شَدَّادِ بْنِ الأَزْمَعِ ، قَالَ : اعْتَکَفَ رَجُلٌ فِی الْمَسْجِدِ الأَعْظَمِ وَضَرَبَ خَیْمَۃً فَحَصَبَہُ النَّاسُ ، فَبَلَغَ ذَلِکَ ابْنَ مَسْعُودٍ ، فَأَرْسَلَ إلَیْہِ رَجُلاً ، فَکَفَّ النَّاسَ عَنْہُ وَحَسَّنَ ذَلِکَ۔",,,9764,,
9765,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ، عَنْ ہَمَّامٍ، عَنْ قَتَادَۃَ، عَنِ ابْنِ الْمُسَیَّبِ، قَالَ: لاَ اعْتِکَافَ إِلاَّ فِی مَسْجِدِ نَبِیٍّ۔",,,9765,,
9766,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ اعْتِکَافَ إِلاَّ فِی مَسْجِدِ جَمَاعَۃٍ یُجْمَعُ فِیہِ۔",,,9766,,
9767,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الاِعْتِکَافِ ؟ فَقَالاَ : لاَ تَعْتَکِف إِلاَّ فِی مَسْجِدٍ یُجَمِّعُونَ فِیہِ۔",,,9767,,
9768,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْمَرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : لاَ اعْتِکَافَ إِلاَّ فِی مَسْجِدٍ یُجْمَعُ فِیہِ۔",,,9768,,
9769,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : لاَ اعْتِکَافَ إِلاَّ فِی مَسْجِدِ جَمَاعَۃٍ۔",,,9769,,
9770,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّہُ أُوتِیَ یَوْمَ الْفِطْرِ فِی مَسْجِدِ قَوْمِہِ ، وَاعْتَکَفَ فِیہِ بِجُوَیْریۃٍ مُزَیَّنَۃٍ فَأَقْعَدَہَا فِی حِجْرِہِ ، ثُمَّ اعْتَنَقَہَا وَخَرَجَ إلَی الْمُصَلَّی کَمَا ہُوَ مِنَ الْمَسْجِدِ۔,,,9770,,
9771,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ لِلْمُعْتَکِفِ أَنْ یَبِیتَ لَیْلَۃَ الْفِطْرِ فِی مَسْجِدِہِ ، حَتَّی یَکُونَ غُدُوُّہُ مِنْہُ۔",,,9771,,
9772,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : بِتْ لَیْلَۃَ الْفِطْرِ فِی الْمَسْجِدِ الَّذِی اعْتَکَفْت فِیہِ ، حَتَّی یَکُونَ غُدُوُّک إلَی مُصلاَّکَ مِنْہُ۔",,,9772,,
9773,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ ابْنِ أَبِی نَجِیحٍ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: إذَا جَامَعَ الْمُعْتَکِفُ، أَبْطَلَ اعْتِکَافَہُ وَاسْتَأْنَفَ۔",,,9773,,
9774,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ عَطَائٍ ، قَالَ : یَقْضِی اعْتِکَافَہُ۔",,,9774,,
9775,"حَدَّثَنَا ابْنُ الدَّرَاوَرْدِیِّ، عَنْ مُوسَی بْنِ أَبِی مَعْبَدٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، وَالْقَاسِمِ، وَسَالِمٍ، قَالُوا: یَسْتَقْبِلُ۔",,,9775,,
9776,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ غَشِیَ امْرَأَتَہُ وَہُوَ مُعْتَکِفٌ ، أَنَّہُ بِمَنْزِلَۃِ الَّذِی غَشِیَ فِی رَمَضَانَ ، عَلَیْہِ مَا عَلَی الَّذِی أَصَابَ فِی رَمَضَانَ۔,,,9776,,
9777,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ ، عَنِ الضَّحَّاکِ ، قَالَ : کَانُوا یُجَامِعُونَ وَہُمْ مُعْتَکِفُونَ حَتَّی نَزَلَتْ : {وَلاَ تُبَاشِرُوہُنَّ وَأَنْتُمْ عَاکِفُونَ فِی الْمَسَاجِدِ}۔",,,9777,,
9778,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : مَنْ أَصَابَ امْرَأَتَہُ وَہُوَ مُعْتَکِفٌ ، فَعَلَیْہِ مِنَ الْکَفَّارَۃِ مِثْلُ مَا عَلَی الَّذِی یُصِیبُ فِی رَمَضَانَ۔",,,9778,,
9779,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ بُکَیْرِ بْنِ الأَخْنَسِ ، عَنْ مُجَاہِدٍ ؛ فِی الْمُعْتَکِفِ إذَا جَامَعَ ، قَالَ : یَتَصَدَّقُ بِدِینَارَین۔",,,9779,,
9780,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ؛ فِی امْرَأَۃٍ نَذَرَتْ أَنْ تَعْتَکِفَ خَمْسِینَ یَوْمًا ، فَاعْتَکَفَتْ أَرْبَعِینَ ، ثُمَّ جَائَ زَوْجُہَا فَأَرْسَلَ إلَیْہَا فَأَتَتْہُ ، قَالَ : تُتِمُّ مَا بَقِیَ۔",,,9780,,
9781,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَطَائٍ ، أَنَّہُ کَرِہَ لِلْمُعْتَکِفِ أَنْ یُقَبِّلَ ، أَوْ یُبَاشِرَ۔,,,9781,,
9782,"حَدَّثَنَا الفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یُقَبِّلُ الْمُعْتَکِفُ ، وَلاَ یُبَاشِرُ۔",,,9782,,
9783,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الْمُعْتَکِفُ لاَ یَبِیعُ ، وَلاَ یَبْتَاعُ۔",,,9783,,
9784,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمَّارِ بْنِ عَبْدِ اللہِ بْنِ یَسَارٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا أَعَانَ جَعْدَۃَ بْنَ ہُبَیْرَۃَ بِسَبْعِ مِئَۃ دِرْہَمٍ مِنْ عَطَائِہِ فِی ثَمَنِ خَادِمٍ لَہُ ، فَسَأَلَہُ : ہَلَ ابْتَعْتَ خَادِمًا ؟ قَالَ : أَنَا مُعْتَکِفٌ ، قَالَ : وَمَا عَلَیْک لََوْ أَتَیْتَ السُّوقَ ، فَابْتَعْت خَادِمًا۔",,,9784,,
9785,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ لَیْثٍ ، قَالَ : سُئِلَ طَاوُوس عَنِ امْرَأَۃٍ مَاتَتْ وَعَلَیْہَا أَنْ تَعْتَکِفَ سَنَۃً فِی الْمَسْجِدِ الْحَرَامِ ، وَلَہَا أَرْبَعَۃُ بَنُونَ ، کُلُّہُمْ یُحِبُّ أَنْ یَقْضِیَ عَنْہَا ؟ قَالَ طَاوُوس : اعْتَکِفُوا أَرْبَعَتُکُمْ فِی الْمَسْجِدِ الْحَرَامِ ، ثَلاَثَۃَ أَشْہُرٍ ، وَصُومُوا۔",,,9785,,
9786,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : لاَ یُقْضَی عَنِ الْمَیِّتِ اعْتِکَافُ۔",,,9786,,
9787,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ؛ أَنَّ أُمَّہُ نَذَرَتْ أَنْ تَعْتَکِفَ عَشْرَۃَ أَیَّامٍ ، فَمَاتَتْ وَلَمْ تَعْتَکِفْ ، فَقَالَ ابْنُ عَبَّاسٍ : اعْتَکِفْ عَنْ أُمِّک۔",,,9787,,
9788,حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ عَامِرِ بْنِ مُصْعَبٍ ؛ أَنَّ عَائِشَۃَ اعْتَکَفَتْ عَنْ أَخِیہَا بَعْدَ مَا مَاتَ۔,,,9788,,
9789,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، قَالَ : حدَّثَنَا حَجَّاجٌ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِالْمُعْتَکِفِ أَنْ یَغْسِلَ ثِیَابَہُ وَیَخِیطَہَا۔",,,9789,,
9790,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا سُفْیَانُ بْنُ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا کَانَ مُعْتَکِفًا ، لَمْ یَدْخُلِ الْبَیْتَ إِلاَّ لِحَاجَۃٍ ، قَالَتْ : فَغَسَلْتُ رَأْسَہُ ، وَإِنَّ بَیْنِی وَبَیْنَہُ لَعَتَبَۃَ الْبَابِ۔ (بخاری 295۔ ابوداؤد 2461)",,,9790,,
9791,"حَدَّثَنَا جَرِیرٌ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ، قَالَ: إذَا حَاضَتِ الْمُعْتَکِفَۃُ ضَرَبَتْ فِی دَارِہَا سِتْرًا، فَکَانَتْ فِیہِ۔",,,9791,,
9792,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ خَالِدٍ، عَنْ أَبِی قِلاَبَۃَ، قَالَ: الْمُعْتَکِفَۃُ تَضْرِبُ بِنَاہَا عَلَی بَابِ الْمَسْجِدِ إذَا حَاضَتْ۔",,,9792,,
9793,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ بَعْضَ أَزْوَاجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَتْ مُسْتَحَاضَۃً وَہِیَ عَاکِفٌ۔,,,9793,,
9794,حَدَّثَنَا عَبَّادٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَدْخُلَ الْمُعْتَکِفُ الْقَبْرَ۔,,,9794,,
9795,"حَدَّثَنَا شَرِیکٌ ، عَنْ سَالِمٍ ؛ قَالَ : صَنَعَ طَعَامًا فَأَرْسَلَ إلَی سَعِیدِ بْنِ جُبَیْرٍ ، فَقَالَ : إنِّی صَائِمٌ ، فَحَدَّثَہُ بِحَدِیثِ سَلْمَانَ ؛ أَنَّہُ فَطَّرَ أَبَا الدَّرْدَائِ ، فَأَفْطَرَ۔",,,9795,,
9796,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ وَبَرَۃَ ، عَنْ خَرَشَۃَ بْنِ الْحُرِّ ، قَالَ : کُنَّا عِنْدَ عُمَرَ فَأُتِیَ بِطَعَامٍ ، فَقَالَ لِلْقَوْمِ : اِطْعِمُوا ، فَکُلُّہُمْ یَقُولُ : إنِّی صَائِمٌ ، فَعَزَمَ عَلَیْہِمْ أَنْ یُفْطِرُوا ، فَأَفْطَرُوا۔",,,9796,,
9797,"حَدَّثَنَا ابْنُ مُبَارَکٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، قَالَ: سَأَلَہُ سُلَیمَان بْن مُوسَی أَکَانَ یُفْطِرُ الرَّجُلُ لِضَیْفِہِ؟ قَالَ : نَعَمْ۔",,,9797,,
9798,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : أَخْبَرَنَا أَشْعَثُ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُرَخِّصُ لِلرَّجُلِ الصَّائِمِ إذَا نَزَلَ بِہِ الضَّیْفُ أَنْ یُفْطِرَ ، وَیَقْضِیَ یَوْمًا مَکَانَہُ۔",,,9798,,
9799,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الرَّجُلِ یَصُومُ تَطَوُّعًا فَنَہَتْہُ أُمُّہُ ؟ قَالاَ : یُطِیعُہَا ، وَیَصُومُ أَحْیَانًا۔",,,9799,,
9800,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لَہُ : إنَّ أُمِّی تُقْسِمُ عَلَیَّ أَنْ لاَ أُصَلِّیَ بَعْدَ الْمَکْتُوبَۃِ شَیْئًا ، وَلاَ أَصُوم إِلاَّ فَرِیضَۃً ، شَفَقَۃً عَلَیَّ ؟ قَالَ : أَبْرِرْ قَسَمَہَا۔",,,9800,,
9801,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : سَأَلْتُ مَکْحُولاً عَنْ رَجُلٍ أَصْبَحَ صَائِمًا ، ثُمَّ عَزَمَتْ عَلَیْہِ أُمُّہُ أَنْ یُفْطِرَ ؟ کَأَنَّہُ کَرِہَ ذَلِکَ ، وَقَالَ : یَصُومُ یَوْمًا مَکَانَہُ۔",,,9801,,
9802,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : أَتَتِ امْرَأَۃٌ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَتْ : یَا نَبِیَّ اللہِ ، مَا حَقُّ الزَّوْجِ عَلَی زَوْجَتِہِ ؟ قَالَ : لاَ تَصُومُ إِلاَّ بِإِذْنِہِ إِلاَّ الْفَرِیضَۃَ ، فَإِنْ فَعَلَتْ أَثَمَتْ ، وَلَمْ یُقْبَلْ مِنْہَا۔ (ابوداؤد 1951)",,,9802,,
9803,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، قَالَ : کَتَبَ إلَیْنَا عُمَرُ أَنَّ الْمَرْأَۃَ لاَ تَصُومُ تَطَوُّعًا ، إِلاَّ بِإِذْنِ زَوْجِہَا۔",,,9803,,
9804,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ تَصُومُ تَطَوُّعًا وَہُوَ شَاہِدٌ إِلاَّ بِإِذْنِہِ۔",,,9804,,
9805,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیانَ ، عَنْ أَبِی الزِّنَادِ ، عَنْ مُوسَی بْنِ أَبِی عُثْمَانَ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : لاَ تَصُومُ الْمَرْأَۃُ إِلاَّ بِإِذْنِ زَوْجِہَا۔ (بخاری 5195۔ مسلم 84)",,,9805,,
9806,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ أَبِی الْخَلِیلِ ، عَنْ أَبِی قَتَادَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَوْمُ عَرَفَۃَ کَفَّارَۃُ سَنَتَیْنِ : سَنَۃٍ مَاضِیَۃٍ ، وَسَنَۃٍ مُسْتَقْبَلَۃٍ۔",,,9806,,
9807,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَہْدِیِّ بْنِ مَیْمُونٍ ، عَنْ غَیْلاَنَ بْنِ جَرِیرٍ ، عَنْ عَبْدِ اللہِ بْنِ مَعْبَدٍ الزِّمَّانِیِّ ، عَنْ أَبِی قَتَادَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ عَنْ صِیَامِ عَرَفَۃَ ؟ فَقَالَ : أحْتَسِبُ عَلَی اللہِ کَفَّارَۃَ سَنَتَیْنِ : سَنَۃً مَاضِیَۃً ، وَسَنَۃً مُسْتَقْبَلَۃً۔",,,9807,,
9808,حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنْ أَبِی قَیْسٍ، عَنْ ہُزَیْلٍ، عَنْ مَسْرُوقٍ، عَنْ عَائِشَۃَ؛ أَنَّہَا کَانَتْ تَصُومُ عَرَفَۃَ۔,,,9808,,
9809,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی قَیْسٍ ، عَنْ ہُزَیْلٍ ، عَنْ مَسْرُوق ، عَنْ عَائِشَۃَ قَالَتْ : مَا مِنَ السَّنَۃِ یَوْمٌ أَحَبُّ إلَیَّ أَنْ أَصُومَہُ مِنْ یَوْمِ عَرَفَۃَ۔",,,9809,,
9810,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ أَبِی حَفْصٍ الطَّائِفِیِّ ، عَنْ أَبِی حَازِمٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَوْمُ عَرَفَۃَ کَفَّارَۃُ سَنَتَیْنِ۔ (ابویعلی 7548۔ طبرانی 5923)",,,9810,,
9811,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَصُومُ عَرَفَۃَ۔,,,9811,,
9812,"حَدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ إبْرَاہِیمَ ، قَالَ فِی صَوْمِ عَرَفَۃَ فِی الْحَضَرِ: إذَا کَانَ فِیہِ اخْتِلاَفٌ فَلاَ یَصُومَنَّ۔",,,9812,,
9813,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا لاَ یَرَوْنَ بِصَوْمِ عَرَفَۃَ بَأْسًا ، إِلاَّ أَنْ یَتَخَوَّفُوا أَنْ یَکُونَ یَوْمَ الذَّبْحِ۔",,,9813,,
9814,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ مُجَاہِدٍ ، أَنَّ عَائِشَۃَ قَالَتْ : إنَّ صَوْمَ عَرَفَۃَ کَفَّارَۃُ نِصْفِ سَنَۃٍ ، قَالَ : وَقَالَ مُجَاہِدٌ ، قَالَ فُلاَنٌ : کَفَّارَۃُ سَنَۃٍ۔",,,9814,,
9815,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ الطَّوِیلُ ، قَالَ : ذُکِرَ عِنْدَ الْحَسَنِ أَنَّ صِیَامَ عَرَفَۃَ یَعْدِلُ صِیَامَ سَنَۃٍ ، فَقَالَ الْحَسَنُ : مَا أَعْلَمُ لِیَوْمٍ فَضْلاً عَلَی یَوْمٍ ، وَلاَ لِلَیْلَۃٍ عَلَی لَیْلَۃٍ ، إِلاَّ لَیْلَۃَ الْقَدْرِ فَإِنَّہَا خَیْرٌ مِنْ أَلْفِ شَہْرٍ ، وَلَقَدْ رَأَیْتُ عُثْمَانَ بْنَ أَبِی الْعَاصِ صَامَ یَوْمَ عَرَفَۃَ ، یَرُشُّ عَلَیْہِ الْمَائَ مِنْ إدَاوَۃٍ مَعَہُ ، یَتَبَرَّدُ بِہِ۔",,,9815,,
9816,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ سَعْدِ بْنِ سَعِیدٍ ، قَالَ : سَمِعْتُ عُمَرَ بْنَ ثَابِتٍ ، قَالَ : سَمِعْتُ أَبَا أَیُّوبَ الأَنْصَارِیَّ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَامَ رَمَضَانَ ، ثُمَّ أَتْبَعَہُ بِسِتَّۃِ أَیامٍ مِنْ شَوَّالٍ فَقَدْ صَامَ الدَّہْرَ ، أَوْ فَکَأَنَّمَا صَامَ الدَّہْرَ۔ (ترمذی 759۔ ابوداؤد 2425)",,,9816,,
9817,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ أَبِی مُوسَی ، عَنِ الْحَسَنِ ، قَالَ : إذَا ذُکِرَ عِنْدَہُ السِّتَّۃُ الأَیَّامُ الَّتِی یَصُومُہَا بَعْضُ النَّاسِ بَعْدَ رَمَضَانَ تَطَوُّعًا ، قَالَ : یَقُولُ : لَقَدْ رَضِیَ اللَّہُ عَزَّ وَجَلَّ بِہَذَا الشَّہْرِ لِلسَّنَۃِ کُلِّہَا۔",,,9817,,
9818,"حَدَّثَنَا حَفْصٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : قَالَتْ عَائِشَۃُ : إِنْ کَانَ لَیَکُونُ عَلَیَّ الصَّوْمُ مِنْ شَہْرِ رَمَضَانَ ، فَمَا أَقْضِیہ حَتَّی یَأْتِیَ شَعْبَانُ۔ (بخاری 1950۔ مسلم 151)",,,9818,,
9819,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنِ السُّدِّیِّ ، عَنْ عَبْدِ اللہِ الْبَہِیِّ ، عَنْ عَائِشَۃَ قَالَتْ : مَا کُنْت أَقْضِی مَا یَبْقَی عَلَیَّ مِنْ رَمَضَانَ فِی حَیَاۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلاَّ فِی شَعْبَانَ۔ (ترمذی 783۔ احمد 6/179)",,,9819,,
9820,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ عُمَرَ ، قَالَ : حَدَّثَنِی مَنْ لاَ أَتَّہِمُ ، عَنْ عُبَادَۃَ بْنِ الصَّامِتِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا رَأَی الْہِلاَلَ ، قَالَ : اللَّہُ أَکْبَرُ اللَّہُ أَکْبَرُ ، الْحَمْدُ لِلَّہِ، وَلاَ حَوْلَ وَلاَ قُوَّۃَ إِلاَّ بِاللَّہِ ، اللَّہُمَّ إنِّی أَسْأَلُک خَیْرَ ہَذَا الشَّہْرِ ، وَأَعُوذُ بِکَ مِنْ شَرِّ الْقَدَرِ ، وَمِنْ شَرِّ یَوْمِ الْحَشْرِ۔ (دارمی 1687۔ ابن حبان 888)",,,9820,,
9821,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، قَالَ : انْصَرَفْتُ مَعَ سَعِیدِ بْنِ الْمُسَیَّبِ مِنَ الْمَسْجِدِ فَقُلْنَا : ہَذَا الْہِلاَلُ ، یَا أَبَا مُحَمَّدٍ ، فَلَمَّا أَبْصَرَہُ ، قَالَ : آمَنْتُ بِالَّذِی خَلَقَک فَسَوَّاک فَعَدَلَک ، ثُمَّ الْتَفَتَ إلَیَّ ، فَقَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا رَأَی الْہِلاَلَ قَالَ ہَکَذَا۔ (عبدالرزاق 7351)",,,9821,,
9822,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عُبَیْدِ بْنِ عَمْرٍو ، عَنْ عَلِیٍّ ، قَالَ : إذَا رَأَی أَحَدُکُمُ الْہِلاَلَ فَلاَ یَرْفَعْ بِہِ رَأْسَہ ، إنَّمَا یَکْفِی مِنْ أَحَدِکُمْ أَنْ یَقُولَ : رَبِّی وَرَبُّک اللَّہُ۔",,,9822,,
9823,"حَدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا رَأَیْت الْہِلاَلَ فَقُلْ : رَبِّی وَرَبُّک اللَّہُ۔",,,9823,,
9824,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، أَنَّ عَلِیًّا کَانَ یَقُولُ إذَا رَأَی الْہِلاَلَ : اللَّہُمَّ ارْزُقْنَا نَصْرَہُ وَخَیْرَہُ وَبَرَکَتَہُ وَفَتْحَہُ وَنُورَہُ ، نَعُوذُ بِکَ مِنْ شَرِّہِ وَشَرِّ مَا بَعْدَہُ۔",,,9824,,
9825,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ رَجُلٍ مِنَ النَّخَعِ ، عَنْ أَبِی مَسْعُودٍ الْبَدْرِیِّ ، قَالَ : لأَنْ أَخِرَّ مِنْ ہَذَا الْقَصْرِ أَحَبُّ إلَیَّ مِنْ أَنْ أَفْعَلَ کَمَا یَفْعَلُونَ ، إذَا رَأَی أَحَدُکُمُ الْہِلاَلَ کَأَنَّمَا یَرَی رَبَّہُ۔",,,9825,,
9826,"حَدَّثَنَا حُسَین بْنُ عَلِیٍّ ، قَالَ : سَأَلْتُ ہِشَامَ بْنَ حَسَّانَ : أَیُّ شَیْئٍ کَانَ الْحَسَنُ یَقُولُ إذَا رَأَی الْہِلاَلَ ؟ قَالَ : کَانَ یَقُولُ : اللَّہُمَّ اجْعَلْہُ شَہْرَ بَرَکَۃٍ وَنُورٍ وَأَجْرٍ وَمُعَافَاۃٍ ، اللَّہُمَّ إنَّک قَاسِمٌ بَیْنَ عِبَادِکَ فِیہِ خَیْرًا ، فَاقْسِمْ لَنَا فِیہِ مِنْ خَیْرِ مَا تُقْسِمُ فِیہِ بَیْنَ عِبَادِکَ الصَّالِحِینَ۔",,,9826,,
9827,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، قَالَ : سَأَلْتُ ابْنَ جُرَیْجٍ فَذَکَرَ ، عَنْ عَطَائٍ : أَنَّ رَجُلاً أَہَلَّ ہِلاَلاً بِفَلاَۃٍ مِنَ الأَرْضِ ، قَالَ : فَسَمِعَ قَائِلاً یَقُولُ : اللَّہُمَّ أَہِلَّہُ عَلَیْنَا بِالأَمْنِ وَالإِیمَانِ ، وَالسَّلاَمَۃِ وَالإِسْلاَمِ ، وَالْہُدَی وَالْمَغْفِرَۃِ ، وَالتَّوْفِیقِ لِمَا تَرْضَی ، وَالْحِفْظِ مِمَّا تَسْخَطُ ، رَبِّی وَرَبُّک اللَّہُ ، قَالَ : فَلَمْ یَزَلْ یُلْقیہنَّ حَتَّی حَفِظْتُہُنَّ ، وَمَا أرََی أَحَدًا۔",,,9827,,
9828,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُعْجِبُہُمْ إذَا رَأَی الرَّجُلُ الْہِلاَلَ أَنْ یَقُولَ : رَبِّی وَرَبُّک اللَّہُ۔",,,9828,,
9829,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ یَکْرَہُ الإِشَارَۃَ عِنْدَ رُؤْیَۃِ الْہِلاَلِ وَرَفْعَ الصَّوْتِ۔",,,9829,,
9830,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْر ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا رَأَی ہِلاَلاً ، قَالَ : ہِلاَلُ خَیْرٍ وَرُشْدٍ ، ہِلاَلُ خَیْرٍ وَرُشْدٍ ، آمَنْتُ بِالَّذِی خَلَقَک ، ثَلاَثًا ، الْحَمْدُ لِلَّہِ الَّذِی ذَہَبَ بِشَہْرِ کَذَا وَکَذَا۔ (ابوداؤد 5051)",,,9830,,
9831,"حَدَّثَنَا یَعْلَی ، قَالَ : حدَّثَنَا حَجَّاجُ بْنُ دِینَارٍ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَرِہَ أَنْ یَنْتَصِبَ لِلْہِلاَلِ ، وَلَکِنْ یَعْتَرِضُ وَیَقُولُ : اللَّہُ أَکْبَرُ ، وَالْحَمْدُ لِلَّہِ الَّذِی ذَہَبَ بِہِلاَلِ کَذَا وَکَذَا ، وَجَائَ بِہِلاَلِ کَذَا وَکَذَا۔",,,9831,,
9832,"حَدَّثَنَا عَبَّادٌ ، عَنْ سَعِیدٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ سُئِلَ عَنْ صَوْمِ النَّیْرُوزِ ؟ فَکَرِہَہُ ، وَقَالَ : تُعَظِّمُونَہُ۔",,,9832,,
9833,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، قَالَ : سُئِلَ الْحَسَنُ عَنْ صَوْمِ یَوْمِ النَّیْرُوزِ ؟ فَقَالَ : مَا لَکُمْ وَلِلنَّیْرُوزِ ؟ لاَ تَلْتَفِتُوا إلَیْہِ ، فَإِنَّمَا ہُوَ لِلْعَجَمِ۔",,,9833,,
9834,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ نُمَیْرِ بن عَرِیبٍ ، عَنْ عَامِرِ بْنِ مَسْعُود ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الصَّوْمُ فِی الشِّتَائِ الْغَنِیمَۃُ الْبَارِدَۃُ۔ (احمد 4/335۔ ترمذی 797)",,,9834,,
9835,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : قَالَ عُمَرُ : الشِّتَائُ غَنِیمَۃُ العَابِدِ۔",,,9835,,
9836,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : کَانَ یَقُولُ إذَا جَائَ الشِّتَائُ : یَا أَہْلَ الْقُرْآنِ طَالَ اللَّیْلُ لِصَلاَتِکُمْ ، وَقَصُرَ النَّہَارُ لِصِیَامِکُمْ فَاغْتَنِمُوا۔",,,9836,,
9837,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ أَبِی زُہْرَۃَ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا صَامَ، ثُمَّ أَفْطَرَ ، قَالَ : اللَّہُمَّ لَکَ صُمْت وَعَلَی رِزْقِکَ أَفْطَرْت ، قَالَ : وَکَانَ الرَّبِیعُ بْنُ خُثَیْمٍ یَقُولُ : الْحَمْدُ لِلَّہِ الَّذِی أَعَانَنِی فَصُمْت ، وَرَزَقَنِی فَأَفْطَرْت۔ (ابوداؤد 2349۔ نسائی 10131)",,,9837,,
9838,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَنَسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا أَفْطَرَ عِنْدَ أَہْلِ بَیْتٍ ، قَالَ : أَفْطَرَ عِنْدَکُمُ الصَّائِمُونَ وَأَکَلَ طَعَامَکُمُ الأَبْرَارُ ، وَنَزَلَتْ عَلَیْکُمُ الْمَلاَئِکَۃُ۔ (احمد 3/118۔ دارمی 1772)",,,9838,,
9839,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ ثَابِتِ بْنِ الْحَجَّاجِ ، عَنْ عَوْفِ بْنِ مَالِکٍ الأَشْجَعِیِّ، قَالَ : قَالَ عُمَرُ : صِیَامُ یَوْمٍ مِنْ غَیْرِ رَمَضَانَ وَإِطْعَامُ مِسْکِینٍ ، یَعْدِلُ صِیَامَ یَوْمٍ مِنْ رَمَضَانَ۔",,,9839,,
9840,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَصُومُ مِنَ الشَّہْرِ حَتَّی نَقُولَ : مَا یُفْطِرُ ، وَیُفْطِرُ حَتَّی نَقُولَ : مَا یَصُومُ مِنْہُ شَیْئًا۔ (مسلم 180۔ ترمذی 769)",,,9840,,
9841,"حَدَّثَنَا ابن نُمَیْرٍ ، قَالَ : حدَّثَنَا عُثْمَانُ بْنُ حَکِیمٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنْ صِیَامِ رَجَبٍ ؟ فَقَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَصُومُ حَتَّی نَقُولَ : لاَ یُفْطِرُ ، وَیُفْطِرُ حَتَّی نَقُولَ : لاَ یَصُومُ۔ (بخاری 1971۔ مسلم 178)",,,9841,,
9842,"حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، عَنْ سَعدِ بْنِ ہِشَامٍ ، عَنْ عَائِشَۃَ قَالَتْ : لاَ أَعْلَمُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَامَ شَہْرًا قَطُّ کَامِلاً ، إِلاَّ رَمَضَانَ۔ (ابوداؤد 1339۔ مسلم 139)",,,9842,,
9843,"حَدَّثَنَا وَکِیعٌ ، عَنْ کَہْمَسٍ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ ، عَنْ عَائِشَۃَ ، قَالَ : سَأَلْتُُہَا عَنْ صِیَامِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَتْ : مَا عَلِمْتُہُ صَامَ شَہْرًا حَتَّی یُفْطِرَ فِیہِ إِلاَّ رَمَضَانَ ، وَلاَ أَفْطَرَہُ حَتَّی یَصُومَ مِنْہُ۔ (مسلم 809۔ احمد 6/157)",,,9843,,
9844,"حَدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ ، عَنْ إسْمَاعِیلَ بْنِ کَثِیرٍ ، عَنْ عَاصِمِ بْنِ لَقِیطِ بْنِ صَبِرَۃَ ، عَنْ أَبِیہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : بَالِغْ فِی الاِسْتِنْشَاق ، إِلاَّ أَنْ تَکُونَ صَائِمًا۔",,,9844,,
9845,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ أَبِیہِ، قَالَ: کَانَ الضَّحَّاکُ وَأَصْحَابُہُ بِخُرَاسَانَ فِی رَمَضَانَ، فَکَانُوا لاَ یَتَمَضْمَضُونَ۔",,,9845,,
9846,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَبِی ہِلاَلٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ یَکْرَہُ أَنْ یَسْتَنْشِقَ الصَّائِمُ حَتَّی لاَ یَدْخُلَ حَلْقَہُ۔",,,9846,,
9847,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ عَمَّارِ بْنِ رُزَیْقٍ ، عَنْ أَبِی فَرْوَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا اسْتَنْشَقْت وَأَنْتَ صَائِمٌ فَلاَ تُبَالِغْ۔",,,9847,,
9848,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ ثَابِتٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَابِسٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إذَا کَانَ أَحَدُکُمْ صَائِمًا ، فَلْیَدَّہِنْ حَتَّی لاَ یُرَی عَلَیْہِ أَثَرُ صَوْمِہِ ، وَإِذَا بَزَقَ فَلْیَسْتُرْ بُزَاقَہُ ، وَأَشَارَ یَزِیدُ بِیَدِہِ کَأَنَّہُ یُغَطِّی بِہَا فَاہُ۔",,,9848,,
9849,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، قَالَ : قَالَ عِیسَی ابْنُ مَرْیَمَ : إذَا کَانَ یَوْمُ صَوْمِ أَحَدِکُمْ فَلْیَدَّہِنْ شَفَتَیْہِ۔",,,9849,,
9850,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَصِینٍ ، عَنْ یَحْیَی ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا أَصْبَحْتُمْ صِیَامًا فَأَصْبِحُوا مُدَّہَنِینَ۔",,,9850,,
9851,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ وَبَرَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ خَرَشَۃَ بْنِ الْحُرِّ ، قَالَ : رَأَیْتُ عُمَرَ یَضْرِبُ أَکُفَّ النَّاسِ فِی رَجَبٍ ، حَتَّی یَضَعُوہَا فِی الْجِفَانِ وَیَقُولُ : کُلُوا فَإِنَّمَا ہُوَ شَہْرٌ کَانَ یُعَظِّمُہُ أَہْلُ الْجَاہِلِیَّۃِ۔",,,9851,,
9852,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، قَالَ : سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ صَوْمِ رَجَبٍ ؟ قَالَ : أَیْنَ أَنْتُمْ مِنْ شَعْبَانَ ؟ (عبدالرزاق 7858)",,,9852,,
9853,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ مَوْلَی الصَّہْبَائِ ، عَنْ رَجُلٍ قَدْ سَمَّاہُ ، عَنْ أَنَسٍ ، قَالَ : لاَ تَکُنْ اثْنَیْنِیًّا ، وَلاَ خَمِیسِیًّا ، وَلاَ رَجَبِیًّا۔",,,9853,,
9854,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَاصِمِ بْنِ مُحَمَّدٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ ابْنُ عُمَرَ إذَا رَأَی النَّاسَ ، وَمَا یُعِدّونَ لِرَجَبٍ ، کَرِہَ ذَلِکَ۔",,,9854,,
9855,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، قَالَ : سَأَلْتُ عَائِشَۃَ عَنْ صِیَامِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَتْ : کَانَ یَصُومُ حَتَّی نَقُولَ : لاَ یُفْطِرُ ، وَیُفْطِرُ حَتَّی نَقُولَ : لاَ یَصُومُ ، وَلَمْ أَرَہُ فِی شَہْرٍ أَکْثَرَ صِیَامًا مِنْہُ فِی شَعْبَانَ ، کَانَ یَصُومُ شَعْبَانَ إِلاَّ قَلِیلاً ، بَلْ کَانَ یَصُومُ شَعْبَانَ کُلَّہُ۔ (بخاری 1919۔ ابوداؤد 2426)",,,9855,,
9856,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا صَدَقَۃُ بْنُ مُوسَی ، قَالَ : أَخْبَرَنَا ثَابِتٌ الْبُنَانِیُّ ، عَنْ أَنَسٍ ، قَالَ : سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ أَفْضَلِ الصِّیَامِ ؟ فَقَالَ : صِیَامُ شَعْبَانَ تَعْظِیمًا لِرَمَضَانَ۔ (ترمذی 663۔ ابویعلی 3431)",,,9856,,
9857,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا الْمَسْعُودِیُّ ، عَنِ الْمُہَاجِرِ أَبِی الْحَسَنِ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، قَالَ : لَمْ یَکُنْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی شَہْرٍ أَکْثَرَ صِیَامًا مِنْہُ فِی شَعْبَانَ ، وَذَلِکَ أَنَّہُ تُنْسَخُ فِیہِ آجَالُ مَنْ یَمُوتُ فِی السَّنَۃِ۔",,,9857,,
9858,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : حَدَّثَتَا ثَابِتُ بْنُ قَیْسٍ ، قَالَ : حدَّثَنِی أَبُو سَعِیدٍ الْمَقْبُرِیُّ ، قَالَ : حَدَّثَنِی أَبُو ہُرَیْرَۃَ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، رَأَیْتُک تَصُومُ فِی شَعْبَانَ صَوْمًا لاَ تَصُومُہ فِی شَیْئٍ مِنَ الشُّہُورِ ، إِلاَّ فِی شَہْرِ رَمَضَانَ ؟ قَالَ : ذَلِکَ شَہْرٌ یَغْفُلُ النَّاسُ عَنْہُ ، بَیْنَ رَجَبٍ وَشَہْرِ رَمَضَانَ ، تُرْفَعُ فِیہِ أَعْمَالُ النَّاسِ ، فَأُحِبُّ أَنْ لاَ یُرْفَعَ لِی عَمَلٌ إِلاَّ وَأَنَا صَائِمٌ۔ (احمد 5/201)",,,9858,,
9859,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی لَبِیدٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ عَائِشَۃَ ، قَالَ : سَأَلْتُُہَا عَنْ صِیَامِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَتْ : لَمْ أَرَہُ صَائِمًا مِنْ شَہْرٍ قَطُّ أَکْثَرَ مِنْ صِیَامِہِ فِی شَعْبَانَ ، کَانَ یَصُومُ شَعْبَانَ کُلَّہ ، کَانَ یَصُومُ شَعْبَانَ إِلاَّ قَلِیلاً۔ (مسلم 176۔ ابن ماجہ 1710)",,,9859,,
9860,"حَدَّثَنَا سُفْیَانُ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی عُبَیْدٍ مَوْلَی ابْنِ أَزْہَرَ ، قَالَ : شَہِدْتُ الْعِیدَ مَعَ عُمَرَ بْنِ الْخَطَّابِ، فَبَدَأَ بِالصَّلاَۃِ قَبْلَ الْخُطْبَۃِ ، وَقَالَ : إنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ صَوْمِ ہَذَیْنِ الْیَوْمَیْنِ : أَمَّا یَوْمُ الْفِطْرِ فَیَوْمُ فِطْرِکُمْ مِنْ صِیَامِکُمْ ، وَأَمَّا یَوْمُ الأَضْحَی فَکُلُوا فِیہِ مِنْ لَحْمِ نُسُکِکُمْ۔ (بخاری 5573۔ ترمذی 771)",,,9860,,
9861,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ سَعْدِ بْنِ سَعِیدٍ ، قَالَ : أَخْبَرَتْنِی عَمْرَۃُ بِنْتُ عَبْدِ الرَّحْمَنِ ، عنْ عَائِشَۃَ قَالَتْ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ صَوْمِ یَوْمِ الْفِطْرِ وَیَوْمِ الأَضْحَی۔ (مسلم 143)",,,9861,,
9862,حَدَّثَنَا یَحْیَی بْنُ یَعْلَی ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، عَنْ قَزَعَۃَ ، عَنْ أَبِی سَعِیدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنْ صَوْمِ یَوْمِ الْفِطْرِ وَیَوْمِ الأَضْحَی۔ (بخاری 1995۔ ترمذی 799),,,9862,,
9863,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُلَیٍّ ، عَنْ أَبِیہِ ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَوْمُ عَرَفَۃَ وَیَوْمُ الأَضْحَی وَأَیَّامُ التَّشْرِیقِ ، أَیَّامُ أَکْلٍ وَشُرْبٍ۔ (ترمذی 773۔ ابوداؤد 2411)",,,9863,,
9864,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ زِیَادِ بْنِ جُبَیْرٍ ، قَالَ : جَائَ رَجُلٌ إلَی ابْنِ عُمَرَ فَسَأَلَہُ عَنْ رَجُلٍ نَذَرَ أَن یَصُومُ یَوْمًا ، فَوَافَقَ ذَلِکَ فِطْرًا ، أَوْ أَضْحَی ؟ قَالَ : أَمَرَ اللَّہُ تَعَالَی بِوَفَائِ النَّذْرِ ، وَنَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ صِیَامِ ہَذَا الْیَوْمِ۔ (بخاری 1994۔ مسلم 800)",,,9864,,
9865,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ صَوْمِ الْفِطْرِ وَیَوْمِ الأَضْحَی۔ (بخاری 6705)",,,9865,,
9866,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَیَزِیدُ بْنُ ہَارُونَ قَالاَ : أَخْبَرَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ یَعْقُوبَ بْنِ عُتْبَۃَ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ صِیَامِ یَومِ الْفِطْرِ وَیَوْمِ النَّحْرِ۔ (بخاری 1991۔ مسلم 141)",,,9866,,
9867,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنِ الْمُطَّلِبِ بْنِ أَبِی وَدَاعَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إنِّی أَفْطَرْت یَوْمًا مِنْ رَمَضَانَ ، فَقَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَصَدَّقْ ، وَاسْتَغْفِرِ اللَّہَ ، وَصُمْ یَوْمًا مَکَانَہُ۔ (ابوداؤد 2385۔ دارقطنی 27)",,,9867,,
9868,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ الْحَذَّائِ ، قَالَ : قَالَ لِی عَاصِمٌ : سَأَلْتُ جَابِرَ بْنَ زَیْدٍ : مَا بَلَغَک فِیمَنْ أَفْطَرَ یَوْمًا مِنْ رَمَضَانَ ، مَا عَلَیْہِ ؟ قَالَ : لِیَصُمْ یَوْمًا مَکَانَہُ ، وَیَصْنَعُ مَعَ ذَلِکَ مَعْرُوفًا۔",,,9868,,
9869,"حَدَّثَنَا شَرِیکٌ، عَنْ مُغِیرَۃَ، عَنْ إِبْرَاہِیمَ (ح) وَعَن ابْنِ أَبِی خَالِدٍ، عَنِ الشَّعْبِیِّ، قَالاَ: یَقْضِی یَوْمًا مَکَانَہُ۔",,,9869,,
9870,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : عَلَیْہِ یَوْمٌ مَکَانَہُ۔",,,9870,,
9871,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ یَعْلَی بْنِ حَکِیمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ فِی رَجُلٍ أَفْطَرَ یَوْمًا مِنْ رَمَضَانَ مُتَعَمِّدًا ، قَالَ : یَسْتَغْفِرُ اللَّہَ مِنْ ذَلِکَ وَیَتُوبُ إلَیْہِ ، وَیَقْضِی یَوْمًا مَکَانَہُ۔",,,9871,,
9872,حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرٍ ، عَنْ یَعْلَی ، عَنْ سَعِیدٍ ، مِثْلَہُ۔,,,9872,,
9873,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَاصِمٍ ، قَالَ : أَرْسَلَ أَبُو قِلاَبَۃَ إلَی سَعِیدِ بْنِ الْمُسَیَّبِ یَسْأَلَہُ عَن رَجُلٍ أَفْطَر یَوْمًا مِنْ رَمَضَانَ مُتَعَمِّدًا ؟ فَقَالَ سَعِیدٌ : یَصُومُ مَکَانَ کُلِّ یَوْمٍ أَفْطَر شَہْرًا۔",,,9873,,
9874,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی رَجُلٍ یُفْطِرُ یَوْمًا مِنْ رَمَضَانَ مُتَعَمِّدًا ، قَالَ : یَصُومُ شَہْرًا۔",,,9874,,
9875,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : عَلَیْہِ صَوْمُ ثَلاَثَۃِ آلاَفِ یَوْمٍ۔",,,9875,,
9876,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنِ ابْنِ الْمُطَوِّسِ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ أَفْطَرَ یَوْمًا مِنْ غَیْرِ رُخْصَۃٍ ، لَمْ یُجْزِہِ صِیَامُ الدَّہْرِ۔ (ابن ماجہ 1672۔ احمد 2/442)",,,9876,,
9877,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ وَاصِلٍ، عَنْ مُغِیرَۃَ الْیَشْکُرِیِّ، عَنْ فُلاَنِ بْنِ الْحَارِثِ، عَنِ ابْنِ مَسْعُودٍ، قَالَ : مَنْ أَفْطَرَ یَوْمًا مِنْ رَمَضَانَ مِنْ غَیْرِ رُخْصَۃٍ ، لَمْ یُجْزِہِ صِیَامُ الدَّہْرِ کُلِّہِ۔ (عبدالرزاق 7476)",,,9877,,
9878,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَمْرِو بْنِ یَعْلَی ، عَنْ عَرْفَجَۃَ ، عَنْ عَلِیٍّ ، قَالَ : مَنْ أَفْطَرَ یَوْمًا مِنْ رَمَضَانَ مُتَعَمِّدًا ، لَمْ یَقْضِہِ أَبَدًا طُولَ الدَّہْرِ۔",,,9878,,
9879,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ حُمَیْدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : ہَلَکْتُ ، قَالَ : وَمَا أَہْلَکَکَ ؟ قَالَ : وَقَعْت عَلَی امْرَأَتِی فِی رَمَضَانَ ، قَالَ : أَعْتِقْ رَقَبَۃً ، قَالَ : لاَ أَجِدُ ، قَالَ : فَصُمْ شَہْرَیْنِ ، قَالَ : لاَ أَسْتَطِیعُ ، قَالَ : فَأَطْعِمْ سِتِّینَ مِسْکِینًا ، قَالَ : لاَ أَجِدُ ، قَالَ : اجْلِسْ فَجَلَسَ ، فَبَیْنَمَا ہُوَ کَذَلِکَ إذْ أُتِیَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِعَرَقٍ فِیہِ تَمْرٌ ، فَقَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اذْہَبْ فَتَصَدَّقْ بِہِ ، قَالَ : وَالَّذِی بَعَثَک بِالْحَقِّ مَا بَیْنَ لاَبَتَیْہَا أَہْلُ بَیْتٍ أَفْقَرُ إلَیْہِ مِنَّا ، قَالَ: فَضَحِکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی بَدَتْ أَنْیَابُہُ ، ثُمَّ قَالَ : انْطَلِقْ ، فَأَطْعِمْہُ عِیَالَک۔ (بخاری6711۔ مسلم 81)",,,9879,,
9880,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِثْلَہُ ، وَقَالَ : صُمْ یَوْمًا مَکَانَہُ۔ (احمد 2/208)",,,9880,,
9881,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ مُحَمَّدِ بْنِ جَعْفَرِ بْنِ الزُّبَیْرِ ، عَنْ عَبَّادِ بْنِ عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، عَنْ عَائِشَۃَ قَالَتْ : أَتَی رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ فَذَکَرَ أَنَّہُ احْتَرَقَ ، فَسَأَلَہُ عَنْ أَمْرِہِ ، فَذَکَرَ أَنَّہُ وَقَعَ عَلَی امْرَأَتِہِ فِی رَمَضَانَ ، فَأُتِیَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِکْتَلٍ یُدْعَی الْعَرْْقُ ، فِیہِ تَمْرٌ ، فَقَالَ : أَیْنَ الْمُحْتَرِقُ ؟ فَقَامَ الرَّجُلُ ، فَقَالَ لَہُ : تَصَدَّقْ بِہَذَا۔ (بخاری 6822۔ ابوداؤد 2386)",,,9881,,
9882,حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ لاَ یُصَلِّی حَتَّی یُفْطِرَ ، وَلَوْ بِشَرْبَۃٍ مِنْ مَائٍ۔ (ابن حبان 3504۔ ابویعلی 3780),,,9882,,
9883,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْحَسَنِ بْنِ حَکِیمٍ ، عَنْ أُمِّہِ ، عَنْ أَبِی بَرْزَۃَ الأَسْلَمِیِّ ، قَالَ : کَانَ یَأْمُرُ أَہْلَہُ أَنْ یُفْطِرُوا قَبْلَ الصَّلاَۃِ عَلَی مَا تَیَسَّرَ۔",,,9883,,
9884,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ، قَالَ: کَانَ الأَسْوَد لاَ یُفْطِرُ فِی رَمَضَانَ حَتَّی یُصَلِّیَ الْمَغْرِبَ۔",,,9884,,
9885,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ؛ أَنَّ عُمَرَ وَعُثْمَانَ کَانَا یُصَلِّیَانِ الْمَغْرِبَ إذَا رَأَیَا اللَّیْلَ ، وَکَانَا یُفْطِرَانِ قَبْلَ أَنْ یُصَلِّیَا۔,,,9885,,
9886,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی مَالِکٍ ، عَنِ ابْن أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الرَّجُلِ یَدْخُلُ حَلْقَہُ الذُّبَابُ ، قَالَ : لاَ یُفْطِرُ۔",,,9886,,
9887,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ یُفْطِرُ۔",,,9887,,
9888,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یُفْطِرُ۔",,,9888,,
9889,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنْ حَفْصَۃَ بِنْتِ سِیرِینَ ، عَنِ الرَّبَابِ ، عَنْ عَمِّہَا سَلْمَانَ بْنِ عَامِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا أَفْطَرَ أَحَدُکُمْ فَلْیُفْطِرْ عَلَی تَمْرٍ ، فَإِنْ لَمْ یَجِدْ فَلْیُفْطِرْ عَلَی مَائٍ ، فَإِنَّہُ طَہُورٌ۔ (ترمذی 658۔ ابن ماجہ 1699)",,,9889,,
9890,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنْ حَفْصَۃَ بِنْتِ سِیرِینَ ، عَنِ الرَّبَابِ ، وَہِیَ أُمُّ الرَّائِحِ بِنْتُ صُلَیْعٍ ، عَنْ سَلْمَانَ بْنِ عَامِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا أَفْطَرَ أَحَدُکُمْ فَلْیُفْطِرْ عَلَی تَمْرٍ، فَإِنْ لَمْ یَجِدْ فَلْیُفْطِرْ عَلَی مَائٍ ، فَإِنَّہُ طَہُورٌ۔ (ترمذی 658۔ احمد 4/17)",,,9890,,
9891,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ أَیْمَنَ ، عَنْ أَبِیہِ ، عَنْ أَبِی سَعِیدٍ، قَالَ: دَخَلْت عَلَیْہِ فَأَفْطَرَ عَلَی تَمْرٍ۔",,,9891,,
9892,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أُمِّ مُوسَی قَالَتْ : کَانُوا یَسْتَحِبُّونَ أَنْ یُفْطِرُوا عَلَی الْبُسْرِ ، أَوِ التَّمْرِ۔",,,9892,,
9893,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ أَشْعَثَ ، عَنْ مُغِیرَۃَ بْنِ عَبْدِ اللہِ الْیَشْکُرِیِّ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ أَفْطَرَ یَوْمًا مِنْ رَمَضَانَ مُتَعَمِّدًا مِنْ غَیْرِ سَفَرٍ ، وَلاَ مَرَضٍ ، لَمْ یَقْضِہِ أَبَدًا وَإِنْ صَامَ الدَّہْرَ کُلَّہُ۔",,,9893,,
9894,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَقْضِی یَوْمًا مَکَانَہُ ، وَیَسْتَغْفِرُ رَبَّہُ۔",,,9894,,
