{"hadithnumber": "4612", "text": "سفیان ثوری کہتے ہیں کہ  ایک شخص نے خط لکھ کر عمر بن عبدالعزیز سے تقدیر کے بارے میں سوال کیا تو انہوں"}
{"hadithnumber": "4613", "text": "نافع کہتے ہیں کہ  ابن عمر رضی اللہ عنہما کا ایک شامی دوست تھا جو ان سے خط و کتابت رکھتا تھا، تو عبدا"}
{"hadithnumber": "4614", "text": "خالد الحذاء کہتے ہیں کہ  میں نے حسن  ( حسن بصری )  سے کہا: اے ابوسعید! آدم کے سلسلہ میں مجھے بتائیے"}
{"hadithnumber": "4615", "text": "حسن بصری سے اللہ تعالیٰ کے قول «ولذلك خلقهم»  اور اسی کے لیے انہیں پیدا کیا   ( سورۃ ھود: ۱۱۹ )  کے"}
{"hadithnumber": "4616", "text": "خالد الخداء کہتے ہیں کہ  میں نے حسن بصری سے کہا «ما أنتم عليه بفاتنين * إلا من هو صال الجحيم» تو انہ"}
{"hadithnumber": "4617", "text": "حمید کہتے ہیں کہ  حسن بصری کہتے تھے: آسمان سے زمین پر گر پڑنا اس بات سے مجھے زیادہ عزیز ہے کہ میں کہ"}
{"hadithnumber": "4618", "text": "حمید کہتے ہیں کہ  حسن ہمارے پاس مکہ تشریف لائے تو اہل مکہ کے فقہاء نے مجھ سے کہا کہ میں ان سے درخواس"}
{"hadithnumber": "4619", "text": "حسن بصری آیت کریمہ: «كذلك نسلكه في قلوب المجرمين»  اسی طرح سے ہم اسے مجرموں کے دل میں ڈالتے ہیں   ("}
{"hadithnumber": "4620", "text": "حسن بصری آیت کریمہ: «وحيل بينهم وبين ما يشتهون»   ان کے اور ان کی خواہشات کے درمیان حائل ہو گئی   ("}
{"hadithnumber": "4621", "text": "ابن عون کہتے ہیں کہ  میں ملک شام میں چل رہا تھا تو ایک شخص نے پیچھے سے مجھے پکارا جب میں مڑا تو دیکھ"}
{"hadithnumber": "4622", "text": "ایوب کہتے ہیں  حسن پر جھوٹ دو قسم کے لوگ باندھتے ہیں: ایک تو قدریہ، جو چاہتے ہیں کہ اس طرح سے ان کے"}
{"hadithnumber": "4623", "text": "یحییٰ بن کثیر بن عنبری کہتے ہیں کہ  قرہ بن خالد ہم سے کہا کرتے تھے: اے نوجوانو! حسن کو قدریہ مت سمجھ"}
{"hadithnumber": "4624", "text": "ابن عون کہتے ہیں کہ  اگر ہمیں یہ معلوم ہوتا کہ حسن کی بات  ( غلط معنی کے ساتھ شہرت کے )  اس مقام کو"}
{"hadithnumber": "4625", "text": "ایوب کہتے ہیں کہ  مجھ سے حسن بصری نے کہا: میں اب دوبارہ کبھی اس میں سے کوئی بات نہیں کہوں گا،  ( جس"}
{"hadithnumber": "4626", "text": "عثمان کہتے ہیں کہ  حسن نے جب بھی کسی آیت کی تفسیر کی تو تقدیر کا اثبات کیا۔"}
{"hadithnumber": "4627", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کے زمانے میں کہا کرتے تھے:"}
{"hadithnumber": "4628", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کی زندگی میں ہم لوگ کہا کرتے"}
