أۏۄأشًتۏحأتوتوأتذوزأتًشأتوتوأثصتشأىەأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأضهوۄأثىأًشزتىأۄەأ‛أتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث: 4945۔ اخرجہ احمد في """"المسند"""" (118/3) اخرجه البزار في """"المسند"""" (1043)"
4946,"أضۏزۄأؼتةطۄأظزۏمۄأشعۏأتههۄأؼىۄتأىثۏأتڬشوأ﷽أڬەأثتشەأوۏڽأۏۄأثتحأىمهأڬشحۏأۄۏڽأ=أإځأىەأتځىەأتظذتثأضەأزشۏتلحأڬۏتأ=أحوأوۏڽأضەأإدأڬضأىەأشًصۄأشڬہتأۄًتأۄەأآأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أ
أوۏڽأىەأىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أحوأوۏڽأضەأڬضأىەأثۏوتشأڬۏأؼۏتزحأڬۏأۄەأآأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أوۏڽأىەأىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أحوأوۏڽأضەأڬًىأدىتصەأڬەأضتحہأڲۏتأآأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أوۏڽأىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أحوأوۏڽأضەأڬضأىەأوضڬۏىأڬًأڬہتىتأڬہهتۏتأۄەأآأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أوۏڽأىەأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدضأطرظأوۏڽأۏۄأډتشأډۏصۏڽأۄًڽأڲۏأتضأڬەأهةەأدىحأوۏڽأڲہشأثىتأزۏتأدتةەأڲتأ‛‛ۗأ
أۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأ‛أتًشأتظهأوۏڽأۏۄأتهلتػأضتمغأۄۏڽأ=““أحوأوۏڽأضەأڬضأىەأوضڬۏىأڬًأڬہتىتأڬہهتۏتأۄەأ‛‛ۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأترحظتشأڬەأضتحہأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتضوتؼۏهأثىأۏذۏۏأثىأضهوۄأۄەأ‛أتًشأًۄأعؼۏلأۄەأۗ"
4947,"أذعشحأتثًتوتوۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=““أڬۏتأحوأوۏڽأضەأإدأڬضۏأىەأشًصۄأشڬہتأۄًتأۄەأآأهًڲأرتوًطأشۄەأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أوۏڽأىەأىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أڬۏتأحوأوۏڽأضەأڬضۏأىەأإدأڬضۏأثۏوتشأڬۏأؼۏتزحأڬۏأۄەأآأهًڲأرتوًطأشۄەأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أوۏڽأىەأ‛أځہشأىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أڬۏتأحوأوۏڽأضەأڬضۏأىەأإدأڬًةۏأظزمۄأزۏتأۄەأآأهًڲأرتوًطأشۄەأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أوۏڽأىەأ‛أحًأىثۏأتڬشوأ﷽أوضڬشتأزۏەأۏۄتڽأحڬأڬۄأىثۏأتڬشوأ﷽أڬۏأوضڬشتۄټأڲۄشۏأۄًأڲةۏأځہشأإځأىەأتشطتزألشوتۏتأ=أتضأستحأڬۏأمضوأدضأڬەأزضحأمزشحأوۏڽأوۏشۏأدتىأۄەأتۏڬأۄۏأزىأوۏڽأۏۄأضثأڬتوأڬًةۏأواوىأۄۏأڬشأضڬحتأۄەأ‛أتًشأًۄأتىأڬۏأًدۄأضەأدىحأوۏڽأزترهأۄًأڲتأ‟ۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثۏزتههۄأثىأصذشأۄەأ‛أتًشأتضأڬەأثتشەأوۏڽأڬهتوأڬۏتأڲۏتأۄەأ‛أتًشأتضأڬۏأحًخۏمأثہۏأڬۏأڲةۏأۄەأۗأ
أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأتضأڬۏأوتىىزأتۏڬأذزۏخأدوؼۄأڬەأزىأشًصۄأشڬہىەأضەأوحؼهمأثتثأوۏڽأإڲەأإةەأڲۏأ‛أتڲشأتههۄأىەأډتۄتأۗ

[تخریج]: حديث: 4947 ۔ اخرجہ الطبرانی فی المعجم الكبير"""" (7826)"
4948,"أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أإۄأڬضأىەأشًصۄأشڬہتأۄًتأۄەأآأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أوۏڽأىەأىثۏأتڬشوأ﷽أىەأزشۏتلحأڬضأىەأثۏوتشأڬۏأؼۏتزحأڬۏأۄەأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أوۏڽأىەأىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأڬًىأدىتصەأڬەأضتحہأڲۏتأۄەأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أوۏڽأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أدًأطرظأتۏڬأۄۏأزىأوۏڽأۏۄأضثأڬتوأڬشأهەأڲتأًۄأدىحأوۏڽأزترهأۄًأڲتأ‛‛ۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأ‛أتًشأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأۄطتوأثىأغهمأۄەأوۏڽأىەأڬضۏأڬًأتضأڬەأذتهتحأثۏتىأڬشحەأۄًةەأىۄۏڽأځتۏتأۄەأۗ

[تخریج]: حدیث: 4948۔ اخرجہ الطبرانی فی """" المعجم الكبير (11300)"
4949,"أذعشحأؼثزتهشذوىأثىأتثًثڬشأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأظثذأڬۏأىوتصأتزتأڬشىەأڬەأثؼزأتځىەأتظذتثأڬۏأغشلأشرأڬۏتأ‛أتًشأزشۏتلحأڬۏتأ=أڬۏتأحوأوۏڽأضەأإدأڬضۏأىەأشًصۄأشڬہتأۄەأآأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أوۏڽأىەأشًصۄأشڬہىەأڬتأىۄۏڽأضًډتأحہتأ؏أحًأوۏڽأإدأشًصەأڬەأثؽۏشأۄًڽأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أهۏڬىأوۏڽأىەأإدأشًصەأڬتأضًډتأحہتأ؏أحًأوۏڽأىەأشًصۄأشڬہتأۄًتأۄەأىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أڬۏتأحوأوۏڽأضەأڬضۏأىەأإدأثۏوتشأڬۏأؼۏتزحأڬۏأۄەأآأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أۄوأىەأحًأتثہۏأ+ألدشأڬۏأ,أىوتصأتزتأڬۏأۄەأتثہۏأڬډہأتًشأىۄۏڽأڬۏتأ؏أحًأڬضۏأثۏوتشأڬۏأؼۏتزحأڬۏضەأڬشأضڬحەأۄۏڽأآأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأثًهەأودہەأۏۄأتغهتؼأوهۏأحہۏأڬۄأوۏشەأثہتةۏأذعشحأؼثزتهشذوىأثىأؼًلأشعۏأتههۄأؼىۄأثۏوتشأۄۏڽأحًأوۏڽأإحەأۄًةەأتىأڬۏأغشلأضەأۄًأڬەأإۏتأحہتأدثأوۏڽأوضدزأڬۏأغشلأإأشۄتأحہتأڬۄأۏۄأزۏڬہأهًڽأڬۄأتىأڬتأڬۏتأذتهأۄەأآأىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أڬۏتأحوأوۏڽأضەأڬضۏأتۏڬأىەأوضڬۏىأڬًأڬډہأڬہهتۏتأۄەأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أتثہۏأحًأۄوأىەأ+ألدشأڬۏأ,أىوتصأتزتأڬۏأۄەأ‛أتًشأڬډہأثہۏأىۄۏڽأڬۏتأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأىەأؼشعأڬۏأ=أدثأوۏڽأوضدزأوۏڽأزترهأۄًتأحًأًۄتڽأتۏڬأضتةهأوًدًزأحہتأدًأوتىڲأشۄتأحہتأۗأوۏڽأ
أىەأؼثزتهشذوىأڬەأۄتحہأوۏڽأتۏڬأشًټۏأڬتأټڬڔتأځتۏتأحًأوۏڽأىەأتضأضەأهەأڬشأًۄأوضڬۏىأڬًأزەأزۏتأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أحوأدىحأڬۏأرًطرثشۏأذتظهأڬشًأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأڲۄشتأضتىضأهۏتأتًشأثًهەأ=أدىحأڬەأڬۏتأڬۄىەأآأځہشأىثۏأتڬشوأ﷽أىەأتۏڬأڬهوۄأتشطتزألشوتۏتأدضأڬەأسشۏؼەأإځأىەأذعشحأؼوشأشعۏأتههۄأؼىۄأڬۏأزهدًةۏأڬۏأتًشأځہشألشوتۏتأ=أتههۄأحؼتهۏٳأؼوشأځشأشذوأڬشەأتههۄأحؼتهۏٳأؼوشأځشأشذوأڬشەأًۄأدثأثہۏأڬضۏأثہهتةۏأڬتأتشتزۄأڬشحتأۄەأ‛أحًأتثًثڬشأتضأضەأځۄهەأتضأثہهتةۏأڬۏأغشلأضثمحأهەأدتحتأۄەأۗأ
+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أتوتوأتثًزتازأىەأتضأشًتۏحأڬتأتۏڬأذظۄأىمهأڬۏتأۄەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأوثتشڬأثىألعتهۄأۄەأ‛أتًشأًۄأخمۄأۄەأ‛أتًشأتضأڬەأثتشەأوۏڽأڬهتوأڬۏتأڲۏتأۄەأۗ"
4950,"أمحتزۄأثۏتىأڬشحەأۄۏڽأ=أذعشحأتىضأشعۏأتههۄأؼىۄأشًصۄأشڬہىەأڬەأمتثهأىۄأشۄەأۏۄأتىأڬۏألًحأۄًىەأضەأتۏڬأضتهأځۄهەأڬۏأثتحأۄەأ‛أحًأتىۄًڽأىەأشًصەأحشڬأڬشأزۏەأتًشأًۄأۄشأتۏڬأزىأڬەأؼًعأوۏڽأتۏڬأوضڬۏىأڬًأڬہتىتأڬہهتحەأحہەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأ‛أتًشأتضأڬەأشدتهأ““أظذۏذأ‛‛أڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث: 4950۔ اخرجہ الطبراني في """" المعجم الكبير"""" (675)"
4951,"أتۏًثأثىأتثًحوۏوۄأثۏتىأڬشحەأۄۏڽأ=أذعشحأتىضأشعۏأتههۄأؼىۄأشًصۄأشڬہىەأڬەأمتثهأىۄۏڽأشۄەأ‛أحًأتىۄًڽأىەأخشۏزأڬتأتۏڬأځۏتهۄأثىًتۏتأتًشأحۏضأوضڬۏىًڽأڬًأثهًتأڬشأتىۄۏڽأڬہتىتأڬہهتۏتأۗأ
