{"hadithnumber": "1524", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”معصیت کے کاموں"}
{"hadithnumber": "1525", "text": "ام المؤمنین عائشہ رضی الله عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اللہ کی معصی"}
{"hadithnumber": "1526", "text": "ام المؤمنین عائشہ رضی الله عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو شخص نذر م"}
{"hadithnumber": "1527", "text": "ثابت بن ضحاک رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”بندہ کے اختیار میں"}
{"hadithnumber": "1528", "text": "عقبہ بن عامر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”غیر متعین نذر کا کفا"}
{"hadithnumber": "1529", "text": "عبدالرحمٰن بن سمرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”عبدالرحمٰن! من"}
{"hadithnumber": "1530", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو آدمی کسی امر پر قس"}
{"hadithnumber": "1531", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے کسی امر پر"}
{"hadithnumber": "1532", "text": "ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے قسم کھائی اور ا"}
{"hadithnumber": "1533", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے عمر رضی الله عنہ کو کہت"}
{"hadithnumber": "1534", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے عمر رضی الله عنہ کو ایک ق"}
{"hadithnumber": "1535", "text": "سعد بن عبیدہ سے روایت ہے کہ  ابن عمر رضی الله عنہما نے ایک آدمی کو کہتے سنا: ایسا نہیں قسم ہے کعبہ"}
{"hadithnumber": "1536", "text": "انس رضی الله عنہ کہتے ہیں کہ  ایک عورت نے نذر مانی کہ وہ بیت اللہ تک  ( پیدل )  چل کر جائے گی، نبی ا"}
{"hadithnumber": "1537", "text": "انس رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ایک بوڑھے کے قریب سے گزرے جو اپنے دو بیٹوں"}
{"hadithnumber": "1538", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”نذر مت مانو، اس لیے کہ ن"}
{"hadithnumber": "1539", "text": "عمر رضی الله عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! میں نے جاہلیت میں نذر مانی تھی کہ ایک را"}
{"hadithnumber": "1540", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم قسم کھاتے تھے تو اکثر «لا وم"}
{"hadithnumber": "1541", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا: ”جس نے ایک موم"}
{"hadithnumber": "1542", "text": "سوید بن مقرن مزنی رضی الله عنہ کہتے ہیں کہ  صورت حال یہ تھی کہ ہم سات بھائی تھے، ہمارے پاس ایک ہی خا"}
{"hadithnumber": "1543", "text": "ثابت بن ضحاک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے اسلام کے سوا ک"}
{"hadithnumber": "1544", "text": "عقبہ بن عامر رضی الله عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! میری بہن نے نذر مانی ہے کہ وہ چ"}
{"hadithnumber": "1545", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے جس نے قسم کھائ"}
{"hadithnumber": "1546", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  سعد بن عبادہ رضی الله عنہ نے رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "1547", "text": "ابوامامہ رضی الله عنہ اور دوسرے صحابہ نبی اکرم صلی اللہ علیہ وسلم سے روایت کرتے ہیں کہ  آپ نے فرمایا"}
