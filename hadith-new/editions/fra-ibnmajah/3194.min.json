{"metadata":{"name":"Sunan Ibn Majah","section":{"27":"Chapters on Slaughtering"},"section_detail":{"27":{"hadithnumber_first":3162,"hadithnumber_last":3199,"arabicnumber_first":3162,"arabicnumber_last":3199}}},"hadiths":[{"hadithnumber":3194,"arabicnumber":3194,"text":"Rapporté par Bara’ bin ‘Azib : Le Messager d’Allah (ﷺ) nous a ordonné de jeter la viande des ânes domestiques, crue ou cuite, puis il ne nous en a plus reparlé après cela","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Sahih - Agreed Upon"}],"reference":{"book":27,"hadith":33}}]}