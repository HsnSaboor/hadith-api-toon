hadiths[4]{hadithnumber,text}:
15801,أذعشحأضۄهأثىأتثۏأذخوۄأشعۏأتههۄأؼىۄأضەأؽتهثتَأوشلًؼتَأوشًۏأۄەأڬۄأىوتصأرًلأوۏڽأتوتوأإڲەأڬہڔتأۄًأ؏أتًشأتۏڬأظلأتځىەأځۏډہەأثىتةەأتًشأتۏڬأتځىەأإڲەأ؏أځہشأځۏډہەأًتهًڽأڬًأتۏڬأشڬًؼأتًشأزًأضدزەأڬشًتةەأ؏أځہشأڬہڔتأشۄەأحتإىڬۄأًۄأهًڲأزًضشۏأشڬؼحأثہۏأځڔہأهۏڽأ؏أتًشأتځىەأضتحہۏًڽأڬۏأدڲۄأإڲەأثڔہأدتةۏڽأتًشأًۄأهًڲأۏۄتڽأإأڬشأتىأڬۏأدڲۄأڬہڔەأۄًأدتةۏڽأتًشأتوتوأتىۄۏڽأثہۏأتۏڬأشڬًؼأتًشأزًأضدزەأڬشًتةەأتًشأثۏټہأدتةەأ؏أۏۄتڽأحڬأڬۄأًۄأتځىۏأزًضشۏأشڬؼحأثہۏأځًشۏأڬشأهۏڽأ؏أځہشأإرشأوۏڽأتىأڬەأضتحہأتڬټہتأضهتوأځہۏشەأۗ
15802,أڲسطحۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗ
15803,أڲسطحۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗ
15804,أؼثزتهشذوىأثىأوضؼًزأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأتۏڬأوشحثۄأذعشحأضۄهأثىأتثۏأذخوۄأشعۏأتههۄأؼىۄأۄوتشۏأودهضأوۏڽأحطشۏلأهتةەأتًشأۏۄأذزۏخأثۏتىأڬۏأڬۄأىثۏأ﷽أىەأتشطتزألشوتۏتأدثأحوأځہهأڬتټتأڬشًأحًأڬډہأڬتټأهۏتأڬشًأ؏أتًشأڬډہأډہًڔأزۏتأڬشًأ؏أحمشۏثتأتۏڬأحۄتةۏأډہًڔأزۏتأڬشًأ؏أتڲشأتۏضتأىۄأڬشًأضڬًأحًأتۏڬأډًحہتةۏأډہًڔأزۏتأڬشًأۗ
