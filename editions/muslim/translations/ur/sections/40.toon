{"hadithnumber": "5862", "text": "ابو سلمہ بن عبد الرحمٰن نے بتا یا کہ حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے کہا  :  میں نے رسول اللہ"}
{"hadithnumber": "5863", "text": "سفیان نے زہری سے حدیث بیان کی انھوں نے ابن مسیب سے ، انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سےر"}
{"hadithnumber": "5864", "text": "معمرنے ہمیں زہری سے خبر دی انھوں نے ابن مسیب سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے ر"}
{"hadithnumber": "5865", "text": "اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما ی"}
{"hadithnumber": "5866", "text": "ابن سیرین نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  انھوں نے نبی  صلی اللہ علیہ وسلم  سے"}
{"hadithnumber": "5867", "text": "ایوب نے ابن سیرین سے ،  انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا  :  رسول اللہ"}
{"hadithnumber": "5868", "text": "سعید نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے ،  انھوں نے نبی  صلی اللہ علیہ وسلم  سے روایت کی ،  کہ"}
{"hadithnumber": "5869", "text": "ہشا م نے ابن سیرین سے ،  انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  سے انھوں  نے نبی  صلی اللہ علیہ"}
{"hadithnumber": "5870", "text": "اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  رسول اللہ  صلی اللہ علیہ وسلم  نے"}
{"hadithnumber": "5871", "text": "ہمام بن منبہ نے کہا  :  یہ احا دیث ہیں جو ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے ہمیں رسول اللہ  صلی اللہ"}
{"hadithnumber": "5872", "text": "عیسیٰ بن یو نس نے شعبہ سے ،  انھوں نے سماک بن حرب سے ،  انھوں نے علقمہ بن وائل سے ،  انھوں نے اپنے و"}
{"hadithnumber": "5873", "text": "عثمان بن عمر نے کہا  :  ہمیں شعبہ نے سماک سے حدیث بیان کی  ، انھوں نے کہا  :  میں نے علمقہ بن وائل س"}
{"hadithnumber": "5874", "text": "لا ء کے والد نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے"}
{"hadithnumber": "5875", "text": "جریر اعمش سے ،  انھوں نے ابو صالح سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روایت کی ،  ک"}
{"hadithnumber": "5876", "text": "ابو معاویہ اور وکیع دونوں نے اعمش سے اسی سند کے ساتھ روایت کی ان دونوں کی حدیث میں ہے ۔   \" غلا م اپ"}
{"hadithnumber": "5877", "text": "ہمام منبہ نے کہا  :  یہ احادیث ہیں جو ہمیں حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے رسول اللہ  صلی الل"}
{"hadithnumber": "5878", "text": "ابو بکر بن ابی شیبہ نے کہا  :  ہمیں سفیان بن عیینہ نے حدیث بیان کی  ۔ ابو کریب محمد بن علاء نے کہا"}
{"hadithnumber": "5879", "text": "ابو کریب نے کہا  :  ہمیں ابو معاویہ نے اسی سند کے ساتھ  ( یہی )  حدیث بیان کی ۔"}
{"hadithnumber": "5880", "text": "ابو امامہ بن سہل حنیف نے اپنے والد سے روایت کی کہ نبی  صلی اللہ علیہ وسلم  نے فر ما یا  :  :  \"  تم"}
{"hadithnumber": "5881", "text": "ابو اسامہ نے شعبہ سے روایت کی  ،  کہا  :  مجھے خُلید بن جعفرنے ابو نضر ہ سے  ، انھوں نے حضرت ابوسعید"}
{"hadithnumber": "5882", "text": "یزید بن ہارون نے شعبہ سے  ،  انھوں نے  خلید بن جعفر اور مستمر سے روایت کی ،  ان دونوں نے کہا  :  ہم"}
{"hadithnumber": "5883", "text": "عبد الرحمٰن اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی کہا  :  رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "5884", "text": "نافع نے کہا  :  حضرت ابن عمر رضی اللہ تعالیٰ عنہ  جب خوشبو کا دھواں لیتے تو عودکا دھواں لیتے  ، اس م"}
