hadiths[67]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
2308,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو شخص لوگوں کا قاضی  ( ف",,,,,2308
2309,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے عہدہ قضاء کا مط",,,,,2309
2310,"علی رضی اللہ عنہ کہتے ہیں کہ  مجھے رسول اللہ صلی اللہ علیہ وسلم نے یمن بھیجا، میں نے عرض کیا: اللہ ک",,,,,2310
2311,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو حاکم بھی لوگو",,,,,2311
2312,"عبداللہ بن ابی اوفی رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ کی مدد",,,,,2312
2313,"عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  رشوت دینے والے ",,,,,2313
2314,"عمرو بن العاص رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جب حاک",,,,,2314
2315,ابوہاشم کہتے ہیں کہ  اگر ابن بریدہ کی یہ روایت نہ ہوتی جو انہوں نے اپنے والد  ( بریدہ رضی اللہ عنہ ),,,,,2315
2316,"ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قاضی غصے کی حالت میں دو ا",,,,,2316
2317,"ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ میرے ",,,,,2317
2318,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں تو ایک انسان ہی ہوں،",,,,,2318
2319,"ابوذر رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو کسی ایسی چی",,,,,2319
2320,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کسی جھگڑے میں",,,,,2320
2321,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اگر لوگوں کو ان",,,,,2321
2322,اشعث بن قیس رضی اللہ عنہ کہتے ہیں کہ  میرے اور ایک یہودی کے درمیان ایک زمین مشترک تھی، اس نے میرے حص,,,,,2322
2323,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کسی چیز ک",,,,,2323
2324,"ابوامامہ حارثی رضی اللہ عنہ بیان کرتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  ",,,,,2324
2325,"جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص میرے اس ",,,,,2325
2326,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اس منبر کے پاس کوئی غلام",,,,,2326
2327,براء بن عازب رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک یہودی عالم کو بلایا،,,,,,2327
2328,"جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے دو یہودیوں سے فرمایا:",,,,,2328
2329,ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  انہوں نے ذکر کیا کہ ایک جانور پر دو آدمیوں نے دعویٰ کیا، اور ,,,,,2329
2330,ابوموسیٰ اشعری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس دو آدمی جھگڑا لے کر,,,,,2330
2331,"سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب آدمی کا کوئی سام",,,,,2331
2332,ابن محیصہ انصاری رضی اللہ عنہ کہتے ہیں کہ  براء رضی اللہ عنہ کی ایک اونٹنی کو لوگوں کا کھیت چرنے کی ,,,,,2332
2333,"قبیلہ بنی سوءۃ کے ایک شخص کا بیان ہے کہ  میں نے ام المؤمنین عائشہ رضی اللہ عنہا سے کہا: مجھ سے رسول ",,,,,2333
2334,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم امہات المؤمنین رضی اللہ عنہن میں س,,,,,2334
2335,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کسی سے اس کا",,,,,2335
2336,عکرمہ بن سلمہ کہتے ہیں  بلمغیرہ  ( بنی مغیرہ )  کے دو بھائیوں میں سے ایک نے یہ شرط لگائی کہ اگر میری,,,,,2336
2337,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی ا",,,,,2337
2338,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  راستہ کو سات ہاتھ رکھو  ",,,,,2338
2339,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم راستے کے ",,,,,2339
2340,"عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حکم دیا:  کسی کو نقصان پہنچا",,,,,2340
2341,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلیاللہ علیہ وسلم  نے فرمایا:  کسی کو نقصان پہ",,,,,2341
2342,"ابوصرمہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو کسی کو نقصان پہنچائے گ",,,,,2342
2343,جاریہ رضی اللہ عنہ سے روایت ہے کہ  کچھ لوگ ایک جھونپڑی کے متعلق جو ان کے بیچ میں تھی جھگڑا لے کر نبی,,,,,2343
2344,"سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب مال دو آدمیوں کے ",,,,,2344
2345,عمران بن حصین رضی اللہ عنہما سے روایت ہے کہ  ایک شخص کے چھ غلام تھے، ان غلاموں کے علاوہ اس کے پاس کو,,,,,2345
2346,ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  ایک بیع کے متعلق دو آدمیوں نے جھگڑا کیا، اور ان میں کسی کے پا,,,,,2346
2347,ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم جب سفر پر جاتے تو اپنی ,,,,,2347
2348,زید بن ارقم رضی اللہ عنہ کہتے ہیں کہ  علی بن ابی طالب رضی اللہ عنہ جب یمن میں تھے، تو ان کے پاس یہ م,,,,,2348
2349,ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ایک دن رسول اللہ صلی اللہ علیہ وسلم میرے پاس خوش خوش تش,,,,,2349
2350,"عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  قریش کے لوگوں نے ایک کاہنہ کے پاس آ کرکہا: ہمیں بتاو",,,,,2350
2351,ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک لڑکے کو اختیار دیا کہ وہ اپ,,,,,2351
2352,رافع بن سنان رضی اللہ عنہ کہتے ہیں کہ  ان کے ماں اور باپ دونوں نبی اکرم صلی اللہ علیہ وسلم کے پاس جھ,,,,,2352
2353,"عمرو بن عوف رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  مسلمانوں ک",,,,,2353
2354,انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں ایک شخص کچھ کم عق,,,,,2354
2355,محمد بن یحییٰ بن حبان کہتے ہیں کہ  میرے دادا منقذ بن عمرو ہیں، ان کے سر میں ایک زخم لگا تھا جس سے ان,,,,,2355
2356,ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے عہد میں ایک شخص کو اس کے خری,,,,,2356
2357,جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے معاذ بن جبل رضی اللہ ,,,,,2357
2358,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے بعینہ اپنا مال اس ",,,,,2358
2359,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے کوئی سامان بیچا",,,,,2359
2360,ابن خلدہ زرقی (وہ مدینہ کے قاضی تھے) کہتے ہیں کہ  ہم اپنے ایک ساتھی کے سلسلے میں جس کا دیوالیہ ہو گی,,,,,2360
2361,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص مر جائے، اور اس ک",,,,,2361
2362,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے پوچھا گیا: کون سے لوگ بہت",,,,,2362
2363,جابر بن سمرہ رضی اللہ عنہ کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ نے مقام جابیہ میں خطبہ دیا، اس خطبہ ,,,,,2363
2364,"زید بن خالد جہنی رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  بہت",,,,,2364
2365,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  انہوں نے آیت کریمہ: «يا أيها الذين آمنوا إذا تداينتم بدين إ",,,,,2365
2366,"عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  نہ خائ",,,,,2366
2367,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  بدوی  ( دیہ",,,,,2367
2368,ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک گواہ اور  ( مدعی کی )  قسم,,,,,2368
2369,جابر رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک گواہ اور  ( مدعی کی )  قسم سے ف,,,,,2369
2370,عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک گواہ اور  ( مدعی کی ,,,,,2370
2371,سرق (ابن اسد جہنی) رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے مدعی کی قسم کے ساتھ ا,,,,,2371
2372,خریم بن فاتک اسدی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے نماز فجر پڑھائی، جب فارغ ,,,,,2372
2373,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جھوٹی گواہی دینے",,,,,2373
2374,جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اہل کتاب کی آپس میں ,,,,,2374
