{"metadata":{"name":"Sunan an Nasai","section":{"1":"The Book of Purification"},"section_detail":{"1":{"hadithnumber_first":1,"hadithnumber_last":324,"arabicnumber_first":1,"arabicnumber_last":324}}},"hadiths":[{"hadithnumber":274,"arabicnumber":274,"text":"Rapporté par 'Aishah : La tête du Messager d’Allah (ﷺ) reposait sur la cuisse de l’une d’entre nous quand elle avait ses règles, et il récitait le Coran","grades":[{"name":"Abu Ghuddah","grade":"Hasan"},{"name":"Al-Albani","grade":"Hasan"},{"name":"Zubair Ali Zai","grade":"Sahih - Agreed Upon"}],"reference":{"book":1,"hadith":275}}]}