hadiths[54]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
688,"ابوقتادہ رضی اللہ عنہ کہتے ہیں کہ  رسول اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب نماز کے لیے اقامت کہی",,,,,688
689,"عمرو بن عبسہ رضی اللہ عنہ سے روایت ہے کہ  رسول اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے کوئی مسجد ب",,,,,689
690,"انس رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قیامت کی نشانیوں میں سے یہ ",,,,,690
691,ابراہیم تیمی کہتے ہیں کہ  گلی میں راستہ چلتے ہوئے میں اپنے والد  ( یزید بن شریک )  کو قرآن سنا رہا ت,,,,,691
692,ام المؤمنین میمونہ رضی اللہ عنہا کہتی ہیں کہ  جس نے رسول اللہ صلی اللہ علیہ وسلم کی مسجد میں نماز پڑ,,,,,692
693,"عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں:  رسول اکرم صلی اللہ علیہ وسلم، اسامہ بن زید، بلال اور عثمان ب",,,,,693
694,"عبداللہ بن عمرو رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سلیمان بن داو",,,,,694
695,"ابوہریرہ رضی اللہ عنہ کہتے ہیں:  رسول اللہ صلی اللہ علیہ وسلم کی مسجد میں نماز پڑھنا دوسری مسجدوں می",,,,,695
696,"عبداللہ بن زید رضی اللہ عنہ کہتے ہیں کہ  رسول اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو حصہ میرے گھر ۱؎",,,,,696
697,"ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  میرے اس منبر ",,,,,697
698,ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  دو آدمی اس بارے میں لڑ پڑے کہ وہ کون سی مسجد ہے جس کی بنیاد ,,,,,698
699,عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مسجد قباء  ( کبھی )  سوار ہو ,,,,,699
700,"سہل بن حنیف رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص  ( اپنے گھر سے",,,,,700
701,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   ( ثواب کی نیت سے )  صرف",,,,,701
702,طلق بن علی رضی اللہ عنہ روایت کرتے ہیں کہ  ہم نبی اکرم صلی اللہ علیہ وسلم کی طرف وفد کی شکل میں نکلے,,,,,702
703,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم مدینہ آئے تو اس کے ایک کنارے ب,,,,,703
704,ام المؤمنین عائشہ اور ابن عباس رضی اللہ عنہم کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم کی وفات کا,,,,,704
705,ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  ام المؤمنین ام حبیبہ اور ام سلمہ رضی اللہ عنہم دونوں,,,,,705
706,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس وقت بندہ اپنے گھر سے م",,,,,706
707,"عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  رسول اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کسی ",,,,,707
708,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو کوئی اس درخت میں سے کھائے",,,,,708
709,"عمر بن خطاب رضی اللہ عنہ فرماتے ہیں:  لوگو! تم ان دونوں پودوں میں سے کھاتے ہو جنہیں میں خبیث ہی سمجھ",,,,,709
710,ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اکرم صلی اللہ علیہ وسلم جب اعتکاف کا ارادہ فرماتے ,,,,,710
711,"ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں:  غزوہ خندق  ( غزوہ احزاب )  کے دن سعد بن معاذ رضی اللہ عنہ",,,,,711
712,"ابوقتادہ رضی اللہ عنہ کہتے ہیں:  ہم لوگ مسجد میں بیٹھے ہوئے تھے کہ اسی دوران رسول اللہ صلی اللہ علیہ",,,,,712
713,ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اکرم صلی اللہ علیہ وسلم نے کچھ سواروں کو قبیلہ نجد کی جانب ب,,,,,713
714,عبداللہ بن عباس رضی اللہ عنہم سے روایت ہے کہ  رسول اکرم صلی اللہ علیہ وسلم نے حجۃ الوداع میں اونٹ پر,,,,,714
715,عبداللہ بن عمرو رضی اللہ عنہم سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے جمعہ کے دن نماز سے پہلے,,,,,715
716,عبداللہ بن عمرو رضی اللہ عنہم سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے مسجد میں اشعار پڑھنے سے,,,,,716
717,سعید بن مسیب کہتے ہیں کہ  عمر رضی اللہ عنہ حسان بن ثابت رضی اللہ عنہ کے پاس سے گزرے، وہ مسجد میں اشع,,,,,717
718,جابر رضی اللہ عنہ کہتے ہیں کہ  ایک آدمی آ کر مسجد میں ایک گمشدہ چیز ڈھونڈنے لگا، تو رسول اللہ صلی ال,,,,,718
719,"سفیان ثوری کہتے ہیں کہ  میں نے عمرو بن دینار سے پوچھا: کیا آپ نے جابر رضی اللہ عنہ کو کہتے ہوئے سنا ",,,,,719
720,اسود کہتے ہیں کہ  میں اور علقمہ دونوں عبداللہ بن مسعود رضی اللہ عنہ کے پاس گئے، تو آپ نے ہم سے پوچھا,,,,,720
721,اس سند سے علقمہ اور اسود نے  عبداللہ بن مسعود رضی اللہ عنہ سے اسی جیسی حدیث ذکر کی ہے۔,,,,,721
722,عبداللہ بن زید بن عاصم رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو مسجد میں ا,,,,,722
723,عبداللہ بن عمر رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے عہد میں جب وہ نوجوان او,,,,,723
724,"انس رضی اللہ عنہ کہتے ہیں کہ  رسول اکرم صلی اللہ علیہ وسلم نے فرمایا:  مسجد میں تھوکنا گناہ ہے، اور ",,,,,724
725,عبداللہ بن عمر رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے قبلہ والی دیوار پر تھوک,,,,,725
726,ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے مسجد کی قبلہ  ( والی دیوار,,,,,726
727,"طارق بن عبداللہ محاربی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم نماز",,,,,727
728,شخیر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو دیکھا، آپ نے کھکھار کر تھوکا، ,,,,,728
729,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مسجد کے قبلہ میں بلغم دیکھا تو,,,,,729
730,ابوحمید اور ابواسید (مالک بن ربیعہ) رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمای,,,,,730
731,"ابوقتادہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی مسج",,,,,731
732,عبداللہ بن کعب کہتے ہیں کہ  میں نے کعب بن مالک رضی اللہ عنہ سے سنا، وہ اپنا وہ واقعہ بیان کر رہے تھے,,,,,732
733,ابوسعید بن معلی رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے عہد میں بازار جاتے تو م,,,,,733
734,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  فرشتے تمہارے حق میں د",,,,,734
735,"سہل ساعدی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا ہے:  جو شخص مس",,,,,735
736,عبداللہ بن مغفل رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اونٹوں کے باڑے میں نماز,,,,,736
737,"جابر بن عبداللہ رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پوری روئے زمین ۱",,,,,737
738,انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  ام سلیم رضی اللہ عنہا نے رسول اللہ صلی اللہ علیہ وسلم سے در,,,,,738
739,ام المؤمنین میمونہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کھجور کی چھوٹی چٹائی پ,,,,,739
740,ابوحازم بن دینار کہتے ہیں کہ  کچھ لوگ سہل بن سعد ساعدی رضی اللہ عنہ کے پاس آئے وہ لوگ منبر کی لکڑی ک,,,,,740
741,عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو گدھے پر نماز پڑھتے ,,,,,741
