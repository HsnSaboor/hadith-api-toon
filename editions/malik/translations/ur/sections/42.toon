{"hadithnumber": "1537", "text": "سلیمان بن یسار رحمہ اللہ سے روایت ہے کہ بے شک ایک سائبہ غلام جسے حاجیوں میں سے کسی نے آزاد کیا تھا ،"}
{"hadithnumber": "1538", "text": "حضرت سہل بن ابی حثمہ ( انصاری ، خزرجی ) رضی اللہ عنہ سے روایت ہے ، ان کی قوم کے بڑوں میں سے کچھ لوگو"}
{"hadithnumber": "1539", "text": "بُشیر بن یسار رحمہ اللہ سے روایت ہے کہ بے شک حضرت عبداللہ بن سہل انصاری رضی اللہ عنہ اور حضرت محیصہ"}
{"hadithnumber": "1540", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے ، کہتے ہیں : یہودی رسول اللہ ﷺ کے پاس آئے ، پھر انھوں ن"}
{"hadithnumber": "1541", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے کہ بے شک اسلم قبیلے کا ایک آدمی ( حضرت ماعزاسلمی رضی اللہ عنہ ) ح"}
{"hadithnumber": "1542", "text": "یحیی بن سعید رحمہ اللہ ، سعید بن مسیب رحمہ اللہ رضی اللہ عنہ سے روایت کرتے ہیں ، انھوں نے کہا : مجھے"}
{"hadithnumber": "1543", "text": "ابن شہاب رحمہ اللہ سے روایت ہے کہ بے شک ایک آدمی نے رسول اللہ ﷺ کے زمانے میں اپنے آپ پر چار بار زنا"}
{"hadithnumber": "1544", "text": "عبداللہ بن ابی ملیکہ رحمہ اللہ سے روایت ہے کہ بلاشبہ ایک عورت رسول اللہ ﷺ کے پاس آئی اور اس نے آپ ﷺ"}
{"hadithnumber": "1545", "text": "حضرت ابوہریرہ رضی اللہ عنہ اور حضرت زید بن خالد جہنی رضی اللہ عنہ سے روایت ہے کہ بے شک دو آدمی رسول"}
{"hadithnumber": "1546", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک حضرت سعد بن عبادہ رضی اللہ عنہ نے رسول اللہ ﷺ سے عرض"}
{"hadithnumber": "1547", "text": "حضرت عبداللہ بن عباس رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ میں نے حضرت عمر بن خطاب رضی اللہ عنہ کو"}
{"hadithnumber": "1548", "text": "حضرت ابوواقد لیثی رضی اللہ عنہ سے روایت ہے کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ کے پاس ایک آدمی آی"}
{"hadithnumber": "1549", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے ، کہتے ہیں : جب حضرت عمر بن خطاب رضی اللہ عنہ ( 23ھ میں اپنے آخری"}
{"hadithnumber": "1550", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عثمان بن عفان رضی اللہ عنہ کے پاس ایک عورت کو لایا"}
{"hadithnumber": "1551", "text": "امام مالک رحمہ اللہ نے ابن شہاب سے اس شخص کے متعلق سوال کیا جو قوم لوط والا عمل کرتا ہے تو ابن شہاب"}
