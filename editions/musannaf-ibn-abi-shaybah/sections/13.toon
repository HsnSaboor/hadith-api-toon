hadiths[411]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
19916,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ بَقِیُّ بْنُ مَخْلَدٍ، قَالَ: حدَّثَنَا أَبُو بَکْرٍ عَبْدُ اللہِ بْنُ مُحَمَّدِ بْنِ أَبِی شَیْبَۃَ الْعَبْسِیُّ، قَالَ:\n\n حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ الضَّبِّیُّ ، عَنْ بَیَانَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَدِیِّ بْنِ حَاتِمٍ ، قَالَ : سَأَلْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : قُلْتُ : إنَّا قَوْمٌ نَصِیدُ بِہَذِہِ الْکِلاَبِ ، قَالَ : إذَا أَرْسَلْت کِلاَبَک الْمُعَلَّمَۃَ وَذَکَرْت اسْمَ اللہِ عَلَیْہَا فَکُلْ مِمَّا أَمْسَکْنَ عَلَیْک ، وَإِنْ قَتَلْنَ إِلاَّ أَنْ یَأْکُلْنَ ، فَإِنْ أَکَلْنَ فَلاَ تَأْکُلْ ، فَإِنِّی أَخَافُ أَنْ یَکُونَ إنَّمَا أَمْسَکَ عَلَی نَفْسِہِ ، وَإِنْ خَالَطَہَا کِلاَبٌ أُخْرَی فَلاَ تَأْکُلْ۔ (بخاری 5483۔ ابوداؤد 2842)",,,19916,,
19917,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، عَنْ مَکْحُولٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا أَرْسَلْت کَلْبَک الْمُکَلَّبَ فَأَکَلَ مِنْہُ ، وَلَمْ تُدْرِکْ ذَکَاتَہُ فَلاَ تَأْکُلْ مِنْہُ ، وَإِنْ لَمْ یَأْکُلْ مِنْہُ فَوَجَدْتہ قَدْ مَاتَ فَکُلْ۔",,,19917,,
19918,"حَدَّثَنَا أَبُو الأَحْوَص، عَنْ أَبِی إِسْحَاقَ، عَنِ الشَّعْبِیِّ، قَالَ: قَالَ ابْنُ عَبَّاسٍ: إذَا أَرْسَلْت کَلْبَک فَأَخَذَ الصَّیْدَ فَأَکَلَ مِنْہُ فَلاَ تَأْکُلْ فَإِنَّمَا أَمْسَکَ عَلَی نَفْسِہِ ، وَإِنْ ہُوَ لَمْ یَأْکُلْ مِنْہُ فَکُلْ فَإِنَّمَا أَمْسَکَ عَلَیْک ، وَإِنْ قَتَلَ۔",,,19918,,
19919,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا أَرْسَلْت کَلْبَک فَأَکَلَ فَلاَ تَأْکُلْ فَإِنَّمَا أَمْسَکَ عَلَی نَفْسِہِ۔",,,19919,,
19920,"حَدَّثَنَا حَفْصٌ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ، عَنِ ابْنِ عُمَرَ، قَالَ: إذَا أَکَلَ مِنْ صَیْدِہِ فَاضْرِبْہُ، فَإِنَّہُ لَیْسَ بِمُعَلَّمٍ۔",,,19920,,
19921,"حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: إذَا أَکَلَ الْکَلْبُ مِنَ الصَّیْدِ فَلَیْسَ بِمُعَلَّمٍ۔",,,19921,,
19922,"حَدَّثَنَا جَرِیرٌ ، عَنِ الْمُغِیرَۃِ ، عَنْ إبْرَاہِیمَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا أَکَلَ الْکَلْبُ فَلاَ تَأْکُلْ۔",,,19922,,
19923,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْمِنْہَالِ الطَّائِیِّ ، عَنْ عَمِّہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : سَأَلْتُہ عَنْ صَیْدِ الْکَلْبِ ، فَقَالَ : وَذِّمہ وَأَرْسِلْہُ وَاذْکُرِ اسْمَ اللہِ ،وَکُلْ مَا أَمْسَکَ عَلَیْک ، مَا لَمْ یَأْکُلْ۔",,,19923,,
19924,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ قَالَ : إِذَا أَکَلَ الْکَلْبُ مِنَ الصَّیْدِ فَلاَ تَأْکُلُ۔",,,19924,,
19925,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ فِی الْکَلْبِ یَأْکُلُ ، قَالَ : إنَّمَا أَمْسَکَ عَلَی نَفْسِہِ ، وَلَمْ یُمْسِکْ عَلَیْک فَلاَ تَأْکُلْ۔",,,19925,,
19926,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : ہُوَ مَیْتَۃٌ۔",,,19926,,
19927,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ عِکْرِمَۃَ قَالَ : إِذَا أَکَلَ فَلاَ تَأْکُلْ۔",,,19927,,
19928,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : إذَا أَرْسَلْت کَلْبَک الْمُعَلَّمَ وَذَکَرْت اسْمَ اللہِ فَکُلْ وَإِنْ قَتَلَ ، قَالَ سُفْیَانُ : وَأَشُکُّ فِی الْبَازِی۔",,,19928,,
19929,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ فِی الْکَلْبِ یَأْکُلُ مِنْ صَیْدِہِ ؟ قَالَ : لاَ تَأْکُلْ۔",,,19929,,
19930,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ أَکَلَ فَلاَ تَأْکُلْ۔",,,19930,,
19931,"حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَکِ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا أَکَلَ الْکَلْبُ فَلاَ تَأْکُلْ۔",,,19931,,
19932,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنِ ابْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : إذَا أَرْسَلْت کَلْبَک وَذَکَرْت اسْمَ اللہِ عَلَیْہِ فَکُلْ مَا لَمْ یَأْکُلْ۔",,,19932,,
19933,"حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ ، عَنِ الشَّعْبِیِّ ، وَأَبِی بُرْدَۃَ ، قَالاَ : صَیْدُ الْکَلْبِ ، إِنْ أَکَلَ فَلاَ تَأْکُلْ۔",,,19933,,
19934,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ؛ فِی الْکَلْبِ إذَا کَانَ مُعَلَّمًا فَأَصَابَ صَیْدًا : فَإِنْ أَکَلَ مِنْہُ فَلاَ تَأْکُلْ ، وَإِنْ قَتَلَ فَأَمْسَکَ عَلَیْک فَکُلْ۔",,,19934,,
19935,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا دَاوُد ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا أَرْسَلْت کَلْبَک فَأَکَلَ فَإِنَّمَا أَمْسَکَ عَلَی نَفْسِہِ فَلاَ تَأْکُلْ ، فَإِنَّہُ لَمْ یَتَعَلَّمْ مَا عَلَّمْتہ۔",,,19935,,
19936,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، قَالَ : حدَّثَنِی أَبَانُ بْنُ صَالِحٍ ، عَنِ الْقَعْقَاعِ بْنِ حَکِیمٍ ، عَنْ سَلْمَی أُمِّ رَافِعٍ ، عن أبی رافع قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا أَرْسَلَ الرَّجُلُ صَائِدَہُ ، وَذَکَرَ اسْمَ اللہِ ، فَلْیَأْکُلْ مَا لَمْ یَأْکُلْ۔ (رویانی 698)",,,19936,,
19937,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنْ أَبِی ثَعْلَبَۃَ الْخُشَنِیِّ ، وَعَنِ الْوَلِیدِ بْنِ أَبِی مَالِکٍ ، عَنْ عَائِذِ اللہِ أَنَّہُ سَمِعَ أَبَا ثَعْلَبَۃَ الْخُشَنِیَّ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، إنَّا أَہْلُ صَیْدٍ ، قَالَ : إذَا أَرْسَلْت کَلْبَک ، وَذَکَرْت اسْمَ اللہِ عَلَیْہِ فأمسک علیک فَکُلْ ، قَالَ : قُلْتُ : وَإِنْ قَتَلَ ؟ قَالَ : وَإِنْ قَتَلَ۔\n\n(بخاری 5478۔ مسلم 1532) (2) من رَخَّصَ فِی أَکْلِہِ وَأَکَلَہُ",,,19937,,
19938,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کُلْ ، وَإِنْ أَکَلَ۔",,,19938,,
19939,حَدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی جَعْفَرٍ وَسَعْدٍ وَسَلْمَانَ ؛ أَنَّہُمْ لَمْ یَرَوْا بَأْسًا إذَا أَکَلَ مِنْ صَیْدِہِ ، أَنْ یَأْکُلَ مِنْ صَیْدِہِ۔,,,19939,,
19940,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ وَوَکِیعٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنْ حُمَیْدِ بْنِ مَالِکٍ ، قَالَ : سَأَلْتُ سَعْدَ بْنِ أَبِی وَقَّاصٍ قُلْتُ إنَّ لَنَا کِلاَبًا ضَوَارِیَ نُرْسِلُہَا عَلَی الصَّیْدِ فَتَأْکُلُ وَتَقْطَعُ ، فَقَالَ : وَإِنْ لَمْ یَبْقَ إِلاَّ بِضْعَۃً۔",,,19940,,
19941,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : سَأَلْتُہ عَنِ الْکَلْبِ یُرْسَلُ عَلَی الصَّیْدِ ، فَقَالَ : کُلْ ، وَإِنْ أَکَلَ ثُلُثَیْہِ ، فَقُلْت : عَنْ مَنْ ؟ قَالَ : عَنْ سَلْمَانَ۔",,,19941,,
19942,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : حدَّثَنَا دَاوُد ، عَنِ الشَّعْبِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إذَا أَرْسَلْت کَلْبَک فَأَکَلَ فَکُلْ ، وَإِنْ أَکَلَ ثُلُثَیْہِ۔",,,19942,,
19943,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ سَلْمَانَ قَالَ : إِنْ أَکَلَ ثُلُثَیْہِ فَکُلِ الثُّلُثَ الْبَاقِیَ۔",,,19943,,
19944,"حَدَّثَنَا وَکِیعٌ، عَنِ ابْنِ أَبِی ذِئْبٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ: کُلْ مِنْ صَیْدِ الْکَلْبِ إِنْ أَکَلَ مِنْ طَرِیدَتِہِ۔",,,19944,,
19945,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ لَہُ : إذَا أَکَلَ الْکَلْبُ فَکُلْ ، وَإِنْ لَمْ یَبْقَ إِلاَّ بِضْعَۃً۔",,,19945,,
19946,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَدِیِّ بْنِ حَاتِمٍ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، إنَّا قَوْمٌ نَصِیدُ فَمَا یَحِلُّ لَنَا وَمَا یَحْرُمُ عَلَیْنَا ؟ قَالَ : یَحِلُّ لَکُمْ (مَا عَلَّمْتُمْ مِنَ الْجَوَارِحِ مُکَلِّبِینَ تُعَلِّمُونَہُنَّ مِمَّا عَلَّمَکُمُ اللَّہُ فَکُلُوا مِمَّا أَمْسَکْنَ عَلَیْکُمْ وَاذْکُرُوا اسْمَ اللہِ عَلَیْہِ) قَالَ : قُلْتُ : وَإِنْ قَتَلَ؟ قَالَ: وَإِنْ قَتَلَ، قَالَ : وَإِنْ خَالَطَہَا کِلاَبٌ أُخْرَی فَلاَ تَأْکُلْ حَتَّی تَعْلَمَ ، أَنَّ کَلْبَک ہُوَ الَّذِی أَخَذَہُ۔\n\n(ابوداؤد 2845۔ ترمذی 1470)",,,19946,,
19947,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ جَمِیلِ بْنِ زَیْدِ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ ، عَنْ صَیْدِ الْکِلاَبِ ، فَقَالَ : أَلَیْسَتْ مُقَلَّدَۃً ؟ قَالَ : قُلْتُ : بلی ، انْطَلَقْت أَقُودُہَا ؟ قَالَ : أَکُلُّہَا تَقُودُ ؟ قَالَ : قُلْتُ : مِنْہَا مَا أَقُودُ ، وَمِنْہَا مَا یَتْبَعُنِی ، قَالَ : إذَا رَأَیْت الصَّیْدَ ، وَخَلَعْت کَلْبَک ، وَذَکَرْت اسْمَ اللہِ علیہ فَکُلْ مَا اصَّادَ ، وَأَمَّا الْکَلْبُ التَّابِعُ ، فَإِنْ أَخَذَہُ فَلاَ تلبس بِہِ ، إِلاَّ أَنْ تَجِدہُ حَیًّا فَتَذْبَحَہُ ، وَإِمَّا أَنْ یَفْتَرِسَہُ کَلْبٌ لَمْ تُرْسِلْہُ فَذَلِکَ حَرَامٌ۔",,,19947,,
19948,"حَدَّثَنَا أَبُو بَکْرٍ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، قَالَ : سَأَلْتُ الْقَاسِمَ عَنِ الرَّجُلِ یُرْسِلُ الْکَلْبَ الْمُعَلَّمَ فَیَأْخُذُ الصَّیْدَ فَیَقْتُلُہُ فَیَجِدُ مَعَہُ کِلاَبًا غَیْرَ مُعَلَّمَۃٍ ، قَالَ : إِنْ کَانَ یَعْلَمُ ، أَنَّ کَلْبَہُ الْمُعَلَّمَ قَتَلَہ فَلْیَأْکُلْ ، وَإِنْ شَکَّ فَلاَ یَدْرِی لَعَلَّ غَیْرَ الْکَلْبِ شَرَکَہُ فَلاَ یَأْکُلُ۔",,,19948,,
19949,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا رَدَّ الْکَلْبُ الَّذِی لَیْسَ بِمُعَلَّمٍ عَلَی الْکَلْبِ الْمُعَلَّمِ صَیْدًا فَقَدْ أَفْسَدَ۔",,,19949,,
19950,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ عَطَائً عَنِ الرَّجُلِ یَنْسَی أَنْ یُسَمِّیَ عَلَی کَلْبِہِ فَیَقْتُلُ ، قَالَ : یَأْکُلُ۔",,,19950,,
19951,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ عن ابْنِ حَرْمَلَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الرَّجُلِ یُرْسِلُ کَلْبَہُ وَیَنْسَی أَنْ یُسَمِّیَ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,19951,,
19952,"حَدَّثَنَا أَسْبَاطٌ ، عَنْ مُغِیرَۃَ بْنِ مُسْلِمٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : سُئِلَ عَنْ رَجُلٍ أَرْسَلَ کَلْبَہُ ، وَلَمْ یُسَمِّ ، قَالَ : الْمُسْلِمُ فِیہِ اسْمُ اللہِ عَزَّ وَجَلَّ۔",,,19952,,
19953,"حَدَّثَنَا عَبْدُ الأَعْلَی ، قَالَ : حدَّثَنَا مَعْمَرٌ ، عَنِ الزُّہْرِیِّ ، قَالَ : إذَا أَرْسَلَ کَلْبَہُ فَنَسِیَ أَنْ یُسَمِّیَ فَلْیَأْکُلْ۔",,,19953,,
19954,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ فِی الرَّجُلِ یُرْسِلُ کَلْبَہُ وَصَقْرَہُ فَیَنْسَی أَنْ یُسَمِّیَ فَیَقْتُلَہُ، قَالَ : یَأْکُلُ۔",,,19954,,
19955,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا رَمَیْت بِالسَّہْمِ ، وَلَمْ تُسَمِّ فَذَکَرْت قَبْلَ أَنْ تَقْتُلَ الصَّیْدَ ، ثُمَّ سَمَّیْتَ ، ثُمَّ قَتَلَہُ فَکُلْ ، وَالْکَلْبُ مِثْلُ ذَلِکَ۔",,,19955,,
19956,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا انْفَلَتَ الْکَلْبُ وَصَاحِبُہُ لاَ یَشْعُرُ ، فَقَالَ بَعْدَ مَا یَطْلُبُ الْکَلْبُ الصَّیْدَ : بِسْمِ اللہِ ، فَأَصَادَ الْکَلْبُ فَلْیَأْکُلْ۔",,,19956,,
19957,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ، عَنْ زُہَیْرٍ، عَنْ جَابِرٍ، عَنْ عَامِرٍ، قَالَ: إذَا أَرْسَلْت کَلْبَک ، أَوْ سَہْمَکَ، فَنَسِیتَ أَنْ تُسَمِّیَ ، أَیْ حِینَ تُرْسِلُہُ ، ثُمَّ سَمَّیْتَ قَبْلَ أَنْ تَأْخُذَہُ ، فَلاَ تَأْکُلْ حَتَّی تُسَمِّیَ حِینَ تُرْسِلُہُ۔",,,19957,,
19958,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّہُ قَالَ ؛ فِی رَجُلٍ رَمَی وَنَسِیَ أَنْ یَذْکُرَ اسْمَ اللہِ ، قَالَ : کَانَ لاَ یَرَی بِہِ بَأْسًا۔",,,19958,,
19959,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ ابن حَرْمَلَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قُلْتُ : رَمَیْت بِحَجَرِی وَنَسِیت أَنْ أُسَمِّیَ ، قَالَ : فَاذْکُرِ اسْمَ اللہِ وَکُلْ۔",,,19959,,
19960,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ أَرْسَلَ کَلْبَہُ عَلَی صَیْدٍ فَیَأْخُذُ غَیْرَہُ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,19960,,
19961,"حَدَّثَنَا حَفْصٌ، عَنْ حَجَّاجٍ، عَنْ عَطَائٍ، قَالَ: سَأَلْتُہ عَنِ الرَّجُلِ یَرْمِی الصَّیْدَ فَیُصِیبُ غَیْرَہُ، قَالَ: یَأْکُلُ۔",,,19961,,
19962,"حَدَّثَنَا ہُشَیْمٌ، عَنْ یُونُسَ، عَنِ الْحَسَنِ؛ فِی رَجُلٍ رَمَی صَیْدًا وَسَمَّی عَلَیْہِ فَأَصَابَ غَیْرَہُ، قَالَ: لاَ بَأْسَ۔",,,19962,,
19963,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ مِثْلَہُ۔,,,19963,,
19964,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ فِی رَجُلٍ یَرْمِی الصَّیْدَ ، وَلاَ یُتَعَمَّد فَیُصِیبُ أَحَدَہُمَا قَالَ : یَأْکُلُ إذَا ذَکَرَ اسْمَ اللہِ۔",,,19964,,
19965,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ، عَنْ مَعْمَرٍ، قَالَ: حدَّثَنِی قَتَادَۃُ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ فِی کَلْبِ الْمُشْرِکِ، قَالَ: إنَّمَا ہُوَ کَشَفْرَتِہِ ، قَالَ : قَالَ الزُّہْرِیُّ : إذَا کُنْتَ أَنْتَ تَصِیدُ بِہِ فَلاَ بَأْسَ۔",,,19965,,
19966,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ، أَنَّہُ کَرِہَ صَیْدَ کَلْبِ الْمَجُوسِیِّ وَالْیَہُودِیِّ وَالنَّصْرَانِیِّ۔,,,19966,,
19967,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ یَصِیدُ بِکَلْبِ الْمَجُوسِیِّ ، وَلاَ یَأْکُلُ مِنْ صَیْدِہِ۔",,,19967,,
19968,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یُکْرَہُ أَنْ یَسْتَعِینَ الْمُسْلِمُ بِکَلْبِ الْمَجُوسِیِّ فَیَصِیدُ بِہِ ، وَلاَ یَرَی بَأْسًا أَنْ یَسْتَعِینَ بِکَلْبِ الْیَہُودِیِّ وَالنَّصْرَانِیِّ فَیَصِیدَ بِہِ۔,,,19968,,
19969,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ ابْنِ أَبِی لَیْلَی، عَنْ رَجُلٍ، عَنْ إبْرَاہِیمَ، أَنَّہُ کَرِہَ صَیْدَ کَلْبِ الْمَجُوسِیِّ۔,,,19969,,
19970,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، قَالَ : کَلْبُہُ کَسِکِّینِہِ۔",,,19970,,
19971,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لاَ بَأْسَ بِصَیْدِ الْیَہُودِیِّ وَالنَّصْرَانِیِّ وَذَبَائِحِہِمْ ، وَلاَ خَیْرَ فِی صَیْدِ الْمَجُوسِ وَذَبَائِحِہِمْ۔",,,19971,,
19972,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لاَ خَیْرَ فِی صَیْدِ الْمَجُوسِیِّ ولا بَازِہِ ، وَلاَ فِی کَلْبِہِ۔",,,19972,,
19973,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ أَنَّہُمَا کَرِہَا صَیْدَ کَلْبِ الْمَجُوسِیِّ۔,,,19973,,
19974,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، أَنَّہُ کان یَکْرَہ أَنْ یَسْتَعِیرَ الرَّجُلُ کَلْبَ الْمَجُوسِیِّ ، أَوِ النَّصْرَانِیِّ ، أَوِ الْیَہُودِیِّ فَیَصِیدَ بِہِ وَیَقُولُ : مَا عَلَّمْتُمْ أَنْتُمْ۔",,,19974,,
19975,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، أَنَّہُ کَرِہَ صَیْدَ کَلْبِ الْمَجُوسِیِّ۔,,,19975,,
19976,حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، أَنَّہُ کَرِہَ صَیْدَ الْمَجُوسِیِّ۔,,,19976,,
19977,"سَمِعْت وَکِیعًا یَقُولُ : سَمِعْت سُفْیَانَ یَکْرَہُ صَیْدَ کَلْبِ الْمَجُوسِیِّ حَتَّی یَأْخُذَ مِنْ تَعْلِیمِ الْمُسْلِمِ۔",,,19977,,
19978,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لَہُ : الْمَجُوسِیُّ یُرْسِلُ إلی بَازِہ ؟ قَالَ: نَعَمْ۔",,,19978,,
19979,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی طَیْرِ الْمَجُوسِیِّ ، قَالَ : لاَ یُؤْکَلُ۔",,,19979,,
19980,حَدَّثَنَا عَلِیُّ بْنُ ہِشَامٍ وَوَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ عِیسَی بْنِ عَاصِمٍ ، عَنْ عَلِیٍّ ، أَنَّہُ کَرِہَ صَیْدَ صَقْرِہِ وَبَازِہِ۔,,,19980,,
19981,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ حَجَّاجٍ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ: لاَ خَیْرَ فِی صَقْرِہِ ، وَلاَ فِی بَازِہِ۔",,,19981,,
19982,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، أَنَّہُ کَرِہَ صَیْدَ صَقْرِہِ وَبَازِہِ۔,,,19982,,
19983,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَخَذْت الصَّیْدَ وَبِہِ رَمَقٌ فَمَاتَ فِی یَدِکَ فَلاَ تَأْکُلْہُ۔",,,19983,,
19984,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ أَنَّہُ رَمَی دُبسیًا بِحَجَرٍ فَأَخَذَ عَبْدُ اللہِ یُعَالِجُہُ بِقَدُومٍ مَعَہُ لِیَذْبَحَہُ فَمَاتَ فِی یَدِہِ قَبْلَ أَنْ یَذْبَحَہُ فَأَلْقَاہُ۔,,,19984,,
19985,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا کُنْتَ فِی تَخْلِیصِ الصَّیْدِ فَسَبَقَک بِنَفْسِہِ فَلاَ بَأْسَ أَنْ تَأْکُلَہُ ، وَإِنْ تَرَبَّصْت بِہِ فَمَاتَ فَلاَ تَأْکُلْہُ۔",,,19985,,
19986,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ عَنِ الرَّجُلِ یُدْرِکُ الصَّیْدَ وَبِہِ رَمَقٌ فَیَدَعُ الْکَلْبَ حَتَّی یَقْتُلَہُ ، قَالَ : لاَ یَأْکُلُ۔",,,19986,,
19987,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ أَبِی حَرَّۃَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ أَرْسَلَ کَلْبَہُ عَلَی صَیْدٍ ، فَأَدْرَکَ الصَّیْدَ وَبِہِ رَمَقٌ ، فَمَاتَ فِی یَدَیْہِ ، فَقَالَ : إذَا کَانَ الْکَلْبُ مُکَلَّبًا فَلْیَأْکُلْ۔",,,19987,,
19988,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، قَالَ : کَانَ أَحَدُہُمْ یُرْسِلُ کَلْبَہُ وَیُسَمِّی ، وَلاَ یَرَی صَیْدًا فَإِذَا صَادَ أَکَلَہُ۔",,,19988,,
19989,"حَدَّثَنَا حَفْصٌ، عَنْ حَجَّاجٍ، قَالَ: سَأَلْتُ عَطَائً عَنِ الْکِلاَبِ تَنْفَلِتُ مِنْ مَرَابِطِہَا فَتَقْتُلُ، قَالَ: لاَ بَأْسَ بِہِ۔",,,19989,,
19990,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ مَعْرُوف ، قَالَ : خَرَجْنَا بِکِلاَبٍ فَلَقِینَا ابْنَ عُمَرَ ، فَقَالَ : إذَا أَرْسَلْتُمُوہُ فَسَمُّوا اللَّہَ عَلَیْہَا وَقُولُوا : اللَّہُمَّ اہْدِ صُدُورَہَا۔",,,19990,,
19991,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زُہَیْرِ بْنِ مُحَمَّدٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، أَنَّ أَبَاہُ کَانَ إذَا أَرْسَلَ کِلاَبَہُ ، قَالَ : اللَّہُمَّ اہْدِ صُدُورَہَا۔",,,19991,,
19992,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَدِیِّ بْنِ حَاتِمٍ ، قَالَ : إِنْ شَرِبَ مِنْ دَمِہِ فَلاَ تَأْکُلْ ، فَإِنَّہُ لَمْ یَعْلَمْ مَا عَلَّمْتہ۔",,,19992,,
19993,"حَدَّثَنَا حَفْصُ بْنُ غِیاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : إِنْ أَکَلَ فَلاَ تَأْکُلْ ، وَإِنْ شَرِبَ فَکُلْ۔",,,19993,,
19994,"حَدَّثَنَا حَفْصُ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ قَالَ : إِنْ أَکَلَ فَلاَ تَأْکُلُ ، وَإِنْ شَرِبَ فَلاَ تَأْکُلْ۔",,,19994,,
19995,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : إِنْ أَکَلَ فَکُلْ وَإِنْ شَرِبَ فَکُلْ۔",,,19995,,
19996,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ فِی الطَّیْرِ والْبُزَاۃِ وَالصُّقُورِ وَغَیْرِہَا ، وَمَا أَدْرَکْت ذَکَاتَہُ فَہُوَ لَکَ ، وَمَا لَمْ تُدْرَکْ ذَکَاتُہُ فَلاَ تَأْکُلْہُ۔,,,19996,,
19997,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : الْکَلْبُ وَالْبَازِی شَیْئٌ وَاحِدٌ ، کُلٌّ صُیُودٌ۔",,,19997,,
19998,"حَدَّثَنَا ابْنُ عُلَیَّۃَ وَوَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْہَیْثَمِ ، عَنْ طَلْحَۃَ بْنِ مُصَرِّف ، قَالَ : قَالَ خَیْثَمَۃُ بْنُ عَبْدِ الرَّحْمَنِ : ہَذَا مَا قَدْ أَثْبَتُّ لَکَ ، إِنَّ الصُّقُورَ وَالْبَازِیَ مِنَ الْجَوَارِحِ۔",,,19998,,
19999,حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ وُہَیْبٍ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ أَنَّہُ لَمْ یَرَ بَأْسًا بِصَیْدِ الْبَازِی وَالصَّقْرِ۔,,,19999,,
20000,"حَدَّثَنَا مُعَاذٌ قَالَ : أَخْبَرَنَا أَشْعَثُ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَقُولُ فِی الصَّقْرِ وَالْبَازِی ہما بِمَنْزِلَۃِ الْکَلْبِ۔",,,20000,,
20001,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْقَاسِمِ ، عَنْ مُجَاہِدٍ : {وَمَا عَلَّمْتُمْ مِنَ الْجَوَارِحِ مُکَلِّبِینَ} قَالَ : مِنَ الطَّیْرِ وَالْکِلاَبِ۔",,,20001,,
20002,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَدِیِّ بْنِ حَاتِمٍ ، قَالَ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ صَیْدِ الْبَازِی ، فَقَالَ : مَا أَمْسَکَ عَلَیْک فَکُلْ۔ (ابوداؤد 2845۔ احمد 4/257)",,,20002,,
20003,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَالِمٍ ، عَنْ سَعِیدٍ قَالَ : إِذَا أَکَلَ فَلاَ تَأْکُلْ۔",,,20003,,
20004,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، وَعَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، قَالاَ : کُلْ مِنْ صَیْدِ الْبَازِی ، وَإِنْ أَکَلَ۔",,,20004,,
20005,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ فِی الصَّقْرِ وَالْکَلْبِ : إِنْ أَصَابَ مِنْہُ ، أَوْ أَکَلَ مِنْہُ فَکُلْ، وَإِنْ أَکَلَ۔",,,20005,,
20006,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ فِی الْکَلْبِ إذَا کَانَ مُعَلَّمًا فَأَصَابَ صَیْدًا ، أَوِ الْبَازِی فَأَکَلَ فَلاَ تَأْکُلْ۔,,,20006,,
20007,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنِ الشَّیْبَانِیِّ ، عَنْ حَمَّادٍ ، قَالَ : إذَا نَتَفَ الطَّیْرَ ، أَوْ أَکَلَ فَکُلْ ، فَإِنَّمَا تَعْلِیمُہُ أَنْ یَرْجِعَ إلَیْک۔",,,20007,,
20008,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ وَالْحَکَمِ ، قَالاَ : إذَا أَرْسَلْت صَقْرَک ، أَوْ بَازیک ، ثُمَّ دَعَوْتہ فَأَتَاک فَذَاکَ عِلْمُہُ ، فَإِذا أَرْسَلْت عَلَی صَیْدٍ فَأَکَلَ فَکُلْ۔",,,20008,,
20009,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ دَاوُدَ بْنِ أَبِی الْفُرَاتِ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ سَلْمَانَ ، قَالَ : إذَا أَرْسَلْت کَلْبَک أو بَازیک فَکُلْ ، وَإِنْ أَکَلَ ثُلُثَہُ۔",,,20009,,
20010,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ الْوَلِیدِ الشَّنی ، عَنْ عِکْرِمَۃَ ، قَالَ : إذَا أَکَلَ الْبَازُ ، أَوِ الصَّقْرُ فَلاَ تَأْکُلْ۔",,,20010,,
20011,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ، وَعَطَائٍ فِی الْبَازِی وَالصَّقْرِ : یَأْکُلُ ، قَالَ عَطَائٌ : إذَا أَکَلَ فَلاَ تَأْکُلْ ، وَقَالَ : الْحَسَنُ : کُلْ۔",,,20011,,
20012,حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَکِ ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، أَنَّہُ لَمْ یَرَ بِصَیْدِ الْفَہْدِ بَأْسًا۔,,,20012,,
20013,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ أَبِی نَجِیح ، عَنْ مُجَاہِدٍ ، قَالَ : الْفَہْد مِنَ الْجَوَارِح۔",,,20013,,
20014,"حدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنْ حَمَّادٍ ، قَالَ : لاَ بَأْسَ بِصَیْدِ الْفَہْدِ۔",,,20014,,
20015,"حَدَّثَنَا رَوَّاد بْنُ الْجَرَّاح ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ بَأْسَ بِصَیْدِ الْفَہْدِ۔",,,20015,,
20016,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : أَخْبَرَنَا أَشْعَثُ ، عَنِ الْحَسَنِ ، قَالَ : الْفَہْدُ وَالشَّاہِینُ بِمَنْزِلَۃِ الْکَلْبِ۔",,,20016,,
20017,حَدَّثَنَا الْمُحَارِبِیُّ ، عَنِ الشَّیْبَانِیِّ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ یَکْرَہُ صَیْدَ الْکَلْبِ وَالْفَہْدِ إذَا أَکَلَ مِنْہُ وَکَانَ لاَ یَرَی بَأْسًا بِصَیْدِ الْبَازِی إذَا أَکَلَ لأَنَّ الْکَلْبَ وَالْفَہْدَ یُضَرَّیَانِ وَالْبَازِ لاَ یُضَرَّی۔,,,20017,,
20018,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لاَ بَأْسَ بِصَیْدِ الْمَجُوسِیِّ السَّمَکِ۔",,,20018,,
20019,"حَدَّثَنَا أَبُو الأَحْوَص، عَنْ سِمَاکٍ، عَنْ عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: کُلِ السَّمَکَ، لاَ یَضُرُّک مَنْ صَادَہُ۔",,,20019,,
20020,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ یُؤْکَلُ مِنْ صَیْدِ الْمَجُوسِیِّ إِلاَّ الْحِیتَانَ۔",,,20020,,
20021,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ مُغِیرَۃَ بْنِ زِیَادٍ ، عَنْ مَکْحُولٍ ، قَالَ : کُلْ صَیْدَ الْبَحْرِ مَا صَادَہ الْیَہُودِیُّ وَالنَّصْرَانِیُّ وَالْمَجُوسِیُّ۔",,,20021,,
20022,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِصَیْدِ الْمَجُوسِیِّ السَّمَکَ۔",,,20022,,
20023,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ ہَارُونَ بْنِ سَعْدٍ ، عَنْ عِکْرِمَۃَ قَالَ : کُلْ مِنْ صَیْدِ الْمَجُوسِیِّ وَالنَّصْرَانِیِّ وَالْیَہُودِیِّ لِلسَّمَکِ۔",,,20023,,
20024,حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ أَنَّہُمَا لَمْ یَرَیَا بَأْسًا بِصَیْدِ الْمَجُوسِیِّ لِلسَّمَکِ۔,,,20024,,
20025,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنِ الْحَسَنِ بْنِ صَالِحٍ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ، قَالَ : سَأَلْتُہ عَنِ الْمَجُوسِیِّ یَصِیدُ السَّمَکَ ، قَالَ : صَیْدُہُ ذَکِیٌّ۔",,,20025,,
20026,حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنْ مُغِیرَۃَ، عَنْ حَمَّادٍ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِصَیْدِ الْمَجُوسِیِّ یَعْنِی لِلسَّمَکِ۔,,,20026,,
20027,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ، عَنْ حَجَّاجٍ، عَنْ عَطَائٍ، قَالَ: لاَ تَأْکُلُ مِنْ صَیْدِ الْمَجُوسِیِّ إِلاَّ السَّمَکَ وَالْجَرَادَ۔",,,20027,,
20028,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ وَالنَّخَعِیِّ أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا بِصَیْدِ الْمَجُوسِیِّ لِلسَّمَکِ۔,,,20028,,
20029,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُؤْکَلُ صَیْدُہُمْ فِی الْبَحْرِ ، وَلاَ یُؤْکَلُ صَیْدُہُمْ فِی الْبَرِّ۔",,,20029,,
20030,حَدَّثَنَا وَکِیعٌ ، وَعَلِیُّ بْنُ ہَاشِمٍ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ عِیسَی بْنِ عَاصِمٍ ، عَنْ عَلِیٍّ ، أَنَّہُ کَرِہَ صَیْدَ الْمَجُوسِیِّ لِلسَّمَکِ۔,,,20030,,
20031,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ عَطَائٍ ، قَالَ : سَأَلْتُہ عَنْ صَیْدِ الْمَجُوسِیِّ فَکَرِہَہُ۔",,,20031,,
20032,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنَ جُبَیْرٍ ، قَالَ : لاَ تَأْکُلْ مِنْ صَیْدِ الْمَجُوسِیِّ سَمَّی ، أَوْ لَمْ یُسَمِّ۔",,,20032,,
20033,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُوسَی بْنِ أَبِی عَائِشَۃَ ، عَنْ أَبِی رَزِینٍ ، قَالَ : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِأَرْنَبٍ ، فَقَالَ : إنِّی رَمَیْت أَرْنَبًا فَأَعْجَزَنِی طَلَبُہَا حَتَّی أَدْرَکَنِی اللَّیْلُ فَلَمْ أَقْدِرْ عَلَیْہَا حَتَّی أَصْبَحْت فَوَجَدْتہَا وَفِیہَا سَہْمِی ، فَقَالَ : أَصْمَیْتَ ، أَوْ أَنْمَیْت ؟ قَالَ : لاَ بَلْ أَنْمَیْت ، قَالَ : إنَّ اللَّیْلَ خَلْقٌ مِنْ خَلْقِ اللہِ عَظِیمٌ ، لاَ یَقْدُرُ قدرہ إِلاَّ الَّذِی خَلَقَہُ لَعَلَّہُ أَعَانَ عَلَی قَتْلِہَا شَیْئٌ انْبِذْہَا۔ (ابوداؤد 383)",,,20033,,
20034,حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَیَحْیَی بْنُ آدَمَ ، عَنْ سُفْیَانَ ، عَنْ مُوسَی بْنِ أَبِی عَائِشَۃَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی رَزِینٍ، عَنْ أَبِیہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِنَحْوٍ مِنْہُ۔ (بیہقی 241),,,20034,,
20035,"حَدَّثَنَا أبو مُعَاوِیَۃ ، عَنِ الأَعْمَشِ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، قَالَ : جَائَ رَجُلٌ إلَی أَبِی الدَّرْدَائِ ، فَقَالَ : إنِّی أَرْمِی الصَّیْدَ فَیَغِیبُ عَنِّی ، ثُمَّ أَجِدُ سَہْمِی فِیہِ مِنَ الْغَدِ أَعْرِفُہُ ، قَالَ : أَمَّا أَنَا فَکُنْت آکُلُہُ۔",,,20035,,
20036,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَجْلَحِ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی الْہُذَیْلِ ، قَالَ : سَأَلْتُ ابْنَ عَبَّاسٍ وَسَأَلَہُ عَبْدٌ أَسْوَدُ ، فَقَالَ لَہُ : یَا أَبَا عَبَّاسٍ ، إنِّی أَرْمِی الصَّیْدَ فَأُصْمِی وَأُنْمِی ، فَقَالَ : مَا أَصْمَیْتَ فَکُلْ وَمَا أَنْمَیْت فَلاَ تَأْکُلْ۔",,,20036,,
20037,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ بِنَحْوٍ مِنْ حَدِیثِ حَفْصٍ۔,,,20037,,
20038,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إذَا رَمَی ، ثُمَّ وَجَدَ سَہْمَہُ مِنَ الْغَدِ فَلْیَأْکُلْ۔",,,20038,,
20039,"حَدَّثَنَا ابن فُضَیْل ، عَنْ حُصَیْنٍ ، عَنْ عَامِرٍ ؛ فِی الرَّجُلِ یَرْمِی الصَّیْدَ فَیَغِیبُ عَنْہُ ، قَالَ : فَإِنْ وَجَدْتہ لَمْ یَقَعْ فِی مَائٍ ، وَلَمْ یَقَعْ مِنْ جَبَلٍ ، وَلَمْ یَأْکُلْ مِنْہُ سَبُعٌ فَکُلْ۔",,,20039,,
20040,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَمْرٍو ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : إذَا وَجَدْت سَہْمَک فِیہِ مِنَ الْغَدِ فَعَرَفْتہ فَلاَ بَأْسَ۔",,,20040,,
20041,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، أَنَّہُ کَانَ یَقُولُ : إذَا غَابَ عَنْک لَیْلَۃً ، وَإِنْ وَجَدْت سَہْمَک فِیہِ مِنَ الْغَدِ فَعَرَفْتہ ، فَلاَ تَأْکُلْ۔",,,20041,,
20042,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا رَمَیْت الصَّیْدَ فَغَابَ عَنْک لَیْلَۃً فَمَاتَ فَوَجَدْت سَہْمَک فِیہِ فَلاَ تَأْکُلْہُ۔",,,20042,,
20043,"حَدَّثَنَا عَبِیْدَۃُ بْنُ حُمَیْدٍ ، عَنْ حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : سَأَلَہُ رَجُلٌ ، فَقَالَ : إنِّی أَرْمِی الصَّیْدَ فَیَغِیبُ عَنِّی ، ثُمَّ أَجِدُہُ بَعْدَ ذَلِکَ ، فَقَالَ لَہُ : سَعِیدٌ : إِنْ وَجَدْتہ وَلَیْسَ فِیہِ إِلاَّ سَہْمُک فَکُلْ ، وَإِنْ لاَ فَلاَ تَأْکُلْ۔",,,20043,,
20044,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، أَنَّ عَدِیَّ بْنَ حَاتِمٍ ، قَالَ : یَا رَسُولَ اللہِ ، أَحَدُنَا یَرْمِی الصَّیْدَ فَیَقْتَفِی أَثَرَہُ الْیَوْمَیْنِ وَالثَّلاَثَۃَ ، ثُمَّ یَجِدُہُ مَیِّتًا وفِیہِ سَہْمُہُ أَیَأْکُلُ ؟ قَالَ : نَعَمْ ، إِنْ شَائَ ، أَوَ قَالَ : یَأْکُلُ إِنْ شَائَ۔ (بخاری 5484۔ مسلم 1531)",,,20044,,
20045,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنْ عَدِیِّ بْنِ حَاتِمٍ ، قَالَ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الصَّیْدِ أَرْمِیہ فَأَطْلُبُ الأَثَرَ بَعْدَ لَیْلِۃٍ؟ قَالَ : إذَا وَجَدْت سَہْمَک فِیہِ، وَلَمْ یَأْکُلْ مِنْہُ سَبُعٌ فَکُلْ۔ (ترمذی 1468۔ احمد 4/377)",,,20045,,
20046,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنْ مَسْرُوقٍ ، قَالَ : قَالَ عَبْدُ اللہِ : إذَا رَمَیْت طَیْرًا فَوَقَعَ فِی المَائِ فَلاَ تَأْکُلْ ، فَإِنِّی أَخَافُ ، أَنَّ الْمَائَ قَتَلَہُ ، وَإِنْ رَمَیْت صَیْدًا وَہُوَ عَلَی جَبَلٍ فَتَرَدَّی فَلاَ تَأْکُلْہُ فَإِنِّی أَخَافُ ، أَنَّ التَّرَدِّی الذی أَہْلَکَہُ۔",,,20046,,
20047,"حَدَّثَنَا عبدۃ بن سلیمان ، عن عاصم ، عن الحسن : مثلہ۔",,,20047,,
20048,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ عَامِرٍ ؛ فِی الرَّجُلِ یَرْمِی الصَّیْدَ فَیَغِیبُ عَنْہُ ، قَالَ : إِنْ وَجَدْتہ لَمْ یَقَعْ فِی المَائِ ، وَلَمْ یَقَعْ مِنْ جَبَلٍ ، وَلَمْ یَأْکُلْ مِنْہُ سَبُعٌ فَکُلْ۔",,,20048,,
20049,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عِیسَی بْنِ أَبِی عَزَّۃَ ، عَنِ الشَّعْبِیِّ فِی دَجَاجَۃٍ ذُبِحَتْ فَوَقَعَتْ فِی مَائٍ فَکَرِہَ أَکْلَہَا۔,,,20049,,
20050,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا رَمَیْتہ فَوَقَعَ فِی مَائٍ فَلاَ تَأْکُلْہُ ، وَإِذَا رَمَیْتہ فَتَرَدَّی مِنْ جَبَلٍ فَلاَ تَأْکُلْہُ۔",,,20050,,
20051,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : إذَا وَقَعَ فِی مَائٍ فَلاَ تَأْکُلْہُ۔",,,20051,,
20052,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : إذَا رَمَیْت الصَّیْدَ فَوَقَعَ فِی مَائٍ فَلاَ تَأْکُلْ ، وَإِنْ تَرَدَّی مِنْ جَبَلٍ فَلاَ تَأْکُلْ۔",,,20052,,
20053,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : إِنْ وَجَدْتہ لَمْ یَتَرَدَّ مِنْ جَبَلٍ ، وَلَمْ یُجَاوِزْ مَائً فَلْتَأْکُلْہُ۔",,,20053,,
20054,"حَدَّثَنَا أَبُو بَکْرٍ الْحَنَفِیُّ ، عَنْ أُسَامَۃَ ، عَنِ الْقَاسِمِ ؛ فِی رَجُلٍ رَمَی صَیْدًا عَلَی شَاہِقٍ فَتَرَدَّی حَتَّی وَقَعَ عَلَی الأَرْضِ وَہُوَ مَیِّتٌ ، قَالَ : إِنْ کَانَ یَعْلَمُ أَنَّہُ مَاتَ مِنْ رَمْیَتِہِ أَکَلَ ، وَإِنْ کان شَکَّ أَنَّہُ مَاتَ مِنَ التَّرَدِّی لَمْ یَأْکُلْ۔",,,20054,,
20055,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَعْمَشِ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، قَالَ : سُئِلَ ابْنُ مَسْعُودٍ ، عَنْ رَجُلٍ ضَرَبَ رِجْلَ حِمَارٍ وَحْشٍ فَقَطَعَہَا ، فَقَالَ : دَعُوا مَا سَقَطَ وَذَکُّوا مَا بَقِیَ فَکُلُوہُ۔",,,20055,,
20056,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا ضَرَبَ الصَّیْدَ فَبَانَ عُضْوٌ لَمْ یَأْکُلْ مَا أَبَانَ وَأَکَلَ مَا بَقِیَ۔",,,20056,,
20057,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : إذَا ضَرَبَ الرَّجُلُ الصَّیْدَ فَبَانَ عُضْوٌ مِنْہُ تَرَکَ مَا سَقَطَ وَأَکَلَ مَا بَقِیَ۔",,,20057,,
20058,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : یَدَعُ مَا أَبَانَ وَیَأْکُلُ مَا بَقِیَ ، فَإِنْ جَزَلَہُ جَزْلاً فَلْیَأْکُلْہ۔",,,20058,,
20059,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ، عَنْ حَجَّاجٍ، عَنِ ابْنِ أَبِی نَجِیحٍ، عَنْ مُجَاہِدٍ، وَعَنْ حَجَّاجٍ ، عَنْ عَطَائٍ مِثْلَہُ۔,,,20059,,
20060,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا أَبَانَ مِنْہُ عُضْوًا تَرَکَ مَا أَبَانَ وَذَکَّی مَا بَقِیَ ، وَإِنْ جَزَلَہُ بِاثْنَیْنِ أَکَلَہُ۔",,,20060,,
20061,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ ضَرَبَ صَیْدًا فَأَبَانَ مِنْہُ یَدًا ، أَوْ رِجْلاً وَہُوَ حَیٌّ ، ثُمَّ مَاتَ، قَالَ: یَأْکُلُہُ، وَلاَ یَأْکُلُ مَا بَانَ مِنْہُ إِلاَّ أَنْ یَضْرِبَہُ فَیَقْطَعَہُ فَیَمُوتَ مِنْ سَاعَتہ فَإِذَا کَانَ ذَلِکَ فَلْیَأْکُلْہُ کُلَّہُ۔",,,20061,,
20062,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَضْرِبُ الصَّیْدَ بِالشَّیْئِ فَیَبِینُ مِنْہُ الشَّیئُ وَیَتَحَامَلُ مَا کَانَ فِیہِ الرَّأْسُ ، قَالَ : لاَ یَأْکُلُ مَا بَانَ مِنْہُ ، وَإِنْ وَقَعَا جَمِیعًا أَکَلَہُ۔",,,20062,,
20063,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ، وَعَطَائٍ ، قَالاَ : إذَا ضَرَبَ الصَّیْدَ فَسَقَطَ عَنْہُ عُضْوٌ فَلاَ یَأْکُلہ یعْنِی الْعُضْوَ۔",,,20063,,
20064,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ ، عَنْ حُصَیْنٍ بن عبد الرحمن ، عن مَسْرُوق سُئِلَ عَنْ صَیْدِ الْمَنَاجِلِ ، قَالَ : إِنَّہَا تَقْطَعُ مِنَ الظِّبَائِ وَالْحُمُرِ فَیَبِینُ مِنْہُ الشَّیئُ وَہُوَ حَیٌّ ، فَقَالَ ابْنُ عُمَرَ : مَا أَبَانَ مِنْہُ وَہُوَ حَیٌّ فَدَعْہُ وَکُلْ مَا سِوَی ذَلِکَ۔",,,20064,,
20065,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، أَنَّہُ قَالَ فِی الْمَنَاجِلِ الَّتِی تُوضَعُ فَتَمُرُّ بِہَا فَتَقْطَعُ مِنْہَا ، قَالَ : لاَ تَأْکُلْ۔",,,20065,,
20066,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا وَقَعَ الصَّیْدُ فِی الْحِبَالَۃِ ، فَکَانَ فِیہَا حَدِیدَۃٌ فَأَصَابَ الصَّیْدُ الْحَدِیدَۃَ فَکُلْ ، وَإِنْ لَمْ تُصِبہ الْحَدِیدَۃَ ، فَإِنْ لَمْ تُدْرِکْ ذَکَاتَہُ فَلاَ تَأْکُلْ۔",,,20066,,
20067,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، أَنَّہُ کَرِہَ صَیْدَ الْمَنَاجِلِ ، وَقَالَ سَالِمٌ : لاَ بَأْسَ بِہِ۔",,,20067,,
20068,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، عَنْ عَدِیِّ بْنِ حَاتِمٍ ، قَالَ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ صَیْدِ الْمِعْرَاضِ ، فَقَالَ : مَا أَصَبْت بِحَدِّہِ فَکُلْ وَمَا أَصَبْت بِعَرْضِہِ فَہُوَ وَقِیذٌ۔\n\n(بخاری 5475۔ مسلم 1529)",,,20068,,
20069,"حَدَّثَنَا أَبُو بَکْرٍ ، قَالَ أَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا مُجَالِدٌ ، عَنِ الشَّعْبِیِّ ، عَنْ عَدِیِّ بْنِ حَاتِمٍ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، إنَّا قَوْمٌ نَرْمِی بِالْمِعْرَاضِ فَمَا یَحِلُّ لَنَا ؟ قَالَ : لاَ تَأْکُلْ مَا أَصَبْت بِالْمِعْرَاضِ إِلاَّ مَا ذَکَّیْت۔ (احمد 257۔ طبرانی 162)",,,20069,,
20070,حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ حُذَیْفَۃَ ، أَنَّہُ کَانَ یَأْکُلُ مَا قَتَلَ الْمِعْرَاض۔,,,20070,,
20071,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، وَعَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قَالَ سَلْمَان : مَا خَزَقَ الْمِعْرَاضُ فَکُلْ۔",,,20071,,
20072,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ تَأْکُلْ مَا أَصَابَ الْمِعْرَاضُ إِلاَّ أَنْ یَخْزِقَ۔",,,20072,,
20073,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ مِثْلَہُ۔,,,20073,,
20074,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، قَالَ : حدَّثَنَا مَکْحُولٌ ، أَنَّ رَجُلاً أَتَی فَضَالَۃَ بْنَ عُبَیْدٍ صَاحِبَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِعَصَافِیرَ صَادَہُنَّ بِمِعْرَاضٍ فَمِنْہَا مَا جَعَلَہُ فِی مِخْلاَتِہِ وَمِنْہَا مَا جَعَلَہُ فِی خَیْطٍ ، فَقَالَ : ہَذَا مَا صِدْتُ بِمِعْرَاضٍ ، مِنْہَا مَا أَدْرَکْت ذَکَاتَہُ ، وَمِنْہَا مَا لَمْ أُدْرِکْ ذَکَاتَہُ ، فَقَالَ : مَا أَدْرَکْت ذَکَاتَہُ فَکُلْ ، وَمَا لَمْ تُدْرِکْ ذَکَاتَہُ فَلاَ تَأْکُلْہُ۔",,,20074,,
20075,حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللہِ ، عَنْ مَکْحُولٍ ، أَنَّ فَضَالَۃَ بْنَ عُبَیْدٍ وَأَبَا مُسْلِمٍ الْخَوْلاَنِیَّ کَانَا یَأْکُلاَنِ مَا قَتَلَ الْمِعْرَاضُ۔,,,20075,,
20076,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ عُبَیْدِ بْنِ سَعْدٍ ، أَنَّ رَجُلاً رَمَی أَرْنَبًا بِعَصًا فَکَسَرَ قَوَائِمَہَا ، ثُمَّ ذَبَحَہَا فَأَکَلَہَا۔,,,20076,,
20077,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ خُصَیْف ، فَقَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ ، عَنِ الْمِعْرَاضِ ، فَقَالَ : لَمْ یَکُنْ مِنْ نُبَالِ الْمُسْلِمِینَ فَلاَ تَأْکُلْ مِنْہُ شَیْئًا إِلاَّ شَیْئًا قَدْ خُزِقَ۔",,,20077,,
20078,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ عَامِرٍ ، قَالَ : سَأَلْتُہُ عَنِ الْمِعْرَاضِ ، فَقَالَ : إذَا کُنت أَصَبْت بِحَدِّہِ فَخَزَقَ کَمَا یَخْزِقُ السَّہْمُ فَکُلْ ، فَإِنْ أَصَابَہُ بِعَرْضِہِ فَلاَ تَأْکُلْ إِلاَّ أَنْ تُذْکِیَہُ۔",,,20078,,
20079,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ سَعِیدٍ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِمَا أُصِیبَ بِالْمِعْرَاضِ۔,,,20079,,
20080,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تَأْکُلْ مَا أَصَابَ الْمِعْرَاضُ إِلاَّ أَنْ یَخْزِقَ۔",,,20080,,
20081,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ ، قَالَ: لاَ تَأْکُلْ مَا أَصَابَ الْمِعْرَاضُ إِلاَّ أَنْ یَخْزِقَ۔",,,20081,,
20082,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ مَا أَصَابَ الْمِعْرَاضُ إِلاَّ مَا خَزَقَ۔,,,20082,,
20083,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ الْقَاسِمِ وَسَالِمٍ أَنَّہُمَا کَانَا یَکْرَہَانِ الْمِعْرَاضَ إِلاَّ مَا أَدْرَکْت ذَکَاتَہُ۔,,,20083,,
20084,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ مُغِیرَۃَ بْنِ زِیَادٍ ، عَنْ مَکْحُولٍ ، قَالَ: أَمَّا الْمِعْرَاضُ فَقَدْ کَانَ نَاسٌ یَکْرَہُونَہُ، قَالَ : ہُوَ مَوْقُوذَۃٌ وَلَکِنْ إذَا خَزَقَ۔",,,20084,,
20085,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ لاَ یَأْکُلُ مَا أَصَابَتِ الْبُنْدُقَۃُ وَالْحَجَرُ وَالْمِعْرَاضُ۔,,,20085,,
20086,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو عن سَعِیدٍ ، قَالَ : قَالَ عَمَّارٌ : إذَا رَمَیْت بِالْحَجَرِ ، أَوِ الْبُنْدُقَۃِ وَذَکَرْت اسْمَ اللہِ فَکُلْ ، وَإِنْ قَتَلَ۔",,,20086,,
20087,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ لاَ یَأْکُلُ مَا أَصَابَتِ الْبُنْدُقَۃُ وَالْحَجَرُ۔,,,20087,,
20088,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنِ الْقَاسِمِ وَسَالِمٍ أَنَّہُمَا کَانَا یَکْرَہَانِ الْبُنْدُقَۃَ إِلاَّ مَا أُدْرِکْت ذَکَاتَہُ۔,,,20088,,
20089,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عِیسَی بْنِ الْمُغِیرَۃِ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنِ الْمِعْرَاضِ وَالْبُنْدُقَۃِ ، فَقَالَ : ذَلِکَ مَا یُفْتِی بِہِ أَہْلُ الشَّامِ ، وَإِذَا ہُوَ لاَ یَرَاہُ۔",,,20089,,
20090,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ تَأْکُلْ مَا أَصَبْت بِالْبُنْدُقَۃِ ، إِلاَّ أَنْ تُذَکِّیَ۔",,,20090,,
20091,"حَدَّثَنَا حَفْصٌ ، عَنْ لیث ، عن مجاہد ، قَالَ : ما أصبت بالبندقۃ أو بالحجر فلا تأکل إلا أن تذکی۔",,,20091,,
20092,"حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَکِ ، عَنْ مَعْمَرٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : مَا رَدَّ عَلَیْک حَجَرُک فَکُلْ ، وَکَانَ عِکْرِمَۃُ یَکْرَہُہُ وَیَقُولُ : ہُوَ مَوْقُوذَۃٌ۔",,,20092,,
20093,"حَدَّثَنَا ابْنُ مُبَارَک ، عَنْ مَعْمَرٍ ، عَنِ ابن أبی نجیح ، عن مجاہد : أنہ کرہہ۔",,,20093,,
20094,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ حَرْمَلَۃَ ، قَالَ : کُلُ وَحْشِیَّۃٍ أَصَبْتہَا بِعَصًا ، أَوْ بِحَجَرٍ ، أَوْ بِبُنْدُقَۃٍ وَذَکَرْت اسْمَ اللہِ عَلَیْہِ فکلہا۔",,,20094,,
20095,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا قَتَلَ الْحَجَرُ فَلاَ تَأْکُلْ۔",,,20095,,
20096,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ تَأْکُلْ مِنْ صَیْدِ الْبُنْدُقَۃِ إِلاَّ مَا ذَکَّیْت۔",,,20096,,
20097,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا رَمَی الرَّجُلُ الصَّیْدَ بِالْحَجَرِ ، وبالجُلاَّہِقۃ فَلاَ تَأْکُلْہُ إِلاَّ أَنْ تُدْرِکَ ذَکَاتَہُ۔",,,20097,,
20098,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جابر ، عَنْ مَکْحُولٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْجَرَادُ وَالنُّونُ ذَکِیٌّ کُلُّہُ فَکُلُوہُ۔",,,20098,,
20099,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : قَالَ عُمَرُ : الْحِیتَانُ ذَکِیٌّ کُلُّہَا وَالْجَرَادُ ذَکِیٌّ کُلُّہُ۔",,,20099,,
20100,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عَلِیٌّ : الْجَرَادُ وَالْحِیتَانُ ذَکِیٌّ کُلُّہُ ، إِلاَّ مَا مَاتَ فِی الْبَحْرِ ، فَإِنَّہُ مَیْتَۃٌ۔",,,20100,,
20101,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی بَکْرِ بْنِ حَفْصٍ ، قَالَ : قَالَ عَبْدُ اللہِ : ذَکَاۃُ الْحُوتِ فَکُّ لَحْیَیْہِ۔",,,20101,,
20102,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : ذَکَاۃُ الْحُوتِ أَخْذُہُ۔",,,20102,,
20103,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ عَبْدِ الأَعْلَی، عَنِ ابْنِ الْحَنَفِیَّۃِ، قَالَ: ذَکَاۃُ الْحُوتِ أَخْذُہُ وَالْجَرَادُ ذَکِیٌّ۔",,,20103,,
20104,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : مَا مَاتَ فِیہِ فَطَفَا فَلاَ تَأْکُلْ۔",,,20104,,
20105,حَدَّثَنَا ابْنُ عُلَیَّۃَ وَعَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عن سَعِیدِ بْنِ الْمُسَیَّبِ أَنَّہُمَا کَرِہَا الطَّافِیَ مِنَ السَّمَکِ۔,,,20105,,
20106,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ لاَ یَکْرَہُ مِنَ السَّمَکِ شَیْئًا إِلاَّ الطَّافِیَ مِنْہُ۔",,,20106,,
20107,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عن عمرو ، عن أبی الشعثاء قَالَ : یکرہ الطافی منہ ، وکل ما جزرہ۔",,,20107,,
20108,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَنْ عَبْدِ اللہِ بْن أَبِی الْہُذَیْلِ ، قَالَ : سَأَلَ رَجُلٌ ابْنَ عَبَّاسٍ ، فَقَالَ : إنِّی آتِی الْبَحْرَ فَأَجِدُہُ قَدْ جَفَلَ سَمَکًا کَثِیرًا ، فَقَالَ : کُلْ مَا لَمْ تَرَ سَمَکًا طَافِیًا۔",,,20108,,
20109,"حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عَلِیٌّ : مَا مَاتَ فِی الْبَحْرِ ، فَإِنَّہُ مَیْتَۃٌ۔",,,20109,,
20110,حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ مِنَ السَّمَکِ مَا یَمُوتُ فِی الْمَائِ إِلاَّ أَنْ یَتَّخِذَ الرَّجُلُ حَظِیرَۃً فَمَا دَخَلَ فِیہَا فَمَاتَ فَلَمْ یَرَ بِأَکْلِہِ بَأْسًا۔,,,20110,,
20111,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ فِی الْحُوتِ یُوجَدُ فِی الْبَحْرِ مَیِّتًا فَنَہَی عَنْہُ۔,,,20111,,
20112,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، أَنَّہُ کَرِہَ الطَّافِیَ مِنْہُ۔,,,20112,,
20113,حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ الطَّافِیَ۔,,,20113,,
20114,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدِ الْحَذَّائِ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، أَنَّ أَبَا أَیُّوبَ وَجَدَ سَمَکَۃً طَافِیَۃً فَأَکَلَہَا۔,,,20114,,
20115,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی بَشِیرٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ قَالَ : أَشْہَدُ عَلَی أَبِی بَکْرٍ ، أَنَّہُ قَالَ : السَّمَکَۃُ الطَّافِیَۃُ عَلَی الْمَائِ حَلاَلٌ۔",,,20115,,
20116,حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنْ أَیُّوبَ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ عُمَرَ أَنَّہُ لَمْ یَکُنْ یَرَی بِالسَّمَکِ الطَّافِی بَأْسًا۔,,,20116,,
20117,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : بَعَثَنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَعَ أَبِی عُبَیْدَۃَ فِی سَرِیَّۃٍ فَنَفِذَ زَادُنَا فَمَرَرْت بِحُوتٍ قَدْ قَذَفَہُ الْبَحْرُ فَأَرَدْنَا أَنْ نَأْکُلَ مِنْہُ فَنَہَانَا أَبُو عُبَیْدَۃَ ، ثُمَّ قَالَ : نَحْنُ رُسُلُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَفِی سَبِیلِ اللہِ تبارک وتعالی کُلُوا فَأَکَلْنَا ، قَالَ : فَلَمَّا قَدِمْنَا عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَکَرْنَا ذَلِکَ ، فَقَالَ : إِنْ کَانَ بَقِیَ مَعَکُمْ مِنْہُ شَیْئٌ فَابْعَثُوا بِہِ إلَیَّ۔\n\n(بخاری 2483۔ مسلم 17)",,,20117,,
20118,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطِیَّۃَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ فِی السَّمَکِ یَجْزُرُ عَنْہُ الْمَائُ ، قَالَ : کُلْ۔",,,20118,,
20119,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عن عمرو ، عن أبی الشعثاء قَالَ : کل ما جزر عنہ۔",,,20119,,
20120,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : مَا جَزَرَ عَنْہُ ضَفِیرُ الْبَحْرِ فَکُلْ۔",,,20120,,
20121,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْقَاسِمِ بْنِ رَبِیعَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ، قَالَ : مَا قَذَفَ الْبَحْرُ فَہُوَ حَلاَلٌ۔",,,20121,,
20122,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزِّنَادِ ، عن الأعرج عَنْ أَبِی سَلَمَۃَ ، عَنْ زَیْدٍ ، وَأَبِی ہُرَیْرَۃَ ، قَالاَ : لاَ بَأْسَ بِمَا قَذَفَ الْبَحْرُ۔",,,20122,,
20123,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ أَنَّہُمَا قَالاَ : إذَا نَضَبَ عَنْہُ الْمَائُ ، ثُمَّ مَاتَ فَلاَ یَرَیَانِ بِأَکْلِہِ بَأْسًا۔",,,20123,,
20124,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ شَہْرِ بْنِ حَوْشَبَ ، عَنْ أَبِی أَیُّوبَ فِی قَوْلِہِ : {مَتَاعًا لَکُمْ وَلِلسَّیَّارَۃِ} قَالَ: مَا لَفَظَ الْبَحْرُ ، وَإِنْ کَانَ مَیْتًا۔",,,20124,,
20125,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ حُمَیْدِ بْنِ صَخْرٍ ، عَنْ مُحَمَّدِ بْنِ کَعْبِ الْقُرَظِیِّ ، عَنِ ابْنِ عَبَّاسٍ فِی قَوْلِہِ : {أحِلَّ لَکُمْ صَیْدُ الْبَحْرِ وَطَعَامُہُ} مَا أَلْقَی الْبَحْرُ عَلَی ظَہْرِہِ مَیِّتًا۔",,,20125,,
20126,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ عَمْرِو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : مَا لَفَظَ عَلَی ظَہْرِہِ مَیِّتًا فَہُوَ طَعَامُہُ۔",,,20126,,
20127,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ شَہْرٍ ، عَنْ أَبِی أَیُّوبَ ، قَالَ : مَا لَفَظَ الْبَحْرُ فَہُوَ طَعَامُہُ ، وَإِنْ کَانَ مَیْتًا۔",,,20127,,
20128,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ أَبِی الشَّعْثَائَ ، قَالَ : مَا کُنَّا نَتَحَدَّثُ إِلاَّ أَنَّ طَعَامَہُ مَالِحُہ۔",,,20128,,
20129,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : طَعَامُہُ مَا قَذَفَ۔",,,20129,,
20130,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : مَا قَذَفَ۔",,,20130,,
20131,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ الْمُسَیَّبِ سُئِلَ عَنْ صَیْدِ الْبَحْرِ وَطَعَامِہِ ، قَالَ : طَعَامُہُ مَا لَفَظَ وَہُوَ حَیٌّ۔",,,20131,,
20132,"حَدَّثَنَا حَمَّادُ بْنُ أَبِی خَالِدٍ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عَنْ سَعْدِ الْجَارِی ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ ، وَابْنَ عَمْرٍو ، عَنِ الْحِیتَانِ تَمُوتُ صَرْدًا ، أَوْ یَقْتُلُ بَعْضُہَا بَعْضًا ، قَالاَ : حَلاَلٌ۔",,,20132,,
20133,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَکْرَہُ الْحُوتَ الَّتِی قَتَلَتْہَا الْحُوتُ۔,,,20133,,
20134,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ مَالِکٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عَنْ سَعْدٍ الْجَارِی ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، قَالَ : لاَ بَأْسَ بِہَا۔",,,20134,,
20135,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، قَالَ : سُئِلَ عَبْدُ اللہِ بْنُ عُبَیْدِ بْنِ عُمَیْرٍ ، عَنْ رَجُلٍ رَمَی بِشِصِّہ فَأَخَذَ سَمَکَۃٌ ، فَجَائَتْ سَمَکَۃٌ أُخْرَی فَضَرَبَتْہَا ، فَذَہَبَتْ بِنِصْفِہَا ، قَالَ : یَأْکُلُ مَا بَقِیَ۔",,,20135,,
20136,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، قَالَ : قُلْتُ لِبُرْدٍ: الرَّجُلُ یَکُونُ عَلَی الرَّحْلِ فَیَطْعَن الْحِمَارَ وَیَذْکُرُ اسْمَ اللہِ، أَوْ یَضْرِبُہُ بِالسَّیْفِ فَذَکَرَ ، عَنْ مَکْحُولٍ ، أَنَّہُ قَالَ : إذَا ذَکَرَ اسْمَ اللہِ حِینَ یَضْرِبُ ، أَوْ یَطْعَنُ فَلَیْسَ بِہِ بَأْسٌ۔",,,20136,,
20137,"حَدَّثَنَا یَحْیَی بْنُ أَبِی زَائِدَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ طَعَنَ صَیْدًا بِرُمْحِہِ وَسَمَّی ، قَالَ : یَأْکُلُہُ۔",,,20137,,
20138,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ إِسْحَاقَ بْنِ سُوَیْد ، عَنْ یَحْیَی بْنِ یَعْمُرَ ، قَالَ : لاَ یَأْکُلُ مَا یَطْعَن بِہِ فِی الْحَلْقِ ، ثُمَّ یَقْطَعُ العروق ، قَالَ : ذَلِکَ لَیْسَ بِذَبْحٍ وَلَکِنَّہُ الْقَتْلُ۔",,,20138,,
20139,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سِمَاکٍ ، قَالَ : کَانَ الظَّبْیُ یَمُرُّ بِہِمْ فَیَضْرِبُونَہُ بِأَسْیَافِہِمْ فَیَقْطَعُ ہَذَا الْیَدَ وَہَذَا الرِّجْلَ فَسَمِعْت مُصْعَبًا بن الزبیر یَخْطُبُ وَیَنْہَی عَنْ ذَلِکَ۔",,,20139,,
20140,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَرِہَ صَیْدَ الْکَلْبِ الأَسْوَدِ الْبَہِیمِ۔,,,20140,,
20141,حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرَ ، عَنْ إبْرَاہِیمَ أَنَّہُ کَرِہَہُ۔,,,20141,,
20142,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، أَنَّہُ کَانَ یَکْرَہُ صَیْدَ الْکَلْبِ الأَسْوَدِ وَیَقُولُ : أُمِرَ بِقَتْلِہِ فَکَیْفَ یُؤْکَلُ صَیْدُہُ۔",,,20142,,
20143,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، أَنَّہُ کَرِہَ صَیْدَ الْکَلْبِ الأَسْوَدِ الْبَہِیمِ۔,,,20143,,
20144,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ خَالِدٍ، عَنْ عِکْرِمَۃَ، قَالَ: قَالَ ابْنُ عَبَّاسٍ: مَا أَعْجَزَک مِمَّا فِی یَدِکَ فَہُوَ بِمَنْزِلَۃِ الصَّیْدِ۔",,,20144,,
20145,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : إذَا نَدَّ مِنَ الإِبِلِ وَالْبَقَرِ شَیْئٌ فَاصْنَعُوا بِہِ کَمَا تَصْنَعُونَ بِالْوَحْشِ۔",,,20145,,
20146,"حَدَّثَنَا وَکِیعٌ ، عَنْ قُرَّۃَ ، عَنِ الضَّحَّاکِ فِی بَقَرَۃٍ شَرَدَتْ ، قَالَ : ہِیَ بِمَنْزِلَۃِ الصَّیْدِ۔",,,20146,,
20147,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، أَنَّ بَعِیرًا نَدَّ فَطَعَنَہُ رَجُلٌ بِالرُّمْحِ فَسُئِلَ عَلِیٌّ عَنْہُ ، فَقَالَ : کُلْہُ وَاہْدِ لِی عَجُزہ۔",,,20147,,
20148,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ وَحَمَّادٍ ، عَنْ إبْرَاہِیمَ وَالشَّعْبِیِّ أَنَّہُمَا قَالاَ : إذَا تَوَحَّشَ الْبَعِیرُ أو الْبَقَرَۃُ صُنِعَ بِہِمَا مَا یُصْنَعُ بِالْوَحْشِیَّۃِ۔",,,20148,,
20149,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَعَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالاَ : ہُوَ بِمَنْزِلَۃِ الصَّیْدِ۔",,,20149,,
20150,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ زِیَادٍ ابْنِ أَبِی مَرْیَمَ ، أَنَّ حِمَارًا وَحْشِیًّا اسْتَعْصَی عَلَی أَہْلِہِ فَضَرَبُوا عُنُقَہُ فَسُئِلَ ابْنُ مَسْعُودٍ ، فَقَالَ : تِلْکَ أَسْرَعُ الذَّکَاۃِ۔",,,20150,,
20151,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : کَانَ حِمَارُ وَحْشٍ فِی دَارِ عَبْدِ اللہِ فَضَرَبَ رَجُلٌ عُنُقَہُ بِالسَّیْفِ وَذَکَرَ اسْمَ اللہِ عَلَیْہِ ، فَقَالَ ابْنُ مَسْعُودٍ : صَیْدٌ فَکُلُوہُ۔",,,20151,,
20152,حَدَّثَنَا عَبِیْدَۃُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ بِمِثْلِہِ ، أَوْ نَحْوِہِ۔,,,20152,,
20153,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، أَنَّ حِمَارًا لأَہْلِ عَبْدِ اللہِ ضَرَبَ رَجُلٌ عُنُقَہُ بِالسَّیْفِ فَسُئِلَ عَبْدُ اللہِ ، فَقَالَ : کُلُوہُ ، إنَّمَا ہُوَ صَیْدٌ۔",,,20153,,
20154,"حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، أَنَّ ثَوْرًا حَرِبَ فِی بَعْضِ دُورِ الْمَدِینَۃِ ، فَضَرَبَہُ رَجُلٌ بِالسَّیْفِ ، وَذَکَرَ اسْمَ اللہِ فَسُئِلَ عَنْہُ ، فَقَالَ : ذَکَاۃٌ وَحِیَّۃٌ ، وَأَمَرَہُمْ بِأَکْلِہِ۔",,,20154,,
20155,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ سُفْیَانَ ، عَنْ أَبِیہِ ، عَنْ عَبَایَۃَ بْنِ رِفَاعَۃَ ، عَنْ جَدِّہِ رَافِعِ بْنِ خَدِیجٍ، قَالَ : کُنَّا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَنَدَّ بَعِیرٌ فَضَرَبَہُ رَجُلٌ بِالسَّیْفِ فَذُکِرَ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إنَّ ہَذِہِ الْبَہَائِمَ لَہَا أَوَابِدُ کَأَوَابِدِ الْوَحْشِ فَمَا غلبکم مِنْہَا فَاصْنَعُوا بِہِ ہَکَذَا۔\n\n(بخاری 2488۔ مسلم 20)",,,20155,,
20156,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ وَیُونُسَ ، عَنِ الْحَسَنِ أَنَّہُمَا لَمْ یَرَیَا بَأْسًا بِمَا مَاتَ مِنَ السَّمَکِ فِی الْحَظِیرَۃِ۔,,,20156,,
20157,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَان ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ مِنَ السَّمَکِ مَا یَمُوتُ فِی الْمَائِ إِلاَّ أَنْ یَتَّخِذَ الرَّجُلُ حَظِیرَۃً فَمَا دَخَلَ فِیہَا فَمَاتَ لَمْ یَرَ بأکلہ بَأْسًا۔,,,20157,,
20158,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ مَعْقِلِ بن عُبَیْدِ اللہِ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إذَا حَظَّرْت فِی الْمَائِ حَظِیرَۃً فَمَا مَاتَ فِیہَا فَکُلْ۔",,,20158,,
20159,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، عَنْ عَبَایَۃَ بْنِ رِفَاعَۃَ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ : إنَّا نَلْقَی الْعَدُوَّ غَدًا وَلَیْسَ مَعَنَا مُدًی ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَرِنْ ، أَوْ أَعْجِلْ مَا أَنْہَرَ الدَّمَ وَذُکِرَ اسْمُ اللہِ عَلَیْہِ فَکُلُوا مَا لَمْ یَکُنْ سِنٌّ ، أَوْ ظُفْرٌ وَسَأُحَدِّثُکُمْ عَنْ ذَلِکَ ، أَمَّا السِّنُّ فَعَظْمٌ وَأَمَّا الظُّفُرُ فَمُدَی الْحَبَشَۃِ۔ (بخاری 5543۔ ابوداؤد 2814)",,,20159,,
20160,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِی إدْرِیسَ ، قَالَ : رَأَیْتُ أَنَسًا أَتَی بِعَصَافِیرَ فَدَعَا بِلِیطَۃٍ فَذَبَحَہُنَّ بِہَا۔",,,20160,,
20161,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، قَالَ : سُئِلَ عَلْقَمَۃُ عَنِ اللِّیطَۃِ یُذْبَحُ بِہَا وَالْمَرْوَۃِ ، فَقَالَ : لاَ بأس بہا وقال : کُلْ مَا أَفْرَی الأَوْدَاجَ إِلاَّ السِّنَّ وَالظُّفُرَ۔",,,20161,,
20162,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ وَالشَّعْبِیِّ، قَالاَ: لاَ بَأْسَ بِذَبْحِ اللِّیطَۃِ، أَوَ قَالَ: الْقَصَبَۃَ۔",,,20162,,
20163,"حَدَّثَنَا یَحْیَی ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : تَذَاکَرْنَا عِنْدَ أَبِی الشَّعْثَائَ مَا یُذَکَّی بِہِ ، فَقَالَ : مَا أَفْرَی الأَوْدَاجَ ، ومَا أَفْرَی مَا حَزَّ۔",,,20163,,
20164,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : مَا أَفْرَی الأَوْدَاجَ وَأَہْرَاقَ الدَّمَ فکل مَا خَلاَ النَّابَ وَالظُّفُرَ وَالْعَظْمَ۔",,,20164,,
20165,"حَدَّثَنَا خَالِدُ بْنُ حَیَّانَ الرَّقِّیُّ ، عَنْ جَعْفَرِ بْنِ مَیْمُونٍ ، قَالَ : کُلُّ مَا أَفْرَی اللَّحْمَ وَقَطَعَ الأَوْدَاجَ إِلاَّ أَنَّہُمْ کَانُوا یَکْرَہُونَ السِّنَّ وَالظُّفُرَ وَیَقُولُونَ : إنَّہُمَا مُدَی الْحَبَشَۃِ۔",,,20165,,
20166,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ ذَکَاۃَ إِلاَّ بِالأَسَلِ والظُّرَر ، وَمَا قَطَعَ الأَوْدَاجَ وَفَرَی اللَّحْمَ فَکُلْ مَا خَلاَ السِّنَّ وَالظُّفْرُ۔",,,20166,,
20167,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ عَوْفٍ ، عَنْ أَبِی رَجَائٍ ، قَالَ : أَصْعَدْنَا فِی الْحَاجِّ فَأَصَابَ صَاحِبٌ لَنَا أَرْنَبًا فَلَمْ یَجِدْ مَا یُذْکِیہَا بِہِ فَذَبَحَہَا بِظُفُرِہِ فَمَلُّوہَا فَأَکَلُوہَا ، وَأَبَیْتُ أَنْ آکُلَ ، قَالَ : فَلَقِیت ابْنَ عَبَّاسٍ فَذَکَرْت ذَلِکَ لَہُ ، فَقَالَ : أَحْسَنْت حِینَ لَمْ تَأْکُلْ ، قَتَلَہَا خَنْقًا۔",,,20167,,
20168,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یُذْبَحُ بِسِنٍّ ، وَلاَ عَظْمٍ ، وَلاَ ظُفُرٍ ، وَلاَ قَرْنٍ۔",,,20168,,
20169,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ سِمَاکٍ ، عَنْ مُرَیِّ بْنِ قَطَرِیِّ، عَنْ عَدِیِّ بْنِ حَاتِمٍ، قَالَ: سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ الذَّبِیحَۃِ بِالْمَرْوَۃِ وشقۃ العصا ، فَقَالَ : لاَ بَأْسَ بِہِ وَرَخَّصَ فِیہِ۔\n\n(ابوداؤد 2817۔ ابن ماجہ 3177)",,,20169,,
20170,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ جُرَیْجٍ عَمَّنْ حَدَّثَہُ ، عَنْ رَافِعِ بْنِ خَدِیجٍ ، قَالَ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ الذَّبِیحَۃِ اللِّیطَۃِ ، فَقَالَ : کُلْ مَا فَرَی الأَوْدَاجَ إِلاَّ سِنًّا ، أَوْ ظُفُرًا۔ \n\n(مسلم 22۔ نسائی 4492م)",,,20170,,
20171,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ إسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ أَبِی الرَّبِیع سُئِلَ ابْنُ عَبَّاسٍ عَنْ ذَبِیحَۃِ الْقَصَبَۃِ ، إذَا لَمْ یَجِدْ سِکِّینًا ، فَقَالَ : إذَا فرت فَقَطَعَتِ الأَوْدَاجَ کَقَطْعِ السِّکِّینِ وَذُکِرَ اسْمُ اللہِ فَکُلْ ، وَإِذَا ثُلغت ثلغًا فَلاَ تَأْکُلْ وَسَأَلَتْہُ عَنْ ذَبِیحَۃِ الْمَرْوَۃِ إذَا لَمْ یَجِدْ سِکِّینًا ، فَقَالَ : إذَا بَرَتْ فَقَطَعَتِ الأَوْدَاجَ فَکُلْ ، وَإِذَا ثُلِغت ثلغًا فَلاَ تَأْکُلْ۔",,,20171,,
20172,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مُحَمَّدِ بْنِ صَیْفِیِّ ، قَالَ : أَتَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِأَرْنَبَیْنِ قَدْ ذَبَحْتُہُمَا بِمَرْوَۃَ فَأَمَرَنِی بِأَکْلِہِمَا۔ (ابن ماجہ 3175)",,,20172,,
20173,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ مُحَمَّدِ بْنِ صَفْوَانَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِمِثْلِہِ۔ (احمد 3۔ دارمی 2014),,,20173,,
20174,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : اذْبَحْ بِحَجَرِکَ وحدیدتک وعودک وَعَظْمَک۔",,,20174,,
20175,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ إِسْحَاقَ بْنِ سُوَیْد ، عَنْ یَحْیَی بْنِ یَعْمُرَ ، قَالَ : کُلْ مَا یُجْرَحُ ، وَلاَ تَأْکُلُ مَا یُفْدَغُ ، وَکُلُّ شَیْئٍ یَفْرِی الأَوْدَاجَ فَکُلْ وَلَوْ بِلِیطَۃٍ ، أَوْ بشظیۃ حَجَرٍ۔",,,20175,,
20176,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : اذْبَحْ بِالْحَجَرِ وَاللِّیطَۃِ وَکُلُّ شَیْئٍ مِنَ الشَّفْرَۃِ مَا لَمْ یَجْرَحْ ، أَوْ یَفْدَغْ۔",,,20176,,
20177,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : جَائَ أَعْرَابِیٌّ إلَی الأَسْوَدِ ، فَقَالَ لَہُ : أَذْبَحُ بِالْمَرْوَۃِ ؟ فَقَالَ لَہُ الأَسْوَدُ : لاَ فَلَمَّا قَفَی الأَعْرَابِیُّ قُلْتُ : أَلَیْسَ لاَ بَأْسَ أَنْ یَذْبَحَ بِالْمَرْوَۃِ ؟ قَالَ : إنَّمَا ہَذَا یُرِیدُ أَنْ یَفصد بَعِیرَہُ فَإِذَا مَاتَ ، قَالَ : ذَکَّیْتہ۔",,,20177,,
20178,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : إذَا ذَبَحْت بِالْعُودِ وَالْمَرْوَۃِ فَقَطَعْت الأَوْدَاجَ فَلَیْسَ بِہِ بَأْسٌ۔",,,20178,,
20179,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَلَمَۃَ بْنِ بِشْرٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : سَأَلْتُہ عَنِ الذَّبِیحَۃِ بِالْمَرْوَۃِ ، فَقَالَ : إذَا کَانَتْ حَدِیدَۃً لاَ تَرِدُ الأَوْدَاجَ فَکُلْ۔",,,20179,,
20180,"حَدَّثَنَا غُنْدَرٌ، حَدَّثَنَا شُعْبَۃَ، عَنْ عَبْدِ اللہِ بْن أَبِی السَّفَرِ، قَالَ: سَمِعْتُ الشَّعْبِیَّ یَقُولُ: کُلْ ذَبِیحَۃَ الْمَرْوَۃِ۔",,,20180,,
20181,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إسْرَائِیلَ ، عَنِ السدی ، عَنِ الْوَلِیدِ بْنِ عُتْبَۃَ ، قَالَ علِیٌّ : إذَا لَمْ تَجِدْ إِلاَّ الْمَرْوَۃَ فَاذْبَحْ بِہَا۔",,,20181,,
20182,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کُلْ مَا ذُبِحَ بِالشَّفْرَۃِ وَالْمَرْوَۃِ وَالْقَصَبَۃِ وَالْعُودِ ومَا أَفْرَی الأَوْدَاجَ ، وَأَنْہَرَ الدَّمَ ، وَکَانَ یُکْرَہُ السِّنُّ وَالْعَظْمُ وَالظُّفُرُ۔",,,20182,,
20183,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، أَنَّ غُلاَمًا مِنْ بَنِی حَارِثَۃَ کَانَ یَرْعَی لِقْحَۃً لہ فَأَتَاہَا الْمَوْتُ وَلَیْسَ مَعَہُ مَا یُذْکِیہَا بِہِ فَأَخَذَ وَتَدًا فَنَحَرَہَا فَسَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَمَرَہُ بِأَکْلِہَا۔,,,20183,,
20184,"حَدَّثَنَا جَرِیرٌ ، عَنِ الرُّکَیْنِ ، عَنْ أَبِی طَلْحَۃَ الأَسَدِیِّ ، قَالَ : کُنْتُ جَالِسًا عِنْدَ ابْنِ عَبَّاسٍ فَأَتَاہُ أَعْرَابِیٌّ، فَقَالَ : کُنْت فِی غَنَمٍ فَعَلاَ الذِّئْبُ فبقر النَّعْجَۃُ مِنْ غَنَمِی فَنَثَرَ قَصْبَہَا فِی الأَرْضِ ، فَأَخَذْت ظِرَارًا مِنَ الأَظرۃِ فَضَرَبْت بَعْضَہُ بِبَعْضٍ حَتَّی صَارَ لِی مِنْہُ کَہَیْئَۃِ السِّکِّینَ فَذَبَحْتُ بِہِ الشَّاۃَ وَأَہْرَقْتُ بِہِ الدَّمَ وَقَطَعْت الْعُرُوقَ ، فَقَالَ : انْظُرْ مَا مَسَّ الأَرْضَ مِنْہَا فَاقْطَعْہُ ، فَإِنَّہُ قَدْ مَاتَ وَکُلْ سَائِرَہَا۔",,,20184,,
20185,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، عَنْ مِسْعَرٍ، عَنْ عَاصِمٍ، عَنْ زِرٍّ، قَالَ: قَالَ عُمَرُ: لیُذَکِّیَنَّ لَکُمُ الأَسَلُ: الرِّمَاحُ وَالنَّبْلُ۔",,,20185,,
20186,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ کَعْبِ بْنِ مَالِکٍ ، عَنْ أَبِیہِ ، أَنَّ جُوَیْرِیَۃَ لَہُمْ سَوْدَائَ ذَبَحَتْ شَاۃً بِمَرْوَۃَ ، فَسَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ ذَلِکَ فَأَمَرَہُ بِأَکْلِھَا۔(بخاری 2304۔ مسندہ 500),,,20186,,
20187,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : کُلْ مَا أَفْرَی الأَوْدَاجَ إِلاَّ سِنٌّ ، أَوْ ظُفُرٌ۔",,,20187,,
20188,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ سَلَمَۃَ بْنِ عَلْقَمَۃَ ، قَالَ : سُئِلَ مُحَمَّدٌ عَنِ الذَّبِیحَۃِ بِالْعُودِ ، فَقَالَ : کُلْ مَا لَمْ یُفْدَغْ۔",,,20188,,
20189,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الذَّکَاۃُ فِی الْحَلْقِ وَاللَّبَّۃِ۔",,,20189,,
20190,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ دَاوُدَ بْنِ أَبِی عَاصِمٍ ، أَنَّ بَعِیرًا تَرَدَّی فِی مَنْہَلٍ مِنْ تِلْکَ الْمَنَاہِلِ فَلَمْ یَسْتَطِیعُوا أَنْ یَنْحَرُوہُ فَسَأَلُوا سَعِیدَ بْنَ الْمُسَیَّبِ ، فَقَالَ : لاَ مَنْحَرَ إِلاَّ مَنْحَرُ إبْرَاہِیمَ علیہ السلام۔",,,20190,,
20191,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ نَحْرَ إِلاَّ فِی الْمَنْحَرِ وَالْمَذْبَحِ۔",,,20191,,
20192,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ أَخْبَرَنَا ہِشَامٌ الدَّسْتَوَائِیُّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی الْمَعْرُورِ ، عَنِ ابن الْفَرَافِصَۃِ : أن الفَرَافِصَۃ کَانَ عِنْدَ عُمَرَ فَأَمَرَ مُنَادِیَہُ ، إنَّ النَّحْرَ فِی اللَّبَّۃِ ، وَالْحَلْقِ لِمَنْ قدر وَأَقِرُّوا الأَنْفُسَ حَتَّی تَزْہَقَ۔ (عبدالرزاق 8614)",,,20192,,
20193,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ عَطَائٍ ؛ فِی رَجُلٍ ذَبَحَ شَاۃً مِنْ قَفَاہَا فَکَرِہَ أَکْلَہَا۔,,,20193,,
20194,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ رَجُلٍ مِنْ بَنِی حَارِثَۃَ ، عَنْ أَشْیَاخٍ لَہُمْ ، أَنَّ بَعِیرًا تَرَدَّی فِی عین فَسَأَلُوا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْہُ ، فَقَالَ : اطْعَنُوہُ وَکُلُوہُ۔ (طبرانی 4380)",,,20194,,
20195,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ سِیَاہٍ ، عَنْ حَبِیبٍ ، عَنْ مَسْرُوقٍ ، أَنَّ بَعِیرًا تَرَدَّی فِی بِئْرٍ فَصَارَ أَعْلاَہُ أَسْفَلَہُ ، فَقَالَ عَلِیٌّ : قَطِّعُوہُ أَعْضَائً وَکُلُوہُ۔",,,20195,,
20196,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ فِی الْبَعِیرِ یَتَرَدَّی فِی الْبِئْرِ ، فَقَالَ : یُطْعَنُ حَیْثُ قُدِرَ ، وَیُذْکَرُ اسْمُ اللہِ عَلَیْہِ۔",,,20196,,
20197,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَبِی الْعُشَرَائِ ، عَنْ أَبِیہِ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، مَا تَکُونُ الذَّکَاۃُ إِلاَّ فِی الْحَلْقِ وَاللَّبَّۃِ ؟ فَقَالَ : لَوْ طَعَنْتَ فِی فَخِذِہَا لأَجْزَأک۔ (ترمذی 1481۔ ابن اجہ 3184)",,,20197,,
20198,"حَدَّثَنَا یَحْیَی ، عَنْ أَبِی حَیَّانَ ، عَنْ عَبَایَۃَ ، قَالَ : تَرَدَّی بَعِیرٌ فِی رَکِیَّۃٍ ، وَابْنُ عُمَرَ حَاضِرٌ فَنَزَلَ رَجُلٌ لِیَنْحَرَہُ ، فَقَالَ : لاَ أَقْدِرُ أَنْ أَنْحَرَہُ ، فقال ابْنُ عُمَرَ ، اذْکُرِ اسْمَ اللہِ عَلَیْہِ وَأَجْہِزْ عَلَیْہِ مِنْ قِبَلِ شَاکِلَتِہِ فَفَعَلَ ، فَأُخْرِجَ مُقَطَّعًا فَأَخَذَ مِنْہُ ابْنُ عُمَرَ عُشْرًا بِدِرْہَمَیْنِ ، أَوْ بِأَرْبَعَۃٍ۔",,,20198,,
20199,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، حَدَّثَنَا سُفْیَانُ ، عَنْ حَبِیبٍ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ فِی قِرْمَلَ تَرَدَّی فِی بِئْرٍ ، فَقَالَ : قطِّعُوہُ وَکُلُوہُ۔",,,20199,,
20200,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ سِیَاہٍ ، عَنْ أَبِی رَاشِدٍ السَّلْمَانِیِّ ، قَالَ : کُنْتُ أَرْعَی مَنَائِحَ لأَہْلِی بِظَہْرِ الْکُوفَۃِ یَعْنِی الْعِشَارَ ، قَالَ : فَتَرَدَّی مِنْہَا بَعِیرٌ فَخَشِیت أَنْ یَسْبِقنِی بِذَکَاۃٍ فَأَخَذْت حَدِیدَۃً فَوَجَأْت بِہَا فِی جَنْبِہِ ، أَوْ سَنَامِہِ ، ثُمَّ قَطَّعْتہ أَعْضَائً وَفَرَّقْتہ عَلَی سَائِرِ أَہْلِی ، ثُمَّ أَتَیْتُ أَہْلِی فَأَبَوْا أَنْ یَأْکُلُوا حَیْثُ أَخْبَرْتہمْ خَبَرَہُ فَأَتَیْت عَلِیًّا فَقُمْت عَلَی بَابِ قَصْرِہِ فَقُلْت : یَا أَمِیرَ الْمُؤْمِنِینَ ، یَا أَمِیرَ الْمُؤْمِنِینَ ، فَقَالَ : لَبَّیْکَاہُ لَبَّیْکَاہُ ، فَأَخْبَرْتہ خَبَرَہُ ، فَقَالَ : کُلْ وَأَطْعِمْنِی عَجُزَہُ۔",,,20200,,
20201,"حَدَّثَنَا مُصْعَبٌ ، حَدَّثَنَا یُونُسُ بْنُ أَبِی إِسْحَاقَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ شُرَیْحٌ وَمَسْرُوقٌ یَقُولاَنِ: أَیُّمَا بَعِیرٍ تَرَدَّی فِی بِئْرٍ فَلَمْ یَجِدُوا مَنْحَرَہُ فَلْیَجَؤُوہ بِالسِّکِّینِ فَہُوَ ذَکَاتُہُ۔",,,20201,,
20202,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سعید ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، عَنْ أَبِی مُرَّۃَ مَوْلَی عَقِیلِ بْنِ أَبِی طَالِبٍ ، قَالَ : رَجَعْت إلَی أَہْلِی وَقَدْ کَانَ لَہُمْ شَاۃٌ فَإِذَا ہِیَ مَیْتَۃٌ فَذَبَحْتہَا فَتَحَرَّکَتْ فَأَتَیْت أَبَا ہُرَیْرَۃَ فَذَکَرْت ذَلِکَ لَہُ فَأَمَرَنِی بِأَکْلِہَا ، قَالَ : ثُمَّ أَتَیْتُ زَیْدَ بْنَ ثابت فَذَکَرْت لَہُ أَمْرَہَا ، فَقَالَ : إنَّ الْمَیِّتَ یَتَحَرَّک۔",,,20202,,
20203,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ فِی الذَّبِیحَۃِ ، قَالَ : إذَا مَصَعَتْ بِذَنَبِہَا ، أَوْ طَرَفَتْ ، أَوْ تَحَرَّکَتْ فَقَدْ حَلَّتْ۔",,,20203,,
20204,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ أَنَّہُ لَمْ یَرَ بِہَا بَأْسًا۔,,,20204,,
20205,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا ذُکِّیَتْ فَحَرَّکَتْ ذَنَبًا ، أَوْ طَرَفًا ، أَوْ رِجْلاً فَہِیَ ذَکِیَّۃٌ۔",,,20205,,
20206,"حَدَّثَنَا عَبَّادُ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی الذَّبِیحَۃِ: إذَا ذُکِّیَتْ فَحَرَّکَتْ طَرَفًا، أَوْ رِجْلاً فَہِیَ ذَکِیّ۔",,,20206,,
20207,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الصَّبَّاحِ بْنِ ثَابِتٍ ، قَالَ : سَأَلَتْ عَامِرَ بْنِ عَبْدَۃَ ، عَنْ بَطَّۃٍ وَقَعَتْ فِی بِئْرٍ فَأَخْرَجُوہَا وَبِہَا رَمَقٌ ، فَقَالَ : اذْبَحُوہَا وَکُلُوہَا۔",,,20207,,
20208,"حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا طَرَفَتْ بِعَیْنِہَا ، أَوْ مَصَعَتْ بِذَنَبِہَا ، أَوْ رَکَضَتْ بِرِجْلِہَا فَکُلْ۔",,,20208,,
20209,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : مَا أَدْرَکْت مِنْ ذَلِکَ یَطْرِفُ بِعَیْنِہِ ، أَوْ یُحَرِّکُ ذَنَبَہُ فَذُبِحَ فَہُوَ حَلاَلٌ ، وَمَا ذُبِحَ فَلَمْ تَطْرِفْ لَہُ عَیْنٌ ، وَلَمْ یَتَحَرَّکْ لَہُ ذَنَبٌ فَہُوَ حَرَامٌ مَیْتَۃٌ۔",,,20209,,
20210,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ أَبِی شِہَابٍ مُوسَی بْنِ نَافِعٍ ، عَنِ النُّعْمَانِ بْنِ عَلِیٍّ ، قَالَ : مَرَّ سَعِیدُ بْنُ جُبَیْرٍ عَلَی نَعَامَۃٍ مُلْقَاۃٍ عَلَی الْکُنَاسَۃِ تَحَرَّکُ ، فَقَالَ : مَا ہَذِہِ ؟ فَقَالُوا : نَخَافُ أَنْ تَکُونَ مَوْقُوذَۃً ؟ فَقَالَ : کِدْتُمْ تَدَعُونہَا لِلشَّیْطَانِ ، إنَّمَا الْوَقِیذُ مَا مَاتَ فِی وَقِیذِہِ۔",,,20210,,
20211,"حَدَّثَنَا مُعْتَمَرٌ ، عَنْ أَبِیہِ ، عَنْ أَبِی مجلز ، قَالَ : کَانُوا یرجون فِی الْمُنْخَنِقَۃِ وَالْمَوْقُوذَۃِ وَالْمُتَرَدِّیَۃِ إِلاَّ مَا ذَکَّیْتُمْ ، ثُمَّ حَرَّمَ اللَّہُ ذَلِکَ کُلَّہُ إلا ما ذُکِّیَ۔",,,20211,,
20212,حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَرَّمَ یَوْمَ خَیْبَرَ الْمُجَثَّمَۃَ۔ (ترمذی 1795۔ احمد 2/366),,,20212,,
20213,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی عَنِ الْمُجَثَّمَۃِ۔,,,20213,,
20214,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : نَہَی عَنِ الْمُجَثَّمَۃِ۔",,,20214,,
20215,"حَدَّثَنَا ہَاشِمُ بْنُ الْقَاسِمِ ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : لَمَّا کَانَ یَوْمَ خَیْبَرَ حَرَّمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمُجَثَّمَۃَ وَالْخِلْسَۃَ وَالنُّہْبَۃَ۔\n\n(ترمذی 1478۔ احمد 3/323)",,,20215,,
20216,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنِ الْمُجَثَّمَۃِ۔ (بخاری 5629۔ ترمذی 1825)",,,20216,,
20217,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : أَرَأَیْت لَوْ رَمَیْت دِیکًا ، أَوْ کَبْشًا بِالنَّبْلِ کُنْت تَأْکُلُہُ ؟ قَالَ : لاَ ہُوَ مَیْتَۃٌ۔",,,20217,,
20218,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، أَنَّہُ کَانَ یَنْہَی عَنْ ذَلِکَ۔,,,20218,,
20219,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْمِنْہَالِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّ ابْنَ عُمَرَ مَرَّ عَلَی قَوْمٍ نَصَبُوا دَجَاجَۃً یَرْمُونَہَا ، فَقَالَ : لَعَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَنْ مَثَّلَ بِالْبَہَائِمِ ۔\n\n(بخاری 5515۔ مسلم 1549)",,,20219,,
20220,"حَدَّثَنَا عُقْبَۃُ بْنُ خَالِدٍ ، عَنْ مُوسَی بْنِ مُحَمَّدٍ ، قَالَ : أَخْبَرَنِی أَبِی ، عَنْ أَبِی سَعِیدٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُمَثَّلَ بِالْبَہَائِمِ۔ (ابن ماجہ 3185)",,,20220,,
20221,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ، عَنْ سُفْیَانَ، عَنْ سِمَاکٍ، عَنْ عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: مَرَّ عَلَی أُنَاسٌ مِنَ الأَنْصَارِ قَدْ وَضَعُوا حَمَامَۃً یَرْمُونَہَا، فَقَالَ: نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُتَّخَذَ الرُّوحُ غَرَضًا۔\n\n(مسلم 1549۔ ترمذی 1475)",,,20221,,
20222,"حَدَّثَنَا یَزِیدُ ، أَخْبَرَنَا شُعْبَۃُ ، عَنْ ہِشَامِ بْنِ زَیْدِ بْنِ أَنَسٍ ، قَالَ : دَخَلْت مَعَ أَنَسٍ دَارَ الإِمَارَۃِ وَقَدْ نَصَبُوا دَجَاجَۃً یَرْمُونَہَا ، فَقَالَ: نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ تُصَبَّرَ الْبَہَائِمُ۔ \n\n(بخاری 5513۔ مسلم 1549)",,,20222,,
20223,"حَدَّثَنَا أَبُو الْمُوَرِّعِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُقْتَلَ شَیْئٌ مِنَ الْبَہَائِمِ صَبْرًا۔ (مسلم 1550۔ ابن ماجہ 3188)",,,20223,,
20224,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنْ عُبَیْدِ بْنِ تِعْلَی ، عَنْ أَبِی أَیُّوبَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَی عَنْ صَبْرِ الْبَہِیمَۃِ وَمَا أُحِبُّ أَنِّی صَبَّرْت دَجَاجَۃً ، وَلاَ أَنَّ لِی کَذَا وَکَذَا۔ (طبرانی 4004۔ احمد 5/442)",,,20224,,
20225,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عن أبی إدریس عَنْ أَبِی ثَعْلَبَۃَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ أَکْلِ کُلِّ ذِی نَابٍ مِنَ السِّبَاعِ۔ (بخاری 5780۔ مسلم 1533)",,,20225,,
20226,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ زَیْدِ بْنِ جَابِرٍ ، قَالَ : حدَّثَنَا الْقَاسِمُ وَمَکْحُولٌ ، عَنْ أَبِی أُمَامَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی یَوْمَ خَیْبَرَ ، عَنْ کُلِّ ذِی نَابٍ مِنَ السِّبَاعِ۔",,,20226,,
20227,حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَرَّمَ یَوْمَ خَیْبَرَ کُلَّ ذِی نَابٍ مِنَ السِّبَاعِ۔ (ابوداؤد 3799۔ ترمذی 1479),,,20227,,
20228,"حَدَّثَنَا ہُشَیْمُ بْنُ أَبِی بِشْرٍ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : نَہَی عَنْ کُلِّ ذِی نَابٍ مِنَ السِّبَاعِ ، وَعَنْ کُلِّ ذِی مِخْلَبٍ مِنَ الطَّیْرِ۔",,,20228,,
20229,"حَدَّثَنَا ہَاشِمُ بْنُ الْقَاسِمِ ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ جَابِرٍ ، قَالَ: حرَّمَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ خَیْبَرَ کُلَّ ذِی نَابٍ مِنَ السِّبَاعِ وَکُلَّ ذِی مِخْلَبٍ مِنَ الطَّیْرِ۔",,,20229,,
20230,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ أَبِی عَوَانَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، عَنْ کُلِّ ذِی نَابٍ مِنَ السِّبَاعِ ، وَعَنْ کُلِّ ذِی مِخْلَبٍ مِنَ الطَّیْرِ۔",,,20230,,
20231,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانُوا یَکْرَہُونَ کُلَّ ذِی مِخْلَبٍ مِنَ الطَّیْرِ ، وَکُلَّ سَبْعٍ ذِی نَابٍ۔",,,20231,,
20232,"حَدَّثَنَا أَبُو الأَحْوَص ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ مِنَ الطَّیْرِ مَا أَکَلَ الْجِیَفَ۔",,,20232,,
20233,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کُلُّ شَیْئٍ لَقَطَ مِنَ الطَّیْرِ فَلَیْسَ بِہِ بَأْسٌ ، وَکُلُّ شَیْئٍ نَہَشَ بِمِنْقَارِہِ ، أَوْ أَخَذَ بِمِخْلَبِہِ ، فَکَانَ یَکْرَہُ لَحْمَہُ ، وَکَانَ یَکْرَہُ لَحْمَ الصُّرَدِ۔",,,20233,,
20234,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، قَالَ : قُلْتُ لِمُجَاہِدٍ : إنَّ الْیَہُودَ لاَ یَأْکُلُونَ مِنَ الطَّیْرِ إِلاَّ مَا لَقَطَ ، قَالَ : فَأَعْجَبَ ذَلِکَ مُجَاہِدًا۔",,,20234,,
20235,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَتْ عَائِشَۃُ إذَا سُئِلَتْ عَنْ کُلِّ ذِی نَابٍ مِنَ السِّبَاعِ ، وَکُلِّ ذِی مِخْلَبٍ مِنَ الطَّیْرِ ، قَالَتْ : {لاَ أَجِدُ فِیمَا أُوحِیَ إلَیَّ مُحَرَّمًا} ، ثُمَّ تَقُولُ : إنَّ الْبُرمَۃَ لَیَکُونُ فِیہَا الصُّفْرَۃُ۔",,,20235,,
20236,حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْمَرٍ ، عَنْ مُوسَی ، عَنْ أَبِی جَعْفَرٍ ، أَنَّہُ کَرِہَ أَکْلَ سِبَاعِ الطَّیْرِ وَسِبَاعِ الْوَحْشِ۔,,,20236,,
20237,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : مَنْ یَأْکُلُ الْغُرَابَ وَقَدْ سَمَّاہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَاسِقًا ؟۔ (ابن ماجہ 3248۔ بیہقی 317)",,,20237,,
20238,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، قَالَ : سَمِعْتُ عِکْرِمَۃَ وَسُئِلَ عَنْ لَحْمِ الْغُرَابِ وَالْحُدَیَّا ، فَقَالَ : دَجَاجَۃٌ سَمِینَۃٌ۔",,,20238,,
20239,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ سُئِلَ عَنْ لَحْمِ الْغُرَابِ وَالْحُدَیَّۃِ ، فَقَالَ : أَحَلَّ اللَّہُ حَلاَلاً وَحَرَّمَ حَرَامًا وَسَکَتَ عَنْ أَشْیَائَ فَمَا سَکَتَ عَنْہُ فَہُوَ عَفْوٌ عَنْہُ۔",,,20239,,
20240,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,20240,,
20241,حَدَّثَنَا عَبَّادٌ ، عَنْ حَجَّاجٍ ، أَنَّہُ کَانَ لاَ یَرَی بِالطَّیْرِ کُلِّہِ بَأْسًا إِلاَّ أَنْ تَقْذَرَ مِنْہُ شَیْئًا۔,,,20241,,
20242,حَدَّثَنَا عَبَّادٌ ، عَنْ حَجَّاجٍ عَمَّنْ سَمِعَ إبْرَاہِیمَ مِثْلَہُ۔,,,20242,,
20243,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی مَکِینٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : مَا لَمْ یُحَرَّمْ عَلَیْک فی القرآن فَہُوَ لَکَ حَلاَلٌ۔",,,20243,,
20244,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : لاَ بَأْسَ بِأَکْلِ الْیَرْبُوعِ۔",,,20244,,
20245,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,20245,,
20246,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ بِالْیَرْبُوعِ۔",,,20246,,
20247,حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ دَاوُدَ بْنِ أَبِی الْفُرَاتِ ، عَنْ إبْرَاہِیمَ الصَّائِغِ ، عَنْ عَطَائٍ ، أَنَّہُ قَالَ فِی الذِّئْبِ لاَ یُؤْکَلُ وَالْیَرْبُوعُ یُؤْکَلُ۔,,,20247,,
20248,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,20248,,
20249,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ أَبِی الْوَسِیمِ ، قَالَ : سَأَلَتْ حَسَنَ بْنَ حُسَیْنِ بْنِ عَلِیٍّ ، عَنِ الْیَرْبُوعِ ، قَالَ: فَأْرُ الْبَرِّیَّۃِ۔",,,20249,,
20250,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا ، عَنْ أَکْلِ الْیَرْبُوعِ فَکَرِہَاہُ۔",,,20250,,
20251,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جُبَیْرِ بْنِ شَیْبَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أُمِّ شَرِیکٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَہَا بِقَتْلِ الأَوْزَاغِ۔ (بخاری 3307۔ مسلم 142),,,20251,,
20252,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّہُ أَمَرَ بِقَتْلِہِ ، یَعْنِی الْوَزَغَ۔,,,20252,,
20253,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ أَبِی جَعْفَرٍ الْخِطْمِیِّ ، قَالَ : حدَّثَنِی خَالِی عَبْدُ الرَّحْمَنِ ، عنْ جَدِّی عُقْبَۃَ بْنِ فَاکِہٍ ، قَالَ : أَتَیْتُ زَیْدَ بْنَ ثَابِتٍ نِصْفَ النَّہَارِ فَاسْتَأْذَنْت عَلَیْہِ فَخَرَجَ مُتَّزِرًا ، بِیَدِہِ عَصَی فَقُلْت : أَیْنَ کُنْت فِی ہَذِہِ السَّاعَۃِ ؟ فَقَالَ : کُنْت أَتْبَعُ ہَذِہِ الدَّابَّۃَ ، یَکْتُبُ اللَّہُ بِقَتْلِہَا الْحَسَنَۃَ وَیَمْحُو بِہِ السَّیِّئَۃَ فَاقْتُلْہَا ، وَہِیَ الْوَزَغُ۔ (ابن ماجہ 1316۔ احمد 4/78)",,,20253,,
20254,حَدَّثَنَا وَکِیعٌ ، عَنْ حَنْظَلَۃَ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ أَنَّہَا کَانَتْ تَقْتُلُ الأَوْزَاغَ۔,,,20254,,
20255,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ أَنَّہَا کَانَتْ تَفْعَلُہُ۔,,,20255,,
20256,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی عَمْرَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : مَنْ قَتَلَ وَزَغَۃً کَانَتْ لَہُ بِہَا صَدَقَۃٌ۔",,,20256,,
20257,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَطَائٍ ، قَالَ : مَنْ قَتَلَ وَزَغَۃً کُفِّرَ عَنْہُ سَبْعَ خَطِیئَاتٍ۔",,,20257,,
20258,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، حَدَّثَنَا جَرِیرُ بْنُ حَازِمٍ ، عَنْ نَافِعٍ ، عَنْ سَائِبَۃٍ مَوْلاَۃٍ لِفَاکِہِ بْنِ الْمُغِیرَۃِ أَنَّہَا دَخَلَتْ عَلَی عَائِشَۃَ فَرَأَتْ فِی بَیْتِہَا رُمْحًا مَوْضُوعًا ، فَقَالَتْ : یَا أُمَّ الْمُؤْمِنِینَ ، مَا تَصْنَعِینَ بِہَذَا ؟ قَالَتْ : نَقْتُلُ بِہَا ہَذِہِ الأَوْزَاغَ ، فَإِنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَخْبَرَنَا أَنَّ إبْرَاہِیمَ خَلِیلَ اللہِ لَمَّا أُلْقِیَ فِی النَّارِ لَمْ تَکُنْ دَابَّۃٌ فِی الأَرْضِ إِلاَّ أَطْفَأَتِ النَّارَ عَنْہُ غَیْرَ الْوَزَغِ ، فَأَنَّہُ کَانَ یَنْفُخُ عَلَیْہِ ، فَأَمَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِقَتْلِہِ۔ (ابن ماجہ 3231۔ احمد 6/109)",,,20258,,
20259,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ مُوسَی بْنِ یَعْقُوبَ ، قَالَ أَخْبَرَتْنِی عَمَّتِی قُرَیْبَۃُ بِنْتُ عَبْدِ اللہِ بْنِ وَہْبٍ ، قَالَتْ : کَانَتْ أُمُّ سَلَمَۃَ تَأْمُرُ بِقَتْلِ الْوَزَغِ۔",,,20259,,
20260,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : اقْتُلُوا الْوَزَغَ فِی الْحِلِّ وَالْحَرَمِ۔",,,20260,,
20261,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ أبی الْعُمیس ، عن أبیہ ، قَالَ : کانت لعائشۃ قناۃ تقتل بہا الوزغ۔",,,20261,,
20262,حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، أَنَّہُ کَانَ یَأْمُرُ بِقَتْلِ الْوَزَغِ۔,,,20262,,
20263,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَبْدِ اللہِ ، قَالَ : کُنَّا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی غَارٍ وَقَدْ أُنْزِلَتْ عَلَیْہِ : {وَالْمُرْسَلاَتِ عُرْفًا} قَالَ : فَنَحْنُ نَأْخُذُہَا مِنْ فِیہِ رَطْبَۃً إذْ دَخَلَتْ عَلَیْنَا حَیَّۃٌ ، فَقَالَ لَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اقْتُلُوہَا ، فَابْتَدَرْنَا لَہَا لِنَقْتُلَہَا فَسَبَقَتْنَا بِنَفْسہَا ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : وَقَاہَا اللَّہُ شَرَّکُمْ کَمَا وَقَاکُمْ شَرَّہَا۔ \n\n(بخاری 1830۔ مسلم 137)",,,20263,,
20264,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ عُمَرُ : اقْتُلُوا الْحَیَّاتِ کُلَّہَا عَلَی کُلِّ حَالٍ۔",,,20264,,
20265,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ اللہِ بْنِ عُبَیْد بْنِ عُمَیْرٍ ، عَنْ أبِی الطُّفَیْلِ ، عَنْ عَلِیِّ بْنِ أَبِی طَالِبٍ ، أَنَّہُ کَانَ یَأْمُرُ بِقَتْلِ الْحَیَّاتِ ذِی الطُّفْیتین۔,,,20265,,
20266,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ أَبِی صَالِحٍ ، قَالَ عُمَرُ : أَصْلِحُوا مَثَاوِیکُمْ وَأَخِیفُوا الْہَوَامَّ قَبْلَ أَنْ تُخِیفَکُمْ ، فَإِنَّہُ لاَ یَظْہَرُ لَکُمْ مِنْہُنَّ مُسْلِمٌ۔",,,20266,,
20267,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ قَتَلَ حَیَّۃً قَتَلَ کَافِرًا۔",,,20267,,
20268,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی قَیْسٍ ، عَنْ عَلْقَمَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : اقْتُلُوا الْحَیَّاتِ کُلَّہَا ، إِلاَّ الَّذِی کَأَنَّہُ مُلمُولٌ ، فَإِنَّہُ جِنُّہَا۔",,,20268,,
20269,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ کَانَ یَقْتُلُ الجان ، وَیَأْمُرُ بِقَتْلِہَا وَیَقُولُ : الْجَانُّ مِسخُ الْجِنِّ کَمَا مُسِخَتِ الْقِرَدَۃُ مِنْ بَنِی إسْرَائِیلَ۔",,,20269,,
20270,"حَدَّثَنَا وَکِیعٌ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ، عَنْ عِکْرِمَۃَ، قَالَ: کَانَ ابْنُ عُمَرَ یَأْمُرُ بِقَتْلِ الْحَیَّاتِ، ثُمَّ أُمِرَ بِنَبْذِہِنَّ۔",,,20270,,
20271,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، قَالَ : کَانَ الْحَسَنُ وَمُحَمَّدٌ یَأْمُرَانِ بِقَتْلِ الْحَیَّاتِ إِلاَّ الْجَانَّ الَّذِی کَأَنَّہُ قَصَبَۃُ فِضَّۃٍ۔",,,20271,,
20272,"حَدَّثَنَا ابْنُ فضیل ، عن مغیرۃ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَأْمَرُونُ بِقَتْلِ الْحَیَّاتِ إِلاَّ الْجَانَّ الَّذِی کَأَنَّہُ قَضِیبُ فِضَّۃٍ۔",,,20272,,
20273,"حَدَّثَنَا خلف ابْنُ خَلِیفَۃَ ، عَنِ أَبِی طَلْحَۃَ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : سَأَلْتُہ عَنْ قَتْلِ الْحَیَّاتِ ؟ فَقَالَ : وَدِدْت أَنِّی وَجَدْت مَنْ یَتَّبِعُہُنَّ فَیَقْتُلُہُنَّ ، وَنُعْطِیہ عَنْ ذَلِکَ أَجْرًا۔",,,20273,,
20274,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی قَیْسٍ ، عَنْ عَلْقَمَۃَ ، قَالَ : مَا یَضُرُّ أَحَدَکُمْ قَتَلَ حَیَّۃً ، أَوْ قَتَلَ کَافِرًا إِلاَّ الَّذِی کَأَنَّہُ مَیَلٌ ، فَإِنَّہُ جِنُّہَا۔",,,20274,,
20275,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : أَمَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِقَتْلِ ذِی الطفیتین ، فَإِنَّہُ یَلْتمس الْبَصَرَ ، وَیُصِیبُ الْحَمْلَ یَعْنِی حَیَّۃً خَبِیثَۃً۔ (بخاری 3308۔ مسلم 127)",,,20275,,
20276,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ ثَابِتٍ الْبُنَانِیِّ ، قَالَ : قَالَ عَبْدُ الرَّحْمَنِ بْنُ أَبِی لَیْلَی : قَالَ أَبُو لَیْلَی : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَسَأَلَہُ عَنِ الْحَیَّاتِ فِی الْبُیُوتِ ؟ فَقَالَ : إِنْ رَأَیْتُمُوہُنَّ فِی مَسَاکِنِکُمْ ، فَقُولُوا لَہُنَّ : نَنْشُدُکُمْ بِالْعَہْدِ الَّذِی أَخَذَ عَلَیْکُمْ نُوحٌ ، نَنْشُدُکُمْ بِالْعَہْدِ الَّذِی أَخَذَ عَلَیْکُمْ سُلَیْمَانُ بْنُ دَاوُد ، أَنْ لاَ تُؤْذُونَا ، فَإِنْ رَأَیْتُمْ مِنْہُنَّ شَیْئًا فَاقْتُلُوہُنَّ۔ (ترمذی 1485۔ ابوداؤد 5218)",,,20276,,
20277,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ دَاوُدَ بْنِ أَبِی الْفُرَاتِ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ ، عَنْ أَبِی الأَعْیَنِ الْعَبْدِیِّ ، عَنْ أَبِی الأَحْوَص ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ قَتَلَ حَیَّۃً قَتَلَ کَافِرًا۔\n\n(احمد 394۔ بزار 1847)",,,20277,,
20278,"حَدَّثَنَا أَبُو دَاوُدَ الْحَفْرِیُّ عُمَرُ بْنُ سَعد ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَبْدِ اللہِ ، قَالَ : مَنْ قَتَلَ حَیَّۃً قَتَلَ کَافِرًا۔",,,20278,,
20279,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : مَنْ قَتَلَ حَیَّۃً فَقَدْ قَتَلَ عَدُوًّا کَافِرًا۔",,,20279,,
20280,حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ عَائِشَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِقَتْلِ الْکِلاَبِ۔ (ابن ماجہ 3651۔ احمد 6/143),,,20280,,
20281,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ أَبَانَ بْنِ صَالِحٍ ، عَنِ الْقَعْقَاعِ بن حَکِیمٍ ، عَنْ سَلْمَی أُمِّ رَافِعٍ ، عَنْ أَبِی رَافِعٍ ، قَالَ : أَمَرَنِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ أَصْبَحَ ، فَلَمْ أَدَعْ کَلْبًا إِلاَّ قَتَلْتہ۔\n\n(طحاوی 53۔ احمد 6/391)",,,20281,,
20282,حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ سُفْیَانَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِقَتْلِ الْکِلاَبِ ، حَتَّی قَتَلْنَا کَلْبَ امْرَأَۃٍ جَائَتْ بِہِ مِنَ الْبَادِیَۃِ۔ (بخاری 3323۔ مسلم 1200),,,20282,,
20283,"حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی التَّیَّاحِ ، قَالَ : سَمِعْتُ مُطَرِّفًا یُحَدِّثُ عَنِ ابْنِ مُغَفَّلٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِقَتْلِ الْکِلاَبِ ، ثُمَّ قَالَ : مَا لَہُمْ وَلِلْکِلاَبِ ، ثُمَّ رَخَّصَ فِی کَلْبِ الصَّیْدِ۔\n\n(مسلم 93۔ ابوداؤد 75)",,,20283,,
20284,"حَدَّثَنَا شَبَابَۃُ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الْحَارِثِ ، عَنْ کُرَیْبٍ ، عَنْ أُسَامَۃَ ، قَالَ : دَخَلْتُ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وعلیہ الْکَآبَۃَ فَقُلْتُ : مَا لَکَ یَا رَسُولَ اللہِ ؟ قَالَ : إنَّ جِبْرِیلَ عَلَیْہِ السَّلاَمُ وَعَدَنِی أَنْ یَأْتِیَنِی فلم یأتینی مُنْذُ ثَلاَثٍ ، قَالَ : فأجاز کَلْبٌ ، قَالَ أُسَامَۃُ : فَوَضَعْت یَدِی عَلَی رَأْسِی وَصِحْت ، فَجَعَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَا لَکَ یَا أُسَامَۃَ ؟ فَقُلْت : أجاز کَلْبٌ ، فَأَمَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِقَتْلِہِ فَقُتِلَ۔ (مسلم 82۔ طبرانی 387)",,,20284,,
20285,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّ عُثْمَانَ أَمَرَ بِقَتْلِ الْکِلاَبِ وَذَبْحِ الْحَمَامِ۔,,,20285,,
20286,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِقَتْلِ الْکِلاَبِ حَتَّی إِنَّ الْمَرْأَۃَ کَانَتْ تَدْخُلُ بِالْکَلْبِ فَیُقْتَلُ قَبْلَ أَنْ تَخْرُجَ ، قَالَ : لَوْلا أَنَّ الْکِلاَبَ أُمَّۃٌ مِنَ الأُمَمِ لأَمَرْتُ بِقَتْلِہَا فَاقْتُلُوا مِنْہَا کُلَّ أَسْوَدَ بَہِیمٍ الَّذِی بَیْنَ عَیْنَیْہِ نُقْطَتَانِ ، فَإِنَّہُ شَیْطَانٌ۔\n\n(مسلم 47۔ ابوداؤد 2840)",,,20286,,
20287,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِقَتْلِ الْکِلاَبِ۔ (مسلم 44۔ احمد 2/113),,,20287,,
20288,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّ علَی حِمَارٍ یُوسَمُ فِی وَجْہِہِ ، فَقَالَ : أَلَمْ أَنْہَ عَنْ ہَذَا ؟ لَعَنَ اللَّہُ مَنْ فَعَلَ ہَذَا۔ (مسلم 106۔ ابوداؤد 2557)",,,20288,,
20289,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُضْرَبَ وَجْہُ الدَّابَّۃِ۔",,,20289,,
20290,حَدَّثَنَا وَکِیعٌ ، عَنْ حَنْظَلَۃَ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، أنہ کرہ أن تُعْلَمَ الصورۃ۔,,,20290,,
20291,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَنْظَلَۃَ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ تُضْرَبَ الصُّورَۃُ۔ (بخاری 5541۔ احمد 2/118)",,,20291,,
20292,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطِیَّۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : رَآنِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی حِمَارٍ مَوْسُومٍ بَیْن عَیْنَیْہِ فَکَرِہَ ذَلِکَ ، وَقَالَ فِیہِ قَوْلاً شَدِیدًا۔",,,20292,,
20293,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الضَّرْبِ فِی الْوَجْہِ ، وَعَنِ الْوَسْمِ فِی الْوَجْہِ۔ (مسلم 106)",,,20293,,
20294,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عُمَرُ : لاَ یُلْطَمُ الْوَجْہُ ، وَلاَ یُوسَمُ۔",,,20294,,
20295,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : نُہِی عَنْ وَسْمِہَا فِی وَجْہِہَا۔",,,20295,,
20296,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُکْرَہُ أَنْ تُوسَمَ الْعَجْمَائُ عَلَی خَدِّہَا ، أَوْ تُلْطَمَ ، أَوْ تُجَرَّ بِرِجْلِہَا إلَی مَذْبَحِہَا۔",,,20296,,
20297,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِکُلِّ شَیْئٍ حُرْمَۃٌ ، وَحُرْمَۃُ الْبَہَائِمِ وُجُوہُہَا۔",,,20297,,
20298,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، حَدَّثَنَا عُثْمَانَ بْنُ حَکِیمٍ قَالَ : أَخْبَرَنِی عَبْدُ الرَّحْمَنِ بْنُ عَبْدِ الْعَزِیزِ ، عَنْ یَعْلَی بْنِ مُرَّۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لِرَجُلٍ : ہَبْہُ لِی ، أَوَ قَالَ بِعْنِیہِ یَعْنِی جَمَلاً ، قَالَ : ہُوَ لَکَ یَا رَسُولَ اللہِ ، فَوَسَمَہُ سِمَۃَ الصَّدَقَۃِ ، ثُمَّ بَعَثَ بِہِ۔ (احمد 4/173۔ طبرانی 694)",,,20298,,
20299,"حَدَّثَنَا شَرِیکٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : لاَ بَأْسَ فِی السِّمَۃِ فِی مُؤَخَّرِ الأُذُنِ۔",,,20299,,
20300,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عن یحیی بن سعید، عن سعید بن المسیب، قَالَ: لاَ بأس بالسمۃ فی الأذن۔",,,20300,,
20301,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ ، قَالَ : مَرَّ ابْنُ عُمَرَ بِأَبِی وَہُوَ یَسِمُ وَسْمَ قُدَامَۃَ بْنِ مَظْعُونٍ ، فَقَالَ : ابْنُ عُمَرَ : لاَ تُلْحِمْ لاَ تُلْحِمْ۔",,,20301,,
20302,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ ہِشَامِ بْنِ زَیْدٍ ، قَالَ : سَمِعْتُ أَنَسَ بْنَ مَالِکٍ یَقُولُ : رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ فِی الْمِرْبَدِ یَسِمُ غَنَمًا لَہُ ، أَحْسَبُہُ قَالَ : فِی آذَانہَا۔\n\n(بخاری 5542۔ مسلم 109)",,,20302,,
20303,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إِسْحَاقَ بْنِ سُلَیْمَانَ ، عَنْ أَبِیہِ ، قَالَ: سَأَلْتُ الشَّعْبِیَّ، عَنْ وَسْمِ الْغَنَمِ فِی آذَانِہَا، فَلَمْ یَرَ بِہِ بَأْسًا۔",,,20303,,
20304,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، قَالَ : ذَہَبْت مَعَ ابْنِ عُمَرَ إلَی بَنِی مُعَاوِیَۃَ فَنَبَحَتْ عَلَیْنَا کِلاَبٌ ، فَقَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنِ اقْتَنَی کَلْبًا إِلاَّ کَلْبَ ضَارِیَۃٍ ، أَوْ مَاشِیَۃٍ نَقَصَ مِنْ أَجْرِہِ کُلَّ یَوْمٍ قِیرَاطَانِ۔ (بخاری 5480۔ مسلم 52)",,,20304,,
20305,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ اقْتَنَی کَلْبًا ، إِلاَّ کَلْبَ صَیْدٍ ، أَوْ مَاشِیَۃٍ ، نَقَصَ مِنْ أَجْرِہِ کُلَّ یَوْمٍ قِیرَاطَانِ۔ (مسلم 51۔ احمد 8)",,,20305,,
20306,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَنْظَلَۃَ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنِ اقْتَنَی کَلْبًا إِلاَّ کَلْبَ صَیْدٍ ، أَوْ مَاشِیَۃٍ نَقَصَ مِنْ أَجْرِہِ کُلَّ یَوْمٍ قِیرَاطَانِ ، قَالَ : وَقَالَ سَالِمٌ : وَقَالَ أَبُو ہُرَیْرَۃَ: أَوْ کَلْبَ حَرْثٍ۔ (بخاری 5481۔ مسلم 54)",,,20306,,
20307,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ زَادَ فِیہِ : أَوْ کَلْبَ مَخَافَۃٍ۔",,,20307,,
20308,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَبْدِ اللہِ ، قَالَ : مَنِ اقْتَنَی کَلْبًا إِلاَّ کَلْبَ قَنْصٍ ، أَوْ مَاشِیَۃٍ نَقَصَ مِنْ أَجْرِہِ کُلَّ یَوْمٍ قِیرَاطان۔ (ابو یعلی 5025)",,,20308,,
20309,"حَدَّثَنَا وَکِیعٌ ، عَنْ عمر بن الولید الشَّنِّی ، عن عکرمۃ قَالَ : إلا کلب زرع ، أو کلب قنص ، أو کلب ماشیۃ ، أو کلب مخافۃ۔",,,20309,,
20310,"حَدَّثَنَا عبد الأعلی ، عن برد ، عن مکحول ، قَالَ : من اقتنی کلبا لیس بکلب صید أو ماشیۃ ؛ نقص من أجر أہل بیتہ کل یوم قیراط۔",,,20310,,
20311,"حَدَّثَنَا عَفَّانُ ، حَدَّثَنَا سُلَیْمُ بْنُ حَیَّانَ ، قَالَ : سَمِعْتُ أَبِی یُحَدِّثُ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنِ اتَّخَذَ کَلْبًا لَیْسَ بِکَلْبِ الزَّرْعِ ، وَلاَ صَیْدٍ ، وَلاَ مَاشِیَۃٍ فإنہ ینْقُصُ مِنْ أَجْرِہِ کُلَّ یَوْمٍ قِیرَاطٌ۔ (بخاری 2322۔ مسلم 58)",,,20311,,
20312,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ یَزِیدَ بْنِ خُصَیْفَۃَ ، عَنِ السَّائِبِ بْنِ یَزِیدَ ، عَنْ سُفْیَانَ بْنِ أَبِی زُہَیْرٍ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنِ اقْتَنَی کَلْبًا لاَ یُغْنِی عَنْہُ زَرْعا ، وَلاَ ضَرْعا نَقَصَ مِنْ أَجْرِہِ کُلَّ یَوْمٍ قِیرَاطٌ۔ (بخاری 3325۔ مسلم 61)",,,20312,,
20313,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنِ اقْتَنَی کَلْبًا نَقَصَ مِنْ أَجْرِہِ کُلَّ یَوْمٍ قِیرَاطٌ۔ (مسلم 50۔ ترمذی 1487)",,,20313,,
20314,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : رُخِّصَ فِی الْکِلاَبِ فِی بَیْتِ الْمُعْوِرِ۔",,,20314,,
20315,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ أَبِی یَزِیدَ ، عَنْ أَبِی الفُضَیل ، قَالَ : کَانَ أَنَسٌ یَأْتِینَا وَمَعَہُ کَلْبٌ لَہُ ،فقلنا لہ ، فَقَالَ : إِنَّہُ یَحْرُسُنَا۔",,,20315,,
20316,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَتَّخِذُ کَلْبًا یَحْرُسُ دَارِہِ ، فَقَالَ : لاَ خَیْرَ فِیہِ إِلاَّ أَنْ یَکُونَ کَلْبَ صَیْدٍ۔",,,20316,,
20317,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ أَبِی طَلْحَۃَ ، عنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تَدْخُلُ الْمَلاَئِکَۃُ بَیْتًا فِیہِ صُورَۃٌ ، وَلاَ کَلْبٌ۔ (بخاری 3322۔ مسلم 1665)",,,20317,,
20318,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حُسَیْنِ بْنِ وَاقِدٍ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَدْخُلُ الْمَلاَئِکَۃُ بَیْتًا فِیہِ کَلْبٌ۔ (احمد 5/353)",,,20318,,
20319,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : أَخْبَرَنَا اللَّیْثُ بْنُ سَعْدٍ ، قَالَ : أَخْبَرَنِی بُکَیْر بْنُ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنْ بُسْرِ بْنِ سَعِیدٍ ، عَنْ زَیْدِ بْنِ خَالِدٍ ، عَنْ أَبِی طَلْحَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تَدْخُلُ الْمَلاَئِکَۃُ بَیْتًا فِیہِ کَلْبٌ ، وَلاَ صُورَۃٌ۔ (بخاری 5958۔ مسلم 85)",,,20319,,
20320,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَلِیِّ بْنِ مُدْرِکٍ ، عَنْ أَبِی زُرْعَۃَ ، عَنْ عَبْدِ اللہِ بْنِ نُجَی ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّہُ قَالَ : لاَ تَدْخُلُ الْمَلاَئِکَۃُ بَیْتًا فِیہِ کَلْبٌ ، وَلاَ صُورَۃٌ۔\n\n(ابوداؤد 229۔ احمد 1/83)",,,20320,,
20321,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُکْرَہُ أَنْ یَرْمِی طَیْرَ جارہ ، وَإِذَا رَمَاہُ فَعَلَیْہِ ثَمَنُہُ۔",,,20321,,
20322,"حَدَّثَنَا وَکِیعٌ، عَنْ فُضَیْلِ بْنِ غَزْوَانَ، قَالَ: سَمِعْتُ رَجُلاً یَسْأَلُ نَافِعًا عَنْ صَیْدِ حَمَامِ الْمَدِینَۃِ فَکَرِہَہَا۔",,,20322,,
20323,حَدَّثَنَا أَبُو أُسَامَۃَ ، أَوْ حُدِّثْتُ عَنْہُ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ ، عَنِ الْحَسَنِ ، أَنَّہُ کَرِہَ صَیْدَ حَمَامِ المدینۃ وَالْأَمْصَارِ۔,,,20323,,
20324,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَرِہَ أَنْ یُحَالَ الرَّجُلُ یَعْنِی : یَأْذَنَ ہَذَا لِہَذَا فِی حَمَامِہِ وَہَذَا لِہَذَا فِی حَمَامِہِ۔",,,20324,,
20325,حَدَّثَنَا وَکِیعٌ ، عَنْ فُضَیْلٍ ، عَنْ نَافِعٍ ، أَنَّہُ کَرِہَ صَیْدَ حَمَامِ الأَمْصَارِ۔,,,20325,,
20326,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، قَالَ : سَأَلْتُ ابْنَ أَبِی لَیْلَی ، عَنْ رَجُلٍ أَصَابَ صَیْدًا بِالْمَدِینَۃِ ، فَقَالَ : یُحْکَمُ عَلَیْہِ۔",,,20326,,
