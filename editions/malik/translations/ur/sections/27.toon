{"hadithnumber": "1074", "text": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ تم میں سے کوئی بھی اپنے بھائی کے"}
{"hadithnumber": "1075", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ تم میں سے کوئی بھی"}
{"hadithnumber": "1076", "text": "عبدالرحمن بن قاسم رحمہ اللہ اپنے والد ( قاسم بن محمد بن ابی بکر رحمہ اللہ ) سے روایت کرتے ہیں کہ وہ"}
{"hadithnumber": "1077", "text": "حضرت عبداللہ بن عباس رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ شوہر دیدہ عورت اپنے"}
{"hadithnumber": "1078", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے کہ حضرت عمر بن خطاب رضی اللہ عنہ نے فرمایا : عورت کا نکاح نہ کیا"}
{"hadithnumber": "1079", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک قاسم بن محمد رحمہ اللہ اور سالم بن عبداللہ رحمہ اللہ اپ"}
{"hadithnumber": "1080", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ قاسم بن محمد رحمہ اللہ ، سالم بن عبداللہ رحمہ اللہ اور سلیمان"}
{"hadithnumber": "1081", "text": "حضرت سہل بن سعد ساعدی رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ کے پاس ایک عورت آئی اور کہنے لگی"}
{"hadithnumber": "1082", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے کہ حضرت عمر بن خطاب رضی اللہ عنہ نے فرمایا : جو کوئی مرد کسی ایسی"}
{"hadithnumber": "1083", "text": "نافع رحمہ اللہ سے روایت ہے کہ بے شک ( حضرت عمر رضی اللہ عنہ کے لخت جگر ) عبیداللہ بن عمر رضی اللہ عن"}
{"hadithnumber": "1084", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عمر بن عبدالعزیز رحمہ اللہ نے اپنی خلافت کے دوران"}
{"hadithnumber": "1085", "text": "سعید بن مسیب رحمہ اللہ سے روایت ہے کہ بے شک حضرت عمر بن خطاب رضی اللہ عنہ نے عورت کے متعلق ، جب کوئی"}
{"hadithnumber": "1086", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک سعید بن مسیب رحمہ اللہ فرمایا کرتے تھے کہ جب مرد ، عورت"}
{"hadithnumber": "1087", "text": "عبدالملک بن ابوبکر بن عبدالرحمن بن حارث بن ہشام مخزومی رحمہ اللہ اپنے والد ( ابوبکر بن عبدالرحمن ) س"}
{"hadithnumber": "1088", "text": "حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے ، وہ فرمایا کرتے تھے کہ کنواری کے لیے سات دن اور شوہر دیدہ"}
{"hadithnumber": "1089", "text": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ سعید بن مسیب رحمہ اللہ سے اس عورت کے متعلق سوال کیا گیا جو اپ"}
