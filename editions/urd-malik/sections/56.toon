hadiths[28]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
1811,حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ مشرق کی جانب ( عراق ) سے دو شخص ( مدینہ منو,,,1811,,
1812,"امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عیسی ابن مریم علیہم السلام فرمایا کرتے تھے : ذکر ا",,,1812,,
1813,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ عشاء کے بعد اپنے,,,1813,,
1814,مطلب بن عبداللہ بن حنطب مخزومی رحمہ اللہ سے روایت ہے کہ ایک آدمی نے رسول اللہ ﷺ سے سوال کیا کہ غیبت ,,,1814,,
1815,"عطاء بن یسار رحمہ اللہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ جس شخص کو اللہ تعالیٰ دو چیزوں",,,1815,,
1816,زید بن اسلم رحمہ اللہ اپنے والد ( اسلم رحمہ اللہ جو حضرت عمر رضی اللہ عنہ کے آزاد کردہ غلام تھے ) سے,,,1816,,
1817,"عبداللہ بن دینار رحمہ اللہ سے روایت ہے ، کہتے ہیں : میں اور حضرت عبداللہ بن عمر رضی اللہ عنہما ، حضر",,,1817,,
1818,"حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ جب ( کسی جگہ ) تی",,,1818,,
1819,"صفوان بن سلیم رحمہ اللہ سے روایت ہے کہ ایک آدمی نے رسول اللہ ﷺ سے عرض کیا : کیا میں اپنی بیوی سے جھو",,,1819,,
1820,"امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت عبداللہ بن مسعود رضی اللہ عنہ فرمایا کرتے تھے :’’ سچ کو ",,,1820,,
1821,"امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ لقمان حکیم سے کہا گیا : آپ کو اس مقام تک کس چیز نے پہنچایا ہے",,,1821,,
1822,"امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت عبداللہ بن مسعود رضی اللہ عنہ فرمایا کرتے تھے : آدمی مسل",,,1822,,
1823,"صفوان بن سلیم رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ رسول اللہ ﷺ سے کہا گیا : کیا مومن بزدل ہو سکتا ہے ",,,1823,,
1824,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ یقیناً اللہ تعالیٰ تمھارے",,,1824,,
1825,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ یقیناً رسول اللہ ﷺ نے فرمایا :’’ بدترین لوگوں میں سے دو چہ",,,1825,,
1826,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک سیدہ ام سلمہ رضی اللہ عنہا زوجہ پیغمبر ﷺ نے عرض کیا کہ ,,,1826,,
1827,"حضرت عمر بن عبدالعزیز رحمہ اللہ سے روایت ہے ، فرماتے ہیں : یہ تو کہا جاتا ہے کہ بے شک اللہ تبارک و ت",,,1827,,
1828,حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ میں نے حضرت عمر بن خطاب رضی اللہ عنہ کو سنا ,,,1828,,
1829,"قاسم بن محمد رحمہ اللہ ( بن ابی بکر صدیق رضی اللہ عنہ ) سے روایت ہے ، وہ فرمایا کرتے تھے : میں نے لو",,,1829,,
1830,عامر بن عبداللہ بن زبیر رحمہ اللہ سے روایت ہے کہ جب وہ کڑک کی آواز سنتے تو گفتگو چھوڑ دیتے اور فرمات,,,1830,,
1831,سیدہ عائشہ ام المومنین رضی اللہ عنہا سے روایت ہے کہ بلاشبہ نبی کریم ﷺ کی ازواج مطہرات نے جس وقت کہ ر,,,1831,,
1832,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ میرے ورثاء دینار تقسیم نہ",,,1832,,
1833,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ بنو آدم کی وہ آگ جسے وہ ج",,,1833,,
1834,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ، انھوں نے فرمایا :’’ کیا تم اس ( جہنم کی آگ ) کو سرخ سمجھتے ",,,1834,,
1835,"ابوالحباب سعید بن یسار رحمہ اللہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ جس شخص نے پاکیزہ ( ",,,1835,,
1836,"حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے ، کہتے ہیں : ( ان کے سوتیلے والد ) حضرت ابوطلحہ رضی اللہ ع",,,1836,,
1837,"زید بن اسلم رحمہ اللہ سے روایت ہے کہ بلاشبہ رسول اللہ ﷺ نے فرمایا :’’ سائل ( مانگنے والے ) کو دیا کر",,,1837,,
1838,عمرو بن معاذ ( بن سعد بن معاذ ) اشہلی انصاری رحمہ اللہ نے اپنی دادی ( حواء بنت یزید بن سکن رحمۃ اللہ,,,1838,,
