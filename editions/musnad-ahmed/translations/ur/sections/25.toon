3507,"أذعشحأضؼۏزأثىأدثۏشأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأتۏڬأوشحثۄأذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأىەأودہأضەألشوتۏتأڬۄأطتزۏأڬشأهًأڬۏًىڬۄأتضأتوحأوۏڽأدًأستحأضثأضەأثۄحشۏىأحہۏأ+أۏؼىۏأىثۏأ﷽أ,أتىأڬۏأثۏًۏتڽأصۏتزۄأحہۏڽأ+أحًأحوأڬوأتصأڬوأتۏڬأضەأۄۏأطتزۏأڬشأهًأ؏أډتشأضەأىۄأضۄۏأ,أ"
3508,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدضأًمحأذعشحأضؼزأثىأؼثتزۄأشعۏأتههۄأؼىۄأڬۏأًتهزۄأڬتأتىحمتهأۄًتأ؏أًۄأتضأًمحأتىأڬەأځتضأوًدًزأىۄأحہەأ؏أثؼزأوۏڽأتىۄًڽأىەأثتشڲتۄأشضتهحأوۏڽأؼشعأڬۏتأۏتأشضًهأتههۄأ$أوۏشۏأؽۏشأوًدًزڲۏأوۏڽأوۏشۏأًتهزۄأڬتأتىحمتهأۄًأڲۏتأۄەأحًأڬۏتأتڲشأوۏڽأتىأڬۏأغشلأضەأڬډہأظزمۄأڬشًڽأحًأتىۄۏڽأتضأڬتألتةزۄأۄًأڲتأآأىثۏأ﷽أىەألشوتۏتأۄتڽأ$أتضأځشأًۄأڬۄىەأهڲەأڬۄأځہشأوۏڽأإځأڬًأڲًتۄأثىتحتأۄًڽأڬۄأوۏشتأتۏڬأثتؽأۄەأ؏أًۄأوۏڽأىەأتىأڬەأىتوأځشأظزمۄأڬشأزۏتأۗأ
3509,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەأدثأذدأڬتأتذشتوأثتىزہتأحًأډتشأسۏأتهذدۄأڬًأوڬۄأوڬشوۄأځۄىډەأتًشألدشأڬۏأىوتصأۄوۏڽأومتوأثغذتؤأوۏڽأځڔہتةۏأتًشألشوتۏتأدًأډتۄەأتضأتذشتوأڬًأؼوشۄأڬتأتذشتوأثىتأهەأۗأ
3510,"أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأ+أىثۏأ﷽أىەأۄوۏڽأرغثۄأزۏحەأۄًةەألشوتۏتأهًڲًأ$أحوأځشأذدألشعأڬشأزۏتأڲۏتأۄەأ,أۏۄأضىأڬشأتمشؼأثىأذتثضأڬہڔەأۄًأڲةەأتًشأڬۄىەأهڲەأۏتأشضًهأتههۄأ$أڬۏتأۄشأضتهأذدأڬشىتألشعأۄەأآأىثۏأ﷽أىەألشوتۏتأتڲشأوۏڽأۄتڽأڬۄۄأزۏحتأحًأحوأځشأۄشأضتهأذدأڬشىتألشعأۄًأدتحتأهۏڬىأتڲشأتۏضتأۄًأدتحتأحًأحوأتضأځشأؼوهأىۄأڬشأضڬحەأ؏أضتشۏأصىزڲۏأوۏڽأذدأتۏڬأوشحثۄألشعأۄەأ؏أتضأضەأصتةزأدًأۄًأڲتأًۄأىلهۏأذدأۄًأڲتأۗأ"
3511,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدىتثأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأمۏتوحأڬەأزىأۏۄأذدشأتضًزأتضأغشذأإةەأڲتأڬۄأتضأڬۏأزًأإىڬہۏڽأۄًڽأڲۏأدىأضەأۏۄأزۏڬہحتأۄًأڲتأتًشأتۏڬأصثتىأۄًأڲۏأدضأضەأۏۄأثًهحتأۄًأڲتأتًشأتضأطرظأڬەأذمأوۏڽأڲًتۄۏأزەأڲتأدضأىەأتضەأذمأڬەأضتحہأثًضۄأزۏتأۄًأڲتأۗأ
3512,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أتًشأإځأڬەأظذتثۄأشعۏأتههۄأؼىۄوأىەأدؼشتىۄأضەأؼوشۄأڬۏتأتًشأغًتلأڬەأزًشتىأتځىۏأډتزشًڽأڬًأتځىۏأثؽهًڽأضەأىڬتهأڬشأتعغثتؼأڬۏتأتًشأتىۄۏڽأتځىەأثتةۏڽأڬىزہًڽأځشأڋتهأهۏتأتًشأشوهأثہۏأڬۏتأۗأ
3513,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأوصزهلۄأۄۏأوۏڽأىثۏأ﷽أثىًأۄتطوأڬەأۄوأهًڲًڽأضەألشوتۏتأثہحۏدًأ$أهًڲًڽأڬەأشطأضەأځۄهەأىڬهأدتاأ؏أهۏڬىأغهًؼأإلحتثأضەأځۄهەأدوشۄأؼمثۄأڬۏأشوۏأىۄأڬشىتأۗأ
