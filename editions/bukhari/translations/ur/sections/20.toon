{"hadithnumber": "1188", "text": "ہم سے حفص بن عمر نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، انہوں نے کہا کہ مجھے عبدالملک نے قزعہ س"}
{"hadithnumber": "1189", "text": "(دوسری سند) ہم سے علی بن مدینی نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، ان سے زہری نے،"}
{"hadithnumber": "1190", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہوں نے کہا کہ ہمیں امام مالک نے زید بن رباح اور عبیداللہ"}
{"hadithnumber": "1192", "text": "نافع نے بیان کیا کہ ابن عمر رضی اللہ عنہما فرمایا کرتے تھے کہ  میں اسی طرح کرتا ہوں جیسے میں نے اپنے"}
{"hadithnumber": "1193", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، انہوں نے کہا کہ ہم سے عبدالعزیز بن مسلم نے بیان کیا، انہوں نے کہ"}
{"hadithnumber": "1194", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، اور ان سے عبیداللہ عمر"}
{"hadithnumber": "1195", "text": "ہم سے عبداللہ بن یوسف تنیسی نے بیان کیا، انہوں نے کہا کہ ہم کو امام مالک رحمہ اللہ نے خبر دی، انہیں"}
{"hadithnumber": "1196", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، ان سے یحییٰ نے، ان سے عبیداللہ عمری نے بیان کیا کہ مجھ سے خبیب بن ع"}
{"hadithnumber": "1197", "text": "ہم سے ابوالولید نے بیان کیا، انہوں نے کہا کہ ہم سے شعبہ نے بیان کیا، ان سے عبدالملک بن عمیر نے بیان"}
