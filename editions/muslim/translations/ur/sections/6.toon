{"hadithnumber": "1859", "text": "حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ  نے حدیث بیان کی کہ حجرت اسید بن حضیر رضی اللہ تعالیٰ عنہ  ا"}
{"hadithnumber": "1860", "text": "ابو عوانہ نے قتادہ سے انھوں نے حضرت انس )  سے انھوں نے حضرت ابو موسیٰ اشعری رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "1861", "text": "ہمام اور شعبہ نے قتادہ سے اسی سند کے ساتھ اسی کی طرح حدیث روایت کی ۔ اس میں یہ فرق ہے کہ ہمام کی روا"}
{"hadithnumber": "1862", "text": "ابو  عوانہ نے قتادہؒ سے روایت کی ، انھوں نے زراہ بن اوفیٰ  ( عامری )  سے  ، انھوں نےسعد بن ہشام سے ا"}
{"hadithnumber": "1863", "text": "ابن ابی عدی نے سعید سے روایت کی ، وکیع نے ہشام دستوائی سے روایت کی ، ان دونوں نے قتادہ سے اسی سند کے"}
{"hadithnumber": "1864", "text": "ہمام نےکہا : ہم سے  قتادہ نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے حدیث بیان کی کہ رسول اللہ  صل"}
{"hadithnumber": "1865", "text": "محمد بن جعفر نے کہا : ہم سے شعبہ نے حدیث بیان کی ، انھوں نے کہا : میں نے قتادہ کو حضرت انس  رضی اللہ"}
{"hadithnumber": "1866", "text": "خالد بن حارث نے کہا : شعبہ نے ہمیں قتادہ کے حوالے سے حدیث بیان کی ، انھوں نے کہا : میں نے حضرت انس"}
{"hadithnumber": "1867", "text": "حفص بن غیاث نے اعمش سے روایت کی ، انھوں نے ابراہیم سے ، انھوں  عبیدہ  ( سلمانی )  سےاور انھوں نے عبد"}
{"hadithnumber": "1868", "text": "ہناد بن سری اور منجانب بن حارث تمیمی نے علی بن مسہر سے روایت کی ، انھوں نے اعمش سے اسی سندکے ساتھ رو"}
{"hadithnumber": "1869", "text": "مسعر نے عمرو بن مرہ سے اور انھوں نے ابراہیم سے روایت کی ، انھوں نے کہا : نبی اکرم  صلی اللہ علیہ وسل"}
{"hadithnumber": "1870", "text": "جریر نے اعمش سے ، انھوں نے ابراہیم سے ، انھوں نے علقمہ سے اور انھوں نے حضرت عبداللہ بن مسعود  رضی ال"}
{"hadithnumber": "1871", "text": "عیسیٰ بن یونس اور ابو معاویہ نے اعمش سے اسی سند کے ساتھ ر وایت کی لیکن ابومعاویہ کی روایت میں  فقال"}
{"hadithnumber": "1872", "text": "حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، انھوں نے کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے"}
{"hadithnumber": "1873", "text": "حضرت عقبہ بن عامر  رضی اللہ تعالیٰ عنہ  سے  روایت ہے ، انھوں نے کہا کہ رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "1874", "text": "ابو توبہ ربیع بن نافع نے بیان کیا کہ ہم سے معاویہ  ، یعنی ابن اسلام نے حدیث بیان کی ، انھوں نے زید س"}
{"hadithnumber": "1875", "text": "یحییٰ بن حسان نے کہا : معاویہ بن سلام نے ہمیں اسی سند کے ساتھ اسی طرح حدیث بیان کی لیکن انہوں نے دون"}
{"hadithnumber": "1876", "text": "حضرت نواس بن سمعان کلابی  رضی اللہ تعالیٰ عنہ  کہتے ہیں کہ میں نے رسول اللہ  صلی اللہ علیہ وسلم  کو"}
{"hadithnumber": "1877", "text": "حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سےروایت ہے کہ جبرئیل علیہ السلام نبی اکرم  صلی اللہ علیہ وسلم  ک"}
{"hadithnumber": "1878", "text": "زہیر نے کہا : ہم سے منصور نے حدیث بیان کی ، انھوں نے ابراہیم سے اور انھوں نے عبدالرحما بن یزید سے ر"}
{"hadithnumber": "1879", "text": "جریر اور شعبہ دونوں نے منصور سے اسی سند کے ساتھ یہی ر وایت بیان کی ہے ۔"}
{"hadithnumber": "1880", "text": "علی بن مسہر نے اعمش سے روایت کی ، انھوں نے ابراہیم سے  ، انھوں نے عبدالرحمان بن یزید سے ، انھوں نے ع"}
{"hadithnumber": "1881", "text": "عیسیٰ بن یونس اور عبداللہ بن نمیر نے اعمش سے باقی ماندہ اسی سند کےساتھ اسی کے مانند روایت بیان کی ۔"}
{"hadithnumber": "1882", "text": "حفص اور ابو معاویہ نے بھی اعمش سے باقی ماندہ سابقہ سند کے ساتھ اسی کے مانند ر وایت بیان کی ہے ۔"}
{"hadithnumber": "1883", "text": "معاذ بن ہشام نے اپنے والد سے حدیث بیان کی ، انھوں نے قتادہ سے ، انھوں نے سالم بن ابی جعد غطفانی سے ،"}
{"hadithnumber": "1884", "text": "شعبہ اور ہمام نے قتادہ سے اسی سند کے ساتھ روایت کی ۔ اس میں شعبہ نے سورہ کہف کی آخری  ( دس ) آیات کہ"}
{"hadithnumber": "1885", "text": "حضرت ابی بن کعب  رضی اللہ تعالیٰ عنہ  سے روایت ہے ، انھوں نے کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے"}
{"hadithnumber": "1886", "text": "شعبہ نے قتادہ سے ، انہوں نے سالم بن ابی جعد سے ، انہوں نے معدان بن ابی طلحہ سے  ، انھوں نے حضرت ابو"}
{"hadithnumber": "1887", "text": "سعید بن ابی عروبہ اور ابان عطار نے قتادہ سے اسی  سابقہ سند کے ساتھ روایت کی  ، ان دونوں   ( سعید اور"}
{"hadithnumber": "1888", "text": "یزید بن کیسان نے کہا : ہمیں ابو حازم نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے حدیث سنائی ، انھوں ن"}
{"hadithnumber": "1889", "text": "ابواسماعیل بشیر نے ابو حازم سے اور انھوں نے حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں"}
{"hadithnumber": "1890", "text": "عمرہ بنت عبدالرحمان نے  ، اور وہ رسول اللہ  صلی اللہ علیہ وسلم  کی زوجہ حضرت عائشہ  رضی اللہ تعالیٰ"}
{"hadithnumber": "1891", "text": "بیان ( بن بشر ) نے قیس بن ابی حازم سے اور انھوں نے حضرت عقبہ بن عامر  رضی اللہ تعالیٰ عنہ  سے  روایت"}
{"hadithnumber": "1892", "text": "محمد بن عبداللہ بن نمیر نے بیان کیا  ، کہا : میرے والد نے ہمیں حدیث بیان کی ، کہا :  مجھ سے اسماعیل"}
{"hadithnumber": "1893", "text": "۔  وکیع اور ابو اسامہ نے اسماعیل سے اسی سند کے سات اسی طرح روایت بیان کی ، البتہ ابو اسامہ نے عقبہ ب"}
{"hadithnumber": "1894", "text": "سفیان بن عینیہ نے حدیث بیان کی  ، کہا : ہمیں  ( ابن شہاب )  زہری نے سالم سے حدیث بیان کی  ، انھوں نے"}
{"hadithnumber": "1895", "text": "یونس نے ابن شہاب  ( زہری )  سے روایت کی  ، انھوں نے کہا :  مجھے سالم بن عبداللہ بن عمر  رضی اللہ تعا"}
{"hadithnumber": "1896", "text": "حضرت عبداللہ بن مسعود  رضی اللہ تعالیٰ عنہ  کہتے ہیں کہ  رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :"}
{"hadithnumber": "1897", "text": "ابراہیم بن سعد نے ابن شہاب  ( زہری )  سے اور انھوں نے عامر بن واثلہ سے  روایت کی کہ نافع بن عبدالحار"}
{"hadithnumber": "1898", "text": "شعیب نے زہری سے خبر دی ، انھوں نے کہا : مجھے عامر بن واثلہ  لیثی نے حدیث بیان کی کہ نافع بن عبدالحار"}
{"hadithnumber": "1899", "text": "مالک نے ابن شہاب سے ، انھوں نے عروہ بن زبیر سے انھوں نے عبدالرحمان بن عبدالقاری سے روایت کی ، انھوں"}
{"hadithnumber": "1900", "text": "یونس نے ابن شہاب سے  روایت کی ، انھوں نے کہا : مجھے عروہ بن زبیر نے بتایا کہ مسود بن مخرمہ اور عبدال"}
{"hadithnumber": "1901", "text": "معمر نے زہری سے یونس کی روایت کی طرح اسی کی سند کے ساتھ روایت کی ۔"}
{"hadithnumber": "1902", "text": "یونس نے ابن شہاب سے روایت کی ، انھوں نے کہا : مجھ سے عبیداللہ بن عبداللہ بن عتبہ نے حدیث بیان کی کہ"}
{"hadithnumber": "1903", "text": "ہمیں معمر نے زہری سے اسی سند کے ساتھ خبر دی ۔"}
{"hadithnumber": "1904", "text": "عبداللہ بن نمیر نے کہا : اسماعیل بن ابی خالد نے ہمیں حدیث بیان کی ، انھوں نے عبداللہ بن عیسیٰ بن عبد"}
{"hadithnumber": "1905", "text": "محمد بن بشر نے اسماعیل بن ابی خالد سے اسی سند کے ساتھ روایت کی کہ حضرت ابی ابن کعب  رضی اللہ تعالیٰ"}
{"hadithnumber": "1906", "text": "محمد بن جعفر غندر نے شعبہ سے روایت کی ، انھوں نے حکم سے ، انھوں نے مجاہد سے  ، انھوں نے ابن ابی لیلی"}
{"hadithnumber": "1907", "text": "معاذ عنبری نےشعبہ  سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "1908", "text": "ابو بکر بن ابی شیبہ اور ابن نمیر نے وکیع سے  ، انھوں نے اعمش سے اور انھوں نے ابو وائل سے روایت کی ،"}
{"hadithnumber": "1909", "text": "ابو معاویہ نے اعمش سے  ، انھوں نے ابو وائل سے روایت کی ، انھوں نے کہا : حضرت عبداللہ کے پاس ایک آدمی"}
{"hadithnumber": "1910", "text": "عیسیٰ بن یونس نے کہا : اعمش نے ہم سے اپنی اسی سند کے ساتھ ان دونوں  ( وکیع اور ابو معاویہ )  کی حدیث"}
{"hadithnumber": "1911", "text": "مہدی بن میمون نے کہا :  واصل حدب نے ہمیں ابو وائل سے حدیث بیان کی ، انھوں نے کہا :  ایک دن ہم صبح کی"}
{"hadithnumber": "1912", "text": "منصور نے ( ابووائل )  شقیق سے روایت کی ، انھوں نے کہا : بنو بجیلہ میں سے ایک آدمی جسے نہیک بن سنان ک"}
{"hadithnumber": "1913", "text": "عمرو بن مرہ سے روایت ہے ۔ انھوں نے ابو وائل سے سنا وہ حدیث بیان کر رہے تھے کہ ایک آدمی حضرت عبد اللہ"}
{"hadithnumber": "1914", "text": "زہیر نے کہا  : ہم سے ابو اسحاق نے حدیث بیان کی ، انھوں نے کہا :  میں نے ایک آدمی کو دیکھا اس نے اسود"}
{"hadithnumber": "1915", "text": "شعبہ نے ابو اسحاق سے انھوں نے اسود سے انھوں نے حضرت عبد اللہ بن مسعود رضی اللہ تعالیٰ عنہ  سے اور ان"}
{"hadithnumber": "1916", "text": "اعمش نے ابرا ہیم سے اور انھوں نے علقمہ  ( بن قیس کوفی ) سے روایت کی انھوں نے کہا :  ہم شام آئے تو ہم"}
{"hadithnumber": "1917", "text": "مغیرہ نے ابرا ہیم سے روا یت کی ، انھوں نے کہا : علقم ہشام آئے اور ایک مسجد میں داخل ہو ئے اس میں نما"}
{"hadithnumber": "1918", "text": "اسماعیل بن ابرا ہیم  ( ابن علیہ  )  نے داودبن ابی ہند سے انھوں نے شعبی سے اور انھوں نے علقمہ سے روا"}
{"hadithnumber": "1919", "text": "عبد الاعلیٰ نے کہا :  ہم سے داودنے عامر  ( شعبی ) سے اور انھوں نے علقمہ سے روا یت کی ،  انھوں نے کہا"}
{"hadithnumber": "1920", "text": "حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روا یت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے نماز عصر کے ب"}
{"hadithnumber": "1921", "text": "منصور نے قتادہ سے روا یت کی انھوں نے کہا :  ہمیں ابو عالیہ نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "1922", "text": "شعبہ سعید اور معاذ بن ہشام نے اپنے والد کے واسطے سے قتادہ سے اسی سند کے ساتھ یہ روا یت بیان کی ،  ال"}
{"hadithnumber": "1923", "text": "عطاء بن یزید لیثی نے خبر دی کہ انھوں نے ابو سعید خدری  رضی اللہ تعالیٰ عنہ  کو کہتے ہوئے سنا کہ رسول"}
{"hadithnumber": "1924", "text": "نافع نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :"}
{"hadithnumber": "1925", "text": "ہشام کے والد عروہ نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : رسول اللہ  صلی"}
{"hadithnumber": "1926", "text": "حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :  \" ج"}
{"hadithnumber": "1927", "text": "لیث نے خیر بن نعیم حضرمی سے روایت کی ، انھوں نے عبداللہ بن ہبیرہ سے ، انھوں نے ابو تمیم جیشانی سے او"}
{"hadithnumber": "1928", "text": "یزید بن ابی حبیب نے خیر بن نعیم حضرمی سے ، انھوں نے عبداللہ بن ہبیرہ سبائی سے ۔  ۔  ۔ اور وہ ثقہ تھے"}
{"hadithnumber": "1929", "text": "حضرت عقبہ بن عامر  جہنی رضی اللہ تعالیٰ عنہ  کہتے تھے کہ تین ا وقات ہیں ، رسول اللہ  صلی اللہ علیہ و"}
{"hadithnumber": "1930", "text": "ابو عمار شداد بن عبداللہ اور یحییٰ بن ابی کثیر نے ابو امامہ سے روایت کی ۔  ۔  ۔ عکرمہ نے کہا : شداد"}
{"hadithnumber": "1931", "text": "وہیب نے کہا : ہم سے عبداللہ بن طاوس نے حدیث بیان کی ، انھوں نے اپنے والد  ( طاوس )  سے اور انھوں نے"}
{"hadithnumber": "1932", "text": "معمر نے باقی ماندہ سابقہ سند کے ساتھ طاوس کے بیٹے سے ، انھوں نے اپنے والد سے اور انھوں نے حضرت عائشہ"}
{"hadithnumber": "1933", "text": "حضرت ابن  عباس  رضی اللہ تعالیٰ عنہ  کے  آزاد کردہ غلام کریب سے روایت ہے کہ عبداللہ بن عباس  رضی الل"}
{"hadithnumber": "1934", "text": "یحییٰ بن ایوب ، قتیبہ ، اور علی بن حجر نے اسماعیل بن جعفر سے حدیث بیان کی ، ابن ایوب نے کہا : ہمیں ا"}
{"hadithnumber": "1935", "text": "عروہ نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ، انھوں نے  فرمایا : رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "1936", "text": "عبدالرحمان بن اسود نے اپنے والد اسود سے اور انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی"}
{"hadithnumber": "1937", "text": "ابو اسحاق نے اسود اور مسروق سے روایت کی ، ان دونوں نے کہا : ہم حضرت عائشہ  رضی اللہ تعالیٰ عنہا   کے"}
{"hadithnumber": "1938", "text": "مختار بن فلفل سے روایت ہے  ، انھوں نے کہا :  میں نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ  سے عصر کے"}
{"hadithnumber": "1939", "text": "عبدالعزیز بن صہیب نے حضرت  انس بن مالک  رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا : ہم مدینے میں ہوتے ت"}
{"hadithnumber": "1940", "text": "کہمس نےکہا : ہم سے عبداللہ بن بریدہ نے حضرت عبداللہ بن مغفل مزنی رضی اللہ تعالیٰ عنہ  سے حدیث بیان ک"}
{"hadithnumber": "1941", "text": "جریری نے عبداللہ بن بریرہ سے ، انھوں نے حضرت عبداللہ بن مغفل  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے ن"}
{"hadithnumber": "1942", "text": "معمر نے زہری سے ، انھوں نے سالم سے اور انھوں نےحضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی  ، انھ"}
{"hadithnumber": "1943", "text": "فلیح نے زہری سے  ، انھوں نے سالم بن عبداللہ بن عمر سے اور انھوں نے ا پنے والد سے  روایت کی کہ وہ رسو"}
{"hadithnumber": "1944", "text": "نافع نے حضرت ابن  عمر  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : رسول اللہ  صلی اللہ علیہ وس"}
{"hadithnumber": "1945", "text": "عطاء نے حضرت جابر بن عبداللہ انصاری  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا : میں رسول اللہ"}
{"hadithnumber": "1946", "text": "ابو زبیر نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت کی ، انھوں نے کہا؛ہم نے رسول اللہ  صلی اللہ علی"}
{"hadithnumber": "1947", "text": "عبدالرحمان بن قاسم نے اپنے والد سے ، انھوں نے صالح بن خوات بن جبیرسے اور انھوں نے حضرت سہل بن ابی حث"}
{"hadithnumber": "1948", "text": "یزید بن رومان نے صالح بن خوات سےاور انھوں نے اس شخص سے نقل کیا جس نے غزوہ ذات الرقاع میں رسول اللہ"}
{"hadithnumber": "1949", "text": "۔  ابان بن یزید نے کہا : ہم سے یحییٰ ابن کثیر نے ابو سلمہ ( بن عبدالرحمان )  سے  حدیث بیان کی اور ان"}
{"hadithnumber": "1950", "text": "معاویہ بن سلام نے کہا : مجھے یحییٰ ( بن ا بی کثیر )  نے خبردی ، انھوں نے کہا : مجھے ابو سلمہ بن عبدا"}
