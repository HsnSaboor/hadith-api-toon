hadiths[4]{hadithnumber,text}:
20614,أشدتؤأثىأتثۏأشدتؤأڬۄحەأۄۏڽأڬۄأذعشحأثشۏزۄأشعۏأتههۄأؼىۄأوضدزأڬەأزشًتصەأځشأڬہڔەأحہەأڬۄأًۄتڽأضەأذعشحأوذدىأشعۏأتههۄأؼىۄأڬتأڲسشأۄًتأ؏أضڬثۄأشعۏأتههۄأؼىۄأىوتصأځڔہأشۄەأحہەأ؏أذعشحأثشۏزۄأشعۏأتههۄأؼىۄأ““أدىأڬۏأغثۏؼحأوۏڽأذضأوصتذأڬتأؽهثۄأحہتأ‛‛أذعشحأوذدىأشعۏأتههۄأؼىۄأضەأڬۄىەأهڲەأڬۄأدضأغشذأۏۄأىوتصأځڔہأشۄەأۄۏڽأ؏أحوأڬۏًڽأىۄۏڽأځڔہأشۄەأآأتىۄًڽأىەأڬۄتأڬۄأتۏڬأوشحثۄأىثۏأ﷽أىەأوۏشتأۄتحہأځڬڔتأتًشأتذزأځۄتڔأځشأډڔہأڲةەأ؏أځہشأوزۏىۄأوىًشۄأڬۏأغشلأدہتىڬأڬشألشوتۏتأۄتةەأتلضًضأ$أتضأثۄحشۏىأطۄشأڬًأثۄحشۏىأذتهحأوۏڽأډہًڔأڬشأۏۄتڽأشۄىەأًتهەأډهەأدتةۏڽأڲەأ؏أځہشأزدتهأۏۄتڽأإةەأڲتأحًأتضأڬەأۄشأزشًتصەأځشأتۏڬأوضهذألشطحۄأځۄشۄأزەأشۄتأۄًأڲتأ؏أهۄستأزدتهأتضأطۄشأوۏڽأزترهأىۄۏڽأۄًأضڬەأڲتأ؏أځہشأىثۏأ﷽أوۏشتأۄتحہأځڬڔەأځڬڔەأىۏډەأتحشەأتًشأوضدزأوۏڽأزترهأۄًأڲةەأ؏أًۄتڽأتۏڬأإزوۏأىوتصأځڔہأشۄتأحہتأ؏أىثۏأ﷽أىەأودہأضەأځًډہتأۏۄأڬًىأۄەأآأوۏڽأىەأتضأڬۏأحؼشۏلأڬۏأحًأىثۏأ﷽أىەألشوتۏتأإۄضحۄأثًهًأ؏أتضەأوحأضىتاأ؏أًشىۄأحوأتضەأۄهتڬأڬشأزًأڲەأ؏أځہشأتځىۏأڬضۏأصًدۄأوذحشوۄأڬەأذدشەأڬەأمشۏثأځۄىډأڬشأوۏشتأۄتحہأډہًڔأزۏتأتًشأزًأوشحثۄألشوتۏتأحوۄتشتأضثأضەأثۄحشۏىأزۏىأًۄأۄەأدًأضثأضەأصۏتزۄأإضتىأۄًأۗ
20615,أڲصطحۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗأ
20616,أڲصطحۄأذزۏخأتضأزًضشۏأضىزأضەأثہۏأوشًۏأۄەأۗأ
20617,أشدتؤأثىأتثۏأشدتؤأڬۄحەأۄۏڽأڬۄأذعشحأثشۏزۄأشعۏأتههۄأؼىۄأوضدزأڬەأزشًتصەأځشأڬہڔەأحہەأڬۄأًۄتڽأضەأذعشحأوذدىأشعۏأتههۄأؼىۄأڬتأڲسشأۄًتأ؏أضڬثۄأشعۏأتههۄأؼىۄأىوتصأځڔہأشۄەأحہەأ؏أذعشحأثشۏزۄأشعۏأتههۄأؼىۄأ““أدىأڬۏأغثۏؼحأوۏڽأذضأوصتذأڬتأؽهثۄأحہتأ‛‛أذعشحأوذدىأشعۏأتههۄأؼىۄأضەأڬۄىەأهڲەأڬۄأدضأغشذأۏۄأىوتصأځڔہأشۄەأۄۏڽأ؏أحوأڬۏًڽأىۄۏڽأځڔہأشۄەأآأتىۄًڽأىەأڬۄتأڬۄأتۏڬأوشحثۄأىثۏأ﷽أىەأوۏشتأۄتحہأځڬڔتأتًشأتذزأځۄتڔأځشأډڔہأڲةەأ؏أځہشأوزۏىۄأوىًشۄأڬۏأغشلأدہتىڬأڬشألشوتۏتأۄتةەأتلضًضأ$أتضأثۄحشۏىأطۄشأڬًأثۄحشۏىأذتهحأوۏڽأډہًڔأڬشأۏۄتڽأشۄىەأًتهەأډهەأدتةۏڽأڲەأ؏أځہشأزدتهأۏۄتڽأإةەأڲتأحًأتضأڬەأۄشأزشًتصەأځشأتۏڬأوضهذألشطحۄأځۄشۄأزەأشۄتأۄًأڲتأ؏أهۄستأزدتهأتضأطۄشأوۏڽأزترهأىۄۏڽأۄًأضڬەأڲتأ؏أځہشأىثۏأ﷽أوۏشتأۄتحہأځڬڔەأځڬڔەأىۏډەأتحشەأتًشأډهحەأډهحەأوضدزأوۏڽأزترهأۄًأڲةەأ؏أًۄتڽأتۏڬأإزوۏأىوتصأځڔہأشۄتأحہتأ؏أىثۏأ﷽أىەأودہأضەأځًډہتأڬۄأۏۄأڬًىأۄەأآأوۏڽأىەأتضأڬۏأحؼشۏلأڬۏأحًأىثۏأ﷽أىەألشوتۏتأإۄضحۄأثًهًأ؏أتضەأوحأضىتاأ؏أًشىۄأحوأتضەأۄهتڬأڬشأزًأڲەأ؏أځہشأتځىۏأڬضۏأصًدۄأوذحشوۄأڬەأذدشەأڬەأمشۏثأځۄىډأڬشأوۏشتأۄتحہأډہًڔأزۏتأتًشأزًأوشحثۄألشوتۏتأحوۄتشتأضثأضەأثۄحشۏىأزۏىأًۄأۄەأدًأضثأضەأصۏتزۄأإضتىأۄًأۗ
