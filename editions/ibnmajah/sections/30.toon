{"hadithnumber": "3429", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ خَلَّادٍ الْبَاهِلِيُّ،‏‏‏‏ حَدَّثَنَا سُفْيَانُ،‏‏‏‏ عَنْ عَبْدِ الْكَ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 30, Hadith 59", "international_number": "3429", "narrator_chain": ""}
{"hadithnumber": "3430", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ،‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ عَبْدِ الرَّحْمَنِ الْمُحَارِبِيُّ،", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 30, Hadith 60", "international_number": "3430", "narrator_chain": ""}
{"hadithnumber": "3431", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ،‏‏‏‏ حَدَّثَنَا بَقِيَّةُ،‏‏‏‏ عَنْ مُسْلِمِ بْنِ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 30, Hadith 61", "international_number": "3431", "narrator_chain": ""}
{"hadithnumber": "3432", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مَنْصُورٍ أَبُو بَكْرٍ،‏‏‏‏ حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ،‏‏‏‏ حَدَّثَن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 30, Hadith 62", "international_number": "3432", "narrator_chain": ""}
{"hadithnumber": "3433", "arabic": "حَدَّثَنَا وَاصِلُ بْنُ عَبْدِ الْأَعْلَى،‏‏‏‏ حَدَّثَنَا ابْنُ فُضَيْلٍ،‏‏‏‏ عَنْ لَيْثٍ،‏‏‏‏ عَنْ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 30, Hadith 63", "international_number": "3433", "narrator_chain": ""}
