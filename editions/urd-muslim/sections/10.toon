hadiths[29]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
2089,"امام مالک بن انس اور عبد اللہ بن نمیر نے کہا :  ہمیں ہشام نے اپنے والد عروہ سے حدیث سنا ئی انھوں نے ",,,,,2089
2090,ابو معاویہ نے ہشام بن عروہ سے اسی سند کے ساتھ  ( سابقہ حدیث کے مانند  )  روایت کی اور اس میں یہ اضاف,,,,,2090
2091,حرملہ بن یحییٰ نے مجھے حدیث بیان کی  ،  ( کہا  )  مجھے ابن وہب نے یونس سے خبر دی نیز ابو طاہر اور مح,,,,,2091
2092,"ابو عمرو اوزاعی اور ان کے علاوہ د وسرے ( راوی ، دونوں میں سے ہرایک ) نے کہا : میں نے ابن شہاب زہری س",,,,,2092
2094,"۔  ( عبدالرحمان بن نمر نے ہی کہا :  ) زہری نے کہا : کثیر بن عباس  رضی اللہ تعالیٰ عنہ  نے ( اپنے بھا",,,,,2094
2095,"محمد بن ولید زبیدی نے زہری سے روایت کی ، انھوں نے کہا : کثیر بن عباس  رضی اللہ تعالیٰ عنہ  حدیث بیان",,,,,2095
2096,"ابن جریج نے کہا : میں نے عطاء ( بن ابی رباح )  کو کہتے ہوئے سنا : میں نے عبید بن عمیر سے سنا ، کہہ ر",,,,,2096
2097,قتادہ نے عطاء بن ابی رباح سے ، انھوں نے عبید بن عمیر سے اور انھوں نے حضر ت عائشہ  رضی اللہ تعالیٰ عن,,,,,2097
2098,سلیمان بن بلال نے یحییٰ ( بن سعید )  سے اور انھوں نے عمرہ سے روایت کی کہ ایک یہودی عورت حضرت عائشہ  ,,,,,2098
2099,عبدالوہاب اور سفیان نے یحییٰ بن سعید سے اسی سند کے ساتھ سلیمان بن بلال کی حدیث کے ہم معنی روایت بیان,,,,,2099
2102,"ابو بکر بن ابی شیبہ نے کہا : ہم سے عبداللہ بن نمیر نے حدیث بیان کی ، نیز محمد بن عبداللہ نمیر نے حدی",,,,,2102
2103,"ہمیں  ( عبداللہ )  ابن نمیر نے حدیث بیان کی ، کہا : ہم سے ہشام نے ، انھوں نے  ( اپنی بیوی ) فاطمہ ( ",,,,,2103
2106,"خالد بن حارث نے کہا :  ہم سے ابن جریج  نے حدیث بیان کی  ،  ( انھوں نے کہا :  )  مجھ سے منصور بن عبدا",,,,,2106
2107,"یحیٰ اموی نے کہا :  ہم سے ا بن جریج نے اسی سند کے ساتھ اسی  ( سابقہ  حدیث  )  کے مانند حدیث بیان کی ",,,,,2107
2108,"وہیب نے کہا : ہمیں منصور نے اپنی والدہ ( صفیہ )  سے حدیث بیان کی ، انھوں نے اسماء بنت ابی بکر  رضی ا",,,,,2108
2109,"حفص بن میسرہ نے کہا : زید بن اسلم نے مجھے عطاء بن یسار سے حدیث بیان کی ، انھوں نے حضرت ابن عباس  رضی",,,,,2109
2110,امام مالک نے زید بن اسلم سے اسی سند کے ساتھ اس  ( مذکورہ حدیث )  کے مانند روایت کی ، البتہ انھوں نے ,,,,,2110
2111,اسماعیل ابن علیہ نے سفیان سے ، انھوں نے حبیب  بن ابی ثابت سے ، انھوں نے طاوس سے اور انھوں نے حضرت اب,,,,,2111
2112,"یحییٰ نے سفیان سے حدیث بیان کی ، انھوں نے کہا : ہمیں حبیب نے  طاوس سے حدیث سنائی ، انھوں نے حضرت ابن",,,,,2112
2113,"حضرت عبداللہ بن عمرو بن عاص  رضی اللہ تعالیٰ عنہ  نے کہا : کہ جب رسول اللہ  صلی اللہ علیہ وسلم  کے ز",,,,,2113
2114,ہشیم نے اسماعیل سے ، انھوں نے قیس بن ابی حازم سے ، اور انھوں نے ابو مسعود انصاری رضی اللہ تعالیٰ عنہ,,,,,2114
2115,معتمر نے اسماعیل سے ، انھوں نے قیس سے اور انھوں نے حضرت ابو مسعود  رضی اللہ تعالیٰ عنہ  سے  روایت کی,,,,,2115
2116,وکیع ، ابواسامہ ، ابن نمیر ، جریر ، سفیان ، اورمروان سب نے اسماعیل سے اسی سند کے ساتھ روایت کی ، سفی,,,,,2116
2117,"ابو عامر اشعری عبداللہ بن براد اور محمد بن علاء نے کہا : ہمیں ابو اسامہ نے برید سے حدیث سنائی ، انھو",,,,,2117
2118,"بشر بن مفضل نے کہا : جریری نے ہمیں ابو علاء حیان بن عمیر سے حدیث بیان کی ، انھوں نے حضرت عبدالرحمان ",,,,,2118
2119,عبدالاعلیٰ بن عبدالاعلیٰ نے جریری سے ، انھوں نے حیان بن نمیر سے اور انھوں نے حضرت عبدالرحمان بن سمرہ,,,,,2119
2120,"سالم بن نوح نے کہا : ہمیں جریری نے حیان بن عمیر سے خبر دی اور انھوں نے عبدالرحمان بن سمرہ  رضی اللہ ",,,,,2120
2121,حضرت عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، وہ رسول اللہ  صلی اللہ علیہ وسلم  سے یہ خبر,,,,,2121
2122,حضرت مغیرہ بن شعبہ  رضی اللہ تعالیٰ عنہ   فرماتے ہیں کہ رسول اللہ  صلی اللہ علیہ وسلم کے عہد مبارک م,,,,,2122
