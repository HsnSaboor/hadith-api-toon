{"hadithnumber": "1400", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  تمہارے نبی  ( صلی اللہ علیہ وسلم )  کو پچاس نمازوں کا حک"}
{"hadithnumber": "1401", "text": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  پانچ وقت"}
{"hadithnumber": "1402", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ایک دفعہ ہم مسجد نبوی میں بیٹھے ہوئے تھے کہ اتنے میں اونٹ پر س"}
{"hadithnumber": "1403", "text": "ابوقتادہ بن ربعی رضی اللہ عنہ خبر دیتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ"}
{"hadithnumber": "1404", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میری مسجد میں ایک نما"}
{"hadithnumber": "1405", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  میری مسجد میں ایک"}
{"hadithnumber": "1406", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میری مسجد میں ایک نماز پڑ"}
{"hadithnumber": "1407", "text": "نبی اکرم صلی اللہ علیہ وسلم کی لونڈی میمونہ رضی اللہ عنہا کہتی ہیں کہ  میں نے عرض کیا:  اللہ کے رسول"}
{"hadithnumber": "1408", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب سلیمان بن داو"}
{"hadithnumber": "1409", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا  تین مساجد: مسجد الحرام"}
{"hadithnumber": "1410", "text": "ابو سعید خدری اور عبداللہ بن عمرو بن العاص رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "1411", "text": "اسید بن ظہیر انصاری رضی اللہ عنہ (جو نبی اکرم صلی اللہ علیہ وسلم کے اصحاب میں سے تھے) کہتے ہیں کہ  ن"}
{"hadithnumber": "1412", "text": "سہل بن حنیف رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص اپنے گھر میں و"}
{"hadithnumber": "1413", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  آدمی کی نماز اپنے گھ"}
{"hadithnumber": "1414", "text": "ابی بن کعب رضی اللہ عنہ کہتے ہیں کہ  جب مسجد چھپر کی تھی تو رسول اللہ صلی اللہ علیہ وسلم کھجور کے ای"}
{"hadithnumber": "1415", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کھجور کے ایک تنے کے سہارے خطبہ دیتے تھے"}
{"hadithnumber": "1416", "text": "ابوحازم کہتے ہیں کہ  لوگوں نے رسول اللہ صلی اللہ علیہ وسلم کے منبر کے بارے میں اختلاف کیا کہ وہ کس چ"}
{"hadithnumber": "1417", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک درخت کی جڑ، یا یوں کہا:"}
{"hadithnumber": "1418", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  ایک رات میں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ نماز"}
{"hadithnumber": "1419", "text": "مغیرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نماز کے لیے کھڑے ہوئے، یہاں تک کہ آپ کے"}
{"hadithnumber": "1420", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نماز پڑھتے یہاں تک کہ آپ کے پاؤں سوج"}
{"hadithnumber": "1421", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سے پوچھا گیا: کون سی نماز اف"}
{"hadithnumber": "1422", "text": "ابوفاطمہ رضی اللہ عنہا کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! مجھے ایسا عمل بتائیے جس پر میں جما"}
{"hadithnumber": "1423", "text": "معدان بن ابی طلحہ یعمری کہتے ہیں کہ  میں ثوبان رضی اللہ عنہ سے ملا، اور ان سے کہا: آپ مجھ سے کوئی حد"}
{"hadithnumber": "1424", "text": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو کوئ"}
{"hadithnumber": "1425", "text": "انس بن حکیم کہتے ہیں کہ  ابوہریرہ رضی اللہ عنہ نے مجھ سے کہا کہ جب تم اپنے شہر والوں کے پاس پہنچو تو"}
{"hadithnumber": "1426", "text": "تمیم داری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قیامت کے دن بندے سے جس چ"}
{"hadithnumber": "1427", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  کیا تم میں کا کوئی اتنا ع"}
{"hadithnumber": "1428", "text": "مغیرہ بن شعبہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  امام اس جگہ سنت"}
{"hadithnumber": "1429", "text": "عبدالرحمٰن بن شبل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( نماز میں )  تین چیزوں"}
{"hadithnumber": "1430", "text": "سلمہ بن الاکوع رضی اللہ عنہ کہتے ہیں کہ  وہ نماز الضحیٰ  ( چاشت کی نفل نماز )  کے لیے آتے اور صف سے"}
{"hadithnumber": "1431", "text": "عبداللہ بن سائب رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فتح مکہ کے دن نماز"}
{"hadithnumber": "1432", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جوتے اپنے پاؤں میں پہنے"}
