metadata:
  section_id: 10
  section_name: رسول اللہ صلی اللہ علیہ وسلم کی معیشت (گزر بسر) کا بیان
  hadith_first: 70
  hadith_last: 71

hadiths[2]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
70,"'Aisha said;\n“Allah's Messenger (Allah bless him and give him peace) went out one early morning, wearing a wrap of black hair.”",,,70,,رسول اللہ صلی اللہ علیہ وسلم کی معیشت (گزر بسر) کا بیان
71,“The Prophet (Allah bless him and give him peace) wore a Byzantine robe with narrow sleeves.”,,,71,"Urwa ibn al-Mughira ibn Shu'ba said that his father said:",رسول اللہ صلی اللہ علیہ وسلم کی معیشت (گزر بسر) کا بیان
