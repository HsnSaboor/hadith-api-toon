hadiths[127]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
682,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب ماہ رمضان کی پہلی رات",,,,,682
683,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے ایمان کے ساتھ اور ",,,,,683
684,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”اس ماہ  ( رمضان )  سے ایک",,,,,684
685,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”رمضان سے ایک یا دو دن پہ",,,,,685
686,صلہ بن زفر کہتے ہیں کہ  ہم عمار بن یاسر رضی الله عنہ کے پاس تھے کہ ایک بھنی ہوئی بکری لائی گئی تو ان,,,,,686
687,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”رمضان کے لیے شعبان کے چا",,,,,687
688,"عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”رمضان سے پہل",,,,,688
689,عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ تیس دن کے روز,,,,,689
690,انس رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنی بیویوں سے ایک ماہ کے لیے ایلاء کی,,,,,690
691,عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  ایک اعرابی نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ کر ک,,,,,691
692,"ابوبکرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”عید کے دونوں مہینے رمضان ",,,,,692
693,کریب بیان کرتے ہیں کہ  ام فضل بنت حارث نے انہیں معاویہ رضی الله عنہ کے پاس شام بھیجا، تو میں شام آی,,,,,693
694,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جسے کھجور میسر ہو، تو",,,,,694
695,"سلمان بن عامر ضبی رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جب تم میں سے ",,,,,695
696,انس بن مالک رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم  ( مغرب )  پڑھنے سے پہلے چند تر کھ,,,,,696
697,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”صیام کا دن وہی ہے جس دن ت",,,,,697
698,"عمر بن خطاب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب رات آ جائے، اور د",,,,,698
699,"سہل بن سعد رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”لوگ برابر خیر میں رہیں",,,,,699
700,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اللہ عزوجل فرماتا ہے:",,,,,700
701,"اس سند سے بھی  اوزاعی سے اسی طرح مروی ہے۔ \r\n\r\nامام ترمذی کہتے ہیں: یہ حدیث حسن غریب ہے۔",,,,,701
702,"ابوعطیہ کہتے ہیں کہ  میں اور مسروق دونوں ام المؤمنین عائشہ رضی الله عنہا کے پاس گئے، ہم نے عرض کیا: ",,,,,702
703,"انس بن مالک رضی الله عنہ سے روایت ہے کہ  زید بن ثابت رضی الله عنہ کہتے ہیں: ہم نے نبی اکرم صلی اللہ ",,,,,703
704,"اس سند سے بھی  ہشام سے اسی طرح مروی ہے البتہ اس میں یوں ہے: پچاس آیتوں کے پڑھنے کے بقدر۔ \r\n\r\nامام ت",,,,,704
705,قیس بن طلق کہتے ہیں کہ  مجھ سے میرے باپ طلق بن علی رضی الله عنہ نے بیان کیا کہ رسول اللہ صلی اللہ عل,,,,,705
706,"سمرہ بن جندب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تمہیں سحری کھانے سے ",,,,,706
707,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو  (  «صائم» )  جھوٹ بول",,,,,707
708,"انس رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”سحری کھاؤ ۱؎، کیونکہ سحری میں",,,,,708
709,اس سند سے عمرو بن عاص رضی الله عنہ  نبی اکرم صلی اللہ علیہ وسلم سے یہی حدیث روایت کرتے ہیں۔ \r\n\r\nامام,,,,,709
710,جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم فتح مکہ کے سال مکہ کی طرف ن,,,,,710
711,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  حمزہ بن عمرو اسلمی رضی الله عنہ نے رسول اللہ صلی اللہ ع,,,,,711
712,ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ رمضان میں سفر کر,,,,,712
713,ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ سفر کرتے تھے تو ,,,,,713
714,معمر بن ابی حیّیہ سے روایت ہے کہ  انہوں نے ابن مسیب سے سفر میں روزہ رکھنے کے بارے میں پوچھا تو ابن م,,,,,714
715,انس بن مالک کعبی رضی الله عنہ ۱؎ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے سواروں نے ہم پر رات می,,,,,715
716,عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  ایک عورت نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ کر کہا,,,,,716
717,"اس سند سے بھی  اعمش سے اسی طرح مروی ہے۔ \r\n\r\nامام ترمذی کہتے ہیں: ۱- ابن عباس رضی الله عنہما کی حدیث ",,,,,717
718,"عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو اس حالت میں",,,,,718
719,"ابو سعید خدری رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تین چیزوں سے روزہ د",,,,,719
720,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جسے قے آ جائے اس پر روزے",,,,,720
721,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے بھول کر کچھ کھا پی",,,,,721
722,اس سند سے بھی  ابوہریرہ رضی الله عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے اسی جیسی حدیث روایت کی ہے۔ \r\n,,,,,722
723,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے بغیر کسی شرعی رخصت",,,,,723
724,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے پاس ایک شخص نے آ کر کہا: اللہ کے",,,,,724
725,عامر بن ربیعہ رضی الله عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو روزہ کی حالت میں اتنی ,,,,,725
726,"انس بن مالک رضی الله عنہ کہتے ہیں کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ کر پوچھا: میر",,,,,726
727,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  کہ نبی اکرم صلی اللہ علیہ وسلم ماہ صیام  ( رمضان )  میں,,,,,727
728,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم روزے کی حالت میں مجھ سے بو,,,,,728
729,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم روزے کی حالت میں بوسہ لیتے,,,,,729
730,"ام المؤمنین حفصہ رضی الله عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس نے روزے کی نی",,,,,730
731,ام ہانی رضی الله عنہا کہتی ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس بیٹھی ہوئی تھی، اتنے میں آ,,,,,731
732,شعبہ کہتے ہیں کہ میں سماک بن حرب کو کہتے سنا کہ  ام ہانی رضی الله عنہا کے دونوں بیٹوں میں سے ایک نے ,,,,,732
733,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک دن میرے پاس آئے اور آ,,,,,733
734,"ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم میرے پاس آتے تو پوچھتے: ”ک",,,,,734
735,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  میں اور حفصہ دونوں روزے سے تھیں، ہمارے پاس کھانے کی ایک,,,,,735
736,ام المؤمنین ام سلمہ رضی الله عنہا کہتی ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو لگاتار دو مہینو,,,,,736
737,اس سند سے بھی  اسے ام المؤمنین عائشہ رضی الله عنہا نے نبی اکرم صلی اللہ علیہ وسلم سے روایت کیا ہے۔ \r,,,,,737
738,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب آدھا شعبان رہ جائے ت",,,,,738
739,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  میں نے ایک رات رسول اللہ صلی اللہ علیہ وسلم کو غائب پای,,,,,739
740,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ماہ رمضان کے بعد سب سے ا",,,,,740
741,"علی رضی الله عنہ کہتے ہیں کہ  ایک شخص نے ان سے پوچھا: ماہ رمضان کے بعد کس مہینے میں روزہ رکھنے کا آپ",,,,,741
742,عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہر ماہ کے شروع کے تین دن روز,,,,,742
743,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم میں سے کوئی جمعہ کے د",,,,,743
744,"عبداللہ بن بسر کی بہن بہیہ صمّاء رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ",,,,,744
745,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم سوموار اور جمعرات کے روزے ک,,,,,745
746,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک مہینہ ہفتہ  ( سنیچر ) ,,,,,746
747,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اعمال سوموار  ( دوشنبہ )",,,,,747
748,مسلم قرشی رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے صیام الدھر  ( سال بھر کے ,,,,,748
749,"ابوقتادہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”میں اللہ تعالیٰ سے امید ر",,,,,749
750,عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے عرفات میں روزہ نہیں رکھا،,,,,,750
751,ابونجیح یسار کہتے ہیں کہ  ابن عمر رضی الله عنہما سے عرفہ کے دن عرفات میں روزہ رکھنے کے بارے میں پوچھ,,,,,751
752,"ابوقتادہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”میں اللہ سے امید رکھتا ہو",,,,,752
753,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  عاشوراء ایک ایسا دن تھا کہ جس میں قریش زمانہ جاہلیت میں,,,,,753
754,حکم بن اعرج کہتے ہیں کہ  میں ابن عباس کے پاس پہنچا، وہ زمزم پر اپنی چادر کا تکیہ لگائے ہوئے تھے، میں,,,,,754
755,عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے دسویں تاریخ کو عاشوراء ک,,,,,755
756,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو ذی الحجہ کے دس دن,,,,,756
757,"عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ذی الحجہ کے دس ",,,,,757
758,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”ذی الحجہ کے  ( ابتدائی",,,,,758
759,"ابوایوب انصاری رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جس نے رمضان کے روزے",,,,,759
760,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مجھ سے تین باتوں کا عہد لیا: ۱- می",,,,,760
761,"ابوذر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”ابوذر! جب تم ہر ماہ کے تین ",,,,,761
