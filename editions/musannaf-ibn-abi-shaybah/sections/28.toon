hadiths[320]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
31359,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ ، قَالَ : حَدَّثَنَا أَبُو بَکْرِ ، قَالَ :\n\n حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ شُرَحْبِیلَ بْنِ مُسْلِمٍ ، قَالَ : سَمِعْتُ أَبَا أُمَامَۃَ الْبَاہِلِیَّ یَقُولُ : سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی خُطْبَتِہِ عَامَ حَجَّۃِ الْوَدَاعِ یَقُولُ : إنَّ اللَّہَ قَدْ أَعْطَی کُلَّ ذِی حَقٍّ حَقَّہُ ، فَلاَ وَصِیَّۃَ لِوَارِثٍ۔",,,31359
31360,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ غَنْمٍ ، عَنْ عَمْرِو بْنِ خَارِجَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ وَصِیَّۃَ لِوَارِثٍ۔",,,31360
31361,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنْ حَجَّاجٍ، عَنْ أَبِی إِسْحَاقَ، عَنِ الْحَارِثِ، عَنْ عَلِیٍّ، قَالَ: لَیْسَ لِوَارِثٍ وَصِیَّۃٌ۔",,,31361
31362,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرٍو ، عَنْ عَبْدِ اللہِ بْنِ بَدْرٍ ، قَالَ : سَأَلَ رَجُلٌ ابْنَ عُمَرَ ، فَقَالَ : یَا ابْنَ عُمَرَ مَا تَرَی فِی الْوَصِیَّۃِ لِلْوَارِثِ ؟ فَانْتَہَرَہُ وَقَالَ : ہَلْ قَارَبْت الْحَرُورِیَّۃَ ، فَقَالَ : لاَ تَجُوزُ الْوَصِیَّۃُ لِلْوَارِثِ۔",,,31362
31363,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ وَابْنِ سِیرِینَ، قَالاَ: لَیْسَ لِوَارِثٍ وَصِیَّۃٌ إلاَّ إنْ یَشَائَ الْوَرَثَۃُ۔",,,31363
31364,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی مِسْکِینٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لَیْسَ لِوَارِثٍ وَصِیَّۃٌ۔",,,31364
31365,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَوْصَی الرَّجُلُ بِوَصِیَّۃَ لِوَارِثٍ ، فَأَجَازَ الْوَرَثَۃُ قَبْلَ أَنْ یَمُوتَ ، ثُمَّ رَجِعَ الْوَرَثَۃُ بَعْدَ مَوْتِہِ ، فَہُمْ عَلَی رَأْسِ أَمْرِہِمْ ، وَإِذَا کَانَ لِغَیْرِ وَارِثٍ زِیَادَۃ عَلَی الثُّلُثِ فَمِثْلُ ذَلِکَ ، وَإِذَا کَانَتْ لِغَیْرِ وَارِثٍ مَا بَیْنَہُ وَبَیْنَ الثُّلُثِ فَإِنَّہَا جَائِزَۃٌ۔",,,31365
31366,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ، قَالَ : إذَا اسْتَأْذَنَ الرَّجُلُ وَرَثَتَہُ فِی الْوَصِیَّۃِ فَأَوْصَی بِأَکْثَرَ مِنَ الثُّلُثِ ، فَطَیَّبُوا لَہُ ، فَإِذَا نَفَضُوا أَیْدِیَہُمْ مِنْ قَبْرِہِ فَہُمْ عَلَی رَأْسِ أَمْرِہِمْ ، إنْ شَاؤُوا أَجَازُوا ، وَإِنْ شَاؤُوا لَمْ یُجِیزُوا۔",,,31366
31367,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ صَالِحِ بْنِ مُسْلِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَأَلْتُہ ؟ فَقَالَ : ہُمْ عَلَی رَأْسِ أَمْرِہِمْ۔",,,31367
31368,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوسٍ ، عَنْ أَبِیہِ ، قَالَ : یَرْجِعُونَ إنْ شَاؤُوا۔",,,31368
31369,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : فِی رَجُلٍ أَوْصَی بِأَکْثَرَ مِنَ الثُّلُثِ بِرِضًا مِنَ الْوَرَثَۃِ ، فَلَمَّا مَاتَ أَنْکَرُوا ذَلِکَ ، قَالَ : ہُوَ جَائِزٌ عَلَیْہِمْ۔",,,31369
31370,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : کَانَ عَطَائٌ یَقُولُ : جَائِزٌ ، قَدْ أَذِنُوا۔",,,31370
31371,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ : أَنَّہُ قَالَ : فِی الرَّجُلِ یُوصِی بِأَکْثَرَ مِنَ الثُّلُثِ یُجِیزُہُ الْوَرَثَۃُ ، ثُمَّ یَرْجِعُونَ فِیہِ ؟ قَالَ : لَیْسَ لَہُمْ أَنْ یَرْجِعُوا ، وَقَالَ الْحَکَمُ : إنْ شَاؤُوا رَجَعُوا فِیہِ۔",,,31371
31372,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ، قَالَ : إذَا أَوْصَی الرَّجُلُ فَزَادَ عَلَی الثُّلُثِ فَاسْتَأْذَنَ ابْنَہُ فِی حَیَاتِہِ فَأَذِنَ لَہُ ، فَإِذَا مَاتَ فَعَادَ إلَی ابْنِہِ ، إنْ شَائَ أَجَازَہُ وَإِنْ شَائَ رَدَّہُ۔",,,31372
31373,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنْ أَبِی عَوْنٍ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ : أَنَّ رَجُلاً اسْتَأْذَنَ وَرَثَتَہُ فِی مَرَضِہِ فِی أَنْ یُوصِیَ بِأَکْثَرَ مِنَ الثُّلُثِ فَأَذِنُوا لَہُ ، فَلَمَّا مَاتَ رَجَعُوا ، فَسُئِلَ ابْنُ مَسْعُودٍ عَنْ ذَلِکَ ؟ فَقَالَ : ذَلِکَ لَہُمْ ، ذَلِکَ التَّکَرُّہُ لاَ یَجُوزُ۔",,,31373
31374,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ عَامِرٍ۔ وَعَنْ خَالِدٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ شُرَیْحٍ ، قَالَ : إذَا أَوْصَی الرَّجُلُ فِی مَرَضِہِ بِأَکْثَرَ مِنَ الثُّلُثِ لِغَیْرِ وَارِثٍ أَوْ لِوَارِثٍ ، فَأَذِنَ الْوَرَثَۃُ ، ثُمَّ مَاتَ فَلَہُمْ أَنْ یَرْجِعُوا۔",,,31374
31375,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ یَزِیدَ أَبِی خَالِدٍ الدَّالاَنِیِّ ، قَالَ : سَمِعْتُ أَبَا عَوْنٍ مُحَمَّدِ بْنِ عُبَیْدِ اللہِ یُحَدِّثُ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ : أَنَّہُ قَالَ ؛ فِی الرَّجُلِ یُوصِی بِأَکْثَرَ مِنَ الثُّلُثِ یُجِیزُہُ الْوَارِثُ ، ثُمَّ لاَ یُجِیزُہُ بَعْدَ مَوْتِہِ ، قَالَ : ذَلِکَ التَّکَرُّہُ لاَ یَجُوزُ۔",,,31375
31376,"حَدَّثَنَا عَبْدُ الأَعْلَی ، أَوْ ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا أَوْصَی بِوَصِیَّۃٍ ، ثُمَّ أَوْصَی بِأُخْرَی بَعْدَہَا ، قَالَ : یُؤْخَذُ بِالأُخْرَی مِنْہُمَا۔",,,31376
31377,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ عَمْرِو بْنِ دِینَارٍ، عَنْ عَطَائٍ وَطَاوُوسٍ وَأَبِی الشَّعْثَائِ ، قَالُوا : یُؤْخَذُ بِآخِرِ وَصِیَّۃٍ۔",,,31377
31378,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ : أَنَّ رَجُلاً أَوْصَی فَدَعَا نَاسًا ، فَقَالَ : أُشْہِدُکُمْ أَنَّ غُلاَمِی فُلاَنًا إنْ حَدَثَ بِی حَدَثٌ فَہُوَ حُرٌّ ، فَخَرَجُوا مِنْ عِنْدِہِ فَقِیلَ لَہُ : أَعْتَقْت فُلاَنًا وَتَرَکْت فُلاَنًا وَکَانَ أَحْسَنَ بَلاَئً ، فَقَالَ : رُدُّوا عَلَیَّ الْبَیِّنَۃَ ، أُشْہِدُکُمْ أَنِّی قَدْ رَجَعْت فِی عِتْقِ فُلاَنٍ ، وَأَنَّ فُلاَنًا لِعَبْدِہِ الآخَرِ إنْ حَدَثَ بِی حَدَثٌ فَہُوَ حُرٌّ ، فَمَاتَ الرَّجُلُ ، فَقَالَ الأَوَّلُ : أَنَا حُرٌّ ، وَقَالَ الآخَرُ : أَنَا حُرٌّ ، فَاخْتَصَمَا إلَی عَبْدِ الْمَلِکِ بْنِ مَرْوَانَ ، فَرَدَّ عِتْقَ الأَوَّلِ وَأَجَازَ عِتْقَ الآخَرِ۔",,,31378
31379,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إذَا أَوْصَی الرَّجُلُ بِوَصِیَّۃٍ ، ثُمَّ نَقَضَہَا فَہِیَ الآخِرَۃُ ، وَإِنْ لَمْ یَنْقُضْہَا فَإِنَّہُمَا تَجُوزَانِ جَمِیعًا فِی ثُلُثِہِ بِالْحِصَصِ۔",,,31379
31380,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ : أَنَّ ابْنَ أَبِی رَبِیعَۃَ کَتَبَ إلَی عُمَرَ بْنِ الْخَطَّابِ : فِی الرَّجُلُ یُوصِی بِوَصِیَّۃٍ ثُمَّ یُوصِی بِأُخْرَی ، قَالَ : أَمْلَکُہُمَا آخِرُہُمَا۔",,,31380
31381,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ : فِی رَجُلٍ أَوْصَی لِرَجُلٍ فَمَاتَ الَّذِی أُوصِیَ لَہُ قَبْلَ أَنْ تَأْتِیَہُ ، قَالَ : ہِیَ لِوَرَثَۃِ الْمُوصَی لَہُ۔",,,31381
31382,"حَدَّثَنَا حَفْصٌ ، قَالَ سَأَلَتْ عَمْرًا عَنْہُ ، قَالَ : کَانَ الْحَسَنُ یَقُولُ : ہِیَ لِوَرَثَۃِ الْمُوصَی لَہُ۔",,,31382
31383,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَوْصَی لِرَجُلٍ وَہُوَ مَیِّتٌ یَوْمَ یُوصِی لَہُ فَإِنَّ الْوَصِیَّۃَ تَرْجِعُ إلَی وَرَثَۃِ الْمُوصِی ، وَإِذَا أَوْصَی لِرَجُلٍ ثُمَّ مَاتَ فَإِنَّ الْوَصِیَّۃَ لِوَرَثَۃِ الْمُوصَی لَہُ۔",,,31383
31384,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : لاَ وَصِیَّۃَ لِمَیِّتٍ۔",,,31384
31385,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ قَالَ : لاَ وَصِیَّۃَ لِمَیِّتٍ۔",,,31385
31386,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ : فِی الرَّجُلِ یُوصِی بِالْوَصِیَّۃِ فَیَمُوتُ الَّذِی أُوصِیَ لَہُ قَبْلَ الَّذِی أَوْصَی ، قَالَ : لَیْسَ لَہُ شَیْئٌ ، أَنَّہُ أَوْصَی لَہُ وَہُوَ مَیِّتٌ۔",,,31386
31387,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ : فِی الرَّجُلِ یُوصِی بِالْوَصِیَّۃِ فَیَمُوتُ الْمُوصَی لَہُ قَبْلَ الَّذِی أَوْصَی ، قَالَ : تَبْطُلُ ، وَإِنْ مَاتَ الَّذِی أَوْصَی ، ثُمَّ الَّذِی أُوصِیَ لَہُ ، کَانَ لِوَرَثَتِہِ۔",,,31387
31388,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : فِی رَجُلٍ أَوْصَی لِرَجُلٍ بِثُلُثِ مَالِہِ وَأَفَادَ مَالاً قَبْلَ أَنْ یَمُوتَ ثُمَّ مَاتَ ، قَالَ : لَہُ ثُلُثُ الَّذِی أَوْصَی لَہُ ، وَلَہُ ثُلُثُ مَا أَفَادَ۔",,,31388
31389,"حَدَّثَنَا حَفْصٌ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، عَنْ عَلِیٍّ : فِی رَجُلٍ أَوْصَی بِثُلُثِ مَالِہِ وَقُتِلَ خَطَأً، قَالَ : الثُّلُثُ دَاخِلٌ فِی دِیَتِہِ۔",,,31389
31390,"حَدَّثَنَا حَفْصٌ، عَنْ أَشْعَثَ، عَنْ أَبِی إِسْحَاقَ، عَنِ الْحَارِثِ، عَنْ عَلِیٍّ ، قَالَ: لَہُ ثُلُثُ مَالِہِ ، وَثُلُثُ دِیَتِہ۔",,,31390
31391,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ : فِی الرَّجُلِ أَوْصَی بِثُلُثِ مَالِہِ فَقُتِلَ خَطَأً ، قَالَ : یَدْخُلُ ثُلُثُ الدِّیَۃِ فِی ثُلُثِ مَالِہِ۔",,,31391
31392,"حَدَّثَنَا عَبَّادٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَہْلُ الْوَصِیَّۃِ شُرَکَائُ فِی الْوَصِیَّۃِ ، إنْ زَادَتْ وَإِنْ نَقَصَتْ ، قَالَ : فَأَخْبَرْت بِہِ ابْنَ سِیرِینَ فَأَعْجَبَہُ ذَلِکَ۔",,,31392
31393,"حَدَّثَنَا زَیْدُ بْنُ حُبَابِ ، عَنِ ابْنِ لَہِیعَۃَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ : فِی رَجُلٍ أَوْصَی لِرَجُلٍ بِوَصِیَّۃٍ ، ثُمَّ جَائَہُ مَالٌ أَوْ أَفَادَ مَالاً ، قَالَ : لاَ یَدْخُلُ فِیہِ۔",,,31393
31394,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَوْصَی الرَّجُلُ لِلرَّجُلِ بِخَمْسِینَ دِرْہَمًا عُجِّلَتْ لَہُ مِنَ الْعَیْنِ ، وَإِذَا أَوْصَی بِثُلُثٍ أَوْ رُبُعٍ کَانَ فِی الْعَیْنِ وَالدَّیْنِ۔",,,31394
31395,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ : فِی الرَّجُلِ یُوصِی لِلرَّجُلِ بِخَمْسِینَ دِرْہَمًا مِنْ مَالِہِ ، قَالَ : یُعَجِّلُ لَہُ مَا بَیْنَہُ وَبَیْنَ ثُلُثِ الْعَیْنِ۔",,,31395
31396,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ یَعْقُوبَ ، عَنْ عَطَائٍ وَقَتَادَۃَ۔ وَعَنْ مَطَرٍ ، عَنِ الْحَسَنِ : فِی رَجُلٍ أَوْصَی لِبَنِی عَمِّہِ رِجَالٍ وَنِسَائٍ ، قَالُوا لِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَی ، إلاَّ أَنْ یَکُونَ قَالَ : {لِلذَّکَرِ مِثْلُ حَظِّ الأُنْثَیَیْنِ}۔",,,31396
31397,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ طَلْحَۃَ بْنِ الأَعْلَمِ الْحَنَفِیِّ ، عَنِ الشَّعْبِیِّ : أَنَّ رَجُلاً أَوْصَی لأَرَامِلَ بَنِی حَنِیفَۃَ ، فَقَالَ الشَّعْبِیُّ : ہُوَ لِلرِّجَالِ وَالنِّسَائِ مِمَّنْ خَرَجَ مِنْ کَمَرَۃِ حَنِیفَۃَ۔",,,31397
31398,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ وُہَیْبٍ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : فِی الرَّجُلِ یَقُولُ : لِبَنِی فُلاَنٍ کَذَا وَکَذَا ، قَالَ : ہُوَ لِغَنِیِّہِمْ وَفَقِیرِہِمْ وَذَکَرِہِمْ وَأُنْثَاہُمْ۔",,,31398
31399,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ عَبْدِ اللہِ بْنِ جَعْفَرٍ ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ ، قَالَ : سَأَلْتُ الْقَاسِمَ عْن رَجُلٍ کَانَتْ لَہُ مَسَاکِنُ فَأَوْصَی بِثُلُثِ کُلِّ مَسْکَنٍ لَہُ ؟ قَالَ : یُخْرَجُ حَتَّی یَکُونَ فِی مَسْکَنٍ وَاحِدٍ۔",,,31399
31400,"حَدَّثَنَا یَعْلَی ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ : فِی رَجُلٍ أَوْصَی بِثُلُثِ مَالِہِ وَأَشْیَائَ سِوَی ذَلِکَ ، وَتَرَکَ دَارًا تَکُونُ ثُلُثُہَا ، أَیُعْطَاہَا الْمُوصَی لَہُ بِالثُّلُثِ ، قَالَ : لاَ وَلَکِنْ یُعْطَی بِالْحِصَّۃِ مِنَ الْمَالِ وَالدَّارِ۔",,,31400
31401,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ وَحَمَّادٌ ، عَنْ إبْرَاہِیمَ : أَنَّہُ سُئِلَ عَنْ رَجُلٍ ، قَالَ : ثُلُثَیْ ثَلاَثُمِئَۃ دِرْہَمٍ : مِئَۃٌ لِفُلاَنٍ ، وَمِئَۃٌ لِفُلاَنٍ ، وَمَا بَقِیَ مِنْ ثُلُثی ؛ فَہُوَ لِفُلاَنٍ ، قَالَ : فَلِفُلاَنٍ مِئَۃٌ ، وَلِفُلاَنٍ مِئَۃٌ ، وَمَا بَقِیَ فَلِفُلاَنٍ ، وَإِنْ لَمْ یَبْقَ شَیْئٌ ، فَلَیْسَ بِشَیْئٍ۔",,,31401
31402,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ : فِی رَجُلٍ أَوْصَی ، قَالَ : ثُلُثَیْ لِفُلاَنٍ ، فَإِنْ مَاتَ فَہُوَ لِفُلاَنٍ ، قَالَ : ہُوَ لِلأَوَّلِ۔",,,31402
31403,"حَدَّثَنَا زَیْدُ بْنُ الحُبَابٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : ہُوَ لِلأَوَّلِ۔",,,31403
31404,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ حَمَّادٍ ، عَنْ قَتَادَۃَ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : یُجْرِی کَمَا قَالَ۔",,,31404
31405,حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ حَمَّادٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، مِثْلَہُ۔,,,31405
31406,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : بَلَغَنِی أَنَّ صَفِیَّۃَ أَوْصَتْ لِقَرَابَۃٍ لَہَا بِمَالٍ عَظِیمٍ، وَکَثِیرٍ مِنَ الْیَہُودِ کَانُوا وَرَثَتَہَا لَوْ کَانُوا مُسْلِمِینَ فَوَرِثَہَا غَیْرُہُمْ مِنَ الْمُسْلِمِینَ وَجَازَ لَہُمْ مَا أَوْصَتْ۔",,,31406
31407,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ : أَنَّ صَفِیَّۃَ أَوْصَتْ لِقَرَابَۃٍ لَہَا یَہُود۔",,,31407
31408,"حَدَّثَنَا مُعَاذٌ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، قَالَ : وَصِیَّۃُ الرَّجُلِ جَائِزَۃٌ لِذِمِّیٍّ کَانَ أَوْ لِغَیْرِہِ۔",,,31408
31409,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یَقُولُ : الْوَصِیَّۃُ لِلْیَہُودِیِّ وَالنَّصْرَانِیِّ وَالْمَجُوسِیِّ وَالْمَمْلُوکِ جَائِزَۃً۔",,,31409
31410,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ : أَنَّ امْرَأَۃً مِنْ أَزْوَاجِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَوْصَتْ لِقَرَابَۃٍ لَہَا مِنَ الْیَہُودِ۔",,,31410
31411,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنْ جَابِرٍ، عَنْ عَامِرٍ، قَالَ: لاَ بَأْسَ أَنْ یُوصَی لِلْیَہُودِیِّ وَالنَّصْرَانِیِّ۔",,,31411
31412,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ {إلاَّ أَنْ تَفْعَلُوا إلَی أَوْلِیَائِکُمْ مَعْرُوفًا} قَالَ : أَوْلِیَائِکَ مِنْ أَہْلِ الْکِتَابِ ، یَقُولُ : وَصِیَّۃٌ وَلاَ مِیرَاثَ لَہُمْ۔",,,31412
31413,"حَدَّثَنَا عُمَرُ بْنُ ہَارون، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ: سَمِعَہُ وَہُوَ یُسْأَلُ عَنِ الْوَصِیَّۃِ لأَہْلِ الشِّرْکِ؟ قَالَ : لاَ بَأْسَ بِہَا۔",,,31413
31414,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ : أَنَّ عُمَرَ أَوْصَی إلَی حَفْصَۃَ۔",,,31414
31415,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا أَبُو جَنَابٍ، عَنْ أَبِی عَوْنٍ الثَّقَفِیِّ: أَنَّ رَجُلاً أَوْصَی إلَی امْرَأَتِہِ، فَأَجَازَ ذَلِکَ شُرَیْحٌ۔",,,31415
31416,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُمَرَ بْنِ عَمْرٍو الأَزْدِیِّ ، قَالَ : حدَّثَتْنِی خَالَتِی ، وَکَانَتِ امْرَأَۃُ إبْرَاہِیمَ ، قَالَتْ : أَوْصَی إلَیَّ إبْرَاہِیمُ بِشَیْئٍ مِنْ وَصِیَّتِہِ۔",,,31416
31417,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : لاَ تَکُونُ الْمَرْأَۃُ وَصِیًّا ، فَإِنْ فَعَلَ نُظِرَ إلَی رَجُلٍ یَوْثقُ بِہِ ، فَجُعِلَ ذَلِکَ إلَیْہِ",,,31417
31418,"وَسَمِعْت وَکِیعًا یَقُولُ : قَالَ سُفْیَانُ : تَکُونُ وَصِیًّا ، رُبَّ امْرَأَۃٍ خَیْرٌ مِنْ رَجُلٍ۔",,,31418
31419,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَعْمَرٍ ، عَنْ رَجُلٍ ، عَنْ عِکْرِمَۃَ : فِی رَجُلٍ أَوْصَی وَصِیَّۃً لِلْمُحْوِجِینَ ، قَالَ : یُجْعَلُ فِی الْقَرَابَۃِ ، فَإِنْ لَمْ یَکُونُوا فَللْمَوَالِی ، فَإِنْ لَمْ یَکُونُوا فَللْجِیرَانِ۔",,,31419
31420,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، قَالَ : قَالَ عُبَیْدُ اللہِ بْنُ عَبْدِ اللہِ بْنِ مَعْمَرٍ فِی الْوَصِیَّۃِ : مَنْ سَمَّی : جَعَلْنَاہَا حَیْثُ سَمَّی ، وَمَنْ قَالَ حَیْثُ أَمَرَ اللَّہُ : جَعَلْنَاہَا فِی قَرَابَتِہِ۔ (عبدالرزاق 16430)",,,31420
31421,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، عَنِ الْحَسَنِ : فِی الرَّجُلِ یُوصِی لِلأَبَاعِدِ وَیَتْرُکُ الأَقَارِبَ ، قَالَ : تُجْعَلُ وَصِیَّتُہُ ثَلاَثَۃُ أَثْلاَثٍ : لِلأَقَارِبِ ثُلُثَانِ ، وَلِلأَبَاعِدِ ثُلُثٌ ، وَأَمَّا مُحَمَّدُ بْنُ کَعْبٍ ، فَقَالَ : إنَّمَا ہُوَ مَالٌ ، أَعْطَاہُ اللَّہُ ، یَضَعُہُ حَیْثُ أَحَبَّ۔",,,31421
31422,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ حُمَیْدٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : ضَعُوہَا حَیْثُ أَمَرَ بِہَا۔",,,31422
31423,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہَمَّامٍ : أَنَّ قَتَادَۃَ سُئِلَ عَنِ الرَّجُلِ یُوصِی لِغَیْرِ قَرَابَتِہِ ؟ قَالَ : کَانَ سَالِمٌ وَسُلَیْمَانُ بْنُ یَسَارٍ وَعَطَائٌ یَقُولُونَ : ہِیَ لِمَنْ أُوصِی لَہُ بِہَا۔",,,31423
31424,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ : أَوْصَی إِنْسَانٌ فِی سَبِیلِ اللہِ ، وَفِی الْمَسَاکِینِ ، وَتَرَکَ قَرَابَۃً مُحْتَاجِینَ ؟ قَالَ : وَصِیَّتُہُ حَیْثُ أَوْصَی بِہَا۔",,,31424
31425,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَ : أَمَرَہُمْ بِأَمْرٍ فَإِنْ خَالَفُوا جَازَ وَبِئْسَ مَا صَنَعُوا ، وَقَدْ کَانَ عَطَاء قَالَ : ذُو الْقَرَابَۃِ أَحَقُّ بِہَا۔",,,31425
31426,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا إسْرَائِیلُ، عَنْ جَابِرٍ، عَنْ عَامِرٍ، قَالَ: لِلرَّجُلِ ثُلُثُہُ، یَطْرَحُہُ فِی الْبَحْرِ إنْ شَائَ۔",,,31426
31427,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ : فِی الرَّجُلِ یُوصِی لِلأَبَاعِدِ وَیَتْرُکُ الأَقَارِبَ ، قَالَ : تُجْعَلُ وَصِیَّتُہُ ثَلاَثَۃَ أَثْلاَثٍ : لِلأَقَارِبِ ثُلُثَانِ ، وَلِلأَبَاعِدِ ثُلُثٌ۔",,,31427
31428,"حَدَّثَنَا الضَّحَّاکُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : کَانَ لاَ یَرَی الْوَصِیَّۃَ إلاَّ لِذَوِی الأَرْحَامِ أَہْلِ الْفَقْرِ ، فَإِنْ أَوْصَی بِہَا لِغَیْرِہِمْ إنْتُزِعَتْ مِنْہُمْ فَرُدَّتْ إلَیْہِمْ ، فَإِنْ لَمْ یَکُنْ فِیہِمْ فُقَرَائُ فَلأَہْلِ الْفَقْرِ مَا کَانُوا ، وَإِنْ سَمَّی أَہْلُہَا الَّذِینَ أُوصِی لَہُمْ۔",,,31428
31429,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَطَائِ بْنِ أَبِی مَیْمُونَۃَ ، قَالَ : سَأَلْتُ الْعَلاَئَ بْنَ زِیَادٍ وَمُسْلِمَ بْنَ یَسَارٍ عَنِ الْوَصِیَّۃِ ؟ فَدَعَا بِالْمُصْحَفِ فَقَرَأَ : {إنْ تَرَکَ خَیْرًا الْوَصِیَّۃُ لِلْوَالِدَیْنِ وَالأَقْرَبِینَ} قَالاَ: ہِیَ لِلْقَرَابَۃِ۔",,,31429
31430,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ ہَمَّامِ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ وَعَبْدِ الْمَلِکِ بْنِ یَعْلَی ، قَالاَ : تُرَدُّ عَلَی قَرَابَتِہِ۔",,,31430
31431,"حَدَّثَنَا حَفْصٌ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ : أَنَّ أَبَا طَلْحَۃَ أَتَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالَ : یَا رَسُولَ اللہِ ، إنِّی جَعَلْت حَائِطِی لِلَّہِ ، وَلَوَ اسْتَطَعْت أَنْ أُخْفِیَہُ لَمْ أُظْہِرْہُ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اجْعَلْہُ فِی فُقَرَائِ أَہْلِک۔ (مسلم 285۔ ابوداؤد 1686)",,,31431
31432,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَقُولُ : فِی الرَّجُلِ إذَا أَوْصَی فِی مَرَضِہِ ، ثُمَّ بَرَأَ فَلَمْ یُغَیِّرْ وَصِیَّتَہُ تِلْکَ حَتَّی یَمُوتَ بَعْدُ ، قَالَ : یُؤْخَذُ بِمَا فِیہَا۔",,,31432
31433,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ یَعْلَی : فِی رَجُلٍ أَوْصَی بِوَصِیَّۃٍ فِی مَرَضِہِ فَبَرَأَثُمَّ تَرَکَہَا حَتَّی مَاتَ ، قَالَ : جَائِزَۃٌ۔",,,31433
31434,"حَدَّثَنَا حَفْصٌ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، قَالَ : سُئِلَ عَامِرٌ عَنْ رَجُلٍ مَاتَ وَتَرَکَ ثَلاَثَۃَ بَنِینَ ، وَأَوْصَی بِمِثْلِ نَصِیبِ أَحَدِہِمْ ؟ قَالَ : ہُوَ رَابِعٌ ، لَہُ الرُّبْعُ۔",,,31434
31435,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ وَالأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا تَرَکَ الرَّجُلُ ثَلاَثَۃَ بَنِینَ وَأَوْصَی بِمِثْلِ نَصِیبِ أَحَد بَنِیہِ ، قَالَ : زِدْ وَاحِدًا اجْعَلْہَا مِنْ أَرْبَعَۃٍ۔",,,31435
31436,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : زِدْ وَاحِدًا وَاجْعَلْہَا مِنْ أَرْبَعَۃٍ۔",,,31436
31437,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ : فِی رَجُلٍ تَرَکَ ابْنَیْنِ وَأَبَوَیْنِ ، وَأَوْصَی بِمِثْلِ نَصِیبِ أَحَدِ الاِبْنَیْنِ ، قَالَ ، ہِیَ مِنْ ثَمَانِیَۃٍ۔",,,31437
31438,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ مَنْصُورٍ وَمُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : فِی رَجُلٍ تَرَکَ سِتَّۃَ بَنِینَ وَأَوْصَی بِمِثْلِ نَصِیبِ بَعْضِ وَلَدِہِ ، قَالَ : قَالَ مَنْصُورٌ : ہِیَ مِنْ سَبْعَۃٍ ، یَدْخُلُ مَعَہُمْ ، وَقَالَ مُغِیرَۃُ : یُنْقَصُ وَلاَ یُتَمُّ لَہُ مِثْلُ نَصِیبِ أَحَدِہِمْ۔",,,31438
31439,"حَدَّثَنَا أَبُو مُعَاویَۃ ، حَدَّثَنَا أَبُو عَاصِمٍ الثَّقَفِیُّ ، قَالَ : لَقِیَنِی إبْرَاہِیمُ فَقَالَ : مَا تَقُولُ فِی رَجُلٍ أَوْصَی بِنِصْفِہِ وَثُلُثِہِ وَرُبْعِہِ ، قَالَ : فَلَمْ یَکُنْ عِنْدِی فِیہَا شَیْئٌ ، فَقَالَ : إبْرَاہِیمُ ، خُذْ مَالاً لَہُ نِصْفٌ وَثُلُثٌ وَرُبْعٌ : اثْنَا عَشَرَ فَخُذْ نِصْفَہَا سِتَّۃً وَثُلُثَہَا أَرْبَعَۃً وَرُبْعَہَا ثَلاَثَۃً ، فَاقْسِمَ الْمَالَ عَلَی ثَلاَثَۃَ عَشَرَ ، فَمَا أَصَابَ سِتَّۃً کَانَ لِصَاحِبِ النِّصْفِ ، وَمَا أَصَابَ أَرْبَعَۃً کَانَ لِصَاحِبِ الثُّلُثِ ، وَمَا أَصَابَ ثَلاَثَۃً کَانَ لِصَاحِبِ الرُّبْعِ۔",,,31439
31440,"حَدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یُوصِیَ الرَّجُلُ بِمِثْلِ نَصِیبِ أَحَدِ الْوَرَثَۃِ حَتَّی یَکُونَ أَقَلَّ۔",,,31440
31441,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا عُبَادَۃُ الصَّیْدَلاَنِیُّ ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ : أَنَّہُ أَوْصَی بِمِثْلِ نَصِیبِ أَحَدِ وَلَدِہِ۔",,,31441
31442,"حَدَّثَنَا وَکِیعٌ حَدَّثَنَا زَائِدَۃُ أَبُو قُتَیْبَۃَ الْہَمْدَانِیُّ ، عَنْ یَسَارِ بْنِ أَبِی کَرِبٍ ، عَنْ شُرَیْحٍ : أَنَّہُ قَضَی فِی رَجُلٍ أَوْصَی لِرَجُلٍ بِسَہْمٍ مِنْ مَالِہِ وَلَمْ یُسَمِّ ، قَالَ : تُرْفَعُ السِّہَامُ فَیَکُونُ لِلْمُوصَی لَہُ سَہْمٌ۔",,,31442
31443,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ رَجُلٍ مِنْ أَہْلِ خُرَاسَانَ ، عَنْ عِکْرِمَۃَ ، قَالَ : لَیْسَ لَہُ شَیْئٌ ، ہَذَا مَجْہُولٌ۔",,,31443
31444,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ یَعْقُوبَ بْنِ الْقَعْقَاعِ ، عَنْ عَطَائٍ۔ وَیَعْقُوبَ ، عَنْ مُحَمَّدِ بْنِ صُہَیْبٍ ، عَنْ عِکْرِمَۃَ : فِی رَجُلٍ أَوْصَی لِرَجُلٍ بِسَہْمٍ مِنْ مَالِہِ ، قَالَ : لَیْسَ بِشَیْئٍ ، لَمْ یُبَیِّنْ۔",,,31444
31445,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ أَیُّوبَ ، عَنْ إیَاسِ بْنِ مُعَاوِیَۃَ ، قَالَ : کَانَتِ الْعَرَبُ تَقُولُ : لَہُ السُّدُسُ۔",,,31445
31446,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ ، عَنْ أَبِی قَیْسٍ ، عَنِ الْہُزَیْلِ : أَنَّ رَجُلاً جَعَلَ لِرَجُلٍ سَہْمًا مِنْ مَالِہِ وَلَمْ یُسَمِّ ، فَقَالَ عَبْدُ اللہِ : لَہُ السُّدُسُ۔",,,31446
31447,"حَدَّثَنَا عَفَّانُ ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ حُمَیْدٍ : أَنْ عَدِیًّا سَأَلَ إیَاسًا ؟ فَقَالَ : السَّہْمُ فِی کَلاَمُ الْعَرَبِ السُّدُسُ۔",,,31447
31448,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ خِلاَسٍ ، أَنَّ امْرَأَۃً قِیلَ لَہَا فِی مَرَضِہَا : أَوْصِی بِکَذَا ، أَوْصِی بِکَذَا ، فَأَوْمَأَتْ بِرَأْسِہَا ، فَلَمْ یُجِزْہُ عَلِیُّ بْنُ أَبِی طَالِبٍ۔",,,31448
31449,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ حُسَیْنِ الْمُعَلِّمِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ بْنِ أَبِی رَبِیعَۃَ ، أَو الْحَارِثِ بْنِ عَبْدِ اللہِ بْنِ أَبِی رَبِیعَۃَ ، قَالَ : قُلْتُ لِعُمَرَ : شَیْئٌ یَصْنَعُہُ أَہْلُ الْیَمَنِ ، یُوصِی الرَّجُلُ، ثُمَّ یُغَیِّرُ وَصِیَّتَہُ ، قَالَ : لِیُغَیِّرْ مَا شَائَ مِنْ وَصِیَّتِہِ۔",,,31449
31450,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ عُمَرُ : مَا أَعْتَقَ الرَّجُلُ فِی مَرَضِہِ مِنْ رَقِیقِہِ فَہِیَ وَصِیَّۃٌ إنْ شَائَ رَجَعَ فِیہَا۔",,,31450
31451,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُغَیِّرُ الرَّجُلُ مِنْ وَصِیَّتِہِ مَا شَائَ إلاَّ الْعَتَاقَۃ۔",,,31451
31452,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مُحَمَّدٍ الْمُحَارِبِیُّ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : کُلُّ وَصِیَّۃٍ إنْ شَائَ رَجَعَ فِیہَا غَیْرِ الْعَتَاقَۃَ۔",,,31452
31453,"حَدَّثَنَا ابْنُ مَہْدِی، عَنْ حَمَّادِ بْنِ سَلَمَۃَ، عَنْ حَجَّاجٍ، عَنِ الْحَکَمِ، عَنْ إبْرَاہِیمَ، قَالَ: إذَا أَوْصَی الرَّجُلُ بِوَصَایَا، وَأَعْتَقَ غُلاَمًا لَہُ إنْ حَدَثَ بِہِ حَدَثُ الْمَوْتِ، قَالَ: لاَ یَرْجِعُ فِی الْعِتْقِ؛ لَیْسَ الْعِتْق کَسَائِرِ الْوَصِیَّۃ۔",,,31453
31454,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا أَوْصَی الرَّجُلُ فَإِنَّہُ یُغَیِّرُ وَصِیَّتَہُ مَا شَائَ ، قِیلَ لَہُ : فَالْعَتَاقَۃُ ، قَالَ الْعَتَاقَۃُ وَغَیْرُ الْعَتَاقَۃِ ، وَإِنَّمَا یُؤْخَذُ بِآخِرِہَا۔",,,31454
31455,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ طَاوُوسٍ : أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَعُودَ الرَّجُلُ فِی عَتَاقِہِ۔",,,31455
31456,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ عَاصِمٍ ، قَالَ : مَرِضَ أَبُو الْعَالِیَۃَ فَأَعْتَقَ مَمْلُوکًا لَہُ ذَکَرُوا لَہُ أَنَّہُ مِنْ وَرَائِ النَّہَرِ ، فَقَالَ : إنْ کَانَ حَیًّا فَلاَ أُعْتِقُہُ ، وَإِنْ کَانَ مَیِّتًا فَہُوَ عَتِیقٌ ، وَذَکَرَ ہَذِہِ الآیَۃَ : {وَلَہُ ذُرِّیَّۃٌ ضُعَفَائُ}۔",,,31456
31457,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانُوا یُوصُونَ ، فَیَکْتُبُ الرَّجُلُ فِی وَصِیَّتِہِ : إنْ حَدَثَ بِی حَدَثٌ قَبْلَ أَنْ أُغَیِّرَ وَصِیَّتِی ہَذِہِ فَإِنْ بَدَا لَہُ أَنْ یُغَیِّرَ غَیَّرَ إنْ شَائَ الْعَتَاقَۃَ وَغَیْرَہَا ، فَإِنْ لَمْ یَسْتَثْنِ فِی وَصِیَّتِہِ غَیَّرَ مِنْہَا مَا شَائَ غَیْرَ الْعَتَاقَۃِ۔",,,31457
31458,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ رُوحِ بْنِ الْقَاسِمِ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ : کَانَ یُقْسِمُ عَلَیْہِ قَسَمًا ، أَنَّ الْمُعْتَقَ عَنْ دُبُرِ وَصِیَّۃٍ ، وَأَنَّ لِلرَّجُلِ أَنْ یُغَیِّرَ مِنْ وَصِیَّتِہِ مَا شَائَ۔",,,31458
31459,"حَدَّثَنَا سَعِیدُ بْنُ خُثَیْمٍ ، عَنْ حَنْظَلَۃَ ، عَنْ طَاوُوسٍ ، قَالَ : یَرْجِعُ مَوْلَی الْمُدَبَّرِ فِیہِ مَتَی شَائَ۔",,,31459
31460,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ نَافِعٍ ، قَالَ : قالَتْ عَائِشَۃُ : لِیَکْتُبَ الرَّجُلُ فِی وَصِیَّتِہِ : إنْ حَدَثَ بِی حَدَثٌ قَبْلَ أَنْ أُغَیِّرَ وَصِیَّتِی ہَذِہِ۔",,,31460
31461,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعُمَیْسِ ، عَنْ عَامِرِ بْنِ عَبْدِ اللہِ بْنِ الزُّبَیْرِ : أَنَّ ابْنَ مَسْعُودٍ أَوْصَی فَکَتَبَ فِی وَصِیَّتِہِ : بِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ ، ہَذَا مَا أَوْصَی بِہِ ابْنُ مَسْعُودٍ : إنْ حَدَثَ بِہِ حَدَثٌ فِی مَرَضِہِ ہَذَا۔",,,31461
31462,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانُوا یُوصُونَ فَیَکْتُبُ الرَّجُلُ فِی وَصِیَّتِہِ : إنْ حَدَثَ بِی حَدَثٌ قَبْلَ أَنْ أُغَیِّرَ وَصِیَّتِی ہَذِہِ۔",,,31462
31463,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ أَبِی خَلْدَۃَ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : أَوْصَیْت بِضْعَ عَشْرَ مَرَّۃٍ أُوَقِّت وَقْتًا إذَا جَائَ الْوَقْتُ کُنْت بِالْخِیَارِ۔",,,31463
31464,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی عُمَیْرٍ الْحَارِثُ بْنُ عُمَیْرٍ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ : أَنَّہُ کَانَ یَشْتَرِطُ : إنْ حَدَثَ بِی حَدَثٌ قَبْلَ أُغَیِّرَ کِتَابِی ہَذَا۔",,,31464
31465,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوس : أَنَّ رَجُلاً مِنْ أَہْلِ الْیَمَنِ أَوْصَی ، فَقَالَ : فُلاَنٌ حُرٌّ وَفُلاَنٌ حُرٌّ - وَلَمْ یُسَمِّ - إنْ مِتّ فِی مَرَضِی ہَذَا ، فَبَرَأَ الرَّجُلُ فَخَاصَمَہُ مَمْلُوکَاہُ إِلَی قَاضِی أَہْلِ الْجَنَدِ ، فَشَاوَرَ فِی ذَلِکَ طَاوُوسًا ، فَقَالَ طَاوُوس : ہُمْ عَبِیدٌ ، إنَّمَا کَانَتْ نِیَّتُہُ : إنْ حَدَثَ بِہِ حَدَثٌ۔",,,31465
31466,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ : أَنَّہُ سُئِلَ عَنْ رَجُلٍ أَوْصَی بِجَارِیَتِہِ لاِبْنِ أَخِیہِ ، ثُمَّ وَطِئَہَا ؟ قَالَ : أَفْسَدَ وَصِیَّتَہُ۔",,,31466
31467,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَوْصَی بِہِمَا فَہُمَا مِنَ الثُّلُثِ۔ یَعْنِی : الْحَجَّ وَالزَّکَاۃَ۔",,,31467
31468,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَوْصَی بِحَجَّۃ وَلَمْ یَکُنْ حَجَّ فَمِنَ الثُّلُثِ۔",,,31468
31469,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : مِنَ الثُّلُثِ۔",,,31469
31470,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ وَمَنْصُورٍ ، عَنِ الْحَسَنِ ، قَالَ : ہُوَ مِنْ جَمِیعِ الْمَالِ۔",,,31470
31471,"حَدَّثَنَا جَرِیرٌ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنِ الْحَسَنِ وَطَاوُسٍ : فِی الرَّجُلِ عَلَیْہِ حِجَّۃُ الإسْلاَمِ وَتَکُونُ عَلَیْہِ الزَّکَاۃُ فِی مَالِہِ ؟ قَالاَ : یَکُونَانِ ہَذَیْنِ بِمَنْزِلَۃِ الدَّیْنِ۔",,,31471
31472,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ ، عَنِ الشَّعْبِیِّ : فِی الرَّجُلِ یَمُوتُ وَیُوصِی أَنْ یُحَجَّ عَنْہُ ، أَوْ یُتَصَدَّقَ عَنْہُ کَفَّارَۃُ رَمَضَانَ ، أَوْ کَفَّارَۃُ یَمِینٍ ؟ قَالَ : مِنَ الثُّلُثِ۔",,,31472
31473,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ، قَالَ: إذَا کَانَ عَلَی الرَّجُلِ شَیْئٌ وَاجِبٌ فَہُوَ مِنْ جَمِیعِ الْمَالِ۔",,,31473
31474,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : ہُوَ مِنْ جَمِیعِ الْمَالِ۔",,,31474
31475,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ صَالِحِ بْنِ خَوَّاتٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ : أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ : أَنَّ الْمُکَاتَبَ لاَ تَجُوزُ لَہُ وَصِیَّۃٌ ، وَلاَ ہِبَۃٌ إلاَّ بِإِذْنِ مَوْلاَہُ۔",,,31475
31476,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : الْمُکَاتَبُ لاَ یَعْتِقُ ، وَلاَ یَہَبُ إلاَّ بِإِذْنِ مَوْلاَہُ۔",,,31476
31477,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : الأَحْمَقُ وَالمُوَسْوَسُ أَتَجُوزُ وَصِیَّتُہُمَا إنْ أَصَابَا الْحَقَّ وَہُمَا مَغْلُوبَانِ عَلَی عُقُولِہِمَا ؟ قَالَ : مَا أَحْسَبُ لَہُمَا وَصِیَّۃ۔",,,31477
31478,"حَدَّثَنَا ابْنُ مَہْدِی ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ إیَاسِ بْنِ مُعَاوِیَۃَ : فِی وَصِیَّۃِ الْمَجْنُونِ ، قَالَ : إِذَا أَصَابَ الْحَقّ جَازَ۔",,,31478
31479,"حَدَّثَنَا ابْنُ مَہْدِیٌّ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : لاَ تَجُوزُ وَصِیَّۃ وَلاَ طَلاَق إِلاَّ فِی عَقْلٍ۔",,,31479
31480,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، قَالَ : إنْ کَانَ سَمَّی الْغُزَاۃَ : أُعْطِیَ الْغُزَاۃَ ، وَإِلاَّ : طَاعَۃُ اللہِ : سَبِیلُہُ۔",,,31480
31481,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی حَبِیبَۃَ ، عَنْ أَبِی الدَّرْدَائِ : فِی الرَّجُلِ أَوْصَی بِشَیْئٍ فِی سَبِیلِ اللہِ ، قَالَ فِی الْمُجَاہِدِینَ۔",,,31481
31482,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ أَنَسِ بْنِ سِیرِینَ : أَنَّ امْرَأَۃً أَوْصَتْ بِثَلاَثِینَ دِرْہَمًا فِی سَبِیلِ اللہِ ، فَلَمَّا کَانَ زَمَنُ الفُرْقَۃِ قُلْتُ لاِبْنِ عُمَرَ : امْرَأَۃٌ أَوْصَتْ بِثَلاَثِینَ دِرْہَمًا فِی سَبِیلِ اللہِ ، فَنُعْطِیہَا فِی الْحَجِّ ؟ فَقَالَ : أَمَا إِنَّہُ مِنْ سَبِیلِ اللہِ۔",,,31482
31483,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ وَاقِدِ بْنِ مُحَمَّدِ بْنِ زَیْدٍ : أَنَّ رَجُلاً مَاتَ وَتَرَکَ مَالاً وَأَوْصَی بِہِ فِی سَبِیلِ اللہِ ، فَذَکَرَ ذَلِکَ الْوَصِیُّ لِعُمَرَ بْنَ الْخَطَّابِ ، فَقَالَ : أَعْطِہِ عُمَّالَ اللہِ ، قَالَ : وَمَا عُمَّالُ اللہِ ؟ قَالَ : حُجَّاجُ بَیْتِ اللہِ۔",,,31483
31484,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ أَیْمَنَ بْنِ نَابِلٍ ، قَالَ : سَأَلَ رَجُلٌ مُجَاہِدًا عَنْ رَجُلٍ ، قَالَ : کُلُّ شَیْئٍ لِی فِی سَبِیلِ اللہِ ؟ قَالَ مُجَاہِدٌ : لَیْسَ سَبِیلُ اللہِ وَاحِدًا ، کُلُّ خَیْرٍ عَمِلَہُ فَہُوَ فِی سَبِیلِ اللہِ۔",,,31484
31485,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَنَسِ بْنِ سِیرِینَ : أَنَّ رَجُلاً أَوْصَی بِشَیْئٍ فِی سَبِیلِ اللہِ ، فَقَالَ ابْنُ عُمَرَ: الْحَجُّ فِی سَبِیلِ اللہِ۔",,,31485
31486,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ : أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ فِی رَجُلٍ تَصَدَّقَ بِمَالِہِ کُلِّہِ عَلَی غَیْرِ وَارِثٍ ، ثُمَّ حَبَسَہُ حَتَّی مَاتَ ، یُرَدُّ ذَلِکَ إلَی الثُّلُثِ۔",,,31486
31487,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ، قَالَ : مَنْ صَنَعَ فِی مَالِہِ شَیْئًا لَمْ یُنَفِّذْہُ حَتَّی یَحْضُرَہُ الْمَوْتُ : فَہُوَ فِی سَبِیلِہِ۔",,,31487
31488,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، قَالَ : جَائَ رَجُلٌ إلَی الْحَسَنِ بِوَصِیَّۃٍ مَخْتُومَۃٍ لِیَشْہَدَ عَلَیْہَا ، فَقَالَ الْحَسَنُ : مَا تَجِدُ فِی ہَؤُلاَئِ النَّاسِ رَجُلَیْنِ تَثِقْہُمَا تُشْہِدُہُمَا عَلَی کِتَابِکَ ہَذَا ؟!۔",,,31488
31489,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : أَرَاہُ عَنْ إبْرَاہِیمَ : فِی الرَّجُلِ یَخْتِمُ وَصِیَّتَہُ ، وَیَقُولُ لِلْقَوْمِ : اشْہَدُوا عَلَی مَا فِیہَا ، قَالَ : لاَ تَجُوزُ إلاَّ أَنْ یَقْرَأَہَا عَلَیْہِمْ ، أَوْ تُقْرَأَ عَلَیْہِ فَیُقِرَّ بِمَا فِیہَا۔",,,31489
31490,"حَدَّثَنَا أَبُو أُسَامَۃ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ : فِی الرَّجُلِ یَکْتب الوَصِیَّۃ وَیَقُولُ : اشْہَدُوا عَلَی مَا فِی ہَذِہِ الصَّحِیفَۃِ ، قَالَ : لاَ ، حَتَّی یُعْلَمَ مَا فِیہَا۔",,,31490
31491,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، عَنْ سَعِیدِ بْنِ زَیْدٍ ، قَالَ : ذَہَبْت مَعَ حَفْصِ بْنِ عَاصِمٍ إلَی سَالِمٍ وَقَدْ خَتَمَ وَصِیَّتَہُ ، فَقَالَ : إنْ حَدَثَ بِی حَادِثٌ فَاشْہَدُوا عَلَیْہَا۔",,,31491
31492,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ یَعْلَی قَاضِی الْبَصْرَۃِ : فِی الرَّجُلِ یَکْتُبُ وَصِیَّتَہُ ، ثُمَّ یَخْتِمُہَا ، ثُمَّ یَقُولُ : اشْہَدُوا عَلَی مَا فِیہَا ، قَالَ : جَائِزٌ۔",,,31492
31493,"حَدَّثَنَا عَبَّادٌ ، عَنْ رَوْحِ بْنِ الْقَاسِمِ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ حَزْمٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ غُلاَمٌ مِنْ غَسَّانَ بِالْمَدِینَۃِ ، وَکَانَ لَہُ وَرَثَۃٌ بِالشَّامِ ، وَکَانَتْ لَہُ عَمَّۃٌ بِالْمَدِینَۃِ ، فَلَمَّا حُضِرَ أَتَتْ عُمَرَ بْنَ الْخَطَّابِ فَذَکَرَتْ ذَلِکَ لَہُ وَقَالَتْ : أَفَیُوصِی ؟ قَالَ : احْتَلَمَ بَعْدُ ؟ قَالَ : قُلْتُ : لاَ ، قَالَ : فَلْیُوصِ، قَالَ : فَأَوْصَی لَہَا بِنَخْلٍ ، فَبِعْتہ أَنَا لَہَا بِثَلاَثِینَ أَلْفِ دِرْہَمٍ۔",,,31493
31494,"حَدَّثَنَا أَبُو عِصَامٍ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ : أَنَّ عُثْمَانَ أَجَازَ وَصِیَّۃَ ابْنِ إحْدَی عَشْرَۃَ سَنَۃً۔",,,31494
31495,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ : أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ أَجَازَ وَصِیَّۃَ الصَّبِیِّ۔",,,31495
31496,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، أَنَّ عَبْد اللہِ بْنِ عُتْبَۃَ سُئِلَ عَنْ وَصِیَّۃِ جَارِیَۃٍ صَغَّرُوہَا وَحَقَّرُوہَا ؟ فَقَالَ : مَنْ أَصَابَ الْحَقَّ أُجِر۔",,,31496
31497,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی مُوسَی ، قَالَ : أَوْصَی ابْنٌ لأَبِی مُوسَی غُلاَمٌ صَغِیرٌ بِوَصِیَّۃٍ ، فَأَرَادَ إخْوَتُہُ أَنْ یَرُدُّوا وَصِیَّتَہُ ، فَارْتَفَعُوا إلَی شُرَیْحٍ ، فَأَجَازَ وَصِیَّۃَ الْغُلاَمِ۔",,,31497
31498,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : تَجُوزُ وَصِیَّۃُ الصَّبِیِّ فِی مَالِہِ فِی الثُّلُثِ فَمَا دُونَہُ۔",,,31498
31499,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : قُلْتُ لَہُ : تَجُوزُ وَصِیَّتُہُ ؟ قَالَ : جَائِزَۃٌ۔",,,31499
31500,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عُمَارَۃَ ، قَالَ : سَمِعْتُ أَبَا عَمْرِو بْنِ الأَجْدَعِ ، قَالَ : اخْتَصَمَ إلَی عَلِیٍّ ظِئْرُ غُلاَمٍ ، فَأَمَرَ عَلِیٌّ أَنْ نُعْتِقَہُ ، فَأَعْتَقْنَاہُ۔",,,31500
31501,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ : أَنَّہُ قَالَ فِی وَصِیَّۃِ الصَّبِیِّ : أَیُّمَا مُوصٍ أَوْصَی فَأَصَابَ حَقًّا جَازَ۔",,,31501
31502,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یُونُسُ بْنُ أَبِی إِسْحَاقَ ، عَنْ أَبِیہِ : أَنَّ صَبِیًّا أَوْصَی لِظِئْرٍ لَہُ مِنْ أَہْلِ الْحِیرَۃِ بِأَرْبَعِینَ دِرْہَمًا ، فَأَجَازَہُ شُرَیْحٌ۔",,,31502
31503,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یُونُسُ بْنُ أَبِی إِسْحَاقَ ، عَنْ أَبِیہِ ، عَنْ شُرَیْحٍ ، قَالَ : إذَا اتَّقَی الصَّبِیُّ الرُّکّی، أَنْ یَقَعَ فِیہَا فَقَدْ جَازَتْ وَصِیَّتُہُ۔",,,31503
31504,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ تَجُوزُ وَصِیَّۃُ غُلاَمٍ وَلاَ جَارِیَۃٍ حَتَّی یُصَلِّیَا۔",,,31504
31505,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ یَجُوزُ عِتْقُ الصَّبِیِّ ، وَلاَ وَصِیَّتُہُ ، وَلاَ بَیْعُہُ ، وَلاَ شِرَاؤُہُ ، وَلاَ طَلاَقُہُ۔",,,31505
31506,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، قَالَ: لاَ تَجُوزُ وَصِیَّۃُ غُلاَمٍ حَتَّی یَحْتَلِمَ، وَلاَ جَارِیَۃٍ حَتَّی تَحِیضَ۔",,,31506
31507,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : وَصِیَّتُہُ لَیْسَتْ بِجَائِزَۃٍ إلاَّ مَا لَیْسَ بِذِی بَالٍ۔",,,31507
31508,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ اللہِ ، عَنْ مَکْحُولٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : إذَا بَلَغَ الْغُلاَمُ خَمْسَۃَ عَشَرَ جَازَتْ وَصِیَّتُہُ۔",,,31508
31509,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ تَجُوزُ وَصِیَّتُہُ۔",,,31509
31510,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنِ الْمُسْتَمِرِّ بْنِ الرَّیَّانِ ، قَالَ : حضَرْت جَابِرَ بْنَ زَیْدٍ فِی الْمَسْجِدِ الْجَامِعِ ، وَقَالَ لَہُ زُرَارَۃُ بْنُ أَوْفَی - وَہُوَ یَوْمَئِذٍ عَلَی الْقَضَائِ : أَنَّہُ رُفِعَ إلَیَّ غُلاَمٌ أَعْتَقَ عَبْدًا لَہُ ، فَأَنْکَرَ ذَلِکَ الأَوْلِیَائُ ، فَرَأَیْت أَنْ أَرُدَّ ذَلِکَ ، ثُمَّ یُؤدِّی الْغُلاَمُ ، حَتَّی یَشِبَّ الْغُلاَمُ وَیُحِبَّ الْمَالَ ، فَإِنْ شَائَ أَنْ یَمْضِیَ أَمْضَی ، وَإِنْ شَائَ أَنْ یَرُدَّ رَدَّ۔",,,31510
31511,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَوْف ، قَالَ : شَہِدْت ہِشَامَ بْنَ ہُبَیْرَۃٍ قَضَی فِی رَجُلٍ أَوْصَی لأُخْتٍ لَہُ عِنْدَ مَوْتِہِ بِمِثْلِ نَصِیبِ اثْنَیْنِ مِنْ وَلَدِہِ ، وَتَرَکَ الْمَیِّتُ بَنِینَ وَبَنَاتٍ ، فَأَرَادَتِ الْمُوصَی لَہَا أَنْ تَجْعَلَ نَفْسَہَا بِمَنْزِلَۃِ الذَّکَرِ ، وَأَبَی الْوَرَثَۃُ أَنْ یَجْعَلُوہَا إلاَّ بِمَنْزِلَۃِ الأُنْثَی ، فَقَضَی أَنَّہَا بِمَنْزِلَتِہَا إنْ لَمْ تَکُنْ تُبَیِّنَ۔",,,31511
31512,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَوْفٍ الأَعْرَابِیِّ ، عَنْ ہِشَامِ بْنِ ہُبَیْرَۃَ : أَنَّہُ قَضَی فِی رَجُلٍ أَوْصَی لِرَجُلٍ بِمِثْلِ نَصِیبِ أَحَدِ وَلَدِہِ ، وَلَہُ ذَکَرٌ وَأُنْثَی ، أَنَّ لَہُ نَصِیبَ الأُنْثَی۔ قَالَ أَبُو بَکْرٍ : قَالَ وَکِیعٌ : قَالَ سُفْیَانُ : لَہُ نَصِیبُ أُنْثَی۔",,,31512
31513,"حَدَّثَنَا عُمَرُ ، عَنْ یُونُسَ ، عَنِ الزُّہْرِیِّ : فِی رَجُلٍ أَوْصَی لِرَجُلٍ بِفَرَسٍ وَسَمَّاہُ ، وَقَالَ : ثُلُثُ مَالِی لِفُلاَنٍ وَفُلاَنٍ ، وَکَانَ الْفَرَسُ کَفَاف ثُلُثِ مَالِہِ ، قَالَ الزُّہْرِیُّ : نَرَی أَنْ یُقَسِّمَ ثُلُثَ مَالِہِ عَلَی حِصَصِہِمْ۔",,,31513
31514,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ بَعْضِ أَصْحَابِہِ ، عَنِ الْحَسَنِ : أَنَّہُ قَالَ فِی رَجُلٍ أَوْصَی بِدَرَاہِمٍ وَبِالسُّدُسِ وَنَحْوِہِ : یَتَحَاصُّونَ جَمِیعًا۔",,,31514
31515,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یُوصِیَ الرَّجُلُ لِمَمْلُوکِہِ بِمِئَۃِ دِرْہَمٍ وَالْمِئَتَیْنِ إذَا رَضِیَ الأَوْلِیَائُ ، وَإِنْ جَعَلَ لَہُ شَیْئًا مِنْ ثُلُثِہِ فَہُوَ فِی عُنُقِہِ۔",,,31515
31516,"حَدَّثَنَا حَفْصٌ ، قَالَ : سَأَلْتُ عُمَرَاً عَنِ الرَّجُلِ یُوصِی لِعَبْدِہِ ؟ فَقَالَ : کَانَ الْحَسَنُ یَقُولُ : لَوْ أَوَصَی لَہُ بِرَغِیفٍ وَصِلَتُہُ عَتَاقَتُہُ۔",,,31516
31517,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ شَبِیبِ بْنِ غَرْقَدَۃَ ، عَنْ جُنْدُبٍ ، قَالَ : سَأَلَ طَہْمَانُ ابْنَ عَبَّاسٍ : أَیُوصِی الْعَبْدُ ؟ قَالَ : لاَ۔",,,31517
31518,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ ، قَالاَ : وَصِیَّۃُ الرَّجُلِ حَیْثُ جَعَلَہَا إلاَّ أَنْ یُتَّہَمَ الْوَصِیُّ بِہِ۔",,,31518
31519,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : الْوَصِیُّ بِمَنْزِلَۃِ الْوَالِدِ ، وَإِذَا اتُّہِمَ الْوَصِیُّ عُزِلَ ، أَوْ جُعِلَ مَعَہُ غَیْرُہُ۔",,,31519
31520,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ عُمَرَ ، قَالَ : إذَا کَانَتْ وَصِیَّۃٌ وَعَتَاقَۃٌ تَحَاصُّوا۔",,,31520
31521,"حَدَّثَنَا حَفْصٌ وَابْنُ عُلَیَّۃَ، عَنْ أَشْعَثَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ: إذَا کَانَتْ عَتَاقَۃٌ وَوَصِیَّۃٌ بُدِئَ بِالْعَتَاقَۃِ۔",,,31521
31522,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ وَحَجَّاجٌ ، عَنِ الْحَکَمِ ، عَنْ شُرَیْحٍ : أَنَّہُ کَانَ یَبْدَأُ بِالْعَتَاقَۃِ۔",,,31522
31523,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ : فِی الرَّجُلِ یُوصِی بِعَتَاقِ عَبْدِہِ فِی مَرَضِہِ وَیُوصِی مَعَہُ بِوَصَایَا، قَالَ : یُبْدَأُ بِعَتَاقِ الْعَبْدِ قَبْلَ الْوَصَایَا ، فَإِنْ أَوْصَی أَنْ یَشْتَرِیَ لَہُ نَسَمَۃً فَتَعْتِقُ : کَانَتِ النَّسَمَۃُ کَسَائِرِ الْوَصِیَّۃِ۔",,,31523
31524,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ یُونُسَ، عَنِ الْحَسَنِ: أَنَّہُ کَانَ یَقُولُ : یُبْدَأُ بِالْعَتَاقِ وَإِنْ أَتَی ذَلِکَ عَلَی الثُّلُثِ کُلِّہِ۔",,,31524
31525,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ : أَنَّہُ کَانَ یَقُولُ فِی الْوَصِیَّۃِ یَکُونُ فِیہَا الْعِتْقُ فَتَزِیدُ عَلَی الثُّلُثِ ، قَالَ : الثُّلُثُ بَیْنَہُمْ بِالْحِصَصِ۔",,,31525
31526,"حَدَّثَنَا ہُشَیْمٌ، عَنِ الشَّیْبَانِیِّ عَمَّنْ حَدَّثَہُ، عَنْ مَسْرُوقٍ: أَنَّہُ قَالَ فِی الْعَتَاقَۃِ وَالْوَصِیَّۃِ، قَالَ: یُبْدَأُ بِالْوَصِیَّۃِ۔",,,31526
31527,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ بِالْحِصَصِ۔",,,31527
31528,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُبْدَأُ بِالْعَتَاقَۃِ۔",,,31528
31529,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إنَّمَا یُبْدَأُ بِالْعَتَاقَۃِ إذَا سَمَّی مَمْلُوکًا بِعَیْنِہِ۔",,,31529
31530,"حَدَّثَنَا وَکِیعٌ ، قَالَ : قَالَ سُفْیَانُ : إذَا أَوْصَی بِأَشْیَائَ ، وَقَالَ : أَعْتِقُوا عَنِّی فَبِالْحِصَصِ ، وَإِذَا أَوْصَی ، فَقَالَ : فُلاَنٌ حُرٌّ ، بُدِئَ بِالْعَتَاقَۃِ۔",,,31530
31531,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یُبْدَأُ بِالْعَتَاقَۃِ۔",,,31531
31532,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : بِالْحِصَصِ۔",,,31532
31533,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ ، یُبْدَأُ بِالْعَتَاقَۃِ۔,,,31533
31534,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ حَجَّاجٍ ، عَنِ الشَّعْبِیِّ : فِی رَجُلٌ مَاتَ وَتَرَکَ أَلْفَیْ دِرْہَمٍ وَعَبْدًا قِیمَتُہُ أَلْفُ دِرْہَمٍ ، وَأَوْصَی لِرَجُلٍ بِخَمْسِمِئَۃٍ وَأَعْتَق الْعَبْد ، قَالَ : یَعْتِقُ الْعَبْدُ وَتَبْطُلُ الْوَصِیَّۃُ۔",,,31534
31535,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ : فِی قَوْلِہِ : {وَإِذَا حَضَرَ الْقِسْمَۃَ أُوْلُواْ الْقُرْبَی وَالْیَتَامَی وَالْمَسَاکِینُ فَارْزُقُوہُم مِّنْہُ} فَحَدَّثَ عَنْ مُحَمَّدٍ ، عَنْ عَبِیدَۃَ : أَنَّہُ وَلِیَ وَصِیَّۃً فَأَمَرَ بِشَاۃٍ فَذُبِحَتْ فَصَنَعَ طَعَامًا لأَجْلِ ہَذِہِ الآیَۃِ ، وَقَالَ : لَوْلاَ ہَذِہِ الآیَۃُ لَکَانَ ہَذَا مِنْ مَالِی۔",,,31535
31536,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ فِی قَوْلِہِ : {وَإِذَا حَضَرَ الْقِسْمَۃَ أُولُوا الْقُرْبَی وَالْیَتَامَی وَالْمَسَاکِینُ فَارْزُقُوہُمْ مِنْہُ} قَالَ : کَانَ إذَا قَسَمَ الْقَوْمُ الْمِیرَاثَ ، وَکَانَ ہَؤُلاَئِ شُہُودًا رُضِخَ لَہُمْ مِنَ الْمِیرَاثِ ، فَإِنْ کَانُوا غَیَبًا وَأَحَدٌ مِنْہُمْ شَاہِدٌ ، فَإِنْ شَائَ أَعْطَی مِنْ نَصِیبِہِ وَإِلاَّ قَالَ لَہُمْ قَوْلاً مَعْرُوفًا ، قَالَ : یَقُولُ : إنَّ لَکُمْ فِیہِ حَقًّا۔",,,31536
31537,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی الْعَالِیَۃِ وَالْحَسَنِ ، قَالاَ : یَرْضَخُونَ وَیَقُولُونَ قَوْلاً مَعْرُوفًا۔",,,31537
31538,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ رَجُلٌ یَقْسِمُ مِیرَاثًا ، فَقَالَ لِصَاحِبِہِ : أَلاَ تَجِیئُ نُحْیِی آیَۃً مِنْ کِتَابِ اللہِ قَدْ أُمِیتَتْ ، فَقَسَمَ بَیْنَہُمْ مِنْ نَصِیبِہِ۔",,,31538
31539,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عنَْسُفْیَانُ بْنُ حُسَیْنٍ، عَنِ الْحَسَنِ وَابْنِ سِیرِینَ: فِی قَوْلِہِ: {وَإِذَا حَضَرَ الْقِسْمَۃَ أُولُوا الْقُرْبَی وَالْیَتَامَی} ، قَالاَ : ہِیَ مُثبتۃٌ ، فَإِذَا حَضَرَتْ وَحَضَرَ ہَؤُلاَئِ الْقَوْمِ أُعْطُوا مِنْہَا وَرُضِخَ لَہُمْ۔",,,31539
31540,"حَدَّثَنَا عَبْدُالأَعْلَی، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ: فِی قَوْلِہِ: {وَإِذَا حَضَرَ الْقِسْمَۃَ أُولُوا الْقُرْبَی} إنَّہَا مُحْکَمَۃٌ۔",,,31540
31541,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، قَالَ : سَمِعْتُ یُونُسَ بْنَ جُبَیْر یُحَدِّثُ عَنْ حِطَّانَ ، عَنْ أَبِی مُوسَی: فِی ہَذِہِ الآیَۃِ : {إِذَا حَضَرَ الْقِسْمَۃَ أُولُوا الْقُرْبَی وَالْیَتَامَی وَالْمَسَاکِینُ فَارْزُقُوہُمْ مِنْہُ وَقُولُوا لَہُمْ قَوْلاً مَعْرُوفًا} قَالَ : قَضَی بِہَا أَبُو مُوسَی۔",,,31541
31542,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ : أَنَّ عُرْوَۃَ قَسَمَ مِیرَاثَ أَخِیہِ مُصْعَبٍ ، فَأَعْطَی مَنْ حَضَرَہُ مِنْ ہَؤُلاَئِ وَبَنُوہُ صِغَارٌ۔",,,31542
31543,"حَدَّثَنَا عَبْدُ الصَّمَدِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی مُوسَی وَعَبْدِ الرَّحْمَنِ بْنِ أَبِی بَکْرٍ : أَنَّہُمَا کَانَا یُعْطِیَانِ مَنْ حَضَرَ مِنْ ہَؤُلاَئِ۔",,,31543
31544,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ السُّدِّیِّ ، عَنْ أَبِی سَعِیدٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ : {وَإِذَا حَضَرَ الْقِسْمَۃَ أُولُوا الْقُرْبَی وَالْیَتَامَی وَالْمَسَاکِینُ فَارْزُقُوہُمْ مِنْہُ}، قَالَ : إنْ کَانُوا کِبَارًا رُضِخُوا ، وَإِنْ کَانُوا صِغَارًا اعْتُذِرَ إلَیْہِمْ ، فَذَلِکَ قَوْلہ {قَوْلاً مَعْرُوفًا}۔",,,31544
31545,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : وَلِیَ أَبِی مِیرَاثًا فَأَمَرَ بِشَاۃٍ فَذُبِحَتْ فَصُنِعَتْ ، فَلَمَّا قَسَمَ ذَلِکَ الْمِیرَاثَ أَطْعَمَہُمْ ، وَقَالَ : لِمَنْ لَمْ یَرِثْ مَعْرُوفًا۔",,,31545
31546,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنِ السُّدِّیِّ ، عَنْ أَبِی مَالِکٍ : نَسَخَتْہَا آیَۃُ الْمِیرَاثِ۔",,,31546
31547,"حَدَّثَنَا ابْنُ یَمَانٍ، عَنْ سُفْیَانَ، عَنِ الشَّیْبَانِیِّ، عَنْ عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: مُحْکَمَۃٌ لَیْسَتْ بِمَنْسُوخَۃٍ۔",,,31547
31548,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، قَالَ : سَمِعْتُ الشَّعْبِیَّ یَقُولُ فِی الْمَسْجِدِ مَرَّۃً : سَمِعْت حَدِیثًا مَا بَقِیَ أَحَدٌ سَمِعَہُ غَیْرِی، سَمِعْت عَمْرَو بْنَ شُرَحْبِیلَ یَقُولُ: قَالَ عَبْدُ اللہِ: إنَّکُمْ مَعْشَرَ الْیَمَنِ مِنْ أَجْدَرِ قَوْمٍ أَنْ یَمُوتَ الرَّجُلُ، وَلاَ یَدْعُ عُصْبَۃً فَلْیَضَعْ مَالَہُ حَیْثُ شَائَ، قَالَ الأَعْمَشُ: فَقُلْتُ لإِبْرَاہِیمَ: إنَّ الشَّعْبِیَّ، قَالَ کَذَا وَکَذَا، قَالَ إبْرَاہِیمُ: حَدَّثَنِی ہَمَّامُ بْنُ الْحَارِثِ، عَنْ عَمْرِو بْنِ شُرَحْبِیلَ، عَنْ عَبْدِاللہِ مِثْلَہُ۔\n\n(سعید بن منصور 217)",,,31548
31549,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : سَأَلْتُ عَبِیدَۃَ عَنْ رَجُلٍ لَیْسَ عَلَیْہِ عَقْدٌ وَلَیْسَ عَلَیْہِ عُصْبَۃٌ ، یُوصِی بِمَالِہِ کُلِّہِ ؟ قَالَ : نَعَمْ۔",,,31549
31550,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ؛ سُئِلَ عَنْ رَجُلٍ مَاتَ وَلَمْ یَتْرُکْ مَوْلًی عَتَاقَۃٍ ، وَلاَ وَارِثًا ؟ قَالَ : مَالُہُ حیْثُ وَضَعَہُ ، فَإِنْ لَمْ یَکُنْ أَوْصَی بِشَیْئٍ فَمَالُہُ فِی بَیْتِ الْمَالِ۔",,,31550
31551,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ : فِی رَجُلٍ وَالَی رَجُلاً فَأَسْلَمَ عَلَی یَدَیْہِ ، قَالَ : إنْ شَائَ أَوْصَی بِمَالِہِ کُلِّہِ۔",,,31551
31552,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ : أَنَّ أَبَا الْعَالِیَۃِ أَوْصَی بِمِیرَاثِہِ لِبَنِی ہَاشِمٍ۔",,,31552
31553,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا ہِشَامٌ ، عَنْ أَبِیہِ : أَنَّ عَبْدَ اللہِ بْنَ مَسْعُودٍ وَعُثْمَانَ وَالْمِقْدَادَ بْنَ الأَسْوَدِ، وَعَبْدَ الرَّحْمَن بْنَ عَوْفٍ وَمُطِیعَ بْنَ الأَسْوَدِ أَوْصَوا إلَی الزُّبَیْرِ بْنِ الْعَوَّامِ ، قَالَ : وَأَوْصَی إلَی عَبْدِ اللہِ بْنِ الزُّبَیْرِ۔",,,31553
31554,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ : کَانَ وَصّی لِرَجُلٍ۔",,,31554
31555,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : أَوْصَی إلَیَّ ابْن عَمٍّ لِی ، قَالَ : فَکَرِہْت ذَلِکَ ، فَسَأَلْت عَمْرًا ؟ فَأَمَرَنِی أَنْ أَقْبَلَہَا ، قَالَ : وَکَانَ ابْنُ سِیرِینَ یَقْبَلُ الْوَصِیَّۃَ۔",,,31555
31556,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ إسْمَاعِیلَ، عَنْ قَیْسٍ، قَالَ: کَانَ أَبُو عُبَیْد عَبَرَ الْفُرَاتِ فَأَوْصَی إلَی عُمَرَ بْنِ الْخَطَّابِ۔",,,31556
31557,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْرَائِیلَ ، عَنْ أَبِی الْہَیْثُمَّ ، قَالَ : بَعَثَ إلَیَّ إبْرَاہِیمُ فَأَوْصَی إلَیَّ۔",,,31557
31558,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عَامِرِ بْنِ سَعْدٍ ، عَنْ أَبِیہِ : أَنَّہُ قَالَ : مَرِضَ مَرَضًا أَشْفَی مِنْہُ ، فَأَتَاہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَعُودُہُ ، فَقَالَ : یَا رَسُولَ اللہِ ، إنَّ لِی مَالاً کَثِیرًا وَلَیْسَ یَرِثُنِی إِلاَّ ابْنَۃٌ لِی ، أَفَأَتَصَدَّقُ بِالثُّلُثَیْنِ ؟ قَالَ : لاَ ، قَالَ : فَالشَّطْرَ ؟ قَالَ : لاَ ، قُلْتُ : فَالثُّلُثُ ؟ قَالَ : الثُّلُثُ کَثِیرٌ۔\n\n(بخاری 6733۔ مسلم 1252)",,,31558
31559,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : وَدِدْت أَنَّ النَّاسَ غَضُّوا مِنَ الثُّلُثِ إلَی الرُّبُعِ ، لأَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الثُّلُثُ کَثِیرٌ۔ (بخاری 2743۔ مسلم 1253)",,,31559
31560,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، أَنَّ الزُّبَیْرَ أَوْصَی بِثُلُثِہِ۔,,,31560
31561,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : ذُکِرَ عِنْدَ عُمَرَ الثُّلُثُ فِی الْوَصِیَّۃِ ، قَالَ : الثُّلُثُ وَسَطٌ لاَ بَخْسٌ ، وَلاَ شَطَطٌ۔",,,31561
31562,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ : أَنَّ مُعَاذَ بْنَ جَبَلٍ قَالَ : إنَّ اللَّہَ تَصَدَّقَ عَلَیْکُمْ بِثُلُثِ أَمْوَالِکُمْ زِیَادَۃً فِی حَیَاتِکُمْ۔ یَعْنِی : الْوَصِیَّۃَ۔",,,31562
31563,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ خَالِدِ بْنِ أَبِی عَزَّۃَ ، قَالَ : قَالَ أَبُو بَکْرٍ : آخُذُ مِنْ مَالِی مَا أَخَذَ اللَّہُ مِنَ الْفَیْئِ فَأَوْصَی بِالْخُمُسِ۔",,,31563
31564,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : أَوْصَی أَبُو بَکْرٍ وَعَلِیٌّ بِالْخُمُسِ۔",,,31564
31565,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ : أَنَّ حُمَیْدَ بْنَ عَبْدِ الرَّحْمَنِ ، قَالَ : مَا کُنْت لأَقْبَلَ وَصِیَّۃَ رَجُلٍ یُوصِی بِالثُّلُثِ وَلَہُ وَلَدٌ۔",,,31565
31566,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، عَنْ شُرَیْحٍ ، قَالَ : الثُّلُثُ جَیِّدٌّ وَہُوَ جَائِزٌ۔",,,31566
31567,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ بَشِیرِ بْنِ عُقْبَۃَ ، عَنْ یَزِیدَ بْنِ الشِّخِّیرِ ، قَالَ : کَانَ مُطَرِّفٌ یَرَی الْخُمُسَ فِی الْوَصِیَّۃِ حَسَنًا۔",,,31567
31568,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَقُولُونَ الَّذِی یُوصِی بِالْخُمُسِ أَفْضَلُ مِنَ الَّذِی یُوصِی بِالرُّبُعِ ، وَالَّذِی یُوصِی بِالرُّبُعِ أَفْضَلُ مِنَ الَّذِی یُوصِی بِالثُّلُثِ۔",,,31568
31569,"حَدَّثَنَا یَعْلَی وَابْنُ نُمَیْرٍ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إنَّمَا کَانُوا یُوصُونَ بِالْخُمُسِ وَالرُّبُعِ ، وَالثُّلُثُ مُنْتَہَی الْجَامِحِ ، وَقَالَ ابْنُ نُمَیْرٍ : مُنْتَہَی الْجِمَاحِ۔",,,31569
31570,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : لأَنْ أُوصِیَ بِالْخُمُسِ أَحَبُّ إلَیَّ مِنْ أَنْ أُوصِیَ بِالرُّبُعِ ، وَلأَنْ أُوصِیَ بِالرُّبُعِ أَحَبُّ إلَیَّ مِنْ أَنْ أُوصِیَ بِالثُّلُثِ ، وَمَنْ أَوْصَی لَمْ یَتْرُکْ۔",,,31570
31571,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا مَنْدَل ، عَنِ الأَعْمَشِ ، عَنْ طَلْحَۃَ ، عَنْ أَبِی عَمَّارٍ ، عَنْ عَمْرِو بْنِ شُرَحْبِیلَ ، قَالَ : الثُّلُثُ حَیْفٌ وَالرُّبُعُ حَیْفٌ۔",,,31571
31572,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا مَنْدَل ، عَنِ الأَعْمَشِ ، عَنْ مَالِکِ بْنِ الْحَارِثِ ، عَنِ الْعَبَّاسِ ، قَالَ : الرُّبُعُ حَیْفٌ وَالثُّلُثُ حَیْفٌ۔",,,31572
31573,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، قَالَ : قَالَ إبْرَاہِیمُ : کَانَ یُقَالَ : السُّدُسُ خَیْرٌ مِنَ الثُّلُثِ فِی الْوَصِیَّۃِ۔",,,31573
31574,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : کَانُوا یَسْتَحِبُّونَ أَنْ یَتْرُکُوا مِنَ الثُّلُثِ۔",,,31574
31575,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ قُثَم مَوْلَی ابْنِ عَبَّاسٍ ، قَالَ : قَالَ عَلِیٌّ : وَصِیَّتِی إلَی أَکْبَرِ وَلَدِی غَیْرَ طَاعن عَلَیْہِ فِی بَطْنٍ وَلاَ فِی فَرْجٍ۔",,,31575
31576,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَا حَقُّ امْرِئٍ مُسْلِمٍ یَبِیتُ لَیْلَتَیْنِ وَلَہُ شَیْئٌ یُوصِی بِہِ ، إلاَّ وَوَصِیَّتُہُ مَکْتُوبَۃٌ عِنْدَہُ۔\n\n(مسلم 1249۔ ابوداؤد 2854)",,,31576
31577,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنْ عَامِرٍ ، قَالَ : مَنْ أَوْصَی بِوَصِیَّۃٍ لَمْ یَحِفْ فِیہَا وَلَمْ یُضَارَّ أَحَدًا أَنْ یَکُونَ لَہُ مِنَ الأَجْرِ مَا لَوْ تَصَدَّقَ بِہِ فِی حَیَاتِہِ فِی صِحَّتِہِ۔",,,31577
31578,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ دَاوُدَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الضِّرَارُ فِی الْوَصِیَّۃِ مِنَ الْکَبَائِرِ ، ثُمَّ تَلاَ {غَیْرَ مُضَارٍّ وَصِیَّۃً مِنَ اللہِ}۔",,,31578
31579,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبٍ ، قَالَ : ذَہَبْت أَنَا وَالْحُکْمُ إلَی سَعِیدِ بْنِ جُبَیْرٍ فَسَأَلْتُہُ عَنْ قولہ : {وَلْیَخْشَ الَّذِینَ لَوْ تَرَکُوا مِنْ خَلْفِہِمْ ذُرِّیَّۃً ضِعَافًا خَافُوا عَلَیْہِمْ} إلَی قَوْلہ {سَدِیدًا} قَالَ : ہُوَ الَّذِی یَحْضُرُہُ الْمَوْتُ فَیَقُولُ لَہُ مَنْ یَحْضُرُہُ : اتَّقِ اللَّہَ وَأَعْطِہِمْ صِلْہُمْ بَرَّہُمْ وَلَوْ کَانُوا ہُمَ الَّذِینَ یَأْمُرُونَہُ بِالْوَصِیَّۃِ لأَحَبُّوا أَنْ یُنْفِقُوا لأَوْلاَدِہِمْ۔\n\nفَأَتَیْنَا مِقْسَمًا فَسَأَلَنَاہ ؟ فَقَالَ : مَا قَالَ سَعِیدٌ ؟ فَقُلْنَا : کَذَا وَکَذَا ، قَالَ : لاَ ، وَلَکِنَّہُ الرَّجُلُ یَحْضُرُہُ الْمَوْتُ فَیُقَالُ لَہُ : اتَّقِ اللَّہَ وَأَمْسِکْ عَلَیْک مَالِکَ فَإِنَّہُ لَیْسَ أَحَدٌ أَحَقَّ بِمَالِکَ مِنْ وَلَدِکَ وَلَوْ کَانَ الَّذِی یُوصِی ذَا قَرَابَۃٍ لاَحَبُّوا أَنْ یُوصِیَ لَہُمْ۔",,,31579
31580,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنْ دَاوُدَ بْنَ أَبِی ہِنْدٍ ، عَنِ الْقَاسِمِ بْنِ عَمْروٍ ، قَالَ : اشْتَکَی أَبِی فَلَقِیت ثُمَامَۃَ بْنَ حَزَنٍ الْقُشَیْرِیَّ ، فَقَالَ لِی : أَوْصَی أَبُوک ؟ قُلْتُ : لاَ ، قَالَ : إنِ اسْتَطَعْت أَنْ یُوصِیَ فَلْیُوصِ ، فَإِنَّہَا تَمَامٌ لِمَا انْتَقَصَ مِنْ زَکَاتِہِ۔ (طبرانی 69)",,,31580
31581,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الضِّرَارُ فِی الْوَصِیَّۃِ مِنَ الْکَبَائِرِ ، ثُمَّ قَرَأَ: {وَمَنْ یَعْصِ اللَّہَ وَرَسُولَہُ وَیَتَعَدَّ حُدُودَہُ یُدْخِلْہُ نَارًا خَالِدًا فِیہَا}۔",,,31581
31582,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی إبْرَاہِیمُ بْنُ مَیْسَرَۃَ ، أَنَّہُ سَمِعَ طَاوُوسًا یَقُولُ : مَا مِنْ مُسْلِمٍ یُوقِنُ بِالْوَصِیَّۃِ یَمُوتُ لَمْ یُوصِ إلاَّ أَہْلُہُ مَحْقُوقُونَ أَنْ یُوصُوا عَنْہُ۔",,,31582
31583,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، قَالَ : حَدَّثَنَا أَبُو حَمْزَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إِنَّمَا کَانُوا یَکْرَہُونَ أَنْ یَمُوتَ الرَّجُلُ قَبْلَ أَنْ یُوصِیَ قَبْلَ أَنْ تُنَزَّلَ الْمَوَارِیثُ۔",,,31583
31584,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ طَلْحَۃَ ، قَالَ : قُلْتُ لاِبْنِ أَبِی أَوْفَی : أَوْصَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : لاَ ، قُلْتُ : فَکَیْفَ أَمَرَ النَّاسَ بِالْوَصِیَّۃِ ؟ قَالَ : أَوْصَی بِکِتَابِ اللہِ۔\n\n(بخاری 2740۔ مسلم 1256)",,,31584
31585,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ وَابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیق ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : مَا تَرَکَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ دِینَارًا ، وَلاَ دِرْہَمًا ، وَلاَ أَوْصَی بِشَیْئٍ۔ (مسلم 1256۔ ابن ماجہ 2695)",,,31585
31586,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : أَخْبَرَنَا إسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَرَقْمَ بْنِ شُرَحْبِیلَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَاتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَلَمْ یُوصِ۔ (احمد 343۔ ابویعلی 2553)",,,31586
31587,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : ذَکَرُوا عِنْدَ عَائِشَۃَ أَنَّ عَلِیًّا کَانَ وَصِیًّا ، فَقَالَتْ : مَتَی أَوْصَی إلَیْہِ ؟ فَلَقَدْ کُنْت مُسْنِدَتَہُ إلَی حِجْرِی ، فَانْخَنَثَ فَمَاتَ ، فَمَتَی أَوْصَی إلَیْہِ؟!۔\n\n(بخاری 2741۔ احمد 32)",,,31587
31588,"حَدَّثَنَا ابْنِ جُرَیْجٍ، عَنْ لَیْثٍ، عَنْ طَاوُوسٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: إِذَا تَرَکَ الْمَیِّت سَبْعمِئۃ دِرْہَم فَلا یُوصِی۔\n\n(سعید بن منصور 250)",,,31588
31589,"حَدَّثَنَا زَیْدُ بْنُ حَبَّابٍ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ {إنْ تَرَکَ خَیْرًا الْوَصِیَّۃُ} قَالَ : خَیْرُ الْمَالِ ، کَانَ یُقَالَ : أَلْفُ دِرْہَمٍ فَصَاعِدًا۔",,,31589
31590,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ : أَنَّ عَلِیًّا دَخَلَ عَلَی رَجُلٍ مِنْ بَنِی ہَاشِمٍ یَعُودُہُ ، فَأَرَادَ أَنْ یُوصِیَ فَنَہَاہُ ، وَقَالَ : إنَّ اللَّہَ یَقُولُ : {إنْ تَرَکَ خَیْرًا} وَإِنَّک لَمْ تَدَعْ مَالا ، فَدَعْہُ لِعِیَالِک۔",,,31590
31591,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ مُحَمَّدِ بْنِ شَرِیکٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عَائِشَۃَ ، قَالَ : قَالَ لَہَا رَجُلٌ : إنِّی أُرِیدُ أَنْ أُوصِیَ ، قَالَتْ : کَمْ مَالُک ؟ قَالَ : ثَلاَثَۃُ آلاَفٍ ، قَالَتْ : فَکَمْ عِیَالُک ؟ قَالَ : أَرْبَعَۃٌ ، قَالَتْ : فَإِنَّ اللَّہَ یَقُولُ : {إنْ تَرَکَ خَیْرًا} وَإِنَّہُ شَیْئٌ یَسِیرٌ ، فَدَعْہُ لِعِیَالِکَ فَإِنَّہُ أَفْضَلُ۔",,,31591
31592,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ حَبِیبٍ، عَنْ إبْرَاہِیمَ: فِی قَوْلِہِ {وَصِیَّۃً لأَزْوَاجِہِمْ} قَالَ: ہِیَ مَنْسُوخَۃٌ۔",,,31592
31593,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْجَہْضَمِ ، عَنْ عَبْدِ اللہِ بْنِ بَدْرٍ ، عَنِ ابْنِ عُمَرَ {إنْ تَرَکَ خَیْرًا الْوَصِیَّۃُ} ، قَالَ : نَسَخَتْہَا آیَۃُ الْمِیرَاثُ۔",,,31593
31594,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ قَالَ: نَسَخَتْہَا آیَۃُ الْفَرَائِضِ، وَتَرَکَ الأَقْرَبُونَ مِمَّنْ لاَ یَرِثُ۔",,,31594
31595,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : الْوَصِیَّۃُ لَیْسَتْ بِمَضْمُونَۃٍ ، إنَّمَا ہِیَ بِمَنْزِلَۃِ الدَّیْنِ فِی مَالِ الرَّجُلِ۔",,,31595
31596,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ : أَنَّہُ کَانَ یَرَی الْوَصِیَّۃَ مَضْمُونَۃً۔",,,31596
31597,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالَ : إذَا أَوْصَی رَجُلٌ إلَی رَجُلٍ غَائِبٍ ، ثُمَّ قَدِمَ فَأَقَرَّ بِالْوَصِیَّۃِ ، ثُمَّ أَنْکَرَ فَلَیْسَ لَہُ ذَلِکَ۔",,,31597
31598,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، أَنَّہُ قَرَأَ عَلَی فُضَیْلِ بْنِ مَیْسَرَۃَ ، عَنْ أَبِی حَرِیزٍ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ ، عَنْ عُمَرَ ، قَالَ : إذَا الْتَقَی الزَّحْفَانِ وَالْمَرْأَۃُ یَضْرِبُہَا الْمَخَاضُ لاَ یَجُوزُ لَہُمَا فِی مَالِہِمَا إلاَّ الثُّلُثُ۔",,,31598
31599,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ : فِی الرَّجُلِ یُعْطِی فِی الْمُزَاحَفَۃِ وَرُکُوبِ الْبَحْرِ وَالطَّاعُونِ وَالْحَامِلِ ، قَالَ : مَا أَعْطَوا فَہُوَ جَائِزٌ ، لاَ یَکُن مِنَ الثُّلُثِ۔",,,31599
31600,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : مَا صَنَعَت الْحَامِلُ فِی شَہْرِہَا فَہُوَ مِنَ الثُّلُثِ۔",,,31600
31601,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ : فِی الرَّجُلِ یَکُونُ بِہِ السِّلُّ وَالْحُمَّی وَہُوَ یَجِیئُ وَیَذْہَبُ ، قَالَ : مَا صَنَعَ مِنْ شَیْئٍ فَہُوَ مِنْ جَمِیعِ الْمَالِ ، إلاَّ أَنْ یَکُونَ أُضْنِی عَلَی فِرَاشِہِ۔",,,31601
31602,"حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : مَا صَنَعَتِ الْحَامِلُ فَہُوَ وَصِیَّۃٌ۔",,,31602
31603,"حَدَّثَنَا وَکِیعٌ قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنِِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ قَالَ : الْحَامِلُ وَصِیَّۃٌ۔",,,31603
31604,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ شُرَیْحٍ ، قَالَ : الْحَامِلُ وَصِیَّۃٌ۔",,,31604
31605,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ أَعْطَتِ امْرَأَتِی عَطیَّۃ وَہِیَ حَامِلٌ ، فَقَالَتْ لِلْقَاسِمِ بْنِ مُحَمَّدٍ ، فَقَالَ : ہُوَ مِنْ جَمِیعِ الْمَالِ۔\n\nقَالَ حَمَّادٌ : قَالَ یَحْیَی : وَنَحْنُ نَقُولُ : ہُوَ مِنْ جَمِیعِ الْمَالِ مَا لَمْ یَضْرِبْہَا الطَّلْقُ۔",,,31605
31606,"حَدَّثَنَا وَکِیعٌ حَدَّثَنَا إسْرَائِیلُ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : الْحَامِلُ وَصِیَّۃٌ۔",,,31606
31607,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُحَمَّدٍ ، قَالَ : حُبِسَ إیَاسُ بْنُ مُعَاوِیَۃَ فِی الظِّنَّۃِ ، فَأَرْسَلِنِی ، فَقَالَ : انْطَلِقْ إلَی الْحَسَنِ فَاسْأَلْہُ مَا حَالِی فِیمَا أخذتُ مِنْ مَالِی عَلَی حَالِی ہَذِہِ ؟ قَالَ : فَأَتَیْت الْحَسَنَ فَقُلْتُ لَہُ : إنَّ أَخَاک إیَاسًا یُقْرِئُک السَّلاَمَ وَیَقُولُ : مَالِی فِیمَا أحدِثُ فِی یَوْمِی ہَذَا ؟ فَقَالَ الْحَسَنُ : حَالُہُ حَالُ الْمَرِیضِ ، لاَ یَجُوزُ لَہُ إلاَّ الثُّلُثُ۔",,,31607
31608,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ سِمَاکٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِذَا وَضَعَ رِجْلَہُ فِی الْغَرْزِ فَمَا أَوْصَی بِہِ فَہُوَ مِنَ الثُّلُثِ۔",,,31608
31609,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، عَنْ شُرَیْحٍ ، قَالَ : إذَا وَضَعَ رِجْلَہُ فِی الْغَرْزِ فَمَا تَکَلَّمَ بِہِ مِنْ شَیْئٍ فَہُوَ مِنْ ثُلُثِہِ۔",,,31609
31610,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ سِمَاکٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ، أَنَّہُ قَالَ : إذَا وَضَعَ الرَّجُلُ رِجْلَہُ فِی الْغَرْزِ یَقُولُ : إذَا سَافَرَ فَمَا أَوْصَی بِہِ فَہُوَ مِنَ الثُّلُثِ۔",,,31610
31611,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ : فِی الأَسِیرِ فِی أَیْدِی الْعَدُوِّ : إنْ أَعْطَی عَطِیَّۃً ، أَوْ نَحَلَ نَحْلاً ، أَوْ أَوْصَی بِثُلُثِہِ فَہُوَ جَائِزٌ۔",,,31611
31612,"حَدَّثَنَا مَعْن بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ یَجُوزُ لِلأَسِیرِ فِی مَالِہِ إلاَّ الثُّلُثُ۔",,,31612
31613,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : بَیْعُ الْوَصِیِّ جَائِزٌ۔",,,31613
31614,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ شَرِیکٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : الْوَصِیُّ بِمَنْزِلَۃِ الأَبِ۔",,,31614
31615,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ یَحْیَی بْنِ حَمْزَۃَ ، عَنْ أَبِی وَہْبٍ ، قَالَ : أمْرُ الْوَصِیِّ جَائِزٌ إلاَّ فِی الرِّبَاعِ ، وَإِنْ بَاعَ بَیْعًا لَمْ یُقَلْ۔",,,31615
31616,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنِ الْحَسَنِ ، قَالَ : یَنْظُرُ والِی الْیَتِیمِ مِثْلُ مَا یُرَی لِلْیَتِیمِ یَعْمَل لِلْیَتِیمِ بِہِ۔",,,31616
31617,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : الْوَصِیُّ بِمَنْزِلَۃِ الْوَالِدِ۔",,,31617
31618,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ : أَنَّ شُرَیْحًا کَانَ یُجِیزُ شَہَادَۃَ الأَوْصِیَائِ۔",,,31618
31619,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، مِثْلُہُ۔,,,31619
31620,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ تَجُوزُ ، ہُوَ خَصْمٌ۔",,,31620
31621,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ : أَنَّ عُمَرَ أَوْصَی لأُمَّہَاتِ أَوْلاَدِہِ بِأَرْبَعَۃِ آلاَفٍ ، أَرْبَعَۃِ آلاَفٍ۔",,,31621
31622,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَلَمَۃَ بْنِ عَلْقَمَۃَ ، عَنِ الْحَسَنِ : أَنَّ عِمْرَانَ بْنَ حُصَیْنٍ أَوْصَی لأُمَّہَاتِ أَوْلاَدِہِ۔",,,31622
31623,"حَدَّثَنَا خَالِدُ بْنُ حَیَّانَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : قُلْتُ لِمَیْمُونِ بْنِ مِہْرَانَ : الرَّجُلُ یُوصِی لأُمِّ وَلَدِہِ ؟ قَالَ : ہُوَ جَائِزٌ۔",,,31623
31624,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : أَوْصَی الشَّعْبِیُّ لأُمِّ وَلَدِہِ۔",,,31624
31625,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ : فِی الرَّجُلِ یَہَبُ لأُمِّ وَلَدِہِ ، قَالَ : ہُوَ جَائِزٌ۔",,,31625
31626,"حَدَّثَنَا مُعْتَمِرٌ، قَالَ: قُلْتُ لِیُونُسَ: رَجُلٌ وَہَبَ لأُمِّ وَلَدٍ شَیْئًا ثُمَّ مَاتَ؟ قَالَ: کَانَ الْحَسَنُ یَقُولُ: ہُوَ لَہَا۔",,,31626
31627,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَحْرَزَتْ أُمُّ الْوَلَدِ شَیْئًا فِی حَیَاۃِ سَیِّدِہَا فَمَاتَ سَیِّدُہَا فَہُوَ لَہَا وَقَدْ عَتَقَتْ ، فَإِنِ انْتَزَعَ الْمَیِّتُ شَیْئًا قَبْلَ أَنْ یَمُوتَ ، أَوْ أَوْصَی بِشَیْئٍ مِمَّا کَانَتْ أَحْرَزَتْ فِی حَیَاتِہِ : یَصْنَعُ فِیہِ مَا شَائَ۔",,,31627
31628,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَبْدِ الْکَرِیمِ بْنِ رُفَیْعٍ ، قَالَ : تُوُفِّیَ رَجُلٌ بِالرَّیِّ وَتَرَکَ مَالاً وَرَقِیقًا ، فَقَالَ : عَبْدِی فُلاَنٌ لِفُلاَنٍ وَعَبْدِی فُلاَنٌ لِفُلاَنٍ ، وَلَمْ تَبْلُغْ وَصِیَّتُہُ الثُّلُثَ ، فَلَمَّا أَقْبَلَ بِالرَّقِیقِ إلَی الْکُوفَۃِ مَاتَ بَعْضُ رَقِیقِ الْوَرَثَۃِ ، وَلَمْ یَمُتْ رَقِیقُ الَّذِی أَوْصَی لَہُمْ ، فَسَأَلْت إبْرَاہِیمَ ؟ فَقَالَ : یُعْطَی أَصْحَابَ الْوَصِیَّۃِ عَلَی مَا أَوْصَی بِہِ صَاحِبُہُ۔",,,31628
31629,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ: فِی رَجُلٍ جَعَلَ وَصِیَّتَہُ إلَی مُکَاتَبِہِ ، فَقَالَ : الْمُکَاتَبُ : إنِّی قَدْ أَنْفَقْت مُکَاتَبَتِی عَلَی عِیَالِ مَوْلاَیَ ، فَقَالَ : یُصَدَّقُ ، وَیَجُوزُ ذَلِکَ ، وَلاَ بَأْسَ أَنْ یُوصِیَ إلَی عَبْدِہِ ، فَإِنْ قَالَ الْعَبْدُ : إنِّی قَدْ کَاتَبْت نَفْسِی ، أَوْ بِعْت نَفْسِی ، لَمْ یَجُزْ ذَلِکَ۔",,,31629
31630,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : سُئِلَ عَنْ رَجُلٍ أَوْصَی لِبَنِی ہَاشِمٍ ، أَیَدْخُلُ مَوَالِیہِمْ مَعَہُمْ ؟ قَالَ : لاَ۔",,,31630
31631,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ : أَنَّ سَعْدَ بْنَ عُبَادَۃَ قَسَمَ مَالَہُ بَیْنَ وَرَثَتِہِ عَلَی کِتَابِ اللہِ ، وَامْرَأَۃٌ لَہُ قَدْ وَضَعَتْ رَجُلاً ، فَأَرْسَلِ أَبُو بَکْرٍ وَعُمَرُ إلَی قَیْسِ بْنِ سَعْدٍ أَنْ أَخْرِجْ لِہَذَا الْغُلاَمِ حَقَّہُ ، قَالَ : قَالَ أَمَّا شَیْئٌ صَنَعَہُ سَعْدٌ فَلاَ أَرْجِعُ فِیہِ ، وَلَکِنْ نَصِیبِی لَہُ ، فَقِبَلاَ ذَلِکَ مِنْہُ۔",,,31631
31632,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَیَانٍ ، عَنْ وَبَرَۃَ ، قَالَ : اشْتَرَی رَجُلٌ أُخْتًا لَہُ کَانَتْ سُبِیَّت فِی الْجَاہِلِیَّۃِ فَاشْتَرَاہَا وَابْنًا لَہَا لاَ یُدْرَی مَنْ أَبُوہُ ، فَشَبَّ فَأَصَابَ مَالاً ، ثُمَّ مَاتَ فَأَتَوْا عُمَرَ فَقَصُّوا عَلَیْہِ الْقِصَّۃَ ، فَقَالَ : خُذُوا مِیرَاثَہُ فَاجْعَلُوہُ فِی بَیْتِ الْمَالِ ، مَا أُرَاہُ تَرَکَ وَلِیَّ نِعْمَۃٍ ، وَلاَ أَرَی لَک فَرِیضَۃً ، فَبَلَغَ ذَلِکَ ابْنَ مَسْعُودٍ ، فَقَالَ : مَہْ ، حَتَّی أَلْقَاہُ ، فَلَقِیَہُ ، فَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ عَصَبَۃٌ وَوَلِیُّ نِعْمَۃٍ ، قَالَ : کَذَا ؟ قَالَ : نَعَمْ، فَأَعْطَاہُ الْمَالَ۔",,,31632
31633,"حَدَّثَنَا یَحْیَی بْنُ عِیسَی ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : جَائَ رَجُلٌ إلَی عُمَرَ ، فَقَالَ لَہُ : کَانَتْ لِی أُخْتٌ بَغِیٌّ فَتُوُفِّیَتْ وَتَرَکَتْ غُلاَمًا فَمَاتَ وَتَرَکَ ذَوْدًا مِنَ الإِبِلِ ، فَقَالَ عُمَرُ : مَا أَرَی بَیْنَکَ وَبَیْنَہُ نَسَبًا ، ائْتِ بِہَا فَاجْعَلْہَا فِی إبِلِ الصَّدَقَۃِ ، قَالَ : فَأَتَی ابْنَ مَسْعُودٍ فَذَکَرَ ذَلِکَ لَہُ ، فَقَامَ عَبْدُ اللہِ فَأَتَی عُمَرَ ، فَقَالَ : مَا تَقُولُ یَا أَمِیرَ الْمُؤْمِنِینَ ؟ فَقَالَ : مَا أَرَی بَیْنَہُ وَبَیْنَہُ نَسَبًا ، فَقَالَ : أَلَیْسَ ہُوَ خَالُہُ وَوَلِیُّ نِعْمَتِہِ ؟ فَقَالَ : مَا تَرَی ؟ قَالَ : أَرَی أَنَّہُ أَحَقُّ بِمَالِہِ ، فَرَدَّہَا عَلَیْہِ عُمَرُ۔",,,31633
31634,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی عَوَانَۃَ ، قَالَ : سُئِلَ حَمَّادٌ عَنْ رَجُلٍ أَوْصَی فِی الْفُقَرَائِ بِدَرَاہِمَ ؟ قَالَ : لَمْ یَرَ بَأْسًا أَنْ یُفَضِّلَ بَعْضَہُمْ عَلَی بَعْضٍ بِقَدْرِ الْحَاجَۃِ۔",,,31634
31635,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : أَحَقٌّ تَسْوِیَۃُ النِّحَلِ بَیْنَ الْوَلَدِ عَلَی کِتَابِ اللہِ ؟ قَالَ : نَعَمْ ، وَقَدْ بَلَغَنَا ذَلِکَ عَنْ نَبِیِّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّہُ قَالَ : سَوَّیْت بَیْنَ وَلَدِکَ ؟ قُلْتُ : فِی النُّعْمَانِ ؟ قَالَ : وَغَیْرِہِ ، زَعَمُوا۔",,,31635
31636,"حَدَّثَنَا عَبَّادٌ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَمِعْتُ النُّعْمَانَ بْنَ بَشِیرٍ یَقُولُ : أَعْطَانِی أَبِی عَطِیَّۃً ، فَقَالَتْ أُمِّی عَمْرَۃُ ابْنَۃُ رَوَاحَۃَ : فَلاَ أَرْضَی حَتَّی تُشْہِدَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَتَی رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، إنِّی أَعْطَیْت ابْنَ عَمْرَۃَ عَطِیَّۃً فَأَمَرَتْنِی أَنْ أُشْہِدَک ، فَقَالَ : أَعْطَیْت کُلَّ وَلَدِکَ مِثْلَ ہَذَا ؟ قَالَ : لاَ ، قَالَ : فَاتَّقُوا اللَّہَ وَاعْدِلُوا بَیْنَ أَوْلاَدِکُمْ ، قَالَ : فَرَجَعَ فَرَدَّ عَطِیَّتَہُ۔\n\n(بخاری 2587۔ مسلم 1242)",,,31636
31637,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، وَعَنْ مُحَمَّدِ بْنِ النُّعْمَانِ ، عَنْ أَبِیہِ : أَنْ أَبَاہُ نَحَلَہُ غُلاَمًا وَأَنَّہُ أَتَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِیُشْہِدَہُ ، فَقَالَ : أَکُلَّ وَلَدِکَ أَعْطَیْتہ مِثْلَ ہَذَا ، قَالَ : لاَ قَالَ : فَارْدُدْہُ۔ (مسلم 1242۔ ترمذی 1367)",,,31637
31638,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ أَبِی حَیَّانَ ، عَنِ الشَّعْبِیِّ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ، قَالَ : انْطَلَقَ بِی أَبِی إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِیُشْہِدَہُ عَلَی عَطِیَّۃٍ أَعْطَانِیہَا ، قَالَ : لَک غَیْرُہُ ، قَالَ : نَعَمْ ، قَالَ : کُلَّہُم أَعْطَیْتَہُمْ مِثْلَ أُعْطِیَّتِہِ ؟ قَالَ : لاَ ، قَالَ : فَلاَ أَشْہَدُ عَلَی جَوْرٍ۔ (بخاری 2650۔ احمد 268)",,,31638
31639,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، قَالَ : کَانَ طَاوس إذَا سُئِلَ عَنْہُ ، قَرَأَ : {أَفَحُکْمَ الْجَاہِلِیَّۃِ یَبْغُونَ}۔",,,31639
31640,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ، قَالَ: قَالَ عُرْوَۃٌ: یُرَدُّ مِنْ حَیْفِ الْحَیِّ مَا یُرَدُّ مِنْ حَیْفِ الْمَیِّتِ۔",,,31640
31641,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ مِسْمَعِ بْنِ ثَابِتٍ ، عَنْ عِکْرِمَۃَ : أَنَّہُ کَانَ یَکْرَہُہُ۔",,,31641
31642,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ أَنْ یَعْدِلَ الرَّجُلُ بَیْنَ وَلَدِہِ حَتَّی فِی الْقُبَلِ۔",,,31642
31643,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ : أَنَّہُ کَرِہَ أَنْ یُفَضِّلَ الرَّجُلُ بَعْضَ وَلَدِہِ عَلَی بَعْضٍ وَکَانَ یُجِیزُہُ فِی الْقَضَائِ۔",,,31643
31644,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا مُجَالِدٌ ، عَنْ عَامِرٍ ، عَنْ شُرَیْحٍ ، أَنَّہُ قَالَ : لاَ بَأْسَ أَنْ یُفَضِّلَ الرَّجُلُ بَعْضَ وَلَدِہِ عَلَی بَعْضٍ۔",,,31644
31645,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ أَبِی حَیَّانَ ، قَالَ : حدَّثَنِی أَبِی ، قَالَ : حَضَرَ جَارٌ لِشُرَیْحٍ وَلَہُ بَنُونَ ، فَقَسَمَ مَالَہُ بَیْنَہُمْ لاَ یَأْلُو أَنْ یَعْدِلَ ، ثُمَّ دَعَا شُرَیْحًا فَجَائَ ، فَقَالَ : أَبَا أُمَیَّۃَ إنِّی قَسَمْت مَالِی بَیْنَ وَلَدِی وَلَمْ آلُ ، وَقَدْ أَشْہَدْتُک ، فَقَالَ شُرَیْحٌ : قِسْمَۃُ اللہِ أَعْدَلُ مِنْ قِسْمَتِکَ ، فَارْدُدْہُمْ إلَی سِہَامِ اللہِ وَفَرَائِضِہِ وَأَشْہِدْنِی وَإِلاَّ فَلاَ تُشْہِدْنِی ، فَإِنِّی لاَ أَشْہَدُ عَلَی جَوْرٍ۔",,,31645
31646,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ : أَنَّہُ حَضَرَ رَجُلاً یُوصِی فَأَوْصَی بِأَشْیَائَ لاَ تََنْبَغِی ، فَقَالَ مَسْرُوقٌ : إنَّ اللَّہَ قَدْ قَسَمَ بَیْنَکُمْ فَأَحْسَنَ ، وَإِنَّہُ مَنْ یَرْغَبْ بِرَأْیِہِ عَنْ رَأْیِ اللہِ یَضِل ، أَوْصِ لِذَوِی قَرَابَتِکَ مِمَّنْ لاَ یَرْغَب ، ثُمَّ دَع الْمَالَ عَلَی مَنْ قَسَمَہُ اللَّہُ عَلَیْہِ۔",,,31646
31647,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنِ الْقَاسِمِ وَالشَّعْبِیِّ : فِی رَجُلٍ کَانَ بِہِ جُذَامٌ ، فَقَالَ : أَخِی شَرِیکِی فِی مَالِی ، فَقَالَ : إنْ شَہِدَتِ الشُّہُودُ أَنَّہُ أَوْصَی بِہِ قَبْلَ أَنْ یُصِیبَہُ وَجَعَہُ شَرَّکَہُ۔",,,31647
31648,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ وَالْحَسَنِ ، قَالَ : إذَا أَقَرَّ بَعْضُ الْوَرَثَۃِ بِدَیْنٍ عَلَی الْمَیِّتِ جَازَ عَلَیْہِ فِی نَصِیبِہِ۔",,,31648
31649,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ : فِی وَارِثٍ أَقَرَّ بِدَیْنٍ ، قَالَ : عَلَیْہِ فِی نَصِیبِہِ بِحِصَّتِہِ ، قَالَ : ثُمَّ قَالَ بَعْدَ ذَلِکَ : یُخَرَّجُ مِنْ نَصِیبِہِ۔",,,31649
31650,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : عَلَیْہِ فِی نَصِیبِہِ بِحِصَّتِہِ۔",,,31650
31651,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ مُغِیرَۃَ ، عَنْ عَامِرٍ : فِی رَجُلٍ مَاتَ وَتَرَکَ ابْنَیْنِ ، وَتَرَکَ مِئَتَیْ دِینَارٍ ، فَأَقَرَّ أَحَدُ الاِبْنَیْنِ أَنَّ عَلَی أَبِیہِ خَمْسِینَ دِینَارًا ، قَالَ : یُؤْخَذُ مِنْ نَصِیبِ ہَذَا وَیَسْلََمُ لِلآخَرِ نَصِیبُہُ۔",,,31651
31652,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا أَقَرَّ بَعْضُ الْوَرَثَۃِ بِدَیْنٍ عَلَی الْمَیِّتِ جَازَ عَلَیْہِ فِی نَصِیبِہِ۔",,,31652
31653,"حَدَّثَنَا حَفْصٌ، عَنْ أَشْعَثَ، عَنِ الشَّعْبِیِّ، قَالَ: إذَا شَہِدَ رَجُلاَنِ أَوْ ثَلاَثَۃٌ مِنَ الْوَرَثَۃِ فَإِنَّمَا أَقَرُّوا عَلَی أَنْفُسِہِمْ۔",,,31653
31654,"حَدَّثَنَا حَفْصٌ، عَنْ أَشْعَثَ، عَنِ الْحَکَمِ وَحَمَّادٌ، عَنْ إبْرَاہِیمَ، قَالَ: یَجُوزُ عَلَی الْوَرَثَۃِ بِحِسَابِ مَا وَرِثُوا۔",,,31654
31655,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : ہُمَا شَاہِدَانِ مِنَ الْمُسْلِمِینَ ، تَجُوزُ شَہَادَتُہُمَا عَلَی الْوَرَثَۃِ کُلِّہِمْ۔",,,31655
31656,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا شَہِدَ اثْنَانِ مِنَ الْوَرَثَۃِ جَازَ عَلَیْہِمَا فِی أَنْصِبَائِہِمَا ، وَقَالَ الْحَکَمُ : یَجُوزُ عَلَیْہِمْ جَمِیعًا۔",,,31656
31657,"حَدَّثَنَا عَبْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ مَنْصُورٍ ، عَنِ الْحَارِثِ ، قَالَ : إذَا شَہِدَ اثْنَانِ مِنَ الْوَرَثَۃِ لِرَجُلٍ بِدَیْنٍ أُعْطِیَ دَیْنَہُ۔",,,31657
31658,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا شَہِدَ أَحَدُ الْوَرَثَۃِ جَازَ عَلَیْہِمْ کُلِّہِمْ۔",,,31658
31659,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ مَرْوَانَ ، عَنْ إبْرَاہِیمَ ، عَنِ ابْنِ سِیرِینَ : سُئِلَ عَنْ رَجُلٍ ، قَالَ : إنْ حَدَثَ بِی حَدَثٌ فَعَبْدِی حُرٌّ ، فَاحْتَاجَ إلَیْہِ ، أَلَہُ أَنْ یَبِیعَہُ ؟ قَالَ : نَعَمْ۔",,,31659
31660,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ : فِی رَجُلٍ قَالَ لِعَبْدِہِ : إنْ مِتّ فِی مَرَضِی ہَذَا فَأَنْتَ حُرٌّ ، قَالَ : لَیْسَ لَہُ أَنْ یَبِیعَہُ حَتَّی یَمُوتَ۔",,,31660
31661,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ وَمُحَمَّدٍ: أَنَّہُمَا کَرِہَا أَنْ یَشْتَرِیَ الْوَصِیُّ مِنَ الْمِیرَاثِ شَیْئًا۔",,,31661
31662,"حَدَّثَنَا عَبْدُ اللہِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ وَعَطَائٍ ، قَالاَ : لاَ یَجُوزُ لِوَالٍ أَنْ یَشْتَرِیَ مِمَّا وَلِیَ عَلَیْہِ۔\n\nقَالَ : وَقَالَ مُجَاہِدٌ : لاَ تَشْتَرِ إحْدَی یَدَیْک مِنَ الأُخْرَی۔",,,31662
31663,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ صِلَۃَ بْنِ زُفَرَ ، قَالَ : کَانَ عِنْدَ عَبْدِ اللہِ فَأَتَاہُ رَجُلٌ عَلَی فَرَسٍ أَبْلَقٍ ، فَقَالَ : تَأْمُرُنِی أَنْ أَشْتَرِیَ ہَذَا ؟ قَالَ : وَمَا شَأْنُہُ ؟ قَالَ : أَوْصَی إلَیَّ رَجُلٌ وَتَرَکَہُ فَأَقَمْتہ فِی السُّوقِ عَلَی ثَمَنٍ ، قَالَ : لاَ تَشْتَرِہِ ، وَلاَ تَسْتَسْلِفْ مِنْ مَالِہِ۔\n\nقَالَ أَبُو إِسْحَاقَ : سَمِعْتہ مِنْ صِلَۃَ مُنْذُ سِتِّینَ سَنَۃً۔",,,31663
31664,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا سِنَانُ بْنُ ہَارُونَ الْبُرْجُمِیُّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ وَابْنِ سِیرِینَ، قَالاَ : فِی رَجُلٍ أَوْصَی لِعَبْدِہِ بِالثُّلُثِ ، قَالاَ : ذَلِکَ مِنْ رَقَبَتِہِ ، فَإِنْ کَانَ الثُّلُثُ أَکْثَرَ مِنْ ثَمَنِہِ عَتَقَ وَدَفَعَ إلَیْہِ مَا بَقِی ، وَإِنْ کَانَ أَقَلَّ مِنْ ثُمَّنِہِ عَتَقَ وَسَعَی لَہُمْ فِیمَا بَقِی ، وَإِنْ أَوْصَی لَہُمْ بِدَرَاہِمَ ، فَإِنْ شَائَ الْوَرَثَۃُ أَجَازُوا ، وَإِنْ شَاؤُوا لَمْ یُجِیزُوا۔",,,31664
31665,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ أَبِی خَالِدٍ ، عَنْ حَکِیمِ بْنِ جَابِرٍ : أَنَّہُ قِیلَ لَہُ فِی الْوَصِیَّۃِ عِنْدَ الْمَوْتِ : لَوْ أَعْتَقْت غُلاَمَک ! فَقَرَأَ ہَذِہِ الآیَۃَ : {وَلْیَخْشَ الَّذِینَ لَوْ تَرَکُوا مِنْ خَلْفِہِمْ ذُرِّیَّۃً ضِعَافًا خَافُوا عَلَیْہِمْ}۔",,,31665
31666,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ عَبْدِ الْعَزِیزِ ، عَنْ إسْمَاعِیلَ ، عَنْ حَکِیمِ بْنِ جَابِرٍ : أَنَّہُ لَمَّا حَضَرَہُ الْمَوْتُ وَکَانَ لَہُ غُلاَمٌ فَقِیلَ لَہُ : لَوْ أَعْتَقْت ہَذَا ؟ فَقَالَ : إنِّی لَمْ أَتْرُکْ لِوَلَدِی غَیْرَہُ ، قَالَ : فَأَعَادُوا عَلَیْہِ : لَوْ أَعْتَقَہُ ، فَقَرَأَ ہَذِہِ الآیَۃَ {وَلْیَخْشَ الَّذِینَ لَوْ تَرَکُوا مِنْ خَلْفِہِمْ ذُرِّیَّۃً ضِعَافًا خَافُوا عَلَیْہِمْ} إلَی قَوْلِہِ {سَدِیدًا}۔",,,31666
31667,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ نُسَیْرٍ ، قَالَ : قَالَ رَجُلٌ لِلرَّبِیعِ بْنِ خُثَیْمٍ : أَوْصِ لِی بِمُصْحَفِکَ ، قَالَ : فَنَظَرَ إلَی ابْنٍ لَہُ صَغِیرٍ ، فَقَالَ : {وَأُولُوا الأَرْحَامِ بَعْضُہُمْ أَوْلَی بِبَعْضٍ فِی کِتَابِ اللہِ}۔",,,31667
31668,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ عَاصِمٍ ، قَالَ : مَرِضَ أَبُو الْعَالِیَۃِ فَأَعْتَقَ مَمْلُوکًا ، ذَکَرَوا لَہُ أَنَّہ مِنْ وَرَائِ النَّہَرِ ، فَقَالَ : إنْ کَانَ حَیًّا فَلاَ أَعْتِقُہُ ، وَإِنْ کَانَ مَیِّتًا فَہُوَ عَتِیقٌ وَذَکَرَ ہَذِہِ الآیَۃَ {وَلَہُ ذُرِّیَّۃٌ ضُعَفَائُ}۔",,,31668
31669,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنِ الأَشْجَعِیِّ سَمِعَ سُفْیَانَ یَقُولُ : فِی رَجُلٍ أَوْصَی بِثُلُثِہِ لِرَجُلَیْنِ فَیُوجَدُ أَحَدُہُمَا مَیِّتًا ، قَالَ : یَکُونُ لِلآخَرِ۔ یَعْنِی : الثُّلُثَ کُلَّہُ۔\n\nقَالَ یَحْیَی : وَہُوَ الْقَوْلُ۔",,,31669
31670,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ : فِی رَجُلٍ أَوْصَی لِعَقِبِ بَنِی فُلاَنٍ ، قَالَ : لَیْسَ الْمَرْأَۃُ مِنَ الْعَقِبِ۔",,,31670
31671,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : عَقِبُ الرَّجُلِ : وَلَدُہُ ، وَوَلَدُ وَلَدِہِ مِنَ الذُّکُورِ۔",,,31671
31672,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا وَضَّاحٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ : فِی رَجُلٍ تُوُفِّیَ وَتَرَکَ ثَلاَثَۃَ بَنِینَ ، وَقَالَ : ثُلُثُ مَالِی لأَصْغَرِ بَنِیَّ ، فَقَالَ : الأَکْبَرُ : أَنَا لاَ أُجِیزُ ، وَقَالَ الأَوْسَطُ : أَنَا أُجِیزُ ، فَقَالَ : اجْعَلْہَا عَلَی تِسْعَۃِ أَسْہُمٍ : یُرْفَعُ ثَلاَثَۃ ، فَلَہُ سَہْمُہُ وَسَہْمُ الَّذِی أَجَازَہُ۔\n\nوَقَالَ حَمَّادٌ : یُرَدُّ عَلَیْہِمَ السَّہْمُ جَمِیعًا۔\n\nوَقَالَ عَامِرٌ : الَّذِی رَدَّ إنَّمَا رَدَّ عَلَی نَفْسِہِ۔",,,31672
31673,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْفَزَارِیِّ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : سُئِلَ الزُّہْرِیُّ عَنِ امْرَأَۃٍ أَوْصَتْ بِثُلُثِ مَالِہَا لِزَوْجِہَا فِی سَبِیلِ اللہِ ؟ قَالَ : لاَ یَجُوزُ إلاَّ أَنْ تَقُولَ : ہُوَ فِی سَبِیلِ اللہِ إلَی زَوْجِی ، یَضَعُہُ حَیْثُ شَاء ۔",,,31673
31674,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، قَالَ : کُنْتُ عِنْدَ دَاوُد بْنِ أَبِی ہِنْدٍ ، فَجَائَ رَجُلاَنِ أَوْ أَکْثَرُ مِنْ آلِ أَنَسِ بْنِ مَالِکٍ بَیْنَہُمْ عُبَیْدُ اللہِ بْنُ أَبِی بَکْرٍ ، وَجَاؤُوا مَعَہُمْ بِکِتَابٍ فِی صَحِیفَۃٍ ذَکَرُوا أَنَّہَا وَصِیَّۃُ أَنَسِ بْنِ مَالِکَ ، فَفُتِحْت صَدْرُہَا : بِسْمِ اللہِ الرَّحْمَن الرَّحِیمِ ہَذَا ذِکْرُ مَا کَتَبَ أَنَسُ بْنُ مَالِکٍ فِی ہَذِہِ الصَّحِیفَۃِ مِنْ أَمْرِ وَصِیَّتِہِ ، إنِّی أُوصِی مَنْ تَرَکْت مِنْ أَہْلِی کُلّہُم بِتَقْوَی اللہِ وَشُکْرِہِ وَاسْتِمْسَاکٍ بِحَبْلِہِ ، وَإِیمَانٍ بِوَعْدِہِ ، وَأُوصِیہِمْ بِصَلاَحِ ذَاتِ بَیْنِہِم وَالتَّرَاحُمِ وَالْبِرِّ وَالتَّقْوَی ، ثُمَّ أَوْصَی إنْ تُوُفِّیَ أَنَّ ثُلُثَ مَالِہِ صَدَقَۃٌ إلاَّ أَنْ یُغَیِّرَ وَصِیَّتَہُ قَبْلَ أَنْ یَلْحَقَ بِاللہِ ، أَلْف فِی سَبِیلِ اللہِ إنْ کَانَ أَمْرُ الأُمَّۃِ یَوْمئِذٍ جَمِیعًا ، وَفِی الرِّقَابِ وَالأَقْرَبِینَ ، وَمَنْ سَمَّیْت لَہُ الْعِتْقَ مِنْ رَقِیقِی یَوْمَ دُبُر مِنِّی فَأَدْرَکَہُ الْعِتْقُ فَإِنَّہُ یُقِیمُہُ وَلِیُّ وَصِیَّتِی فِی الثُّلُثِ غَیْرَ حَرِجٍ ، وَلاَ مُنَازِعٍ۔",,,31674
31675,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنِ ابْنِ عَوْنٍ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ مِنْہُمْ مَنْ یُوَرِّثُ الصَّامِتَ وَمِنْہُمْ مَنْ لاَ یُوَرِّثُہُ۔",,,31675
31676,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُوسَی ، قَالَ : قَالَ سُفْیَانُ : لاَ تَجُوزُ وَصِیَّۃٌ لأَہْلِ الْحَرْبِ۔",,,31676
31677,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ سَعِیدِ بْنِ السَّائِبِ : أَنَّ رَجُلاً أَوْصَی أَنْ تُعْتَقَ عَنْہُ رَقَبَتَانِ بِثَمَنٍ ، وَسَمَّاہُ ، فَلَمْ یُوجَدْ بِذَلِکَ الثَمَنُ رَقَبَتَانِ ، فَسَأَلْت عَطَائً ، فَقَالَ : اشْتَرُوا رَقَبَۃً وَاحِدَۃً وَأَعْتِقُوہَا عَنْہُ۔",,,31677
31678,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامُ بْنُ حَسَّانٍ ، قَالَ : کَانَ أَوَّلُ وَصِیَّۃِ مُحَمَّدِ بْنِ سِیرِینَ : ہَذَا مَا أَوْصَی بِہِ مُحَمَّدُ بْنُ أَبِی عَمْرَۃَ ، أَنَّہُ یَشْہَدُ أَنْ لاَ إلَہَ إلاَّ اللَّہُ ، وَأَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ، وَأَوْصَی بَنِیہِ وَأَہْلِہِ أَنِ {اتَّقُوا اللَّہَ وَأَصْلِحُوا ذَاتَ بَیْنِکُمْ وَأَطِیعُوا اللَّہَ وَرَسُولَہُ إنْ کُنْتُمْ مُؤْمِنِینَ} ، وَأُوصِیہِمْ بِمَا أَوْصَی بِہِ إبْرَاہِیمُ بَنِیہِ وَیَعْقُوبُ : {یَا بَنِیَّ إنَّ اللَّہَ اصْطَفَی لَکُمُ الدِّینَ فَلاَ تَمُوتُنَّ إلاَّ وَأَنْتُمْ مُسْلِمُونَ} وَزَعَمَ أَنَّہَا کَانَتْ أَوَّلَ وَصِیَّۃِ أَنَسِ بْنِ مَالِکٍ۔",,,31678
