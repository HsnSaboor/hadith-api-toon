hadiths[30]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
3770,عبداللہ ‌بن ‌عمر ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌رسول ‌اللہ ‌نے ‌فرمایا ‌جو ‌شخص ‌اپنا ‌حصہ ‌آزاد ‌ك,,,,,3770
3771,اس حدیث کی دوسری اسناد مذکورہیں  ۔,,,,,3771
3772,حضرت ‌ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌سے ‌روایت ‌ہے ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌نے ‌فرمایا ‌جو ‌بر,,,,,3772
3773,ابو ‌ہریرہ ‌رضی ‌اللہ ‌عنہ ‌سے ‌رویت ‌ہے ‌رسول ‌اللہ ‌صلی ‌اللہ ‌علیہ ‌وسلم ‌نے ‌فرمایا ‌جو ‌شخص ‌اپ,,,,,3773
3774,ترجمہ ‌دوسری ‌روایت ‌كا ‌بھی ‌وہی ‌ہے ‌جو ‌اوپر ‌گذرا ‌اس ‌میں ‌اتنا ‌زیادہ ‌ہے ‌كہ ‌اگر ‌وہ ‌آزاد ‌,,,,,3774
3775,قتادہ ‌رضی ‌اللہ ‌عنہ ‌نے ‌ابن ‌ابی ‌عروبہ ‌كی ‌حدیث ‌كی ‌مانند ‌روایت ‌كی ‌اور ‌حدیث ‌میں ‌یہ ‌بھی ,,,,,3775
3776,حضرت ابن عمر رضی اللہ عنہ نے حضرت عائشہ رضی اللہ عنہا سے روایت کی کہ انہوں نے ایک لونڈی خرید کر اسے ,,,,,3776
3777,لیث نے ہمیں ابن شہاب سے حدیث بیان کی ،  انہوں نے عروہ سے روایت کی ،  حضرت عائشہ رضی اللہ عنہا نے انہ,,,,,3777
3778,یونس نے مجھے ابن شہاب سے خبر دی ،  انہوں نے عروہ بن زبیر سے ،  انہوں نے نبی صلی اللہ علیہ وسلم کی اہ,,,,,3778
3779,"ابواسامہ نے کہا :  ہمیں ہشام بن عروہ نے حدیث بیان کی ،  انہوں نے کہا :  مجھے میرے والد نے حضرت عائشہ",,,,,3779
3780,ابن نمیر ،  وکیع اور جریر سب نے ہشام بن عروہ سے اسی سند کے ساتھ ابواسامہ کی حدیث کے ہم معنی روایت بی,,,,,3780
3781,ہشام بن عروہ نے ہمیں عبدالرحمٰن بن قاسم سے حدیث بیان کی ،  انہوں نے اپنے والد سے ،  انہوں نے حضرت عا,,,,,3781
3782,سماک نے عبدالرحمٰن بن قاسم سے ،  انہوں نے اپنے والد سے ،  انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت,,,,,3782
3783,"ہمیں محمد بن جعفر نے حدیث بیان کی ،  کہا :  ہمیں شعبہ نے حدیث بیان کی ،  انہوں نے کہا :  میں نے عبدا",,,,,3783
3784,"ابوداؤد نے ہمیں حدیث بیان کی ،   ( کہا :   )  ہمیں شعبہ نے اسی سند سے اسی کے ہم معنی حدیث بیان کی",,,,,3784
3785,"عروہ نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہا :  بریرہ رضی اللہ عنہا کا شوہر غلام تھا",,,,,3785
3786,ربیعہ بن ابوعبدالرحمٰن نے قاسم بن محمد سے ،  انہوں نے نبی صلی اللہ علیہ وسلم کی اہلیہ حضرت عائشہ رضی,,,,,3786
3787,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  حضرت عائشہ رضی اللہ عنہا نے چاہا کہ ایک لو",,,,,3787
3788,سلیمان بن بلال نے ہمیں عبداللہ بن دینار سے خبر دی ،  انہوں نے ابن عمر رضی اللہ عنہ سے روایت کی کہ رس,,,,,3788
3789,ابن عیینہ ،  اسماعیل بن جعفر ،  سفیان ثوری ،  شعبہ ،  عبیداللہ اور ضحاک بن عثمان سب نے عبداللہ بن دی,,,,,3789
3790,"حضرت جابر بن عبداللہ رضی اللہ عنہ کہتے ہیں :  نبی صلی اللہ علیہ وسلم نے  ( میثاقِ مدینہ میں )  دیتوں",,,,,3790
3791,سہیل نے اپنے والد  ( صالح سمان )  سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول الل,,,,,3791
3793,"شیبان نے اعمش سے اسی سند کے ساتھ حدیث بیان کی ،  البتہ انہوں نے کہا :   "" جس نے اپنے آزاد کرنے والوں",,,,,3793
3794,"ابراہیم تیمی کے والد یزید بن شریک سے روایت ہے ،  انہوں نے کہا :  حضرت علی بن ابی طالب رضی اللہ عنہ ن",,,,,3794
3795,اسماعیل بن ابی حکیم نے مجھے سعید بن مرجانہ سے حدیث بیان کی ،  انہوں نے ابوہریرہ رضی اللہ عنہ سے اور ,,,,,3795
3796,علی بن حسین نے سعید بن مرجانہ سے ،  انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ,,,,,3796
3797,عمر بن  ( زین العابدین )  علی بن حسین  ( بن علی بن ابی طالب )  نے سعید بن مرجانہ سے اور انہوں نے حضر,,,,,3797
3798,"واقد بن محمد نے ہمیں حدیث بیان کی ،   ( کہا :   )  مجھے علی بن حسین  ( بن علی بن ابی طالب )  کے ساتھ",,,,,3798
3799,"ابوبکر بن ابی شیبہ اور زہیر بن حرب نے کہا :  ہمیں جرید نے سہیل سے حدیث بیان کی ،  انہوں نے اپنے والد",,,,,3799
3800,وکیع ،  عبداللہ بن نمیر اور ابو احمد زبیری سب نے سفیان سے ،  انہوں نے سہیل سے اسی سند کے ساتھ اسی کے,,,,,3800
