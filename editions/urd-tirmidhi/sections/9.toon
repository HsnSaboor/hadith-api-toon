hadiths[157]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
809,ابوشریح عدوی رضی الله عنہ سے روایت ہے کہ  انہوں نے عمرو بن سعید ۲؎ سے - جب وہ مکہ کی طرف  ( عبداللہ ,,,,,809
810,"عبداللہ بن مسعود رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”حج اور عمرہ ایک ",,,,,810
811,"ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے حج کیا اور اس نے ک",,,,,811
812,"علی رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”سفر کے خرچ اور سواری کا مالک ",,,,,812
813,عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  ایک شخص نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ کر پوچھا,,,,,813
814,علی بن ابی طالب رضی الله عنہ کہتے ہیں کہ  جب یہ حکم نازل ہوا کہ ”اللہ کے لیے لوگوں پر خانہ کعبہ کا ح,,,,,814
815,جابر بن عبداللہ رضی الله عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے تین حج کئے، دو حج ہجرت سے,,,,,815
