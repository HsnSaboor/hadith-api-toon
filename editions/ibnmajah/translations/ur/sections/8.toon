{"hadithnumber": "1810", "text": "عبداللہ بن انیس رضی اللہ عنہ بیان کرتے ہیں کہ  انہوں نے اور عمر بن خطاب رضی اللہ عنہ نے ایک دن زکاۃ"}
{"hadithnumber": "1811", "text": "عمران رضی اللہ عنہ کے غلام عطا بیان کرتے ہیں کہ  عمران بن حصین رضی اللہ عنہما زکاۃ پہ عامل بنائے گئے"}
{"hadithnumber": "1812", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسلمان پر اس کے گھوڑے او"}
{"hadithnumber": "1813", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  میں نے تم سے گھوڑوں، غلام اور"}
{"hadithnumber": "1814", "text": "معاذ بن جبل رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے انہیں یمن بھیجا اور فرمایا:"}
{"hadithnumber": "1815", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ان پانچ چیزوں می"}
{"hadithnumber": "1816", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو غلہ بارش یا چشمہ کے پ"}
{"hadithnumber": "1817", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو غل"}
{"hadithnumber": "1818", "text": "معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے یمن بھیجا، اور حکم دیا کہ"}
{"hadithnumber": "1819", "text": "عتاب بن اسید رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم لوگوں کے پاس ایک شخص کو بھیجتے"}
{"hadithnumber": "1820", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے جب خیبر فتح کیا، تو آپ"}
{"hadithnumber": "1821", "text": "عوف بن مالک اشجعی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم گھر سے نکلے، اور ایک شخص نے"}
{"hadithnumber": "1822", "text": "براء بن عازب رضی اللہ عنہما کہتے ہیں  آیت کریمہ: «ومما أخرجنا لكم من الأرض ولا تيمموا الخبيث منه تن"}
{"hadithnumber": "1823", "text": "ابوسیارہ متقی رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! میرے پاس شہد کی مکھیاں ہیں؟ آپ"}
{"hadithnumber": "1824", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے شہد سے دسواں حصہ زکاۃ لی۔"}
{"hadithnumber": "1825", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے کھجور اور جو سے ایک ای"}
{"hadithnumber": "1826", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے صدقہ فطر میں ایک صاع کھجو"}
{"hadithnumber": "1827", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے صدقہ فطر روزہ دار کو فحش"}
{"hadithnumber": "1828", "text": "قیس بن سعد رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے زکاۃ کا حکم نازل ہونے سے پہلے ہ"}
{"hadithnumber": "1829", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  جب ہم میں رسول اللہ صلی اللہ علیہ وسلم موجود تھے ہم تو صدقہ"}
{"hadithnumber": "1830", "text": "مؤذن رسول سعد رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک صاع کھجور، ایک صاع جو"}
{"hadithnumber": "1831", "text": "علاء بن حضرمی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے بحرین ہجر بھیجا، میں ای"}
{"hadithnumber": "1832", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ایک وسق ساٹھ صاع کا"}
{"hadithnumber": "1833", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایک وسق ساٹھ صاع کا ہوتا ہے"}
{"hadithnumber": "1834", "text": "عبداللہ بن مسعود رضی اللہ عنہ کی بیوی زینب رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "1835", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں صدقہ کا حکم دیا،"}
{"hadithnumber": "1836", "text": "زبیر بن عوام رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اگر تم میں سے کوئی ا"}
{"hadithnumber": "1837", "text": "ثوبان رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کون میری ایک بات قبول کرتا"}
{"hadithnumber": "1838", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے لوگوں سے مال بڑھان"}
{"hadithnumber": "1839", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  صدقہ و خیرات کسی مالدار"}
{"hadithnumber": "1840", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص سوال کرے"}
{"hadithnumber": "1841", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مالدار کے لیے زکاۃ"}
{"hadithnumber": "1842", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا ہے:  جو شخص حلال مال سے صد"}
{"hadithnumber": "1843", "text": "عدی بن حاتم رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ تم میں سے"}
{"hadithnumber": "1844", "text": "سلمان بن عامر ضبی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسکین و فقیر کو"}
