{"hadithnumber": "994", "text": "( اعمش کے بجائے )  عمرو  ( بن دینار جحمی )  نے مجاہد سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہما سے"}
{"hadithnumber": "995", "text": "( خود )  بلال بن عبد اللہ بن عمر نے اپنے والد حضرت ابن عمر رضی اللہ عنہما سے روایت کی ،  انہوں نے کہ"}
{"hadithnumber": "996", "text": "مخرمہ نے اپنے والد  ( بکیر )  سے ،  انہوں نے بسر بن سعید  روایت کی کہ حضرت زینب ثقفیہ رضی اللہ عنہما"}
{"hadithnumber": "997", "text": "( مخرمہ کے بجائے )  محمد بن عجلان نے بکیر بن عبد اللہ بن اشج سے ،  انہوں نے بسر بن سعید سے ،  انہوں"}
{"hadithnumber": "998", "text": "حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  انہوں  نے کہا کہ رسول اللہﷺ نے فرمایا :  ’’ جس عو"}
{"hadithnumber": "999", "text": "سلیمان بن بلال نے یحییٰ بن سعید  سے اور انہوں نے عمرہ بنت عبد الرحمان سے روایت کی کہ انہوں نے نبی ﷺ"}
{"hadithnumber": "1000", "text": "( سلیمان بن بلال کے بجائے )  عبد الوہاب ثقفی ،  سفیان بن عیینہ ،  ابو خالد احمر  اورعیسیٰ بن یونس سب"}
{"hadithnumber": "1001", "text": "سعید بن جبیر نے حضرت ابن عباس رضی اللہ عنہما سے اللہ تعالیٰ کے فرمان :  ﴿ولا تجهر بصلاتك ولا تخافت ب"}
{"hadithnumber": "1002", "text": "یحییٰ بن زکریا نے ہشام بن عروہ سے ،  انہوں نے اپنے والد سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے"}
{"hadithnumber": "1003", "text": "حماد بن زید ،  ابو اسامہ  ،  وکیع اور ابو معاویہ نے اپنی اپنی سند کے ساتھ ہشام سے اسی سابقہ  سند کے"}
{"hadithnumber": "1004", "text": "جریر بن عبد الحمید نے موسیٰ بن ابی عائشہ سے ،  انہوں نے سعید بن جبیر سے اور انہوں نے حضرت ابن عباس ر"}
{"hadithnumber": "1005", "text": "۔   ( جریر بن عبد الحمید کے بجائے )  ابو عوانہ نے موسیٰ بن ابی عائشہ سے ،  انہوں نے سعید بن جبیر سے"}
{"hadithnumber": "1006", "text": "سعید نے جبیر نے حضرت ابن عباس رضی اللہ عنہما  سے  روایت کی ،  انہوں نے کہا کہ رسول اللہ ﷺ نے جنوں کو"}
{"hadithnumber": "1007", "text": "۔  عبد الاعلیٰ نے داؤد سے اور انہوں نے عامر  ( بن شراحیل )  سے روایت کی ،  کہا :  میں نے علقمہ سے پو"}
{"hadithnumber": "1008", "text": "۔  اسماعیل بن ابراہیم نے داؤد سے اسی سند کے ساتھ  وآثار نيرانهم  ( ان کی آگ کے نشانات )  تک بیان کیا"}
{"hadithnumber": "1009", "text": "عبد اللہ بن ادریس نے داؤد سے باقی ماندہ سابقہ سند کے ساتھ نبی ﷺسے  وآثار نيرانهم تک روایت کیا اور بع"}
{"hadithnumber": "1010", "text": "شعبی کے بجائے )  ابراہیم  ( نخعی )  نے علقمہ سے اور انہوں نے عبد اللہ سے روایت کی ،  کہا :  میں لیلۃ"}
{"hadithnumber": "1011", "text": "معن  ( بن عبد الرحمن بن عبد اللہ بن مسعود ہذلی )  سے روایت ہے ،  کہا :  میں نے اپنے والد سے سنا ،  ک"}
{"hadithnumber": "1012", "text": "حجاج صواف نے یحییٰ بن ابی کثیر سے ،  انہوں نے عبد اللہ بن ابی قتادہ  اور ابو سلمہ سے اور انہوں نے حض"}
{"hadithnumber": "1013", "text": "حجاج کے بجائے )  ہمام اور ابان بن یزید نے یحییٰ بن ابی کثیر سے ،  انہوں نے عبد اللہ بن ابی قتادہ سے"}
{"hadithnumber": "1014", "text": "یحییٰ بن یحییٰ اور ابو بکر بن ابی شیبہ نے ہشیم سے ،   انہوں نے منصور سے ،  انہوں نے ولید بن مسلم سے"}
{"hadithnumber": "1015", "text": "۔  ابو عوانہ نے منصور سے باقی ماندہ سابقہ سند سے حضرت ابو سعید خدری ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی"}
{"hadithnumber": "1016", "text": "ہشیم نے عبد الملک بن عمیر سے اور انہوں نے حضرت جابر بن سمرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ کوفہ"}
{"hadithnumber": "1017", "text": "ہشیم کے بجائے )  جریر نے عبد الملک بن عمیر سے اسی سند کے ساتھ یہی روایت بیان کی ۔"}
{"hadithnumber": "1018", "text": "شعبہ نے ابوعون سے روایت کی ،  انہوں نے  کہا کہ میں نے حضرت جابر بن سمرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا"}
{"hadithnumber": "1019", "text": "۔  مسعر نے عبد الملک  ( بن عمیر )  اور ابو عون سے روایت کی ،  انہوں نے حضرت جابر  بن سمرہ ‌رضی ‌اللہ"}
{"hadithnumber": "1020", "text": "۔  عطیہ بن قیس نے قزعہ سے ،  انہوں نے حضرت ابو سعید خدری ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی ،  انہوں ن"}
{"hadithnumber": "1021", "text": "ربیعہ نے کہا :  قزعہ نے مجھے حدیث سنائی  ،  کہا :  میں ابو سعید خدری ‌رضی ‌اللہ ‌عنہ ‌ ‌  کی خدمت می"}
{"hadithnumber": "1022", "text": "حجاج بن محمد نے ابن جریج سے روایت کی ،  نیز عبد الرزاق نے ہمیں حدیث بیان کی ،  کہا :  ابن جریج نے ہم"}
{"hadithnumber": "1023", "text": "حضرت عمرو بن حریث  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کہ انہوں  نے رسول اللہﷺ کو فجر کی نماز میں ﴿واليل إ"}
{"hadithnumber": "1024", "text": "ابو عوانہ نے زیاد بن علاقہ سے اور انہوں نے حضرت قطبہ نے مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی ،  انہ"}
{"hadithnumber": "1025", "text": "( ابو عوانہ کے بجائے )  شریک اور سفیان بن عیینہ نے زیاد بن علاقہ سے اور انہوں نے حضرت قطبہ بن مالک ‌"}
{"hadithnumber": "1026", "text": "( ابو عوانہ ،  شریک اور ابن عیینہ کے بجائے )  شعبہ نے زیادہ بن علاقہ سے اور انہوں  نے اپنے چچا  ( حض"}
{"hadithnumber": "1027", "text": "زائدہ نے کہا :  ہمیں سماک بن حرب نے حضرت جابر بن سمرہ رضی اللہ عنہما سے حدیث بیان کی کہ نبی اکرمﷺ فج"}
{"hadithnumber": "1028", "text": "( زائدہ کے بجائے )  زہیر نے سماک سے روایت کی ،  انہوں نے کہا :  میں نے جابر بن سمرہ ‌رضی ‌اللہ ‌عنہ"}
{"hadithnumber": "1029", "text": "عبد الرحمن بن مہدی نے کہا :  ہمیں شعبہ نے سماک سے حدیث سنائی ،  انہوں نے حضرت جابر بن سمرہ رضی اللہ"}
{"hadithnumber": "1030", "text": "ابو داؤد طیالسی نے شعبہ سے ،  انہوں نے سماک سے اور انہوں نے حضرت جابر بن سمرہ رضی اللہ عنہما سے روای"}
{"hadithnumber": "1031", "text": "سلیمان )  تیمی نے ابو منہال سے اور انہوں نے حضرت ابو برزہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول"}
{"hadithnumber": "1032", "text": "تیمی کے بجائے )  خالد حذاء نے ابو منہال سے ،  انہوں نے حضرت ابو برزہ اسلمی ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے ر"}
{"hadithnumber": "1033", "text": "۔  مالک نے ابن شہاب  ( زہری )  سے ،  انہوں نے عبید اللہ بن عبد اللہ سے اور انہوں نے حضرت ابن عباس ‌ر"}
{"hadithnumber": "1034", "text": "( امام مالک کے بجائے )  سفیان  ( بن عیینہ )  ،  یونس ،  معمر اور صالح نے زہری سے اسی سابقہ سند کے سا"}
{"hadithnumber": "1035", "text": "مالک نے ابن شہاب  ( زہری )  سے ،  انہوں نے محمد بن جبیر بن مطعم سے اور انہوں نے اپنے والد  ( جبیر بن"}
{"hadithnumber": "1036", "text": "سفیان ،  یونس اور معمر نے اپنی اپنی سند سے زہری سے اسی سابقہ سند کے ساتھ اس جیسی روایت بیان کی ۔"}
{"hadithnumber": "1037", "text": "۔  شعبہ نے عدی سے روایت کی ،  انہوں نے کہا :  میں نے حضرت براء  ‌رضی ‌اللہ ‌عنہ ‌ ‌  کو نبی اکرمﷺ سے"}
{"hadithnumber": "1038", "text": "( شعبہ کے بجائے )  یحییٰ بن سعید نے عدی بن  ثابت سے اور انہوں نے حضرت براء بن عازب ‌رضی ‌اللہ ‌عنہ ‌"}
{"hadithnumber": "1039", "text": "( شعبہ اور یحییٰ کے بجائے )  مسعر نے عدی بن ثابت سے روایت کی ،  انہوں نے کہا :  میں نے حضرت براء بن"}
{"hadithnumber": "1040", "text": "سفیان نے عمرو سے ،  انہوں نے حضرت جابر ‌رضی ‌اللہ ‌عنہ ‌ ‌   سے حدیث بیان کی ،  انہوں نے کہا :  حضرت"}
{"hadithnumber": "1041", "text": "ابو زبیر نے حضرت جابر ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ معاذ بن جبل انصاری ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے"}
{"hadithnumber": "1042", "text": "منصور نے عمرو بن دینار سے اور انہوں نے حضرت جابربن عبد اللہ رضی اللہ عنہما سے روایت کی کہ معاذ بن جب"}
{"hadithnumber": "1043", "text": "( منصور کے بجائے )  ایوب نے عمرو بن دینار سے اور انہوں نے حضرت جابر بن عبد اللہ رضی اللہ عنہما سے رو"}
{"hadithnumber": "1044", "text": "ہشیم نے اسماعیل بن ابی خالد سے ،  انہوں نے قیس سے اور انۂں نے حضرت ابو مسعود انصاری ‌رضی ‌اللہ ‌عنہ"}
{"hadithnumber": "1045", "text": "۔  ہشیم ،  وکیع ،  عبد اللہ بن نمیر اور سفیان نے اسماعیل  ( بن ابی خالد )  سے اسی سند کے ساتھ  ہشیم"}
{"hadithnumber": "1046", "text": "اعرج نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ نبی اکرمﷺ نے فرمایا :  ’’جب تم میں سے کوئ"}
{"hadithnumber": "1047", "text": "ہمام بن منبہ سے روایت ہے ،  انہوں نے کہا :  ہمیں یہ احادیث ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے محمد رس"}
{"hadithnumber": "1048", "text": "۔  ابو سلمہ بن عبد الرحمن نے خبر دی کہ انہوں نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے سنا ،  وہ کہت"}
{"hadithnumber": "1049", "text": "ابو سلمہ کے بجائے )  ابو بکر بن عبد الرحمن نے حدیث بیان کی  کہ انہوں نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌ع"}
{"hadithnumber": "1050", "text": "موسیٰ بن طلحہ نے کہا :  مجھے حضرت عثمان بن ابو عاص ثقفی ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے حدیث سنائی کہ نبیﷺ ن"}
{"hadithnumber": "1051", "text": "سعید بن مسیب نے کہا :  حضرت عثمان بن ابی عاص ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے حدیث بیان کی ،  انہوں نے کہا :"}
{"hadithnumber": "1052", "text": "عبد العزیز بن صہیب نے حضرت انس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ نبی اکرمﷺ نماز میں تخفیف کرتے اور"}
{"hadithnumber": "1053", "text": "قتادہ نے حضرت انس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہﷺ  ( سب سے زیادہ )  مکمل صورت میں سب"}
{"hadithnumber": "1054", "text": "شریک بن عبد اللہ ابی نمر نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ میں نے کبھی کسی ایس"}
{"hadithnumber": "1055", "text": "۔  ثابت بنانی نے حضرت انس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی ،  انہوں نے کہا :  رسول اللہﷺ ماں کے ساتھ"}
{"hadithnumber": "1056", "text": "قتادہ نے حضرت انس بن مالک ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی ،  انہوں نے کہا :  رسول اللہﷺ نے فرمایا :"}
{"hadithnumber": "1057", "text": "ہلال بن ابی حمید نے عبد الرحمن بن ابی لیلیٰ سے اور انہوں نے حضرت براء بن عازب ‌رضی ‌اللہ ‌عنہ ‌ ‌  س"}
{"hadithnumber": "1058", "text": "۔  عبید اللہ کے والجد معاذ عنبری نے کہا :  ہمیں شعبہ نے حکم سے حدیث سنائی ،  انہوں نے کہا کہ ابن اشع"}
{"hadithnumber": "1059", "text": "محمد بن جعفر نے کہا :  ہمیں شعبہ نے حکم سے حدیث بیان کی کہ جب مطر بن ناجیہ کوفہ پر قابض ہو  گیا تو ا"}
{"hadithnumber": "1060", "text": "۔  خلف بن ہشام نے حماد بن زید سے حدیث بیان کی ،  انہوں نے ثابت سے اور انہوں نے کہا :  ہمیں ثابت نے ح"}
{"hadithnumber": "1061", "text": "۔  بہز بن حماد سے حدیث بیان کی ،  انہوں نے کہا :  ہمیں ثابت نے حضرت انس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے خبر"}
{"hadithnumber": "1062", "text": "زہیر اور ابو خیثمہ نے اپنی اپنی سند کے ساتھ ابو اسحاق سے اور انہوں نے عبد اللہ بن یزید سے روایت کی ،"}
{"hadithnumber": "1063", "text": "سفیان نے ابو  اسحاق سے ،  انہوں نے عبد اللہ بن یزید سے اور انہوں نے حضرت براء  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "1064", "text": "محارب بن دثار نے کہا کہ میں نے عبد اللہ بن یزید کو منبر پر بیان کرتے ہوئے سنا ،  وہ کہہ رہے تھے :  ب"}
{"hadithnumber": "1065", "text": "۔  زہیر بن حرب اور ابن نمیر نے کہا :  ہم سے سفیان بن عیینہ نے حدیث بیان کی ،  کہا :  ہمیں ابان وغیرہ"}
{"hadithnumber": "1066", "text": "حضرت عمرو بن حریث  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  انہوں نے کہا :  میں نے نبی اکرمﷺ کے پیچھے فجر"}
{"hadithnumber": "1067", "text": "اعمش نے عبید بن حسن سے اور انہوں نے حضرت ابن ابی اوفیٰ   سے روایت کی ،  انہوں نے کہا :  رسول اللہﷺجب"}
{"hadithnumber": "1068", "text": "شعبہ نے عبیدبن حسن سے  انہوں نے عبد اللہ بن اوفیٰ سے روایت ےکی ہے انہوں نے کہا رسو ل اللہ ﷺ یہ دعا م"}
{"hadithnumber": "1069", "text": "محمد بن جعفر نے شعبہ سے ،  انہوں نے مجزاہ بن زاہر سے روایت کی ،  کہا :  میں نے حضرت عبد اللہ بن ابی"}
{"hadithnumber": "1070", "text": "عبید اللہ کے والد معاذ عنبری اور یزید بن ہارون دونوں نے شعبہ سے اسی سند کے ساتھ مذکورہ بالا روایت بی"}
{"hadithnumber": "1071", "text": "حضرت ابو سعید خدری ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  انہوں نے کہا کہ رسول اللہﷺ جب رکوع سے اپنا سر"}
{"hadithnumber": "1072", "text": "۔  ہشیم نے بشیر نے بیان کیا :  ہمیں ہشام بن حسان نے قیس بن سعد سے خبر دی ،  انہوں نے عطاء سے اور انہ"}
{"hadithnumber": "1073", "text": "حفص نے حدیث بیان کی ،  کہا :  ہمیں ہشام بن حسان نے باقی ماندہ سابقہ سند کے ساتھ حضرت ابن عباس ‌رضی ‌"}
{"hadithnumber": "1074", "text": "سعید بن منصور ،  ابو بکر بن ابی شیبہ اور زہیر بن حرب نے کہا :  ہمیں سفیان بن عیینہ نے حدیث بیان کی ک"}
{"hadithnumber": "1075", "text": "۔  اسماعیل بن جعفر نے سلیمان سے باقی ماندہ سابقہ سند سے حضرت عبد اللہ بن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  س"}
{"hadithnumber": "1076", "text": "۔  ابن شہاب زہری نے کہا :  مجھے ابراہیم بن عبد اللہ بن حنین نے حدیث سنائی کہ ان کے والد نے ان سے بیا"}
{"hadithnumber": "1077", "text": "ولید بن کثیر سے روایت ہے کہ مجھے ابراہیم بن عبد اللہ بن حنین نے اپنے والد سے بیان کیا ،  انہوں نے حض"}
{"hadithnumber": "1078", "text": "زید بن اسلم نے ابراہیم بن عبد اللہ بن حنین سے ،  انہوں نے اپنے والد سے اور انہوں نے حضرت علی بن ابی"}
{"hadithnumber": "1079", "text": "داؤد بن قیس نے کہا :  مجھے ابراہیم بن عبد اللہ بن حنین نے اپنے والد ،  انہوں نے حضرت ابن عباس ‌رضی ‌"}
{"hadithnumber": "1080", "text": "نافع ،  یزید بن ابی حبیب ،  ضحاک بن عثمان ،  ابن عجلان ،  اسامہ بن زید ،  محمد بن عمرو اور محمد بن ا"}
{"hadithnumber": "1081", "text": "۔  عبد اللہ بن  حنین کے ایک اور شاگرد محمد بن مکندر نے یہی حدیث حضرت علی ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روا"}
{"hadithnumber": "1082", "text": "عبد اللہ بن حنین نے حضرت ابن عباس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ انہوں نے کہا :  مجھے رکوع کی ح"}
{"hadithnumber": "1083", "text": "۔  ذکوان  نے حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہﷺ نے فرمایا :  ’’بندہ اپنے"}
{"hadithnumber": "1084", "text": "ابو صالح نے حضرت ابوہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی کہ رسول اللہﷺ سجدے میں کہا کرتے تھے :  ’’"}
{"hadithnumber": "1085", "text": "منصور نے ابو ضحیٰ  ( مسلم بن صبیح القرشی )  سے ،  انہوں نے مسروق سے اور انہوں نے حضرت عائشہ رضی اللہ"}
{"hadithnumber": "1086", "text": "ابو معاویہ نے اعمش سے ،  انہوں نے مسلم  ( بن صبیح سے ،  انہوں نے مسروق سے اور انہوں نے حضرت عائشہ رض"}
{"hadithnumber": "1087", "text": "مفضل نے اعمش سے باقی ماندہ سابقہ سند کےساتھ حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہا :"}
{"hadithnumber": "1088", "text": "عامر  ( شعبی )  نے مسروق سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہا :  رسو"}
{"hadithnumber": "1089", "text": "۔  ابن جریج نے کہا :  میں نے عطاء سے پوچھا :  آپ رکوع میں کہتے ہیں؟ انہوں نے کہا :  جہاں تک  ( دعا )"}
{"hadithnumber": "1090", "text": "حضرت ابو ہریرہ ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے حضرت عائشہ رضی اللہ عنہا سے روایت کی ،  انہوں نے کہا :  میں ن"}
{"hadithnumber": "1091", "text": "سعید بن ابی عروبہ نے قتادہ سے اور انہوں  نے مطرف بن عبد اللہ بن شخیر سے روایت کی کہ حضرت عائشہ رضی ا"}
{"hadithnumber": "1092", "text": "ہمیں ابوداؤد  ( طیالسی )  نے شعبہ سے حدیث سنائی کہ قتادہ نے کہا :  میں نے مطرف بن عبد اللہ بن شخیر س"}
{"hadithnumber": "1093", "text": "۔  معدان بن ابی طلحہ یعمری نے کہا :  میں رسول اللہﷺ کے آزاد کردہ غلام ثوبان ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے"}
{"hadithnumber": "1094", "text": "حضرت ربیعہ بن کعب  ( بن مالک )  اسلمی ‌رضی ‌اللہ ‌عنہ ‌ ‌  نے کہا :  میں  ( خدمت کے لیے )  رسول اللہ"}
{"hadithnumber": "1095", "text": "یحییٰ اور ابو ربیع نے حدیث بیان کی ،  یحییٰ نے کہا :  حماد بن زید نے ’’ہمیں خبر دی ‘  ‘  اور ابو ربی"}
{"hadithnumber": "1096", "text": "شعبہ نے عمرو بن دینار سے ،  انہوں نے طاؤس اور انہوں نے حضرت ابن عباس رضی اللہ عنہما سے روایت کی ،  ا"}
{"hadithnumber": "1097", "text": "سفیان بن عیینہ نے  ( عبد اللہ )  بن طاؤس سے اور انہوں نے اپنے والد کے حوالے سے حضرت ابن عباس رضی الل"}
{"hadithnumber": "1098", "text": "وہیب نے عبد اللہ بن طاؤس سے حدیث بیان کی ،  انہوں نے  ( اپنے والد )  طاؤس سے انہوں نے عبداللہ ‌بن ‌ع"}
{"hadithnumber": "1099", "text": "ابن جریح نے عبد اللہ بن طاؤس سے ،  انہوں نے اپنے والد سے اور انہوں نے حضرت عبد اللہ بن عباس رضی اللہ"}
{"hadithnumber": "1100", "text": "۔  حضرت عباس بن عبد المطلب  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے کہ انہوں نے رسول اللہﷺ کو فرماتے ہوئے س"}
{"hadithnumber": "1101", "text": "حضرت عبد اللہ بن عباس رضی اللہ عنہما نے عبد اللہ بن حارث  ( بن نوفل ‌رضی ‌اللہ ‌عنہ ‌ ‌  بن عبد المط"}
{"hadithnumber": "1102", "text": "وکیع نے شعبہ سے ،  انہوں نے قتادہ سے اور انہوں نے حضرت انس ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت کی ،  انہوں"}
{"hadithnumber": "1103", "text": "محمد بن جعفر  اور خالد بن حارث نے کہا :  ہمیں شعبہ نے اسی سند کے ساتھ روایت کی ہے ۔  ابن جعفر کی روا"}
{"hadithnumber": "1104", "text": "حضرت براء  ‌رضی ‌اللہ ‌عنہ ‌ ‌  سے روایت ہے ،  انہوں نے کہا کہ رسول اللہﷺ نے فرمایا :   ’’ جب تم سجد"}
{"hadithnumber": "1105", "text": "بکر بن مضر نے جعفر بن ربیعہ سے ،  انہوں نے اعرج سے اور انہوں نے حضرت عبد اللہ بن ملک سے ،  جو ابن بح"}
{"hadithnumber": "1106", "text": "عمرو بن حارث اور لیث بن سعد دونوں نے جعفر بن ربیعہ سے اسی سند کے ساتھ  ( مذکورہ حدیث )  بیان کی ۔ \\n\\n"}
{"hadithnumber": "1107", "text": "سفیان بن عیینہ نے عبید اللہ بن عبد اللہ بن اصم سے ،  انہوں نے  اپنے چچا یزید بن اصم سے ،  انہوں نے ح"}
{"hadithnumber": "1108", "text": "مروان بن معاویہ فزاری  نے ہمیں  خبر دی  ،  کہا :  عبید اللہ بن عبد اللہ بن اصم نے  یزید بن اصم سے حد"}
{"hadithnumber": "1109", "text": "وکیع نے کہا :  ہمیں جعفر بن برقان نے یزید بن اصم سے حدیث سنائی ،  انہوں نے حضرت میمونہ بنت حارث رضی"}
{"hadithnumber": "1110", "text": "محمد بن عبد اللہ بن نمیر نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ابو خالد احمر نے  حسین معلم سے حدیث سنا"}
{"hadithnumber": "1111", "text": "ابو احوص نے سماک  ( بن حرب )  سے ،  انہوں نے موسیٰ بن طلحہ سے اور انہوں نے اپنے والد حضرت طلحہ  ‌رضی"}
{"hadithnumber": "1112", "text": "محمد بن عبد اللہ بن نمیر اور اسحاق بن ابراہیم نے حدیث بیان کی ،  اسحاق نے کہا :  ’’عمر بن عبید طنافس"}
{"hadithnumber": "1113", "text": "۔  سعید بن ابی ایوب نے ابو اسود سے ،  انہوں نے عروہ سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا سے روای"}
{"hadithnumber": "1114", "text": "حیوہ نے ابو اسود محمد بن عبد الرحمن سے ،  انہوں نے عروہ سے اور انہوں نے حضرت عائشہ رضی اللہ عنہا  سے"}
{"hadithnumber": "1115", "text": "عبد اللہ بن نمیر نے عبید اللہ سے ،  انہوں نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہما سے روا"}
{"hadithnumber": "1116", "text": "ابو بکر بن ابی شیبہ نے اور ابن نمیر نے کہا :  ہمیں محمد بن بشر نے حدیث سنائی ،  کہا :  ہمیں عبید الل"}
{"hadithnumber": "1117", "text": "معتمر بن سلیمان نے عبید اللہ سے ،  انہوں نے نافع سے اور انہوں نے حضرت ابن عمر  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "1118", "text": "ابو بکر بن ابی شیبہ  اور ابن نمیر نے کہا :  ہمیں ابو خالد احمر نے عبید اللہ سے ،  انہوں نے نافع سے ا"}
{"hadithnumber": "1119", "text": "۔   سفیان نے بیان کیا :  ہمیں عون بن ابی جحیفہ نے اپنے والد  ( حضرت ابو جحیفہ  ‌رضی ‌اللہ ‌عنہ ‌ ‌"}
{"hadithnumber": "1120", "text": "۔  عمر بن ابی زائدہ سے روایت ہے کہ مجھے عون بن ابی جحیفہ نے حدیث بیان کی کہ ان کے والد نے رسول اللہﷺ"}
{"hadithnumber": "1121", "text": "ابو عمیس نے اور مالک بن مغول دونوں نے اپنی اپنی سند سے عون بن ابی جحفہ سے ،  انہوں نے اپنے والد سے ا"}
{"hadithnumber": "1122", "text": "۔  محمد بن جعفر نے کہا :  ہمیں شعبہ نے حکم سے حدیث سنائی ،  انہوں نے کہا :  میں نے حضرت ابو جحیفہ  ‌"}
{"hadithnumber": "1123", "text": "۔   ( عبد الرحمان  )  بن مہدی نے ہمیں حدیث بیان کی ،   ( کہا :   )  شعبہ نے ہمیں  ( حکم اور عون کی )"}
{"hadithnumber": "1124", "text": "مالک نے ابن شاب سے ،  انہوں نے عبید اللہ بن عبد اللہ سے اور انہوں نے حضرت ابن عباس رضی اللہ عنہما  س"}
{"hadithnumber": "1125", "text": "۔  یونس نے ابن شہاب سے روایت کی ،  کہا :  مجھے عبید اللہ بن عبد اللہ بن عتبہ نے خبر دی کہ انہیں حضرت"}
{"hadithnumber": "1126", "text": "سفیان بن عیینہ نے زہری سے اسی سند کے ساتھ مذکورہ روایت بیان کی ،  کہا :  نبی اکرمﷺ عرفہ میں نماز پڑھ"}
