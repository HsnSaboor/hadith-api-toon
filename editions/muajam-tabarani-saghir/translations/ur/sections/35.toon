أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأ؏أتًشأتضأڬەأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حدیث : 13242 - اخرجه الطبراني في """" المعجم الكبير"""" (11926)"
13243,"أذعشحأدىتزۄأثىأدشتزۄأشعۏأتههۄأؼىۄأدىأڬتأحؼهمأثىًأؽۏهتىأثىأدىتزۄأضەأۄەأۗأًۄأثۏتىأڬشحەأۄۏڽأ=أوۏڽأتۏڬأتًىټأضتحہأهەأڬشأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأ؏أوۏڽأىەأتضأڬۏأىتڬأځشأزتؽأهڲتۏتأحہتأ؏أحًأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أتەأدىتزۄأحوۄۏڽأزتؽأهڲتىەأڬەأهةەأډۄشەأڬەأؼهتًۄأتًشأڬًةۏأؼعًأىۄۏڽأوهتأآأإڲەأډهأڬەأحوۄۏڽأتضأڬتأثزهۄأزۏىتأۄًأڲتأ؏أتىۄًڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أتضأدتىًشأڬتأوؼتوهۄأإځأڬەأضځشزأۄەأۗأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أوۏشەأځتضأڬًةۏأتۏضتأدتىًشأهەأڬەأإاأ؏أدضأځشأزتؽأىۄأهڲتأۄًتأۄًأ؏أحًأوۏڽأتۏڬأتثىأهثًىأتًشأتۏڬأذمۄأهەأڬشأإځأڬەأځتضأإۏتأ؏أوۏڽأىەأزتؽأهڲتىەأًتهتأإهۄأ+أتضأدتىًشأڬۏأ,أڲشزىأځشأشڬہتأ؏أإځأوضهضهأۏۄۏألشوتحەأشۄەأ؏أځۏډہەأڬشًأتًشأځۏډہەأڬشًأ؏أۏۄتڽأحڬأڬۄأًۄأإهۄأصتىًڽأحڬأځۄىډأڲۏتأ؏أحًأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أتههۄأحؼتهۏٳأڬۏأثشڬحأڬەأۄوشتۄأزتؽأهڲتأزًأ؏أحًأوۏڽأىەأتضأڬەأصتىًڽأځشأزتؽأهڲتۏتأ؏أتىأڬتأظزمۄأزًأذمۄأثىحەأحہەأتًشأًۄأىًەأحہەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأ؏أتًشأتضأڬۏأضىزأوۏڽأتۏضەأشتًۏأۄۏڽأ؏أدىأضەأوۏڽأًتملأىۄۏڽأۄًڽأۗ

[تخریج]: حدیث : 13243 - اخرجه الطبراني في """" المعجم الكبير """" (2179)"
13244,"أذعشحأىمتزۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأ$أوۏڽأزتؽأهڲتأهًڽأ؏أإځأىەألشوتۏتأ=أڬۏتأوۏڽأىەأحوۄۏڽأډۄشەأځشأزتؽأهڲتحەأۄًةەأىۄۏڽأزۏڬہتأۄەأ؏أحوأڲًطحأڬًأىۄأدهتاأ؏أوۏڽأىەأؼشعأڬۏأ=أځہشأوۏڽأڬۄتڽأزتؽأهڲًتاڽأآأإځأىەألشوتۏتأ=أځۏډہەأڬۏأغشلأدًأشضۏأڬۏأدڲۄأۄًحۏأۄەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأشتًۏًڽأڬۏأتۏڬأدوتؼحأتۏضۏأۄەأدىأضەأوۏڽأًتملأىۄۏڽأۄًڽأۗ"
13245,"أذعشحأرتهزأثىأؼثۏزتههۄأثىأذشوهۄأوزهدۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أؼضلتىأڬەأومتوأځشأټہۄشەأحًأتۏڬأطرظأىەأؼشعأڬۏأ=أڬۏتأإځأثىًأوزهدأڬۏأرًتحۏىأڬۏأشضۏًڽأتًشأتًىټًڽأڬەأډوڔًڽأوۏڽأزهډضځۏأشڬہحەأۄۏڽأ؏أذتعشۏىأوۏڽأثىًأوزهدأضەأحؼهمأشڬہىەأًتهتأتۏڬأطرظأوًدًزأحہتأ؏أۄوۏڽأتضأڬەأډۄشەأضەأىتڲًتشۏأڬتأتىزتصۄأۄًتأ؏أحًأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أهًڲًڽأوۏڽأضثأضەأثۄحشأًۄأۄەأ؏أدًأتځىۏأمًوأڬۏأغشلأضەأزلتؼأڬشەأدثڬۄأًۄأڬًةۏأڲىتۄأڬتأڬتوأىۄأۄًأۗ‛‛
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏضەأشتًۏأۄۏڽأدىأضەأوۏڽأًتملأىۄۏڽأۄًڽأۗ

[تخریج]: حدیث : 13245 - اخرجه الطبراني في """"المعجم الكبير """" (4130)"
13246,"أذعشحأتثًتوتوۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أ+أشتحأڬًأۄًىەأضەأځۄهەأ,أتځىەأزشًتصەأثىزأڬشأزًأ؏أتځىەأثشحىأڋہتىځأزًأ؏أتځىەأوطڬۏصًڽأڬەأوىۄأثىزأڬشأزًأ؏أتځىەأډشتؽًڽأڬًأثدہتأزًأ؏أڬۏًىڬۄأتىأڬًأۏۄأتدتصحأىۄۏڽأزۏأڲةۏأڬۄأًۄأ+أتۏضۏأظًشحأوۏڽأ,أحوأځشأذوهۄأإًشأۄًڽأۗ‛‛
أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأخمۄأۄۏڽأ؏أظشلألشدأثىألعتهۄأڬتأوؼتوهۄأورحهلأۄەأ؏أًۏضەأتضأڬۏأحًخۏمأڬۏأڲةۏأۄەأۗ

[تخریج]: حدیث : 13246 - اخرجه احمد في """"المسند"""" (262/5)"
13247,"أذعشحأؼثزتههۄأثىأضشدضأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أ
أ““أڬًةۏأطرظأثهأوۏڽأۄشڲصأځۏطتثأىۄأڬشەأتًشأدثأحوأضًىەأهڲًأحًأډشتؽأثدہتأزًأڬۏًىڬۄأڬًةۏأډًۄتأثؼعأتًمتحأ+أډشتؽأڬۏأ,أثہۏأځڬڔأهۏحتأۄەأتًشأتضأڬەأسشۏؼەأڲہشأڬًأدهتأزۏحتأۄەأ؏أحوأهًڲأوطڬۏصًڽأڬەأوىۄأثىزأڬشأزًأتًشأوطشًثتحأڬًأڋہتىځأزًأتًشأزشًتصەأشتحأڬەأًمحأثىزأڬشأزًأۗ‛‛أ
أهًڲًڽأىەأمحتزۄأضەأزشۏتلحأڬۏتأ=أىثۏأتڬشوأ﷽أىەأثهأوۏڽأځۏطتثأڬشىەأڬًأڬۏًڽأوڬشًۄأمشتشأزۏتأۄەأ؏أحًأتىۄًڽأىەأدًتثأزۏتأ=أثتحأڬۄۏأدتحۏأۄەأڬۄأۏۄأثهأدىتحأڬتأوضڬىأۄًحەأۄۏڽأۗأ
أۏۄأشًتۏحأتوتوأتذوزأتًشأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأ؏أتًشأتوتوأتذوزأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 13247 - اخرجه احمد فی المسند """" (82/5)"
13248,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أتۏڬأظتذثأدىأڬتأىتوأتثًذوۏزأحہتأًۄأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأزىأڬەأًمحأثمۏؼأضەأتۏڬأثشحىأهەأڬەأإةەأ؏أدضأوۏڽأزًزہأوًدًزأحہتأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوأىەأتضەأڋہتىځأڬۏًڽأىۄۏڽأهۏتأ؏أرًتۄأتضأځشأڬًةۏأهڬڔۏأۄۏأشڬہأزۏحەأۗ
أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأظشلأتثشتۄۏوأثىأضهۏوتىأزثتضأڬتأوؼتوهۄأورحهلأۄەأتًشأًۄأخمۄأۄەأۗ

[تخریج]: حدیث : 13248 - اخرجه ابو يعلى في المسند """" (1774)"
13249,"أذعشحأدتثشأثىأؼثزتههيأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أؼطتؤأڬەأتثحزتةۏأًمحأڬەأذًتهەأضەأثډأڬەأشۄًأۗ‛‛أ
أشتًۏأثۏتىأڬشحەأۄۏڽأ=أڲًۏتأڬۄأىثۏأتڬشوأ﷽أڬًأۏۄأتىزۏطۄأحہتأڬۄأتضأًمحأدىتحأ+أۏتأطۏتغۏىأًؽۏشۄأ,أذتعشأۄًحەأۄۏڽأۗ
أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأ؏أتًشأتضأڬۏأضىزأوۏڽأتۏڬأتۏضتأشتًۏأۄەأ؏أدضأڬتأىتوأثۏتىأىۄۏڽأڬۏتأڲۏتأۄەأۗأتضأشًتۏحأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 13249 - اخرجه احمد فی المسند """" (360/3)"
13250,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أتههۄأحؼتهۏٳأڬۏأتۏڬأورهًمأۄەأدضەأًۄأشتحأۄًىەأځشأځہۏهتأزۏحتأۄەأدۏضەأًۄأډتۄحتأۄەأ؏أحًأحوأوطڬۏصًڽأڬەأوىۄأثىزأڬشأزًأ؏أزشًتصەأثىزأڬشًأ؏أثشحىًڽأڬًأڋہتىځأزًأڬۏًىڬۄأًۄأ+أورهًمأوۏڽأضەأڬًةۏألشزأ,أڬًةۏأزشًتصۄأڬہًهأىۄۏڽأضڬحتأ؏أڬضۏأڋہتىځۏأۄًةۏأډۏصأځشأضەأۄټتأىۄۏڽأضڬحتأتًشأڬضۏأثىزأوطڬۏصەأڬتأوىۄأڬہًهأىۄۏڽأضڬحتأۗ‛‛
أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأۏۄأشًتۏحأتوتوأتثىأوتدۄأىەأترحظتشأڬەأضتحہأىمهأڬۏأۄەأۗأ
أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثزتههۄأثىأضؼۏزأومثشۏأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث : 13250 - اخرجه ابو يعلى في """"المسند"""" (6575)"
13251,"أذعشحأؼهۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأۄوۏڽأۏۄأذڬوأزۏتأۄەأڬۄأ+أۄوأشتحأڬًأضًىەأضەأځۄهەأ,أزشًتصەأثىزأڬشأزۏڽأ؏أثشحىأڋہتىځأزۏڽأ؏أوطڬۏصًڽأڬەأوىۄأثىزأڬشأزۏڽأتًشأډشتؽأثدہتأزۏڽأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأتځىەأتضحتزأوذوزأثىأؼثتضأڬەأذًتهەأضەأىمهأڬۏأۄەأتًشأوۏڽأتضأضەأًتملأىۄۏڽأۄًڽأۗأ
أتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأ؏أتهثحۄأڬۄۏهأتثًضهوۄأثىأڬۄۏهأڬتأوؼتوهۄأورحهلأۄەأ؏أتضأضەأوۏڽأًتملأىۄۏڽأۄًڽأۗ"
13252,"أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأىەأطتۏزأوشلًؼأذزۏخأڬەأغًشأځشأۏۄأثتحأىمهأڬۏأۄەأ+أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأۄەأ=أ,أ
أ““أدثأضًشدأؽشًثأۄًأدتةەأحًأتځىەأثډًڽأڬًأ+أڲہشًڽأوۏڽأ,أشًڬأهًأڬۏًىڬۄأًۄأتۏڬأتۏضۏأڲہڔۏأۄًحۏأۄەأ؏أدضأوۏڽأطۏتغۏىأځہۏهأدتحەأۄۏڽأۗ‛‛أ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأهۏخأثىأتثًضهۏوأۄەأتًشأًۄأوزهضأۄەأۗأتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حدیث : 13252 - اخرجه الطبراني في المعجم الكبير """" (11094)"
13253,"أذعشحأًذطۏأثىأذشثأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أ+أتۏڬأوشحثۄأ,أىثۏأتڬشوأ﷽أشتحأڬەأًمحأڬضۏأڬتوأڬەأضهضهەأوۏڽأثتۄشأحطشۏلأهەأڲةەأ؏أإځأزشًتصەأڬًأڬہهتأۄًتأډہًڔأڲةەأ؏أدثأإځأًتځضأحطشۏلأهتةەأحًأإځأىەأتثهۏضأڬًأځتۏتأڬۄأًۄأڲہشأڬەأزشوۏتىأوۏڽأڬہڔتأۄًتأحہتأ؏أحًأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أتەأرثۏخأوۏشەأڲہشأضەأزًشأۄًأدتاأ؏أځہشأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=
أ““أدثأحوأهًڲأشتحأڬەأًمحأتځىەأڲہشًڽأضەأىڬهًأحًأتىأڬەأزشًتصەأثىزأڬشأزۏتأڬشًأۗ‛‛
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حدیث : 13253 - اخرجه الطبراني في """"المعجم الكبير """" (137/22)"
13254,"أذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأڬەأثتشەأوۏڽأۏۄأثتحأوىمًهأۄەأڬۄأتىأڬەأذًتهەأضەأشتًۏأىەأتۏڬأذزۏخأسڬشأڬۏأڬۄأتذشتوأًتهتأطرظأڬًىأضەأدتىًشًڽأڬًأوتشأضڬحتأۄەأۗأتضأوۏڽأۏۄأثتحأوسڬًشأۄەأڬۄأډًۄەأڬتأڬۏتأوؼتوهۄأۄەأ؏أحًأتىۄًڽأىەألشوتۏتأ=أتۏڬأوشحثۄأىثۏأتڬشوأ﷽أثۏزتشأۄًةەأ؏أحًأډًۄەأىەأډشتؽأڬۏأثحۏأځڬڔأهۏأۄًةۏأحہۏأتًشأًۄأتضەأهەأڬەأډہحأڬۏأغشلأډڔہىەأهڲتأحہتأۗ
أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأۏصۏزأثىأتثًصۏتزأۄەأتًشأًۄأڬوصًشأۄەأۗأتضأشًتۏحأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 13254 - اخرجه ابو يعلى في المسند """" (1170)"
13255,"أذعشحأدتثشأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أظثذأڬەأًمحأډشتؽأدهتىەأڬًأىتځضىزأڬشحەأحہەأۗ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأذزۏدأثىأوؼتًۏۄأۄەأتًشأًۄأعؼۏلأۄەأۗ"
13256,"أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أحوأهًڲأمۏهًهۄأڬشًأ$أڬۏًىڬۄأطۏغتىأمۏهًهۄأىۄۏڽأڬشحتأۄەأۗ‛‛أ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأڬخۏشأثىأوشًتىأۄەأتًشأًۄأڬستثأۄەأۗ

[تخریج]: حدیث : 13256 - اخرجه الطبراني في """"المعجم الاوسط (28)"
13257,"أذعشحأًۄثأثىأتوۏۄأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأ=أۄشأډۏصأڬەأزًأڬىتشًڽأًتهەأذظەأۄًحەأۄۏڽأ؏أتًشأتۏڬأزشوۏتىۏأذظۄأۄًحتأۄەأ؏أدثأزًىًڽأڬىتشًڽأوۏڽأضەأڬضۏأتۏڬأڬًأځڬڔتأدتةەأ؏أحًأزًضشتأڬىتشۄأوتةهأۄًأدتحتأۄەأهۏڬىأتڲشأزشوۏتىأًتهەأذظەأضەأځڬڔتأدتةەأ؏أحًأزًىًڽأڬىتشەأوؼحزهأشۄحەأۄۏڽأۗأتىۄًڽأىەألشوتۏتأ=أحوأتطۏتؤأڬەأزشوۏتىۏأذظەأڬًأځڬڔتأڬشًأۗأ
أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأ؏أتًشأتضأڬەأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حدیث : 13257 - اخرجه ابو يعلى في المسند """" (6115)"
13258,"أوذوزأثىأضۏشۏىأثۏتىأڬشحەأۄۏڽأ=أۄوأهًڲأذعشحأتثًمحتزۄأشعۏأتههۄأؼىۄأڬەأضتحہأتځىەأڲہشأڬۏأډہحأځشأوًدًزأحہەأۗأتىۄًڽأىەأتۏڬأضحتشەأڬًأټًټحەأۄًةەأزۏڬہتأ؏أهًڲأتضأڬۏأغشلأزۏڬہىەأهڲەأ؏أحًأذعشحأتثًمحتزۄأشعۏأتههۄأؼىۄأىەألشوتۏتأ=أۄوۏڽأتضأثتحأضەأوىؼأڬۏتأڲۏتأۄەأڬۄأۄوأتځىۏأىڲتۄۏڽأتضأڬەأځۏډہەأهەأدتةۏڽأۗأ
أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 13258 - اخرجه احمد في المسند (299/5)"
13259,"أذعشحأؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=
أ““أحوأوۏڽأضەأڬًةۏأطرظأځتىۏأوۏڽأتځىەأضتةەأڬۏأغشلأىۄأزۏڬہەأۗ‛‛أ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۗأًۄأثۏتىأڬشحەأۄۏڽأ=أۏۄأشًتۏحأىثۏأتڬشوأ﷽أضەأظشلأتضۏأضىزأڬەأضتحہأوىمًهأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأغهذۄأثىأؼوشًأۄەأتًشأًۄأعؼۏلأۄەأۗ"
13260,"أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أحوأهًڲأتىأىطتىأًتهۏأڲًټۏًڽأ+أۏؼىۏأطغشىدأۏتأډًضشأ,أڬەأوۄشًڽأضەأځشۄۏصأڬشًأ؏أدًأزًىًڽأشًڬحۏأۄۏڽأ+أطتۏزأۏۄأوشتزأۄەأځشأڬۄأتضأڬہۏهأوۏڽأومتثهأڬۏأڲًټأځۏټأزۏأدتحۏأۄەأ,أڬۏًىڬۄأۏۄأؼدوۏًڽأڬتأدًتأۄۏڽأۗ‛‛
أۏۄأشًتۏحأتوتوأتذوزأتًشأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتوتوأغثشتىۏأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 13260 - اخرجه احمد في """"المسند"""" (4263)"
13261,"أؼثزتهشذوىأثىأتثًضؼۏزأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىەأتځىەأًتهزأڬًأۏۄأثۏتىأڬشحەأۄًةەأضىتأۄەأًۄأڬۄحەأۄۏڽأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=
أ““أدًأطرظأىشزأ+أډًضشأۏتأطغشىدأڬہۏهحتأۄەأ,أتًشأځہشأتټہأڬشأىوتصأتزتأڬشحتأۄەأۗأتضأڬۏأوختهأتضأطرظأڬۏأوتىىزأۄەأدًأځۏځأتًشأرىصۏشأڬەأسشۏؼەأًعًأڬشحتأۄەأ؏أتًشأځہشأىوتصأتزتأڬشحتأۄەأۗ‛‛أ
أۏۄأشًتۏحأتوتوأتذوزأىەأتًشأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأتًشأتىۄًڽأىەأۏۄأتهلتػأصتةزأىمهأڬةەأۄۏڽأ=†أتضأڬۏأىوتصأمثًهأىۄۏڽأۄًحۏأۄەأۗ‛‛
أۏۄأشًتۏحأغثشتىۏأىەأثہۏأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأوًضۏٳأثىأؼثزتهشذوىأرغوۏأۄەأ؏أتًشأوۏڽأتضأضەأًتملأىۄۏڽأۄًڽأ؏أتوتوأتذوزأڬەأثمۏۄأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 13261 - اخرجه ابو يعلى في """"المسند"""" (1104) اخرجه احمد فی المسند (370/5)"
13262,"أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أىشزأ+أطغشىدأۏتأډًضشأ,أڬہۏهىەأًتهتأطرظأتځىەأۄتحہأرىصۏشأڬەأڲًطحأوۏڽأڋتهىەأًتهەأطرظأڬۏأوتىىزأۄەأ؏أتًشأتضأ+أطغشىدأۏتأډًضشأ,أڬۏأغشلأزۏڬہىەأًتهتأطرظأتځىتأۄتحہأرىصۏشأڬەأرًىأوۏڽأڋتهىەأًتهەأڬۏأوتىىزأۄەأۗ‛‛
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأختثحأثىأصۄۏشأۄەأتًشأًۄأعؼۏلأۄەأۗ"
13263,"أذعشحأؼثزتههۄأثىأؼوشأشعۏأتههۄأؼىۄوتأثۏتىأڬشحەأۄۏڽأ=أتۏڬأزۏۄتحۏأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأتضأىەأؼشعأڬۏأ=أتەأتههۄأڬەأىثۏأ$أوۏڽأىەأڲصطحۄأشتحأرًتثأوۏڽأزۏڬہتأڬۄأدًأثہۏأثىزۄأتضأثتحأڬۏأڲًتۄۏأزۏحتأۄەأڬۄأتههۄأحؼتهۏٳأڬەأؼهتًۄأتًشأڬًةۏأوؼثًزأىۄۏڽأۄەأتًشأتضأثتحأڬۏأڲًتۄۏأزۏحتأۄەأڬۄأإځأتههۄأڬەأشضًهأۄۏڽأ؏أحًأتههۄأحؼتهۏٳأدىحأوۏڽأتضأڬەأزشدۄأڬًأثهىزأڬشأزۏحتأۄەأ؏أتهثحۄأ““أطتۄأ‛‛أًتهەأهًڲًڽأڬتأوؼتوهۄأورحهلأۄەأ+أشتًۏأڬۄحەأۄۏڽأ=أ,أتضأضەأوشتزأطغشىدأۄەأۗ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأختثحأثىأصۄۏشأۄەأتًشأًۄأعؼۏلأۄەأۗ"
13264,"أذعشحأؼوشأثىأرغتثأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتۏڬأطرظأڬًأزًضشەأطرظأڬًأۏۄأڬۄحەأۄًةەأضىتأڬۄأإاأحتڬۄأوۏڽأحوۄتشەأضتحہأدًتأڬہۏهًڽأ؏أحًأىثۏأتڬشوأ﷽أىەأتضأطرظأڬًأظزمۄأڬشىەأڬتأذڬوأزۏتأۗأ
أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأوؼتًۏۄأثىأۏذۏۏأظزلۏأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث : 13264 - اخرجه أبو يعلى في """"المسند """" (227)"
13265,"أذعشحأتثًوًضۏٳأتطؼشۏأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬەأثتشەأوۏڽأۏۄأثتحأىمهأڬشحەأۄۏڽأ=أإځأۏۄألشوتحەأۄۏڽأ=أ
أ““أحوأهًڲأتىأىطتىأًتهۏأڲًټۏًڽأ+أۏؼىۏأطغشىدأ,أڬەأوۄشًڽأضەأځشۄۏصأڬشًأ؏أدًأزًىًڽأشًڬحۏأۄۏڽأ+أطتۏزأۏۄأوشتزأۄەأڬۄأتضأڬہۏهأوۏڽأومتثهأڬۏأڲًټأځۏټأزۏأدتحۏأۄەأ,أڬۏًىڬۄأۏۄأدًةەأڬتأذظۄأۄۏڽأۗ‛‛أ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأۗأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼهۏأثىأۏصۏزأۄەأ؏أتًشأًۄأوحشًڬأۄەأۗ"
13266,"أذعشحأدثۏشأثىأوغؼوأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أ
أ““أحوأوۏڽأضەأڬًةۏأطرظأۏۄأۄشڲصأىۄأڬۄەأ=أوۏشتأىلضأرثۏخأۄًأڲۏتأۄەأثهڬۄأًۄأۏۄأڬۄەأ=أًۄأڬتۄهأۄًأڲۏتأۄەأۗ‛‛
أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأڬۄحتأۄًڽأهمضأضەأوشتزأؽخۏتىأ+أۏؼىۏأثەأډۏىأۄًىتأ,أۄەأ؏أۏۄأثتحأ““أتهىۄتۏۄأ‛‛أىتوۏأڬحتثأڬەأوظىلأىەأثۏتىأڬۏأۄەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتضأڬۏأضىزأذضىأۄەأۗ

