[تخریج]: [ صحیح ]"
13229,أؼهۏأثىأتثًغتهثأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأڬضۏأتًهتزأۏتأًتهزأڬتألشعۏأظزمەأوۏڽأذمأىۄۏڽأۄەأتًشأدضأڬۏأتًهتزأۄًأۏتأًتهزأۄًأًۄأظهۄأشذوۏأىۄۏڽأڬشحتأحًأًۄأىتلشوتىأۄەأۗ
13230,"أضۏزىتأؼثزتههۄأثىأوضؼًزأڬۏأثۏًۏأىەأڬۄتأ=أتەأتههۄأڬەأشضًهأ﷽أ$أتڲشأۄوأظزمۄأتځىەألمۏشأرتًىزأڬًأزەأزۏڽأۏتأتځىەأثہحۏدەأڬًأدًأۄوتشۏأصۏشأځشًشطأۄەأحًأۄوأضەأتزتأۄًأدتةەأڲتأحًأىثۏأ﷽أىەألشوتۏتأ=أحۏشەأهۏەأظزمەأڬتأتًشأظهۄأشذوۏأڬتأزڲىتأتدشأۄًأڲتأۗ

[تخریج]: [ بخاری 446 ۔ مسلم 1000 ]"
13231,"أذعشحأذضىأثىأؼهۏأىەأظزمەأڬۏأڬہدًشأوۏڽأضەأتۏڬأڬہدًشأځڬڔۏأتًشأڬہتأهۏأىثۏأ﷽أىەألشوتۏتأ=أڬٓرأڬٓرأحتڬۄأًۄأځہۏىڬأزەأ؏أځہشأإځأ﷽أىەألشوتۏتأ=أڬۏتأحوۄۏڽأوؼهًوأىۄۏڽأڬۄأۄوأظزمۄأىۄۏڽأڬہتحەأۗ

[تخریج]: [ صحیح ۔ بخاری1466 ۔ مسلم 1069 ]"
13232,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأشضًهأتههۄأ﷽أڬەأځتضأهًڲًڽأڬەأڋہۏشًڽأضەأظزمۄأڬۏأڬہدًشۏڽأهتةۏأڲةۏڽأ؏أهًڲأتځىۏأتځىۏأڬہدًشۏڽأځۏطأڬشىەأهڲەأذحۏٳأڬۄأإځأڬەأځتضأڬہدًشًڽأڬتأڋہۏشأهڲأڲۏتأۗأذضىأثىأؼهۏأشعۏأتههۄأؼىۄأتىأڬہدًشًڽأضەأڬہۏهأشۄەأحہەأتىہًڽأىەأتۏڬأڬہدًشأځڬڔۏأتًشأڬہتأهۏأۗأىثۏأ﷽أىەأتضأڬًأتىأڬەأوىۄأضەأىڬهأڬشأځہۏىڬأزۏتأځہشألشوتۏتأ=أڬۏتأحوۄۏڽأوؼهًوأىۄۏڽأڬۄأإهٓأوذوزأظزمۄأىۄۏڽأڬہتحەأۗ

[تخریج]: [ صحیح ۔ بخاری 1466 ۔ مسلم 1069 ]"
13233,"أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأىثۏأ﷽أىەألشوتۏتأ=أوۏڽأتځىەأڲہشأًتهًڽأڬۏأغشلأڲۏتأحًأوۏڽأىەأصوۏىأځشأڲشۏأۄًةۏأڬہدًشأزۏڬہۏأۗأوۏڽأىەأتضأڬًأتټہتۏتأتًشأڬہتىتأډتۄتأ؏أهۏڬىأودہەأۏۄأرۏتهأإۏتأڬۄأۄًأضڬحتأۄەأۏۄأظزمەأڬۏأۄًأ؏أځہشأوۏڽأىەأتضأڬًأځہۏىڬأزۏتأۗ

[تخریج]: [ صحیح ۔ بخاری 2433 ۔ مسلم 1070 ]"
13234,"أذعشحأتىضأشعۏأتههۄأؼىۄأضەأشًتۏحأۄەأڬۄأىثۏأ﷽أىەأتۏڬأڬہدًشأزۏڬہۏأ؏أإځأ﷽أىەألشوتۏتأڬۄأتڲشأوۏڽأرًلأىۄأۄًحتأڬۄأۏۄأظزمەأڬۏأۄەأحًأوۏڽأڬہتأهۏحتأۄەأۗ

[تخریج]: [ بخاری 2000 ۔ مسلم 1071 ]"
13235,"أتۏعتَ

[تخریج]: [ صحیح ]"
13236,"أؼثزتههۄأثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأۄوأتثىأؼثتضأڬەأځتضأثىۏأۄتطوأڬەأىًدًتىأڬەأڲہشأثۏټہەأحہەأ؏أتىہًڽأىەألشوتۏتأڬۄأتههۄأڬۏأمضوأۄوأڬًأىثۏأ﷽أىەأڬضۏأډۏصأوۏڽأثہۏأتځىەأضتحہأرتظأىۄۏڽأڬۏتأضًتةەأحۏىأډۏصًڽأڬەأ=أۄوأڬًأذڬوأزۏتأڬۄأۄوأتډہەأغشۏمەأضەأًعًأڬشۏڽأتًشأۄوأڬًأذڬوأزۏتأڬۄأۄوأظزمۄأىۄأڬہتةۏڽأتًشأىۄأۄوأڲزہًڽأڬۏأڲہًڔًڽأځشأدلحۏأڬشتةۏڽأۗ

[تخریج]: [ صحیح ۔ الطیالسی 2723 ]"
13237,"أتثىأؼثتضأشعۏأتههۄأؼىۄوتألشوتحەأۄۏڽأڬۄأودہەأوۏشەأًتهزأىەأثہۏدتأڬۄأىثۏأ﷽أڬۏأغشلأتًىټأزەأإاڽأدًأرتظأظزمەأڬەأحہەأۗأتضأوۏڽأزًأوؼىًڽأڬتأتذحوتهأۄەأ=أ4أۏۄأثىًأۄتطوأڬەأهۏەأظزمۄأڬۏأذشوحأضەأځۄهەأحہتأ؏أځہشأوىضًرأۄًأڲۏتأ5أووڬىأۄەأتىہًڽأىەأوضتڬۏىأضەأذعشحأؼثتضأشعۏأتههۄأؼىۄوتأضەأوضحؼتشأهۏتأۄًأ؏أځہشأتىہۏڽأتًىټًڽأڬەأظزمۄأوۏڽأزەأزۏتأۗ

[تخریج]: [ ضعیف ]"
13238,"+أتهلأ,أضۏزىتأصۏزأثىأتشموأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأىثۏأ﷽أتۏڬأزىأڬہڔەأۄًةەأرغثۄأزۏىەأهڲەأ؏أتههۄأڬۏأذوزأًأخىتأثۏتىأڬۏأ؏أځہشألشوتۏتأ=أوۏڽأحوأوۏڽأضەأتۏڬأتىضتىأۄًڽأتًشأمشۏثأۄەأڬۄأتههۄأڬتألشطحۄأوۏشەأځتضأإةەأتًشأوۏڽأتضأڬۏأثتحأڬًأمثًهأڬشأهًڽأ+أۏؼىۏأوًحأ,أوۏڽأحوأوۏڽأزًأډۏصۏڽأډہًڔأڬشأدتأشۄتأۄًڽأ؏أتۏڬأتههۄأڬۏأڬحتثأدضأوۏڽأىًشأتًشأۄزتۏحأۄەأحوأتههۄأڬۏأڬحتثأڬًأوعثًغۏأضەأځڬڔەأشڬہىتأځہشأتضأځشأتثہتشتأتًشأشؽثحأزهتةۏأځہشألشوتۏتأ=أتًشأوۏشەأتۄهأثۏحأ؏أوۏڽأحوأڬًأتځىەأتۄهأثۏحأڬەأثتشەأوۏڽأتههۄأضەأڋشتحتأۄًڽأۗأذظۏىأىەأصۏزأضەأڬۄتأ=أإځأڬەأتۄهأثۏحأڬًىأۄۏڽأآأڬۏتأإځأڬۏأثۏًۏتڽأتۄهأوۏڽأضەأۄۏڽأآأحًأتىہًڽأىەألشوتۏتأ=أثۏطڬأإځأڬۏأثۏًۏتڽأتۄهأثۏحأوۏڽأضەأۄۏڽأ؏أهۏڬىأإځأڬەأثؼزأدىأځشأظزمۄأذشتوأۄەأۗأځًډہتأ=أًۄأڬًىأهًڲأۄۏڽأآألشوتۏتأ=أإهٓأؼهۏأتًشأإهٓأدؼلشأتًشأإهٓأؼثتضألشوتۏتأ=أڬۏتأتىأحوتوأځشأظزمۄأذشتوأۄەأآأحًأتىہًڽأىەألشوتۏتأ=أدۏأۄتڽأۗ+أثأ,أذعشحأدثۏشأثىأوغؼوأشعۏأتههۄأؼىۄأشضًهأتههۄأ﷽أضەأشًتۏحأڬشحەأۄۏڽأڬۄأىثۏأ﷽أىەألشوتۏتأ=أثىًأوغهثأتًشأثىًأۄتطوأتۏڬأۄۏأۄۏڽأتًشأتىہۏڽأمشتثحأزتشًڽأڬەأذظۄأضەأزۏتأۗ

[تخریج]: [ صحیح ]"
13239,"أؼثزتهوغهثأثىأشثۏؼۄأثىأذتشخألشوتحەأۄۏڽأڬۄأشثۏؼۄأثىأذتشخأتًشأذعشحأؼثتضأىەأوطًشۄأڬۏتأڬۄأتڲشأۄوأتىأزًأثډًڽأۏؼىۏأودہەأتًشألعهأڬًأشضًهأڬەأځتضأثہۏدۏڽأحًأًۄأزًىًڽأىەأشضًهأتههۄأ﷽أضەأثتحأڬشۏڽأتًشأإځأتىہۏڽأظزمتحأځشأؼتوهأومششأڬشأزۏڽأحًأدًأڬتوأهًڲأڬشۏڽأًۄأثہۏأڬشۏڽأتًشأدًأذظۄأهًڲًڽأڬًأوهحتأۄەأًۄأتىہۏڽأثہۏأوهەأ؏أًۄأتثہۏأۏۄأثتحۏڽأڬشأشۄەأحہەأڬۄأذعشحأؼهۏأشعۏأتههۄأؼىۄأتىأڬەأځتضأإةەأتًشأتىأضەأثتحأڬۏأحًأتىہًڽأىەأڬۏتأ=أتۏضتأىۄأڬشًأ؏أتههۄأڬۏأمضوأ$أًۄأڬشىەأًتهتأڬتوأىۄۏڽأ؏أشثۏؼۄأثىأذتشخأىەأڬۄتأ=أتههۄأڬۏأمضوأ$أحًأتضأهۏەأۏۄأڬتوأىۄۏڽأڬشحتأڬۄأحدہەأۄوأځشألعۏهحأۄەأحًأتههۄأڬۏأمضوأ$أشضًهأتههۄأ﷽أڬتأزتوتزأۄەأ؏أذعشحأؼهۏأشعۏأتههۄأؼىۄأىەأڬۄتأ=أتىہۏڽأثہۏدأزًأحًأًۄأزًىًڽأډهەأڲةەأ؏أدثأىثۏأ﷽أىەأىوتصأځڔہتأزۏأحًأۄوأدهزۏأضەأذدشۄأڬەأځتضأډهەأڲةەأتًشأًۄتڽأڬہڔەأۄًأڲةەأۗأإځأىەأۄوۏڽأڬتىًڽأضەأځڬڔأڬشأڬۄتأ=أتځىتأتشتزۄأػتۄشأڬشًأ؏أځہشأإځأتىزشأزترهأۄًةەأ؏أۄوأثہۏأإځأڬەأضتحہأزترهأۄًةەأ؏أتضأزىأإځأصۏىثأثىحأدذطأڬەأځتضأحہەأ؏أۄوأىەأڬهتوأڬشىەأڬتأتشتزۄأڬۏتأ؏أۄوأوۏڽأضەأتۏڬأىەأڬۄتأ=أإځأهًڲًڽأوۏڽأضەأضثأضەأصۏتزۄأظهۄأشذوۏأڬشىەأًتهەأۄۏڽأ؏أۄوأدًتىأۄًأډڬەأۄۏڽأ؏أۄوأإځأڬەأځتضأإحەأۄۏڽأحتڬۄأإځأۄوۏڽأظزمتحأځشأڬضۏأڬتوأځشأهڲتأزۏڽأحًأۄوأثہۏأإځأ﷽أڬەأځتضأًۄأوتهأهەأڬشأإةۏڽأڲەأدًأهًڲأهەأڬشأإحەأۄۏڽأتًشأۄوۏڽأثہۏأًۄأذظۄأوهأدتةەأدًأهًڲًڽأڬًأوهحتأۄەأ؏أإځأرتوًطأشۄەأ؏أۄوأىەأزًثتشۄأثًهىەأڬتأتشتزۄأڬۏتأحًأذعشحأصۏىحأشعۏأتههۄأؼىۄتأىەأۄوۏڽأځشزۄأڬەأځۏډہەأضەأرتوًطأشۄىەأڬتأتطتشۄأڬۏتأ؏أځہشأإځأىەألشوتۏتأ=أثۏطڬأظزمۄأإهأوذوزأ﷽أڬەأهۏەأدتةصأىۄۏڽأ؏أۏۄأحًأهًڲًڽأڬۏأوۏهأڬډۏهأۄەأ؏أځہشأوذوۏۄأڬًأثهًتۏتأۗأتضأڬۏأسوۄأزتشۏأروضأځشأحہۏأتًشأىًلهأثىأذتشخأثىأؼثزتهوغهثأڬًأثهتۏتأحًأإځأىەأوذوۏۄأضەأڬۄتأ=أتضأىًدًتىألعهأثىأؼثتضأشعۏأتههۄأؼىۄأڬۏأطتزۏأتځىۏأثۏټۏأضەأڬشأزەأحًأتضأىەأطتزۏأڬشأزۏأتًشأىًلهأثىأذتشخأضەأڬۄتأ=أتضأىًدًتىأڬۏأطتزۏأتځىۏأثۏټۏأضەأڬشأزەأدًأوۏشەأهۏەأحہۏأحًأتضأىەأوۏشۏأطتزۏأڬشأزۏأۗأځہشأوذوۏۄأضەأڬۄتأ=أتىہۏڽأروضأضەأتحىتأتحىتأزەأزًأۗ

[تخریج]: [ مسلم 1072 ]"
13240,"أتثىأطۄتثأصۄشۏأذزۏخأوۏڽألشوتحەأۄۏڽأڬۄأإځأىەأۄوۏڽألشوتۏتأ=أظزمۄأهًڲًڽأڬۏأوۏهأڬډۏهأۄەأتًشأىۄأحًأۏۄأوذوزأ﷽أڬەأهۏەأدتةصأۄەأتًشأىۄأۄۏأتىأڬۏأإهأڬەأهۏەأۗ

