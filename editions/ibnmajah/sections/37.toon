4263,حَدَّثَنَا أَحْمَدُ بْنُ ثَابِتٍ الْجَحْدَرِيُّ،‏‏‏‏ وَعُمَرُ بْنُ شَبَّةَ بْنِ عَبِيدَةَ،‏‏‏‏ قَالَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۹۴۱، ومصباح الزجاجة:۹۵۴۱),4263,,Zuhd
4264,حَدَّثَنَا يَحْيَى بْنُ خَلَفٍ أَبُو سَلَمَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ الْأَعْلَى،‏‏‏‏ عَنْ سَعِيدٍ،‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح البخاری/الرقاق ۴۱ (۶۵۰۷،۶۵۰۸ تعلیقاً)، صحیح مسلم/الذکروالدعاء (۲۶۸۴)، سنن الترمذی/الجنائز ۶۸ (۱۰۶۷)، سنن النسائی/الجنائز ۱۰ (۱۸۳۹)،(تحفة الأشراف:۱۶۱۰۳)، وقد أخرجہ: مسند احمد (۶/۴۴،۵۵،۲۰۷،۲۱۸،۲۳۶),4264,,Zuhd
4265,حَدَّثَنَا عِمْرَانُ بْنُ مُوسَى،‏‏‏‏ حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ،‏‏‏‏ حَدَّثَنَا عَبْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الجنائز ۱۳ (۳۱۰۸)،(تحفة الأشراف:۱۰۳۷)، وقد أخرجہ: صحیح البخاری/المرضی ۱۹ (۵۶۷۲)، الدعوات ۳۰ (۶۳۵۱)، صحیح مسلم/الذکر ۴ (۲۶۸۰)، سنن الترمذی/الجنائز ۳ (۹۷۱)، سنن النسائی/الجنائز ۲ (۱۸۲۲)، مسند احمد (۳/۱۰۱،۱۰۴،۱۶۳،۱۷۱،۱۹۵،۲۰۸،۲۴۷،۲۸۱),4265,,Zuhd
4266,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ عَنْ الْأَعْمَشِ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۵۵۲)، وقد أخرجہ: صحیح البخاری/تفسیر الزمر ۴ (۴۸۱۴)، تفسیر النبأ ۱ (۴۹۳۵)، صحیح مسلم/الفتن ۲۸ (۲۹۵۵)، سنن ابی داود/السنة ۲۴ (۴۷۴۳)، سنن النسائی/الجنائز ۱۱۷ (۲۰۷۹)، موطا امام مالک/الجنائز ۱۶ (۴۸)، مسند احمد (۲/۳۱۵،۳۲۲،۴۲۸),4266,,Zuhd
4267,حَدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاق،‏‏‏‏ حَدَّثَنِي يَحْيَى بْنُ مَعِينٍ،‏‏‏‏ حَدَّثَنَا هِشَامُ بْنُ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الزھد ۵ (۲۳۰۸)،(تحفة الأشراف:۹۸۳۹)، وقد أخرجہ: مسند احمد (۱/۶۳),4267,,Zuhd
4268,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا شَبَابَةُ،‏‏‏‏ عَنْ ابْنِ أَبِي ذِئْبٍ،‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۳۸۷، ومصباح الزجاجة:۱۵۲۷)، وقد أخرجہ: مسند احمد (۲/۱۴۰،۳۶۴،۶/۱۳۹),4268,,Zuhd
4269,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ،‏‏‏‏ حَدَّثَنَا شُعْبَةُ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجنائز ۸۶ (۱۳۶۹)، التفسیرسورة ابراہیم ۲ (۴۶۹۹)، صحیح مسلم/الجنة ۱۷ (۲۸۷۱)، سنن ابی داود/السنة ۲۷ (۴۷۵۰ سنن الترمذی/تفسیرالقران سورة ٕابراہیم ۱۵ (۳۱۲۰)، سنن النسائی/الجنائز ۱۱۴ (۲۰۵۹)،(تحفة الأشراف:۱۷۶۲)، وقد أخرجہ: مسند احمد (۴/۲۸۲،۲۹۱),4269,,Zuhd
4270,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ،‏‏‏‏ حَدَّث,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۰۱۵)، وقد أخرجہ: صحیح البخاری/الجنائز ۸۹ (۱۳۷۹)، بدء الخلق ۸ (۳۲۴۰)، الرقاق ۴۲ (۶۵۱۵)، صحیح مسلم/الجنة ۱۷ (۲۸۶۶)، سنن الترمذی/الجنائز ۷۰ (۱۰۷۲)، سنن النسائی/الجنائز ۱۱۶ (۲۰۷۲)، موطا امام مالک/الجنائز ۱۶ (۴۷)، مسند احمد (۲/۱۶،۵۱،۱۱۳،۱۲۳),4270,,Zuhd
4271,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ،‏‏‏‏ أَنْبَأَنَا مَالِكُ بْنُ أَنَسٍ،‏‏‏‏ عَنْ ابْنِ شِهَابٍ،‏‏‏‏ ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/فضائل الجہاد ۱۳ (۱۶۴۱)، سنن النسائی/الجنائز ۱۱۷ (۲۰۷۵)،(تحفة الأشراف:۱۱۴۸)، وقد أخرجہ: موطا امام مالک/الجنائز ۱۶ (۴۹)، مسند احمد (۳/۴۵۵،۴۵۶،۴۶۰),4271,,Zuhd
4272,حَدَّثَنَا إِسْمَاعِيل بْنُ حَفْصٍ الْأُبُلِّيُّ،‏‏‏‏ حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ،‏‏‏‏ عَن,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۳۳۴، ومصباح الزجاجة:۱۵۲۸),4272,,Zuhd
4273,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ،‏‏‏‏ عَنْ حَجّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Munkar; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۱۹۳، ومصباح الزجاجة:۱۵۲۹),4273,,Zuhd
4274,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ،‏‏‏‏ عَنْ مُحَمَّد,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۰۷۶، ومصباح الزجاجة:۱۵۳۱)، وقد أخرجہ: صحیح مسلم/الفضائل ۴۲ (۲۳۷۳),4274,,Zuhd
4275,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا عَبْد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/صفة القیامة نحوہ (۲۷۸۸)،(تحفة الأشراف:۷۳۱۵)، وقد أخرجہ: مسند احمد (۲/۷۲،۸۷),4275,,Zuhd
4276,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ،‏‏‏‏ عَنْ حَات,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الرقاق ۴۵ (۶۵۲۷)، صحیح مسلم/الجنة ۱۴ (۲۸۵۹)، سنن النسائی/الجنائز ۱۱۸ (۲۰۸۶)،(تحفة الأشراف:۱۷۴۶۱)، وقد أخرجہ: مسند احمد (۶/۵۳،۹۰),4276,,Zuhd
4277,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا وَكِيعٌ،‏‏‏‏ عَنْ عَلِيِّ بْن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۹۸۶، ومصباح الزجاجة:۱۵۳۲)، وقد أخرجہ: مسند احمد (۴/۴۱۴),4277,,Zuhd
4278,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عِيسَى بْنُ يُونُسَ،‏‏‏‏ وَأَبُو خَالِدٍ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/تفسیر القرآن ۸۳ (۴۹۳۸)، الرقاق ۴۷ (۶۵۳۱)، صحیح مسلم/الجنة وصفة نعیمہا ۱۵ (۲۸۶۲)، سنن الترمذی/صفة القیامة ۲ (۲۴۲۲)، التفسیر ۷۴ (۳۳۳۶)،(تحفة الأشراف:۷۷۴۳)، وقد أخرجہ: مسند احمد (۲/۱۳،۳۱،۳۳),4278,,Zuhd
4279,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا عَلِيُّ بْنُ مُسْهِرٍ،‏‏‏‏ عَنْ دَاوُدَ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/صفة القیامة ۲ (۲۷۹۱)، سنن الترمذی/تفسیر القرآن ۱۵ (۳۱۲۱)،(تحفة الأشراف:۱۷۶۱۷)، وقد أخرجہ: مسند احمد۶/۳۵)، سنن الدارمی/الرقاق ۸۸ (۲۸۵۱),4279,,Zuhd
4280,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ قَالَ:‏‏‏‏ حَدَّثَنَا عَبْدُ الْأَعْلَى،‏‏‏‏ عَنْ م,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۰۶۸، ومصباح الزجاجة:۱۵۳۰)، وقد أخرجہ: صحیح مسلم/الإیمان ۸۱ (۲۸۳)، مسند احمد (۲/۲۹۳،۳/۱۱،۱۷),4280,,Zuhd
4281,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ،‏‏‏‏ عَنْ الْأَعْمَشِ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۸۲۰، ومصباح الزجاجة:۱۵۳۳)، وقد أخرجہ: مسند احمد۶/۲۸۵),4281,,Zuhd
4282,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ قَالَ،‏‏‏‏ حَدَّثَنَا يَحْيَى بْنُ زَكَرِيَّا بْنِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الطہارة ۱۲ (۲۴۷)،(تحفة الأشراف:۱۳۳۹۹),4282,,Zuhd
4283,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ،‏‏‏‏ حَدَّثَنَا شُعْبَةُ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الرقاق ۴۵ (۶۵۲۶)، صحیح مسلم/الإیمان ۹۵ (۲۲۱)، سنن الترمذی/صفة الجنة ۱۳ (۲۵۴۷)،(تحفة الأشراف:۹۴۸۳)، وقد أخرجہ: موطا امام مالک/قصرالصلاة ۲۴ (۸۸)، مسند احمد (۱/۳۸۶،۴۳۷،۴۴۵),4283,,Zuhd
4284,حَدَّثَنَا أَبُو كُرَيْبٍ،‏‏‏‏ وَأَحْمَدُ بْنُ سِنَانٍ،‏‏‏‏ قَالَا:‏‏‏‏ حَدَّثَنَا أَبُو مُعَاوِيَةَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/أحادیث الأنبیاء ۳ (۳۳۳۹)، سنن الترمذی/تفسیر القرآن ۳ (۲۹۶۱)،(تحفة الأشراف:۴۰۰۳)، وقد أخرجہ: مسند احمد (۳/۹،۳۲،۵۸),4284,,Zuhd
4285,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ،‏‏‏‏ عَنْ الْأَو,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۶۱۱، ومصباح الزجاجة:۱۵۳۴)، وقد أخرجہ: مسند احمد (۴/۱۶),4285,,Zuhd
4286,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ،‏‏‏‏ حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ،‏‏‏‏ حَدَّثَنَا مُحَمَّدُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/صفة القیامة ۱۲ (۲۴۳۷)،(تحفة الأشراف:۴۹۲۴)، وقد أخرجہ: مسند احمد (۵/۲۶۸),4286,,Zuhd
