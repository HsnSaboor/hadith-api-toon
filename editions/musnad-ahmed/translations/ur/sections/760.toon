hadiths[1]{hadithnumber,text}:
20864,أتثًتهضهۏهأڬۄحەأۄۏڽأڬۄأىثۏأ﷽أڬەأتۏڬأظذتثۏأشعۏأتههۄأؼىۄأهًڲًڽأڬەأضتوىەأذزۏخأثۏتىأڬشأشۄەأحہەأ؏أهًڲًڽأڬۏأحؼزتزأدثأثڔہحۏأڲةۏأحًأًۄأڲہشأڬۏأډہحأځشأثۏټہأڬشأذزۏخۏڽأثۏتىأڬشىەأهڲەأ؏أتىۄًڽأىەأڬۄتأڬۄأتۏڬأزىأىثۏأ﷽أىەأهًڲًڽأضەأځًډہتأمشإىأوۏڽأضثأضەأثڔۏأإۏحأڬًىأضۏأۄەأآأتۏڬأإزوۏأىەأڬۄتأإۏحأتهڬشضۏأ؏أًۄأظتذثأڬۄحەأۄۏڽأڬۄأوۏشتأدًتثأضىأڬشأىثۏأ﷽أىەأتځىتأزضحأوثتشڬأوۏشەأزًىًڽأڬىزہًڽأڬەأزشوۏتىأشڬہأزۏتأدضأڬۏأټہىڋڬأوۏڽأىەأتځىەأضۏىەأوۏڽأوذضًضأڬۏأ؏أتًشأىثۏأ﷽أىەألشوتۏتأتەأتثًوىسشأ$أحوۄۏڽأؼهوأوثتشڬأۄًأۗ
