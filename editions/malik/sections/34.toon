metadata:

hadiths[10]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "1390", "arabic": "[1390] وَحَدَّثَنِی مَالِکٌ، عَنْ نَافِعٍ أَ نَّہُ سَمِعَ عَبْدَ اللّٰہِ بْنَ عُمَرَ یَقُولُ : مَنْ", "bengali": "", "english": "Yahya related to me from Malik from Nafi that Abdullah ibn Umar said, \"In the time of the Messenger of Allah, may Allah bless him and grant him peace, we used to buy food. He sent orders for us to move our purchases from the place in which we purchased them to another place before we re-sold them.\"", "french": "", "indonesian": "", "russian": "", "urdu": "نافع سے روایت ہے ، انھوں نے حضرت عبداللہ بن عمر رضی اللہ عنہما کو یہ فرماتے ہوئے سنا : جس شخص نے کوئ", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Sahih'}", "reference": "Book 34, Hadith 1", "international_number": "1390", "narrator_chain": "", "chapter_intro": "Renting Land"}
{"hadithnumber": "1391", "arabic": "[1391] وَحَدَّثَنِی مَالِکٌ، أَ نَّہُ بَلَغَہُ أَنَّ عَبْدَ اللّٰہِ بْنَ مَسْعُودٍ کَانَ یَقُولُ :", "bengali": "", "english": "Malik related to me that Ibn Shihab said, \"I asked Said ibn al- Musayyab about renting land for gold or silver, and he said, 'There is no harm in it", "french": "", "indonesian": "", "russian": "", "urdu": "امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ بے شک حضرت عبداللہ بن مسعود رضی اللہ عنہ فرمایا کرتے تھے کہ ج", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}", "reference": "Book 34, Hadith 2", "international_number": "1391", "narrator_chain": "", "chapter_intro": "Renting Land"}
{"hadithnumber": "1392", "arabic": "[1392] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ، أَنَّ رَسُو", "bengali": "", "english": "Malik related to me from Ibn Shihab that he asked Salim ibn 'Abdullah ibn Umar about renting out fields. He said, \"There is no harm in it for gold or silver.\" Ibn Shihab said, \"I said to him, 'What do you think of the hadith which is mentioned from Rafi ibn Khadij?'\" He said, ''Rafi has exaggerated. If I had a field, I would rent it out", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ کوئی شخص کسی کی بی", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}", "reference": "Book 34, Hadith 3", "international_number": "1392", "narrator_chain": "", "chapter_intro": "Renting Land"}
{"hadithnumber": "1393", "arabic": "[1393] وَحَدَّثَنِی مَالِکٌ، عَنْ أبِی الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أبِی ہُرَیْرَۃَ أَنَّ ر", "bengali": "", "english": "Malik related to me that he had heard that Abd ar-Rahman ibn Awf rented land, and he continued to have it in his possession until he died. His son said, \"I thought that it was ours because of the length of time which it had remained in his hands, until he mentioned it to us at his death. He ordered us to pay some rent which he owed in gold or silver", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ ( مال کی ) خرید و فروخت کے", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}", "reference": "Book 34, Hadith 4", "international_number": "1393", "narrator_chain": "", "chapter_intro": "Renting Land"}
{"hadithnumber": "1394", "arabic": "[1394] قَالَ مَالِکٌ : عَنْ نَافِعٍ عَنْ عَبْدِ اللّٰہِ بْنِ عُمَرَ : أَنَّ رَسُولَ اللّٰہِ  ﷺ نَہَ", "bengali": "", "english": "Malik related to me from Hisham ibn Urwa that his father used to rent out his land for gold and silver. Malik was asked about a man who rented his field for 100 sa of dates or part of its produce of wheat or from other than its produce. He disapproved of that", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ بے شک رسول اللہ ﷺ نے نجش ( ناجائز بولی چڑھانے ) سے", "grades": "{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}", "reference": "Book 34, Hadith 5", "international_number": "1394", "narrator_chain": "", "chapter_intro": "Renting Land"}
{"hadithnumber": "1469", "arabic": "حَدَّثَنَا يَحْيَى، عَنْ مَالِكٍ، عَنْ رَبِيعَةَ بْنِ أَبِي عَبْدِ الرَّحْمَنِ، عَنْ حَنْظَلَةَ بْنِ قَيْسٍ الزُّرَقِيِّ،  عَنْ رَافِعِ بْنِ خَدِيجٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنْ كِرَاءِ الْمَزَارِعِ قَالَ حَنْظَلَةُ فَسَأَلْتُ رَافِعَ بْنَ خَدِيجٍ بِالذَّهَبِ وَالْوَرِقِ فَقَالَ أَمَّا بِالذَّهَبِ وَالْوَرِقِ فَلاَ بَأْسَ بِهِ ‏.‏", "bengali": "", "english": "Yahya related to me from Malik from Rabia ibn Abd ar-Rahman from Handhala ibn Qays az-Zuraqi from Rafi ibn Khadij that the Messenger of Allah, may Allah bless him and grant him peace, forbade renting out fields.   Handhala said, \"I asked Rafi ibn Khadij, about paying in gold and silver, and he said, 'There is no harm in it.' \"", "french": "", "indonesian": "", "russian": "", "urdu": "عمرو بن سلیم زرقی سے روایت ہے کہ بے شک عمر بن خطاب رضی اللہ عنہ سے کہا گیا کہ یقیناً یہاں ( مدینہ می", "grades": "", "reference": "", "international_number": "1469", "narrator_chain": "", "chapter_intro": "Renting Land"}
{"hadithnumber": "1470", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنِ ابْنِ شِهَابٍ، أَنَّهُ قَالَ سَأَلْتُ سَعِيدَ بْنَ الْمُسَيَّبِ عَنْ كِرَاءِ الأَرْضِ، بِالذَّهَبِ وَالْوَرِقِ فَقَالَ لاَ بَأْسَ بِهِ ‏.‏", "bengali": "", "english": "Malik related to me that Ibn Shihab said, \"I asked Said ibn al- Musayyab about renting land for gold or silver, and he said, 'There is no harm in it.' \"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبکر بن حزم رحمہ اللہ سے روایت ہے کہ غسّان قبیلے کے ایک لڑکے کو مدینہ منورہ میں موت کا وقت آ گیا ،", "grades": "", "reference": "", "international_number": "1470", "narrator_chain": "", "chapter_intro": "Renting Land"}
{"hadithnumber": "1471", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنِ ابْنِ شِهَابٍ، أَنَّهُ سَأَلَ سَالِمَ بْنَ عَبْدِ اللَّهِ بْنِ عُمَرَ عَنْ كِرَاءِ الْمَزَارِعِ، فَقَالَ لاَ بَأْسَ بِهَا بِالذَّهَبِ وَالْوَرِقِ ‏.‏ قَالَ ابْنُ شِهَابٍ فَقُلْتُ لَهُ أَرَأَيْتَ الْحَدِيثَ الَّذِي يُذْكَرُ عَنْ رَافِعِ بْنِ خَدِيجٍ فَقَالَ أَكْثَرَ رَافِعٌ وَلَوْ كَانَ لِي مَزْرَعَةٌ أَكْرَيْتُهَا ‏.‏", "bengali": "", "english": "Malik related to me from Ibn Shihab that he asked Salim ibn 'Abdullah ibn Umar about renting out fields. He said, \"There is no harm in it for gold or silver.\" Ibn Shihab said, \"I said to him, 'What do you think of the hadith which is mentioned from Rafi ibn Khadij?'\" He said, ''Rafi has exaggerated. If I had a field, I would rent it out.\"", "french": "", "indonesian": "", "russian": "", "urdu": "حضرت سعد بن ابی وقاص رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ رسول اللہ ﷺ حجۃ الوداع والے سال میرے پاس", "grades": "", "reference": "", "international_number": "1471", "narrator_chain": "", "chapter_intro": "Renting Land"}
{"hadithnumber": "1472", "arabic": "وَحَدَّثَنِي مَالِكٌ، أَنَّهُ بَلَغَهُ أَنَّ عَبْدَ الرَّحْمَنِ بْنَ عَوْفٍ، تَكَارَى أَرْضًا فَلَمْ تَزَلْ فِي يَدَيْهِ بِكِرَاءٍ حَتَّى مَاتَ قَالَ ابْنُهُ فَمَا كُنْتُ أُرَاهَا إِلاَّ لَنَا مِنْ طُولِ مَا مَكَثَتْ فِي يَدَيْهِ حَتَّى ذَكَرَهَا لَنَا عِنْدَ مَوْتِهِ فَأَمَرَنَا بِقَضَاءِ شَىْءٍ كَانَ عَلَيْهِ مِنْ كِرَائِهَا ذَهَبٍ أَوْ وَرِقٍ ‏.‏", "bengali": "", "english": "Malik related to me that he had heard that Abd ar-Rahman ibn Awf rented land, and he continued to have it in his possession until he died. His son said, \"I thought that it was ours because of the length of time which it had remained in his hands, until he mentioned it to us at his death. He ordered us to pay some rent which he owed in gold or silver.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ہشام بن عروہ رحمہ اللہ اپنے والد ( عروہ بن زبیر رضی اللہ عنہ ) سے روایت کرتے ہیں کہ بے شک سیدہ ام سل", "grades": "", "reference": "", "international_number": "1472", "narrator_chain": "", "chapter_intro": "Renting Land"}
{"hadithnumber": "1473", "arabic": "وَحَدَّثَنِي مَالِكٌ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، أَنَّهُ كَانَ يُكْرِي أَرْضَهُ بِالذَّهَبِ وَالْوَرِقِ ‏.‏ وَسُئِلَ مَالِكٌ عَنْ رَجُلٍ أَكْرَى مَزْرَعَتَهُ بِمِائَةِ صَاعٍ مِنْ تَمْرٍ أَوْ مِمَّا يَخْرُجُ مِنْهَا مِنَ الْحِنْطَةِ أَوْ مِنْ غَيْرِ مَا يَخْرُجُ مِنْهَا فَكَرِهَ ذَلِكَ ‏.‏", "bengali": "", "english": "Malik related to me from Hisham ibn Urwa that his father used to rent out his land for gold and silver.   Malik was asked about a man who rented his field for 100 sa of dates or part of its produce of wheat or from other than its produce. He disapproved of that.", "french": "", "indonesian": "", "russian": "", "urdu": "قاسم بن محمد رحمہ اللہ ( بن ابی بکر رضی اللہ عنہ ) سے روایت ہے ، کہتے ہیں : حضرت عمر بن خطاب رضی الل", "grades": "", "reference": "", "international_number": "1473", "narrator_chain": "", "chapter_intro": "Renting Land"}
