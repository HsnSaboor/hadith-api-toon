{"hadithnumber": "6109", "text": "جریر نے ہمیں اعمش سے حدیث سنائی ، انھوں نے ابو ضحیٰ ( مسلم )  سے  ، انھوں نے مسروق سے ، انھوں نے حضر"}
{"hadithnumber": "6110", "text": "حفص بن غیاث اورعیسیٰ بن یونس دونوں نے اعمش سے جریر کی سند کے ساتھ انھی کی حدیث کے مانند ہمیں حدیث بی"}
{"hadithnumber": "6111", "text": "ابو معاویہ نے ہمیں اعمش سے حدیث بیان کی ، انھوں نے ( ابوضحیٰ )  مسلم سے ، انھوں نے مسروق سے ، انھوں"}
{"hadithnumber": "6112", "text": "عروہ بن زبیر سے روایت ہے کہ حضرت عبداللہ بن زبیر رضی اللہ تعالیٰ عنہ  نے انھیں حدیث سنائی کہ انصار م"}
{"hadithnumber": "6113", "text": "یو نس نے ابن شہاب سے روایت کی ،  کہا  :  مجھے ابو سلمہ بن عبدالرحمٰن اور سعید بن مسیب نے خبر دی  ، ا"}
{"hadithnumber": "6114", "text": "یزید بن ہاد نے ابن شہاب سے اسی سند کے ساتھ بالکل اسی کے مانند روایت کی ۔"}
{"hadithnumber": "6115", "text": "ابو صالح  ، اعرج  ، محمد بن زیاد اور ہمام بن منبہ ، سب نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے روای"}
{"hadithnumber": "6116", "text": "ابرا ہیم بن سعد نے ابن شہاب سے ،  انھوں نے عامر بن سعد سے انھوں نے اپنے والد سے روایت کی ،  کہا  :"}
{"hadithnumber": "6117", "text": "ہمیں سفیان  ( بن عیینہ )  نے حدیث بیان کی ،  کہا :  ۔ مجھے یہ اسی طرح یاد ہے جس طرح بسم اللہ الرحمٰن"}
{"hadithnumber": "6118", "text": "یو نس اور معمر دونوں نے اسی سند کے ساتھ زہری سے روایت کی اور معمر کی حدیث میں مزید بیان ہے ۔  \" وہ آ"}
{"hadithnumber": "6119", "text": "نضر بن شمیل نے کہا  :  ہمیں شعبہ نے خبر دی  ، انھوں نے کہا  :  ہمیں موسیٰ بن انس نے حضرت  انس بن ما"}
{"hadithnumber": "6120", "text": "روح بن عباد ہ نے ہمیں حدیث سنائی  ، کہا ہمیں شعبہ نے حدیث بیان کی کہا  :  مجھے مو سیٰ بن انس نے خبر"}
{"hadithnumber": "6121", "text": "یونس نے ابن شہاب سے خبر دی ، کہا : مجھے حضرت انس بن مالک رضی اللہ تعالیٰ عنہ  نے خبر دی کہ ( ایک دن"}
{"hadithnumber": "6122", "text": "معمر اور شعیب دونوں نے زہری سے ،  انھوں نے حضرت انس رضی اللہ تعالیٰ عنہ  سے ،  انھوں نے نبی  صلی الل"}
{"hadithnumber": "6123", "text": "سعید نے قتادہ سے ،  انھوں نے حضرت انس بن مالک  رضی اللہ تعالیٰ عنہ سے روایت کی کہ لو گوں نے نبی  صلی"}
{"hadithnumber": "6124", "text": "ہشام اور معمر کے والد سلیمان دونوں نے کہا  :  ہمیں قتادہ نے حضرت انس رضی اللہ تعالیٰ عنہ  سےیہ قصہ ب"}
{"hadithnumber": "6125", "text": "عبد اللہ بن براداشعری اور  ( ابو کریب )  محمد بن علاءہمدانی نے کہا  :  ہمیں ابو اسامہ نے یزید سے حدی"}
{"hadithnumber": "6126", "text": "موسیٰ بن طلحہ نے اپنے والد سے روایت کی ،  کہا  :  رسول اللہ  صلی اللہ علیہ وسلم کے ساتھ کچھ لوگوں کے"}
{"hadithnumber": "6127", "text": "عبد اللہ بن رومی یمامی  ، عباس بن عبد العظیم عنبری اور احمد بن جعفر معقری نے مجھے حدیث بیان کی ،  ان"}
{"hadithnumber": "6128", "text": "حماد بن سلمہ نے ہشام بن عروہ سے ،  انھوں نے اپنے والد سے ،  انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "6129", "text": "ہمام بن منبہ نے کہا  :  یہ احادیث ہیں جو حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ  نے رسول اللہ  صلی اللہ ع"}
{"hadithnumber": "6130", "text": "ابن شہاب سے روایت ہے کہ ابو سلمہ بن عبد الرحمٰن نے انھیں بتا یا کہ حضرت ابو ہریرہ رضی اللہ تعالیٰ عن"}
{"hadithnumber": "6131", "text": "اعرج نے ابو سلمہ سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  : رسول اللہ"}
{"hadithnumber": "6132", "text": "معمر نے ہمام بن منبہ سے حدیث بیان کی  ، انھوں نے کہا  :  یہ احادیث ہیں جو حضرت ابو ہریرہ رضی اللہ تع"}
{"hadithnumber": "6133", "text": "معمر نے زہری سے ،  انھوں نے سعید سے ،  انھوں نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ سے روایت کی ،  کہ"}
{"hadithnumber": "6134", "text": "معمر اور شعیب نے زہری سے ،  اسی سند کے ساتھ خبر دی  ، دونوں نے کہا  :   \"  ( بچہ  )  جب پیدا ہو تا ہ"}
{"hadithnumber": "6135", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  کے آزاد کردہ غلام ابو یونس سلیم نے حدیث بیان کی ،  انھوں نے حضرت"}
{"hadithnumber": "6136", "text": "سہیل  ( بن ابی صالح )  کے والد نے حضرت ابوہریرہ رضی اللہ تعالیٰ عنہ سے روایت کی ،  کہا  :  رسول اللہ"}
{"hadithnumber": "6137", "text": "۔  معمر نے ہمام بن منبہ سے حدیث بیان کی ،  انھوں نے کہا  :  یہ احادیث ہیں جو حضرت ابو ہریرہ رضی اللہ"}
{"hadithnumber": "6138", "text": "علی بن مسہر اور ابن فضیل نے مختار بن فلفل سے روایت کی ،  انھوں نے حضرت انس بن مالک رضی اللہ تعالیٰ ع"}
{"hadithnumber": "6139", "text": "ابن ادریس نے کہا  :  میں نے عمرو بن حریث کے آزاد کردہ غلام مختار بن فلفل سے سنا ، انھوں نے کہامیں نے"}
{"hadithnumber": "6140", "text": "سفیان نے مختار سے روایت کی ،  انھوں نے کہا  :  میں نے حضرت انس رضی اللہ تعالیٰ عنہ  کو نبی  صلی اللہ"}
{"hadithnumber": "6141", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے کہا  :  رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا"}
{"hadithnumber": "6142", "text": "یو نس نے ابن شہاب سے خبر دی  ، انھوں نے ابو سلمہ بن عبدالرحمٰن اور سعید بن مسیب  سے ، انھوں نے حضرت"}
{"hadithnumber": "6143", "text": "امام مالک نے زہری سے روایت کی کہ سعید بن مسیب اور ابو عبید نے انھیں حضرت ابو ہریرہ رضی اللہ تعالیٰ ع"}
{"hadithnumber": "6145", "text": "سیدنا ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :  سیدنا ابراہیم ع"}
{"hadithnumber": "6146", "text": "ہمام بن منبہ نے کہا  : یہ احادیث ہیں جو حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  نے ہمیں رسول اللہ  صلی ا"}
{"hadithnumber": "6147", "text": "عبد اللہ بن شفیق نے کہا  :  ہمیں حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ نے بتایا کہا :  حضرت موسی علیہ ا"}
{"hadithnumber": "6148", "text": "محمد بن رافع اور عبد بن حمید نے مجھے حدیث بیان کی ۔  عبد نے کہا :  عبدلرزاق نے ہمیں خبر دی اور ابن ر"}
{"hadithnumber": "6149", "text": "۔  محمد بن رافع کہا :  ہمیں  عبدلرزاق  نے  حدیث بیان کی ، کہا :  ہمیں معمر نے ہمام بن منبہ سے روایت"}
{"hadithnumber": "6150", "text": "محمد بن یحییٰ نے کہا  :  ہمیں عبد الرزاق نے حدیث بیان کی  ،  کہا  :   ہمیں معمر نے اسی حدیث کے مانند"}
{"hadithnumber": "6151", "text": "حجین بن مثنیٰ نے کہا  :  ہمیں عبد العز یز بن عبد اللہ بن ابی سلمہ نے عبد اللہ بن فضل ہاشمی سے حدیث ب"}
{"hadithnumber": "6152", "text": "یزید بن ہارون نے کہا :  ہمیں عبد العزیز بن ابی سلمہ نے اسی سند سے بالکل اسی طرح بیان کیا ۔"}
{"hadithnumber": "6153", "text": "یعقوب کے والد ابرا ہیم  ( بن سعد )  نے ابن شہاب سے ،  انھوں نے ابو سلمہ بن عبد الرحمٰن اور عبدالرحمٰ"}
{"hadithnumber": "6154", "text": "شعیب نے زہری سے روایت کی ، کہا :  مجھے ابوسلمہ بن عبد الرحمٰن اور سعید بن مسیب نے خبر دی  ، انھوں نے"}
{"hadithnumber": "6155", "text": "ابو احمد زبیری نے کہا  :  ہمیں سفیان نے عمرو بن یحییٰ سے ،  انھوں نےاپنے والد سے ،  انھوں نے حضرت اب"}
{"hadithnumber": "6156", "text": "ابو بکر بن ابی شیبہ نے کہا  :  ہمیں وکیع نے سفیان سے حدیث بیان کی ، ابن نمیر نے کہا : ہمیں میرے والد"}
{"hadithnumber": "6157", "text": "ہداب بن خالد اور شیبان بن فروخ نے کہا  : ہمیں حماد بن سلمہ نے ثابت بنانی اور سلیمان تیمی سے حدیث بیا"}
{"hadithnumber": "6158", "text": "عیسیٰ بن یونس جریر اور سفیان نے سلیمان تیمی سے روایت کی ،  کہا  : میں نے حضرت انس  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "6159", "text": "ابو بکر بن ابی شیبہ محمد بن مثنیٰ اور محمد بن بشار نے کہا :  ہمیں محمد بن جعفر نے حدیث بیان کی کہا"}
{"hadithnumber": "6160", "text": "قتادہ سے روایت ہے کہا :  میں نے ابو العالیہ سے سنا ،  وہ کہہ رہے تھے  :  تمھارے نبی  صلی اللہ علیہ و"}
{"hadithnumber": "6161", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے کہا :  آپ  صلی اللہ علیہ وسلم  سے عرض کی گئی  ، اللہ"}
{"hadithnumber": "6162", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے ۔ کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا  :"}
{"hadithnumber": "6163", "text": "عمرو بن محمد ناقد  ، اسحاق بن ابراہیم حنظلی  ، عبیداللہ بن سعید اور محمد بن ابی عمر مکی ، ان سب نے ہ"}
{"hadithnumber": "6164", "text": "۔  معتمر کے والد سلیمان تیمی نے رقبہ سے ،  انھوں نے ابو اسحق سے انھوں نے سعید بن جبیر سے روایت کی ،"}
{"hadithnumber": "6165", "text": "حضرت ابی ابن کعب  رضی اللہ تعالیٰ عنہ  نے ہمیں حدیث سنائی ، کہا : میں نےرسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "6166", "text": "اسرائیل نے ابو اسحاق سے تیمی کی سند کے ساتھ ابو اسحاق سے اس کی ابو اسحاق سے  روایت کردہ حدیث کے مانن"}
{"hadithnumber": "6167", "text": "عمروناقد نے کہا : ہمیں سفیان بن عینیہ نے عمرو ( بن دینار )  سے حدیث بیان کی ، انھوں نے سعید بن جبیر"}
{"hadithnumber": "6168", "text": "یونس نے ابن شہاب سے ، انھوں نے عبیداللہ بن عبداللہ بن عتبہ بن مسعود  ، انھوں نے حضرت عبداللہ بن عباس"}
