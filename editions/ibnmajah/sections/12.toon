metadata:

hadiths[342]{hadithnumber,arabic,bengali,english,french,indonesian,russian,urdu,grades,reference,international_number,narrator_chain,chapter_intro}:
{"hadithnumber": "1871", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، وَإِسْحَاقُ بْنُ إِبْرَاهِيمَ بْنِ حَبِيبٍ، قَالُوا حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنَا الأَعْمَشُ، عَنْ إِبْرَاهِيمَ، عَنِ الأَسْوَدِ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ أَطْيَبَ مَا أَكَلَ الرَّجُلُ مِنْ كَسْبِهِ وَإِنَّ وَلَدَهُ مِنْ كَسْبِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "'The best (most pure) food a man consumes is that which he has earned himself, and his child (and his child's wealth) is part of his earnings.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Aishah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1872", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، عَنْ بَحِيرِ بْنِ سَعْدٍ، عَنْ خَالِدِ بْنِ مَعْدَانَ، عَنِ الْمِقْدَامِ بْنِ مَعْدِيكَرِبَ الزُّبَيْدِيِّ، عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا كَسَبَ الرَّجُلُ كَسْبًا أَطْيَبَ مِنْ عَمَلِ يَدِهِ وَمَا أَنْفَقَ الرَّجُلُ عَلَى نَفْسِهِ وَأَهْلِهِ وَوَلَدِهِ وَخَادِمِهِ فَهُوَ صَدَقَةٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"No man earns anything better than that which he earns with his own hands, and what a man spends on himself, his wife, his child and his servant, then it is charity.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Miqdam bin Ma'dikarib (Ar- Zubaidi) that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1873", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، حَدَّثَنَا كَثِيرُ بْنُ هِشَامٍ، حَدَّثَنَا كُلْثُومُ بْنُ جَوْشَنٍ الْقُشَيْرِيُّ، عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ التَّاجِرُ الأَمِينُ الصَّدُوقُ الْمُسْلِمُ مَعَ الشُّهَدَاءِ يَوْمَ الْقِيَامَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "'The trustworthy, honest Muslim merchant will be with the martyrs on the Day of Resurrection.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1874", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ الدَّرَاوَرْدِيُّ، عَنْ ثَوْرِ بْنِ زَيْدٍ الدِّيلِيِّ، عَنْ أَبِي الْغَيْثِ، مَوْلَى ابْنِ مُطِيعٍ عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ السَّاعِي عَلَى الأَرْمَلَةِ وَالْمِسْكِينِ كَالْمُجَاهِدِ فِي سَبِيلِ اللَّهِ وَكَالَّذِي يَقُومُ اللَّيْلَ وَيَصُومُ النَّهَارَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "'The one who strives to support the widow and the poor is like a Mujahid who fights in the cause of Allah, and like one who stands in the night (in voluntary prayer) and fasts by day.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1875", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سُلَيْمَانَ، عَنْ مُعَاذِ بْنِ عَبْدِ اللَّهِ بْنِ خُبَيْبٍ، عَنْ أَبِيهِ، عَنْ عَمِّهِ، قَالَ كُنَّا فِي مَجْلِسٍ فَجَاءَ النَّبِيُّ ـ صلى الله عليه وسلم ـ وَعَلَى رَأْسِهِ أَثَرُ مَاءٍ فَقَالَ لَهُ بَعْضُنَا نَرَاكَ الْيَوْمَ طَيِّبَ النَّفْسِ ‏.‏ فَقَالَ ‏\"‏ أَجَلْ وَالْحَمْدُ لِلَّهِ ‏\"‏ ‏.‏ ثُمَّ أَفَاضَ الْقَوْمُ فِي ذِكْرِ الْغِنَى فَقَالَ ‏\"‏ لاَ بَأْسَ بِالْغِنَى لِمَنِ اتَّقَى وَالصِّحَّةُ لِمَنِ اتَّقَى خَيْرٌ مِنَ الْغِنَى وَطِيبُ النَّفْسِ مِنَ النِّعَمِ ‏\"‏ ‏.‏", "bengali": "", "english": "\"We were sitting in a gathering, and the Prophet (ﷺ) came with traces of water on his head. One of us said to him: 'We see that you are of good cheer today.' He said: 'Yes, praise is to Allah.' Then he spoke to the people about being rich. He said: 'There is nothing wrong with being rich for one who has piety, but good health for one who has piety is better than riches, and being of good cheer is a blessing.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  ایک کنواری لڑکی نبی اکرم صلی اللہ علیہ وسلم کے پاس آ", "grades": "", "reference": "", "international_number": "1875", "narrator_chain": "It was narrated from Mu'adh bin 'Abdullah bin Khubaib, from his father, that his paternal uncle said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1876", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، عَنْ عُمَارَةَ بْنِ غَزِيَّةَ، عَنْ رَبِيعَةَ بْنِ أَبِي عَبْدِ الرَّحْمَنِ، عَنْ عَبْدِ الْمَلِكِ بْنِ سَعِيدٍ الأَنْصَارِيِّ، عَنْ أَبِي حُمَيْدٍ السَّاعِدِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَجْمِلُوا فِي طَلَبِ الدُّنْيَا فَإِنَّ كُلاًّ مُيَسَّرٌ لِمَا خُلِقَ لَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Be moderate in seeking worldly things, for everyone will be facilitated for which he was created.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Humaid As-Sa'idi that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1877", "arabic": "حَدَّثَنَا إِسْمَاعِيلُ بْنُ بَهْرَامَ، حَدَّثَنَا الْحَسَنُ بْنُ مُحَمَّدِ بْنِ عُثْمَانَ، زَوْجُ بِنْتِ الشَّعْبِيِّ حَدَّثَنَا سُفْيَانُ، عَنِ الأَعْمَشِ، عَنْ يَزِيدَ الرَّقَاشِيِّ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَعْظَمُ النَّاسِ هَمًّا الْمُؤْمِنُ الَّذِي يَهُمُّ بِأَمْرِ دُنْيَاهُ وَأَمْرِ آخِرَتِهِ ‏\"\"‏ ‏.‏ قَالَ أَبُو عَبْدِ اللَّهِ هَذَا حَدِيثٌ غَرِيبٌ تَفَرَّدَ بِهِ إِسْمَاعِيلُ ‏.‏\"", "bengali": "", "english": "The one who has the most concerns is the believer who is concerned about both his worldly affairs and his Hereafter.\"' (Da'if)Abu 'Abdullah said: \"This Hadith is Gharib' Isma'il, alone, has narrated it.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1878", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، عَنِ ابْنِ جُرَيْجٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَيُّهَا النَّاسُ اتَّقُوا اللَّهَ وَأَجْمِلُوا فِي الطَّلَبِ فَإِنَّ نَفْسًا لَنْ تَمُوتَ حَتَّى تَسْتَوْفِيَ رِزْقَهَا وَإِنْ أَبْطَأَ عَنْهَا فَاتَّقُوا اللَّهَ وَأَجْمِلُوا فِي الطَّلَبِ خُذُوا مَا حَلَّ وَدَعُوا مَا حَرُمَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"O people, fear Allah and be moderate in seeking a living, for no soul will die until it has received all its provision, even if it is slow in coming. So fear Allah and be moderate in seeking provision; take that which is permissible and leave that which is forbidden. \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir bin 'Abdullah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1879", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ شَقِيقٍ، عَنْ قَيْسِ بْنِ أَبِي غَرَزَةَ، قَالَ كُنَّا نُسَمَّى فِي عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ السَّمَاسِرَةَ فَمَرَّ بِنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَسَمَّانَا بِاسْمٍ هُوَ أَحْسَنُ مِنْهُ فَقَالَ ‏ ‏ يَا مَعْشَرَ التُّجَّارِ إِنَّ الْبَيْعَ يَحْضُرُهُ الْحَلِفُ وَاللَّغْوُ فَشُوبُوهُ بِالصَّدَقَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"At the time of the Messenger of Allah (ﷺ) we used to be called brokers, but the Messenger of Allah (ﷺ) passed by us and called by a name that was better than that. He said: 'O merchants, selling involves (false) oaths and idle talk, so mix some charity with it.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Qais bin Abu Gharazah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1880", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا يَحْيَى بْنُ سُلَيْمٍ الطَّائِفِيُّ، عَنْ عَبْدِ اللَّهِ بْنِ عُثْمَانَ بْنِ خُثَيْمٍ، عَنْ إِسْمَاعِيلَ بْنِ عُبَيْدِ بْنِ رِفَاعَةَ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، رِفَاعَةَ قَالَ خَرَجْنَا مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَإِذَا النَّاسُ يَتَبَايَعُونَ بُكْرَةً فَنَادَاهُمْ ‏\"‏ يَا مَعْشَرَ التُّجَّارِ ‏\"‏ ‏.‏ فَلَمَّا رَفَعُوا أَبْصَارَهُمْ وَمَدُّوا أَعْنَاقَهُمْ قَالَ ‏\"‏ إِنَّ التُّجَّارَ يُبْعَثُونَ يَوْمَ الْقِيَامَةِ فُجَّارًا إِلاَّ مَنِ اتَّقَى اللَّهَ وَبَرَّ وَصَدَقَ ‏\"‏ ‏.‏", "bengali": "", "english": "\"We went out with the Messenger of Allah (ﷺ)  and the people were trading early in the morning. He called them: 'O merchants!' and when they looked up and craned their necks, he said : 'The merchants will be raised on the Day of Resurrection as immoral people, apart from those who fear Allah and act righteously and speak the truth (i.e. those who are honest).\"'", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ اور ابن عباس رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  و", "grades": "", "reference": "", "international_number": "1880", "narrator_chain": "It was narrated from Isma'il bin 'Ubaid bin Rifa'ah, from his father, that his grandfather Rifa'ah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1881", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ، حَدَّثَنَا فَرْوَةُ أَبُو يُونُسَ، عَنْ هِلاَلِ بْنِ جُبَيْرٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ أَصَابَ مِنْ شَىْءٍ فَلْيَلْزَمْهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "'Whoever achieves at something, let him stick with It.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1882", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا أَبُو عَاصِمٍ، أَخْبَرَنِي أَبِي، عَنِ الزُّبَيْرِ بْنِ عُبَيْدٍ، عَنْ نَافِعٍ، قَالَ كُنْتُ أُجَهِّزُ إِلَى الشَّامِ وَإِلَى مِصْرَ فَجَهَّزْتُ إِلَى الْعِرَاقِ فَأَتَيْتُ عَائِشَةَ أُمَّ الْمُؤْمِنِينَ فَقُلْتُ لَهَا يَا أُمَّ الْمُؤْمِنِينَ كُنْتُ أُجَهِّزُ إِلَى الشَّامِ فَجَهَّزْتُ إِلَى الْعِرَاقِ ‏.‏ فَقَالَتْ لاَ تَفْعَلْ مَالَكَ وَلِمَتْجَرِكَ فَإِنِّي سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ إِذَا سَبَّبَ اللَّهُ لأَحَدِكُمْ رِزْقًا مِنْ وَجْهٍ فَلاَ يَدَعْهُ حَتَّى يَتَغَيَّرَ لَهُ أَوْ يَتَنَكَّرَ لَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "I used to send trade goods to Sham and Egypt, then I prepared to send trade goods to 'Iraq. I went to 'Aishah, the Mother of the Believers, and said to her: \" O Mother of the Believers I used to send trade goods to Sham and I am preparing to send trade goods to 'Iraq.\" She said: \"Do not do that. What is wrong with the way you have been doing it? I heard the Messenger of Allah (ﷺ) say: 'If Allah causes provision to come to one of you through a certain means, he should not leave it unless it changes or deteriorates.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Nafi' said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1883", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا عَمْرُو بْنُ يَحْيَى بْنِ سَعِيدٍ الْقُرَشِيُّ، عَنْ جَدِّهِ، سَعِيدِ بْنِ أَبِي أُحَيْحَةَ عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ مَا بَعَثَ اللَّهُ نَبِيًّا إِلاَّ رَاعِيَ غَنَمٍ ‏\"‏ ‏.‏ قَالَ لَهُ أَصْحَابُهُ وَأَنْتَ يَا رَسُولَ اللَّهِ ‏.‏ قَالَ ‏\"‏ وَأَنَا كُنْتُ أَرْعَاهَا لأَهْلِ مَكَّةَ بِالْقَرَارِيطِ ‏\"‏ ‏.‏ قَالَ سُوَيْدٌ يَعْنِي كُلُّ شَاةٍ بِقِيرَاطٍ ‏.‏", "bengali": "", "english": "\"Allah has not sent any Prophet but he was a shepherd.\" His Companions said to him: \"Even you, O Messenger of Allah?\" He said: \"Even me I used to tend the sheep of the people of Makkah for a few Qirats.\" (Sahih)(One of the narrators) Suwaid said: \" Meaning one Qirat for every sheep.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے شغار سے منع فرمایا ہے۔ او", "grades": "", "reference": "", "international_number": "1883", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1884", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الْخُزَاعِيُّ، وَالْحَجَّاجُ، وَالْهَيْثَمُ بْنُ جَمِيلٍ، قَالُوا حَدَّثَنَا حَمَّادٌ، عَنْ ثَابِتٍ، عَنْ أَبِي رَافِعٍ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ كَانَ زَكَرِيَّا نَجَّارًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Zakariyya was a carpenter.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1885", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، حَدَّثَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ نَافِعٍ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّ أَصْحَابَ الصُّوَرِ يُعَذَّبُونَ يَوْمَ الْقِيَامَةِ يُقَالُ لَهُمْ أَحْيُوا مَا خَلَقْتُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The image-makers will be punished on the Day of Resurrection and will be told: 'Give life to that which you have created.' \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Aishah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1886", "arabic": "حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا عُمَرُ بْنُ هَارُونَ، عَنْ هَمَّامٍ، عَنْ فَرْقَدٍ السَّبَخِيِّ، عَنْ يَزِيدَ بْنِ عَبْدِ اللَّهِ بْنِ الشِّخِّيرِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَكْذَبُ النَّاسِ الصَّبَّاغُونَ وَالصَّوَّاغُونَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The most dishonest of people are the dyers and the goldsmiths. \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1887", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا أَبُو أَحْمَدَ، حَدَّثَنَا إِسْرَائِيلُ، عَنْ عَلِيِّ بْنِ سَالِمِ بْنِ ثَوْبَانَ، عَنْ عَلِيِّ بْنِ زَيْدِ بْنِ جُدْعَانَ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْجَالِبُ مَرْزُوقٌ وَالْمُحْتَكِرُ مَلْعُونٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The importer is blessed with provision and the hoarder is cursed.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Umar bin Khattab that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1888", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ مُحَمَّدِ بْنِ إِبْرَاهِيمَ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ مَعْمَرِ بْنِ عَبْدِ اللَّهِ بْنِ نَضْلَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ يَحْتَكِرُ إِلاَّ خَاطِئٌ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"No one hoards but a sinner.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ma'mar bin 'Abdullah bin Nadlah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1889", "arabic": "حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، حَدَّثَنَا أَبُو بَكْرٍ الْحَنَفِيُّ، حَدَّثَنَا الْهَيْثَمُ بْنُ رَافِعٍ، حَدَّثَنِي أَبُو يَحْيَى الْمَكِّيُّ، عَنْ فَرُّوخَ، مَوْلَى عُثْمَانَ بْنِ عَفَّانَ عَنْ عُمَرَ بْنِ الْخَطَّابِ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَنِ احْتَكَرَ عَلَى الْمُسْلِمِينَ طَعَامَهُمْ ضَرَبَهُ اللَّهُ بِالْجُذَامِ وَالإِفْلاَسِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I heard the Messenger of Allah (ﷺ) say: 'Whoever hoards food (and keeps it from) the Muslims, Allah will afflict him with leprosy and bankruptcy.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that 'Umar bin Khattab said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1890", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنَا الأَعْمَشُ، عَنْ جَعْفَرِ بْنِ إِيَاسٍ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ بَعَثَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ثَلاَثِينَ رَاكِبًا فِي سَرِيَّةٍ فَنَزَلْنَا بِقَوْمٍ فَسَأَلْنَاهُمْ أَنْ يَقْرُونَا فَأَبَوْا فَلُدِغَ سَيِّدُهُمْ فَأَتَوْنَا فَقَالُوا أَفِيكُمْ أَحَدٌ يَرْقِي مِنَ الْعَقْرَبِ فَقُلْتُ نَعَمْ أَنَا وَلَكِنْ لاَ أَرْقِيهِ حَتَّى تُعْطُونَا غَنَمًا ‏.‏ قَالُوا فَإِنَّا نُعْطِيكُمْ ثَلاَثِينَ شَاةً ‏.‏ فَقَبِلْنَاهَا فَقَرَأْتُ عَلَيْهِ ‏(‏ الْحَمْدُ ‏)‏ سَبْعَ مَرَّاتٍ فَبَرِئَ وَقَبَضْنَا الْغَنَمَ فَعَرَضَ فِي أَنْفُسِنَا مِنْهَا شَىْءٌ فَقُلْنَا لاَ تَعْجَلُوا حَتَّى نَأْتِيَ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَلَمَّا قَدِمْنَا ذَكَرْتُ لَهُ الَّذِي صَنَعْتُ فَقَالَ ‏ ‏ أَوَ مَا عَلِمْتَ أَنَّهَا رُقْيَةٌ اقْتَسِمُوهَا وَاضْرِبُوا لِي مَعَكُمْ سَهْمًا ‏\"\"‏ ‏.‏ حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا هُشَيْمٌ، حَدَّثَنَا أَبُو بِشْرٍ، عَنْ أَبِي الْمُتَوَكِّلِ، عَنْ أَبِي سَعِيدٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ بِنَحْوِهِ ح وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي بِشْرٍ، عَنْ أَبِي الْمُتَوَكِّلِ، عَنْ أَبِي سَعِيدٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ بِنَحْوِهِ ‏.‏ قَالَ أَبُو عَبْدِ اللَّهِ وَالصَّوَابُ هُوَ أَبُو الْمُتَوَكِّلِ إِنْ شَاءَ اللَّهُ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) sent us, thirty horsemen, on a military campaign. We camped near some people and asked them for hospitality but they refused. Then their leader was stung by a scorpion and they said: 'Is there anyone among you who can recite Ruqyah for a scorpion sting?' I said: 'Yes, I can, but I will not recite Ruqyah for him until you give us some sheep.' They said: 'We will give you thirty sheep.' So we accepted them, and I recited Al-Hamd (i.e. Al-Fatihah) over him seven times. Then he recovered, and I took the sheep. Then some doubts occurred within ourselves. Then we said: 'Let us not hasten (to make a decision concerning the sheep) until we come to the Prophet (ﷺ)' So when we came back: 'I told him what I had done. He said: 'How did you know that it is a Ruqyah? Divide them up and give me a share as well.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Sa'eed Al-Khudri said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1891", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَمُحَمَّدُ بْنُ إِسْمَاعِيلَ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا مُغِيرَةُ بْنُ زِيَادٍ الْمَوْصِلِيُّ، عَنْ عُبَادَةَ بْنِ نُسَىٍّ، عَنِ الأَسْوَدِ بْنِ ثَعْلَبَةَ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، قَالَ عَلَّمْتُ نَاسًا مِنْ أَهْلِ الصُّفَّةِ الْقُرْآنَ وَالْكِتَابَةَ فَأَهْدَى إِلَىَّ رَجُلٌ مِنْهُمْ قَوْسًا فَقُلْتُ لَيْسَتْ بِمَالٍ وَأَرْمِي عَنْهَا فِي سَبِيلِ اللَّهِ فَسَأَلْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْهَا فَقَالَ ‏ ‏ إِنْ سَرَّكَ أَنْ تُطَوَّقَ بِهَا طَوْقًا مِنْ نَارٍ فَاقْبَلْهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I taught people from Ahtus-Suffah\" Qur'an and how to write, and one of them gave me a bow. I said: 'It is not money, and I can shoot (with it) for the sake of Allah., I asked the Messenger of Allah (ﷺ) about it and he said: 'If it would please you to have a necklace of fire placed around your neck, then accept it.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that 'Ubadah bin Samit said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1892", "arabic": "حَدَّثَنَا سَهْلُ بْنُ أَبِي سَهْلٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، عَنْ ثَوْرِ بْنِ يَزِيدَ، حَدَّثَنَا خَالِدُ بْنُ مَعْدَانَ، حَدَّثَنِي عَبْدُ الرَّحْمَنِ بْنُ سَلْمٍ، عَنْ عَطِيَّةَ الْكَلاَعِيِّ، عَنْ أُبَىِّ بْنِ كَعْبٍ، قَالَ عَلَّمْتُ رَجُلاً الْقُرْآنَ فَأَهْدَى إِلَىَّ قَوْسًا فَذَكَرْتُ ذَلِكَ لِرَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ ‏ ‏ إِنْ أَخَذْتَهَا أَخَذْتَ قَوْسًا مِنْ نَارٍ ‏\"\"‏ ‏.‏ فَرَدَدْتُهَا ‏.‏\"", "bengali": "", "english": "\"I taught a man the Qur'an, and he gave me a bow. I mentioned that to the Messenger of Allah (ﷺ) and he said: 'If you accept it you will be accepting a bow of fire.' So I returned it.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Ubayy bin Ka'b said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1893", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ أَبِي بَكْرِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي مَسْعُودٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى عَنْ ثَمَنِ الْكَلْبِ وَمَهْرِ الْبَغِيِّ وَحُلْوَانِ الْكَاهِنِ ‏.‏", "bengali": "", "english": "the Prophet (ﷺ) forbade the price of a dog, the payment (given to a prostitute) and the payment made to a soothsayer.", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے  ( خطبہ میں )  فرمایا:", "grades": "", "reference": "", "international_number": "1893", "narrator_chain": "It was narrated from Abu Mas'ud that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1894", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَمُحَمَّدُ بْنُ طَرِيفٍ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، حَدَّثَنَا الأَعْمَشُ، عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ ثَمَنِ الْكَلْبِ وَعَسْبِ الْفَحْلِ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) forbade the price of a dog and studding a stallion.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو بھی اہم کام اللہ کی ح", "grades": "", "reference": "", "international_number": "1894", "narrator_chain": "It was narrated that Abu Hurairah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1895", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْوَلِيدُ، أَنْبَأَنَا ابْنُ لَهِيعَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ ثَمَنِ السِّنَّوْرِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) forbade the price of a cat.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اس نکاح کا اعلا", "grades": "", "reference": "", "international_number": "1895", "narrator_chain": "lt was narrated from Abu Az-Zubair that Jabir said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1896", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ ابْنِ طَاوُسٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ احْتَجَمَ وَأَعْطَاهُ أَجْرَهُ ‏.‏ قَالَ ابْنُ مَاجَهْ تَفَرَّدَ بِهِ ابْنُ أَبِي عُمَرَ وَحْدَهُ ‏.‏", "bengali": "", "english": "the Prophet (ﷺ) was treated with cupping and he gave him (the cupper) his wages. (Sahih)Ibn Abu 'Umar was alone in narrating it. That was said by Ibn Majah. ", "french": "", "indonesian": "", "russian": "", "urdu": "محمد بن حاطب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  حلال اور حرام میں فر", "grades": "", "reference": "", "international_number": "1896", "narrator_chain": "It was narrated from Ibn 'Abbas that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1897", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عَلِيٍّ أَبُو حَفْصٍ الصَّيْرَفِيُّ، حَدَّثَنَا أَبُو دَاوُدَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ عَبَادَةَ الْوَاسِطِيُّ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، قَالاَ حَدَّثَنَا وَرْقَاءُ، عَنْ عَبْدِ الأَعْلَى، عَنْ أَبِي جَمِيلَةَ عَنْ عَلِيٍّ، قَالَ احْتَجَمَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ وَأَمَرَنِي فَأَعْطَيْتُ الْحَجَّامَ أَجْرَهُ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) was treated with cupping and he told me to give the cupper his wages.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوالحسین خالد مدنی کہتے ہیں کہ  ہم عاشورہ کے دن مدینہ میں تھے، لڑکیاں دف بجا رہی تھیں اور گا رہی تھ", "grades": "", "reference": "", "international_number": "1897", "narrator_chain": "It was narrated that 'Ali said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1898", "arabic": "حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ بَيَانٍ الْوَاسِطِيُّ، حَدَّثَنَا خَالِدُ بْنُ عَبْدِ اللَّهِ، عَنْ يُونُسَ، عَنِ ابْنِ سِيرِينَ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ احْتَجَمَ وَأَعْطَى الْحَجَّامَ أَجْرَهُ ‏.‏", "bengali": "", "english": "the Prophet (ﷺ) was treated with cupping and gave the cupper his wages.", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ابوبکر رضی اللہ عنہ میرے پاس آئے، اس وقت میرے پاس انصا", "grades": "", "reference": "", "international_number": "1898", "narrator_chain": "It was narrated from Anas bin Malik that:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1899", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا يَحْيَى بْنُ حَمْزَةَ، حَدَّثَنِي الأَوْزَاعِيُّ، عَنِ الزُّهْرِيِّ، عَنْ أَبِي بَكْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ هِشَامٍ، عَنْ أَبِي مَسْعُودٍ، عُقْبَةَ بْنِ عَمْرٍو قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ كَسْبِ الْحَجَّامِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ), forbade the earnings of a cupper.\"", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم مدینہ کے ایک راستہ سے گزرے تو د", "grades": "", "reference": "", "international_number": "1899", "narrator_chain": "It was narrated that Abu Mas'ud, 'Uqbah bin 'Amr, said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1900", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا شَبَابَةُ بْنُ سَوَّارٍ، عَنِ ابْنِ أَبِي ذِئْبٍ، عَنِ الزُّهْرِيِّ، عَنْ حَرَامِ بْنِ مُحَيِّصَةَ، عَنْ أَبِيهِ، أَنَّهُ سَأَلَ النَّبِيَّ ـ صلى الله عليه وسلم ـ عَنْ كَسْبِ الْحَجَّامِ فَنَهَاهُ عَنْهُ فَذَكَرَ لَهُ الْحَاجَةَ فَقَالَ ‏ ‏ اعْلِفْهُ نَوَاضِحَكَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "his father asked the Prophet (ﷺ) about the earnings of a cupper and he forbade him from that. Then he mentioned his need and he said: \"Spend it on feeding your she-camels that draw water.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from  Haram bin Munayyisah that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1901", "arabic": "حَدَّثَنَا عِيسَى بْنُ حَمَّادٍ الْمِصْرِيُّ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، أَنَّهُ قَالَ قَالَ عَطَاءُ بْنُ أَبِي رَبَاحٍ سَمِعْتُ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَامَ الْفَتْحِ وَهُوَ بِمَكَّةَ ‏\"‏ إِنَّ اللَّهَ وَرَسُولَهُ حَرَّمَ بَيْعَ الْخَمْرِ وَالْمَيْتَةِ وَالْخِنْزِيرِ وَالأَصْنَامِ ‏\"‏ ‏.‏ فَقِيلَ لَهُ عِنْدَ ذَلِكَ يَا رَسُولَ اللَّهِ أَرَأَيْتَ شُحُومَ الْمَيْتَةِ فَإِنَّهُ يُدْهَنُ بِهَا السُّفُنُ وَيُدْهَنُ بِهَا الْجُلُودُ وَيَسْتَصْبِحُ بِهَا النَّاسُ قَالَ ‏\"‏ لاَ هُنَّ حَرَامٌ ‏\"‏ ‏.‏ ثُمَّ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ قَاتَلَ اللَّهُ الْيَهُودَ إِنَّ اللَّهَ حَرَّمَ عَلَيْهِمُ الشُّحُومَ فَأَجْمَلُوهُ ثُمَّ بَاعُوهُ فَأَكَلُوا ثَمَنَهُ ‏\"‏ ‏.‏", "bengali": "", "english": "I heard Jabir bin 'Abdullah say: \"In the Year of the Conquest, while he was in Makkah the Messenger of Allah (ﷺ), said: 'Allah and His Messenger have forbidden the sale of wines, meat of dead animals, pigs and 'idols.' It was said to him: 'O Messenger of Allah, what do you think of the fat of dead animals, for it is used to caulk ships, it is daubed on animal skins and people use it to light their lamps?' He said: 'No, it is unlawful.' Then the Messenger of Allah (ﷺ) said: 'May Allah curse the jews, for Allah forbade them the fat (of animals) but they rendered it, (i.e. melted it) sold it and consumed its price.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "مجاہد کہتے ہیں کہ  میں ابن عمر رضی اللہ عنہما کے ساتھ تھا انہوں نے طبلہ کی آواز سنی تو اپنی دونوں ا", "grades": "", "reference": "", "international_number": "1901", "narrator_chain": "Ata' bin Abu Rabah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1902", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدِ بْنِ يَحْيَى بْنِ سَعِيدٍ الْقَطَّانُ، حَدَّثَنَا هَاشِمُ بْنُ الْقَاسِمِ، حَدَّثَنَا أَبُو جَعْفَرٍ الرَّازِيُّ، عَنْ عَاصِمٍ، عَنْ أَبِي الْمُهَلَّبِ، عَنْ عُبَيْدِ اللَّهِ الإِفْرِيقِيِّ، عَنْ أَبِي أُمَامَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ بَيْعِ الْمُغَنِّيَاتِ وَعَنْ شِرَائِهِنَّ وَعَنْ كَسْبِهِنَّ وَعَنْ أَكْلِ أَثْمَانِهِنَّ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah, forbade selling or buying singing girls, and their wages, and consuming their price.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین ام سلمہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم ان کے پاس آئے، وہاں ا", "grades": "", "reference": "", "international_number": "1902", "narrator_chain": "It was narrated that Abu Umamah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1903", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، وَأَبُو أُسَامَةَ عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ خُبَيْبِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ حَفْصِ بْنِ عَاصِمٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ بَيْعَتَيْنِ عَنِ الْمُلاَمَسَةِ وَالْمُنَابَذَةِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) forbade two kinds of transactions: Mulimasah and Mundbadhah.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اس عورت پر لعنت کی جو مردوں کی", "grades": "", "reference": "", "international_number": "1903", "narrator_chain": "It was narrated that Abu Hurairah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1904", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَسَهْلُ بْنُ أَبِي سَهْلٍ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عَطَاءِ بْنِ يَزِيدَ اللَّيْثِيِّ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ نَهَى عَنِ الْمُلاَمَسَةِ وَالْمُنَابَذَةِ ‏.‏ زَادَ سَهْلٌ قَالَ سُفْيَانُ الْمُلاَمَسَةُ أَنْ يَلْمِسَ الرَّجُلُ الشَّىْءَ بِيَدِهِ وَلاَ يَرَاهُ وَالْمُنَابَذَةُ أَنْ يَقُولَ أَلْقِ إِلَىَّ مَا مَعَكَ وَأُلْقِي إِلَيْكَ مَا مَعِي ‏.‏", "bengali": "", "english": "the Messenger of Allah (ﷺ) forbade Mulamasah and Munabadhah. (Sahih) Sahl added: \"Sufyan said: 'Mulamasah means when a man touches something with his hand without seeing it, and Munabadhah means when he says: \"Toss me what you have, and I will toss you what have.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے عورتوں کی مشابہت اختیا", "grades": "", "reference": "", "international_number": "1904", "narrator_chain": "It was narrated from Abu Sa'eed Al-Khudri that  :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1905", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ يَبِيعُ بَعْضُكُمْ عَلَى بَيْعِ بَعْضٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Let one of you not undersell another.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1906", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ يَبِيعُ الرَّجُلُ عَلَى بَيْعِ أَخِيهِ وَلاَ يَسُومُ عَلَى سَوْمِ أَخِيهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"A man is not to undersell his brother, nor is he to fry to outhaggle his brother.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "lt was narrated from Abu Hurairah that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1907", "arabic": "قَرَأْتُ عَلَى مُصْعَبِ بْنِ عَبْدِ اللَّهِ الزُّبَيْرِيِّ عَنْ مَالِكٍ، ح وَحَدَّثَنَا أَبُو حُذَافَةَ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى عَنِ النَّجْشِ ‏.‏", "bengali": "", "english": "the Prophet (ﷺ) forbade the Najsh.", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے عبدالرحمٰن بن عوف رضی اللہ ع", "grades": "", "reference": "", "international_number": "1907", "narrator_chain": "It was narrated from Ibn 'Umar that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1908", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَسَهْلُ بْنُ أَبِي سَهْلٍ، قَالاَ حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ تَنَاجَشُوا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Do not practice Najsh.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Prophet said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1909", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ يَبِيعُ حَاضِرٌ لِبَادٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"A City-dweller should not sell for a Bedouin.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1910", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ يَبِيعُ حَاضِرٌ لِبَادٍ دَعُوا النَّاسَ يَرْزُقُ اللَّهُ بَعْضَهُمْ مِنْ بَعْضٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"A city-dweller should not sell for a Bedouin. Leave people to (engage in trade) and Allah will grant them provision through one another.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir bin 'Abdullah that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1911", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ الْعَنْبَرِيُّ، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا مَعْمَرٌ، عَنِ ابْنِ طَاوُسٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ يَبِيعَ حَاضِرٌ لِبَادٍ ‏.‏ قُلْتُ لاِبْنِ عَبَّاسٍ مَا قَوْلُهُ حَاضِرٌ لِبَادٍ قَالَ لاَ يَكُونُ لَهُ سِمْسَارًا ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) forbade a city-dweller to sell for a Bedouin.\" (Sahih)I (Tawus) said to Ibn 'Abbas: \"What is meant by the words: 'A city-dweller selling for a Bedouin?' He said: \"He should not be a broker for him.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ اور ام المؤمنین ام سلمہ رضی اللہ عنہما کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ن", "grades": "", "reference": "", "international_number": "1911", "narrator_chain": "Ibn Tawus narrated from his father that Ibn 'Abbas said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1912", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا أَبُو أُسَامَةَ، عَنِ هِشَامِ بْنِ حَسَّانَ، عَنْ مُحَمَّدِ بْنِ سِيرِينَ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ تَلَقَّوُا الأَجْلاَبَ فَمَنْ تَلَقَّى مِنْهُ شَيْئًا فَاشْتَرَى فَصَاحِبُهُ بِالْخِيَارِ إِذَا أَتَى السُّوقَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Do not meet the traders on the way, and whoever meets any of them and buys from him, the vendor has the choice of annulling the transaction when he comes to the marketplace.''", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1913", "arabic": "حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ تَلَقِّي الْجَلَبِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) forbade meeting traders on the way.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  سب سے برا کھانا اس ولیمہ کا کھانا ہے جس میں مالداروں کو بلایا جائ", "grades": "", "reference": "", "international_number": "1913", "narrator_chain": "It was narrated that Ibn 'Umar said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1914", "arabic": "حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، وَحَمَّادُ بْنُ مَسْعَدَةَ، عَنْ سُلَيْمَانَ التَّيْمِيِّ، ح وَحَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ بْنِ حَبِيبِ بْنِ الشَّهِيدِ، حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَيْمَانَ، قَالَ سَمِعْتُ أَبِي قَالَ، حَدَّثَنَا أَبُو عُثْمَانَ النَّهْدِيُّ، عَنْ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ تَلَقِّي الْبُيُوعِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) forbade. meeting the owners of goods (away from the market).\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے", "grades": "", "reference": "", "international_number": "1914", "narrator_chain": "It was narrated that 'Abdullah bin Mas'ud said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1915", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ الْمِصْرِيُّ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِذَا تَبَايَعَ الرَّجُلاَنِ فَكُلُّ وَاحِدٍ مِنْهُمَا بِالْخِيَارِ مَا لَمْ يَتَفَرَّقَا وَكَانَا جَمِيعًا أَوْ يُخَيِّرْ أَحَدُهُمَا الآخَرَ فَإِنْ خَيَّرَ أَحَدُهُمَا الآخَرَ فَتَبَايَعَا عَلَى ذَلِكَ فَقَدْ وَجَبَ الْبَيْعُ ‏.‏ وَإِنْ تَفَرَّقَا بَعْدَ أَنْ تَبَايَعَا وَلَمْ يَتْرُكْ وَاحِدٌ مِنْهُمَا الْبَيْعَ فَقَدْ وَجَبَ الْبَيْعُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"When two men enter into a transaction, each of them has the choice (of annulling it) so long as they have not yet parted and are still together, or one of them has given the option or choice to the other. Once he has accepted the terms of the other, then the transaction is binding. If they part after concluding the transaction and neither of them has rescinded the transaction then the transaction is binding.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Abdullah bin 'Umar that the Messenger of Allah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1916", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، وَأَحْمَدُ بْنُ الْمِقْدَامِ، قَالاَ حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ جَمِيلِ بْنِ مُرَّةَ، عَنْ أَبِي الْوَضِيءِ، عَنْ أَبِي بَرْزَةَ الأَسْلَمِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْبَيِّعَانِ بِالْخِيَارِ مَا لَمْ يَتَفَرَّقَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "”The two parties to a transaction have the choice (of annulling it) so long as they have not yet parted.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Barzah Al-Aslami that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1917", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، وَإِسْحَاقُ بْنُ مَنْصُورٍ، قَالاَ حَدَّثَنَا عَبْدُ الصَّمَدِ، حَدَّثَنَا شُعْبَةُ، عَنْ قَتَادَةَ، عَنِ الْحَسَنِ، عَنْ سَمُرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْبَيِّعَانِ بِالْخِيَارِ مَا لَمْ يَتَفَرَّقَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The two parties to a transaction have the choice (of annulling it) so long as they have not yet parted. \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Samurah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1918", "arabic": "حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، وَأَحْمَدُ بْنُ عِيسَى الْمِصْرِيَّانِ، قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي ابْنُ جُرَيْجٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ اشْتَرَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ مِنْ رَجُلٍ مِنَ الأَعْرَابِ حِمْلَ خَبَطٍ فَلَمَّا وَجَبَ الْبَيْعُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اخْتَرْ ‏\"\"‏ ‏.‏ فَقَالَ الأَعْرَابِيُّ عَمْرَكَ اللَّهَ بَيِّعًا ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) bought a load of fodder from a Bedouin man. When the transaction was concluded, the Messenger of Allah (ﷺ) said: 'Choose (either to go ahead or to cancel the transaction).' The Bedouin said: 'May Allah grant you a long life of good transaction!\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Jabir bin' Abdullah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1919", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ، حَدَّثَنَا مَرْوَانُ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ دَاوُدَ بْنِ صَالِحٍ الْمَدَنِيِّ، عَنْ أَبِيهِ، قَالَ سَمِعْتُ أَبَا سَعِيدٍ الْخُدْرِيَّ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّمَا الْبَيْعُ عَنْ تَرَاضٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "I heard Abu Sa'eed Al-Khudri say: \"The Messenger of Allah (ﷺ) said: 'Transactions may only be done by mutual consent.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Dawud bin Salih Al Madani that his father said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1920", "arabic": "حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا هُشَيْمٌ، أَنْبَأَنَا ابْنُ أَبِي لَيْلَى، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِيهِ، أَنَّ عَبْدَ اللَّهِ بْنَ مَسْعُودٍ، بَاعَ مِنَ الأَشْعَثِ بْنِ قَيْسٍ رَقِيقًا مِنْ رَقِيقِ الإِمَارَةِ فَاخْتَلَفَا فِي الثَّمَنِ ‏.‏ فَقَالَ ابْنُ مَسْعُودٍ بِعْتُكَ بِعِشْرِينَ أَلْفًا ‏.‏ وَقَالَ الأَشْعَثُ بْنُ قَيْسٍ إِنَّمَا اشْتَرَيْتُ مِنْكَ بِعَشْرَةِ آلاَفٍ ‏.‏ فَقَالَ عَبْدُ اللَّهِ إِنْ شِئْتَ حَدَّثْتُكَ بِحَدِيثٍ سَمِعْتُهُ مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ فَقَالَ هَاتِهِ ‏.‏ قَالَ فَإِنِّي سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ إِذَا اخْتَلَفَ الْبَيِّعَانِ وَلَيْسَ بَيْنَهُمَا بَيِّنَةٌ وَالْبَيْعُ قَائِمٌ بِعَيْنِهِ فَالْقَوْلُ مَا قَالَ الْبَائِعُ أَوْ يَتَرَادَّانِ الْبَيْعَ ‏\"\"‏ ‏.‏ قَالَ فَإِنِّي أَرَى أَنْ أَرُدَّ الْبَيْعَ ‏.‏ فَرَدَّهُ ‏.‏\"", "bengali": "", "english": "Abdullah bin Mas'ud sold one of the slaves from the state to Ash'ath bin Qais, and they differed concerning the price. Ibn Mas'ud said: \"I sold him to you for twenty thousand,' but Ash'ath bin Qais said: \"I bought him from you for ten thousand.\" 'Abdullah said: \"If you want, I will tell you a Hadith which I heard from the Messenger of Allah (ﷺ)\" He said: \"Tell me it.\" He said: \"I heard the Messenger of Allah (ﷺ) say: 'If two parties to a transaction differ, and they have no proof, and the sale item remains (unredeemed), then what the seller says is valid. Or they may cancel the transaction.\" He said: \"I want to cancel the transaction.\" And he cancelled it.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Qasim bin 'Abdur Rahman from his father that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1921", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي بِشْرٍ، قَالَ سَمِعْتُ يُوسُفَ بْنَ مَاهَكَ، يُحَدِّثُ عَنْ حَكِيمِ بْنِ حِزَامٍ، قَالَ قُلْتُ يَا رَسُولَ اللَّهِ الرَّجُلُ يَسْأَلُنِي الْبَيْعَ وَلَيْسَ عِنْدِي أَفَأَبِيعُهُ قَالَ ‏ ‏ لاَ تَبِعْ مَا لَيْسَ عِنْدَكَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I said: 'O Messenger of Allah, a man is asking me to sell him something that I do not possess; Shall I sell it to him?' He said: 'Do not sell what is not with you.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Hakim bin Hizam said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1922", "arabic": "حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ، قَالَ حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، ح وَحَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، قَالاَ حَدَّثَنَا أَيُّوبُ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ يَحِلُّ بَيْعُ مَا لَيْسَ عِنْدَكَ وَلاَ رِبْحُ مَا لَمْ يُضْمَنْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) said: 'It is not permissible to sell something that is not with you, nor to profit from what  you do not possess.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Amr bin Shu'aib, from his father, that his grandfather said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1923", "arabic": "حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ الْفُضَيْلِ، عَنْ لَيْثٍ، عَنْ عَطَاءٍ، عَنْ عَتَّابِ بْنِ أَسِيدٍ، قَالَ لَمَّا بَعَثَهُ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ إِلَى مَكَّةَ نَهَاهُ عَنْ شِفِّ مَا لَمْ يُضْمَنْ ‏.‏", "bengali": "", "english": "when the Messenger of Allah (ﷺ) sent him to Makkah, he forbade him from profiting off of what he did not possess.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ اس شخص کی طرف", "grades": "", "reference": "", "international_number": "1923", "narrator_chain": "It was narrated from 'Ata that 'Attab bin Asid said that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1924", "arabic": "حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، حَدَّثَنَا سَعِيدٌ، عَنْ قَتَادَةَ، عَنِ الْحَسَنِ، عَنْ عُقْبَةَ بْنِ عَامِرٍ، أَوْ سَمُرَةَ بْنِ جُنْدُبٍ عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ أَيُّمَا رَجُلٍ بَاعَ بَيْعًا مِنْ رَجُلَيْنِ فَهُوَ لِلأَوَّلِ مِنْهُمَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Any man who sells to two men, it is for the one who was first.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Uqbah bin 'Amir or Samurah bin Jundab that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1925", "arabic": "حَدَّثَنَا الْحُسَيْنُ بْنُ أَبِي السَّرِيِّ الْعَسْقَلاَنِيُّ، وَمُحَمَّدُ بْنُ إِسْمَاعِيلَ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سَعِيدُ بْنُ بَشِيرٍ، عَنْ قَتَادَةَ، عَنِ الْحَسَنِ، عَنْ سَمُرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا بَاعَ الْمُجِيزَانِ فَهُوَ لِلأَوَّلِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"If two (separate) authorized persons make a sale (of the same thing), then the first transaction is the one that is valid. \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Samurah that the Messenger of Allah (ﷺ), said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1926", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، قَالَ بَلَغَنِي عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى عَنْ بَيْعِ الْعُرْبَانِ ‏.‏", "bengali": "", "english": "the Prophet (ﷺ) forbade the deal involving earnest money .", "french": "", "indonesian": "", "russian": "", "urdu": "ابوسعید خدری رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم سے عزل کے بارے میں پو", "grades": "", "reference": "", "international_number": "1926", "narrator_chain": "It was narrated from 'Amr bin Shu'aib, from his father, from his grandfather that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1927", "arabic": "حَدَّثَنَا الْفَضْلُ بْنُ يَعْقُوبَ الرُّخَامِيُّ، حَدَّثَنَا حَبِيبُ بْنُ أَبِي حَبِيبٍ أَبُو مُحَمَّدٍ، كَاتِبُ مَالِكِ بْنِ أَنَسٍ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عَامِرٍ الأَسْلَمِيُّ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى عَنْ بَيْعِ الْعُرْبَانِ ‏.‏ قَالَ أَبُو عَبْدِ اللَّهِ الْعُرْبَانُ أَنْ يَشْتَرِيَ الرَّجُلُ دَابَّةً بِمِائَةِ دِينَارٍ فَيُعْطِيَهُ دِينَارَيْنِ أَرْبُونًا فَيَقُولَ إِنْ لَمْ أَشْتَرِ الدَّابَّةَ فَالدِّينَارَانِ لَكَ ‏.‏", "bengali": "", "english": "the Prophet (ﷺ) forbade the deal involving earnest money. (Hasan)Abu 'Abdullah said: Earnest money refers to when a man buys an animal for one hundred Dinar, then he gives the seller two Dinar in advance and says: \"If I do not buy the animal, then the two Dinar are yours.\"  And it was said that it refers, and Allah knows best, to when a man buys something, and gives the seller a Dirham or less or more, and says: \"If I take it (all well and good), and if I do not, then the Dirham is yours.\"", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں عزل کیا کرتے تھے، اور قر", "grades": "", "reference": "", "international_number": "1927", "narrator_chain": "It was narrated from 'Amr bin Shu'aib, from his father, from his grandfather that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1928", "arabic": "حَدَّثَنَا مُحْرِزُ بْنُ سَلَمَةَ الْعَدَنِيُّ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ أَبِي الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ بَيْعِ الْغَرَرِ وَعَنْ بَيْعِ الْحَصَاةِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) forbade Gharar transaction sand Hasah transactions. \"", "french": "", "indonesian": "", "russian": "", "urdu": "عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے آزاد عورت سے اس کی اجازت کے ب", "grades": "", "reference": "", "international_number": "1928", "narrator_chain": "It was narrated that Abu Hurairah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1929", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ، وَالْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ الْعَنْبَرِيُّ، قَالاَ حَدَّثَنَا الأَسْوَدُ بْنُ عَامِرٍ، حَدَّثَنَا أَيُّوبُ بْنُ عُتْبَةَ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ عَطَاءٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ بَيْعِ الْغَرَرِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) forbade Gharar transactions. \"", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  کوئی مرد اس عورت سے نکاح", "grades": "", "reference": "", "international_number": "1929", "narrator_chain": "It was narrated that Ibn 'Abbas said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1930", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيلَ، حَدَّثَنَا جَهْضَمُ بْنُ عَبْدِ اللَّهِ الْيَمَامِيُّ، عَنْ مُحَمَّدِ بْنِ إِبْرَاهِيمَ الْبَاهِلِيِّ، عَنْ مُحَمَّدِ بْنِ زَيْدٍ الْعَبْدِيِّ، عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ شِرَاءِ مَا فِي بُطُونِ الأَنْعَامِ حَتَّى تَضَعَ وَعَمَّا فِي ضُرُوعِهَا إِلاَّ بِكَيْلٍ وَعَنْ شِرَاءِ الْعَبْدِ وَهُوَ آبِقٌ وَعَنْ شِرَاءِ الْمَغَانِمِ حَتَّى تُقْسَمَ وَعَنْ شِرَاءِ الصَّدَقَاتِ حَتَّى تُقْبَضَ وَعَنْ ضَرْبَةِ الْغَائِصِ ‏.‏", "bengali": "", "english": "“The Messenger of Allah (ﷺ) forbade selling what is in the wombs of cattle until they give birth, and selling what is in their udders unless it is measured out, and selling a slave who has fled, and selling spoils of war until it has been distributed, and selling Sadaqah until it has been received, and what a diver is going to bring up.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو دو نکاحوں سے منع فرما", "grades": "", "reference": "", "international_number": "1930", "narrator_chain": "It was narrated that Abu Sa'eed Al-Khudri said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1931", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ، عَنْ أَيُّوبَ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى عَنْ بَيْعِ حَبَلِ الْحَبَلَةِ ‏.‏", "bengali": "", "english": "the Prophet (ﷺ) forbade selling Hablul-Habalah.", "french": "", "indonesian": "", "russian": "", "urdu": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  عورت سے اس کی پھوپ", "grades": "", "reference": "", "international_number": "1931", "narrator_chain": "It was narrated from Ibn 'Umar that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1932", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا عِيسَى بْنُ يُونُسَ، حَدَّثَنَا الأَخْضَرُ بْنُ عَجْلاَنَ، حَدَّثَنَا أَبُو بَكْرٍ الْحَنَفِيُّ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ رَجُلاً، مِنَ الأَنْصَارِ جَاءَ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ يَسْأَلُهُ فَقَالَ ‏\"‏ لَكَ فِي بَيْتِكَ شَىْءٌ ‏\"‏ ‏.‏ قَالَ بَلَى حِلْسٌ نَلْبَسُ بَعْضَهُ وَنَبْسُطُ بَعْضَهُ وَقَدَحٌ نَشْرَبُ فِيهِ الْمَاءَ ‏.‏ قَالَ ‏\"‏ ائْتِنِي بِهِمَا ‏\"‏ ‏.‏ قَالَ فَأَتَاهُ بِهِمَا فَأَخَذَهُمَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِيَدِهِ ثُمَّ قَالَ ‏\"‏ مَنْ يَشْتَرِي هَذَيْنِ ‏\"‏ ‏.‏ فَقَالَ رَجُلٌ أَنَا آخُذُهُمَا بِدِرْهَمٍ ‏.‏ قَالَ ‏\"‏ مَنْ يَزِيدُ عَلَى دِرْهَمٍ ‏\"‏ ‏.‏ مَرَّتَيْنِ أَوْ ثَلاَثًا قَالَ رَجُلٌ أَنَا آخُذُهُمَا بِدِرْهَمَيْنِ ‏.‏ فَأَعْطَاهُمَا إِيَّاهُ وَأَخَذَ الدِّرْهَمَيْنِ فَأَعْطَاهُمَا الأَنْصَارِيَّ وَقَالَ ‏\"‏ اشْتَرِ بِأَحَدِهِمَا طَعَامًا فَانْبِذْهُ إِلَى أَهْلِكَ وَاشْتَرِ بِالآخَرِ قَدُومًا فَأْتِنِي بِهِ ‏\"‏ ‏.‏ فَفَعَلَ فَأَخَذَهُ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَشَدَّ فِيهِ عُودًا بِيَدِهِ وَقَالَ ‏\"‏ اذْهَبْ فَاحْتَطِبْ وَلاَ أَرَاكَ خَمْسَةَ عَشَرَ يَوْمًا ‏\"‏ ‏.‏ فَجَعَلَ يَحْتَطِبُ وَيَبِيعُ فَجَاءَ وَقَدْ أَصَابَ عَشْرَةَ دَرَاهِمَ فَقَالَ ‏\"‏ اشْتَرِ بِبَعْضِهَا طَعَامًا وَبِبَعْضِهَا ثَوْبًا ‏\"‏ ‏.‏ ثُمَّ قَالَ ‏\"‏ هَذَا خَيْرٌ لَكَ مِنْ أَنْ تَجِيءَ وَالْمَسْأَلَةُ نُكْتَةٌ فِي وَجْهِكَ يَوْمَ الْقِيَامَةِ إِنَّ الْمَسْأَلَةَ لاَ تَصْلُحُ إِلاَّ لِذِي فَقْرٍ مُدْقِعٍ أَوْ لِذِي غُرْمٍ مُفْظِعٍ أَوْ دَمٍ مُوجِعٍ ‏\"‏ ‏.‏", "bengali": "", "english": "a man from among the Ansar came to the Prophet (ﷺ) and begged from him. He said, \"Do you have anything in your house?\" He said: \"Yes, a blanket, part of which we cover ourselves with and part we spread beneath us, and a bowl from which we drink water.\" He said: \"Givethem to me.\" So he brought them to him, and the Messenger of Allah (ﷺ) took them in his hand and said, \"Who will by these two things?\" A man said: \"I will by them for one Dirham.\" He said: \"Who will offer more than a Dirham?\" two or three times. A man said: \"I will buy them for two Dirham.\" So he gave them to him and took the two Dirham, which he gave to the Ansari and said: \"Buy food with one of them and give it to your family, and buy an axe with the other and bring it to me.\" So he did that, and the Messenger of Allah (ﷺ) took it and fixed a handle to it, and said: \"Go and gather firewood, and I do not want to see you for fifteen days.\" So he went and gathered firewood and sold it, then he came back, and he had earned ten Dirham. (The Prophet (ﷺ)) said: \"Buy food with some of it and clothes with some.\" Then he said: \"This is better for you than coming with begging (appearing)  as a spot on your face on the Day of Resurrection. Begging is only appropriate for one who is extremely poor or who is in severe debt, or one who must pay painful blood money.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رفاعہ قرظی کی بیوی  ( رضی اللہ عنہا )  نے رسول اللہ صلی", "grades": "", "reference": "", "international_number": "1932", "narrator_chain": "It was narrated from Anas bin Malik that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1933", "arabic": "حَدَّثَنَا زِيَادُ بْنُ يَحْيَى أَبُو الْخَطَّابِ، حَدَّثَنَا مَالِكُ بْنُ سُعَيْرٍ، حَدَّثَنَا الأَعْمَشُ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ أَقَالَ مُسْلِمًا أَقَالَهُ اللَّهُ عَثْرَتَهُ يَوْمَ الْقِيَامَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "Whoever agrees with a Muslim to cancel a transaction Allah will forgive his sins on the Day of Resurrection. \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1934", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا حَجَّاجٌ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ قَتَادَةَ، وَحُمَيْدٍ، وَثَابِتٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ غَلاَ السِّعْرُ عَلَى عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالُوا يَا رَسُولَ اللَّهِ قَدْ غَلاَ السِّعْرُ فَسَعِّرْ لَنَا ‏.‏ فَقَالَ ‏ ‏ إِنَّ اللَّهَ هُوَ الْمُسَعِّرُ الْقَابِضُ الْبَاسِطُ الرَّازِقُ إِنِّي لأَرْجُو أَنْ أَلْقَى رَبِّي وَلَيْسَ أَحَدٌ يَطْلُبُنِي بِمَظْلَمَةٍ فِي دَمٍ وَلاَ مَالٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Prices rose during the time of the Messenger of Allah (ﷺ), and they said: 'O Messenger of Allah, prices have risen, so fix the prices for us.' He said: 'Indeed Allah is the Musa'ir,  the Razzaq (Provider). And I am hopeful that I meet my Lord and none of you are seeking (recompense from) me for an injustice involving blood or wealth.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was nanated that Anas bin Malik said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1935", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ زِيَادٍ، حَدَّثَنَا عَبْدُ الأَعْلَى، حَدَّثَنَا سَعِيدٌ، عَنْ قَتَادَةَ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ، قَالَ غَلاَ السِّعْرُ عَلَى عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالُوا لَوْ قَوَّمْتَ يَا رَسُولَ اللَّهِ قَالَ ‏ ‏ إِنِّي لأَرْجُو أَنْ أُفَارِقَكُمْ وَلاَ يَطْلُبَنِي أَحَدٌ مِنْكُمْ بِمَظْلَمَةٍ ظَلَمْتُهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Prices rose at the time of the Messenger of Allah (ﷺ), and they said: 'Why do you not fix the food prices, O Messenger of Allah?' He said: 'I hope that when I leave you, no one among you will be demanding restitution for a wrong that I have done to him.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Sa'eed said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1936", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ أَبَانَ الْبَلْخِيُّ أَبُو بَكْرٍ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، عَنْ يُونُسَ بْنِ عُبَيْدٍ، عَنْ عَطَاءِ بْنِ فَرُّوخَ، قَالَ قَالَ عُثْمَانُ بْنُ عَفَّانَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَدْخَلَ اللَّهُ رَجُلاً الْجَنَّةَ كَانَ سَهْلاً بَائِعًا وَمُشْتَرِيًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“Allah will admit to Paradise a man who was lenient when he sold and when he bought. \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'Uthman bin 'Affan narrated that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1937", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، حَدَّثَنَا أَبِي، حَدَّثَنَا أَبُو غَسَّانَ، مُحَمَّدُ بْنُ مُطَرِّفٍ عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ رَحِمَ اللَّهُ عَبْدًا سَمْحًا إِذَا بَاعَ سَمْحًا إِذَا اشْتَرَى سَمْحًا إِذَا اقْتَضَى ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"May Allah have mercy on a person who is lenient when he sells, lenient when he buys, and lenient when he asks for payment. \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir bin 'Abdullah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1938", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا يَعْلَى بْنُ شَبِيبٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُثْمَانَ بْنِ خُثَيْمٍ، عَنْ قَيْلَةَ أُمِّ بَنِي أَنْمَارٍ، قَالَتْ أَتَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فِي بَعْضِ عُمَرِهِ عِنْدَ الْمَرْوَةِ فَقُلْتُ يَا رَسُولَ اللَّهِ إِنِّي امْرَأَةٌ أَبِيعُ وَأَشْتَرِي فَإِذَا أَرَدْتُ أَنْ أَبْتَاعَ الشَّىْءَ سُمْتُ بِهِ أَقَلَّ مِمَّا أُرِيدُ ثُمَّ زِدْتُ ثُمَّ زِدْتُ حَتَّى أَبْلُغَ الَّذِي أُرِيدُ وَإِذَا أَرَدْتُ أَنْ أَبِيعَ الشَّىْءَ سُمْتُ بِهِ أَكْثَرَ مِنَ الَّذِي أُرِيدُ ثُمَّ وَضَعْتُ حَتَّى أَبْلُغَ الَّذِي أُرِيدُ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ لاَ تَفْعَلِي يَا قَيْلَةُ إِذَا أَرَدْتِ أَنْ تَبْتَاعِي شَيْئًا فَاسْتَامِي بِهِ الَّذِي تُرِيدِينَ أُعْطِيتِ أَوْ مُنِعْتِ ‏\"‏ ‏.‏ وَقَالَ ‏\"‏ إِذَا أَرَدْتِ أَنْ تَبِيعِي شَيْئًا فَاسْتَامِي بِهِ الَّذِي تُرِيدِينَ أَعْطَيْتِ أَوْ مَنَعْتِ ‏\"‏ ‏.‏", "bengali": "", "english": "\"I came to the Messenger of Allah (ﷺ), during one of his 'Umrah at Marwah and said: 'O Messenger of Allah, I am a woman who buys and sells. When I want to buy something, I state a price less than I want to pay, then I raise it gradually until it reaches the price I want to pay. And when I want to sell something, I state a price more than I want, then I lower it until it reaches the price I want.' The Messenger of Allah (ﷺ) said: 'Do not do that, O Qailah. When you want to buy something, state the price you want, whether it is given or not. And when you want to sell something, state the price you want, whether it is given or not.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کو حمزہ بن عبدالمطلب رضی", "grades": "", "reference": "", "international_number": "1938", "narrator_chain": "It was narrated that Qailah Umm Bani Anmar said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1939", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، عَنِ الْجُرَيْرِيِّ، عَنْ أَبِي نَضْرَةَ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ كُنْتُ مَعَ النَّبِيِّ ـ صلى الله عليه وسلم ـ فِي غَزْوَةٍ فَقَالَ لِي ‏\"‏ أَتَبِيعُ نَاضِحَكَ هَذَا بِدِينَارٍ وَاللَّهُ يَغْفِرُ لَكَ ‏\"‏ ‏.‏ قُلْتُ يَا رَسُولَ اللَّهِ هُوَ نَاضِحُكُمْ إِذَا أَتَيْتُ الْمَدِينَةَ ‏.‏ قَالَ ‏\"‏ فَتَبِيعُهُ بِدِينَارَيْنِ وَاللَّهُ يَغْفِرُ لَكَ ‏\"‏ ‏.‏ قَالَ فَمَا زَالَ يَزِيدُنِي دِينَارًا دِينَارًا وَيَقُولُ مَكَانَ كُلِّ دِينَارٍ ‏\"‏ وَاللَّهُ يَغْفِرُ لَكَ ‏\"‏ ‏.‏ حَتَّى بَلَغَ عِشْرِينَ دِينَارًا فَلَمَّا أَتَيْتُ الْمَدِينَةَ أَخَذْتُ بِرَأْسِ النَّاضِحِ فَأَتَيْتُ بِهِ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَقَالَ ‏\"‏ يَا بِلاَلُ أَعْطِهِ مِنَ الْعَيْبَةِ عِشْرِينَ دِينَارًا ‏\"‏ ‏.‏ وَقَالَ ‏\"‏ انْطَلِقْ بِنَاضِحِكَ وَاذْهَبْ بِهِ إِلَى أَهْلِكَ ‏\"‏ ‏.‏", "bengali": "", "english": "\"I was with the Prophet (ﷺ) on a military campaign, and he said to me: 'Will you sell this camel of yours for a Dinar?' I said: 'O Messenger of Allah, it is yours when I get to Al-Madinah.' He said: 'Then sell it for two Dinar, may Allah forgive you.' And he kept increasing the price for me, saying: 'May Allah forgive you,' each time, until the amount reached twenty Dinar. When I came to Al-Madinah, I took hold of the camel's head and brought it to the Prophet (ﷺ) and he said: 'O Bilal, give him twenty Dinar from the spoils of war.' And he said: 'Take your camel away and go to your people with it.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین ام حبیبہ رضی اللہ عنہا بیان کرتی ہیں کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم سے عرض کی", "grades": "", "reference": "", "international_number": "1939", "narrator_chain": "It was narrated that Jabir bin 'Abdullah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1940", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَسَهْلُ بْنُ أَبِي سَهْلٍ، قَالاَ حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، أَنْبَأَنَا الرَّبِيعُ بْنُ حَبِيبٍ، عَنْ نَوْفَلِ بْنِ عَبْدِ الْمَلِكِ، عَنْ أَبِيهِ، عَنْ عَلِيٍّ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ السَّوْمِ قَبْلَ طُلُوعِ الشَّمْسِ وَعَنْ ذَبْحِ ذَوَاتِ الدَّرِّ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) forbade haggling before sunrise, and (he forbade) slaughtering animals that yield milk.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام الفضل رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایک یا دو بار دودھ پینے", "grades": "", "reference": "", "international_number": "1940", "narrator_chain": "It was narrated that 'Ali said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1941", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، وَأَحْمَدُ بْنُ سِنَانٍ، قَالُوا حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ ثَلاَثَةٌ لاَ يُكَلِّمُهُمُ اللَّهُ عَزَّ وَجَلَّ يَوْمَ الْقِيَامَةِ وَلاَ يَنْظُرُ إِلَيْهِمْ وَلاَ يُزَكِّيهِمْ وَلَهُمْ عَذَابٌ أَلِيمٌ رَجُلٌ عَلَى فَضْلِ مَاءٍ بِالْفَلاَةِ يَمْنَعُهُ ابْنَ السَّبِيلِ وَرَجُلٌ بَايَعَ رَجُلاً سِلْعَةً بَعْدَ الْعَصْرِ فَحَلَفَ بِاللَّهِ لأَخَذَهَا بِكَذَا وَكَذَا فَصَدَّقَهُ وَهُوَ عَلَى غَيْرِ ذَلِكَ وَرَجُلٌ بَايَعَ إِمَامًا لاَ يُبَايِعُهُ إِلاَّ لِدُنْيَا فَإِنْ أَعْطَاهُ مِنْهَا وَفَى لَهُ وَإِنْ لَمْ يُعْطِهِ مِنْهَا لَمْ يَفِ لَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"There are three to whom Allah will not speak on the Day of Resurrection, nor will He look at them or purify them, and theirs will be a painful torment: A man who has surplus water in the desert but refuses to give any to a wayfarer; a man who sells a product to a man after 'Asr and swears by Allah that he bought it for such and such amount, and he believes him, when that is not the case; and a man who swears allegiance to a ruler, and only does so for worldly gains, so if he gives him some of (these worldly benefits) he fulfills his oath of allegiance, and if he is not given anything he does not uphold his oath of allegiance. \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1942", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَمُحَمَّدُ بْنُ إِسْمَاعِيلَ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنِ الْمَسْعُودِيِّ، عَنْ عَلِيِّ بْنِ مُدْرِكٍ، عَنْ خَرَشَةَ بْنِ الْحُرِّ، عَنْ أَبِي ذَرٍّ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ ح وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ عَلِيِّ بْنِ مُدْرِكٍ، عَنْ أَبِي زُرْعَةَ بْنِ عَمْرِو بْنِ جَرِيرٍ، عَنْ خَرَشَةَ بْنِ الْحُرِّ، عَنْ أَبِي ذَرٍّ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏\"‏ ثَلاَثَةٌ لاَ يُكَلِّمُهُمُ اللَّهُ يَوْمَ الْقِيَامَةِ وَلاَ يَنْظُرُ إِلَيْهِمْ وَلاَ يُزَكِّيهِمْ وَلَهُمْ عَذَابٌ أَلِيمٌ ‏\"‏ ‏.‏ فَقُلْتُ مَنْ هُمْ يَا رَسُولَ اللَّهِ فَقَدْ خَابُوا وَخَسِرُوا ‏.‏ قَالَ ‏\"‏ الْمُسْبِلُ إِزَارَهُ وَالْمَنَّانُ عَطَاءَهُ وَالْمُنَفِّقُ سِلْعَتَهُ بِالْحَلِفِ الْكَاذِبِ ‏\"‏ ‏.‏", "bengali": "", "english": "\"There are three to whom Allah will not speak on the Day of Resurrection nor will He look at them or purify them, and theirs will be a painful torment.\" I said: \"Who are they, O Messenger of Allah? For they are indeed losers.\" He said: \"The one who lets his garment hang beneath his ankles, the one who reminds another of what he has given him, and the one who sells his product by means of false oaths.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  پہلے قرآن میں یہ آیت تھی، پھر وہ ساقط و منسوخ ہو گئی،", "grades": "", "reference": "", "international_number": "1942", "narrator_chain": "It was narrated from Abu Dharr that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1943", "arabic": "حَدَّثَنَا يَحْيَى بْنُ خَلَفٍ، حَدَّثَنَا عَبْدُ الأَعْلَى، ح وَحَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ، عَنْ مَعْبَدِ بْنِ كَعْبِ بْنِ مَالِكٍ، عَنْ أَبِي قَتَادَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِيَّاكُمْ وَالْحَلِفَ فِي الْبَيْعِ فَإِنَّهُ يُنَفِّقُ ثُمَّ يَمْحَقُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Beware of swearing oaths when selling, for it may help you to make a sale but it destroys the blessing.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Qatadah that the Messenger of Allah (ﷺ), said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1944", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، قَالَ حَدَّثَنِي نَافِعٌ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنِ اشْتَرَى نَخْلاً قَدْ أُبِّرَتْ فَثَمَرَتُهَا لِلْبَائِعِ إِلاَّ أَنْ يَشْتَرِطَ الْمُبْتَاعُ ‏\"\"‏ ‏.‏ حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ بِنَحْوِهِ ‏.‏\"", "bengali": "", "english": "\"Whoever buys a palm tree that has been pollinated, its fruits belong to the seller, unless the purchaser stipulated a condition.\" (Sahih)  Another chain from Ibn 'Umar, from the Prophet (ﷺ), with similar wording.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1945", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ح وَحَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، جَمِيعًا عَنِ ابْنِ شِهَابٍ الزُّهْرِيِّ، عَنْ سَالِمِ بْنِ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ بَاعَ نَخْلاً قَدْ أُبِّرَتْ فَثَمَرَتُهَا لِلَّذِي بَاعَهَا إِلاَّ أَنْ يَشْتَرِطَ الْمُبْتَاعُ وَمَنِ ابْتَاعَ عَبْدًا وَلَهُ مَالٌ فَمَالُهُ لِلَّذِي بَاعَهُ إِلاَّ أَنْ يَشْتَرِطَ الْمُبْتَاعُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "the Messenger of Allah (ﷺ) said: \"Whoever sells a palm tree that has been pollinated, its fruits belong to the seller, unless the purchaser stipulated a condition. And whoever buys a slave who has wealth, his wealth belongs to the seller, unless the purchaser stipulated a condition.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Salim bin 'Abdullah, bin 'Umar, from Ibn 'Umar, that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1946", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْوَلِيدِ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ عَبْدِ رَبِّهِ بْنِ سَعِيدٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ أَنَّهُ قَالَ ‏ ‏ مَنْ بَاعَ نَخْلاً وَبَاعَ عَبْدًا جَمَعَهُمَا جَمِيعًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Whoever sells a palm tree and sells a slave.\" Mentioning both of them together.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Nafi' from Ibn 'Umar that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1947", "arabic": "حَدَّثَنَا عَبْدُ رَبِّهِ بْنُ خَالِدٍ النُّمَيْرِيُّ أَبُو الْمُغَلِّسِ، حَدَّثَنَا الْفُضَيْلُ بْنُ سُلَيْمَانَ، عَنْ مُوسَى بْنِ عُقْبَةَ، حَدَّثَنِي إِسْحَاقُ بْنُ يَحْيَى بْنِ الْوَلِيدِ بْنِ عُبَادَةَ بْنِ الصَّامِتِ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، قَالَ قَضَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنَّ ثَمَرَ النَّخْلِ لِمَنْ أَبَّرَهَا إِلاَّ أَنْ يَشْتَرِطَ الْمُبْتَاعُ وَأَنَّ مَالَ الْمَمْلُوكِ لِمَنْ بَاعَهُ إِلاَّ أَنْ يَشْتَرِطَ الْمُبْتَاعُ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) ruled that the fruit of a palm tree belongs to the one who pollinated it, and that the wealth of a slave belongs to the one who sold him, unless the purchaser stipulated a condition.\"", "french": "", "indonesian": "", "russian": "", "urdu": "زینب بنت ابی سلمہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کی ساری بیویوں نے اس مسئ", "grades": "", "reference": "", "international_number": "1947", "narrator_chain": "It was narrated that 'Ubadah bin Samit said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1948", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ تَبِيعُوا الثَّمَرَةَ حَتَّى يَبْدُوَ صَلاَحُهَا ‏\"\"‏ ‏.‏ نَهَى الْبَائِعَ وَالْمُشْتَرِيَ ‏.‏\"", "bengali": "", "english": "\"Do not sell fruits until they have ripened.\" And he forbade (both) the seller and the purchaser (to engage in such a transaction).", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1949", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عِيسَى الْمِصْرِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، عَنْ يُونُسَ بْنِ يَزِيدَ، عَنِ ابْنِ شِهَابٍ، حَدَّثَنِي سَعِيدُ بْنُ الْمُسَيَّبِ، وَأَبُو سَلَمَةَ بْنُ عَبْدِ الرَّحْمَنِ عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ تَبِيعُوا الثَّمَرَ حَتَّى يَبْدُوَ صَلاَحُهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Do not sell fruits until they have ripened.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1950", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ، عَنِ ابْنِ جُرَيْجٍ، عَنْ عَطَاءٍ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ نَهَى عَنْ بَيْعِ الثَّمَرِ حَتَّى يَبْدُوَ صَلاَحُهُ ‏.‏", "bengali": "", "english": "the Prophet (ﷺ) forbade selling fruits until they have ripened.", "french": "", "indonesian": "", "russian": "", "urdu": "دیلمی (فیروز دیلمی) رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا، اور میرے", "grades": "", "reference": "", "international_number": "1950", "narrator_chain": "It was narrated from Jabir that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1951", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا حَجَّاجٌ، حَدَّثَنَا حَمَّادٌ، عَنْ حُمَيْدٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ نَهَى عَنْ بَيْعِ الثَّمَرَةِ حَتَّى تَزْهُوَ وَعَنْ بَيْعِ الْعِنَبِ حَتَّى يَسْوَدَّ وَعَنْ بَيْعِ الْحَبِّ حَتَّى يَشْتَدَّ ‏.‏", "bengali": "", "english": "the Messenger of Allah (ﷺ) forbade selling fruits until they have changed the color, and selling grapes until they have turned black, and selling grains until they have hardened.", "french": "", "indonesian": "", "russian": "", "urdu": "فیروز دیلمی رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا اور میں نے عرض کیا", "grades": "", "reference": "", "international_number": "1951", "narrator_chain": "It was narrated from Anas bin Malik that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1952", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا سُفْيَانُ، عَنْ حُمَيْدٍ الأَعْرَجِ، عَنْ سُلَيْمَانَ بْنِ عَتِيقٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ نَهَى عَنْ بَيْعِ السِّنِينَ ‏.‏", "bengali": "", "english": "the Messenger of Allah (ﷺ) forbade selling for many years ahead.", "french": "", "indonesian": "", "russian": "", "urdu": "قیس بن حارث رضی اللہ عنہ کہتے ہیں کہ  میں نے اسلام قبول کیا، اور میرے پاس آٹھ عورتیں تھیں، چنانچہ م", "grades": "", "reference": "", "international_number": "1952", "narrator_chain": "It was narrated from Jabir bin 'Abdullah that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1953", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا يَحْيَى بْنُ حَمْزَةَ، حَدَّثَنَا ثَوْرُ بْنُ يَزِيدَ، عَنِ ابْنِ جُرَيْجٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنْ بَاعَ ثَمَرًا فَأَصَابَتْهُ جَائِحَةٌ فَلاَ يَأْخُذْ مِنْ مَالِ أَخِيهِ شَيْئًا عَلاَمَ يَأْخُذُ أَحَدُكُمْ مَالَ أَخِيهِ الْمُسْلِمِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Whoever sells fruits then the crop fails, should not take any of his brother's money. Why would any of you take the money of his Muslim brother?\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir bin 'Abdullah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1954", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، وَمُحَمَّدُ بْنُ إِسْمَاعِيلَ، قَالُوا حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ سِمَاكِ بْنِ حَرْبٍ، عَنْ سُوَيْدِ بْنِ قَيْسٍ، قَالَ جَلَبْتُ أَنَا وَمَخْرَفَةُ الْعَبْدِيُّ، بَزًّا مِنْ هَجَرَ فَجَاءَنَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَسَاوَمَنَا سَرَاوِيلَ وَعِنْدَنَا وَزَّانٌ يَزِنُ بِالأَجْرِ فَقَالَ لَهُ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏ ‏ يَا وَزَّانُ زِنْ وَأَرْجِحْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Makhrafah Al' Abdi and I brought linens from Hajar The Messenger of Allah (ﷺ) came to us to bargain with us with some trousers. There was someone with me who weighed (the goods) in exchange for a wage. So the Prophet (ﷺ) said to the one weighing: 'Weigh and add more.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Suwaid bin Qais said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1955", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَمُحَمَّدُ بْنُ الْوَلِيدِ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ سِمَاكِ بْنِ حَرْبٍ، قَالَ سَمِعْتُ مَالِكًا أَبَا صَفْوَانَ بْنَ عُمَيْرَةَ، قَالَ بِعْتُ مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ رِجْلَ سَرَاوِيلَ قَبْلَ الْهِجْرَةِ فَوَزَنَ لِي فَأَرْجَحَ لِي ‏.‏", "bengali": "", "english": "\"I heard Malik Abu Safwan bin 'Umairah, say: 'I bought a pair of trousers from the Messenger of Allah (ﷺ) before the Hijrah, and he weighed it for me and allowed more.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مہر یا", "grades": "", "reference": "", "international_number": "1955", "narrator_chain": "It was narrated that Simak bin Harb said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1956", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الصَّمَدِ، حَدَّثَنَا شُعْبَةُ، عَنْ مُحَارِبِ بْنِ دِثَارٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا وَزَنْتُمْ فَأَرْجِحُوا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"When you weigh, allow more. \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir bin 'Abdullah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1957", "arabic": "حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ بِشْرِ بْنِ الْحَكَمِ، وَمُحَمَّدُ بْنُ عَقِيلِ بْنِ خُوَيْلِدٍ، قَالاَ حَدَّثَنَا عَلِيُّ بْنُ الْحُسَيْنِ بْنِ وَاقِدٍ، حَدَّثَنِي أَبِي، حَدَّثَنِي يَزِيدُ النَّحْوِيُّ، أَنَّ عِكْرِمَةَ، حَدَّثَهُ عَنِ ابْنِ عَبَّاسٍ، قَالَ لَمَّا قَدِمَ النَّبِيُّ ـ صلى الله عليه وسلم ـ الْمَدِينَةَ كَانُوا مِنْ أَخْبَثِ النَّاسِ كَيْلاً فَأَنْزَلَ اللَّهُ سُبْحَانَهُ ‏{وَيْلٌ لِلْمُطَفِّفِينَ}‏ فَأَحْسَنُوا الْكَيْلَ بَعْدَ ذَلِكَ ‏.‏", "bengali": "", "english": "\"When the Prophet (ﷺ) came to Al-Madinah, they were the worst people in weights and measures. Then Allah, Glorious is He revealed: \"Woe to the Mutaffifun (those who give less in measure and weight)\", and they were fair in weights and measures after that.", "french": "", "indonesian": "", "russian": "", "urdu": "انس رضی اللہ عنہ کہتے ہیں کہ  پہلے ام المؤمنین صفیہ رضی اللہ عنہا دحیہ کلبی رضی اللہ عنہ کے حصہ میں", "grades": "", "reference": "", "international_number": "1957", "narrator_chain": "It was narrated that Ibn 'Abbas said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1958", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ، عَنِ الْعَلاَءِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ مَرَّ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ بِرَجُلٍ يَبِيِعُ طَعَامًا فَأَدْخَلَ يَدَهُ فِيهِ فَإِذَا هُوَ مَغْشُوشٌ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لَيْسَ مِنَّا مَنْ غَشَّ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) passed by a man who was selling food. He put his hand in it and saw that there was something wrong with it. The Messenger of Allah (ﷺ) said, 'He is not one of us who cheats.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Hurairah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1959", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو نُعَيْمٍ، حَدَّثَنَا يُونُسُ بْنُ أَبِي إِسْحَاقَ، عَنْ أَبِي دَاوُدَ، عَنْ أَبِي الْحَمْرَاءِ، قَالَ رَأَيْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ مَرَّ بِجَنَبَاتِ رَجُلٍ عِنْدَهُ طَعَامٌ فِي وِعَاءٍ فَأَدْخَلَ يَدَهُ فِيهِ فَقَالَ ‏ ‏ لَعَلَّكَ غَشَشْتَهُ مَنْ غَشَّنَا فَلَيْسَ مِنَّا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I saw the Messenger of Allah (ﷺ) pass by a man having food in a vessel. He put his hand in it and said: 'Perhaps you are cheating. Whoever cheats us is not one of us.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Hamra' said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1960", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنِ ابْتَاعَ طَعَامًا فَلاَ يَبِعْهُ حَتَّى يَسْتَوْفِيَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Whoever buys food, let him not sell it until he has taken full possession of it.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Umar that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1961", "arabic": "حَدَّثَنَا عِمْرَانُ بْنُ مُوسَى اللَّيْثِيُّ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، ح وَحَدَّثَنَا بِشْرُ بْنُ مُعَاذٍ الضَّرِيرُ، حَدَّثَنَا أَبُو عَوَانَةَ، وَحَمَّادُ بْنُ زَيْدٍ، قَالاَ حَدَّثَنَا عَمْرُو بْنُ دِينَارٍ، عَنْ طَاوُسٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنِ ابْتَاعَ طَعَامًا فَلاَ يَبِعْهُ حَتَّى يَسْتَوْفِيَهُ ‏\"\"‏ ‏.‏ قَالَ أَبُو عَوَانَةَ فِي حَدِيثِهِ قَالَ ابْنُ عَبَّاسٍ وَأَحْسِبُ كُلَّ شَىْءٍ مِثْلَ الطَّعَامِ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) said: 'Whoever buys food, let him not sell it until he has taken full possession of it.'\" (Sahih)  In his narration, (one of the narrators) Abu 'Awanah said: \"Ibn 'Abbas said: 'I think everything is like food.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Ibn 'Abbas said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1962", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنِ ابْنِ أَبِي لَيْلَى، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ بَيْعِ الطَّعَامِ حَتَّى يَجْرِيَ فِيهِ الصَّاعَانِ صَاعُ الْبَائِعِ وَصَاعُ الْمُشْتَرِي ‏.‏", "bengali": "", "english": "'The Messenger of Allah (ﷺ) forbade selling food bought by measure until two Sa' have been measured - the Sa' of the seller and the Sa' of the buyer.\"", "french": "", "indonesian": "", "russian": "", "urdu": "سبرہ بن معبد جہنی رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ حجۃ الوداع میں ن", "grades": "", "reference": "", "international_number": "1962", "narrator_chain": "It was narrated that Jabir said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1963", "arabic": "حَدَّثَنَا سَهْلُ بْنُ أَبِي سَهْلٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ كُنَّا نَشْتَرِي الطَّعَامَ مِنَ الرُّكْبَانِ جِزَافًا فَنَهَانَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ أَنْ نَبِيعَهُ حَتَّى نَنْقُلَهُ مِنْ مَكَانِهِ ‏.‏", "bengali": "", "english": "\"We used to buy food from troops of riders (i.e., the caravans) without knowing the amount, but the Messenger of Allah (ﷺ) forbade us to sell it until it had been delivered to us.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  جب عمر بن خطاب رضی اللہ عنہ خلیفہ ہوئے، تو انہوں نے خطبہ", "grades": "", "reference": "", "international_number": "1963", "narrator_chain": "It was narrated that Ibn 'Umar said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1964", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مَيْمُونٍ الرَّقِّيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ يَزِيدَ، عَنِ ابْنِ لَهِيعَةَ، عَنْ مُوسَى بْنِ وَرْدَانَ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ عُثْمَانَ بْنِ عَفَّانَ، قَالَ كُنْتُ أَبِيعُ التَّمْرَ فِي السُّوقِ فَأَقُولُ كِلْتُ فِي وَسْقِي هَذَا كَذَا ‏.‏ فَأَدْفَعُ أَوْسَاقَ التَّمْرِ بِكَيْلِهِ وَآخُذُ شِفِّي فَدَخَلَنِي مِنْ ذَلِكَ شَىْءٌ فَسَأَلْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ ‏ ‏ إِذَا سَمَّيْتَ الْكَيْلَ فَكِلْهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I used to sell dates in the marketplace, and I would say: 'This was such and such an amount (when I bought it).' I Would give the purchaser a specific amount of dates according to the way it had been measured for me, and take my profit. Then I began to have some doubts about that, so I asked the Messenger of Allah (ﷺ), and he said: ‘When you name the amount, measure it in front of the purchaser.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that 'Uthman bin 'Affan said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1965", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الرَّحْمَنِ الْيَحْصُبِيُّ، عَنْ عَبْدِ اللَّهِ بْنِ بُسْرٍ الْمَازِنِيِّ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ كِيلُوا طَعَامَكُمْ يُبَارَكْ لَكُمْ فِيهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I heard the Messenger of Allah (ﷺ) say: 'Measure your food, may you be blessed therein.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abdullah bin Busr Al-Mazini said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1966", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، حَدَّثَنَا بَقِيَّةُ بْنُ الْوَلِيدِ، عَنْ بَحِيرِ بْنِ سَعْدٍ، عَنْ خَالِدِ بْنِ مَعْدَانَ، عَنِ الْمِقْدَامِ بْنِ مَعْدِيكَرِبَ، عَنْ أَبِي أَيُّوبَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ كِيلُوا طَعَامَكُمْ يُبَارَكْ لَكُمْ فِيهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Measure your food, may you be blessed therein.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Ayyub that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1967", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، حَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ بْنِ سَعِيدٍ، حَدَّثَنِي صَفْوَانُ بْنُ سُلَيْمٍ، حَدَّثَنِي مُحَمَّدٌ، وَعَلِيٌّ، ابْنَا الْحَسَنِ بْنِ أَبِي الْحَسَنِ الْبَرَّادِ أَنَّ الزُّبَيْرَ بْنَ الْمُنْذِرِ بْنِ أَبِي أُسَيْدٍ السَّاعِدِيِّ، حَدَّثَهُمَا أَنَّ أَبَاهُ الْمُنْذِرَ حَدَّثَهُ عَنْ أَبِي أُسَيْدٍ، أَنَّ أَبَا أُسَيْدٍ، حَدَّثَهُ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ ذَهَبَ إِلَى سُوقِ النَّبِيطِ فَنَظَرَ إِلَيْهِ فَقَالَ ‏\"‏ لَيْسَ هَذَا لَكُمْ بِسُوقٍ ‏\"‏ ‏.‏ ثُمَّ ذَهَبَ إِلَى سُوقٍ فَنَظَرَ إِلَيْهِ فَقَالَ ‏\"‏ لَيْسَ هَذَا لَكُمْ بِسُوقٍ ‏\"‏ ‏.‏ ثُمَّ رَجَعَ إِلَى هَذَا السُّوقِ فَطَافَ فِيهِ ثُمَّ قَالَ ‏\"‏ هَذَا سُوقُكُمْ فَلاَ يُنْتَقَصَنَّ وَلاَ يُضْرَبَنَّ عَلَيْهِ خَرَاجٌ ‏\"‏ ‏.‏", "bengali": "", "english": "the Messenger of Allah (ﷺ) went to the market of Nabit, and looked at it, and said: \"This is not a market for you.\" Then we went to another market and looked at it, and said: \"This is not a market for you.\" Then he came back to this market and walked around in it then he said: \"This is your market. It will always be your market and no duty will be levied on it.\" (Do,if)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تمہارے پاس کسی ایسے ش", "grades": "", "reference": "", "international_number": "1967", "narrator_chain": "It was narrated that Abu Usaid said that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1968", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُسْتَمِرِّ الْعُرُوقِيُّ، حَدَّثَنَا أَبِي، حَدَّثَنَا عُبَيْسُ بْنُ مَيْمُونٍ، حَدَّثَنَا عَوْنٌ الْعُقَيْلِيُّ، عَنْ أَبِي عُثْمَانَ النَّهْدِيِّ، عَنْ سَلْمَانَ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَنْ غَدَا إِلَى صَلاَةِ الصُّبْحِ غَدَا بِرَايَةِ الإِيمَانِ وَمَنْ غَدَا إِلَى السُّوقِ غَدَا بِرَايَةِ إِبْلِيسَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I heard the Messenger of Allah (ﷺ) saying: 'Whoever goes to the Morning prayer first thing in the morning, he goes out with the banner of faith but whoever goes out to the marketplace first thing in the morning, he goes out under the banner of Iblis (Satan).' \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Salman said :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1969", "arabic": "حَدَّثَنَا بِشْرُ بْنُ مُعَاذٍ الضَّرِيرُ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ عَمْرِو بْنِ دِينَارٍ، مَوْلَى آلِ الزُّبَيْرِ عَنْ سَالِمِ بْنِ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ مَنْ قَالَ حِينَ يَدْخُلُ السُّوقَ لاَ إِلَهَ إِلاَّ اللَّهُ وَحْدَهُ لاَ شَرِيكَ لَهُ لَهُ الْمُلْكُ وَلَهُ الْحَمْدُ يُحْيِي وَيُمِيتُ وَهُوَ حَىٌّ لاَ يَمُوتُ بِيَدِهِ الْخَيْرُ كُلُّهُ وَهُوَ عَلَى كُلِّ شَىْءٍ قَدِيرٌ - كَتَبَ اللَّهُ لَهُ أَلْفَ أَلْفِ حَسَنَةٍ وَمَحَا عَنْهُ أَلْفَ أَلْفِ سَيِّئَةٍ وَبَنَى لَهُ بَيْتًا فِي الْجَنَّةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Whoever says, when he enters the marketplace: 'La ilaha illallah wahdahu la sharika lahu, lahul-mulk wa lahul-hamdu, yuhyi wa yumitu, wa Huwa hayyun la yamutu, bi yadihil-khairu kulluhu, wa Huwa ala kulli shay’in Qadir (None has the right to be worshiped but Allah alone, with no partner, to Him belongs all sovereignty and to Him is the praise, He gives life and gives death, and He is Ever-Living and does not die; in His Hand is all goodness and He is Able to do all things),' Allah will record for him one million good deeds, and will erase from him one million bad deeds, and will build for him a house in Paradise. \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Salim bin 'Abdullah bin 'Umar, from his father, that his grandfather told that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1970", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا هُشَيْمٌ، عَنْ يَعْلَى بْنِ عَطَاءٍ، عَنْ عُمَارَةَ بْنِ حَدِيدٍ، عَنْ صَخْرٍ الْغَامِدِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اللَّهُمَّ بَارِكْ لأُمَّتِي فِي بُكُورِهَا ‏\"\"‏ ‏.‏ قَالَ وَكَانَ إِذَا بَعَثَ سَرِيَّةً أَوْ جَيْشًا بَعَثَهُمْ فِي أَوَّلِ النَّهَارِ ‏.‏ قَالَ وَكَانَ صَخْرٌ رَجُلاً تَاجِرًا فَكَانَ يَبْعَثُ تِجَارَتَهُ فِي أَوَّلِ النَّهَارِ فَأَثْرَى وَكَثُرَ مَالُهُ ‏.‏\"", "bengali": "", "english": "\"O Allah, bless my nation in their early mornings (i.e., what they do early in the morning).\" (Hasan)He said: \"When he sent out a raiding party or an army, he would send them at the beginning of the day.\" He said: (1) \"Sakhr was a man engaged in trade, and he used to send his goods out at the beginning of the day, and his wealth grew and increased.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Sakhr Al-Ghamidi that the  Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1971", "arabic": "حَدَّثَنَا أَبُو مَرْوَانَ، مُحَمَّدُ بْنُ عُثْمَانَ الْعُثْمَانِيُّ حَدَّثَنَا مُحَمَّدُ بْنُ مَيْمُونٍ الْمَدَنِيُّ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي الزِّنَادِ، عَنْ أَبِيهِ، عَنِ الأَعْرَجِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ اللَّهُمَّ بَارِكْ لأُمَّتِي فِي بُكُورِهَا يَوْمَ الْخَمِيسِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"O Allah, bless my nation early in the morning of Thursday.' \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1972", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا إِسْحَاقُ بْنُ جَعْفَرِ بْنِ مُحَمَّدِ بْنِ عَلِيِّ بْنِ الْحُسَيْنِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي بَكْرٍ الْجُدْعَانِيِّ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ اللَّهُمَّ بَارِكْ لأُمَّتِي فِي بُكُورِهَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"O Allah, bless my nation early in the morning.' \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn Umar that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1973", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ هِشَامِ بْنِ حَسَّانَ، عَنْ مُحَمَّدِ بْنِ سِيرِينَ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَنِ ابْتَاعَ مُصَرَّاةً فَهُوَ بِالْخِيَارِ ثَلاَثَةَ أَيَّامٍ فَإِنْ رَدَّهَا رَدَّ مَعَهَا صَاعًا مِنْ تَمْرٍ لاَ سَمْرَاءَ ‏\"\"‏ ‏.‏ يَعْنِي الْحِنْطَةَ ‏.‏\"", "bengali": "", "english": "\"O Allah, bless my nation in their early mornings.\". It was narrated from Abu Hurairah that the Prophet (ﷺ) said: \"Whoever buys a Musarrah, he has the choice (of annulling the deal) for three days. If he returns it, then he must also give a Sa' of dates, not Samra'.\" Meaning wheat.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Umar that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1974", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا عَبْدُ الْوَاحِدِ بْنُ زِيَادٍ، حَدَّثَنَا صَدَقَةُ بْنُ سَعِيدٍ الْحَنَفِيُّ، حَدَّثَنَا جُمَيْعُ بْنُ عُمَيْرٍ التَّيْمِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ يَا أَيُّهَا النَّاسُ مَنْ بَاعَ مُحَفَّلَةً فَهُوَ بِالْخِيَارِ ثَلاَثَةَ أَيَّامٍ فَإِنْ رَدَّهَا رَدَّ مَعَهَا مِثْلَىْ لَبَنِهَا - أَوْ قَالَ مِثْلَ لَبَنِهَا - قَمْحًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) said: 'Whoever buys a Muhaffalah, (1) he has the choice (of annulling the deal) for three days. If he returns it, then he must also give wheat equal to twice, the amount of its milk, or equal to the amount of its milk.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "'Abdullah bin 'Umar said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1975", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا الْمَسْعُودِيُّ، عَنْ جَابِرٍ، عَنْ أَبِي الضُّحَى، عَنْ مَسْرُوقٍ، عَنْ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ، أَنَّهُ قَالَ أَشْهَدُ عَلَى الصَّادِقِ الْمَصْدُوقِ أَبِي الْقَاسِمِ ـ صلى الله عليه وسلم ـ أَنَّهُ حَدَّثَنَا قَالَ ‏ ‏ بَيْعُ الْمُحَفَّلاَتِ خِلاَبَةٌ وَلاَ تَحِلُّ الْخِلاَبَةُ لِمُسْلِمٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I bear witness that the true and truly inspired one Abul-Qasim (ﷺ) told us: 'Selling a Muhaffalah is Khilabah, and Khilabah is not lawful for the Muslim.\"' (Ibn Majah said: \" Meaning: 'Deception.\")", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that 'Abdullah bin Mas'ud said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1976", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنِ ابْنِ أَبِي ذِئْبٍ، عَنْ مَخْلَدِ بْنِ خُفَافِ بْنِ إِيمَاءَ بْنِ رَحَضَةَ الْغِفَارِيِّ، عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، عَنْ عَائِشَةَ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَضَى أَنَّ خَرَاجَ الْعَبْدِ بِضَمَانِهِ ‏.‏", "bengali": "", "english": "the Messenger of Allah (ﷺ) ruled that what a slave earns belongs to his guarantor.", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  اسامہ رضی اللہ عنہ دروازہ کی چوکھٹ پر گر پڑے، جس سے ان", "grades": "", "reference": "", "international_number": "1976", "narrator_chain": "It was narrated from Aishah that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1977", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا مُسْلِمُ بْنُ خَالِدٍ الزَّنْجِيُّ، حَدَّثَنَا هِشَامُ بْنُ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، أَنَّ رَجُلاً، اشْتَرَى عَبْدًا فَاسْتَغَلَّهُ ثُمَّ وَجَدَ بِهِ عَيْبًا فَرَدَّهُ ‏.‏ فَقَالَ يَا رَسُولَ اللَّهِ إِنَّهُ قَدِ اسْتَغَلَّ غُلاَمِي ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الْخَرَاجُ بِالضَّمَانِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "a man bought a slave and put him to work, then he found some defect in him, so he returned him. He (the seller) said: \"O Messenger of Allah he put my slave to work.\" The Messenger of Allah (ﷺ) said: \"A slave's earnings belong to his guarantor.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Aishah that:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1978", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ سَعِيدٍ، عَنْ قَتَادَةَ، عَنِ الْحَسَنِ، إِنْ شَاءَ اللَّهُ عَنْ سَمُرَةَ بْنِ جُنْدُبٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ عُهْدَةُ الرَّقِيقِ ثَلاَثَةُ أَيَّامٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The contractual obligation regarding a slave lasts for three days.\" (1)", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Samurah bin Jundab that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1979", "arabic": "حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا هُشَيْمٌ، عَنْ يُونُسَ بْنِ عُبَيْدٍ، عَنِ الْحَسَنِ، عَنْ عُقْبَةَ بْنِ عَامِرٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ عُهْدَةَ بَعْدَ أَرْبَعٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"There is no contractual obligation after four (days).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Uqbah bin 'Amir that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1980", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، حَدَّثَنَا أَبِي، سَمِعْتُ يَحْيَى بْنَ أَيُّوبَ، يُحَدِّثُ عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ شُمَاسَةَ، عَنْ عُقْبَةَ بْنِ عَامِرٍ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ الْمُسْلِمُ أَخُو الْمُسْلِمِ وَلاَ يَحِلُّ لِمُسْلِمٍ بَاعَ مِنْ أَخِيهِ بَيْعًا فِيهِ عَيْبٌ إِلاَّ بَيَّنَهُ لَهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I heard the Messenger of Allah (ﷺ) say: 'The Muslim is the brother of another Muslim, and it is not permissible for a Muslim to sell his brother goods in which there is a defect, without pointing that out to him.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that 'Uqbah bin 'Amir said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1981", "arabic": "حَدَّثَنَا عَبْدُ الْوَهَّابِ بْنُ الضَّحَّاكِ، حَدَّثَنَا بَقِيَّةُ بْنُ الْوَلِيدِ، عَنْ مُعَاوِيَةَ بْنِ يَحْيَى، عَنْ مَكْحُولٍ، وَسُلَيْمَانَ بْنِ مُوسَى، عَنْ وَاثِلَةَ بْنِ الأَسْقَعِ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏ ‏ مَنْ بَاعَ عَيْبًا لَمْ يُبَيِّنْهُ لَمْ يَزَلْ فِي مَقْتٍ مِنَ اللَّهِ وَلَمْ تَزَلِ الْمَلاَئِكَةُ تَلْعَنُهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I heard the Messenger of Allah (ﷺ) say: 'Whoever sells defective goods without pointing it out, he will remain subject to the wrath of Allah, and the angels will continue to curse him.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Wathilah bin Asqa' said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1982", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَمُحَمَّدُ بْنُ إِسْمَاعِيلَ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا سُفْيَانُ، عَنْ جَابِرٍ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ أَبِيهِ، عَنْ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ، قَالَ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ إِذَا أُتِيَ بِالسَّبْىِ أَعْطَى أَهْلَ الْبَيْتِ جَمِيعًا كَرَاهِيَةَ أَنْ يُفَرِّقَ بَيْنَهُمْ ‏.‏", "bengali": "", "english": "\"When captives were brought to him, the Prophet (ﷺ) would give the members of one family together (to one person), not wanting to separate them.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کے پاس گڑیوں سے کھیلا", "grades": "", "reference": "", "international_number": "1982", "narrator_chain": "It was narrated that 'Abdullah bin Mas'ud said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1983", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَفَّانُ، عَنْ حَمَّادٍ، أَنْبَأَنَا الْحَجَّاجُ، عَنِ الْحَكَمِ، عَنْ مَيْمُونِ بْنِ أَبِي شَبِيبٍ، عَنْ عَلِيٍّ، قَالَ وَهَبَ لِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ غُلاَمَيْنِ أَخَوَيْنِ فَبِعْتُ أَحَدَهُمَا فَقَالَ ‏\"‏ مَا فَعَلَ الْغُلاَمَانِ ‏\"‏ ‏.‏ قُلْتُ بِعْتُ أَحَدَهُمَا قَالَ ‏\"‏ رُدَّهُ ‏\"‏ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) gave me two slaves who were brothers, and I sold one of them. He said: 'What happened with the two slaves?' I said: 'I sold one of them.' He said: 'Take him back.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن زمعہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے خطبہ دیا، پھر عورتوں کا ذکر", "grades": "", "reference": "", "international_number": "1983", "narrator_chain": "It was narrated that 'Ali said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1984", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ الْهَيَّاجِ، حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، أَنْبَأَنَا إِبْرَاهِيمُ بْنُ إِسْمَاعِيلَ، عَنْ طَلِيقِ بْنِ عِمْرَانَ، عَنْ أَبِي بُرْدَةَ، عَنْ أَبِي مُوسَى، قَالَ لَعَنَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ مَنْ فَرَّقَ بَيْنَ الْوَالِدَةِ وَوَلَدِهَا وَبَيْنَ الأَخِ وَبَيْنَ أَخِيهِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) cursed the one who separates a mother and her child, or a brother from his brother.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے نہ کسی خادم کو اپنے ہات", "grades": "", "reference": "", "international_number": "1984", "narrator_chain": "It was narrated that Abu Musa said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1985", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبَّادُ بْنُ لَيْثٍ، صَاحِبُ الْكَرَابِيسِيِّ حَدَّثَنَا عَبْدُ الْمَجِيدِ بْنُ وَهْبٍ، قَالَ قَالَ لِي الْعَدَّاءُ بْنُ خَالِدِ بْنِ هَوْذَةَ أَلاَ نُقْرِئُكَ كِتَابًا كَتَبَهُ لِي رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏.‏ قَالَ قُلْتُ بَلَى ‏.‏ فَأَخْرَجَ لِي كِتَابًا فَإِذَا فِيهِ ‏ ‏ هَذَا مَا اشْتَرَى الْعَدَّاءُ بْنُ خَالِدِ بْنِ هَوْذَةَ مِنْ مُحَمَّدٍ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ اشْتَرَى مِنْهُ عَبْدًا أَوْ أَمَةً لاَ دَاءَ وَلاَ غَائِلَةَ وَلاَ خِبْثَةَ بَيْعَ الْمُسْلِمِ لِلْمُسْلِمِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Adda' bin Khalid bin Hawdhah said to me: 'Shall I not read to you a letter that the Messenger of Allah (ﷺ), wrote to me?' I said: 'Yes.' So he took out a letter. In it was: 'This is what 'Adda' bin Khalid bin Hawdhah bought  Muhammad the Messenger of Allah (ﷺ)  He bought from him a slave' or 'a female slave, having no ailments, nor being a runaway, not having any malicious behavior. Sold by a Muslim to a Muslim.'\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that 'Abdul-Majid bin Wahb said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1986", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنِ ابْنِ عَجْلاَنَ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا اشْتَرَى أَحَدُكُمُ الْجَارِيَةَ فَلْيَقُلِ اللَّهُمَّ إِنِّي أَسْأَلُكَ خَيْرَهَا وَخَيْرَ مَا جَبَلْتَهَا عَلَيْهِ وَأَعُوذُ بِكَ مِنْ شَرِّهَا وَشَرِّ مَا جَبَلْتَهَا عَلَيْهِ وَلْيَدْعُ بِالْبَرَكَةِ وَإِذَا اشْتَرَى أَحَدُكُمْ بَعِيرًا فَلْيَأْخُذْ بِذِرْوَةِ سَنَامِهِ وَلْيَدْعُ بِالْبَرَكَةِ وَلْيَقُلْ مِثْلَ ذَلِكَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"When anyone of you buys a slave woman let him say: 'Allahumma inni as'aluka khairaha wa khaira ma jabaltaha alaihi, wa a'udhu bika min sharriha wa sharri ma jabaltaha alaihi (O Allah, I ask You for the goodness within her and the goodness that You have made her inclined towards, and I seek refuge with You from the evil within her and the evil that You have made her inclined towards).' And he should pray for blessing. And if anyone of you buys a camel then he should take hold of its hump and pray for. blessing and say similar words.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Amr bin Shu'aib from his father that his grandfather told that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1987", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، وَهِشَامُ بْنُ عَمَّارٍ، وَنَصْرُ بْنُ عَلِيٍّ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالُوا حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ مَالِكِ بْنِ أَوْسِ بْنِ الْحَدَثَانِ النَّصْرِيِّ، قَالَ سَمِعْتُ عُمَرَ بْنَ الْخَطَّابِ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الذَّهَبُ بِالذَّهَبِ رِبًا إِلاَّ هَاءَ وَهَاءَ وَالْبُرُّ بِالْبُرِّ رِبًا إِلاَّ هَاءَ وَهَاءَ وَالشَّعِيرُ بِالشَّعِيرِ رِبًا إِلاَّ هَاءَ وَهَاءَ وَالتَّمْرُ بِالتَّمْرِ رِبًا إِلاَّ هَاءَ وَهَاءَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I heard 'Umar bin Al-Khattab say: 'The Messenger of Allah (ﷺ) said: \"Exchanging gold for gold is usury  unless it is done on the spot. (Exchanging) wheat for wheat is usury, unless it is done on the spot. (Exchanging) barley for barley is usury unless it is done on the spot. (Exchanging) dates for dates is usury, unless it is done on the spot.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Malik bin Aws bin Hadathan Nasri said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1988", "arabic": "حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ خَالِدِ بْنِ خِدَاشٍ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، قَالاَ حَدَّثَنَا سَلَمَةُ بْنُ عَلْقَمَةَ التَّمِيمِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ سِيرِينَ، أَنَّ مُسْلِمَ بْنَ يَسَارٍ، وَعَبْدَ اللَّهِ بْنَ عُبَيْدٍ، حَدَّثَاهُ قَالاَ، جَمَعَ الْمَنْزِلُ بَيْنَ عُبَادَةَ بْنِ الصَّامِتِ وَمُعَاوِيَةَ إِمَّا فِي كَنِيسَةٍ وَإِمَّا فِي بِيعَةٍ فَحَدَّثَهُمْ عُبَادَةُ بْنُ الصَّامِتِ فَقَالَ نَهَانَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ بَيْعِ الْوَرِقِ بِالْوَرِقِ وَالذَّهَبِ بِالذَّهَبِ وَالْبُرِّ بِالْبُرِّ وَالشَّعِيرِ بِالشَّعِيرِ وَالتَّمْرِ بِالتَّمْرِ - قَالَ أَحَدُهُمَا وَالْمِلْحِ بِالْمِلْحِ وَلَمْ يَقُلْهُ الآخَرُ - وَأَمَرَنَا أَنْ نَبِيعَ الْبُرَّ بِالشَّعِيرِ وَالشَّعِيرَ بِالْبُرِّ يَدًا بِيَدٍ كَيْفَ شِئْنَا ‏.‏", "bengali": "", "english": "\"Ubadah bin Samit and Mu'awiyah happened to meet, either in a church or in a synagogue. 'Ubadah bin Samit narrated to them and said: 'The Messenger of Allah (ﷺ) forbade us from selling silver for silver, gold for gold, wheat for wheat, barley for barley, and dates for dates.'I one of them said: \"And salt for salt,\" but the other did not say it. \"And he commanded us to sell wheat for barley, or barley for wheat, hand-to-hand, however we wished.\"", "french": "", "indonesian": "", "russian": "", "urdu": "اسماء رضی اللہ عنہا کہتی ہیں کہ  ایک عورت نبی اکرم صلی اللہ علیہ وسلم کے پاس آئی اور کہنے لگی: میری", "grades": "", "reference": "", "international_number": "1988", "narrator_chain": "Muslim bin Yasar and 'Abdullah bin 'Ubaid said :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1989", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَعْلَى بْنُ عُبَيْدٍ، حَدَّثَنَا فُضَيْلُ بْنُ غَزْوَانَ، عَنِ ابْنِ أَبِي نُعْمٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ الْفِضَّةُ بِالْفِضَّةِ وَالذَّهَبُ بِالذَّهَبِ وَالشَّعِيرُ بِالشَّعِيرِ وَالْحِنْطَةُ بِالْحِنْطَةِ مِثْلاً بِمِثْلٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "'(Sell) silver for silver, gold for gold, barley for barley, wheat for wheat, like for like.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1990", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنْ أَبِي سَعِيدٍ، قَالَ كَانَ النَّبِيُّ ـ صلى الله عليه وسلم ـ يَرْزُقُنَا تَمْرًا مِنْ تَمْرِ الْجَمْعِ فَنَسْتَبْدِلُ بِهِ تَمْرًا هُوَ أَطْيَبُ مِنْهُ وَنَزِيدُ فِي السِّعْرِ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لاَ يَصْلُحُ صَاعُ تَمْرٍ بِصَاعَيْنِ وَلاَ دِرْهَمٌ بِدِرْهَمَيْنِ وَالدِّرْهَمُ بِالدِّرْهَمِ وَالدِّينَارُ بِالدِّينَارِ لاَ فَضْلَ بَيْنَهُمَا إِلاَّ وَزْنًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“The Prophet used to give us dates from the collection (mixed)  The Messenger of Allah said: ‘It is not right to give one Sa of dates for two Sa, nor one Dirham for two Dirham. A Dirham for a Dirham and a Dinar for a Dinar is allowed: the only difference between them is in weight (i.e., the weight must be equal.)’” Sahih", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Sa’eed said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1991", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ سَمِعْتُ أَبَا سَعِيدٍ الْخُدْرِيَّ، يَقُولُ الدِّرْهَمُ بِالدِّرْهَمِ وَالدِّينَارُ بِالدِّينَارِ ‏.‏ فَقُلْتُ إِنِّي سَمِعْتُ ابْنَ عَبَّاسٍ يَقُولُ غَيْرَ ذَلِكَ ‏.‏ قَالَ أَمَا إِنِّي لَقِيتُ ابْنَ عَبَّاسٍ فَقُلْتُ أَخْبِرْنِي عَنْ هَذَا الَّذِي تَقُولُ فِي الصَّرْفِ أَشَىْءٌ سَمِعْتَهُ مِنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ أَمْ شَىْءٌ وَجَدْتَهُ فِي كِتَابِ اللَّهِ ‏.‏ فَقَالَ مَا وَجَدْتُهُ فِي كِتَابِ اللَّهِ وَلاَ سَمِعْتُهُ مِنْ رَسُولِ اللَّهِ وَلَكِنْ أَخْبَرَنِي أُسَامَةُ بْنُ زَيْدٍ أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِنَّمَا الرِّبَا فِي النَّسِيئَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I heard Abu Saeed Al-Khudri say: 'A Dirham for a Dirham and a Dinar for a Dinar.' So I said: 'I heard Ibn 'Abbas say something other than that.' He said: 'But I met Ibn 'Abbas and said: \"Tell me about what you say concerning  exchange is it something that you heard from the Messenger of Allah (ﷺ) or something that You found in the Book of Allah?\" He said: \"I did not find it in the Book of Allah, and I did not hear it from the Messenger of Allah; rather Usamah bin Zaid told me that the Messenger of Allah (ﷺ) said: \"Usury is only in credit.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Hurairah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1992", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، أَنْبَأَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ سُلَيْمَانَ بْنِ عَلِيٍّ الرِّبْعِيِّ، عَنْ أَبِي الْجَوْزَاءِ، قَالَ سَمِعْتُهُ يَأْمُرُ، بِالصَّرْفِ - يَعْنِي ابْنَ عَبَّاسٍ - وَيُحَدَّثُ ذَلِكَ عَنْهُ ثُمَّ بَلَغَنِي أَنَّهُ رَجَعَ عَنْ ذَلِكَ فَلَقِيتُهُ بِمَكَّةَ فَقُلْتُ إِنَّهُ بَلَغَنِي أَنَّكَ رَجَعْتَ ‏.‏ قَالَ نَعَمْ إِنَّمَا كَانَ ذَلِكَ رَأْيًا مِنِّي وَهَذَا أَبُو سَعِيدٍ يُحَدِّثُ عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ أَنَّهُ نَهَى عَنِ الصَّرْفِ ‏.‏", "bengali": "", "english": "\"I heard him meaning Ibn 'Abbas allowing exchange (of Dirhams for Dirham etc., if extra was given) and that was narrated from him. Then I heard that he has taken back this opinion. I met him in Makkah and said: 'I heard that you had taken back (your opinion).' He said: 'Yes. That was just my own opinion, but Abu Sa'eed narrated from the Messenger of Allah (ﷺ) that he forbade exchange (of like items if extra is given).\"'", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان کو حکم دیا کہ شوہ", "grades": "", "reference": "", "international_number": "1992", "narrator_chain": "It was narrated that Abu Jawza' said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1993", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، سَمِعَ مَالِكَ بْنَ أَوْسِ بْنِ الْحَدَثَانِ، يَقُولُ سَمِعْتُ عُمَرَ، يَقُولُ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الذَّهَبُ بِالْوَرِقِ رِبًا إِلاَّ هَاءَ وَهَاءَ ‏\"\"‏ ‏.‏ قَالَ أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ سَمِعْتُ سُفْيَانَ يَقُولُ الذَّهَبُ بِالْوَرِقِ احْفَظُوا ‏.‏\"", "bengali": "", "english": "\"I heard 'Umar say: \"The Messenger of Allah (ﷺ), said: 'Gold for silver is usury, unless it is exchanged on the spot.\"' (Sahih) Abu Bakr bin Abu-Shaibah said: \"I heard sufyan saying: 'Gold for silver.\" memorize (this).", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Zuhri heard Malik bin Aws bin Hadathan say:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1994", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنِ ابْنِ شِهَابٍ، عَنْ مَالِكِ بْنِ أَوْسِ بْنِ الْحَدَثَانِ، قَالَ أَقْبَلْتُ أَقُولُ مَنْ يَصْطَرِفُ الدَّرَاهِمَ فَقَالَ طَلْحَةُ بْنُ عُبَيْدِ اللَّهِ وَهُوَ عِنْدَ عُمَرَ بْنِ الْخَطَّابِ أَرِنَا ذَهَبَكَ ثُمَّ ائْتِنَا إِذَا جَاءَ خَازِنُنَا نُعْطِكَ وَرِقَكَ ‏.‏ فَقَالَ عُمَرُ كَلاَّ وَاللَّهِ لَتُعْطِيَنَّهُ وَرِقَهُ أَوْ لَتَرُدَّنَّ إِلَيْهِ ذَهَبَهُ فَإِنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ الْوَرِقُ بِالذَّهَبِ رِبًا إِلاَّ هَاءَ وَهَاءَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I came saying. 'Who will exchange Dirham?' Talhah bin 'Ubaidullah, who was with 'Umar bin Khattab, said: 'Show us your gold, then come to us; when our treasure comes, we will give you your silver.' 'Umar said: 'No, by Allah, you will give him silver (now), or give him back his gold, for the Messenger of Allah (ﷺ) said: \"Silver for gold is usury, unless it is exchanged on the spot.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Malik bin Aws bin Hadathan said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1995", "arabic": "حَدَّثَنَا أَبُو إِسْحَاقَ الشَّافِعِيُّ، إِبْرَاهِيمُ بْنُ مُحَمَّدِ بْنِ الْعَبَّاسِ حَدَّثَنِي أَبِي، عَنْ أَبِيهِ الْعَبَّاسِ بْنِ عُثْمَانَ بْنِ شَافِعٍ، عَنْ عُمَرَ بْنِ مُحَمَّدِ بْنِ عَلِيِّ بْنِ أَبِي طَالِبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الدِّينَارُ بِالدِّينَارِ وَالدِّرْهَمُ بِالدِّرْهَمِ لاَ فَضْلَ بَيْنَهُمَا فَمَنْ كَانَتْ لَهُ حَاجَةٌ بِوَرِقٍ فَلْيَصْطَرِفْهَا بِذَهَبٍ وَمَنْ كَانَتْ لَهُ حَاجَةٌ بِذَهَبٍ فَلْيَصْطَرِفْهَا بِالْوَرِقِ وَالصَّرْفُ هَاءَ وَهَاءَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "'The Messenger of Allah (ﷺ) said: 'Dinar for Dinar, Dirham for Dirham, with no increase between them. Whoever has need of silver, let him trade gold for it, and whoever has need of gold, let him trade silver for it, and let the transaction be done on the spot.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Umar bin Muhammad bin 'Ali bin abi Talib, from his father, that his grandfather said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1996", "arabic": "حَدَّثَنَا إِسْحَاقُ بْنُ إِبْرَاهِيمَ بْنِ حَبِيبٍ، وَسُفْيَانُ بْنُ وَكِيعٍ، وَمُحَمَّدُ بْنُ عُبَيْدِ بْنِ ثَعْلَبَةَ الْحِمَّانِيُّ، قَالُوا حَدَّثَنَا عُمَرُ بْنُ عُبَيْدٍ الطَّنَافِسِيُّ، حَدَّثَنَا عَطَاءُ بْنُ السَّائِبِ، أَوْ سِمَاكٌ - وَلاَ أَعْلَمُهُ إِلاَّ سِمَاكًا - عَنْ سَعِيدِ بْنِ جُبَيْرٍ عَنِ ابْنِ عُمَرَ قَالَ كُنْتُ أَبِيعُ الإِبِلَ فَكُنْتُ آخُذُ الذَّهَبَ مِنَ الْفِضَّةِ وَالْفِضَّةَ مِنَ الذَّهَبِ وَالدَّنَانِيرَ مِنَ الدَّرَاهِمِ وَالدَّرَاهِمَ مِنَ الدَّنَانِيرِ ‏.‏ فَسَأَلْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَقَالَ ‏ ‏ إِذَا أَخَذْتَ أَحَدَهُمَا وَأَعْطَيْتَ الآخَرَ فَلاَ تُفَارِقْ صَاحِبَكَ وَبَيْنَكَ وَبَيْنَهُ لَبْسٌ ‏\"\"‏ ‏.‏ حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، حَدَّثَنَا يَعْقُوبُ بْنُ إِسْحَاقَ، أَنْبَأَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ سِمَاكِ بْنِ حَرْبٍ، عَنْ سَعِيدِ بْنِ جُبَيْرٍ، عَنِ ابْنِ عُمَرَ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ نَحْوَهُ ‏.‏\"", "bengali": "", "english": "\"I used to sell camels, and I used to buy gold for silver and silver for gold, Dinar for Dirham and Dirham for Dinar. I asked the Prophet (ﷺ) about that, and he said: 'If you take one of them and give the other, then you and your companion should not separate until everything is clear (i.e., the exchange is completed).’” (Hasan) Another chain with similar wording.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Ibn 'Umar said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1997", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَسُوَيْدُ بْنُ سَعِيدٍ، وَهَارُونُ بْنُ إِسْحَاقَ، قَالُوا أَنْبَأَنَا الْمُعْتَمِرُ بْنُ سُلَيْمَانَ، عَنْ مُحَمَّدِ بْنِ فَضَاءٍ، عَنْ أَبِيهِ، عَنْ عَلْقَمَةَ بْنِ عَبْدِ اللَّهِ، عَنْ أَبِيهِ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنْ كَسْرِ سِكَّةِ الْمُسْلِمِينَ الْجَائِزَةِ بَيْنَهُمْ إِلاَّ مِنْ بَأْسٍ ‏\"‏ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) forbade breaking the coins of the Muslims that are in circulation among them, without any necessary reason.”(1)", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے جتنی غیرت خدیجہ رضی اللہ عنہا پر کی اتنی کسی عور", "grades": "", "reference": "", "international_number": "1997", "narrator_chain": "It was narrated from 'Alqamah bin 'Abdullah that his father said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1998", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، وَإِسْحَاقُ بْنُ سُلَيْمَانَ، قَالاَ حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ عَبْدِ اللَّهِ بْنِ يَزِيدَ، مَوْلَى الأَسْوَدِ بْنِ سُفْيَانَ أَنَّ زَيْدًا أَبَا عَيَّاشٍ، - مَوْلًى لِبَنِي زُهْرَةَ - أَخْبَرَهُ أَنَّهُ، سَأَلَ سَعْدَ بْنَ أَبِي وَقَّاصٍ عَنِ اشْتِرَاءِ الْبَيْضَاءِ، بِالسُّلْتِ فَقَالَ لَهُ سَعْدٌ أَيَّتُهُمَا أَفْضَلُ قَالَ الْبَيْضَاءُ ‏.‏ فَنَهَانِي عَنْهُ وَقَالَ إِنِّي سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ سُئِلَ عَنِ اشْتِرَاءِ الرُّطَبِ بِالتَّمْرِ فَقَالَ ‏ ‏ أَيَنْقُصُ الرُّطَبُ إِذَا يَبِسَ ‏\"\"‏ ‏.‏ قَالُوا نَعَمْ ‏.‏ فَنَهَى عَنْ ذَلِكَ ‏.‏\"", "bengali": "", "english": "Zaid, Abu 'Ayyash, the freed slave of Bani Zuhrah, told him that he asked Sa'd bin Abu Waqqas about buying wheat with barley. Sa'd said to him: \"Which of them is better?\" He said: \"Wheat.\" He told him not to do that and said: \"I heard the Messenger of Allah (ﷺ) being asked about buying fresh dates with dried dates, and he said: 'Do fresh dates decrease in weight when they become dry?' They said: 'Yes.' So he told them not to do that.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Abdullah bin Yazid, the freed slave of Al-Aswad bin Sufyan, that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "1999", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الْمُزَابَنَةِ ‏.‏ وَالْمُزَابَنَةُ أَنْ يَبِيعَ الرَّجُلُ تَمْرَ حَائِطِهِ إِنْ كَانَتْ نَخْلاً بِتَمْرٍ كَيْلاً وَإِنْ كَانَتْ كَرْمًا أَنْ يَبِيعَهُ بِزَبِيبٍ كَيْلاً وَإِنْ كَانَتْ زَرْعًا أَنْ يَبِيعَهُ بِكَيْلِ طَعَامٍ نَهَى عَنْ ذَلِكَ كُلِّهِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) forbade the Muzabanah. The Muzdbanah means when a man sells the dates of his grove when they are still on the tree, for a measure of dty dates; or, if it is grapes, he sells them when they are still on the vine, for a measure of raisins; or if it is a crop, he sells it for food, estimating the amount (of the crop in the field). He forbade all of these things.\"", "french": "", "indonesian": "", "russian": "", "urdu": "مسور بن مخرمہ رضی اللہ عنہما کہتے ہیں کہ  علی بن ابی طالب رضی اللہ عنہ نے ابوجہل کی بیٹی کو پیغام دی", "grades": "", "reference": "", "international_number": "1999", "narrator_chain": "It was narrated that 'Abduilah bin 'Umar said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2000", "arabic": "حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ أَيُّوبَ، عَنْ أَبِي الزُّبَيْرِ، وَسَعِيدِ بْنِ مِينَاءَ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ نَهَى عَنِ الْمُحَاقَلَةِ وَالْمُزَابَنَةِ ‏.‏", "bengali": "", "english": "the Messenger of Allah (ﷺ) forbade the Muhaqalah and the Muzabanah.", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی تھیں  کیا عورت اس بات سے نہیں شرماتی کہ وہ اپنے آپ کو نبی اکرم", "grades": "", "reference": "", "international_number": "2000", "narrator_chain": "lt was narrated from Sabir bin 'Abdullah that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2001", "arabic": "حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ طَارِقِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ رَافِعِ بْنِ خَدِيجٍ، قَالَ نَهَى رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ عَنِ الْمُحَاقَلَةِ وَالْمُزَابَنَةِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) forbade the Muhaqalah and the Muzabanah.\"", "french": "", "indonesian": "", "russian": "", "urdu": "ثابت کہتے ہیں کہ  ہم انس بن مالک رضی اللہ عنہ کے ساتھ بیٹھے تھے، ان کے پاس ان کی ایک بیٹی تھی، انس ر", "grades": "", "reference": "", "international_number": "2001", "narrator_chain": "It was narrated that Rafi, bin Khadij said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2002", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَمُحَمَّدُ بْنُ الصَّبَّاحِ، قَالاَ حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ سَالِمٍ، عَنْ أَبِيهِ، حَدَّثَنِي زَيْدُ بْنُ ثَابِتٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ رَخَّصَ فِي الْعَرَايَا ‏.‏", "bengali": "", "english": "\"Zaid bin Thabit narrated to me that the Messenger of Allah (ﷺ) gave a concession regarding the sale of 'Araya.”", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  قبیلہ بنی فزارہ کا ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے پاس آ", "grades": "", "reference": "", "international_number": "2002", "narrator_chain": "It was narrated from Salim from his father:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2003", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، أَنَّهُ قَالَ حَدَّثَنِي زَيْدُ بْنُ ثَابِتٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ أَرْخَصَ فِي بَيْعِ الْعَرِيَّةِ بِخَرْصِهَا تَمْرًا ‏.‏ قَالَ يَحْيَى الْعَرِيَّةُ أَنْ يَشْتَرِيَ الرَّجُلُ ثَمَرَ النَّخَلاَتِ بِطَعَامِ أَهْلِهِ رُطَبًا بِخَرْصِهَا تَمْرًا ‏.‏", "bengali": "", "english": "\"Zaid bin Thabit told me that the Messenger of Allah (ﷺ) gave a concession regarding the sale of the estimated harvest of 'Araya return for dried dates.\" (Sahih) Yahya (one of the narrators) said: \"The 'Araya is when a man purchases dates on the trees for food that his family has that is ripe, by estimating them (the dates).\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  ایک بدوی  ( دیہاتی )  نبی اکرم صلی اللہ علیہ وسلم کے پ", "grades": "", "reference": "", "international_number": "2003", "narrator_chain": "It was narrated from 'Abdullah bin 'Umar that he said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2004", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ سَعِيدِ بْنِ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنِ الْحَسَنِ، عَنْ سَمُرَةَ بْنِ جُنْدُبٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ نَهَى عَنْ بَيْعِ الْحَيَوَانِ بِالْحَيَوَانِ نَسِيئَةً ‏.‏", "bengali": "", "english": "the Messenger of Allah (ﷺ) forbade selling animals for animals on credit.", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  عبد بن زمعہ اور سعد رضی اللہ عنہما دونوں زمعہ کی لونڈی", "grades": "", "reference": "", "international_number": "2004", "narrator_chain": "It was narrated from Samurah bin Jundub that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2005", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، وَأَبُو خَالِدٍ عَنْ حَجَّاجٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ لاَ بَأْسَ الْحَيَوَانُ بِالْحَيَوَانِ وَاحِدًا بِاثْنَيْنِ يَدًا بِيَدٍ ‏\"\"‏ ‏.‏ وَكَرِهَهُ نَسِيئَةً ‏.‏\"", "bengali": "", "english": "\"There is nothing wrong with selling animals, one for two, hand to hand,\" but he disliked selling them on credit.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2006", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا الْحُسَيْنُ بْنُ عُرْوَةَ، ح وَحَدَّثَنَا أَبُو عُمَرَ، حَفْصُ بْنُ عَمْرٍو حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، قَالاَ حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ ثَابِتٍ، عَنْ أَنَسٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ اشْتَرَى صَفِيَّةَ بِسَبْعَةِ أَرْؤُسٍ ‏.‏ قَالَ عَبْدُ الرَّحْمَنِ مِنْ دِحْيَةَ الْكَلْبِيِّ ‏.‏", "bengali": "", "english": "the Prophet (ﷺ) bought Safiyyah for seven slaves. (Sahih) (One of the narrators) 'Abdur-Rahman said: \"From Dihyah Kalbi.'", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  بچہ صاحب فراش کا ہے اور ز", "grades": "", "reference": "", "international_number": "2006", "narrator_chain": "It was narrated from Anas that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2007", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا الْحَسَنُ بْنُ مُوسَى، عَنْ حَمَّادِ بْنِ سَلَمَةَ، عَنْ عَلِيِّ بْنِ زَيْدٍ، عَنْ أَبِي الصَّلْتِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ أَتَيْتُ لَيْلَةَ أُسْرِيَ بِي عَلَى قَوْمٍ بُطُونُهُمْ كَالْبُيُوتِ فِيهَا الْحَيَّاتُ تُرَى مِنْ خَارِجِ بُطُونِهِمْ فَقُلْتُ مَنْ هَؤُلاَءِ يَا جِبْرَائِيلُ قَالَ هَؤُلاَءِ أَكَلَةُ الرِّبَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "' \"'On the night in which I was taken on the Night Journey (Al-Isra'), I came to people whose stomachs were like houses, in which there were snakes that could be seen from outside their stomachs. I said: 'Who are these, O Jibra’il?’ He said: 'They are the ones who consumed usury.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2008", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ أَبِي مَعْشَرٍ، عَنْ سَعِيدٍ الْمَقْبُرِيِّ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الرِّبَا سَبْعُونَ حُوبًا أَيْسَرُهَا أَنْ يَنْكِحَ الرَّجُلُ أُمَّهُ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"There are seventy degrees of usury, the least of which is equivalent to a man having intercourse with his mother.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2009", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عَلِيٍّ الصَّيْرَفِيُّ أَبُو حَفْصٍ، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنْ شُعْبَةَ، عَنْ زُبَيْدٍ، عَنْ إِبْرَاهِيمَ، عَنْ مَسْرُوقٍ، عَنْ عَبْدِ اللَّهِ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ الرِّبَا ثَلاَثَةٌ وَسَبْعُونَ بَابًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"There are seventy-three degrees of usury.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Abdullah that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2010", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، حَدَّثَنَا سَعِيدٌ، عَنْ قَتَادَةَ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، قَالَ إِنَّ آخِرَ مَا نَزَلَتْ آيَةُ الرِّبَا وَإِنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ قُبِضَ وَلَمْ يُفَسِّرْهَا لَنَا فَدَعُوا الرِّبَا وَالرِّيبَةَ ‏.‏", "bengali": "", "english": "\"The last thing to be revealed was the Verse on usury but the Messenger of Allah (ﷺ) died before he had explained it to us. So give up usury (interest) and doubtful things.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنی بیٹی زی", "grades": "", "reference": "", "international_number": "2010", "narrator_chain": "It was narrated that 'Umar bin Khattab said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2011", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، حَدَّثَنَا سِمَاكُ بْنُ حَرْبٍ، قَالَ سَمِعْتُ عَبْدَ الرَّحْمَنِ بْنَ عَبْدِ اللَّهِ، يُحَدِّثُ عَنْ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ، أَنَّ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ لَعَنَ آكِلَ الرِّبَا وَمُوكِلَهُ وَشَاهِدَيْهِ وَكَاتِبَهُ ‏.‏", "bengali": "", "english": "Xthe Messenger of Allah (ﷺ) cursed the one who consumes usury, the one who pays it, those who witness it and the one who writes it down.", "french": "", "indonesian": "", "russian": "", "urdu": "جدامہ بنت وہب اسدیہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  م", "grades": "", "reference": "", "international_number": "2011", "narrator_chain": "It was narrated from 'Abdullah bin Mas'ud that :", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2012", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا إِسْمَاعِيلُ ابْنُ عُلَيَّةَ، حَدَّثَنَا دَاوُدُ بْنُ أَبِي هِنْدٍ، عَنْ سَعِيدِ بْنِ أَبِي خَيْرَةَ، عَنِ الْحَسَنِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ لَيَأْتِيَنَّ عَلَى النَّاسِ زَمَانٌ لاَ يَبْقَى مِنْهُمْ أَحَدٌ إِلاَّ أَكَلَ الرِّبَا فَمَنْ لَمْ يَأْكُلْ أَصَابَهُ مِنْ غُبَارِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "“There will come a time when there will be no one left who does not consume usury (interest), and whoever does not consume it will nevertheless be affected by it.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2013", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ جَعْفَرٍ، حَدَّثَنَا عَمْرُو بْنُ عَوْنٍ، حَدَّثَنَا يَحْيَى بْنُ أَبِي زَائِدَةَ، عَنْ إِسْرَائِيلَ، عَنْ رُكَيْنِ بْنِ الرَّبِيعِ بْنِ عَمِيلَةَ، عَنْ أَبِيهِ، عَنِ ابْنِ مَسْعُودٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ مَا أَحَدٌ أَكْثَرَ مِنَ الرِّبَا إِلاَّ كَانَ عَاقِبَةُ أَمْرِهِ إِلَى قِلَّةٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"There is no one who deals in usury a great deal (to increase his wealth) but he will end up with little (i.e., his wealth will be decreased).\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn Mas'ud that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2014", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ ابْنِ أَبِي نَجِيحٍ، عَنْ عَبْدِ اللَّهِ بْنِ كَثِيرٍ، عَنْ أَبِي الْمِنْهَالِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَدِمَ النَّبِيُّ ـ صلى الله عليه وسلم ـ وَهُمْ يُسْلِفُونَ فِي التَّمْرِ السَّنَتَيْنِ وَالثَّلاَثَ فَقَالَ ‏ ‏ مَنْ أَسْلَفَ فِي تَمْرٍ فَلْيُسْلِفْ فِي كَيْلٍ مَعْلُومٍ وَوَزْنٍ مَعْلُومٍ إِلَى أَجَلٍ مَعْلُومٍ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"When the Prophet (ﷺ) came (to Al-Madinah), they used to pay in advance for dates, two or three years in advance. He said: 'Whoever pays in advance for dates, let him pay for a known amount or a known weight, to be delivered at a known time.’”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Ibn 'Abbas said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2015", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، عَنْ مُحَمَّدِ بْنِ حَمْزَةَ بْنِ يُوسُفَ بْنِ عَبْدِ اللَّهِ بْنِ سَلاَمٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ عَبْدِ اللَّهِ بْنِ سَلاَمٍ، قَالَ جَاءَ رَجُلٌ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ إِنَّ بَنِي فُلاَنٍ أَسْلَمُوا - لِقَوْمٍ مِنَ الْيَهُودِ - وَإِنَّهُمْ قَدْ جَاعُوا فَأَخَافُ أَنْ يَرْتَدُّوا ‏.‏ فَقَالَ النَّبِيُّ ـ صلى الله عليه وسلم ـ ‏\"‏ مَنْ عِنْدَهُ ‏\"‏ ‏.‏ فَقَالَ رَجُلٌ مِنَ الْيَهُودِ عِنْدِي كَذَا وَكَذَا - لِشَىْءٍ قَدْ سَمَّاهُ أُرَاهُ قَالَ ثَلاَثُمِائَةِ دِينَارٍ بِسِعْرِ كَذَا وَكَذَا مِنْ حَائِطِ بَنِي فُلاَنٍ ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ بِسِعْرِ كَذَا وَكَذَا إِلَى أَجَلِ كَذَا وَكَذَا وَلَيْسَ مِنْ حَائِطِ بَنِي فُلاَنٍ ‏\"‏ ‏.‏", "bengali": "", "english": "\"A man came to the Prophet (ﷺ) and said, 'The tribe of Banu so-and- so, who were descended from the Jews, have become Muslim, and they are starving, and I am afraid that they may apostatize.' The Prophet (ﷺ) said:  'Who has something with him?' A Jewish man said: 'I have such and such, and he named it, and I think he said three hundred Dinar for such and such 'an amount (of produce) from the garden of the tribe of Banu so-and-so.' The Messenger of Allah (ﷺ) said: 'For such and such a price at such and such a time, but not from the garden of the tribe of Banu so-and- so.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  حرام کام حلال", "grades": "", "reference": "", "international_number": "2015", "narrator_chain": "It was narrated from Muhammad bin Hamzah bin Yusuf bin 'Abdullah bin Salam, from his father, that his grandfather 'Abdullah bin Salam said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2016", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، وَعَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، قَالاَ حَدَّثَنَا شُعْبَةُ، - قَالَ يَحْيَى عَنْ عَبْدِ اللَّهِ بْنِ أَبِي الْمُجَالِدِ، وَقَالَ عَبْدُ الرَّحْمَنِ، عَنِ ابْنِ أَبِي الْمُجَالِدِ، - قَالَ امْتَرَى عَبْدُ اللَّهِ بْنُ شَدَّادٍ وَأَبُو بُرْدَةَ فِي السَّلَمِ فَأَرْسَلُونِي إِلَى عَبْدِ اللَّهِ بْنِ أَبِي أَوْفَى فَسَأَلْتُهُ فَقَالَ كُنَّا نُسْلِمُ عَلَى عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ وَعَهْدِ أَبِي بَكْرٍ وَعُمَرَ فِي الْحِنْطَةِ وَالشَّعِيرِ وَالزَّبِيبِ وَالتَّمْرِ عِنْدَ قَوْمٍ مَا عِنْدَهُمْ ‏.‏ فَسَأَلْتُ ابْنَ أَبْزَى فَقَالَ مِثْلَ ذَلِكَ ‏.‏\"", "bengali": "", "english": "\"Abdullah bin Shaddad and Abu Barzah had a dispute about paying in advance. They sent me to 'Abdullah bin Abu Awfa to ask him about it. He said: 'We used to make payments in advance at the time of the Messenger of Allah (ﷺ) and the time of Abu Bakr and 'Umar, for wheat, barley, raisins and dates, to people who did not yet possess those things.' I asked Ibn Abza, and he said something similar.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Mujalid said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2017", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا شُجَاعُ بْنُ الْوَلِيدِ، حَدَّثَنَا زِيَادُ بْنُ خَيْثَمَةَ، عَنْ سَعْدٍ، عَنْ عَطِيَّةَ، عَنْ أَبِي سَعِيدٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا أَسْلَفْتَ فِي شَىْءٍ فَلاَ تَصْرِفْهُ إِلَى غَيْرِهِ ‏\"\"‏ ‏.‏ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا شُجَاعُ بْنُ الْوَلِيدِ، عَنْ زِيَادِ بْنِ خَيْثَمَةَ، عَنْ عَطِيَّةَ، عَنْ أَبِي سَعِيدٍ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَذَكَرَ مِثْلَهُ وَلَمْ يَذْكُرْ سَعْدًا ‏.‏\"", "bengali": "", "english": "\"When you have paid in advance for something, do not exchange it for something else.\" (Da'if)Another chain with similar wording.", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Sa'eed that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2018", "arabic": "حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِي إِسْحَاقَ، عَنِ النَّجْرَانِيِّ، قَالَ قُلْتُ لِعَبْدِ اللَّهِ بْنِ عُمَرَ أُسْلِمُ فِي نَخْلٍ قَبْلَ أَنْ يُطْلِعَ قَالَ لاَ ‏.‏ قُلْتُ لِمَ قَالَ إِنَّ رَجُلاً أَسْلَمَ فِي حَدِيقَةِ نَخْلٍ فِي عَهْدِ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ قَبْلَ أَنْ يُطْلِعَ النَّخْلُ فَلَمْ يُطْلِعِ النَّخْلُ شَيْئًا ذَلِكَ الْعَامَ فَقَالَ الْمُشْتَرِي هُوَ لِي حَتَّى يُطْلِعَ ‏.‏ وَقَالَ الْبَائِعُ إِنَّمَا بِعْتُكَ النَّخْلَ هَذِهِ السَّنَةَ ‏.‏ فَاخْتَصَمَا إِلَى رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فَقَالَ لِلْبَائِعِ ‏\"‏ أَخَذَ مِنْ نَخْلِكَ شَيْئًا ‏\"‏ ‏.‏ قَالَ لاَ ‏.‏ قَالَ ‏\"‏ فَبِمَ تَسْتَحِلُّ مَالَهُ ارْدُدْ عَلَيْهِ مَا أَخَذْتَ مِنْهُ وَلاَ تُسْلِمُوا فِي نَخْلٍ حَتَّى يَبْدُوَ صَلاَحُهُ ‏\"‏ ‏.‏", "bengali": "", "english": "\"I said to 'Abdullah bin 'Umar: 'Can I pay in advance for a date palm before it bears fruit?' He said: 'No.' I said: 'Why not?' He said: 'A man paid in advance for a grove of trees during the time of the Messenger of Allah (ﷺ), before they had produced any fruit, and they did not bear anything that year. The purchaser said: 'They belong to me until they produce but the seller said: 'I only sold the trees to you for this year! They referred their dispute to the Messenger of Allah who said to the seller: 'Did he take anything from your date palms?' He said: 'No.' He said: 'Then why do you regard his wealth as lawful for You? Give back what you took from him, and do not take payment in advance for date palms until their usefulness appears.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  حلال چیزوں میں ا", "grades": "", "reference": "", "international_number": "2018", "narrator_chain": "It was narrated that Najrani said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2019", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا مُسْلِمُ بْنُ خَالِدٍ، حَدَّثَنَا زَيْدُ بْنُ أَسْلَمَ، عَنْ عَطَاءِ بْنِ يَسَارٍ، عَنْ أَبِي رَافِعٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ اسْتَسْلَفَ مِنْ رَجُلٍ بَكْرًا وَقَالَ ‏\"‏ إِذَا جَاءَتْ إِبِلُ الصَّدَقَةِ قَضَيْنَاكَ ‏\"‏ ‏.‏ فَلَمَّا قَدِمَتْ قَالَ ‏\"‏ يَا أَبَا رَافِعٍ اقْضِ هَذَا الرَّجُلَ بَكْرَهُ ‏\"‏ ‏.‏ فَلَمْ أَجِدْ إِلاَّ رَبَاعِيًا فَصَاعِدًا فَأَخْبَرْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَقَالَ ‏\"‏ أَعْطِهِ فَإِنَّ خَيْرَ النَّاسِ أَحْسَنُهُمْ قَضَاءً ‏\"‏ ‏.‏", "bengali": "", "english": "the Prophet (ﷺ) asked a man to give as a loan a young camel and said: “When the camels of the Sadaqah come, we will pay you back.” When the camels came, he said: \" O Abu Rafi', pay this man back for his Young camel.\" But all I could find was a seven-year-old camel or that which is better. I told the Prophet  (ﷺ) and he said: \"Give it to him, for the best of People are those who are best in repaying.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  میں نے اپنی بیوی کو حیض کی حالت میں طلاق دے دی، عمر رضی ا", "grades": "", "reference": "", "international_number": "2019", "narrator_chain": "It was narrated from Abu Rafi' that:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2020", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، حَدَّثَنَا مُعَاوِيَةُ بْنُ صَالِحٍ، حَدَّثَنِي سَعِيدُ بْنُ هَانِئٍ، قَالَ سَمِعْتُ الْعِرْبَاضَ بْنَ سَارِيَةَ، يَقُولُ كُنْتُ عِنْدَ النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ أَعْرَابِيٌّ اقْضِنِي بَكْرِي ‏.‏ فَأَعْطَاهُ بَعِيرًا مُسِنًّا فَقَالَ الأَعْرَابِيُّ يَا رَسُولَ اللَّهِ هَذَا أَسَنُّ مِنْ بَعِيرِي ‏.‏ فَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ خَيْرُ النَّاسِ خَيْرُهُمْ قَضَاءً ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"I heard 'Irbad bin Sariyah say: 'I was with the Prophet (ﷺ) and a Bedouin said: \"Pay me back for my young camel, and he gave him an older (i.e., better) camel.\" He said: 'O Messenger of Allah! It is older (i.e., better) than my camel.' The Messenger of Allah (ﷺ) said: 'The best of people are those who are best in repaying.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "Sa'eed bin Hani' said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2021", "arabic": "حَدَّثَنَا عُثْمَانُ، وَأَبُو بَكْرٍ ابْنَا أَبِي شَيْبَةَ قَالاَ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ سُفْيَانَ، عَنْ إِبْرَاهِيمَ بْنِ مُهَاجِرٍ، عَنْ مُجَاهِدٍ، عَنْ قَائِدِ السَّائِبِ، عَنِ السَّائِبِ، قَالَ لِلنَّبِيِّ ـ صلى الله عليه وسلم ـ كُنْتَ شَرِيكِي فِي الْجَاهِلِيَّةِ فَكُنْتَ خَيْرَ شَرِيكٍ كُنْتَ لاَ تُدَارِينِي وَكُنْتَ لاَ تُمَارِينِي ‏.‏", "bengali": "", "english": "\"You were my partner during the Ignorance period and you were the best of partners, you did not contend or dispute.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں  طلاق سنی یہ ہے کہ عورت کو ہر طہر میں ایک طلاق دے، جب تیسری ب", "grades": "", "reference": "", "international_number": "2021", "narrator_chain": "It was narrated that Sa'ib said to the Prophet (ﷺ):", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2022", "arabic": "حَدَّثَنَا أَبُو السَّائِبِ، سَلْمُ بْنُ جُنَادَةَ حَدَّثَنَا أَبُو دَاوُدَ الْحَفَرِيُّ، عَنْ سُفْيَانَ، عَنْ أَبِي إِسْحَاقَ، عَنْ أَبِي عُبَيْدَةَ، عَنْ عَبْدِ اللَّهِ، قَالَ اشْتَرَكْتُ أَنَا وَسَعْدٌ، وَعَمَّارٌ، يَوْمَ بَدْرٍ فِيمَا نُصِيبُ فَلَمْ أَجِئْ أَنَا وَلاَ عَمَّارٌ بِشَىْءٍ وَجَاءَ سَعْدٌ بِرَجُلَيْنِ ‏.‏", "bengali": "", "english": "\"Sa'd, 'Ammar and I entered into a partnership on the day of Badr, (agreeing to share) whatever was allotted to us. 'Ammar and I did not get anything, but Sa'd got two men (slaves).\"", "french": "", "indonesian": "", "russian": "", "urdu": "ابو غلاب یونس بن جبیر کہتے ہیں کہ  میں نے ابن عمر رضی اللہ عنہما سے اس شخص کے بارے میں پوچھا جس نے ا", "grades": "", "reference": "", "international_number": "2022", "narrator_chain": "It was narrated that 'Abdullah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2023", "arabic": "حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا بِشْرُ بْنُ ثَابِتٍ الْبَزَّارُ، حَدَّثَنَا نَصْرُ بْنُ الْقَاسِمِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ دَاوُدَ، عَنْ صَالِحِ بْنِ صُهَيْبٍ، عَنْ أَبِيهِ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ ثَلاَثٌ فِيهِنَّ الْبَرَكَةُ الْبَيْعُ إِلَى أَجَلٍ وَالْمُقَارَضَةُ وَإِخْلاَطُ الْبُرِّ بِالشَّعِيرِ لِلْبَيْتِ لاَ لِلْبَيْعِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) said: 'There are three things in which there is blessing: A sale with deferred payment; Muqaradhah (profit sharing); and mixing wheat with barley for one's house, but not for sale.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "lt was narrated from Salih bin Suhaib that his father said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2024", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا ابْنُ أَبِي زَائِدَةَ، عَنِ الأَعْمَشِ، عَنْ عُمَارَةَ بْنِ عُمَيْرٍ، عَنْ عَمَّتِهِ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِنَّ أَطْيَبَ مَا أَكَلْتُمْ مِنْ كَسْبِكُمْ وَإِنَّ أَوْلاَدَكُمْ مِنْ كَسْبِكُمْ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The best of your provision is what you earn, and your children are part of what you earn. \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Aishah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2025", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا عِيسَى بْنُ يُونُسَ، حَدَّثَنَا يُوسُفُ بْنُ إِسْحَاقَ، عَنْ مُحَمَّدِ بْنِ الْمُنْكَدِرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَجُلاً، قَالَ يَا رَسُولَ اللَّهِ إِنَّ لِي مَالاً وَوَلَدًا وَإِنَّ أَبِي يُرِيدُ أَنْ يَجْتَاحَ مَالِي فَقَالَ ‏ ‏ أَنْتَ وَمَالُكَ لأَبِيكَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"O Messenger of Allah, I have wealth and a son, and my father wants to take all my wealth.\" He said: \"You and your wealth belong to your father.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Jabir bin 'Abdullah that a man said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2026", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، وَيَحْيَى بْنُ حَكِيمٍ، قَالاَ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا حَجَّاجٌ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ جَاءَ رَجُلٌ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَ إِنَّ أَبِي اجْتَاحَ مَالِي ‏.‏ فَقَالَ ‏\"‏ أَنْتَ وَمَالُكَ لأَبِيكَ ‏\"‏ ‏.‏ وَقَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏\"‏ إِنَّ أَوْلاَدَكُمْ مِنْ أَطْيَبِ كَسْبِكُمْ فَكُلُوا مِنْ أَمْوَالِهِمْ ‏\"‏ ‏.‏", "bengali": "", "english": "\"A man came to the Messenger of Allah (ﷺ), and said: 'My father is taking all my wealth.' He said: 'You and your wealth belong to your father.' And the Messenger of Allah (ﷺ) said: 'Your children are among the best of your earnings, so eat from your wealth.’”", "french": "", "indonesian": "", "russian": "", "urdu": "زبیر بن عوام رضی اللہ عنہ سے روایت ہے کہ  ان کی زوجیت میں ام کلثوم بنت عقبہ تھیں، انہوں نے حمل کی حا", "grades": "", "reference": "", "international_number": "2026", "narrator_chain": "It was narrated from 'Amr bin Shu'aib, from his father, that his grandfather said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2027", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، وَأَبُو عُمَرَ الضَّرِيرُ قَالُوا حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا هِشَامُ بْنُ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ عَائِشَةَ، قَالَتْ جَاءَتْ هِنْدٌ إِلَى النَّبِيِّ ـ صلى الله عليه وسلم ـ فَقَالَتْ يَا رَسُولَ اللَّهِ إِنَّ أَبَا سُفْيَانَ رَجُلٌ شَحِيحٌ وَلاَ يُعْطِينِي مَا يَكْفِينِي وَوَلَدِي إِلاَّ مَا أَخَذْتُ مِنْ مَالِهِ وَهُوَ لاَ يَعْلَمُ ‏.‏ فَقَالَ ‏ ‏ خُذِي مَا يَكْفِيكِ وَوَلَدَكِ بِالْمَعْرُوفِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "'Hind came to the Prophet (ﷺ) and said: 'O Messenger of Allah, Abu Sufyan is a stingy man and he does not give me enough for me and my child, except for what I take from his wealth without him realizing.' He said: Take what is sufficient for you and your child, on a reasonable basis.' \"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that 'Aishah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2028", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبِي وَأَبُو مُعَاوِيَةَ عَنِ الأَعْمَشِ، عَنْ أَبِي وَائِلٍ، عَنْ مَسْرُوقٍ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا أَنْفَقَتِ الْمَرْأَةُ - وَقَالَ أَبِي فِي حَدِيثِهِ إِذَا أَطْعَمَتِ الْمَرْأَةُ - مِنْ بَيْتِ زَوْجِهَا غَيْرَ مُفْسِدَةٍ كَانَ لَهَا أَجْرُهَا وَلَهُ مِثْلُهُ بِمَا اكْتَسَبَ وَلَهَا بِمَا أَنْفَقَتْ وَلِلْخَازِنِ مِثْلُ ذَلِكَ مِنْ غَيْرِ أَنْ يَنْقُصَ مِنْ أُجُوِرِهِمْ شَيْئًا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"When a woman spends\" and my father said: - \"When a woman feeds (the poor) from her husband's house, without spending too much, she will have her reward, and he will be rewarded likewise because he earned it , and she will be rewarded for what she spent. The same applies to the storekeeper, without anything being detracted from their rewards.”", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Aishah that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2029", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنِي شُرَحْبِيلُ بْنُ مُسْلِمٍ الْخَوْلاَنِيُّ، قَالَ سَمِعْتُ أَبَا أُمَامَةَ الْبَاهِلِيَّ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ ـ صلى الله عليه وسلم ـ يَقُولُ ‏\"‏ لاَ تُنْفِقُ الْمَرْأَةُ مِنْ بَيْتِهَا شَيْئًا إِلاَّ بِإِذْنِ زَوْجِهَا ‏\"‏ ‏.‏ قَالُوا يَا رَسُولَ اللَّهِ وَلاَ الطَّعَامَ قَالَ ‏\"‏ ذَلِكَ أَفْضَلُ أَمْوَالِنَا ‏\"‏ ‏.‏", "bengali": "", "english": "I heard Abu Umamah Al-Bahili say: I heard the Messenger of Allah (ﷺ) say: \" No woman should spend anything from her house without her husband's permission.\" They said: \"O Messenger of Allah, not even food?\" He said: \"That is among the best of our wealth.\"", "french": "", "indonesian": "", "russian": "", "urdu": "مسور بن مخرمہ رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے سبیعہ رضی اللہ عنہا کو ح", "grades": "", "reference": "", "international_number": "2029", "narrator_chain": "Shurahbil bin Muslim Al-Khawlani said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2030", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، حَدَّثَنَا سُفْيَانُ، ح وَحَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، حَدَّثَنَا جَرِيرٌ، عَنْ مُسْلِمٍ الْمُلاَئِيِّ، سَمِعَ أَنَسَ بْنَ مَالِكٍ، يَقُولُ كَانَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ يُجِيبُ دَعْوَةَ الْمَمْلُوكِ ‏.‏", "bengali": "", "english": "\"The Messenger of Allah (ﷺ) used to accept the invitation of a slave.\"", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  اللہ کی قسم! جو کوئی چاہے ہم اس سے لعان کر لیں کہ چھوٹی س", "grades": "", "reference": "", "international_number": "2030", "narrator_chain": "It was narrated from Muslim Al-Mula'i that he heard Anas bin Malik say:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2031", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، عَنْ مُحَمَّدِ بْنِ زَيْدٍ، عَنْ عُمَيْرٍ، - مَوْلَى آبِي اللَّحْمِ - قَالَ كَانَ مَوْلاَىَ يُعْطِينِي الشَّىْءَ فَأُطْعِمُ مِنْهُ فَمَنَعَنِي - أَوْ قَالَ فَضَرَبَنِي - فَسَأَلْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ أَوْ سَأَلَهُ فَقُلْتُ لاَ أَنْتَهِي أَوْ لاَ أَدَعُهُ ‏.‏ فَقَالَ ‏ ‏ الأَجْرُ بَيْنَكُمَا ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"My master used to give me food and I would feed others from it, then he stopped me,\" or he said: \"He beat me. So I asked the Prophet,” -or- \"he asked him and I said: 'I will not stop.' He said: 'Both of you will be rewarded.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that 'Umair, the freed slave of Aabi Lahm, said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2032", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا شَبَابَةُ بْنُ سَوَّارٍ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَمُحَمَّدُ بْنُ الْوَلِيدِ، قَالاَ حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي بِشْرٍ، جَعْفَرِ بْنِ إِيَاسٍ قَالَ سَمِعْتُ عَبَّادَ بْنَ شُرَحْبِيلَ، - رَجُلاً مِنْ بَنِي غُبَرَ - قَالَ أَصَابَنَا عَامُ مَخْمَصَةٍ فَأَتَيْتُ الْمَدِينَةَ فَأَتَيْتُ حَائِطًا مِنْ حِيطَانِهَا فَأَخَذْتُ سُنْبُلاً فَفَرَكْتُهُ وَأَكَلْتُهُ وَجَعَلْتُهُ فِي كِسَائِي فَجَاءَ صَاحِبُ الْحَائِطِ فَضَرَبَنِي وَأَخَذَ ثَوْبِي فَأَتَيْتُ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَأَخْبَرْتُهُ فَقَالَ لِلرَّجُلِ ‏ ‏ مَا أَطْعَمْتَهُ إِذْ كَانَ جَائِعًا أَوْ سَاغِبًا وَلاَ عَلَّمْتَهُ إِذْ كَانَ جَاهِلاً ‏\"\"‏ ‏.‏ فَأَمَرَهُ النَّبِيُّ ـ صلى الله عليه وسلم ـ فَرَدَّ إِلَيْهِ ثَوْبَهُ وَأَمَرَ لَهُ بِوَسْقٍ مِنْ طَعَامٍ أَوْ نِصْفِ وَسْقٍ ‏.‏\"", "bengali": "", "english": "“I heard 'Abbad bin Shurahbil, a man from Banu Ghubar, say: ‘We suffered a year of famine, and I came to Al-Madinah. I came to one of its gardens and took an ear of corn, I rubbed it, ate some and put the rest in my garment. The owner of the garden came and beat me and took my garment. I came to the Prophet (ﷺ) and told him (what had happened). He said to the man: \"You did not feed him when he was hungry and you did not teach him when he was ignorant.\"' Then the Prophet (ﷺ) told him to give back his garment and ordered that a Wasq or half a Wasq of food be brought to him.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Bishr Ja'far bin Abu Jyas said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2033", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، وَيَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، قَالاَ حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَيْمَانَ، قَالَ سَمِعْتُ ابْنَ أَبِي الْحَكَمِ الْغِفَارِيَّ، قَالَ حَدَّثَتْنِي جَدَّتِي، عَنْ عَمِّ، أَبِيهَا رَافِعِ بْنِ عَمْرٍو الْغِفَارِيِّ قَالَ كُنْتُ وَأَنَا غُلاَمٌ، أَرْمِي نَخْلَنَا - أَوْ قَالَ نَخْلَ الأَنْصَارِ - فَأُتِيَ بِيَ النَّبِيَّ ـ صلى الله عليه وسلم ـ فَقَالَ ‏\"‏ يَا غُلاَمُ - وَقَالَ ابْنُ كَاسِبٍ فَقَالَ يَا بُنَىَّ - لِمَ تَرْمِي النَّخْلَ ‏\"‏ ‏.‏ قَالَ قُلْتُ آكُلُ ‏.‏ قَالَ ‏\"‏ فَلاَ تَرْمِي النَّخْلَ وَكُلْ مِمَّا يَسْقُطُ فِي أَسَافِلِهَا ‏\"‏ ‏.‏ قَالَ ثُمَّ مَسَحَ رَأْسِي وَقَالَ ‏\"‏ اللَّهُمَّ أَشْبِعْ بَطْنَهُ ‏\"‏ ‏.‏", "bengali": "", "english": "\"When I was a boy, I used to throw stones at our date-palm trees\" - or he said: \"the date-palm trees of the Ansar.\" I was brought to the Prophet (ﷺ) and he said: 'O boy' - (one of the narrators) Ibn Kasib said: He said: 'O my son - why are you throwing stones at the date-palm trees?' I said: 'So I can eat.' He said: 'Do not throw stones at the date-palm trees. Eat from what falls to the ground from them.' Then he patted me on the head and said: 'O Allah give him enough to eat.'”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  فاطمہ بنت قیس رضی اللہ عنہا نے کہا: اللہ کے رسول! میں ڈ", "grades": "", "reference": "", "international_number": "2033", "narrator_chain": "It was narrated that Rafi' bin 'Amr Al-Ghifari said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2034", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا الْجُرَيْرِيُّ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ، عَنِ النَّبِيِّ ـ صلى الله عليه وسلم ـ قَالَ ‏ ‏ إِذَا أَتَيْتَ عَلَى رَاعٍ فَنَادِهِ ثَلاَثَ مِرَارٍ فَإِنْ أَجَابَكَ وَإِلاَّ فَاشْرَبْ فِي غَيْرِ أَنْ تُفْسِدَ وَإِذَا أَتَيْتَ عَلَى حَائِطِ بُسْتَانٍ فَنَادِ صَاحِبَ الْبُسْتَانِ ثَلاَثَ مَرَّاتٍ فَإِنْ أَجَابَكَ وَإِلاَّ فَكُلْ فِي أَنْ لاَ تُفْسِدَ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"When you come to a shepherd, call him three times. If he answers (all well and good), otherwise drink (milk from the flock) without taking advantage. And when you come to a garden call the owner of the garden three times. If he answers (all well and good), otherwise eat (from the produce of the garden) without taking advantage.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Abu Sa'eed that the Prophet (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2035", "arabic": "حَدَّثَنَا هَدِيَّةُ بْنُ عَبْدِ الْوَهَّابِ، وَأَيُّوبُ بْنُ حَسَّانَ الْوَاسِطِيُّ، وَعَلِيُّ بْنُ سَلَمَةَ، قَالُوا حَدَّثَنَا يَحْيَى بْنُ سُلَيْمٍ الطَّائِفِيُّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ إِذَا مَرَّ أَحَدُكُمْ بِحَائِطٍ فَلْيَأْكُلْ وَلاَ يَتَّخِذْ خُبْنَةً ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"When anyone of you passes by a garden let him eat therefrom, but he should not carry any away in his garment.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2036", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، قَالَ أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ أَنَّهُ قَامَ فَقَالَ ‏ ‏ لاَ يَحْتَلِبَنَّ أَحَدُكُمْ مَاشِيَةَ رَجُلٍ بِغَيْرِ إِذْنِهِ أَيُحِبُّ أَحَدُكُمْ أَنْ تُؤْتَى مَشْرُبَتُهُ فَيُكْسَرَ بَابُ خِزَانَتِهِ فَيُنْتَثَلَ طَعَامُهُ فَإِنَّمَا تَخْزُنُ لَهُمْ ضُرُوعُ مَوَاشِيهِمْ أَطْعِمَاتِهِمْ فَلاَ يَحْتَلِبَنَّ أَحَدُكُمْ مَاشِيَةَ امْرِئٍ بِغَيْرِ إِذْنِهِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"No one of you should milk from the livestock of another man without his permission. Would anyone of you like someone to break into his storeroom and take his food? The udders of their livestock store food for them, so none of you should milk the livestock of another man without his permission.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from 'Abdullah bin 'Umar that the Messenger of Allah (ﷺ) stood up and said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2037", "arabic": "حَدَّثَنَا إِسْمَاعِيلُ بْنُ بِشْرِ بْنِ مَنْصُورٍ، حَدَّثَنَا عُمَرُ بْنُ عَلِيٍّ، عَنْ حَجَّاجٍ، عَنْ سَلِيطِ بْنِ عَبْدِ اللَّهِ الطُّهَوِيِّ، عَنْ ذُهَيْلِ بْنِ عَوْفِ بْنِ شَمَّاخٍ الطُّهَوِيِّ، حَدَّثَنَا أَبُو هُرَيْرَةَ، قَالَ بَيْنَمَا نَحْنُ مَعَ رَسُولِ اللَّهِ ـ صلى الله عليه وسلم ـ فِي سَفَرٍ إِذْ رَأَيْنَا إِبِلاً مَصْرُورَةً بِعِضَاهِ الشَّجَرِ فَثُبْنَا إِلَيْهَا فَنَادَانَا رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ فَرَجَعْنَا إِلَيْهِ فَقَالَ ‏\"‏ إِنَّ هَذِهِ الإِبِلَ لأَهْلِ بَيْتٍ مِنَ الْمُسْلِمِينَ هُوَ قُوتُهُمْ وَيُمْنُهُمْ بَعْدَ اللَّهِ أَيَسُرُّكُمْ لَوْ رَجَعْتُمْ إِلَى مَزَاوِدِكُمْ فَوَجَدْتُمْ مَا فِيهَا قَدْ ذُهِبَ بِهِ أَتُرَوْنَ ذَلِكَ عَدْلاً ‏\"‏ ‏.‏ قَالُوا لاَ ‏.‏ قَالَ ‏\"‏ فَإِنَّ هَذَا كَذَلِكَ ‏\"‏ ‏.‏ قُلْنَا أَفَرَأَيْتَ إِنِ احْتَجْنَا إِلَى الطَّعَامِ وَالشَّرَابِ فَقَالَ ‏\"‏ كُلْ وَلاَ تَحْمِلْ وَاشْرَبْ وَلاَ تَحْمِلْ ‏\"‏ ‏.‏", "bengali": "", "english": "“While we were with the Messenger of Allah (ﷺ) on a journey, we saw some camels with their udders tied, among some thorny trees. We rushed towards it, but the Messenger of Allah (ﷺ) called us and we came back to him. He said: 'These camels belong to a family of Muslims, and this is their support (and blessing) after Allah. Would you be happy if you went back to your vessels and found that what was in them had been taken away? Do you think that is fair?' They said: 'No.' He said: 'This is like that.' We said: 'What do you think if we are in need of food and drink?' He said: 'Eat but do not carry any away: drink but do not carry any away.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  جب عمرہ بنت جون رسول اللہ صلی اللہ علیہ وسلم کے پاس", "grades": "", "reference": "", "international_number": "2037", "narrator_chain": "Abu Hurairah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2038", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ هِشَامِ بْنِ عُرْوَةَ، عَنْ أَبِيهِ، عَنْ أُمِّ هَانِئٍ، أَنَّ النَّبِيَّ ـ صلى الله عليه وسلم ـ قَالَ لَهَا ‏ ‏ اتَّخِذِي غَنَمًا فَإِنَّ فِيهَا بَرَكَةً ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Keep sheep, for in them is blessing!'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Umm Hani' that the Prophet (ﷺ) said to her:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2039", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ حُصَيْنٍ، عَنْ عَامِرٍ، عَنْ عُرْوَةَ الْبَارِقِيِّ، يَرْفَعُهُ قَالَ ‏ ‏ الإِبِلُ عِزٌّ لأَهْلِهَا وَالْغَنَمُ بَرَكَةٌ وَالْخَيْرُ مَعْقُودٌ فِي نَوَاصِي الْخَيْلِ إِلَى يَوْمِ الْقِيَامَةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Camels are the pride of their owners, and sheep are a blessing, and goodness is tied to the forelocks of horses until the Day of Resurrection.\"", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that 'Urwah Al-Bariqi said in a Marfu’ report:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2040", "arabic": "حَدَّثَنَا عِصْمَةُ بْنُ الْفَضْلِ النَّيْسَابُورِيُّ، وَمُحَمَّدُ بْنُ فِرَاسٍ أَبُو هُرَيْرَةَ الصَّيْرَفِيُّ، قَالاَ حَدَّثَنَا حَرَمِيُّ بْنُ عُمَارَةَ، حَدَّثَنَا زَرْبِيٌّ، إِمَامُ مَسْجِدِ هِشَامِ بْنِ حَسَّانَ حَدَّثَنَا مُحَمَّدُ بْنُ سِيرِينَ، عَنِ ابْنِ عُمَرَ، رضى الله عنه قَالَ قَالَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ ‏ ‏ الشَّاةُ مِنْ دَوَابِّ الْجَنَّةِ ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"Sheep are among the animals of Paradise.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2041", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ، حَدَّثَنَا عُثْمَانُ بْنُ عَبْدِ الرَّحْمَنِ، حَدَّثَنَا عَلِيُّ بْنُ عُرْوَةَ، عَنِ الْمَقْبُرِيِّ، عَنْ أَبِي هُرَيْرَةَ، رضى الله عنه قَالَ أَمَرَ رَسُولُ اللَّهِ ـ صلى الله عليه وسلم ـ الأَغْنِيَاءَ بِاتِّخَاذِ الْغَنَمِ وَأَمَرَ الْفُقَرَاءَ بِاتِّخَاذِ الدَّجَاجِ وَقَالَ ‏ ‏ عِنْدَ اتِّخَاذِ الأَغْنِيَاءِ الدَّجَاجَ يَأْذَنُ اللَّهُ بِهَلاَكِ الْقُرَى ‏\"\"‏ ‏.‏\"", "bengali": "", "english": "\"The  Messenger of Allah (ﷺ) commanded the rich to keep sheep, and he commanded the poor to keep chickens, and he said: 'When the rich keep chickens, then Allah will give permission for the town to be destroyed.\"'", "french": "", "indonesian": "", "russian": "", "urdu": "", "grades": "", "reference": "", "international_number": "", "narrator_chain": "It was narrated that Abu Hurairah said:", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2137", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَإِسْحَاق بْنُ", "bengali": "", "english": "It was narrated from 'Aishah that the Messenger of Allah (ﷺ) said:'The best (most pure) food a man consumes is that which he has earned himself, and his child (and his child's wealth) is part of his earnings", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  آدمی کا سب سے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 1", "international_number": "2137", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2138", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ، ‏‏‏‏‏‏عَنْ بَحِيرِ بْن", "bengali": "", "english": "It was narrated from Miqdam bin Ma'dikarib (Ar- Zubaidi) that the Messenger of Allah (ﷺ) said:\"No man earns anything better than that which he earns with his own hands, and what a man spends on himself, his wife, his child and his servant, then it is charity", "french": "", "indonesian": "", "russian": "", "urdu": "مقدام بن معدیکرب زبیدی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  آدمی کی ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 12, Hadith 2", "international_number": "2138", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2139", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، ‏‏‏‏‏‏حَدَّثَنَا كَثِيرُ بْنُ هِشَامٍ، ‏‏‏‏‏‏حَدَّثَنَا كُلْثُومُ", "bengali": "", "english": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:'The trustworthy, honest Muslim merchant will be with the martyrs on the Day of Resurrection", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سچا، امانت دار م", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 3", "international_number": "2139", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2140", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ الدَّرَاوَرْدِيّ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said:'The one who strives to support the widow and the poor is like a Mujahid who fights in the cause of Allah, and like one who stands in the night (in voluntary prayer) and fasts by day", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیوہ عورتوں اور مسکین", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 4", "international_number": "2140", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2141", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ، ‏‏‏‏‏‏حَدَّثَنَ", "bengali": "", "english": "It was narrated from Mu'adh bin 'Abdullah bin Khubaib, from his father, that his paternal uncle said:\"We were sitting in a gathering, and the Prophet (ﷺ) came with traces of water on his head. One of us said to him: 'We see that you are of good cheer today.' He said: 'Yes, praise is to Allah.' Then he spoke to the people about being rich. He said: 'There is nothing wrong with being rich for one who has piety, but good health for one who has piety is better than riches, and being of good cheer is a blessing", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن خبیب کے چچا سے روایت ہے  ہم ایک مجلس میں تھے، رسول اللہ صلی اللہ علیہ وسلم بھی وہاں اچانک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 5", "international_number": "2141", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2142", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ، ‏‏‏‏‏‏عَنْ عُمَارَةَ ب", "bengali": "", "english": "It was narrated from Abu Humaid As-Sa'idi that the Messenger of Allah (ﷺ) said:Be moderate in seeking worldly things, for everyone will be facilitated for which he was created", "french": "", "indonesian": "", "russian": "", "urdu": "ابو حمید ساعدی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  دنیا کی طلب میں اع", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 6", "international_number": "2142", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2143", "arabic": "حَدَّثَنَا إِسْمَاعِيل بْنُ بِهْرَامٍ، ‏‏‏‏‏‏حَدَّثَنَا الْحَسَنُ بْنُ مُحَمَّدِ بْنِ عُثْمَانَ زَوْ", "bengali": "", "english": "It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) said:The one who has the most concerns is the believer who is concerned about both his worldly affairs and his Hereafter.\"' (Da'if)Abu 'Abdullah said: \"This Hadith is Gharib' Isma'il, alone, has narrated it", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سب سے زیادہ فکرمندی ا", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 7", "international_number": "2143", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2144", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُصَفَّى الْحِمْصِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، ‏‏‏‏‏", "bengali": "", "english": "It was narrated from Jabir bin 'Abdullah that the Messenger of Allah (ﷺ) said:\"O people, fear Allah and be moderate in seeking a living, for no soul will die until it has received all its provision, even if it is slow in coming. So fear Allah and be moderate in seeking provision; take that which is permissible and leave that which is forbidden", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  لوگو! اللہ سے ڈ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 8", "international_number": "2144", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2145", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَ", "bengali": "", "english": "It was narrated that Qais bin Abu Gharazah said:\"At the time of the Messenger of Allah (ﷺ) we used to be called brokers, but the Messenger of Allah (ﷺ) passed by us and called by a name that was better than that. He said: 'O merchants, selling involves (false) oaths and idle talk, so mix some charity with it", "french": "", "indonesian": "", "russian": "", "urdu": "قیس بن ابی غرزہ رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے عہد میں «سماسرہ»  (", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 9", "international_number": "2145", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2146", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سُلَيْمٍ الطَّائِفِيّ", "bengali": "", "english": "It was narrated from Isma'il bin 'Ubaid bin Rifa'ah, from his father, that his grandfather Rifa'ah said:\"We went out with the Messenger of Allah (ﷺ) and the people were trading early in the morning. He called them: 'O merchants!' and when they looked up and craned their necks, he said : 'The merchants will be raised on the Day of Resurrection as immoral people, apart from those who fear Allah and act righteously and speak the truth (i.e. those who are honest)", "french": "", "indonesian": "", "russian": "", "urdu": "رفاعہ رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ تھے کہ اچانک کچھ لوگ صبح", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 10", "international_number": "2146", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2147", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏حَدَّثَنَا", "bengali": "", "english": "It was narrated from Anas bin Malik that the Messenger of Allah (ﷺ) said:'Whoever achieves at something, let him stick with It", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جسے روزی کا کوئی ذریع", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 11", "international_number": "2147", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2148", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا أَبُو عَاصِمٍ، ‏‏‏‏‏‏أَخْبَرَنِي أَبِي، ‏‏‏‏‏‏عَ", "bengali": "", "english": "It was narrated that Nafi' said:I used to send trade goods to Sham and Egypt, then I prepared to send trade goods to 'Iraq. I went to 'Aishah, the Mother of the Believers, and said to her: \" O Mother of the Believers I used to send trade goods to Sham and I am preparing to send trade goods to 'Iraq.\" She said: \"Do not do that. What is wrong with the way you have been doing it? I heard the Messenger of Allah (ﷺ) say: 'If Allah causes provision to come to one of you through a certain means, he should not leave it unless it changes or deteriorates", "french": "", "indonesian": "", "russian": "", "urdu": "نافع کہتے ہیں کہ  میں اپنا سامان تجارت شام اور مصر بھیجا کرتا تھا، پھر میں نے عراق کی طرف بھیج دیا،", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 12", "international_number": "2148", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2149", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَمْرُو بْنُ يَحْيَى بْنِ سَعِيدٍ الْقُرَشِيُّ، ‏", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:\"Allah has not sent any Prophet but he was a shepherd.\" His Companions said to him: \"Even you, O Messenger of Allah?\" He said: \"Even me I used to tend the sheep of the people of Makkah for a few Qirats.\" (Sahih)(One of the narrators) Suwaid said: \" Meaning one Qirat for every sheep", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ نے جتنے بھی نبی بھی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 12, Hadith 13", "international_number": "2149", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2150", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ الْخُزَاعِيُّ، ‏‏‏", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:\"Zakariyya was a carpenter", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  زکریا علیہ السلام  (", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 14", "international_number": "2150", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2151", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏حَدَّثَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ، ‏‏‏‏‏‏", "bengali": "", "english": "It was narrated from 'Aishah that the Messenger of Allah (ﷺ) said:\"The image-makers will be punished on the Day of Resurrection and will be told: 'Give life to that which you have created", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تصویریں بنانے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 12, Hadith 15", "international_number": "2151", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2152", "arabic": "حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، ‏‏‏‏‏‏حَدَّثَنَا عُمَرُ بْنُ هَارُونَ، ‏‏‏‏‏‏عَنْ هَمَّامٍ، ‏‏‏‏‏‏ع", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:\"The most dishonest of people are the dyers and the goldsmiths", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  لوگوں میں سب سے زیادہ جھ", "grades": "{'name': 'Al-Albani', 'grade': 'Mawdu'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Mawdu'},{'name': 'Shuaib Al Arnaut', 'grade': 'Mawdu'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 16", "international_number": "2152", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2153", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أَحْمَدَ، ‏‏‏‏‏‏حَدَّثَنَا إِس", "bengali": "", "english": "It was narrated from 'Umar bin Khattab that the Messenger of Allah (ﷺ) said:\"The importer is blessed with provision and the hoarder is cursed", "french": "", "indonesian": "", "russian": "", "urdu": "عمر بن الخطاب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   «جلب» کرنے والا رو", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 17", "international_number": "2153", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2154", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏عَنْ مُحَمَّدِ ب", "bengali": "", "english": "It was narrated from Ma'mar bin 'Abdullah bin Nadlah that the Messenger of Allah (ﷺ) said:\"No one hoards but a sinner", "french": "", "indonesian": "", "russian": "", "urdu": "معمر بن عبداللہ بن نضلہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ذخیرہ اند", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 18", "international_number": "2154", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2155", "arabic": "حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو بَكْرٍ الْحَنَفِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْهَي", "bengali": "", "english": "It was narrated that 'Umar bin Khattab said:\"I heard the Messenger of Allah (ﷺ) say: 'Whoever hoards food (and keeps it from) the Muslims, Allah will afflict him with leprosy and bankruptcy", "french": "", "indonesian": "", "russian": "", "urdu": "عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو مسلمانو", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 19", "international_number": "2155", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2156", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏حَ", "bengali": "", "english": "It was narrated that Abu Sa'eed Al-Khudri said:\"The Messenger of Allah (ﷺ) sent us, thirty horsemen, on a military campaign. We camped near some people and asked them for hospitality but they refused. Then their leader was stung by a scorpion and they said: 'Is there anyone among you who can recite Ruqyah for a scorpion sting?' I said: 'Yes, I can, but I will not recite Ruqyah for him until you give us some sheep.' They said: 'We will give you thirty sheep.' So we accepted them, and I recited Al-Hamd (i.e. Al-Fatihah) over him seven times. Then he recovered, and I took the sheep. Then some doubts occurred within ourselves. Then we said: 'Let us not hasten (to make a decision concerning the sheep) until we come to the Prophet (ﷺ)' So when we came back: 'I told him what I had done. He said: 'How did you know that it is a Ruqyah? Divide them up and give me a share as well", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  ہم تیس سواروں کو رسول اللہ صلی اللہ علیہ وسلم نے ایک سریہ  (", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 20", "international_number": "2156", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2157", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated that 'Ubadah bin Samit said:\"I taught people from Ahtus-Suffah\" Qur'an and how to write, and one of them gave me a bow. I said: 'It is not money, and I can shoot (with it) for the sake of Allah., I asked the Messenger of Allah (ﷺ) about it and he said: 'If it would please you to have a necklace of fire placed around your neck, then accept it", "french": "", "indonesian": "", "russian": "", "urdu": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  میں نے اہل صفہ میں سے کئی لوگوں کو قرآن پڑھنا اور لکھنا سکھ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 21", "international_number": "2157", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2158", "arabic": "حَدَّثَنَا سَهْلُ بْنُ أَبِي سَهْلٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، ‏‏‏‏‏‏عَنْ ثَوْرِ بْنِ ي", "bengali": "", "english": "It was narrated that Ubayy bin Ka'b said:\"I taught a man the Qur'an, and he gave me a bow. I mentioned that to the Messenger of Allah (ﷺ) and he said: 'If you accept it you will be accepting a bow of fire.' So I returned it", "french": "", "indonesian": "", "russian": "", "urdu": "ابی بن کعب رضی اللہ عنہ کہتے ہیں کہ  میں نے ایک شخص کو قرآن پڑھنا سکھایا تو اس نے مجھے ایک کمان ہدی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 22", "international_number": "2158", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2159", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated from Abu Mas'ud that :the Prophet (ﷺ) forbade the price of a dog, the payment (given to a prostitute) and the payment made to a soothsayer", "french": "", "indonesian": "", "russian": "", "urdu": "ابومسعود عقبہ بن عمرو انصاری بدری رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے کتے کی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 23", "international_number": "2159", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2160", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ طَرِيفٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا مُح", "bengali": "", "english": "It was narrated that Abu Hurairah said:\"The Messenger of Allah (ﷺ) forbade the price of a dog and studding a stallion", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے کتے کی قیمت، اور نر سے جفتی کرانے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 24", "international_number": "2160", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2161", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ، ‏‏‏‏‏‏أَنْبَأَنَا ابْنُ لَهِيعَةَ، ‏‏", "bengali": "", "english": "lt was narrated from Abu Az-Zubair that Jabir said:\"The Messenger of Allah (ﷺ) forbade the price of a cat", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بلی کی قیمت سے منع کیا ہے۔", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 25", "international_number": "2161", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2162", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ أَبِي عُمَرَ الْعَدَنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏", "bengali": "", "english": "It was narrated from Ibn 'Abbas that :the Prophet (ﷺ) was treated with cupping and he gave him (the cupper) his wages. (Sahih)Ibn Abu 'Umar was alone in narrating it. That was said by Ibn Majah", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے پچھنا لگوایا، اور حجام", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 26", "international_number": "2162", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2163", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عَلِيٍّ أَبُو حَفْصٍ الصَّيْرَفِيُّ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو دَاوُدَ، ‏‏‏‏‏‏ح", "bengali": "", "english": "It was narrated that 'Ali said:\"The Messenger of Allah (ﷺ) was treated with cupping and he told me to give the cupper his wages", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے پچھنا لگوایا، اور مجھے حکم دیا تو میں", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 27", "international_number": "2163", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2164", "arabic": "حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ بَيَانٍ الْوَاسِطِيُّ، ‏‏‏‏‏‏حَدَّثَنَا خَالِدُ بْنُ عَبْدِ اللَّه", "bengali": "", "english": "It was narrated from Anas bin Malik that:the Prophet (ﷺ) was treated with cupping and gave the cupper his wages", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے پچھنا لگوایا اور حجام  ( پچھ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 28", "international_number": "2164", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2165", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ حَمْزَةَ، ‏‏‏‏‏‏حَدَّثَنِي الْأَوْزَ", "bengali": "", "english": "It was narrated that Abu Mas'ud, 'Uqbah bin 'Amr, said:\"The Messenger of Allah (ﷺ), forbade the earnings of a cupper", "french": "", "indonesian": "", "russian": "", "urdu": "ابومسعود عقبہ بن عمرو رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے حجام  ( پچھنا لگانے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 29", "international_number": "2165", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2166", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا شَبَابَةُ بْنُ سَوَّارٍ، ‏‏‏‏‏‏عَنْ اب", "bengali": "", "english": "It was narrated from Haram bin Munayyisah that :his father asked the Prophet (ﷺ) about the earnings of a cupper and he forbade him from that. Then he mentioned his need and he said: \"Spend it on feeding your she-camels that draw water", "french": "", "indonesian": "", "russian": "", "urdu": "محیصہ بن مسعود رضی اللہ عنہ سے روایت ہے کہ  انہوں نے حجام  ( پچھنا لگانے والے )  کی کمائی کے متعلق ن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 30", "international_number": "2166", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2167", "arabic": "حَدَّثَنَا عِيسَى بْنُ حَمَّادٍ الْمِصْرِيُّ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ يَ", "bengali": "", "english": "Ata' bin Abu Rabah said:I heard Jabir bin 'Abdullah say: \"In the Year of the Conquest, while he was in Makkah the Messenger of Allah (ﷺ), said: 'Allah and His Messenger have forbidden the sale of wines, meat of dead animals, pigs and 'idols.' It was said to him: 'O Messenger of Allah, what do you think of the fat of dead animals, for it is used to caulk ships, it is daubed on animal skins and people use it to light their lamps?' He said: 'No, it is unlawful.' Then the Messenger of Allah (ﷺ) said: 'May Allah curse the jews, for Allah forbade them the fat (of animals) but they rendered it, (i.e. melted it) sold it and consumed its price", "french": "", "indonesian": "", "russian": "", "urdu": "عطاء بن ابی رباح کہتے ہیں کہ  میں نے جابر بن عبداللہ رضی اللہ عنہما کو کہتے سنا کہ رسول اللہ صلی الل", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 31", "international_number": "2167", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2168", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدِ بْنِ يَحْيَى بْنِ سَعِيدٍ الْقَطَّانِ، ‏‏‏‏‏‏حَدَّثَنَا هَاشِمُ ب", "bengali": "", "english": "It was narrated that Abu Umamah said:\"The Messenger of Allah, forbade selling or buying singing girls, and their wages, and consuming their price", "french": "", "indonesian": "", "russian": "", "urdu": "ابوامامہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مغنیہ  ( گانے والی عورتوں )  کی خ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 32", "international_number": "2168", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2169", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏ و", "bengali": "", "english": "It was narrated that Abu Hurairah said:\"The Messenger of Allah (ﷺ) forbade two kinds of transactions: Mulimasah and Mundbadhah", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے دو بیع سے منع کیا ہے: ایک بیع ملا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 33", "international_number": "2169", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2170", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَسَهْلُ بْنُ أَبِي سَهْلٍ قَالَا:‏‏‏‏ حَدَّثَنَ", "bengali": "", "english": "It was narrated from Abu Sa'eed Al-Khudri that :the Messenger of Allah (ﷺ) forbade Mulamasah and Munabadhah. (Sahih) Sahl added: \"Sufyan said: 'Mulamasah means when a man touches something with his hand without seeing it, and Munabadhah means when he says: \"Toss me what you have, and I will toss you what have", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے بیع ملامسہ و منابذہ سے من", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 12, Hadith 34", "international_number": "2170", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2171", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ، ‏‏‏‏‏‏عَ", "bengali": "", "english": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:\"Let one of you not undersell another", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 35", "international_number": "2171", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2172", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنْ الزُّهْرِيِّ، ‏‏‏‏‏‏عَنْ سَ", "bengali": "", "english": "lt was narrated from Abu Hurairah that the Prophet (ﷺ) said:\"A man is not to undersell his brother, nor is he to fry to outhaggle his brother", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  کوئی شخص اپنے بھائی کے سو", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 36", "international_number": "2172", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2173", "arabic": "قَرَأْتُ عَلَى مُصْعَبِ بْنِ عَبْدِ اللَّهِ الزُّبَيْرِيِّ، ‏‏‏‏‏‏عَنْ مَالِكٍ، ‏‏‏‏‏‏ح وحَدَّثَنَا", "bengali": "", "english": "It was narrated from Ibn 'Umar that :the Prophet (ﷺ) forbade the Najsh", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے بیع نجش سے منع فرمایا ہے ۱", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 37", "international_number": "2173", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2174", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَسَهْلُ بْنُ أَبِي سَهْلٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا سُ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Prophet said:\"Do not practice Najsh", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  آپس میں بیع نجش نہ کرو ۔", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 38", "international_number": "2174", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2175", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:\"A City-dweller should not sell for a Bedouin", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شہری باہر سے آنے والے د", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 39", "international_number": "2175", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2176", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ أَبِي الزُّ", "bengali": "", "english": "It was narrated from Jabir bin 'Abdullah that the Prophet (ﷺ) said:\"A city-dweller should not sell for a Bedouin. Leave people to (engage in trade) and Allah will grant them provision through one another", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شہری باہر سے آ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 40", "international_number": "2176", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2177", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ الْعَنْبَرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏", "bengali": "", "english": "Ibn Tawus narrated from his father that Ibn 'Abbas said:\"The Messenger of Allah (ﷺ) forbade a city-dweller to sell for a Bedouin.\" (Sahih)I (Tawus) said to Ibn 'Abbas: \"What is meant by the words: 'A city-dweller selling for a Bedouin?' He said: \"He should not be a broker for him", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے شہری کو دیہاتی کا مال بی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 41", "international_number": "2177", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2178", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said:\"Do not meet the traders on the way, and whoever meets any of them and buys from him, the vendor has the choice of annulling the transaction when he comes to the marketplace", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  باہر سے آنے والے سامان ت", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 42", "international_number": "2178", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2179", "arabic": "حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏عَنْ عُب", "bengali": "", "english": "It was narrated that Ibn 'Umar said:\"The Messenger of Allah (ﷺ) forbade meeting traders on the way", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے باہر سے آنے والے سامان ت", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 43", "international_number": "2179", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2180", "arabic": "حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، ‏‏‏‏‏‏ وَحَمَّادُ بْنُ مَسْع", "bengali": "", "english": "It was narrated that 'Abdullah bin Mas'ud said:\"The Messenger of Allah (ﷺ) forbade. meeting the owners of goods (away from the market)", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مال بیچنے والوں سے بازار", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 44", "international_number": "2180", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2181", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ الْمِصْرِيُّ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ ن", "bengali": "", "english": "It was narrated from 'Abdullah bin 'Umar that the Messenger of Allah said:\"When two men enter into a transaction, each of them has the choice (of annulling it) so long as they have not yet parted and are still together, or one of them has given the option or choice to the other. Once he has accepted the terms of the other, then the transaction is binding. If they part after concluding the transaction and neither of them has rescinded the transaction then the transaction is binding.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب دو آدمی ایک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 45", "international_number": "2181", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2182", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، ‏‏‏‏‏‏ وَأَحْمَدُ بْنُ الْمِقْدَامِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated from Abu Barzah Al-Aslami that the Messenger of Allah (ﷺ) said:”The two parties to a transaction have the choice (of annulling it) so long as they have not yet parted", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبرزہ اسلمی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بائع اور مشتری  ( ب", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 46", "international_number": "2182", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2183", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏ وَإِسْحَاق بْنُ مَنْصُورٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا عَ", "bengali": "", "english": "It was narrated from Samurah that the Messenger of Allah (ﷺ) said:\"The two parties to a transaction have the choice (of annulling it) so long as they have not yet parted", "french": "", "indonesian": "", "russian": "", "urdu": "سمرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیچنے اور خریدنے والے دونوں", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 47", "international_number": "2183", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2184", "arabic": "حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، ‏‏‏‏‏‏ وَأَحْمَدُ بْنُ عِيسَى، ‏‏‏‏‏‏الْمِصْرِيَّانِ قَالَا:‏‏‏‏", "bengali": "", "english": "It was narrated that Jabir bin' Abdullah said:\"The Messenger of Allah (ﷺ) bought a load of fodder from a Bedouin man. When the transaction was concluded, the Messenger of Allah (ﷺ) said: 'Choose (either to go ahead or to cancel the transaction).' The Bedouin said: 'May Allah grant you a long life of good transaction", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک اعرابی  ( دیہاتی )", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 48", "international_number": "2184", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2185", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ الْوَلِيدِ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا مَرْوَانُ بْنُ مُحَمَّدٍ، ‏‏", "bengali": "", "english": "It was narrated from Dawud bin Salih Al Madani that his father said:I heard Abu Sa'eed Al-Khudri say: \"The Messenger of Allah (ﷺ) said: 'Transactions may only be done by mutual consent", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیع بیچنے والے اور", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 49", "international_number": "2185", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2186", "arabic": "حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَد", "bengali": "", "english": "It was narrated from Qasim bin 'Abdur Rahman from his father that :Abdullah bin Mas'ud sold one of the slaves from the state[1] to Ash'ath bin Qais, and they differed concerning the price. Ibn Mas'ud said: \"I sold him to you for twenty thousand,' but Ash'ath bin Qais said: \"I bought him from you for ten thousand.\" 'Abdullah said: \"If you want, I will tell you a Hadith which I heard from the Messenger of Allah (ﷺ)\" He said: \"Tell me it.\" He said: \"I heard the Messenger of Allah (ﷺ) say: 'If two parties to a transaction differ, and they have no proof, and the sale item remains (unredeemed), then what the seller says is valid. Or they may cancel the transaction.\" He said: \"I want to cancel the transaction.\" And he cancelled it", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالرحمٰن سے روایت ہے کہ  عبداللہ بن مسعود رضی اللہ عنہ نے اشعث بن قیس رضی اللہ عنہ کے ہاتھ حکومت ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 12, Hadith 50", "international_number": "2186", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2187", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، ‏‏‏‏‏‏حَدَّثَنَا شُعْب", "bengali": "", "english": "It was narrated that Hakim bin Hizam said:\"I said: 'O Messenger of Allah, a man is asking me to sell him something that I do not possess; Shall I sell it to him?' He said: 'Do not sell what is not with you", "french": "", "indonesian": "", "russian": "", "urdu": "حکیم بن حزام رضی اللہ عنہ کہتے ہیں کہ  میں نے کہا: اللہ کے رسول! ایک آدمی مجھ سے ایک چیز خریدنا چاہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 51", "international_number": "2187", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2188", "arabic": "حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏ح وحَدَّ", "bengali": "", "english": "It was narrated from 'Amr bin Shu'aib, from his father, that his grandfather said:\"The Messenger of Allah (ﷺ) said: 'It is not permissible to sell something that is not with you, nor to profit from what you do not possess", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو چیز", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 52", "international_number": "2188", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2189", "arabic": "حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ الْفُضَيْلِ، ‏‏‏‏‏‏عَنْ لَ", "bengali": "", "english": "It was narrated from 'Ata that 'Attab bin Asid said that :when the Messenger of Allah (ﷺ) sent him to Makkah, he forbade him from profiting off of what he did not possess", "french": "", "indonesian": "", "russian": "", "urdu": "عتاب بن اسید رضی اللہ عنہ کہتے ہیں  جب رسول اللہ صلی اللہ علیہ وسلم نے ان کو مکہ بھیجا، تو اس چیز کے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 53", "international_number": "2189", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2190", "arabic": "حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، ‏‏‏‏‏‏حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، ‏‏‏‏‏‏حَدَّثَنَا سَعِ", "bengali": "", "english": "It was narrated from 'Uqbah bin 'Amir or Samurah bin Jundab that the Messenger of Allah (ﷺ) said:\"Any man who sells to two men, it is for the one who was first", "french": "", "indonesian": "", "russian": "", "urdu": "عقبہ بن عامر رضی اللہ عنہ یا سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ف", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 12, Hadith 54", "international_number": "2190", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2191", "arabic": "حَدَّثَنَا الْحُسَيْنُ بْنُ أَبِي السَّرِيِّ الْعَسْقَلَانِيُّ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ إِسْمَاعِيل،", "bengali": "", "english": "It was narrated from Samurah that the Messenger of Allah (ﷺ), said:\"If two (separate) authorized persons make a sale (of the same thing), then the first transaction is the one that is valid", "french": "", "indonesian": "", "russian": "", "urdu": "سمرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب دو اختیار رکھنے والے ایک", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 12, Hadith 55", "international_number": "2191", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2192", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ بَلَغَنِي ع", "bengali": "", "english": "It was narrated from 'Amr bin Shu'aib, from his father, from his grandfather that :the Prophet (ﷺ) forbade the deal involving earnest money", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے بیعانہ  ( عربان", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 12, Hadith 56", "international_number": "2192", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2193", "arabic": "حَدَّثَنَا الْفَضْلُ بْنُ يَعْقُوبَ الرُّخَامِيُّ، ‏‏‏‏‏‏حَدَّثَنَا حَبِيبُ بْنُ أَبِي حَبِيبٍ أَبُو", "bengali": "", "english": "It was narrated from 'Amr bin Shu'aib, from his father, from his grandfather that :the Prophet (ﷺ) forbade the deal involving earnest money. (Hasan)Abu 'Abdullah said: Earnest money refers to when a man buys an animal for one hundred Dinar, then he gives the seller two Dinar in advance and says: \"If I do not buy the animal, then the two Dinar are yours.\" And it was said that it refers, and Allah knows best, to when a man buys something, and gives the seller a Dirham or less or more, and says: \"If I take it (all well and good), and if I do not, then the Dirham is yours", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے  ( عربان کی ب", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 12, Hadith 57", "international_number": "2193", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2194", "arabic": "حَدَّثَنَا مُحْرِزُ بْنُ سَلَمَةَ الْعَدَنِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، ‏", "bengali": "", "english": "It was narrated that Abu Hurairah said:\"The Messenger of Allah (ﷺ) forbade Gharar transaction sand Hasah transactions", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بیع غرر اور بیع حصاۃ سے منع فرمای", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 58", "international_number": "2194", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2195", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏ وَالْعَبَّاسُ بْنُ عَبْدِ الْعَظِيمِ الْعَنْبَرِيُّ، ‏‏‏‏‏‏قَالَا:", "bengali": "", "english": "It was narrated that Ibn 'Abbas said:\"The Messenger of Allah (ﷺ) forbade Gharar transactions", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بیع غرر سے منع کیا ہے۔", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 59", "international_number": "2195", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2196", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا حَاتِمُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏حَدَّثَنَا جَهْضَ", "bengali": "", "english": "It was narrated that Abu Sa'eed Al-Khudri said:“The Messenger of Allah (ﷺ) forbade selling what is in the wombs of cattle until they give birth, and selling what is in their udders unless it is measured out, and selling a slave who has fled, and selling spoils of war until it has been distributed, and selling Sadaqah until it has been received, and what a diver is going to bring up", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے جانوروں کے پیٹ میں جو ہو اس", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 60", "international_number": "2196", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2197", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ أَيُّوبَ، ‏", "bengali": "", "english": "It was narrated from Ibn 'Umar that :the Prophet (ﷺ) forbade selling Hablul-Habalah", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے حمل کے حمل کو بیچنے سے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 61", "international_number": "2197", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2198", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عِيسَى بْنُ يُونُسَ، ‏‏‏‏‏‏حَدَّثَنَا الْأَخْضَرُ", "bengali": "", "english": "It was narrated from Anas bin Malik that :a man from among the Ansar came to the Prophet (ﷺ) and begged from him. He said, \"Do you have anything in your house?\" He said: \"Yes, a blanket, part of which we cover ourselves with and part we spread beneath us, and a bowl from which we drink water.\" He said: \"Givethem to me.\" So he brought them to him, and the Messenger of Allah (ﷺ) took them in his hand and said, \"Who will by these two things?\" A man said: \"I will by them for one Dirham.\" He said: \"Who will offer more than a Dirham?\" two or three times. A man said: \"I will buy them for two Dirham.\" So he gave them to him and took the two Dirham, which he gave to the Ansari and said: \"Buy food with one of them and give it to your family, and buy an axe with the other and bring it to me.\" So he did that, and the Messenger of Allah (ﷺ) took it and fixed a handle to it, and said: \"Go and gather firewood, and I do not want to see you for fifteen days.\" So he went and gathered firewood and sold it, then he came back, and he had earned ten Dirham. (The Prophet (ﷺ)) said: \"Buy food with some of it and clothes with some.\" Then he said: \"This is better for you than coming with begging (appearing) as a spot on your face on the Day of Resurrection. Begging is only appropriate for one who is extremely poor or who is in severe debt, or one who must pay painful blood money.”", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  انصار کا ایک شخص رسول اللہ صلی اللہ علیہ وسلم کی خدمت میں ا", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 62", "international_number": "2198", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2199", "arabic": "حَدَّثَنَا زِيَادُ بْنُ يَحْيَى أَبُو الْخَطَّابِ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ سُعَيْرٍ، ‏‏‏‏‏‏حَد", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:Whoever agrees with a Muslim to cancel a transaction Allah will forgive his sins on the Day of Resurrection", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص کسی مسلمان کے اقا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 63", "international_number": "2199", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2200", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏حَدَّثَنَا حَجَّاجٌ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ سَل", "bengali": "", "english": "It was nanated that Anas bin Malik said:\"Prices rose during the time of the Messenger of Allah (ﷺ), and they said: 'O Messenger of Allah, prices have risen, so fix the prices for us.' He said: 'Indeed Allah is the Musa'ir, [1] the Qabid, (Restrainer) the Basit,[2] the Razzaq (Provider). And I am hopeful that I meet my Lord and none of you are seeking (recompense from) me for an injustice involving blood or wealth", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے عہد میں ایک دفعہ قیمتیں چڑھ گئ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 64", "international_number": "2200", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2201", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ زِيَادٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْأَعْلَى، ‏‏‏‏‏‏حَدَّثَنَا سَعِيدٌ، ‏‏‏", "bengali": "", "english": "It was narrated that Abu Sa'eed said:\"Prices rose at the time of the Messenger of Allah (ﷺ), and they said: 'Why do you not fix the food prices, O Messenger of Allah?' He said: 'I hope that when I leave you, no one among you will be demanding restitution for a wrong that I have done to him", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے عہد میں مہنگائی بڑھ گئی، تو", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 65", "international_number": "2201", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2202", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ أَبَانَ الْبَلْخِيُّ أَبُو بَكْرٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عُلَي", "bengali": "", "english": "Uthman bin 'Affan narrated that the Messenger of Allah (ﷺ) said:“Allah will admit to Paradise a man who was lenient when he sold and when he bought", "french": "", "indonesian": "", "russian": "", "urdu": "عثمان بن عفان رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ اس شخص", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 66", "international_number": "2202", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2203", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، ‏‏‏‏‏‏حَدَّث", "bengali": "", "english": "It was narrated from Jabir bin 'Abdullah that the Messenger of Allah (ﷺ) said:\"May Allah have mercy on a person who is lenient when he sells, lenient when he buys, and lenient when he asks for payment", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ اس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 12, Hadith 67", "international_number": "2203", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2204", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا يَعْلَى بْنُ شَبِيبٍ، ‏‏‏‏‏‏عَنْ ع", "bengali": "", "english": "It was narrated that Qailah Umm Bani Anmar said:\"I came to the Messenger of Allah (ﷺ), during one of his 'Umrah at Marwah and said: 'O Messenger of Allah, I am a woman who buys and sells. When I want to buy something, I state a price less than I want to pay, then I raise it gradually until it reaches the price I want to pay. And when I want to sell something, I state a price more than I want, then I lower it until it reaches the price I want.' The Messenger of Allah (ﷺ) said: 'Do not do that, O Qailah. When you want to buy something, state the price you want, whether it is given or not. And when you want to sell something, state the price you want, whether it is given or not", "french": "", "indonesian": "", "russian": "", "urdu": "قیلہ ام بنی انمار رضی اللہ عنہا کہتی ہیں کہ  میں رسول اللہ صلیاللہ علیہ وسلم  کی خدمت میں آئی تو آپ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 68", "international_number": "2204", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2205", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏عَنْ الْجُرَيْرِيِّ", "bengali": "", "english": "It was narrated that Jabir bin 'Abdullah said:\"I was with the Prophet (ﷺ) on a military campaign, and he said to me: 'Will you sell this camel of yours for a Dinar?' I said: 'O Messenger of Allah, it is yours when I get to Al-Madinah.' He said: 'Then sell it for two Dinar, may Allah forgive you.' And he kept increasing the price for me, saying: 'May Allah forgive you,' each time, until the amount reached twenty Dinar. When I came to Al-Madinah, I took hold of the camel's head and brought it to the Prophet (ﷺ) and he said: 'O Bilal, give him twenty Dinar from the spoils of war.' And he said: 'Take your camel away and go to your people with it", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے ساتھ ایک غزوہ میں تھا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 69", "international_number": "2205", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2206", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَسَهْلُ بْنُ أَبِي سَهْلٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا ع", "bengali": "", "english": "It was narrated that 'Ali said:\"The Messenger of Allah (ﷺ) forbade haggling before sunrise, and (he forbade) slaughtering animals that yield milk", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے سورج نکلنے سے پہلے مول بھاؤ کرنے سے،", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 70", "international_number": "2206", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2207", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَأَحْمَدُ بْنُ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:\"There are three to whom Allah will not speak on the Day of Resurrection, nor will He look at them or purify them, and theirs will be a painful torment: A man who has surplus water in the desert but refuses to give any to a wayfarer; a man who sells a product to a man after 'Asr and swears by Allah that he bought it for such and such amount, and he believes him, when that is not the case; and a man who swears allegiance to a ruler, and only does so for worldly gains, so if he gives him some of (these worldly benefits) he fulfills his oath of allegiance, and if he is not given anything he does not uphold his oath of allegiance", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ قیامت کے دن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 71", "international_number": "2207", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2208", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated from Abu Dharr that the Prophet (ﷺ) said:\"There are three to whom Allah will not speak on the Day of Resurrection nor will He look at them or purify them, and theirs will be a painful torment.\" I said: \"Who are they, O Messenger of Allah? For they are indeed losers.\" He said: \"The one who lets his garment hang beneath his ankles, the one who reminds another of what he has given him, and the one who sells his product by means of false oaths", "french": "", "indonesian": "", "russian": "", "urdu": "ابوذر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تین آدمیوں سے اللہ تعالیٰ ق", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 72", "international_number": "2208", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2209", "arabic": "حَدَّثَنَا يَحْيَى بْنُ خَلَفٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْأَعْلَى، ‏‏‏‏‏‏ح وحَدَّثَنَا هِشَامُ بْنُ", "bengali": "", "english": "It was narrated from Abu Qatadah that the Messenger of Allah (ﷺ), said:\"Beware of swearing oaths when selling, for it may help you to make a sale but it destroys the blessing", "french": "", "indonesian": "", "russian": "", "urdu": "ابوقتادہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیع  ( خرید و فروخت )  م", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 73", "international_number": "2209", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2210", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنِي", "bengali": "", "english": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:\"Whoever buys a palm tree that has been pollinated, its fruits belong to the seller, unless the purchaser stipulated a condition.\" (Sahih) Another chain from Ibn 'Umar, from the Prophet (ﷺ), with similar wording", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو کوئی تابیر  (", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 74", "international_number": "2210", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2211", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏ح وحَدَّثَنَا هِشَا", "bengali": "", "english": "It was narrated from Salim bin 'Abdullah, bin 'Umar, from Ibn 'Umar, that :the Messenger of Allah (ﷺ) said: \"Whoever sells a palm tree that has been pollinated, its fruits belong to the seller, unless the purchaser stipulated a condition. And whoever buys a slave who has wealth, his wealth belongs to the seller, unless the purchaser stipulated a condition", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص تابیر  (", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 75", "international_number": "2211", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2212", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْوَلِيدِ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، ‏‏‏‏‏‏حَدَّثَنَا شُع", "bengali": "", "english": "It was narrated from Nafi' from Ibn 'Umar that the Prophet (ﷺ) said:\"Whoever sells a palm tree and sells a slave.\" Mentioning both of them together", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو کوئی کھجور کا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 76", "international_number": "2212", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2213", "arabic": "حَدَّثَنَا عَبْدُ رَبِّهِ بْنُ خَالِدٍ النُّمَيْرِيُّ أَبُو الْمُغَلِّسِ، ‏‏‏‏‏‏حَدَّثَنَا الْفُضَيْ", "bengali": "", "english": "It was narrated that 'Ubadah bin Samit said:\"The Messenger of Allah (ﷺ) ruled that the fruit of a palm tree belongs to the one who pollinated it, and that the wealth of a slave belongs to the one who sold him, unless the purchaser stipulated a condition", "french": "", "indonesian": "", "russian": "", "urdu": "عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فیصلہ کیا کہ کھجور کے درخت ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 77", "international_number": "2213", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2214", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ، ‏‏‏‏‏", "bengali": "", "english": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:\"Do not sell fruits until they have ripened.\" And he forbade (both) the seller and the purchaser (to engage in such a transaction)", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پختگی ظاہر ہونے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 78", "international_number": "2214", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2215", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عِيسَى الْمِصْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏عَن", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:\"Do not sell fruits until they have ripened", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پھلوں کو ان کی پختگی ظاہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 79", "international_number": "2215", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2216", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنْ ابْنِ جُرَيْجٍ، ‏‏‏‏‏‏عَنْ", "bengali": "", "english": "It was narrated from Jabir that :the Prophet (ﷺ) forbade selling fruits until they have ripened", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے پھلوں کو ان کی پختگی ظاہر ہو جانے س", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 12, Hadith 80", "international_number": "2216", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2217", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏حَدَّثَنَا حَجَّاجٌ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادٌ، ‏‏‏‏‏‏ع", "bengali": "", "english": "It was narrated from Anas bin Malik that :the Messenger of Allah (ﷺ) forbade selling fruits until they have changed the color, and selling grapes until they have turned black, and selling grains until they have hardened", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے پھل کی بیع سے منع کیا ہے یہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 81", "international_number": "2217", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2218", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated from Jabir bin 'Abdullah that :the Messenger of Allah (ﷺ) forbade selling for many years ahead", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے کئی سال کے لیے  ( پھل", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 82", "international_number": "2218", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2219", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ حَمْزَةَ، ‏‏‏‏‏‏حَدَّثَنَا ثَوْرُ بْ", "bengali": "", "english": "It was narrated from Jabir bin 'Abdullah that the Messenger of Allah (ﷺ) said:\"Whoever sells fruits then the crop fails, should not take any of his brother's money. Why would any of you take the money of his Muslim brother?", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے پھل بیچا،", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 83", "international_number": "2219", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2220", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْن", "bengali": "", "english": "It was narrated that Suwaid bin Qais said:\"Makhrafah Al' Abdi and I brought linens from Hajar[1] The Messenger of Allah (ﷺ) came to us to bargain with us with some trousers. There was someone with me who weighed (the goods) in exchange for a wage. So the Prophet (ﷺ) said to the one weighing: 'Weigh and add more", "french": "", "indonesian": "", "russian": "", "urdu": "سوید بن قیس رضی اللہ عنہ کہتے ہیں کہ  میں اور مخرفہ عبدی رضی اللہ عنہ دونوں ہجر سے کپڑا لائے، تو رسو", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 84", "international_number": "2220", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2221", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الْوَلِيدِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated that Simak bin Harb said:\"I heard Malik Abu Safwan bin 'Umairah, say: 'I bought a pair of trousers from the Messenger of Allah (ﷺ) before the Hijrah, and he weighed it for me and allowed more", "french": "", "indonesian": "", "russian": "", "urdu": "سماک بن حرب کہتے ہیں کہ  میں نے مالک ابوصفوان بن عمیرہ رضی اللہ عنہ کو کہتے سنا کہ ہجرت سے پہلے میں", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 85", "international_number": "2221", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2222", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الصَّمَدِ، ‏‏‏‏‏‏حَدَّثَنَا شُعْبَةُ، ‏‏‏", "bengali": "", "english": "It was narrated from Jabir bin 'Abdullah that the Messenger of Allah (ﷺ) said:\"When you weigh, allow more", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تولو تو جھکا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 86", "international_number": "2222", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2223", "arabic": "حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ بِشْرِ بْنِ الْحَكَمِ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ عَقِيلِ بْنِ خُوَي", "bengali": "", "english": "It was narrated that Ibn 'Abbas said:\"When the Prophet (ﷺ) came to Al-Madinah, they were the worst people in weights and measures. Then Allah, Glorious is He revealed: \"Woe to the Mutaffifun (those who give less in measure and weight)\",[1] and they were fair in weights and measures after that", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  جب نبی اکرم صلی اللہ علیہ وسلم مدینہ تشریف لائے تو مدینہ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 87", "international_number": "2223", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2224", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنْ الْعَلَاءِ بْنِ عَبْدِ الرّ", "bengali": "", "english": "It was narrated that Abu Hurairah said:\"The Messenger of Allah (ﷺ) passed by a man who was selling food. He put his hand in it and saw that there was something wrong with it. The Messenger of Allah (ﷺ) said, 'He is not one of us who cheats", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک شخص کے پاس سے گزرے جو گیہوں  ( غ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 88", "international_number": "2224", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2225", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ حَدَّثَنَا أَبُو نُعَيْمٍ، ‏‏‏‏‏‏حَدَّثَنَا يُونُسُ بْنُ", "bengali": "", "english": "It was narrated that Abu Hamra' said:\"I saw the Messenger of Allah (ﷺ) pass by a man having food in a vessel. He put his hand in it and said: 'Perhaps you are cheating. Whoever cheats us is not one of us", "french": "", "indonesian": "", "russian": "", "urdu": "ابوالحمراء رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو دیکھا، آپ ایک شخص کے پاس", "grades": "{'name': 'Al-Albani', 'grade': 'Very Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Very Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 89", "international_number": "2225", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2226", "arabic": "حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ، ‏‏‏‏‏‏عَ", "bengali": "", "english": "It was narrated from Ibn 'Umar that the Prophet (ﷺ) said:\"Whoever buys food, let him not sell it until he has taken full possession of it", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو اناج خریدے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 90", "international_number": "2226", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2227", "arabic": "حَدَّثَنَا عِمْرَانُ بْنُ مُوسَى اللَّيْثِيُّ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏ح وحَدَّ", "bengali": "", "english": "It was narrated that Ibn 'Abbas said:\"The Messenger of Allah (ﷺ) said: 'Whoever buys food, let him not sell it until he has taken full possession of it.'\" (Sahih) In his narration, (one of the narrators) Abu 'Awanah said: \"Ibn 'Abbas said: 'I think everything is like food", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو گیہوں خریدے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 91", "international_number": "2227", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2228", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ ابْنِ أَبِي لَيْلَى، ‏‏‏‏‏‏ع", "bengali": "", "english": "It was narrated that Jabir said:'The Messenger of Allah (ﷺ) forbade selling food bought by measure until two Sa' have been measured - the Sa' of the seller and the Sa' of the buyer", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اناج کو بیچنے سے منع کیا", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 92", "international_number": "2228", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2229", "arabic": "حَدَّثَنَا سَهْلُ بْنُ أَبِي سَهْلٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏عَنْ عُبَي", "bengali": "", "english": "It was narrated that Ibn 'Umar said:\"We used to buy food from troops of riders (i.e., the caravans) without knowing the amount, but the Messenger of Allah (ﷺ) forbade us to sell it until it had been delivered to us", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  ہم لوگ سواروں سے گیہوں  ( غلہ )  کا ڈھیر بغیر ناپے تولے ا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 93", "international_number": "2229", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2230", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مَيْمُونٍ الرَّقِّيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ يَزِيدَ، ‏‏‏‏‏‏ع", "bengali": "", "english": "It was narrated that 'Uthman bin 'Affan said:\"I used to sell dates in the marketplace, and I would say: 'This was such and such an amount (when I bought it).' I Would give the purchaser a specific amount of dates according to the way it had been measured for me, and take my profit. Then I began to have some doubts about that, so I asked the Messenger of Allah (ﷺ), and he said: ‘When you name the amount, measure it in front of the purchaser", "french": "", "indonesian": "", "russian": "", "urdu": "عثمان بن عفان رضی اللہ عنہ کہتے ہیں کہ  میں بازار میں کھجور بیچتا تھا، تو میں  ( خریدار سے )  کہتا:", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 94", "international_number": "2230", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2231", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَم", "bengali": "", "english": "It was narrated that Abdullah bin Busr Al-Mazini said:\"I heard the Messenger of Allah (ﷺ) say: 'Measure your food, may you be blessed therein", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن بسر مازنی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا ہے:", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 12, Hadith 95", "international_number": "2231", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2232", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عُثْمَانَ بْنِ سَعِيدِ بْنِ كَثِيرِ بْنِ دِينَارٍ الْحِمْصِيُّ، ‏‏‏‏‏‏حَدَّث", "bengali": "", "english": "It was narrated from Abu Ayyub that the Prophet (ﷺ) said:\"Measure your food, may you be blessed therein", "french": "", "indonesian": "", "russian": "", "urdu": "ابوایوب انصاری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اپنا اناج ناپ لیا ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 96", "international_number": "2232", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2233", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، ‏‏‏‏‏‏حَدَّثَنَا إِسْحَاق بْنُ إِبْرَاهِيمَ", "bengali": "", "english": "It was narrated that Abu Usaid said that :the Messenger of Allah (ﷺ) went to the market of Nabit,[1] and looked at it, and said: \"This is not a market for you.\" Then we went to another market and looked at it, and said: \"This is not a market for you.\" Then he came back to this market and walked around in it then he said: \"This is your market. It will always be your market and no duty will be levied on it.\" (Do,if)", "french": "", "indonesian": "", "russian": "", "urdu": "ابواسید رضی اللہ عنہ بیان کرتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نبیط کے بازار تشریف لے گئے، اس ک", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 97", "international_number": "2233", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2234", "arabic": "حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُسْتَمِرِّ الْعُرُوقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا أَبِي، ‏‏‏‏‏‏حَدَّثَنَا", "bengali": "", "english": "It was narrated that Salman said :\"I heard the Messenger of Allah (ﷺ) saying: 'Whoever goes to the Morning prayer first thing in the morning, he goes out with the banner of faith but whoever goes out to the marketplace first thing in the morning, he goes out under the banner of Iblis (Satan)", "french": "", "indonesian": "", "russian": "", "urdu": "سلمان رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا ہے:  جو صبح سویرے", "grades": "{'name': 'Al-Albani', 'grade': 'Very Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Very Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 98", "international_number": "2234", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2235", "arabic": "حَدَّثَنَا بِشْرُ بْنُ مُعَاذٍ الضَّرِيرُ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏عَنْ عَمْرِو", "bengali": "", "english": "It was narrated from Salim bin 'Abdullah bin 'Umar, from his father, that his grandfather told that the Messenger of Allah (ﷺ) said:\"Whoever says, when he enters the marketplace: 'La ilaha illallah wahdahu la sharika lahu, lahul-mulk wa lahul-hamdu, yuhyi wa yumitu, wa Huwa hayyun la yamutu, bi yadihil-khairu kulluhu, wa Huwa ala kulli shay’in Qadir (None has the right to be worshiped but Allah alone, with no partner, to Him belongs all sovereignty and to Him is the praise, He gives life and gives death, and He is Ever-Living and does not die; in His Hand is all goodness and He is Able to do all things),' Allah will record for him one million good deeds, and will erase from him one million bad deeds, and will build for him a house in Paradise", "french": "", "indonesian": "", "russian": "", "urdu": "عمر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص بازار میں داخل ہوتے وق", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 99", "international_number": "2235", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2236", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ حَدَّثَنَا هُشَيْمٌ، ‏‏‏‏‏‏عَنْ يَعْلَى بْنِ عَطَاءٍ، ‏‏", "bengali": "", "english": "It was narrated from Sakhr Al-Ghamidi that the Messenger of Allah (ﷺ) said:\"O Allah, bless my nation in their early mornings (i.e., what they do early in the morning).\" (Hasan)He said: \"When he sent out a raiding party or an army, he would send them at the beginning of the day.\" He said: (1) \"Sakhr was a man engaged in trade, and he used to send his goods out at the beginning of the day, and his wealth grew and increased", "french": "", "indonesian": "", "russian": "", "urdu": "صخر غامدی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اے اللہ! میری امت کے لی", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 100", "international_number": "2236", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2237", "arabic": "حَدَّثَنَا أَبُو مَرْوَانَ مُحَمَّدُ بْنُ عُثْمَانَ الْعُثْمَانِيُّ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:\"O Allah, bless my nation early in the morning of Thursday", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اے اللہ! میری امت کو جمع", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 101", "international_number": "2237", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2238", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْحَاق بْنُ جَعْفَرِ بْنِ مُحَمّ", "bengali": "", "english": "It was narrated from Ibn Umar that the Messenger of Allah (ﷺ) said:\"O Allah, bless my nation early in the morning", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اے اللہ! میری", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 102", "international_number": "2238", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2239", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ", "bengali": "", "english": "It was narrated from Ibn 'Umar that the Prophet (ﷺ) said:\"O Allah, bless my nation in their early mornings.\". It was narrated from Abu Hurairah that the Prophet (ﷺ) said: \"Whoever buys a Musarrah, he has the choice (of annulling the deal) for three days. If he returns it, then he must also give a Sa' of dates, not Samra'.\" Meaning wheat", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے «مصّراۃ» خریدی تو ا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 103", "international_number": "2239", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2240", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْوَاحِ", "bengali": "", "english": "Abdullah bin 'Umar said:\"The Messenger of Allah (ﷺ) said: 'Whoever buys a Muhaffalah, (1) he has the choice (of annulling the deal) for three days. If he returns it, then he must also give wheat equal to twice, the amount of its milk, or equal to the amount of its milk", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  لوگو! اگر کوئی «", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 104", "international_number": "2240", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2241", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا الْمَسْعُودِيُّ، ‏", "bengali": "", "english": "It was narrated that 'Abdullah bin Mas'ud said:\"I bear witness that the true and truly inspired one Abul-Qasim (ﷺ) told us: 'Selling a Muhaffalah is Khilabah, and Khilabah is not lawful for the Muslim.\"' (Ibn Majah said: \" Meaning: 'Deception)", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  میں صادق و مصدوق ابوالقاسم صلی اللہ علیہ وسلم پر گواہی دی", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 105", "international_number": "2241", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2242", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ", "bengali": "", "english": "It was narrated from Aishah that :the Messenger of Allah (ﷺ) ruled that what a slave earns belongs to his guarantor", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فیصلہ کیا کہ غلام کی", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 106", "international_number": "2242", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2243", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مُسْلِمُ بْنُ خَالِدٍ الزَّنْجِيُّ، ‏‏‏‏‏‏حَدَّثَ", "bengali": "", "english": "It was narrated from 'Aishah that:a man bought a slave and put him to work, then he found some defect in him, so he returned him. He (the seller) said: \"O Messenger of Allah he put my slave to work.\" The Messenger of Allah (ﷺ) said: \"A slave's earnings belong to his guarantor", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  ایک شخص نے ایک غلام خریدا، پھر اس سے مزدوری کرائی، ب", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 107", "international_number": "2243", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2244", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ،", "bengali": "", "english": "It was narrated from Samurah bin Jundab that the Messenger of Allah (ﷺ) said:\"The contractual obligation regarding a slave lasts for three days", "french": "", "indonesian": "", "russian": "", "urdu": "سمرہ بن جندب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیچنے والے پر غلام ی", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 108", "international_number": "2244", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2245", "arabic": "حَدَّثَنَا عَمْرُو بْنُ رَافِعٍ، ‏‏‏‏‏‏حَدَّثَنَا هُشَيْمٌ، ‏‏‏‏‏‏عَنْ يُونُسَ بْنِ عُبَيْدٍ، ‏‏‏‏‏‏", "bengali": "", "english": "It was narrated from 'Uqbah bin 'Amir that the Messenger of Allah (ﷺ) said:\"There is no contractual obligation after four (days)", "french": "", "indonesian": "", "russian": "", "urdu": "عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  چار دن کے بعد بیچنے", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 109", "international_number": "2245", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2246", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبِي سَم", "bengali": "", "english": "It was narrated that 'Uqbah bin 'Amir said:\"I heard the Messenger of Allah (ﷺ) say: 'The Muslim is the brother of another Muslim, and it is not permissible for a Muslim to sell his brother goods in which there is a defect, without pointing that out to him", "french": "", "indonesian": "", "russian": "", "urdu": "عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  مسلمان مس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 110", "international_number": "2246", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2247", "arabic": "حَدَّثَنَا عَبْدُ الْوَهَّابِ بْنُ الضَّحَّاكِ، ‏‏‏‏‏‏حَدَّثَنَا بَقِيَّةُ بْنُ الْوَلِيدِ، ‏‏‏‏‏‏عَ", "bengali": "", "english": "It was narrated that Wathilah bin Asqa' said:\"I heard the Messenger of Allah (ﷺ) say: 'Whoever sells defective goods without pointing it out, he will remain subject to the wrath of Allah, and the angels will continue to curse him", "french": "", "indonesian": "", "russian": "", "urdu": "واثلہ بن اسقع رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو کوئی", "grades": "{'name': 'Al-Albani', 'grade': 'Very Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Very Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 111", "international_number": "2247", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2248", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated that 'Abdullah bin Mas'ud said:\"When captives were brought to him, the Prophet (ﷺ) would give the members of one family together (to one person), not wanting to separate them", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس جب قیدی  ( جو آپس میں", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 112", "international_number": "2248", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2249", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَفَّانُ، ‏‏‏‏‏‏عَنْ حَمَّادٍ، ‏‏‏‏‏‏أَنْبَأَنَا", "bengali": "", "english": "It was narrated that 'Ali said:\"The Messenger of Allah (ﷺ) gave me two slaves who were brothers, and I sold one of them. He said: 'What happened with the two slaves?' I said: 'I sold one of them.' He said: 'Take him back", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے دو غلام ہبہ کئے جو دونوں سگے بھائ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 113", "international_number": "2249", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2250", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ بْنِ هَيَّاجٍ، ‏‏‏‏‏‏حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، ‏‏‏‏‏", "bengali": "", "english": "It was narrated that Abu Musa said:\"The Messenger of Allah (ﷺ) cursed the one who separates a mother and her child, or a brother from his brother", "french": "", "indonesian": "", "russian": "", "urdu": "ابوموسیٰ اشعری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اس شخص پر لعنت فرمائی ہے جو", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 114", "international_number": "2250", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2251", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبَّادُ بْنُ لَيْثٍ صَاحِبُ الْكَرَابِيسِيِّ،", "bengali": "", "english": "It was narrated that 'Abdul-Majid bin Wahb said:\"Adda' bin Khalid bin Hawdhah said to me: 'Shall I not read to you a letter that the Messenger of Allah (ﷺ), wrote to me?' I said: 'Yes.' So he took out a letter. In it was: 'This is what 'Adda' bin Khalid bin Hawdhah bought [from] Muhammad the Messenger of Allah (ﷺ) He bought from him a slave' or 'a female slave, having no ailments, nor being a runaway, not having any malicious behavior. Sold by a Muslim to a Muslim", "french": "", "indonesian": "", "russian": "", "urdu": "عبدالمجید بن وہب کہتے ہیں کہ  مجھ سے عداء بن خالد بن ہوذہ رضی اللہ عنہ نے کہا: کیا میں تم کو وہ تحری", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 12, Hadith 115", "international_number": "2251", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2252", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو خَالِدٍ الْأَحْمَرُ، ‏‏‏‏‏‏عَنْ ابْنِ", "bengali": "", "english": "It was narrated from 'Amr bin Shu'aib from his father that his grandfather told that the Messenger of Allah (ﷺ) said:\"When anyone of you buys a slave woman let him say: 'Allahumma inni as'aluka khairaha wa khaira ma jabaltaha alaihi, wa a'udhu bika min sharriha wa sharri ma jabaltaha alaihi (O Allah, I ask You for the goodness within her and the goodness that You have made her inclined towards, and I seek refuge with You from the evil within her and the evil that You have made her inclined towards).' And he should pray for blessing. And if anyone of you buys a camel then he should take hold of its hump and pray for. blessing and say similar words", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 12, Hadith 116", "international_number": "2252", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2253", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَهِشَامُ بْنُ", "bengali": "", "english": "It was narrated that Malik bin Aws bin Hadathan Nasri said:\"I heard 'Umar bin Al-Khattab say: 'The Messenger of Allah (ﷺ) said: \"Exchanging gold for gold is usury unless it is done on the spot. (Exchanging) wheat for wheat is usury, unless it is done on the spot. (Exchanging) barley for barley is usury unless it is done on the spot. (Exchanging) dates for dates is usury, unless it is done on the spot", "french": "", "indonesian": "", "russian": "", "urdu": "عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سونے کو سونے سے بیچنا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 117", "international_number": "2253", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2254", "arabic": "حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ زُرَيْعٍ، ‏‏‏‏‏‏ح وحَدَّثَنَا مُح", "bengali": "", "english": "Muslim bin Yasar and 'Abdullah bin 'Ubaid said :\"Ubadah bin Samit and Mu'awiyah happened to meet, either in a church or in a synagogue. 'Ubadah bin Samit narrated to them and said: 'The Messenger of Allah (ﷺ) forbade us from selling silver for silver, gold for gold, wheat for wheat, barley for barley, and dates for dates.'I one of them said: \"And salt for salt,\" but the other did not say it. \"And he commanded us to sell wheat for barley, or barley for wheat, hand-to-hand, however we wished", "french": "", "indonesian": "", "russian": "", "urdu": "مسلم بن یسار اور عبداللہ بن عبید سے روایت ہے کہ  عبادہ بن صامت اور معاویہ رضی اللہ عنہما دونوں کسی ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 118", "international_number": "2254", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2255", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَعْلَى بْنُ عُبَيْدٍ، ‏‏‏‏‏‏حَدَّثَنَ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Prophet (ﷺ) said:'(Sell) silver for silver, gold for gold, barley for barley, wheat for wheat, like for like", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  چاندی کو چاندی سے، اور سو", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 119", "international_number": "2255", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2256", "arabic": "حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏عَنْ مُحَمَّدِ بْنِ عَم", "bengali": "", "english": "It was narrated that Abu Sa’eed said:“The Prophet used to give us dates from the collection (mixed) [1] dates, and we would exchange them for dates that were better, and we add to the price. [2] The Messenger of Allah said: ‘It is not right to give one Sa of dates for two Sa, nor one Dirham for two Dirham. A Dirham for a Dirham and a Dinar for a Dinar is allowed: the only difference between them is in weight (i.e., the weight must be equal.)’” Sahih", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم ہمیں مختلف قسم کی مخلوط کھجوریں", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 120", "international_number": "2256", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2257", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ عَمْرِ", "bengali": "", "english": "It was narrated that Abu Hurairah said:\"I heard Abu Saeed Al-Khudri say: 'A Dirham for a Dirham and a Dinar for a Dinar.' So I said: 'I heard Ibn 'Abbas say something other than that.' He said: 'But I met Ibn 'Abbas and said: \"Tell me about what you say concerning exchange is it something that you heard from the Messenger of Allah (ﷺ) or something that You found in the Book of Allah?\" He said: \"I did not find it in the Book of Allah, and I did not hear it from the Messenger of Allah; rather Usamah bin Zaid told me that the Messenger of Allah (ﷺ) said: \"Usury is only in credit", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میں نے ابو سعید خدری رضی اللہ عنہ کو کہتے سنا کہ درہم کو درہم سے،", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 121", "international_number": "2257", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2258", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، ‏‏‏‏‏‏أَنْبَأَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏عَنْ سُلَيْمَانَ بْ", "bengali": "", "english": "It was narrated that Abu Jawza' said:\"I heard him meaning Ibn 'Abbas allowing exchange (of Dirhams for Dirham etc., if extra was given) and that was narrated from him. Then I heard that he has taken back this opinion. I met him in Makkah and said: 'I heard that you had taken back (your opinion).' He said: 'Yes. That was just my own opinion, but Abu Sa'eed narrated from the Messenger of Allah (ﷺ) that he forbade exchange (of like items if extra is given)", "french": "", "indonesian": "", "russian": "", "urdu": "ابوالجوزاء کہتے ہیں کہ  میں نے عبداللہ بن عباس رضی اللہ عنہما کو بیع صرف کے جواز کا حکم دیتے سنا، او", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 122", "international_number": "2258", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2259", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنِ", "bengali": "", "english": "It was narrated that Zuhri heard Malik bin Aws bin Hadathan say:\"I heard 'Umar say: \"The Messenger of Allah (ﷺ), said: 'Gold for silver is usury, unless it is exchanged on the spot.\"' (Sahih) Abu Bakr bin Abu-Shaibah said: \"I heard sufyan saying: 'Gold for silver.\" memorize (this)", "french": "", "indonesian": "", "russian": "", "urdu": "عمر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سونے کو چاندی سے بیچنا سود ہے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 123", "international_number": "2259", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2260", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ ابْنِ شِهَابٍ،", "bengali": "", "english": "It was narrated that Malik bin Aws bin Hadathan said:\"I came saying. 'Who will exchange Dirham?' Talhah bin 'Ubaidullah, who was with 'Umar bin Khattab, said: 'Show us your gold, then come to us; when our treasure comes, we will give you your silver.' 'Umar said: 'No, by Allah, you will give him silver (now), or give him back his gold, for the Messenger of Allah (ﷺ) said: \"Silver for gold is usury, unless it is exchanged on the spot", "french": "", "indonesian": "", "russian": "", "urdu": "مالک بن اوس بن حدثان کہتے ہیں کہ  میں یہ کہتے ہوئے آیا کہ کون درہم کی بیع صرف کرتا ہے؟ یہ سن کر طلح", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 124", "international_number": "2260", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2261", "arabic": "حَدَّثَنَا أَبُو إِسْحَاق الشَّافِعِيُّ إِبْرَاهِيمُ بْنُ مُحَمَّدِ بْنِ الْعَبَّاسِ، ‏‏‏‏‏‏حَدَّثَن", "bengali": "", "english": "It was narrated from Umar bin Muhammad bin 'Ali bin abi Talib, from his father, that his grandfather said:'The Messenger of Allah (ﷺ) said: 'Dinar for Dinar, Dirham for Dirham, with no increase between them. Whoever has need of silver, let him trade gold for it, and whoever has need of gold, let him trade silver for it, and let the transaction be done on the spot", "french": "", "indonesian": "", "russian": "", "urdu": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  دینار کو دینار سے، اور درہم ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Muquf'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 125", "international_number": "2261", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2262", "arabic": "حَدَّثَنَا إِسْحَاق بْنُ إِبْرَاهِيمَ بْنِ حَبِيبٍ، ‏‏‏‏‏‏ وَسُفْيَانُ بْنُ وَكِيعٍ، ‏‏‏‏‏‏ وَمُحَمّ", "bengali": "", "english": "It was narrated that Ibn 'Umar said:\"I used to sell camels, and I used to buy gold for silver and silver for gold, Dinar for Dirham and Dirham for Dinar. I asked the Prophet (ﷺ) about that, and he said: 'If you take one of them and give the other, then you and your companion should not separate until everything is clear (i.e., the exchange is completed).’” (Hasan) Another chain with similar wording", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  میں اونٹ بیچا کرتا تھا، تو میں چاندی  ( جو قیمت میں ٹھہرت", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 12, Hadith 126", "international_number": "2262", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2263", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَسُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏ وَهَارُونُ بْنُ", "bengali": "", "english": "It was narrated from 'Alqamah bin 'Abdullah that his father said:\"The Messenger of Allah (ﷺ) forbade breaking the coins of the Muslims that are in circulation among them, without any necessary reason.”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بغیر ضرورت مسلمانوں کے را", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 127", "international_number": "2263", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2264", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏ وَإِسْحَاق بْنُ سُلَيْمَانَ، ‏‏‏", "bengali": "", "english": "It was narrated from 'Abdullah bin Yazid, the freed slave of Al-Aswad bin Sufyan, that :Zaid, Abu 'Ayyash, the freed slave of Bani Zuhrah, told him that he asked Sa'd bin Abu Waqqas about buying wheat with barley. Sa'd said to him: \"Which of them is better?\" He said: \"Wheat.\" He told him not to do that and said: \"I heard the Messenger of Allah (ﷺ) being asked about buying fresh dates with dried dates, and he said: 'Do fresh dates decrease in weight when they become dry?' They said: 'Yes.' So he told them not to do that", "french": "", "indonesian": "", "russian": "", "urdu": "بنی زہرۃ کے غلام زید ابوعیاش کہتے ہیں کہ  انہوں نے سعد بن ابی وقاص رضی اللہ عنہ سے پوچھا: سالم جَو ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 128", "international_number": "2264", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2265", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ، ‏‏‏‏‏", "bengali": "", "english": "It was narrated that 'Abduilah bin 'Umar said:\"The Messenger of Allah (ﷺ) forbade the Muzabanah. The Muzdbanah means when a man sells the dates of his grove when they are still on the tree, for a measure of dty dates;[2] or, if it is grapes, he sells them when they are still on the vine, for a measure of raisins; or if it is a crop, he sells it for food, estimating the amount (of the crop in the field). He forbade all of these things", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مزابنہ سے منع فرمایا، مزا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 129", "international_number": "2265", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2266", "arabic": "حَدَّثَنَا أَزْهَرُ بْنُ مَرْوَانَ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏عَنْ أَيُّوبَ، ‏‏‏‏", "bengali": "", "english": "lt was narrated from Sabir bin 'Abdullah that :the Messenger of Allah (ﷺ) forbade the Muhaqalah and the Muzabanah", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے محاقلہ اور مزابنہ سے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 130", "international_number": "2266", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2267", "arabic": "حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْأَحْوَصِ، ‏‏‏‏‏‏عَنْ طَارِقِ بْنِ عَب", "bengali": "", "english": "It was narrated that Rafi, bin Khadij said:\"The Messenger of Allah (ﷺ) forbade the Muhaqalah and the Muzabanah", "french": "", "indonesian": "", "russian": "", "urdu": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے محاقلہ اور مزابنہ سے منع کیا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 131", "international_number": "2267", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2268", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا", "bengali": "", "english": "It was narrated from Salim from his father:\"Zaid bin Thabit narrated to me that the Messenger of Allah (ﷺ) gave a concession regarding the sale of 'Araya.”", "french": "", "indonesian": "", "russian": "", "urdu": "زید بن ثابت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے عرایا کی بیع میں رخصت دی ہے ۱؎", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 132", "international_number": "2268", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2269", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ يَحْيَى بْنِ س", "bengali": "", "english": "It was narrated from 'Abdullah bin 'Umar that he said:\"Zaid bin Thabit told me that the Messenger of Allah (ﷺ) gave a concession regarding the sale of the estimated harvest of 'Araya return for dried dates.\" (Sahih) Yahya (one of the narrators) said: \"The 'Araya is when a man purchases dates on the trees for food that his family has that is ripe, by estimating them (the dates)", "french": "", "indonesian": "", "russian": "", "urdu": "زید بن ثابت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے عریہ کی بیع میں اجازت دی ہے کہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 133", "international_number": "2269", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2270", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏عَنْ سَعِي", "bengali": "", "english": "It was narrated from Samurah bin Jundub that :the Messenger of Allah (ﷺ) forbade selling animals for animals on credit", "french": "", "indonesian": "", "russian": "", "urdu": "سمرہ بن جندب رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے حیوان کو حیوان کے بدلے ادھ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 134", "international_number": "2270", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2271", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، ‏‏‏‏‏‏ وَأَبُو خَالِدٍ", "bengali": "", "english": "It was narrated from Jabir that the Messenger of Allah (ﷺ) said:\"There is nothing wrong with selling animals, one for two, hand to hand,\" but he disliked selling them on credit", "french": "", "indonesian": "", "russian": "", "urdu": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ایک حیوان کو دو حیوان کے بدل", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 135", "international_number": "2271", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2272", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْحُسَيْنُ بْنُ عُرْوَةَ، ‏‏‏‏‏‏ح و", "bengali": "", "english": "It was narrated from Anas that :the Prophet (ﷺ) bought Safiyyah for seven slaves. (Sahih) (One of the narrators) 'Abdur-Rahman said: \"From Dihyah Kalbi", "french": "", "indonesian": "", "russian": "", "urdu": "انس رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ام المؤمنین صفیہ رضی اللہ عنہا کو سا", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 136", "international_number": "2272", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2273", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا الْحَسَنُ بْنُ مُوسَى، ‏‏‏‏‏‏عَنْ حَمّ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:' \"'On the night in which I was taken on the Night Journey (Al-Isra'), I came to people whose stomachs were like houses, in which there were snakes that could be seen from outside their stomachs. I said: 'Who are these, O Jibra’il?’ He said: 'They are the ones who consumed usury", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  معراج کی رات میں کچھ لوگ", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 137", "international_number": "2273", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2274", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، ‏‏‏‏‏‏عَنْ أ", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:\"There are seventy degrees of usury, the least of which is equivalent to a man having intercourse with his mother", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سود ستر گناہوں کے برابر", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 138", "international_number": "2274", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2275", "arabic": "حَدَّثَنَا عَمْرُو بْنُ عَلِيٍّ الصَّيْرَفِيُّ أَبُو حَفْصٍ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، ‏", "bengali": "", "english": "It was narrated from 'Abdullah that the Prophet (ﷺ) said:\"There are seventy-three degrees of usury", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  سود کے تہتر درواز", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 139", "international_number": "2275", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2276", "arabic": "حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، ‏‏‏‏‏‏حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، ‏‏‏‏‏‏حَدَّ", "bengali": "", "english": "It was narrated that 'Umar bin Khattab said:\"The last thing to be revealed was the Verse on usury but the Messenger of Allah (ﷺ) died before he had explained it to us. So give up usury (interest) and doubtful things", "french": "", "indonesian": "", "russian": "", "urdu": "عمر رضی اللہ عنہ کہتے ہیں کہ  آخری آیت جو نازل ہوئی، وہ سود کی حرمت والی آیت ہے، رسول اللہ صلی ال", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih Hadith'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 140", "international_number": "2276", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2277", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، ‏‏‏‏‏‏حَدَّثَنَا شُعْب", "bengali": "", "english": "It was narrated from 'Abdullah bin Mas'ud that :Xthe Messenger of Allah (ﷺ) cursed the one who consumes usury, the one who pays it, those who witness it and the one who writes it down", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے سود کے کھانے والے پر،", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 141", "international_number": "2277", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2278", "arabic": "حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل ابْنُ عُلَيَّةَ، ‏‏‏‏‏‏حَدَّثَن", "bengali": "", "english": "It was narrated from Abu Hurairah that the Messenger of Allah (ﷺ) said:“There will come a time when there will be no one left who does not consume usury (interest), and whoever does not consume it will nevertheless be affected by it", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  یقیناً لوگوں پر ایک زمان", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 142", "international_number": "2278", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2279", "arabic": "حَدَّثَنَا الْعَبَّاسُ بْنُ جَعْفَرٍ، ‏‏‏‏‏‏حَدَّثَنَا عَمْرُو بْنُ عَوْنٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى", "bengali": "", "english": "It was narrated from Ibn Mas'ud that the Prophet (ﷺ) said:\"There is no one who deals in usury a great deal (to increase his wealth) but he will end up with little (i.e., his wealth will be decreased)", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے بھی سود سے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 143", "international_number": "2279", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2280", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنِ ابْنِ أَبِي", "bengali": "", "english": "It was narrated that Ibn 'Abbas said:\"When the Prophet (ﷺ) came (to Al-Madinah), they used to pay in advance for dates, two or three years in advance. He said: 'Whoever pays in advance for dates, let him pay for a known amount or a known weight, to be delivered at a known time.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مدینہ تشریف لائے، اس وقت اہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 144", "international_number": "2280", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2281", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، ‏‏‏‏‏‏عَ", "bengali": "", "english": "It was narrated from Muhammad bin Hamzah bin Yusuf bin 'Abdullah bin Salam, from his father, that his grandfather 'Abdullah bin Salam said:\"A man came to the Prophet (ﷺ) and said, 'The tribe of Banu so-and- so, who were descended from the Jews, have become Muslim, and they are starving, and I am afraid that they may apostatize.' The Prophet (ﷺ) said: 'Who has something with him?' A Jewish man said: 'I have such and such, and he named it, and I think he said three hundred Dinar for such and such 'an amount (of produce) from the garden of the tribe of Banu so-and-so.' The Messenger of Allah (ﷺ) said: 'For such and such a price at such and such a time, but not from the garden of the tribe of Banu so-and- so", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن سلام رضی اللہ عنہ کہتے ہیں کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں حاضر ہوا،", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 145", "international_number": "2281", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2282", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، ‏‏‏‏‏‏ وَعَبْدُ الرَّحْمَ", "bengali": "", "english": "It was narrated that Abu Mujalid said:\"Abdullah bin Shaddad and Abu Barzah had a dispute about paying in advance. They sent me to 'Abdullah bin Abu Awfa to ask him about it. He said: 'We used to make payments in advance at the time of the Messenger of Allah (ﷺ) and the time of Abu Bakr and 'Umar, for wheat, barley, raisins and dates, to people who did not yet possess those things.' I asked Ibn Abza, and he said something similar", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن ابی مجالد کہتے ہیں کہ  عبداللہ بن شداد اور ابوبرزہ رضی اللہ عنہما کے درمیان بیع سلم کے سل", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 146", "international_number": "2282", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2283", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا شُجَاعُ بْنُ الْوَلِيدِ، ‏‏", "bengali": "", "english": "It was narrated from Abu Sa'eed that the Messenger of Allah (ﷺ) said:\"When you have paid in advance for something, do not exchange it for something else.\" (Da'if)Another chain with similar wording", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم کسی چیز میں ب", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 147", "international_number": "2283", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2284", "arabic": "حَدَّثَنَا هَنَّادُ بْنُ السَّرِيِّ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْأَحْوَصِ، ‏‏‏‏‏‏عَنْ أَبِي إِسْحَاق،", "bengali": "", "english": "It was narrated that Najrani said:\"I said to 'Abdullah bin 'Umar: 'Can I pay in advance for a date palm before it bears fruit?' He said: 'No.' I said: 'Why not?' He said: 'A man paid in advance for a grove of trees during the time of the Messenger of Allah (ﷺ), before they had produced any fruit, and they did not bear anything that year. The purchaser said: 'They belong to me until they produce but the seller said: 'I only sold the trees to you for this year! They referred their dispute to the Messenger of Allah who said to the seller: 'Did he take anything from your date palms?' He said: 'No.' He said: 'Then why do you regard his wealth as lawful for You? Give back what you took from him, and do not take payment in advance for date palms until their usefulness appears", "french": "", "indonesian": "", "russian": "", "urdu": "نجرانی کہتے ہیں کہ  میں نے عبداللہ بن عمر رضی اللہ عنہما سے کہا: کیا میں کسی درخت کے کھجور کی ان کے", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 148", "international_number": "2284", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2285", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مُسْلِمُ بْنُ خَالِدٍ، ‏‏‏‏‏‏حَدَّثَنَا زَيْدُ بْ", "bengali": "", "english": "It was narrated from Abu Rafi' that:the Prophet (ﷺ) asked a man to give as a loan a young camel and said: “When the camels of the Sadaqah come, we will pay you back.” When the camels came, he said: \" O Abu Rafi', pay this man back for his Young camel.\" But all I could find was a seven-year-old camel or that which is better. I told the Prophet (ﷺ) and he said: \"Give it to him, for the best of People are those who are best in repaying", "french": "", "indonesian": "", "russian": "", "urdu": "ابورافع رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک شخص سے ایک جوان اونٹ کی بیع", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 149", "international_number": "2285", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2286", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا زَيْدُ بْنُ الْحُبَاب، ‏‏‏‏‏‏حَدَّثَنَ", "bengali": "", "english": "Sa'eed bin Hani' said:\"I heard 'Irbad bin Sariyah say: 'I was with the Prophet (ﷺ) and a Bedouin said: \"Pay me back for my young camel, and he gave him an older (i.e., better) camel.\" He said: 'O Messenger of Allah! It is older (i.e., better) than my camel.' The Messenger of Allah (ﷺ) said: 'The best of people are those who are best in repaying", "french": "", "indonesian": "", "russian": "", "urdu": "عرباض بن ساریہ رضی اللہ عنہ کہتے ہیں کہ  عرباض بن ساریہ رضی اللہ عنہ کہتے ہیں کہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 150", "international_number": "2286", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2287", "arabic": "حَدَّثَنَا عُثْمَانُ، ‏‏‏‏‏‏ وَأَبُو بَكْرٍ ابْنَا أَبِي شَيْبَةَ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا عَبْ", "bengali": "", "english": "It was narrated that Sa'ib said to the Prophet (ﷺ):\"You were my partner during the Ignorance period and you were the best of partners, you did not contend or dispute", "french": "", "indonesian": "", "russian": "", "urdu": "سائب رضی اللہ عنہ کہتے ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم سے عرض کیا: اللہ کے رسول! زمانہ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 151", "international_number": "2287", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2288", "arabic": "حَدَّثَنَا أَبُو السَّائِبِ سَلْمُ بْنُ جُنَادَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو دَاوُدَ الْحَفَرِيُّ، ‏‏‏‏", "bengali": "", "english": "It was narrated that 'Abdullah said:\"Sa'd, 'Ammar and I entered into a partnership on the day of Badr, (agreeing to share) whatever was allotted to us. 'Ammar and I did not get anything, but Sa'd got two men (slaves)", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  میں سعد اور عمار تینوں بدر کے دن مال غنیمت میں شریک ہوئے،", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 152", "international_number": "2288", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2289", "arabic": "حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، ‏‏‏‏‏‏حَدَّثَنَا بِشْرُ بْنُ ثَابِتٍ الْبَزَّارُ، ‏‏‏", "bengali": "", "english": "lt was narrated from Salih bin Suhaib that his father said:\"The Messenger of Allah (ﷺ) said: 'There are three things in which there is blessing: A sale with deferred payment; Muqaradhah (profit sharing); and mixing wheat with barley for one's house, but not for sale", "french": "", "indonesian": "", "russian": "", "urdu": "صہیب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تین چیزوں میں برکت ہے: پہلی", "grades": "{'name': 'Al-Albani', 'grade': 'Very Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Very Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Very Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 153", "international_number": "2289", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2290", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ أَبِي زَائِدَةَ، ‏‏‏‏‏‏عَنِ الْأ", "bengali": "", "english": "It was narrated from 'Aishah that the Messenger of Allah (ﷺ) said:\"The best of your provision is what you earn, and your children are part of what you earn", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تمہارے کھانوں", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 154", "international_number": "2290", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2291", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عِيسَى بْنُ يُونُسَ، ‏‏‏‏‏‏حَدَّثَنَا يُوسُفُ بْن", "bengali": "", "english": "It was narrated from Jabir bin 'Abdullah that a man said:\"O Messenger of Allah, I have wealth and a son, and my father wants to take all my wealth.\" He said: \"You and your wealth belong to your father", "french": "", "indonesian": "", "russian": "", "urdu": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  ایک شخص نے کہا: اللہ کے رسول! میرے پاس مال اور اولاد", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 155", "international_number": "2291", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2292", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏ وَيَحْيَى بْنُ حَكِيمٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا يَزِي", "bengali": "", "english": "It was narrated from 'Amr bin Shu'aib, from his father, that his grandfather said:\"A man came to the Messenger of Allah (ﷺ), and said: 'My father is taking all my wealth.' He said: 'You and your wealth belong to your father.' And the Messenger of Allah (ﷺ) said: 'Your children are among the best of your earnings, so eat from your wealth.’”", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم کے پاس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Lighairihi'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 12, Hadith 156", "international_number": "2292", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2293", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَأَبُو عُمَرَ", "bengali": "", "english": "It was narrated that 'Aishah said:'Hind came to the Prophet (ﷺ) and said: 'O Messenger of Allah, Abu Sufyan is a stingy man and he does not give me enough for me and my child, except for what I take from his wealth without him realizing.' He said: Take what is sufficient for you and your child, on a reasonable basis", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ہند رضی اللہ عنہا نبی اکرم صلی اللہ علیہ وسلم کی خدمت م", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 157", "international_number": "2293", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2294", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبِي، ‏‏‏‏‏‏ وَأَبُو مُعَا", "bengali": "", "english": "It was narrated from 'Aishah that the Messenger of Allah (ﷺ) said:\"When a woman spends\" and my father said: - \"When a woman feeds (the poor) from her husband's house, without spending too much, she will have her reward, and he will be rewarded likewise because he earned it , and she will be rewarded for what she spent. The same applies to the storekeeper, without anything being detracted from their rewards.”", "french": "", "indonesian": "", "russian": "", "urdu": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب عورت اپنے ش", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 158", "international_number": "2294", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2295", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ، ‏‏‏‏‏‏حَدَّثَنِي شُرَح", "bengali": "", "english": "Shurahbil bin Muslim Al-Khawlani said:I heard Abu Umamah Al-Bahili say: I heard the Messenger of Allah (ﷺ) say: \" No woman should spend anything from her house without her husband's permission.\" They said: \"O Messenger of Allah, not even food?\" He said: \"That is among the best of our wealth", "french": "", "indonesian": "", "russian": "", "urdu": "ابوامامہ باہلی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  عورت اپ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Hasan'}", "reference": "Book 12, Hadith 159", "international_number": "2295", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2296", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏ح وحَدَّثَنَا عَمْرُو بْنُ", "bengali": "", "english": "It was narrated from Muslim Al-Mula'i that he heard Anas bin Malik say:\"The Messenger of Allah (ﷺ) used to accept the invitation of a slave", "french": "", "indonesian": "", "russian": "", "urdu": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم غلام کی دعوت قبول کرتے تھے۔", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 160", "international_number": "2296", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2297", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، ‏‏‏‏‏‏عَنْ مُحَمَّدِ بْن", "bengali": "", "english": "It was narrated that 'Umair, the freed slave of Aabi Lahm, said:\"My master used to give me food and I would feed others from it, then he stopped me,\" or he said: \"He beat me. So I asked the Prophet,” -or- \"he asked him and I said: 'I will not stop.' He said: 'Both of you will be rewarded", "french": "", "indonesian": "", "russian": "", "urdu": "عمیر مولی آبی اللحم رضی اللہ عنہما کہتے ہیں کہ  میرے مالک مجھے کوئی چیز دیتے تو میں اس میں سے اوروں", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 161", "international_number": "2297", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2298", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا شَبَابَةُ بْنُ سَوَّارٍ، ‏‏‏‏‏‏ح وحَدّ", "bengali": "", "english": "It was narrated that Abu Bishr Ja'far bin Abu Jyas said:“I heard 'Abbad bin Shurahbil, a man from Banu Ghubar, say: ‘We suffered a year of famine, and I came to Al-Madinah. I came to one of its gardens and took an ear of corn, I rubbed it, ate some and put the rest in my garment. The owner of the garden came and beat me and took my garment. I came to the Prophet (ﷺ) and told him (what had happened). He said to the man: \"You did not feed him when he was hungry and you did not teach him when he was ignorant.\"' Then the Prophet (ﷺ) told him to give back his garment and ordered that a Wasq or half a Wasq of food be brought to him", "french": "", "indonesian": "", "russian": "", "urdu": "ابوبشر جعفر بن أبی ایاس کہتے ہیں  میں نے عباد بن شرحبیل رضی اللہ عنہ جو بنی غبر کے ایک فرد ہیں کو ک", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 162", "international_number": "2298", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2299", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏ وَيَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏قَالَا:‏", "bengali": "", "english": "It was narrated that Rafi' bin 'Amr Al-Ghifari said:\"When I was a boy, I used to throw stones at our date-palm trees\"[1] - or he said: \"the date-palm trees of the Ansar.\" I was brought to the Prophet (ﷺ) and he said: 'O boy' - (one of the narrators) Ibn Kasib said: He said: 'O my son - why are you throwing stones at the date-palm trees?' I said: 'So I can eat.' He said: 'Do not throw stones at the date-palm trees. Eat from what falls to the ground from them.' Then he patted me on the head and said: 'O Allah give him enough to eat.'”", "french": "", "indonesian": "", "russian": "", "urdu": "رافع بن عمرو غفاری رضی اللہ عنہ کہتے ہیں کہ  میں اور ایک لڑکا دونوں مل کر اپنے یا انصار کے کھجور کے", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 163", "international_number": "2299", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2300", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏أَنْبَأَنَا الْجُرَ", "bengali": "", "english": "It was narrated from Abu Sa'eed that the Prophet (ﷺ) said:\"When you come to a shepherd, call him three times. If he answers (all well and good), otherwise drink (milk from the flock) without taking advantage. And when you come to a garden call the owner of the garden three times. If he answers (all well and good), otherwise eat (from the produce of the garden) without taking advantage", "french": "", "indonesian": "", "russian": "", "urdu": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم کسی چرواہے کے", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 164", "international_number": "2300", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2301", "arabic": "حَدَّثَنَا هَدِيَّةُ بْنُ عَبْدِ الْوَهَّابِ، ‏‏‏‏‏‏ وَأَيُّوبُ بْنُ حَسَّانَ الْوَاسِطِيُّ، ‏‏‏‏‏‏", "bengali": "", "english": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:\"When anyone of you passes by a garden let him eat therefrom, but he should not carry any away in his garment", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 165", "international_number": "2301", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2302", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ نَا", "bengali": "", "english": "It was narrated from 'Abdullah bin 'Umar that the Messenger of Allah (ﷺ) stood up and said:\"No one of you should milk from the livestock of another man without his permission. Would anyone of you like someone to break into his storeroom and take his food? The udders of their livestock store food for them, so none of you should milk the livestock of another man without his permission", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کھڑے ہوئے اور فرمایا:  کوئی", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 12, Hadith 166", "international_number": "2302", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2303", "arabic": "حَدَّثَنَا إِسْمَاعِيل بْنُ بِشْرِ بْنِ مَنْصُورٍ، ‏‏‏‏‏‏حَدَّثَنَا عُمَرُ بْنُ عَلِيٍّ، ‏‏‏‏‏‏عَنْ", "bengali": "", "english": "Abu Hurairah said:“While we were with the Messenger of Allah (ﷺ) on a journey, we saw some camels with their udders tied, among some thorny trees. We rushed towards it, but the Messenger of Allah (ﷺ) called us and we came back to him. He said: 'These camels belong to a family of Muslims, and this is their support (and blessing) after Allah. Would you be happy if you went back to your vessels and found that what was in them had been taken away? Do you think that is fair?' They said: 'No.' He said: 'This is like that.' We said: 'What do you think if we are in need of food and drink?' He said: 'Eat but do not carry any away: drink but do not carry any away", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ایک سفر میں تھے کہ اتنے م", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 167", "international_number": "2303", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2304", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ هِشَامِ بْنِ عُرْو", "bengali": "", "english": "It was narrated from Umm Hani' that the Prophet (ﷺ) said to her:\"Keep sheep, for in them is blessing", "french": "", "indonesian": "", "russian": "", "urdu": "ام ہانی رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ان سے فرمایا:  تم بکریاں پالو، اس", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Isnaad Sahih'}", "reference": "Book 12, Hadith 168", "international_number": "2304", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2305", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِي", "bengali": "", "english": "It was narrated that 'Urwah Al-Bariqi said in a Marfu’ report:\"Camels are the pride of their owners, and sheep are a blessing, and goodness is tied to the forelocks of horses until the Day of Resurrection", "french": "", "indonesian": "", "russian": "", "urdu": "عروہ بارقی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اونٹ ان کے مالکوں کے ل", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Agreed Upon'}", "reference": "Book 12, Hadith 169", "international_number": "2305", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2306", "arabic": "حَدَّثَنَا عِصْمَةُ بْنُ الْفَضْلِ النَّيْسَابُورِيُّ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ فِرَاسٍ أَبُو هُرَيْر", "bengali": "", "english": "It was narrated from Ibn 'Umar that the Messenger of Allah (ﷺ) said:\"Sheep are among the animals of Paradise", "french": "", "indonesian": "", "russian": "", "urdu": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بکری تو جنت کے ج", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih Muquf'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 170", "international_number": "2306", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
{"hadithnumber": "2307", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏حَدَّثَنَا عُثْمَانُ بْنُ عَبْدِ الرَّحْمَنِ، ‏‏‏‏‏‏حَد", "bengali": "", "english": "It was narrated that Abu Hurairah said:\"The Messenger of Allah (ﷺ) commanded the rich to keep sheep, and he commanded the poor to keep chickens, and he said: 'When the rich keep chickens, then Allah will give permission for the town to be destroyed", "french": "", "indonesian": "", "russian": "", "urdu": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مالدار لوگوں کو بکریاں اور محتاج", "grades": "{'name': 'Al-Albani', 'grade': 'Mawdu'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Mawdu'},{'name': 'Shuaib Al Arnaut', 'grade': 'Mawdu'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 12, Hadith 171", "international_number": "2307", "narrator_chain": "", "chapter_intro": "The Chapters on Business Transactions"}
