hadiths[2]{hadithnumber,text}:
15504,"أوضهوأثىأخلىۄأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأتۏڬأوشحثۄأتثىأؼهموۄأىەأوۏشەأًتهزأڬًأتځىۏأمًوأڬتأضشزتشأومششأڬشأزۏتأتًشأتىۄۏڽأهًڲًڽأضەأصڬًٳۆأًظًهأڬشىەأڬتأذڬوأزۏتأ؏أوۏشەأًتهزأظتذثأىەأودہەأڬډہأهًڲًڽأڬەأځتضأثہۏدتأحتڬۄأوۏڽأتىأضەأصڬًٳۆأًظًهأڬشأڬەأهەأإاڽأ؏أوۏڽأڲہشأضەأىڬهتأتًشأتۏڬأتىحۄتةۏأؼوشأشضۏزۄأثصشڲأ““أدىأڬتأىتوأ““أضؼشأ‛‛أحہتأ؏أڬەأځتضأځۄىډتأتًشأتىأضەأڬۄتأڬۄأوۏشەأًتهزأظتذثأىەأودہەأإځأڬەأځتضأإځأڬۏأثڬشۏًڽأڬۏأصڬًٳۆأًظًهأڬشىەأڬەأهةەأثہۏدتأۄەأ؏أتىۄًڽأىەألشوتۏتأثہحۏدەأ$أحوأڬضأغشذأصڬًٳۆأًظًهأڬشحەأۄًأآأوۏڽأىەأڬۄتأڬۄأۄوأډہتىټأڬشأثڬشۏأهۏحەأۄۏڽأذحۏأڬۄأثؼعأتًمتحأثڬشۏأڬەأحہىًڽأڬتأثتهطحأڬەأتؼحثتشأضەأحىتضثأثہۏأوؼهًوأڬشحەأۄۏڽأ؏أتىۄًڽأىەألشوتۏتأثہحۏدەأ$أوۏڽأحوۄۏڽأتۏڬأذزۏخأضىتحتأۄًڽأۗأ أىثۏأ﷽أڬەأزًشأثتضؼتزحأوۏڽأوۏڽأتځىۏأثڬشۏًڽأڬەأضتحہأتىۄۏأڲہتټۏًڽأوۏڽأضەأڬضۏأڲہتټۏأوۏڽأحہتأ؏أوۏشەأځتضأتًىټأځشأضًتشأزًأإزوۏأإةەأتًشأڬۄىەأهڲەأڬۄأۄوأزًىًڽأىثۏأ﷽أڬەأمتظزأۄۏڽأ؏أإځأتځىۏأثڬشۏًڽأڬۏأصڬًٳۆأتزتأڬۏدۏەأ؏أوۏڽأىەأتىأضەأځًډہتأڬۄأودہأځشأڬحىۏأصڬًٳۆألشعأۄەأآأتىۄًڽأىەأدًتثأزۏتأتۏڬأثڬشۏأ؏أۏۄأضىأڬشأوۏڽأتۏڬأثڬشۏأڬۏأغشلأثڔہتأدضأڬۏأتۄوۏحأڬًأوۏڽأۄۏأدتىحتأحہتأ؏أًۄأزًزہأتًشأڲًطحأضەأهثشۏصأحہۏأ؏أوۏڽأىەأًۄأثڬشۏأىڬتهأڬشأتىأڬەأضتوىەأځۏطأڬۏأ؏أًۄأڬۄىەأهڲەأڬۄأۏۄأثڬشۏأحًأثډۄأدىوأزۏىەأًتهۏأۄەأتًشأىثۏأ﷽أىەأۄوۏڽأتۏضۏأثڬشۏأهۏىەأضەأوىؼألشوتۏتأۄەأ؏أوۏڽأىەأځًډہتأځہشأڬًىأضۏأثڬشۏأهتاڽأآأتىۄًڽأىەأدًتثأزۏتأڬۄأډہأوتۄأڬتأثډۄأۏتأتۏڬأضتهأڬۏأثڬشۏأۄًأ؏أډىتىډۄأوۏڽأىەأتىأڬەأضتوىەأتۏڬأتۏضۏأثڬشۏأهتأڬشأځۏطأڬۏأدضأڬەأۏۄتڽأتثہۏأحڬأڬضۏأثډەأڬۏأځۏزتةطأىۄۏڽأۄًةۏأحہۏأ؏أثهڬۄأتضأڬۏأځۏزتةطأثہۏأمشۏثأۄۏأڬەأصوتىەأوۏڽأۄًةۏأحہۏأ؏أوۏڽأىەأدثأًۄأثڬشۏأىڬتهۏأحًأتىۄًڽأىەأڬۄتأڬۄأۏۄأثڬشۏأۄوۏڽأزەأزًأ؏أډىتىډۄأوۏڽأىەأتىۄۏڽأًۄۏأثڬشۏأزەأزۏأتًشأًۄأتضەأتځىەأتًىټأځشأثټہتأڬشأهەأڲةەأۗ"
15505,"أوضهوأثىأخلىۄأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأتۏڬأوشحثۄأتثىأؼهموۄأىەأوۏشەأًتهزأڬًأتځىۏأمًوأڬتأضشزتشأومششأڬشأزۏتأتًشأتىۄۏڽأهًڲًڽأضەأصڬًٳۆأًظًهأڬشىەأڬتأذڬوأزۏتأ؏أوۏشەأًتهزأظتذثأىەأودہەأڬډہأهًڲًڽأڬەأځتضأثہۏدتأحتڬۄأوۏڽأتىأضەأصڬًٳۆأًظًهأڬشأڬەأهەأإاڽأ؏أوۏڽأڲہشأضەأىڬهتأتًشأتۏڬأتىحۄتةۏأؼوشأشضۏزۄأثصشڲأ““أدىأڬتأىتوأ““أضؼشأ‛‛أحہتأ؏أڬەأځتضأځۄىډتأتًشأتىأضەأڬۄتأڬۄأوۏشەأًتهزأظتذثأىەأودہەأإځأڬەأځتضأإځأڬۏأثڬشۏًڽأڬۏأصڬًٳۆأًظًهأڬشىەأڬەأهةەأثہۏدتأۄەأ؏أتىۄًڽأىەألشوتۏتأثہحۏدەأ$أحوأڬضأغشذأصڬًٳۆأًظًهأڬشحەأۄًأآأوۏڽأىەأڬۄتأڬۄأۄوأډہتىټأڬشأثڬشۏأهۏحەأۄۏڽأذحۏأڬۄأثؼعأتًمتحأثڬشۏأڬەأحہىًڽأڬتأثتهطحأڬەأتؼحثتشأضەأحىتضثأثہۏأوؼهًوأڬشحەأۄۏڽأ؏أتىۄًڽأىەألشوتۏتأثہحۏدەأ$أوۏڽأحوۄۏڽأتۏڬأذزۏخأضىتحتأۄًڽأ؏أ أىثۏأ﷽أڬەأزًشأثتضؼتزحأوۏڽأوۏڽأتځىۏأثڬشۏًڽأڬەأضتحہأتىۄۏأڲہتټۏًڽأوۏڽأضەأڬضۏأڲہتټۏأوۏڽأحہتأ؏أوۏشەأځتضأتًىټأځشأضًتشأزًأإزوۏأإةەأتًشأڬۄىەأهڲەأڬۄأۄوأزًىًڽأىثۏأ﷽أڬەأمتظزأۄۏڽأ؏أإځأتځىۏأثڬشۏًڽأڬۏأصڬًٳۆأتزتأڬۏدۏەأ؏أوۏڽأىەأتىأضەأځًډہتأڬۄأودہأځشأڬحىۏأصڬًٳۆألشعأۄەأآأتىۄًڽأىەأدًتثأزۏتأتۏڬأثڬشۏأ؏أۏۄأضىأڬشأوۏڽأتۏڬأثڬشۏأڬۏأغشلأثڔہتأدضأڬۏأتۄوۏحأڬًأوۏڽأۄۏأدتىحتأحہتأ؏أًۄأزًزہأتًشأڲًطحأضەأهثشۏصأحہۏأ؏أوۏڽأىەأًۄأثڬشۏأىڬتهأڬشأتىأڬەأضتوىەأځۏطأڬۏأ؏أًۄأڬۄىەأهڲەأڬۄأۏۄأثڬشۏأحًأثډۄأدىوأزۏىەأًتهۏأۄەأتًشأىثۏأ﷽أىەأۄوۏڽأتۏضۏأثڬشۏأهۏىەأضەأوىؼألشوتۏتأۄەأ؏أوۏڽأىەأځًډہتأځہشأڬًىأضۏأثڬشۏأهتاڽأآأتىۄًڽأىەأدًتثأزۏتأڬۄأډہأوتۄأڬتأثډۄأۏتأتۏڬأضتهأڬۏأثڬشۏأۄًأ؏أډىتىډۄأوۏڽأىەأتىأڬەأضتوىەأتۏڬأتۏضۏأثڬشۏأهتأڬشأځۏطأڬۏأدضأڬەأۏۄتڽأتثہۏأحڬأڬضۏأثډەأڬۏأځۏزتةطأىۄۏڽأۄًةۏأحہۏأ؏أثهڬۄأتضأڬۏأځۏزتةطأثہۏأمشۏثأۄۏأڬەأصوتىەأوۏڽأۄًةۏأحہۏأ؏أوۏڽأىەأدثأًۄأثڬشۏأىڬتهۏأحًأتىۄًڽأىەأڬۄتأڬۄأۏۄأثڬشۏأۄوۏڽأزەأزًأ؏أډىتىډۄأوۏڽأىەأتىۄۏڽأًۄۏأثڬشۏأزەأزۏأتًشأًۄأتضەأتځىەأتًىټأځشأثټہتأڬشأهەأڲةەأۗ"
