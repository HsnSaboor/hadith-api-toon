{"hadithnumber": "2885", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   ( اصل"}
{"hadithnumber": "2886", "text": "جابر رضی اللہ عنہ کہتے ہیں  میں بیمار ہوا تو نبی اکرم صلی اللہ علیہ وسلم اور ابوبکر رضی اللہ عنہ مجھ"}
{"hadithnumber": "2887", "text": "جابر رضی اللہ عنہ کہتے ہیں  میں بیمار ہوا اور میرے پاس سات بہنیں تھیں، رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "2888", "text": "براء بن عازب رضی اللہ عنہما کہتے ہیں  کلالہ کے سلسلے میں آخری آیت جو نازل ہوئی ہے وہ: «يستفتونك قل ا"}
{"hadithnumber": "2889", "text": "براء بن عازب رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نبی اکرم صلی اللہ علیہ وسلم کے پاس آیا اور اس نے عر"}
{"hadithnumber": "2890", "text": "ہزیل بن شرحبیل اودی کہتے ہیں  ایک شخص ابوموسیٰ اشعری رضی اللہ عنہ اور سلیمان بن ربیعہ کے پاس آیا اور"}
{"hadithnumber": "2891", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ نکلے تو اسواف  ("}
{"hadithnumber": "2892", "text": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  سعد بن ربیع کی عورت نے کہا: اللہ کے رسول! سعد مر گئے"}
{"hadithnumber": "2893", "text": "اسود بن یزید کہتے ہیں کہ  معاذ بن جبل رضی اللہ عنہ نے بہن اور بیٹی میں اس طرح ترکہ تقسیم کیا کہ آدھا"}
{"hadithnumber": "2894", "text": "قبیصہ بن ذویب کہتے ہیں کہ  میت کی نانی ابوبکر صدیق رضی اللہ عنہ کے پاس میراث میں اپنا حصہ دریافت کرن"}
{"hadithnumber": "2895", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے نانی کا چھٹا حصہ مقرر فرمایا ہے اگر م"}
{"hadithnumber": "2896", "text": "عمران بن حصین رضی اللہ عنہما کہتے ہیں کہ  ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا اور کہنے ل"}
{"hadithnumber": "2897", "text": "حسن بصری کہتے ہیں کہ  عمر رضی اللہ عنہ نے پوچھا: رسول اللہ صلی اللہ علیہ وسلم نے دادا کو ترکے میں سے"}
{"hadithnumber": "2898", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ذوی الفروض ۱؎ میں"}
{"hadithnumber": "2899", "text": "مقدام رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: جو شخص بوجھ  ( قرضہ یا بال بچے"}
{"hadithnumber": "2900", "text": "مقدام کندی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں ہر مسلمان سے اس کی"}
{"hadithnumber": "2901", "text": "مقدام رضی اللہ عنہ کہتے ہیں  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا کہ جس کا کوئی وا"}
{"hadithnumber": "2902", "text": "ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کا ایک غلام مر گیا، کچھ"}
{"hadithnumber": "2903", "text": "بریدہ رضی اللہ عنہ کہتے ہیں  ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا اور اس نے عرض کیا: قبیل"}
{"hadithnumber": "2904", "text": "بریدہ رضی اللہ عنہ کہتے ہیں  خزاعہ  ( قبیلہ )  کے ایک شخص کا انتقال ہو گیا، اس کی میراث رسول اللہ صل"}
{"hadithnumber": "2905", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ایک شخص رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں مر گیا"}
{"hadithnumber": "2906", "text": "واثلہ بن اسقع رضی اللہ عنہ نبی اکرم صلی اللہ علیہ وسلم سے روایت کرتے ہیں  آپ نے فرمایا:  عورت تین شخ"}
{"hadithnumber": "2907", "text": "مکحول کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے لعان والی عورت کے بچے کی میراث اس کی ماں کو دلائی ہے"}
{"hadithnumber": "2908", "text": "اس سند سے بھی  نبی اکرم صلی اللہ علیہ وسلم سے اسی کے مثل مروی ہے۔"}
{"hadithnumber": "2909", "text": "اسامہ بن زید رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مسلمان کافر کا ا"}
{"hadithnumber": "2910", "text": "اسامہ بن زید رضی اللہ عنہما کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! کل آپ  ( مکہ میں )  کہاں اتری"}
{"hadithnumber": "2911", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  دو دین والے  ("}
{"hadithnumber": "2912", "text": "عبداللہ بن بریدہ کہتے ہیں کہ  دو بھائی اپنا جھگڑا یحییٰ بن یعمر کے پاس لے گئے ان میں سے ایک یہودی تھ"}
{"hadithnumber": "2913", "text": "ابوالاسود دیلی سے روایت ہے کہ  معاذ رضی اللہ عنہ کے پاس ایک یہودی کا ترکہ لایا گیا جس کا وارث ایک مس"}
{"hadithnumber": "2914", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  زمانہ جاہلیت میں"}
{"hadithnumber": "2915", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  ام المؤمنین عائشہ رضی اللہ عنہا نے ایک لونڈی خرید کر آزاد"}
{"hadithnumber": "2916", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ولاء اس شخص کا"}
{"hadithnumber": "2917", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رئاب بن حذیفہ نے ایک عورت سے شادی کی، اس کے بطن سے تین ل"}
{"hadithnumber": "2918", "text": "تمیم داری رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! اس شخص کے بارے میں شرع کا کیا حکم"}
{"hadithnumber": "2919", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ولاء کو بیچنے اور اسے ہبہ"}
{"hadithnumber": "2920", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب بچہ آواز کرے تو وراثت"}
{"hadithnumber": "2921", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  اللہ تعالیٰ کے فرمان: «والذين عقدت أيمانكم فآتوهم نصيبهم»"}
{"hadithnumber": "2922", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  اللہ تعالیٰ کے قول: «والذين عقدت أيمانكم فآتوهم نصيبهم»"}
{"hadithnumber": "2923", "text": "داود بن حصین کہتے ہیں کہ  میں ام سعد بنت ربیع سے  ( کلام پاک )  پڑھتا تھا وہ ابوبکر صدیق رضی اللہ عن"}
{"hadithnumber": "2924", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  پہلے اللہ تعالیٰ نے یوں فرمایا تھا: «والذين، ‏‏‏‏ آمنوا"}
{"hadithnumber": "2925", "text": "جبیر بن مطعم رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا کہ  ( زمانہ کفر کی )"}
{"hadithnumber": "2926", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے ہمارے گھر میں انصار و مہاجرین کے"}
{"hadithnumber": "2927", "text": "سعید کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ پہلے کہتے تھے کہ دیت کنبہ والوں پر ہے، اور عورت اپنے شوہر"}
