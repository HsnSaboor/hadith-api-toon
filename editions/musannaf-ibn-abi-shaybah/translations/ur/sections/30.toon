33380,أذعشحأؼوشًأثىأوۏوًىأشذوۆأتههۄأؼهۏۄألشوتحەأۄۏڽأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأڬہۏحۏأًتهًڽأځشأۄشأڬہۏحۏأوۏڽأتۏڬأملۏصأتًشأتۏڬأزشۄوأومششألشوتۏتأۗ
33381,أذعشحأتثًؼًىأوذوزأثىأؼثۏزأتههۄأتهخملۏأشذوۆأتههۄأؼهۏۄألشوتحەأۄۏڽأڬۄأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأتۄهأضًتزأځشأۄشأإثتزأۏتأؽۏشأإثتزأصوۏىأوۏڽأتۏڬأملۏصأتًشأتۏڬأزشۄوأومششألشوتۏتأ=أتًشأضثصۏأڬۏأڬہۏحۏأځشأځتىډأزشۄوأتًشأځتىډأملۏصأومششألشوتةەأۗأتًشأزشرحًڽأڬۏأڬہۏحۏأځشأزضأزشۄوأتًشأزضأملۏصأومششألشوتةەأتًشأتىڲًشأڬۏأڬہۏحۏأځشأثہۏأزضأزشۄوأتًشأزضأملۏصأومششألشوتةەأۗأتًشأڬہدًشأڬتأسڬشأىۄۏڽألشوتۏتأۗ
33382,أذعشحأتثًؼًىأوذوزأثىأؼثزتههۄأتهخملۏأشذوۆأتههۄأؼهۏۄألشوتحەأۄۏڽأڬۄأذعشحأؼوشأثىأرغتثأضًتزأًتهًڽأځشأۄشأڬہۏحۏأوۏڽأدضأڬۏأصوۏىأځتىۏأضەأضۏشتثأۄًحۏأۄًأډتۄەأإثتزأۄًأۏتأؽۏشأإثتزأتۏڬأزشۄوأتًشأڬہتىەأڬتأتۏڬأملۏصأومششألشوتۏتأ=أتًشأثتؽتحأڬۏأحوتوأڬہۏحۏًڽأځشأزضأزشۄوأتًشأڬہتىەأڬەأزضأملۏصأومششألشوتةەأۗأتًشأضثصۏًڽأڬۏأحوتوأڬہۏحۏًڽأځشأځتىډأزشۄوأتًشأڬہتىەأڬەأځتىډأملۏصأومششألشوتةەأۗأتًشأتىڲًشأڬۏأوڬوهأڬہۏحۏأځشأزضأزشۄوأتًشأڬہتىەأڬەأزضأملۏصأومششألشوتةەأتًشأڬہدًشأڬۏأڬہۏحۏأځشأڬډہأومششأىۄۏڽألشوتۏتأۗأتضەأصوۏىأڬەأحتثؼأمشتشأزۏتأۗ
