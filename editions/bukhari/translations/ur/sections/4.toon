{"hadithnumber": "213", "text": "ہم سے ابومعمر نے بیان کیا، کہا ہم سے عبدالوارث نے، کہا ہم سے ایوب نے ابوقلابہ کے واسطے سے نقل کیا، و"}
{"hadithnumber": "214", "text": "ہم سے محمد بن یوسف نے بیان کیا، کہا ہم سے سفیان نے عمرو بن عامر کے واسطے سے بیان کیا، کہا میں نے انس"}
{"hadithnumber": "215", "text": "ہم سے خالد بن مخلد نے بیان کیا، انہوں نے کہا ہم سے سلیمان نے بیان کیا، انہوں نے کہا مجھے یحییٰ بن سع"}
{"hadithnumber": "216", "text": "ہم سے عثمان نے بیان کیا، کہا ہم سے جریر نے منصور کے واسطے سے نقل کیا، وہ مجاہد سے وہ ابن عباس رضی ال"}
{"hadithnumber": "217", "text": "ہم سے یعقوب بن ابراہیم نے بیان کیا، انہوں نے کہا ہم کو اسماعیل بن ابراہیم نے خبر دی، کہا مجھے روح بن"}
{"hadithnumber": "218", "text": "ہم سے محمد بن المثنی نے بیان کیا، انہوں نے کہا ہم سے محمد بن حازم نے بیان کیا، انہوں نے کہا ہم سے اع"}
{"hadithnumber": "219", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے ہمام نے، کہا ہم سے اسحاق نے انس بن مالک کے واسطے سے نق"}
{"hadithnumber": "220", "text": "ہم سے ابوالیمان نے بیان کیا، انہوں نے کہا ہمیں شعیب نے زہری کے واسطے سے خبر دی، انہوں نے کہا مجھے عب"}
{"hadithnumber": "221", "text": "ہم سے عبدان نے بیان کیا، کہا ہمیں عبداللہ نے خبر دی، کہا ہمیں یحییٰ بن سعید نے خبر دی، کہا میں نے ان"}
{"hadithnumber": "222", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا ہم کو مالک نے ہشام بن عروہ سے خبر دی، انہوں نے اپنے باپ (عروہ"}
{"hadithnumber": "223", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا ہمیں مالک نے ابن شہاب سے خبر دی، وہ عبیداللہ بن عبداللہ بن عت"}
{"hadithnumber": "224", "text": "ہم سے آدم نے بیان کیا، کہا ہم سے شعبہ نے اعمش کے واسطے سے نقل کیا، وہ ابووائل سے، وہ حذیفہ رضی اللہ"}
{"hadithnumber": "225", "text": "ہم سے عثمان ابن ابی شیبہ نے بیان کیا، کہا ہم سے جریر نے منصور کے واسطے سے بیان کیا، وہ ابووائل سے، و"}
{"hadithnumber": "226", "text": "ہم سے محمد بن عرعرہ نے بیان کیا، کہا ہم سے شعبہ نے منصور کے واسطے سے بیان کیا، وہ ابووائل سے نقل کرت"}
{"hadithnumber": "227", "text": "ہم سے محمد ابن المثنی نے بیان کیا، انہوں نے کہا ہم سے یحییٰ نے ہشام کے واسطے سے بیان کیا، ان سے فاطم"}
{"hadithnumber": "228", "text": "ہم سے محمد بن سلام نے بیان کیا، کہا مجھ سے ابومعاویہ نے، کہا ہم سے ہشام بن عروہ نے اپنے باپ (عروہ) ک"}
{"hadithnumber": "229", "text": "ہم سے عبدان نے بیان کیا، کہا مجھے عبداللہ ابن مبارک نے خبر دی، کہا مجھے عمرو بن میمون الجزری نے بتلا"}
{"hadithnumber": "230", "text": "ہم سے قتیبہ نے بیان کیا، کہا ہم سے یزید نے، کہا ہم سے عمرو نے سلیمان سے روایت کیا، انہوں نے کہا کہ م"}
{"hadithnumber": "231", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، انہوں نے کہا ہم سے عبدالواحد نے بیان کیا، انہوں نے کہا ہم سے عمر"}
{"hadithnumber": "232", "text": "ہم سے عمرو بن خالد نے بیان کیا، کہا ہم سے زہیر نے، کہا ہم سے عمرو بن میمون بن مہران نے، انہوں نے سلی"}
{"hadithnumber": "233", "text": "ہم سے سلیمان بن حرب نے بیان کیا، انہوں نے حماد بن زید سے، وہ ایوب سے، وہ ابوقلابہ سے، وہ انس رضی الل"}
{"hadithnumber": "234", "text": "ہم سے آدم نے بیان کیا، کہا ہم سے شعبہ نے، کہا مجھے ابوالتیاح یزید بن حمید نے انس رضی اللہ عنہ سے خبر"}
{"hadithnumber": "235", "text": "ہم سے اسماعیل نے بیان کیا، انہوں نے کہا مجھ کو مالک نے ابن شہاب کے واسطے سے روایت کی، وہ عبیداللہ بن"}
{"hadithnumber": "236", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے معن نے، کہا ہم سے مالک نے ابن شہاب کے واسطے سے بیان کیا،"}
{"hadithnumber": "237", "text": "ہم سے احمد بن محمد نے بیان کیا، انہوں نے کہا ہمیں عبداللہ نے خبر دی، انہوں نے کہا مجھے معمر نے ہمام"}
{"hadithnumber": "238", "text": "ہم سے ابوالیمان بیان کیا، کہا ہم کو شعیب نے خبر دی، کہا مجھے ابوالزناد نے خبر دی کہ ان سے عبدالرحمٰن"}
{"hadithnumber": "239", "text": "اور اسی سند سے   ( یہ بھی )  فرمایا کہ تم میں سے کوئی ٹھہرے ہوئے پانی میں جو جاری نہ ہو پیشاب نہ کرے"}
{"hadithnumber": "240", "text": "ہم سے عبدان نے بیان کیا، کہا مجھے میرے باپ (عثمان) نے شعبہ سے خبر دی، انہوں نے ابواسحاق سے، انہوں نے"}
{"hadithnumber": "241", "text": "ہم سے محمد بن یوسف نے بیان کیا، کہا ہم سے سفیان نے حمید کے واسطے سے بیان کیا، وہ انس رضی اللہ عنہ سے"}
{"hadithnumber": "242", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے سفیان نے، ان سے زہری نے ابوسلمہ کے واسطے سے بیان کیا، وہ"}
{"hadithnumber": "243", "text": "ہم سے محمد نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے ابن ابی حازم کے واسطے سے نقل کیا، انہوں نے سہل ب"}
{"hadithnumber": "244", "text": "ہم سے ابوالنعمان نے بیان کیا، کہا ہم سے حماد بن زید نے غیلان بن جریر کے واسطے سے نقل کیا، وہ ابوبردہ"}
{"hadithnumber": "245", "text": "ہم سے عثمان بن ابی شیبہ نے بیان کیا، کہا ہم سے جریر نے منصور کے واسطے سے، وہ ابووائل سے، وہ حذیفہ سے"}
{"hadithnumber": "246", "text": "عفان نے کہا کہ ہم سے صخر بن جویریہ نے نافع کے واسطے سے بیان کیا، وہ ابن عمر رضی اللہ عنہما سے نقل کر"}
{"hadithnumber": "247", "text": "ہم سے محمد بن مقاتل نے بیان کیا، انہوں نے کہا ہم کو عبداللہ نے خبر دی، انہوں نے کہا ہمیں سفیان نے من"}
