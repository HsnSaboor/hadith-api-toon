{"hadithnumber": "2612", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم جب کسی لشکر یا سریہ کا کسی کو امیر بنا"}
{"hadithnumber": "2613", "text": "بریدہ رضی اللہ عنہ روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ کے نام سے اور الل"}
{"hadithnumber": "2614", "text": "انس بن مالک رضی اللہ عنہ کا بیان ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے  ( مجاہدین کو رخصت کرتے وقت"}
{"hadithnumber": "2615", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے بنونضیر کے کھجوروں کے"}
{"hadithnumber": "2616", "text": "عروہ کہتے ہیں کہ اسامہ رضی اللہ عنہ نے مجھ سے بیان کیا کہ  رسول اللہ صلی اللہ علیہ وسلم نے انہیں وصی"}
{"hadithnumber": "2617", "text": "عبداللہ بن عمرو غزی کہتے ہیں کہ  ابومسہر کے سامنے ابنیٰ کا تذکرہ آیا تو میں نے ان کو کہتے ہوئے سنا:"}
{"hadithnumber": "2618", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے بسیسہ کو جاسوس بنا کر بھیجا تا"}
{"hadithnumber": "2619", "text": "سمرہ بن جندب رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئی"}
{"hadithnumber": "2620", "text": "عباد بن شرحبیل رضی اللہ عنہ کہتے ہیں کہ  مجھے قحط نے ستایا تو میں مدینہ کے باغات میں سے ایک باغ میں"}
{"hadithnumber": "2621", "text": "ابوبشر رضی اللہ عنہ کہتے ہیں کہ  میں نے عباد بن شرحبیل سے جو ہمیں میں سے قبیلہ بنو غبر کے ایک فرد تھ"}
