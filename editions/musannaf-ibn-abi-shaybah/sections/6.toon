hadiths[1010]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
9895,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ ہِلاَلٍ الْعَبْسِیِّ ، عَنْ جَرِیرٍ ، قَالَ : خَطَبَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَحَثَّنَا عَلَی الصَّدَقَۃِ ، فَأَبْطَؤُوا حَتَّی رُئِیَ فِی وَجْہِہِ الْغَضَبُ ، ثُمَّ إنَّ رَجُلاً مِنَ الأَنْصَارِ جَائَ بِصُرَّۃٍ فَأَعْطَاہَا ، فَتَتَابَعَ النَّاسُ حَتَّی رُئِیَ فِی وَجْہِہِ السُّرُورُ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ سَنَّ سُنَّۃً حَسَنَۃً کَانَ لَہُ أَجْرُہَا ، وَمِثْلُ أَجْرِ مَنْ عَمِلَ بِہَا ، مِنْ غَیْرِ أَنْ یَنْتَقِصَ مِنْ أُجُورِہِمْ شَیْئًا ، وَمَنْ سَنَّ سُنَّۃً سَیِّئَۃً کَانَ عَلَیْہِ وِزْرُہَا ، وَوِزْرُ مَنْ عَمِلَ بِہَا ، مِنْ غَیْرِ أَنْ یَنْتَقِصَ مِنْ أَوْزَارِہِمْ شَیْئًا۔",,,9895,,
9896,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ شُعْبَۃَ، قَالَ: حدَّثَنِی عَوْنُ بْنُ أَبِی جُحَیْفَۃَ ، قَالَ : سَمِعْتُ الْمُنْذِرَ بْنَ جَرِیرٍ یَذْکُرُ، عَنْ أَبِیہِ ، قَالَ : کُنَّا عِنْدَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَدْرَ النَّہَارِ ، قَالَ : فَجَائَہُ قَوْمٌ حُفَاۃٌ ، مُجْتَابِی النِّمَارِ ، عَلَیْہِمُ السُّیُوفُ وَالْعَمَائِمُ ، عَامَّتُہُمْ مِنْ مُضَرَ ، بَلْ کُلُّہُمْ مِنْ مُضَرَ ، قَالَ : فَرَأَیْتُ وَجْہَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَغَیَّرُ تَغَیُّرًا لِمَا رَأَی بِہِمْ مِنَ الْفَاقَۃِ ، قَالَ : ثُمَّ قَامَ فَدَخَلَ الْمَسْجِدَ ، ثُمَّ أَمَرَ بِلاَلاً فَأَذَّنَ، ثُمَّ أَقَامَ فَصَلَّی ، ثُمَّ قَالَ : {یَا أَیُّہَا النَّاسُ اتَّقُوا رَبَّکُمُ الَّذِی خَلَقَکُمْ مِنْ نَفْسٍ وَاحِدَۃٍ} ، ثُمَّ قَرَأَ إلَی آخِرِ الآیَۃِ : {وَاتَّقُوا اللَّہَ الَّذِی تَسَائَلُونَ بِہِ وَالأَرْحَامَ} ، {اتَّقُوا اللَّہَ وَلْتَنْظُرْ نَفْسٌ مَا قَدَّمَتْ لِغَدٍ} تَصَدَّقَ امْرُؤٌ مِنْ دِینَارِہِ وَمِنْ دِرْہَمِہِ ، وَمِنْ ثَوْبِہِ وَمِنْ صَاعِ بُرِّہِ ، یَعْنِی الْحِنْطَۃَ ، وَمِنْ صَاعِ تَمْرِہِ حَتَّی قَالَ: وَلَوْ بِشِقِّ تَمْرَۃٍ ، قَالَ : فَجَائَ رَجُلٌ مِنَ الأَنْصَارِ بِصُرَّۃٍ قَدْ کَادَتْ کَفُّہُ تَعْجَزُ عَنْہَا ، بَلْ قَدْ عَجَزَتْ ، قَالَ : ثُمَّ تَتَابَعَ النَّاسُ حَتَّی رَأَیْت کَوْمَیْنِ مِنْ طَعَامٍ وَثِیَابٍ ، قَالَ : فَرَأَیْتُ وَجْہَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَہَلَّلُ، کَأَنَّہُ مُذْہَبَۃٌ ، فَقَالَ: مَنْ سَنَّ فِی الإِسْلاَمِ سُنَّۃً حَسَنَۃً ، أَوْ صَالِحَۃً فَاسْتُنَّ بِہَا بَعْدَہُ ، کَانَ لَہُ أَجْرُہَا وَأَجْرُ مَنْ عَمِلَ بِہَا بَعْدَہُ، لاَ یَنْتَقِصُ مِنْ أُجُورِہِمْ شَیْئًا، وَمَنِ اسْتَنَّ فِی الإِسْلاَمِ سُنَّۃً سَیِّئَۃً فَاسْتُنَّ بِہَا بَعْدَہُ، کَانَ عَلَیْہِ وِزْرُہ وَوِزْرُ مَنْ عَمِلَ بِہَا بَعْدَہُ، لاَ یَنْتَقِصُ مِنْ أَوْزَارِہِمْ شَیْئًا۔(مسلم 706۔ احمد 4/359)",,,9896,,
9897,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، قَالَ : سَمِعْتُ عَطَائً ، قَالَ : سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ : أَشْہَدُ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَصَلَّی قَبْلَ الْخُطْبَۃِ ، ثُمَّ خَطَبَ ، فَرَأَی أَنَّہُ لَمْ یُسْمِعِ النِّسَائَ ، فَأَتَاہُنَّ ، فَذَکَّرَہُنَّ، وَوَعَظَہُنَّ ، وَأَمَرَہُنَّ بِالصَّدَقَۃِ ، وَبِلاَلٌ قَائِلٌ بِثَوْبِہِ ، قَالَ : فَجَعَلَتِ الْمَرْأَۃُ تُلْقِی الْخَاتَمَ وَالْخُرْصَ وَالشَّیْئَ۔",,,9897,,
9898,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مَنْصُورٍ ، عَنْ ذَرٍّ ، عَنْ وَائِلِ بْنِ مُہَانَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَصَدَّقْنَ یَا مَعْشَرَ النِّسَائِ ، فَإِنَّکُنَّ أَکْثَرُ أَہْلِ جَہَنَّمَ ، فَقَالَتِ امْرَأَۃٌ لَیْسَتْ مِنْ عِلْیَۃِ النِّسَائِ: مِمَّ ذَلِکَ یَا رَسُولَ اللہِ؟ قَالَ: لأَنَّکُنَّ تُکْثِرْنَ اللَّعَنَ وَتَکْفُرْنَ الْعَشِیرَ۔ (احمد 1/376۔ طیالسی 384)",,,9898,,
9899,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ خَیْثَمَۃَ ، عَنْ عَدِیِّ بْنِ حَاتِمٍ ، قَالَ : ذَکَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ النَّارَ فَأَعْرَضَ بِوَجْہِہِ وَأَشَاحَ ، ثُمَّ ذَکَرَ النَّارَ فَأَعْرَضَ وَأَشَاحَ ، حَتَّی ظَنَنَّا أَنَّہُ کَأَنَّمَا یَنْظُرُ إلَیْہَا ، ثُمَّ قَالَ : اتَّقُوا النَّارَ وَلَوْ بِشِقِّ تَمْرَۃٍ ، فَمَنْ لَمْ یَجِدْ فَبِکَلِمَۃٍ طَیِّبَۃٍ۔ (بخاری 6540۔ مسلم 68)",,,9899,,
9900,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ مَعْقِلٍ ، عَنْ عَدِیِّ بْنِ حَاتِمٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : اتَّقُوا النَّارَ وَلَوْ بِشِقِّ تَمْرَۃٍ۔ (بخاری 1417۔ مسلم 703)",,,9900,,
9901,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا دَاوُدُ بْنُ قَیْسٍ ، قَالَ : حدَّثَنَا عِیَاضُ بْنُ عَبْدِ اللہِ بْنِ سَعْدِ بْنِ أَبِی سَرْحٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَخْرُجُ یَوْمَ الْعِیدِ ، یَوْمَ الْفِطْرِ فَیُصَلِّی بِالنَّاسِ تَیْنِکَ الرَّکْعَتَیْنِ ، ثُمَّ یُسَلِّمُ ، ثُمَّ یَقُومُ فَیَسْتَقْبِلُ النَّاسَ وَہُمْ جُلُوسٌ فَیَقُولُ : تَصَدَّقُوا ، تَصَدَّقُوا : فَکَانَ أَکْثَرَ مَنْ تَصَدَّقَ النِّسَائُ بِالْقُرْطِ وَالْخَاتَمِ وَالشَّیْئِ۔ (بخاری 1462۔ مسلم 605)",,,9901,,
9902,"حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنِ الأَعْمَشِ، عَنْ شَقِیقٍ، عَنْ عَمْرِو بْنِ الْحَارِثِ، عَنْ زَیْنَبَ امْرَأَۃِ عَبْدِاللہِ، قَالَتْ: أَمَرَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالصَّدَقَۃِ ، فَقَالَ : تَصَدَّقْنَ یَا مَعْشَرَ النِّسَائِ۔(بخاری 1466۔ ترمذی 636)",,,9902,,
9903,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ مَنْصُورِ بْنِ حَیَّانَ ، عَنِ ابْنِ بِجَادٍ ، عَنْ جَدَّتِہِ ، قَالَتْ : قُلْتُ : یَا رَسُولَ اللہِ ، یَأْتِینِی السَّائِلُ ، لَیْسَ عِنْدِی شَیْئٌ أُعْطِیہ ، قَالَتْ : فَقَالَ : لاَ تَرُدِّی سَائِلَکِ إِلاَّ بِشَیْئٍ ، وَلَوْ بِظِلْفٍ۔ (بخاری 845۔ طبرانی 561)",,,9903,,
9904,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ مَعْبَدِ بْنِ خَالِدٍ ، عَنْ حَارِثَۃَ بْنِ وَہْبٍ الْخُزَاعِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَصَدَّقُوا ، فَإِنَّہُ یُوشِکُ أَنْ یَخْرُجَ الرَّجُلُ بِصَدَقَتِہِ فَلاَ یَجِدُ مَنْ یَقْبَلُہَا۔ (بخاری 1411۔ مسلم 700)",,,9904,,
9905,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَمَّارٍ ، عَنْ رَاشِدِ بْنِ الْحَارِثِ ، عَنْ أَبِی ذَرٍّ ، قَالَ : مَا عَلَی الأَرْضِ مِنْ صَدَقَۃٍ تَخْرُجُ ، حَتَّی یُفکَّ عَنْہَا لَحْیَا سَبْعِینَ شَیْطَانًا ، کُلُّہُمْ یَنْہَاہُ عَنْہَا۔ (ابن خزیمۃ 2457۔ حاکم 417)",,,9905,,
9906,حَدَّثَنَا عُمَر بْنُ سَعْدٍ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ أَبِی الزَّعْرَائِ ، عَنْ عَبْدِ اللہِ ؛ أَنَّ رَاہِبًا عَبَدَ اللَّہَ فِی صَوْمَعَۃ سِتِّینَ سَنَۃً ، فَجَائَتِ امْرَأَۃٌ فَنَزَلَتْ إلَی جَنْبِہِ ، فَنَزَلَ إلَیْہَا فَوَاقَعَہَا سِتَّ لَیَالٍ ، ثُمَّ أُسقِط فِی یَدِہِ ، ثُمَّ ہَرَبَ ، فَأَتَی مَسْجِدًا فَأَوَی فِیہِ ، فَمَکَثَ ثَلاَثًا لاَ یَطْعَمُ شَیْئًا ، فَأُتِیَ بِرَغِیفٍ فَکَسَرَ نِصْفَہُ ، فَأَعْطَاہُ رَجُلاً عَنْ یَمِینِہِ ، وَأَعْطَی الآخَرَ عَنْ یَسَارِہِ ، ثُمَّ بُعِثَ إلَیْہِ مَلَکٌ فَقَبَضَ رُوحَہُ ، فَوُضِعَ عَمَلُ سِتِّینَ سَنَۃً فِی کِفَّۃٍ ، وَوُضِعَتِ السَّیِّئَۃُ فِی أُخْرَی ، فَرَجَحَتْ ، ثُمَّ جِیئَ بِالرَّغِیفِ ، فَرَجَحَ بِالسَّیِّئَۃِ۔,,,9906,,
9907,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إنَّ اللَّہَ یَقْبَلُ الصَّدَقَۃَ ، وَیَأْخُذُہَا بِیَمِینِہِ فَیُرَبِّیہَا لِصَاحِبِہَا ، کَمَا یُرَبِّی أَحَدُکُمْ فَلُوَّہُ، أَوْ فَصِیلَہُ حَتَّی إنَّ اللُّقْمَۃَ لَتَصِیرُ مِثْلَ أُحُدٍ ، وَتَصْدِیقُ ذَلِکَ فِی کِتَابِ اللہِ عَزَّ وَجَلَّ : {ہُوَ الذی یَقْبَلُ التَّوْبَۃَ عَنْ عِبَادِہِ وَیَأْخُذُ الصَّدَقَاتِ} ، وَ{یَمْحَقُ اللَّہُ الرِّبَا وَیُرْبِی الصَّدَقَاتِ} ۔ (ترمذی 662۔ ابن خزیمۃ 2427)",,,9907,,
9908,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ یُونُسَ بْنِ خَبَّابٍ ، عَنْ أَبِی سَلَمَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا نَقَصَتْ صَدَقَۃٌ مِنْ مَالٍ قَطُّ ، فَتَصَدَّقُوا۔ (احمد 1/193۔ ابویعلی 845)",,,9908,,
9909,"حَدَّثَنَا یَحْیَی بْنُ عِیسَی ، عَنِ الأَعْمَشِ ، عَنْ طَلْحَۃَ ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : أُہْدِیَتْ لَنَا شَاۃٌ مَشْوِیَّۃٌ ، فَقَسَّمْتُہَا کُلَّہَا إِلاَّ کَتِفَہَا ، فَدَخَلَ عَلَیَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَذَکَرْت ذَلِکَ لَہُ ، فَقَالَ: لاَ ، کُلُّہَا لَکُمْ إِلاَّ کَتِفَہَا۔ (ترمذی 2470۔ احمد 6/50)",,,9909,,
9910,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ سَالِمٍ ، عَنْ عَطِیَّۃَ مَوْلَی بَنِی عَامِرٍ ، عَنْ یَزِیدَ بْنِ بِشْرٍ السَّکْسَکِیِّ ، قَالَ: بَعَثَہُ یَزِیدُ بْنُ عَبْدِ الْمَلِکِ بِکُِسْوَۃٍ إلَی الْکَعْبَۃِ ، فَلَمَّا أَتَی تَیْمَائَ جَائَہُ سَائِلٌ فَسَأَلَ ، قَالَ : فَقَالَ : تَصَدَّقُوا ، فَإِنَّ الصَّدَقَۃَ تُنْجِی مِنْ سَبْعِینَ بَابًا مِنَ الشَّرِّ ، قَالَ : فَقُلْتُ : مَنْ ہَاہُنَا أَفْقَہُ ؟ قَالُوا : نُسَیٌّ ، رَجُلٌ مِنَ الْیَہُودِ ، فَأَتَیْتُ الدَّارَ ، فَقُلْتُ : ثَمَّ نُسَیٌّ ؟ فَأَشْرَفَتْ عَلَیَّ امْرَأَتُہُ ، فَأَذِنَتْ لِی فَدخلتُ عَلَیْہِ ، فَلَمَّا رَآنِی تَوَضَّأَ ، فَقُلْتُ لَہُ : مَا شَأْنُکَ حِینَ رَأَیْتَنِی تَوَضَّأْتَ ؟ قَالَ : إنَّ اللَّہَ تَعَالَی قَالَ : یَا مُوسَی ، تَوَضَّأْ ، فَإِنْ لَمْ تَفْعَلْ فَأَصَابَتْک مُصِیبَۃٌ فَلاَ تَلُومَنَّ إِلاَّ نَفْسَک ۔ قَالَ : قُلْتُ : إنَّ سَائِلاً یَسْأَلُ ، فَقَالَ : تَصَدَّقُوا ، فَإِنَّ الصَّدَقَۃَ تُنْجِی مِنْ سَبْعِینَ بَابًا مِنَ الشَّرِّ، قَالَ : صَدَقَ ، فَذَکَرَ أَشیائَ مِنَ الْمَنَایَا ، وَہَدْمِ الْحَائِطِ ، وَوَقْصِ الدَّابَّۃِ ، وَالْغَرَقِ مِمَّا شَائَ اللَّہ مِمَّا عُدَّ مِنَ الْمَنَایَا ، قَالَ : قُلْتُ : وَتُنَجِّی مِنَ النَّارِ۔",,,9910,,
9911,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ مَرْثَدِ بْنِ عَبْدِ اللہِ الْیَزَنِیِّ ، قَالَ : حدَّثَنِی مَنْ سَمِعَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : صَدَقَۃُ الْمُؤْمِنِ ظِلُّہُ یَوْمَ الْقِیَامَۃِ۔ (احمد 233)",,,9911,,
9912,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنْ عَلِیِّ بْنِ الأَقْمَرِ ، عَنْ أَبِی الأَحْوَصِ ، قَالَ : (قدْ أَفْلَحَ مَنْ تَزَکَّی) ، قَالَ : مَنْ رَضَخ۔",,,9912,,
9913,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ثَابِتٍ ، عَنْ أَبِی مَدَیْنَۃَ ؛ أَنَّ سَائِلاً سَأَلَ عَبْدَ الرَّحْمَن بْنِ عَوْفٍ وَبَیْنَ یَدَیْہِ عِنَبٌ ، فَنَاوَلَہُ حَبَّۃً ، فَکَأَنَّہُمْ أَنْکَرُوا ذَلِکَ ، فَقَالَ : فِی ہَذِہِ مِثْقَالُ ذَرٍّ کَثِیرٌ۔",,,9913,,
9914,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ خُلَیْدِ بْنِ جَعْفَرٍ ، قَالَ : سَمِعْتُ أَبَا إیَاسٍ یُحَدِّثُ عَنْ أُمِّ الْحَسَنِ ؛ أَنَّہَا کَانَتْ عِنْدَ أُمِّ سَلَمَۃَ زَوْجِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَجَائَ مَسَاکِینُ ، فَقَالَتْ : أُخْرِجُہُنّ ؟ فَقَالَتْ أُمُّ سَلَمَۃَ : مَا بِہَذَا أمِرنَا ، أَبِدِّیہنَّ بِتَمْرَۃٍ تَمْرَۃٍ۔",,,9914,,
9915,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ حَمَّادِ بْنِ الْمُخْتَارِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : کَانَ یُقَالُ : رُدُّوا السَّائِلَ وَلَوْ بِمِثْلِ رَأْسِ الْقَطَاۃ۔",,,9915,,
9916,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُصْعَبِ بْنِ مُحَمَّدٍ ، عَنْ یَعْلَی بْنِ أَبِی یَحْیَی ، عَنْ فَاطِمَۃَ بِنْتِ حُسَیْنٍ ، عَنْ أَبِیہَا ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِلسَّائِلِ حَقٌّ وَإِنْ جَائَ عَلَی فَرَسٍ۔ (ابوداؤد 1663۔ احمد 1/201)",,,9916,,
9917,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، قَالَ : قَالَ عِیسَی ابْنُ مَرْیَمَ : لِلسَّائِلِ حَقٌّ ، وَإِنْ جَائَ عَلَی فَرَسٍ مُطَوَّقٍ بِالْفِضَّۃِ۔",,,9917,,
9918,"حَدَّثَنَا مَالِکُ بْنُ إسْمَاعِیلَ ، عَنْ زُہَیْرٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، قَالَ : إذَا أَتَی أَحَدَکُمُ السَّائِلُ ، وَہُوَ یُرِیدُ الصَّلاَۃَ ، أَوَ قَالَ : یُرِیدُ أَنْ یُصَلِّیَ ، فَإِنِ اسْتَطَاعَ أَنْ یَتَصَدَّقَ فَلْیَفْعَلْ ، فَإِنَّ اللَّہَ یَقُولُ : {قَدْ أَفْلَحَ مَنْ تَزَکَّی وَذَکَرَ اسْمَ رَبِّہِ فَصَلَّی} ، فَإِنِ اسْتَطَاعَ أَنْ یُقَدِّمَ بَیْنَ یَدَیْ صَلاَتِہِ صَدَقَۃً فَلْیَفْعَلْ۔",,,9918,,
9919,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ لَمْ یُؤَدِّ الزَّکَاۃَ ، فَلاَ صَلاَۃَ لَہُ۔",,,9919,,
9920,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ سَلَمَۃَ ، عَنِ الضَّحَّاکِ ، قَالَ : لاَ صَلاَۃَ إِلاَّ بِزَکَاۃٍ۔",,,9920,,
9921,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، قَالَ : قَالَ عَبْدُ اللہِ : مَا مَانِعُ الزَّکَاۃِ بِمُسْلِمٍ۔",,,9921,,
9922,"حَدَّثَنَا شَرِیکٌ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ أَبُو بَکْرٍ : لَوْ مَنَعُونِی وَلَوْ عِقَالاً مِمَّا أَعْطَوْا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَجَاہَدْتُہمْ ۔ قَالَ ، ثُمَّ تَلاَ : {وَمَا مُحَمَّدٌ إِلاَّ رَسُولٌ قَدْ خَلَتْ مِنْ قَبْلِہِ الرُّسُلُ أَفَئِنْ مَاتَ ، أَوْ قُتِلَ انْقَلَبْتُمْ عَلَی أَعْقَابِکُمْ}۔",,,9922,,
9923,حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ إذَا أَدَّیْتَ زَکَاۃَ مَالِکَ ، أَذْہَبْتَ عَنْک شَرَّہُ۔,,,9923,,
9924,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا زَکَرِیَّا بْنُ إِسْحَاقَ الْمَکِّیِّ ، قَالَ : حَدَّثَنِی یَحْیَی بْنُ عَبْدِ اللہِ بْنِ صَیْفِیٍّ ، عَنْ أَبِی مَعْبَدٍ مَوْلَی ابْنِ عَبَّاسٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ مُعَاذٍ ، قَالَ : بَعَثَنِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إنَّکَ تَأْتِی قَوْمًا مِنْ أَہْلِ الْکِتَابِ ، فَادْعُہُمْ إلَی شَہَادَۃِ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ وَأَنِّی رَسُولُ اللہِ ، فَإِنْ ہُمْ أَطَاعُوا لِذَلِکَ فَأَعْلِمْہُمْ ، أَنَّ اللَّہَ افْتَرَضَ عَلَیْہِمْ خَمْسَ صَلَوَاتٍ فِی کُلِّ یَوْمٍ وَلَیْلَۃٍ ، فَإِنْ ہُمْ أَطَاعُوا لِذَلِکَ، فَأَعْلِمْہُمْ أَنَّ اللَّہَ افْتَرَضَ عَلَیْہِمْ صَدَقَۃً فِی أَمْوَالِہِمْ ، تُؤْخَذُ مِنْ أَغْنِیَائِہِمْ فَتُرَدُّ فِی فُقَرَائِہِمْ ، فَإِنْ ہُمْ أَطَاعُوا لِذَلِکَ ، فَإِیَّاکَ وَکَرَائِمَ أَمْوَالِہِمْ ، وَاتَّقِ دَعْوَۃَ الْمَظْلُومِ ، فَإِنَّہَا لَیْسَ بَیْنَہَا وَبَیْنَ اللہِ حِجَابٌ۔ (بخاری 2448۔ ابوداؤد 1579)",,,9924,,
9925,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ ابن أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : لُعِنَ مَانِعُ الصَّدَقَۃِ۔ (ترمذی 1119۔ ابوداؤد 2069)",,,9925,,
9926,حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ مِثْلَہُ۔,,,9926,,
9927,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنِ الْحَارِثِ بْنِ عَبْدِ اللہِ ، عَنْ عَبْدِ اللہِ ، قَالَ : لاَوِی الصَّدَقَۃِ ، یَعْنِی : مَانِعَہَا ، مَلْعُونٌ عَلَی لِسَانِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ الْقِیَامَۃِ۔ (احمد 1/430۔ ابن حبان 3252)",,,9927,,
9928,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُثَنَّی بْنِ سَعِیدٍ ، قَالَ : سَمِعْتُ أَنَسًا وَشَکَا إلَیْہِ قَوْمٌ مِنَ الأَعْرَابِ الصَّدَقَۃَ ، فَقَالَ : اجْمَعُوہَا وَأَدُّوہَا لِوَقْتِہَا ، فَمَا أُخِذَ مِنْکُمْ بَعْدَ ذَلِکَ فَہُوَ ظُلْمٌ ظُلِمْتُمُوہُ۔",,,9928,,
9929,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، عَنْ جَرِیرٍ ، قَالَ : قُلْتُ لِبَنِیَّ : یَا بَنِیَّ ، إذَا جَائَکُمُ الْمُصَدِّقُ فَلاَ تَکْتُمُوہُ مِنْ نَعَمِکُمْ شَیْئًا۔",,,9929,,
9930,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إذَا جَائَکَ الْمُصَدِّقُ ، فَقَالَ: أَخْرِجْ صَدَقَتَکَ ، فَأَخْرِجْہَا ، فَإِنْ قَبِلَ فَبِہَا وَنَعِمَتْ ، فَإِنْ أَبَی فَوَلِّہ ظَہْرَک ، وَقُلَ : اللَّہُمَّ إنِّی أَحْتَسِبُ عِنْدَکَ مَا یَأْخُذُ مِنِّی ، وَلاَ تَلْعَنہُ۔",,,9930,,
9931,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ جَرِیرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِیَصْدُرَ الْمُصَدِّقُ عَنْکُمْ حِینَ یُصْدِرُ وَہُوَ رَاضٍ ۔ وَقَالَ الشَّعْبِیُّ : الْمُعْتَدِی فِی الصَّدَقَۃِ کَمَانِعِہَا۔ (ترمذی 648۔ احمد 4/365)",,,9931,,
9932,"حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، قَالَ : حدَّثَنَا ثَابِتُ بْن قَیْسٍ ، عَنْ خَارِجَۃَ بْنِ إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ جَابِرِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : سَیَأْتِیکُمْ رَکْبٌ مُبْغَضُونَ ، فَإِنْ جَاؤُوکُمْ فَرَحِّبُوا بِہِمْ ، وَخَلُّوا بَیْنَہُمْ وَبَیْنَ مَا یَبْغُونَ ، فَإِنْ عَدَلُوا فَلأَنْفُسِہِمْ وَإِنْ ظَلَمُوا فَعَلَیْہِمْ ، وَأَرْضُوہُمْ فَإِنَّ تَمَامَ زَکَاتِکُمْ رِضَاہُمْ ، وَلْیَدْعُوا لَکُمْ۔",,,9932,,
9933,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ الرَّازِیّ ، عَنْ أَبِی سَنان ، عَنِ الضَّحَّاکِ ، قَالَ : کَانَ عُمَرُ بْنُ الْخَطَّابِ إذَا ظَہَرَ عَلَی مَالٍ قَدْ غُیِّبَ عَنِ الصَّدَقَۃِ ، خَمَّسَہُ۔",,,9933,,
9934,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، قَالَ: حدَّثَنَا ابْنُ أَبِی عَرُوبَۃَ، عَنْ عُبَیْدِاللہِ بْنِ رُزَیْقٍ، أَنَّہُ سَمِعَ الْحَسَنَ، قَالَ: قَالَ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ أَدَّی زَکَاۃَ مَالِہِ أَدَّی الْحَقَّ الَّذِی عَلَیْہِ، وَمَنْ زَادَ فَہُوَ خَیْرٌ لَہُ۔ (ابوداؤد 130)",,,9934,,
9935,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ أَدَّی زَکَاۃَ مَالِہِ ، فَلاَ جُنَاحَ عَلَیْہِ أَنْ لاَ یَتَصَدَّقَ۔ (بخاری 1454۔ عبدالرزاق 7085)",,,9935,,
9936,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا بَلَغَ الْمَالُ مِئَتَیْ دِرْہَمٍ ، فَفِیہِ خَمْسَۃُ دَرَاہِمَ۔",,,9936,,
9937,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَاصِمٍ ، عَنِ الْحَسَنِ ، قَالَ : کَتَبَ عُمَرُ إلَی أَبِی مُوسَی : أَنْ خُذْ مِمَّنْ مَرَّ بِکَ مِنْ تُجَّارِ الْمُسْلِمِینَ مِنْ کُلِّ مِئَتَیْ دِرْہَمٍ ، خَمْسَۃَ دَرَاہِمَ۔",,,9937,,
9938,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ جَابِرِ الْحَذَّائِ ، وَکَانَ عَبْدًا لِبَنِی مُجَاشِعٍ ، قَالَ : قُلْتُ لاِبْنِ عُمَرَ : ہَلْ عَلَی الْعَبْدِ زَکَاۃٌ ؟ قَالَ : أَمُسْلِمٌ ؟ قُلْتُ : نَعَمْ ، قَالَ : عَلَیْہِ فِی کُلِّ مِئَتَیْ دِرْہَمٍ خَمْسَۃُ دَرَاہِمَ۔",,,9938,,
9939,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ؛ قَالَ : تَحِلُّ عَلَیْہِ الزَّکَاۃُ مِنْ یَوْمِ مَلَکَ مِئَتَیْ دِرْہَمٍ ، ثُمَّ یَحُولُ عَلَیْہِ الْحَوْلُ۔",,,9939,,
9940,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی کُلِّ مِئَتَیْ دِرْہَمٍ خَمْسَۃُ دَرَاہِمَ۔",,,9940,,
9941,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، رَفَعَہُ ، قَالَ : إذَا بَلَغَتْ خَمْسَ أَوَاقٍ فَفِیہَا خَمْسَۃُ دَرَاہِمَ ، وَفِی کُلِّ أَرْبَعِینَ دِرْہَمًا دِرْہَمٌ۔",,,9941,,
9942,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی ابْنُ حُجَیْرٍ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ کَانَ یَقُولُ : فِی مِئَتَیْ دِرْہَمٍ خَمْسَۃُ دَرَاہِمَ۔",,,9942,,
9943,"حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ عَوْفٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا کَانَتْ مِئَتَیْ دِرْہَمٍ ،فَفِیہَا خَمْسَۃُ دَرَاہِمَ۔",,,9943,,
9944,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ قَالَ : فِی الْمَعَادِنِ مِنْ کُلِّ مِئَتَیْنِ خَمْسَۃٌ۔",,,9944,,
9945,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا بَلَغَتْ مِئَتَیْنِ فَفِیہَا خَمْسَۃُ دَرَاہِمَ۔",,,9945,,
9946,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَکُونُ فِی الدَّرَاہِمِ زَکَاۃٌ حَتَّی تَبْلُغَ خَمْسَ أَوَاقٍ۔",,,9946,,
9947,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : إِنْ لَمْ تَکُنْ لَکَ إِلاَّ تِسْعَۃٌ وَتِسْعِینَ وَمِئَۃٌ ، فَلَیْسَ فِیہَا زَکَاۃٌ۔",,,9947,,
9948,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : لَیْسَ فِی أَقَلَّ مِنْ مِئَتَیْ دِرْہَمٍ زَکَاۃٌ۔",,,9948,,
9949,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ قَالَ : کُلُّ شَیْئٍ دُونَ الْمِئَتَیْنِ نَفَقَۃٌ۔",,,9949,,
9950,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَمْرِو بْنِ یَحْیَی بْنِ عُمَارَۃَ ؛ أَنَّ أَبَاہُ یَحْیَی بْنَ عُمَارَۃَ أَخْبَرَہُ أَنَّہُ سَمِعَ أَبَا سَعِیدٍ الْخُدْرِیَّ ، یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ فِیمَا دُونَ خَمْسِ أَوَاقٍ صَدَقَۃٌ ، وَکَانَتْ تُقَوَّمُ مِئَتَیْ دِرْہَمٍ۔ (بخاری 1447۔ مسلم 674)",,,9950,,
9951,"حَدَّثَنَا عَبْدُالرَّحِیمِ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ؛ أَنَّہُ قَالَ: لَیْسَ فِیمَا دُونَ خَمْسِ أَوَاقٍ مِنْ فِضَّۃٍ صَدَقَۃٌ۔",,,9951,,
9952,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ؛ قَالَ : لَیْسَ فِی الشَّنْقِ شَیْئٌ ، قَالَ : الشَّنْقُ : مَالٌ لَمْ یَبْلُغْ مِئَتَیْ دِرْہَمٍ۔",,,9952,,
9953,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَیْسَ فِی أَقَلَّ مِنْ مِئَتَیْ دِرْہَمٍ شَیْئٌ۔ (دارقطنی 93)",,,9953,,
9954,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ ، عَنْ عَلِیٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَیْسَ فِی أَقَلَّ مِنْ مِئَتَیْ دِرْہَمٍ شَیْئٌ۔ (ترمذی 620۔ ابوداؤد 1566)",,,9954,,
9955,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنِی عَمَّارُ بْنُ رُزَیْقٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِثْلَہ ، قَالَ : لَیْسَ فِی أَقَلَّ مِنْ مِئَتَیْ دِرْہَمٍ شَیْئٌ۔",,,9955,,
9956,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانَ لاَ یَرَی فِیمَا زَادَ عَلَی الْمِئَتَیْنِ شَیْئٌ ، حَتَّی یَبْلُغَ أَرْبَعِینَ۔",,,9956,,
9957,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَاصِمٍ ، عَنِ الْحَسَنِ ، قَالَ : کَتَبَ عُمَرُ إلَی أَبِی مُوسَی : فَمَا زَادَ عَلَی الْمِئَتَیْنِ ، فَفِی کُلِّ أَرْبَعِینَ دِرْہَماً دِرْہَم۔",,,9957,,
9958,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ فِیمَا زَادَ عَلَی الْمِئَتَیْنِ شَیْئٌ ، حَتَّی یَکُونَ أَرْبَعِینَ دِرْہَماً۔",,,9958,,
9959,"حَدَّثَنَا ابْنُ مَہْدِِیٍّ ، عَنْ سَعِیدِ بْنِ زَیْدٍ ، عَنْ وَاصِلٍ مَوْلَی أَبِی عُیَیْنَۃَ ، عَنْ مَکْحُولٍ ، قَالَ : لَیْسَ فِیمَا زَادَ عَلَی الْمِئَتَیْنِ شَیْئٌ ، حَتَّی یَبْلُغَ أَرْبَعِینَ دِرْہَمًا۔",,,9959,,
9960,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : حَتَّی یَبْلُغَ أَرْبَعِینَ دِرْہَمًا نَیِّفًا عَلَی الْمِئَتَیْنِ فَہِیَ حِینَئِذٍ سِتَّۃُ دَرَاہِمَ ، ثُمَّ لاَ شَیْئَ حَتَّی تَبْلُغَ ثَمَانِینَ وَمِئَتَیْ دِرْہَمٍ ، فَہِیَ سَبْعَۃُ دَرَاہِمَ ، ثُمَّ کَذَلِکَ۔",,,9960,,
9961,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : لَیْسَ فِی أَقَلَّ مِنْ مِئَتَیْ دِرْہَمٍ شَیْئٌ ، فَمَا زَادَ فَبِالْحِسَابِ۔",,,9961,,
9962,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ جَابِر الْحَذَّائِ ، وَکَانَ عَبْدًا لِبَنِی مُجَاشِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَا زَادَ عَلَی الْمِئَتَیْنِ ، فَبِالْحِسَابِ۔",,,9962,,
9963,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : مَا زَادَ عَلَی الْمِئَتَیْنِ فَبِحِسَابٍ۔",,,9963,,
9964,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ وُہَیْبٍ ، عَنْ یُونُسَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : مَا زَادَ فَبِالْحِسَابِ۔",,,9964,,
9965,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ قَتَادَۃَ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : مَا زَادَ فَبِالْحِسَابِ۔",,,9965,,
9966,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنَ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : لَیْسَ فِی أَقَلَّ مِنْ عِشْرِینَ دِینَارًا شَیْئٌ ، وَفِی عِشْرِینَ دِینَارًا نِصْفُ دِینَارٍ ، وَفِی أَرْبَعِینَ دِینَارًا دِینَارٌ ، فَمَا زَادَ فَبِالْحِسَابِ۔",,,9966,,
9967,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَلْقَمَۃَ بْنِ مَرْثَدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی عِشْرِینَ مِثْقَالاً نِصْفُ مِثْقَالٍ ، وَفِی أَرْبَعِینَ مِثْقَالاً مِثْقَالٌ۔",,,9967,,
9968,"حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ عِمْرَانَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : فِی أَرْبَعِینَ دِینَارًا دِینَارٌ ، وَفِی عِشْرِینَ دِینَارًا نِصْفُ دِینَارٍ۔",,,9968,,
9969,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی عِشْرِینَ دِینَارًا نِصْفُ دِینَارٍ۔",,,9969,,
9970,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَیْسَ فِی أَقَلَّ مِنْ عِشْرِینَ مِثْقَالاً شَیْئٌ ، وَفِی عِشْرِینَ نِصْفُ مِثْقَالٍ ، وَفِی أَرْبَعِینَ مِثْقَالاً مِثْقَالٌ۔",,,9970,,
9971,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ رُزَیْقٍ مَوْلَی بَنِی فَزَارَۃَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ إلَیْہِ حِینَ اُسْتُخْلِفَ : خُذْ مِمَّنْ مَرَّ بِکَ مِنْ تُجَّارِ الْمُسْلِمِینَ فِیمَا یُدِیرُونَ مِنْ أَمْوَالِہِمْ ، مِنْ کُلِّ أَرْبَعِینَ دِینَارًا دِینَارًا ، فَمَا نَقَصَ فَبِحِسَابِ مَا نَقَصَ حَتَّی یَبْلُغَ عشرین ، فَإِذَا نَقَصَتْ ثُلُثَ دِینَارٍ فَدَعْہَا ، لاَ تَأْخُذْ مِنْہَا شَیْئًا ، وَاکْتُبْ لَہُمْ بَرَائَۃً بِمَا تَأْخُذُ مِنْہُمْ إلَی مِثْلِہَا مِنَ الْحَوْلِ ، وَخُذْ مِمَّنْ مَرَّ بِکَ مِنْ تُجَّارِ أَہْلِ الذِّمَّۃِ ، فِیمَا یُظْہِرُونَ مِنْ أَمْوَالِہِمْ وَیُدِیرُونَ مِنَ التِّجَارَاتِ ، مِنْ کُلِّ عِشْرِینَ دِینَارًا دِینَارًا ، فَمَا نَقَصَ فَبِحِسَابِ مَا نَقَصَ حَتَّی یَبْلُغَ عَشَرَۃَ دَنَانِیرَ ، فَإِذَا نَقَصَتْ ثُلُثَ دِینَارٍ فَدَعْہَا ، لاَ تَأْخُذْ مِنْہَا شَیْئًا ، وَاکْتُبْ لَہُمْ بَرَائَۃً إلَی مِثْلِہَا مِنَ الْحَوْلِ بِمَا تَأْخُذُ مِنْہُمْ۔",,,9971,,
9972,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِاللہِ، عَنْ أَشْعَثَ، عَنِ الْحَسَنِ، قَالَ: لَیْسَ فِیمَا دُونَ أَرْبَعِینَ مِثْقَالاً مِنَ الذَّہَبِ صَدَقَۃٌ۔",,,9972,,
9973,حَدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ؛ أَنَّہُ کَانَ لاَ یَرَی فِی عِشْرِینَ دِینَارًا زَکَاۃً ، حَتَّی تَکُونَ عِشْرِینَ مِثْقَالاً ، فَیَکُون فِیہَا نِصْفُ مِثْقَالٍ۔,,,9973,,
9974,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ؛ قَالَ : کَانَ لِاِمْرَأَۃِ عَبْدِ اللہِ طَوْقٌ فِیہِ عِشْرُونَ مِثْقَالاً ، فَأَمَرَہَا أَنْ تُخْرِجَ مِنْہُ خَمْسَۃَ دَرَاہِمَ۔",,,9974,,
9975,"حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ أَشعث ، عَنِ الْحَسَنِ ، قَالَ : فِی عِشْرِینَ دِینَارًا نِصْفُ دِینَارٍ ، وَفِی أَرْبَعِینَ دِینَارًا دِینَارٌ۔",,,9975,,
9976,"حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ فِی أَقَلَّ مِنْ أَرْبَعِینَ دِینَارًا شَیْئٌ۔",,,9976,,
9977,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : لاَ یَکُونُ فِی مَالٍ صَدَقَۃٌ حَتَّی یَبْلُغَ عِشْرِینَ دِینَارًا ، فَإِذَا بَلَغَتْ عِشْرِینَ دِینَارًا فَفِیہَا نِصْفُ دِینَارٍ ، وَفِی کُلِّ أَرْبَعَۃِ دَنَانِیرَ یَزِیدُہَا الْمَالُ دِرْہَمٌ ، حَتَّی تَبْلُغَ أَرْبَعِینَ دِینَارًا ، وَفِی کُلِّ أَرْبَعِینَ دِینَارًا دِینَارٌ ، وَفِی کُلِّ أَرْبَعَۃٍ وَعِشْرِینَ دِینَارًا نِصْفُ دِینَارٍ وَدِرْہَمٌ۔",,,9977,,
9978,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عُبَیْدَۃَ ، قَالَ : سَأَلْتُ إِبْرَاہِیمَ عَن رَجُلٍ لَہُ مِئَۃ دِرْہَمٍ وَعَشَرَۃُ دَنَانِیرَ ؟ قَالَ : یُزَکِّی مِنَ الْمِئَۃِ دِرْہَم دِرْہَمَیْنِ وَنصفًا ، وَمِنَ الدَّنَانِیرِ بِرُبْعِ دِینَارٍ ۔ قَالَ : وَسَأَلْتُ الشَّعْبِیَّ ، فَقَالَ : یُحْمَلُ الأَکْثَرُ عَلَی الأَقَلِّ ۔ أَوَ قَالَ : الأَقَلُّ عَلَی الأَکْثَرِ ، فَإِذَا بَلَغَتْ فِیہِ الزَّکَاۃُ زَکَّاہ۔",,,9978,,
9979,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عُبَیْدِ اللہِ بْنُ عُبَیْدٍ ، قَالَ : قُلْتُ لِمَکْحُولٍ : یَا أَبَا عَبْدِ اللہِ ، إنَّ لِی سَیْفًا فِیہِ خَمْسُونَ وَمِئَۃُ دِرْہَمٍ ، فَہَلْ عَلَیَّ فِیہِ زَکَاۃٌ ، قَالَ : أَضِفْ إلَیْہِ مَا کَانَ لَکَ مِنْ ذَہَبٍ وَفِضَّۃٍ ، فَإِذَا بَلَغَ مِئَتَیْ دِرْہَمٍ ذَہَبٍ وَفِضَّۃٍ ، فَعَلَیْک فِیہِ الزَّکَاۃُ۔",,,9979,,
9980,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَنْصَارِیُّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَقُولُ : إذَا کَانَتْ لَہُ ثَلاَثُونَ دِینَارًا وَمِئَۃُ دِرْہَمٍ کَانَ عَلَیْہِ فِیہَا الصَّدَقَۃُ ، وَکَانَ یَرَی الدَّرَاہِمَ وَالدَّنَانِیرَ عَیْنًا کُلَّہُ۔",,,9980,,
9981,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَتَبَ کِتَابَ الصَّدَقَۃِ فَقَرَنَہُ بِسَیْفِہِ ، أَوَ قَالَ : بِوَصِیَّتِہِ ، وَلَمْ یُخْرِجْہُ حَتَّی قُبِضَ ، فَلَمَّا قُبِضَ عَمِلَ بِہِ أَبُو بَکْرٍ حَتَّی ہَلَکَ ، ثُمَّ عَمِلَ بِہِ عُمَرُ ، فَکَانَ فِیہِ : فِی خَمْسٍ مِنَ الإِبِلِ شَاۃٌ ، وَفِی عَشْرٍ شَاتَانِ ، وَفِی خَمْسَۃَ عَشَرَ ثَلاَثُ شِیَاہٍ ، وَفِی عِشْرِینَ أَرْبَعُ شِیَاہٍ ، وَفِی خَمْسٍ وَعِشْرِینَ بِنْتُ مَخَاضٍ إلَی خَمْسٍ وَثَلاَثِینَ ، فَإِذَا زَادَتْ فَفِیہَا بِنْتُ لَبُونٍ إلَی خَمْسٍ وَأَرْبَعِینَ ، فَإِذَا زَادَتْ فَحِقَّۃٌ إلَی سِتِّینَ ، فَإِذَا زَادَتْ فَجَذَعَۃٌ إلَی خَمْسٍ وَسَبْعِینَ ، فَإِنْ زَادَتْ فَابْنَتَا لَبُونٍ إلَی تِسْعِینَ ، فَإِنْ زَادَتْ فَحِقَّتَانِ إلَی عِشْرِینَ وَمِئَۃٍ ، فَإِنْ زَادَتْ عَلَی عِشْرِینَ وَمِئَۃٍ فَفِی کُلِّ خَمْسِینَ حِقَّۃٌ ، وَفِی کُلِّ أَرْبَعِینَ بِنْتُ لَبُونٍ ، لاَ یُجْمَعُ بَیْنَ مُفْتَرِقٍ ، وَلاَ یُفَرَّقُ بَیْنَ مُجْتَمِعٍ ، وَمَا کَانَ مِنْ خَلِیطَیْنِ ، فَإِنَّہُمَا یَتَرَاجَعَانِ بِالسَّوِیَّۃِ۔ (ترمذی 621۔ ابوداؤد 1562)",,,9981,,
9982,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ خُصَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، وَزِیَادِ بْنِ أَبِی مَرْیَمَ ، عْن عَبْدِ اللہِ قَالَ : فِی خَمْسٍ وَعِشْرِینَ مِنَ الإِبِلِ بِنْتُ مَخَاضٍ۔",,,9982,,
9983,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : فِی خَمْسٍ مِنَ الإِبِلِ شَاۃٌ إلَی تِسْعٍ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا شَاتَانِ إلَی أَرْبَعَ عَشْرَۃَ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا ثَلاَثُ شِیَاہٍ إلَی تِسْعَ عَشْرَۃَ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا أَرْبَعٌ إلَی أَرْبَعٍ وَعِشْرِینَ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا خَمْسُ شِیَاہٍ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا بِنْتُ مَخَاضٍ ، أَوِ ابْنُ لَبُونٍ ذَکَرٌ ، أَکْبَرُ مِنْہَا بِعَامٍ إلَی خَمْسٍ وَثَلاَثِینَ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا بِنْتُ لَبُونٍ إلَی خَمْسٍ وَأَرْبَعِینَ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا حِقَّۃٌ طَرُوقَۃُ الْفَحْلِ إلَی سِتِّینَ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا جَذَعَۃٌ إلَی خَمْسٍ وَسَبْعِینَ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا بِنْتَا لَبُونٍ إلَی تِسْعِینَ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا حِقَّتَانِ إلَی عِشْرِینَ وَمِئَۃٍ ، فَإِذَا کَثُرَتِ الإِبِلُ فَفِی کُلِّ خَمْسِینَ مِنَ الإِبِلِ حِقَّۃٌ ، وَلاَ یُجْمَعُ بَیْنَ مُفْتَرِقٍ ، وَلاَ یُفَرَّقُ بَیْنَ مُجْتَمِعٍ۔",,,9983,,
9984,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، قَالَ : وُجِدَ فِی وَصِیَّۃِ عُمَرَ : فِی خَمْسٍ وَعِشْرِینَ مِنَ الإِبِلِ بِنْتُ مَخَاضٍ۔",,,9984,,
9985,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، عَنِ الشَّعْبِیِّ (ح) وَعَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ قَالاَ : فِی خَمْسٍ وَعِشْرِینَ بِنْتُ مَخَاضٍ۔",,,9985,,
9986,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ بَہزِ بْنِ حَکِیمٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : فِی کُلِّ إبِلٍ سَائِمَۃٍ أَرْبَعِینَ بِنْتُ لَبُونٍ ، لاَ یُفَرَّقُ إبِلٌ عَنْ حِسَابِہَا ، مَنْ أَعْطَاہَا مُؤْتَجِرًا فَلَہُ أَجْرُہُ ، عَزْمَۃٌ مِنْ عَزَمَاتِ رَبِّنَا ، لاَ یَحِلُّ لآلِ مُحَمَّدٍ مِنْہَا شَیْئٌ۔ (ابوداؤد 1569۔ احمد 5/4)",,,9986,,
9987,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : قَالَ عُمَرُ : إذَا کَثُرَتِ الإِبِلُ فَفِی کُلِّ خَمْسِینَ حِقَّۃٌ ، وَفِی کُلِّ أَرْبَعِینَ بِنْتُ لَبُونٍ۔",,,9987,,
9988,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : فِی کُلِّ خَمْسٍ وَعِشْرِینَ بِنْتُ مَخَاضٍ۔",,,9988,,
9989,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ، عَنْ یَحْیَی بْنِ سَعِیدٍ، قَالَ: کَانَ فِی الْکِتَابِ الَّذِی کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ حِینَ بَعَثَہُمْ یُصَدِّقُونَ فِی الإِبِلِ : إذَا بَلَغَتْ خَمْسًا وَعِشْرِینَ فَفِیہَا بِنْتُ مَخَاضٍ ، فَإِنْ زَادَتْ فَابْنُ لَبُونٍ ذَکَرٌ۔",,,9989,,
9990,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، قَالَ : فِی خَمْسٍ وَعِشْرِینَ بِنْتُ مَخَاضٍ۔",,,9990,,
9991,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَتَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی الْیَمَنِ أَنْ یُؤْخَذَ مِنَ الإِبِلِ مِنْ کُلِّ خَمْسٍ شَاۃٌ ، وَمِنْ کُلِّ عَشْرٍ شَاتَانِ ، وَمِنْ خَمْسَۃَ عَشَرَ ثَلاَثُ شِیَاہٍ ، وَمِنْ عِشْرِینَ أَرْبَعُ شِیَاہٍ ، وَمِنْ خَمْسٍ وَعِشْرِینَ خَمْسُ شِیَاہٍ ، فَإِذَا زَادَتْ وَاحِدَۃً فَفِیہَا بِنْتُ مَخَاضٍ إلَی خَمْسٍ وَثَلاَثِینَ ، فَإِنْ لَمْ تَجِدْ فِی الإِبِلِ بِنْتَ مَخَاضٍ فَابْنُ لَبُونٍ ذَکَرٌ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا بِنْتُ لَبُونٍ إلَی خَمْسٍ وَأَرْبَعِینَ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا حِقَّۃٌ إلَی سِتِّینَ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا جَذَعَۃٌ إلَی خَمْسٍ وَسَبْعِینَ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا بِنْتَا لَبُونٍ إلَی تِسْعِینَ ، فَإِنْ زَادَتْ وَاحِدَۃً فَفِیہَا حِقَّتَانِ إلَی عِشْرِینَ وَمِئَۃٍ ، فَإِذَا کَثُرَتِ الإِبِلُ فَفِی کُلِّ خَمْسِینَ حِقَّۃٌ ، وَفِی کُلِّ أَرْبَعِینَ بِنْتُ لَبُونٍ ، وَلاَ یُفَرَّقُ بَیْنَ مُجْتَمِعٍ ، وَلاَ یُجْمَعُ بَیْنَ مُفْتَرِقٍ ، وَلاَ یُؤْخَذُ فِی الصَّدَقَۃِ تَیْسٌ ، وَلاَ ہَرِمَۃٌ ، وَلاَ ذَاتُ عَوَارٍ ۔ قَالَ الأَجْلَحُ : فَقُلْتُ لِلشَّعْبِیِّ : مَا یَعْنِی بِقَوْلِہِ : لاَ یُجْمَعُ بَیْنَ مُفْتَرِقٍ ، وَلاَ یُفَرَّقُ بَیْنَ مُجْتَمِعٍ ؟ قَالَ : الرَّجُلُ تَکُونُ لَہُ الْغَنَمُ فَلاَ یُفَرِّقُہَا کَیْ لاَ یُؤْخَذَ مِنْہَا صَدَقَۃٌ ، وَلاَ یُجْمَعُ بَیْنَ مُفْتَرِقٍ الْقَوْمُ تَکُونُ لَہُمَ الْغَنَمُ لاَ تَجِبُ فِیہَا الزَّکَاۃُ ، فَلاَ تُجْمَعُ فَتُؤْخَذُ مِنْہَا الصَّدَقَۃُ۔",,,9991,,
9992,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ ، عَنْ عَلِیٍّ ، قَالَ : إِنْ لَمْ تَکُنْ إِلاَّ أَرْبَعٌ مِنَ الذَّوْدِ فَلَیْسَ فِیہَا صَدَقَۃٌ۔",,,9992,,
9993,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ، أَنَّہُمَا قَالاَ : لَیْسَ فِی أَقَلَّ مِنْ خَمْسٍ مِنْ الإِبِلِ صَدَقَۃٌ۔",,,9993,,
9994,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : بَلَغَنَا أَنَّ سَالِمَ بْنَ عَبْدِ اللہِ کَانَ یَقُولُ : عِنْدَنَا کِتَابُ عُمَرَ بْنِ الْخَطَّابِ فِی صَدَقَۃِ الإِبِلِ ، فَلَمْ یَسْأَلْنَا عَنْہُ أَحَدٌ ، حَتَّی قَدِمَ عَلَیْنَا عُمَرُ بْنُ عَبْدِ الْعَزِیزِ فَأَرْسَلْنَا بِہِ إلَیْہِ ، فَکَانَ فِی الْکِتَابِ الَّذِی کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ حِینَ بَعَثَہُمْ یُصَدِّقُونَ : أَنْ لَیْسَ فِی الإِبِلِ صَدَقَۃٌ حَتَّی تَبْلُغَ خَمْسًا۔",,,9994,,
9995,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَمْرِو بْنِ یَحْیَی بْنِ عُمَارَۃَ ، عَنْ أَبِیہِ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ فِی أَقَلَّ مِنْ خَمْسِ ذَوْدٍ صَدَقَۃٌ۔",,,9995,,
9996,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَیْسَ فِی أَقَلَّ مِنْ خَمْسِ ذَوْدٍ شَیْئٌ۔",,,9996,,
9997,"حَدَّثَنَا الْحَسَنُ بْنُ مُوسَی ، عَنْ شَیْبَانَ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَیْسَ فِیمَا دُونَ خَمْسِ ذَوْدٍ صَدَقَۃٌ۔ (احمد 2/92۔ بزار 888)",,,9997,,
9998,"حَدَّثَنَا عَلِیُّ بْنُ إِسْحَاقَ ، عَنِ ابْنِ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ سُہَیْلٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَیْسَ فِی أَقَلَّ مِنْ خَمْسِ ذَوْدٍ صَدَقَۃٌ۔ (احمد 2/403۔ طحاوی 35)",,,9998,,
9999,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَتَبَ کِتَابَ الصَّدَقَۃِ ، فَقَرَنَہُ بِسَیْفِہِ ، أَوَ قَالَ : بِوَصِیَّتِہِ فَلَمْ یُخْرِجْہُ حَتَّی قُبِضَ ، عَمِلَ بِہِ أَبُو بَکْرٍ حَتَّی ہَلَکَ ، ثُمَّ عَمِلَ بِہِ عُمَرُ حَتَّی ہَلَکَ ، فَکَانَ فِیہِ : فِی الإِبِلِ إذَا زَادَتْ عَلَی عِشْرِینَ وَمِئَۃٍ ، فَفِی کُلِّ خَمْسِینَ حِقَّۃٌ ، وَفِی کُلِّ أَرْبَعِینَ ابْنَۃُ لَبُونٍ۔",,,9999,,
10000,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : إذَا کَثُرَتِ الإِبِلُ فَفِی کُلِّ خَمْسِینَ حِقَّۃٌ۔",,,10000,,
10001,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَتَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی الْیَمَنِ : إذَا کَثُرَتِ الإِبِلُ فَفِی کُلِّ خَمْسِینَ حِقَّۃٌ ، وَفِی کُلِّ أَرْبَعِینَ بِنْتُ لَبُونٍ۔",,,10001,,
10002,"حَدَّثَنَا عَبْدُ بْنُ سُلَیْمَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ، قَالَ: وُجِدَ فِی وَصِیَّۃِ عُمَرَ: مَا زَادَ عَلَی عِشْرِینَ وَمِئَۃٍ ، فَفِی کُلِّ أَرْبَعِینَ بِنْتُ لَبُونٍ ، وَفِی کُلِّ خَمْسِینَ حِقَّۃٌ۔",,,10002,,
10003,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا کَثُرَتِ الإِبِلُ فَفِی کُلِّ خَمْسِینَ حِقَّۃٌ۔",,,10003,,
10004,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : بَلَغَنَا أَنَّ سَالِمًا کَانَ یَقُولُ : عِنْدَنَا کِتَابُ عُمَرَ فِی صَدَقَۃِ الإِبِلِ وَالْغَنَمِ ، حَتَّی قَدِمَ عَلَیْنَا کِتَابُ عُمَرَ بْنِ عَبْدِالْعَزِیزِ ، فَکَانَ فِی الْکِتَابِ الَّذِی کَتَبَ عُمَرُ بْنُ عَبْدِالْعَزِیزِ حِینَ بَعَثَہُمْ یُصْدِقُونَ : إِذَا زَادَتْ عَلَی عِشْرِینَ وَمِئَۃٍ فَفِی کُلِّ خَمْسِینَ حِقَّۃٌ ، وَفِی کُلِّ أَرْبَعِینَ بِنْتُ لَبُونٍ۔",,,10004,,
10005,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : إذَا زَادَتْ عَلَی عِشْرِینَ وَمِئَۃٍ اسْتَقْبَلَ بِہَا الْفَرِیضَۃَ.",,,10005,,
10006,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ مِثْلَہُ.,,,10006,,
10007,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُجَالِدٍ ، عَنْ قَیْسِ بْنِ أَبِی حَازِمٍ ، عَنِ الصُّنَابِحِیِّ الأَحْمَسِیِّ ، قَالَ: أَبْصَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَاقَۃً حَسَنَۃً فِی إبِلِ الصَّدَقَۃِ ، فَقَالَ : مَا ہَذِہِ ؟ قَالَ صَاحِبُ الصَّدَقَۃِ : إنِّی ارْتَجَعْتہَا بِبَعِیرَیْنِ مِنْ حَوَاشِی الإِبِلِ ، قَالَ : فَقَالَ : فَنَعَمْ إذًا. (احمد 4/349۔ طبرانی 7417)",,,10007,,
10008,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ ہِلاَلِ بْنِ خَبَّابٍ ، عَنْ مَیْسَرَۃَ أَبِی صَالِحٍ ، قَالَ : حدَّثَنَا سُوَیْد بْنُ غَفَلَۃَ ، قَالَ : أَتَانَا مُصَدِّقُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَتَیْتَہُ فَجَلَسْتُ إلَیْہِ ، فَسَمِعْتُہُ یَقُولُ : إنَّ فِی عَہْدِی أَنْ لاَ آخُذَ مِنْ رَاضِعِ لَبَنٍ ، وَلاَ یُجْمَعُ بَیْنَ مُتَفَرِّقٍ ، وَلاَ یُفَرَّقُ بَیْنَ مُجْتَمِعٍ ، قَالَ : وَأَتَاہُ رَجُلٌ بِنَاقَۃٍ کَوْمَائَ ، فَأَبَی أَنْ یَأْخُذَہَا. (ابوداؤد 1573۔ طبرانی 6473)",,,10008,,
10009,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَ مُصَدِّقًا ، فَقَالَ : لاَ تَأْخُذْ مِنْ حَزَرَاتِ أَنْفُسِ النَّاسِ شَیْئًا ، وَخُذِ الشَّارِفَ ، وَذَاتَ الْعَیْبِ. (بیہد 102)",,,10009,,
10010,"حَدَّثَنَا حَفْصٌ ، عَنْ إسْمَاعِیلَ ، عَنْ قَیْسٍ ، قَالَ : أَبْصَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَاقَۃً حَسَنَۃً فِی إبِلِ الصَّدَقَۃِ ، فَقَالَ : مَا أَمْرُ ہَذِہِ النَّاقَۃِ ؟ فَقَالَ صَاحِبُ الصَّدَقَۃِ : یَا رَسُولَ اللہِ ، عَرَفْتُ حَاجَتَکَ إلَی الظَّہْرِ ، فَارْتَجَعْتہَا بِبَعِیرَیْنِ مِنَ الصَّدَقَۃِ.",,,10010,,
10011,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی ، عَنِ الْقَاسِمِ ؛ أَنَّ عُمَرَ مَرَّتْ بِہِ غَنَمُ مِنْ غَنَمِ الصَّدَقَۃِ ، فَرَأَی فِیہَا شَاۃً ذَاتَ ضَرْعٍ ، فَقَالَ : مَا ہَذِہِ ؟ قَالُوا : مِنْ غَنَمِ الصَّدَقَۃِ ، فَقَالَ : مَا أَعْطَی ہَذِہِ أَہْلُہَا وَہُمْ طَائِعُونَ ، لاَ تَفْتِنُوا النَّاسَ ، لاَ تَأْخُذُوا حَزَرَاتِ النَّاسِ ، نُکِبُوا عَنِ الطَّعَامِ.",,,10011,,
10012,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا بْنِ إِسْحَاقَ ، عَنْ یَحْیَی بْنِ عَبْدِ اللہِ بْنِ صَیْفِیٍّ ، عَنْ أَبِی مَعْبَدٍ ، عَنِ ابْنِ عَبَّاسٍ، عَنْ مُعَاذٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إیَّاکَ وَکَرَائِمَ أَمْوَالِہِمْ ، حِینَ بَعَثَہُ إلَی الْیَمَنِ.",,,10012,,
10013,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ خُصَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فِی ثَلاَثِینَ مِنَ الْبَقَرِ تَبِیعٌ ، أَوْ تَبِیعَۃٌ ، وَفِی أَرْبَعِینَ مُسِنَّۃٌ. (ترمذی 622۔ احمد 1/411)",,,10013,,
10014,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن مَسْرُوقٍ ، قَالَ : لَمَّا بَعَثَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُعَاذًا إلَی الْیَمَنِ ، أَمَرَہُ أَنْ یَأْخُذَ مِنْ کُلِّ ثَلاَثِینَ مِنَ الْبَقَرِ تَبِیعًا ، أَوْ تَبِیعَۃً ، وَمِنْ کُلِّ أَرْبَعِینَ مُسِنَّۃً ، وَمِنْ کُلِّ حَالِمٍ دِینَارًا ، أَوْ عَدْلَہُ مَعَافِرَ. (ابوداؤد 1571)",,,10014,,
10015,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَتَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی الْیَمَنِ : أَنْ یُؤْخَذَ مِنْ ثَلاَثِینَ مِنَ الْبَقَرِ تَبِیعٌ ، أَوْ تَبِیعَۃٌ ، وَفِی کُلِّ أَرْبَعِینَ مُسِنَّۃٌ.",,,10015,,
10016,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، وَأَبِی وَائِلٍ ، قَالاَ : بَعَثَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُعَاذًا إلَی الْیَمَنِ ، وَأَمَرَہُ أَنْ یَأْخُذَ مِنَ الْبَقَرِ مِنْ کُلِّ ثَلاَثِینَ تَبِیعًا ، أَوْ تَبِیعَۃً ، وَمِنْ أَرْبَعِینَ مُسِنَّۃً ، وَمِنْ کُلِّ حَالِمٍ دِینَارًا، أَوْ عَدْلَہُ مِنَ الْمَعَافِرِ. (ابوداؤد 1570۔ نسائی 2232)",,,10016,,
10017,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : إذَا بَلَغَتْ ثَلاَثِینَ فَفِیہَا تَبِیعٌ ، أَوْ تَبِیعَۃٌ حَوْلِیٌّ ، فَإِذَا بَلَغَتْ أَرْبَعِینَ فَفِیہَا مُسِنَّۃٌ ، ثَنِیَّۃٌ فَصَاعِدًا.",,,10017,,
10018,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، قَالَ : بَلَغَنِی أَنَّ مُعَاذًا قَالَ : فِی ثَلاَثِینَ تَبِیعٌ ، وَفِی أَرْبَعِینَ بَقَرَۃٌ.",,,10018,,
10019,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : فِی ثَلاَثِینَ مِنَ الْبَقَرِ تَبِیعٌ ، أَوْ تَبِیعَۃٌ جَذَعٌ ، أَوْ جَذعَۃٌ ، وَفِی أَرْبَعِینَ مُسِنَّۃٌ.",,,10019,,
10020,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ شَہْرٍ ، قَالَ : فِی سَائِمَۃِ الْبَقَرِ ، فِی کُلِّ ثَلاَثِینَ تَبِیعٌ ، وَفِی کُلِّ أَرْبَعِینَ مُسِنَّۃٌ.",,,10020,,
10021,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی ثَلاَثِینَ مِنَ الْبَقَرِ تَبِیعٌ ، أَوْ تَبِیعَۃٌ ، وَفِی أَرْبَعِینَ مُسِنَّۃٌ.",,,10021,,
10022,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ ، قَالَ : اُسْتُعْمِلْتُ عَلَی صَدَقَاتِ عَکٍّ ، فَلَقِیتُ أَشْیَاخًا مِمَّنْ صَدَّقَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَاخْتَلَفُوا عَلَیَّ ، فَمِنْہُمْ مَنْ قَالَ اجْعَلْہَا مِثْلَ صَدَقَۃِ الإِبِلِ ، وَمِنْہُمْ مَنْ قَالَ فِی ثَلاَثِینَ تَبِیعٌ ، وَمِنْہُمْ مَنْ قَالَ فِی أَرْبَعِینَ بَقَرَۃٍ بَقَرَۃٌ مُسِنَّۃٌ",,,10022,,
10023,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی ثَلاَثِینَ تَبِیعٌ ، أَوْ تَبِیعَۃٌ جَذَعٌ ، أَوْ جَذَعَۃٌ ، وَفِی أَرْبَعِینَ مُسِنَّۃٌ.",,,10023,,
10024,"حَدَّثَنَا زَیْدُ بْنُ حَبَّابٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنِ الْعَلاَئِ بْنِ الْحَارِثِ ، عَنْ مَکْحُولٍ ، قَالَ : إذَا بَلَغَتْ ثَلاَثِینَ فَفِیہَا تَبِیعٌ ، أَوْ تَبِیعَۃٌ ، فَإِذَا بَلَغَتْ أَرْبَعِینَ فَفِیہَا مُسِنَّۃٌ.",,,10024,,
10025,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ أَنَّہُ قَالَ : فِی ثَلاَثِینَ مِنَ الْبَقَرِ تَبِیعٌ جَذَعٌ ، أَوْ جَذَعَۃٌ ، وَفِی کُلِّ أَرْبَعِینَ بَقَرَۃً بَقَرَۃٌ.",,,10025,,
10026,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ صَالِحِ بْنِ دِینَارٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ إلَی عُثْمَانَ بْنِ مُحَمَّدِ بْنِ أَبِی سُوَیْد : أَنْ یَأْخُذَ مِنْ کُلِّ ثَلاَثِینَ بَقَرَۃً تَبِیعًا ، وَمِنْ کُلِّ أَرْبَعِینَ بَقَرَۃً بَقَرَۃً ، وَلَمْ یَزِدْ عَلَی ذَلِکَ.",,,10026,,
10027,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا ؟ فَقَالاَ : فِی ثَلاَثِینَ جَذَعٌ ، أَوْ جَذَعَۃٌ ، وَفِی أَرْبَعِینَ مُسِنَّۃٌ.",,,10027,,
10028,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَمْرٌو ، قَالَ : کَانَ عُثْمانُ بْنُ الزُّبَیْرِ بْنِ أَبِی عَوْفٍ وَغَیْرُہُ یَأْخُذُونَ مِنْ کُلِّ خَمْسِینَ بَقَرَۃً بَقَرَۃً.",,,10028,,
10029,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : إذَا بَلَغَتِ الْبَقَرُ ثَلاَثِینَ فَفِیہَا تَبِیعٌ ، أَوْ جَذَعٌ ، أَوْ جَذَعَۃٌ حَتَّی تَبْلُغَ أَرْبَعِینَ ، فَإِذَا بَلَغَتْ أَرْبَعِینَ فَفِیہَا بَقَرَۃٌ مُسِنَّۃٌ.",,,10029,,
10030,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ؛ أَنَّ نُعَیْمَ بْنَ سَلاَمَۃَ أَخْبَرَہُ، وَہُوَ الَّذِی کَانَ خَاتَمُ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فِی یَدِہِ : أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ دَعَا بِصَحِیفَۃٍ ، زَعَمُوا أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَتَبَ بِہَا إلَی مُعَاذٍ ، فَقَالَ نُعَیْمٌ : فَقُرِئَتْ وَأَنَا حَاضِرٌ ، فَإِذَا فِیہَا : مِنْ کُلِّ ثَلاَثِینَ تَبِیعًا جَذَعٌ ، أَوْ جَذَعَۃٌ ، وَمِنْ کُلِّ أَرْبَعِینَ بَقَرَۃً بَقَرَۃٌ مُسِنَّۃٌ ، قَالَ نُعَیْمٌ : فَقُلْتُ : تَبِیعُ الْجَذَعِ ، فَقَالَ عُمَرُ: بَلْ تَبِیعٌ جَذَعٌ.",,,10030,,
10031,"حَدَّثَنَا زَیْدُ بْنُ حَبَّابٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنِ الْعَلاَئِ بْنِ الْحَارِثِ ، عَنْ مَکْحُولٍ ، قَالَ : لَیْسَ فِیمَا دُونَ الثَّلاَثِینَ مِنَ الْبَقَرِ شَیْئٌ.",,,10031,,
10032,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، قَالَ : حدَّثَنَا ابْنُ جُرَیْجٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : لَیْسَ فِیمَا دُونَ الثَّلاَثِینَ بَقَرَۃً شَیْئٌ.",,,10032,,
10033,"حَدَّثَنَا عَبْدُ الرَّحِیمِ، عَنْ زَکَرِیَّا، عَنْ أَبِی إِسْحَاقَ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ، عَنْ عَلِیٍّ، قَالَ: لَیْسَ فِیہَا شَیْئٌ.",,,10033,,
10034,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَمْرِو بْنِ مُرَّۃً ، عَنْ أَبِی الْبَخْتَرِیِّ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : لَیْسَ فِیمَا دُونَ الثَّلاَثِینَ مِنَ الْبَقَرِ شَیْئٌ.",,,10034,,
10035,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ ابْن أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، قَالَ : بَعَثَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُعَاذًا ، فَأَمَرَہُ أَنْ یَأْخُذَ مِنَ الْبَقَرِ مِنْ کُلِّ ثَلاَثِینَ تَبِیعًا ، أَوْ تَبِیعَۃً ، وَمِنْ کُلِّ أَرْبَعِینَ مُسِنَّۃً ، فَسَأَلُوہُ عَنْ فَضْلِ مَا بَیْنَہُمَا ؟ فَأَبَی أَنْ یَأْخُذَ حَتَّی سَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : لاَ تَأْخُذْ شَیْئًا. (احمد 5/240۔ مالک 24)",,,10035,,
10036,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنْ مُعَاذٍ ، قَالَ : لَیْسَ فِی الأَوْقَاصِ شَیْئٌ.",,,10036,,
10037,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ فِی الأَشْنَاقِ شَیْئٌ.",,,10037,,
10038,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلِیٍّ ، قَالَ : فِی أَرْبَعِینَ مُسِنَّۃٌ ، وَفِی ثَلاَثِینَ تَبِیعٌ ، وَلَیْسَ فِی النَّیِّفِ شَیْئٌ.",,,10038,,
10039,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا ، قُلْتُ : إِنْ کَانَتْ خَمْسِینَ بَقَرَۃً ؟ فَقَالَ الْحَکَمُ : فِیہَا مُسِنَّۃٌ ، وَقَالَ حَمَّادٌ : بِحِسَابِ ذَلِکَ.",,,10039,,
10040,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ حَجَّاجٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : صَاحِبُ الْبَقَرِ بِمَا فَوْقَ الْفَرِیضَۃِ.",,,10040,,
10041,"حَدَّثَنَا زَیْدُ بْنُ حَبَّابٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنِ الْعَلاَئِ بْنِ الْحَارِثِ ، عَنْ مَکْحُولٍ ، قَالَ : مَا زَادَ فَبِالْحِسَابِ.",,,10041,,
10042,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی أَبُو بَکْرِ بْنُ عَبْدِ اللہِ ، عَنِ ابْنِ شِہَابٍ ، قَالَ : لَیْسَ فِی الْفُضُولِ شَیْئٌ إِلاَّ أَنْ یَکُونَ تَأْلِیفٌ.",,,10042,,
10043,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : التَّبِیعُ : الَّذِی قَدِ اسْتَوَی قَرْنَاہُ وَأُذُنَاہُ ، وَالْمُسِنُّ : الثَّنِیُّ فَصَاعِدًا.",,,10043,,
10044,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ الْحَذَّائِ ، قَالَ : قُلْتُ لأَبِی قِلاَبَۃَ : کَمِ السَّائِمَۃُ ؟ قَالَ : مِئَۃ.",,,10044,,
10045,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَیْسَ فِی شَیْئٍ مِنَ السَّوَائِمِ صَدَقَۃٌ ، إِلاَّ إنَاثِ الإِبِلِ ، وَإِنَاثِ الْبَقَرِ وَالْغَنَمِ.",,,10045,,
10046,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : لَیْسَ فِی الْبَقَرِ الْعَوَامِلِ صَدَقَۃٌ.",,,10046,,
10047,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ لَیْثٍ، عَنْ طَاوُوسٍ، عَنْ مُعَاذٍ؛ أَنَّہُ کَانَ لاَ یَأْخُذُ مِنَ الْبَقَرِ الْعَوَامِلِ صَدَقَۃً.,,,10047,,
10048,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، وَمُجَاہِدٍ ، قَالاَ : لَیْسَ فِی الْبَقَرِ الْعَوَامِلِ صَدَقَۃٌ.",,,10048,,
10049,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ، عَنْ حَجَّاجٍ، عَنِ الْحَکَمِ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ، قَالَ: لَیْسَ فِی الْبَقَرِ الْعَوَامِلِ صَدَقَۃٌ.",,,10049,,
10050,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لَیْسَ عَلَی جَمَلٍ ظَعِینَۃٍ ، وَلاَ عَلَی ثَوْرٍ عَامِلٍ صَدَقَۃٌ.",,,10050,,
10051,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : لَیْسَ فِی عَوَامِلِ الْبَقَرِ شَیْئٌ ، إِلاَّ مَا کَانَ سَائِمًا ، وَذَلِکَ فِی الإِبِلِ.",,,10051,,
10052,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ شَہْرٍ ، قَالَ : لَیْسَ فِی الْبَقَرِ الْعَوَامِلِ صَدَقَۃٌ.",,,10052,,
10053,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ فِی الْبَقَرِ الْعَوَامِلِ صَدَقَۃٌ",,,10053,,
10054,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : لَیْسَ عَلَی الْبَقَرِ الْعَوَامِلِ ، وَلاَ عَلَی الإِبِلِ الَّتِی یُسْتَقَی عَلَیْہَا النَّوَاضِحِ ، وَیُغْزَی عَلَیْہَا فِی سَبِیلِ اللہِ صَدَقَۃٌ.",,,10054,,
10055,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی زِیَادٌ ، أَنَّ أَبَا الزُّبَیْرِ أَخْبَرَہُ ، عَنْ جَابِرٍ ، قَالَ : لاَ صَدَقَۃَ فِی الْمُثِیرَۃِ.",,,10055,,
10056,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : الْحَمُولَۃُ وَالْمُثِیرَۃُ فِیہَا الصَّدَقَۃ ؟ قَالَ : لاَ ، وَقَالَ عَمْرُو بْنُ دِینَارٍ : سَمِعْنَا ذَلِکَ.",,,10056,,
10057,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَتَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کِتَابَ الصَّدَقَۃِ فَقَرَنَہُ بِسَیْفِہِ ، أَوَ قَالَ : بِوَصِیَّتِہِ وَلَمْ یُخْرِجْہُ إلَی عُمَّالِہِ حَتَّی قُبِضَ ، عمِلَ بِہِ أَبُو بَکْرٍ حَتَّی ہَلَکَ ، وَعَمِلَ بِہِ عُمَرُ : فِی صَدَقَۃِ الْغَنَمِ فِی کُلِّ أَرْبَعِینَ شَاۃً شَاۃٌ إلَی عِشْرِینَ وَمِئَۃٍ ، فَإِنْ زَادَتْ فَشَاتَانِ إلَی مِئَتَیْنِ ، فَإِنْ زَادَتْ فَثَلاَثٌ إلَی ثَلاَثِ مِئَۃٍ ، فَإِنْ زَادَتْ فَفِی کُلِّ مِئَۃِ شَاۃٍ شَاۃٌ ، لَیْسَ فِیہَا شَیْئٌ حَتَّی تَبْلُغَ الْمِئَۃَ ، وَلاَ یُفَرَّقُ بَیْنَ مُجْتَمِعٍ ، وَلاَ یُجْمَعُ بَیْنَ مُفْتَرِقٍ ، وَمَا کَانَ مِنْ خَلِیطَیْنِ ، فَإِنَّہُمَا یَتَرَاجَعَانِ بِالسَّوِیَّۃِ.",,,10057,,
10058,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : فِی کُلِّ أَرْبَعِینَ شَاۃً شَاۃٌ إلَی عِشْرِینَ وَمِئَۃٍ ، فَإِنْ زَادَتْ فَفِیہَا شَاتَانِ إلَی مِئَتَیْنِ ، فَإِنْ زَادَتْ فَفِیہَا ثَلاَثُ شِیَاہٍ إلَی ثَلاَثِ مِئَۃٍ ، فَإِنْ کَثُرَتِ الْغَنَمُ فَفِی کُلِّ مِئَۃِ شَاۃٍ شَاۃٌ.",,,10058,,
10059,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: فِی کُلِّ أَرْبَعِینَ شَاۃً شَاۃٌ إلَی عِشْرِینَ وَمِئَۃٍ، فَإِذَا زَادَتْ وَاحِدَۃً فَفِیہَا شَاتَانِ إلَی مِئَتَیْنِ ، فَإِنْ زَادَتْ شَاۃً وَاحِدَۃً فَفِیہَا ثَلاَثُ شِیَاہٍ إلَی ثَلاَثِ مِئَۃٍ فِی کُلِّ مِئَۃ شَاۃٍ شَاۃٌ.",,,10059,,
10060,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إلَی أَرْبَعِ مِئَۃٍ ، فَإِنْ زَادَتْ وَاحِدَۃً فَإِلَی خَمْسِ مِئَۃٍ ، ثُمَّ عَلَی ہَذَا الْحِسَابِ.",,,10060,,
10061,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : فِی أَرْبَعِینَ شَاۃً شَاۃٌ إلَی عِشْرِینَ وَمِئَۃٍ ، فَإِذَا جَاوَزَتِ الْعِشْرِینَ وَمِئَۃ فَشَاتَانِ حَتَّی تَبْلُغَ الْمِئَتَیْنِ، وَإِذَا جَاوَزَ الْمِئَتَیْنِ فَثَلاَثُ شِیَاہٍ حَتَّی تَبْلُغَ الثَّلاَثَ مِئَۃ.",,,10061,,
10062,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنْ عَامِرٍ ، عَنْ عَلِیٍّ ، فِی صَدَقَۃِ الْغَنَمِ ، قَالَ: إذَا بَلَغَتْ أَرْبَعِینَ فَفِیہَا شَاۃٌ إلَی عِشْرِینَ وَمِئَۃٍ ، فَإِذَا زَادَتْ وَاحِدَۃً فَفِیہَا شَاتَانِ إلَی مِئَتَیْنِ ، فَإِذَا زَادَتْ وَاحِدَۃً فَفِیہَا ثَلاَثُ شِیَاہٍ إلَی ثَلاَثِ مِئَۃٍ ، فَإِذَا زَادَتْ عَلَی ثَلاَثِ مِئَۃٍ وَکَثُرَتْ فَفِی کُلِّ مِئَۃِ شَاۃٍ شَاۃٌ ، وَقَالَ عَبْدُ اللہِ مِثْلَ قَوْلِ عَلِیٍّ حَتَّی تَبْلُغَ ثَلاَثَ مِئَۃٍ ، ثُمَّ قَالَ عَبْدُ اللہِ : فَإِذَا زَادَتْ وَاحِدَۃً عَلَی ثَلاَثِ مِئَۃٍ فَفِیہَا أَرْبَعٌ إلَی أَرْبَعِ مِئَۃٍ ، ثُمَّ عَلَی ہَذَا الْحِسَابِ.\n\nقَالَ مُحَمَّدٌ : أَخْبَرَنَا عَامِرٌ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ، قَالاَ : لاَ یُجْمَعُ بَیْنَ مُفْتَرِقٍ ، وَلاَ یُفَرَّقُ بَیْنَ مُجْتَمِعٍ.",,,10062,,
10063,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إذَا بَلَغَتْ أَرْبَعِینَ فَفِیہَا شَاۃٌ حَتَّی تَبْلُغَ عِشْرِینَ وَمِئَۃ ، فَإِذَا زَادَتْ وَاحِدَۃً فَفِیہَا شَاتَانِ إلَی مِئَتَیْنِ ، فَإِذَا زَادَتْ وَاحِدَۃً فَفِیہَا ثَلاَثُ شِیَاہٍ إلَی ثَلاَثِ مِئَۃٍ ، فَإِذَا زَادَتْ فَفِی کُلِّ مِئَۃِ شَاۃٍ شَاۃٌ ، وَسَقَطَتِ الأَرْبَعُونَ.",,,10063,,
10064,"حُدِّثَنَا حَفْص ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ عُمَرَ کَانَ إذَا بَعَثَ الْمُصَدِّقَ بَعَثَ مَعَہُ بِکِتَابٍ : لَیْسَ فِی أَقَلَّ مِنْ أَرْبَعِینَ شَاۃٍ شَیْئٌ.",,,10064,,
10065,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : إِنْ لَمْ یَکُنْ لَکَ إِلاَّ تِسْعٌ وَثَلاَثُونَ شَاۃً ، فَلَیْسَ فِیہَا صَدَقَۃٌ.",,,10065,,
10066,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَیْسَ فِی أَقَلَّ مِنْ أَرْبَعِینَ شَیْئٌ.",,,10066,,
10067,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : کَانَ الْکِتَابُ الَّذِی کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ حِینَ بَعَثَہُمْ یُصَدِّقُونَ : لاَ صَدَقَۃَ فِی الْغَنَمِ حَتَّی تَبْلُغَ أَرْبَعِینَ.",,,10067,,
10068,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لَیْسَ فِیمَا دُونَ أَرْبَعِینَ مِنَ الشَّائِ صَدَقَۃٌ.",,,10068,,
10069,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ فِیمَا زَادَ عَلَی الثَّلاَثِ مِئَۃٍ شَیْئٌ حَتَّی تَبْلُغَ أَرْبَعَ مِئَۃٍ.",,,10069,,
10070,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَمْزَۃَ ، عَنِ الْحَکَمِ ، قَالَ : لَیْسَ فِیمَا زَادَ عَلَی ثَلاَثِ مِئَۃٍ شَیْئٌ ، حَتَّی تَبْلُغَ أَرْبَعَ مِئَۃٍ ، یَعْنِی الْغَنَمَ.",,,10070,,
10071,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، قَالَ : کَتَبَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کِتَابَ الصَّدَقَۃِ فَقَرَنَہُ بِسَیْفِہِ ، أَوَ قَالَ : بِوَصِیَّتِہِ فَلَمْ یُخْرِجْہُ إلَی عُمَّالِہِ حَتَّی قُبِضَ ، عَمِلَ بِہِ أَبُو بَکْرٍ حَتَّی ہَلَکَ ، ثُمَّ عَمِلَ بِہِ عُمَرُ ، قَالَ : فِی الْغَنَمِ فِی ثَلاَثِ مِئَۃِ شَاۃٍ ثَلاَثُ شِیَاہٍ ، فَإِنْ زَادَتْ فَفِی کُلِّ مِئَۃِ شَاۃٍ شَاۃٌ ، وَلَیْسَ فِیہَا شَیْئٌ حَتَّی تَبْلُغَ الْمِئَۃَ.",,,10071,,
10072,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إذَا زَادَتْ عَلَی الْمِائَتَیْنِ وَاحِدَۃً فَفِیہَا ثَلاَثُ شِیَاہٍ إلَی ثَلاَثِ مِئَۃٍ ، فَإِذَا زَادَتْ فَفِی کُلِّ مِئَۃِ شَاۃٍ شَاۃٌ ، وَسَقَطَتِ الأَرْبَعُونَ.",,,10072,,
10073,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا زَادَتْ عَلَی الثَّلاَثِ مِئَۃٍ فَفِی کُلِّ مِئَۃٍ شَاۃٌ.",,,10073,,
10074,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ رَجُلٍ ، عَنْ مُجَاہِدٍ ؛ فِی الرَّجُلِ تَکُونُ لَہُ أَرْبَعُونَ شَاۃً فِی الْمِصْرِ یَحْلِبُہَا ، قَالَ : لَیْسَ عَلَیْہِ صَدَقَۃٌ.",,,10074,,
10075,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَیْسَ فِی غَنَمِ الرَّبَائِبِ صَدَقَۃٌ.",,,10075,,
10076,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالاَ : لاَ یُعْتَدُّ بِالسَّخْلَۃِ ، وَلاَ تُؤْخَذُ فِی الصَّدَقَۃِ.",,,10076,,
10077,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، قَالَ: قُلْتُ لَہُ: أَیُعْتَدُّ بِالصِّغَارِ أَوْلاَدِ الشَّائِ؟ قَالَ: نَعَمْ.",,,10077,,
10078,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : یُعْتَدُّ بِالصَّغِیرِ حِینَ تُنْتِجُہُ أُمُّہُ.",,,10078,,
10079,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ بِشْرِ بْنِ عَاصِمٍ ، عَنْ أَبِیہِ ، عَنْ عُمَرَ ؛ اسْتَعْمَلَ أَبَاہُ عَلَی الطَّائِفِ وَمَخَالیفہا ، فَکَانَ یُصَدِّقُ فَاعْتَدَّ عَلَیْہِمْ بِالْغِذَائِ ، فَقَالَ لَہُ النَّاسُ : إِنْ کُنْت مُعْتَدًّا بِالْغِذَائِ فَخُذْ مِنْہُ ، فَأَمْسَکَ عَنْہُمْ حَتَّی لَقِیَ عُمَرَ ، فَأَخْبَرَہُ بِالَّذِی قَالُوا ، فَقَالَ : اعْتَدْ عَلَیْہِمْ بِالْغِذَائِ ، وَإِنْ جَائَ بِہَا الرَّاعِی یَحْمِلُہَا عَلَی یَدِہِ ، وَأَخْبِرْہُمْ أَنَّک تَدَعُ لَہُمَ الرُّبَّی وَالْمَاخِضَ وَالأَکِیلَۃَ وَفَحْلَ الْغَنَمِ ، وَخُذِ الْعَنَاقَ وَالْجَذَعَۃَ وَالثَّنِیَّۃَ ، فَذَلِکَ عَدْلٌ بَیْنَ خِیَارِ الْمَالِ وَالْغِذَائِ.",,,10079,,
10080,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنِ النَّہَّاسِ بْنِ قَہْمٍ، قَالَ: حدَّثَنَا الْحَسَنُ بْنُ مُسْلِمٍ، قَالَ: بَعَثَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُفْیَانَ بْنَ عَبْدِ اللہِ عَلَی الصَّدَقَۃِ ، فَقَالَ : خُذْ مَا بَیْنَ الْغَذِیَّۃِ ، وَالْہَرِمَۃِ ، یَعْنِی بِالْغَذِیَّۃِ السَّخْلَۃَ.",,,10080,,
10081,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ رَجُلٍ مِنْ ثَقِیفٍ ، قَالَ : سَأَلْتُ أَبَا ہُرَیْرَۃَ : فِی أَیِّ الْمَالِ صَدَقَۃٌ ؟ فَقَالَ : فِی الثُّلُثِ الأَوْسَطِ ، فَإِذَا أَتَاک الْمُصَدِّقُ فَأَخْرِجْ لَہُ الْجَذَعَۃَ وَالثَّنِیَّۃَ.",,,10081,,
10082,"حَدَّثَنَا عَبْدُ الرَّزَّاقِ ، عَنْ مَعْمَرٍ، عَنْ سِمَاکٍ ، عَنِ ابْنِ شِہَابٍ ، أَو شِہَابِ بْنِ مَالِکٍ ، عَنْ سَعِیدٍ الأَعْرَجِ، قَالَ: خَرَجْت أُرِیدُ الْجِہَادَ ، فَلَقِیتُ عُمَرَ بِمَکَّۃَ ، فَقَالَ: بإِذْنِ صَاحِبِکَ خَرَجتَ؟ یَعْنِی یَعْلَی بْنَ أُمَیَّۃَ، قَالَ: قُلْتُ : لاَ ، قَالَ : فَارْجِعْ إلَی صَاحِبِکَ ، فَإِذَا أَوْقَفَ الرَّجُلُ عَلَیْکُمْ غَنَمَہُ ، فَاصْدَعُوہَا صَدْعَیْنِ ، ثُمَّ اخْتَارُوا مِنَ النِّصْفِ الآخَرَ.",,,10082,,
10083,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَمِعْتُ أَبِی وَغَیْرَہُ یَذْکُرُونَ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ : أَنْ تُقَسَّمَ الْغَنَمُ أَثْلاَثًا ، ثُمَّ یَخْتَارُ سَیِّدُہَا ثُلُثًا ، وَیَأْخُذُ الْمُصَدِّقُ مِنَ الثُّلُثِ الأَوْسَطِ.",,,10083,,
10084,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنِ الْقَاسِمِ ، قَالَ : تُقْسَمُ الْغَنَمُ أَثْلاَثًا.",,,10084,,
10085,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إذَا جَائَ الْمُصَدِّقُ قُسِمَتِ الْغَنَمُ أَثْلاَثًا : ثُلُثٌ خِیَارٌ ، وَثُلُثٌ شِرَارٌ، وَثُلُثٌ أَوْسَاطٌ ، وَیَأْخُذُ الْمُصَدِّقُ مِنَ الْوَسَطِ.",,,10085,,
10086,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنِ الْحَکَمِ ، قَالَ : کَانَ الْمُصَدِّقُ یَصْدَعُ الْغَنَمَ صَدْعَیْنِ ، فَیَخْتَارُ صَاحِبُ الْغَنَمِ خَیْرَ الصَّدْعَیْنِ.",,,10086,,
10087,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : یَقْسِمُ الْغَنَمَ قِسْمَیْنِ ، فَیَخْتَارُ صَاحِبُ الْغَنَمِ خَیْرَ الْقِسْمَیْنِ ، وَیَخْتَارُ الْمُصَدِّقُ مِنَ الْقَسَمِ الأَخرَ.",,,10087,,
10088,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَجْمَعُ الشَّائَ فَیَأْخُذُ صَاحِبُ الْغَنَمِ الثُّلُثَ مِنْ خِیَارِہِ ، وَیَأْخُذُ صَاحِبُ الصَّدَقَۃِ مِنَ الثُّلُثَیْنِ حَقَّہُ.",,,10088,,
10089,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : تُفَرَّقُ فِرْقَتَیْنِ.",,,10089,,
10090,حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ؛ نَحْوَہُ.,,,10090,,
10091,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَتَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کِتَابَ الصَّدَقَۃِ فَقَرَنَہُ بِسَیْفِہِ ، أَوَ قَالَ : بِوَصِیَّتِہِ ثُمَّ لَمْ یُخْرِجْہُ إلَی عُمَّالِہِ حَتَّی قُبِضَ ، فَلَمَّا قُبِضَ عَمِلَ بِہِ أَبُو بَکْرٍ حَتَّی ہَلَکَ ، ثُمَّ عَمِلَ بِہِ عُمَرُ : لاَ یُؤْخَذُ فِی الصَّدَقَۃِ ہَرِمَۃٌ ، وَلاَ ذَاتُ عَوَارٍ.",,,10091,,
10092,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : لاَ یَأْخُذُ الْمُصَدِّقُ ہَرِمَۃً ، وَلاَ ذَاتَ عَوَارٍ ، وَلاَ تَیْسًا إِلاَّ أَنْ یَشَائَ الْمُصَدِّقُ.",,,10092,,
10093,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ خُصَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : لَیْسَ لِلْمُصَدِّقِ ہَرِمَۃٌ ، وَلاَ ذَاتُ عَوَارٍ ، وَلاَ جَدَّائَ.",,,10093,,
10094,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَیْسَ لِلْمُصَدِّقِ ہَرِمَۃٌ ، وَلاَ ذَاتُ عَوَارٍ ، وَلاَ جَدَّائُ إِلاَّ أَنْ یَشَائَ الْمُصَدِّقُ.",,,10094,,
10095,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، قَالَ : سَمِعْتُ سُلَیْمَانَ بْنَ یَسَارٍ ، قَالَ : لاَ یُجْزِء فِی الصَّدَقَۃِ ذَاتُ عَوَارٍ.",,,10095,,
10096,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ مَیْمُونٍ ، قَالَ : لاَ یُؤْخَذُ فِی الصَّدَقَۃِ الْعَجْفَائُ ، وَلاَ الْعَوْرَائُ ، وَلاَ الْجَرْبَائُ ، وَلاَ الْعَرْجَائُ الَّتِی لاَ تَتْبَعُ الْغَنَمَ.",,,10096,,
10097,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَمْرِو بْنِ یَحْیَی بن عُمَارَۃَ ، أَنَّ أَبَاہُ یَحْیَی بْنَ عُمَارَۃَ أَخْبَرَہُ ، أَنَّ أَبَا سَعِیدٍ کَانَ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ فِیمَا دُونَ خَمْسَۃِ أَوْسُقٍ صَدَقَۃٌ.",,,10097,,
10098,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، عَنْ یَحْیَی بْنِ عُمَارَۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ فِی أَقَلَّ مِنْ خَمْسَۃِ أَوْسَاقٍ تَمْرٍ، وَلاَ حَبٍّ صَدَقَۃٌ. (مسلم 674۔ احمد 3/97)",,,10098,,
10099,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَمْرِو بْنِ یَحْیَی ، عَنْ أَبِیہِ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ فِیمَا دُونَ خَمْسَۃِ أَوْسَاقٍ صَدَقَۃٌ.",,,10099,,
10100,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ (ح) وَعَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لَیْسَ فِیمَا دُونَ خَمْسَۃِ أَوْسَاقٍ صَدَقَۃٌ. (عبدالرزاق 7251۔ احمد 3/296)",,,10100,,
10101,"حَدَّثَنَا حَفْصٌ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا بَلَغَ الطَّعَامُ خَمْسَۃَ أَوْسُقٍ فَفِیہِ الصَّدَقَۃُ.",,,10101,,
10102,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ فِیمَا دُونَ خَمْسَۃِ أَوْسَاقٍ صَدَقَۃٌ.",,,10102,,
10103,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالاَ : لاَ تَجِبُ الصَّدَقَۃُ حَتَّی تَبْلُغَ ثَلاَثَ مِئَۃِ صَاعٍ.",,,10103,,
10104,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لَیْسَ فِی أَقَلَّ مِنْ خَمْسَۃِ أَوْسُقٍ شَیْئٌ.",,,10104,,
10105,"حَدَّثَنَا شَرِیکٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِی الْبَخْتَرِیِّ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : الْوَسْقُ سِتُّونَ صَاعًا.",,,10105,,
10106,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ (ح) وَمُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالاَ : الْوَسْقُ سِتُّونَ صَاعًا.",,,10106,,
10107,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الْوَسْقُ سِتُّونَ صَاعًا.",,,10107,,
10108,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : الْوَسْقُ سِتُّونَ صَاعًا.",,,10108,,
10109,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنِ الْحَسَنِ (ح) وَمُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قاَلَ : الْوَسْقُ سِتُّونَ صَاعًا.",,,10109,,
10110,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ قَالاَ : الْوَسْقُ سِتُّونَ صَاعًا.",,,10110,,
10111,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَر ، عَنْ أَشْعَثَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ (ح) وَعَنْ أَبِی الزُّبَیْرِ، عَنْ جَابِرٍ ، قَالاَ: الْوَسْقُ سِتُّونَ صَاعًا.",,,10111,,
10112,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : الْوَسْقُ سِتُّونَ صَاعًا.",,,10112,,
10113,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : الْوَسْقُ سِتُّونَ صَاعًا.",,,10113,,
10114,"حَدَّثَنَا رَوَّادُ بْنُ جَرَّاحٍ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ، قَالَ : الْوَسْقُ سِتُّونَ صَاعًا.",,,10114,,
10115,"حَدَّثَنَا بَعض أَصْحَابِنَا ، عَنِ ابْنِ الْمُبَارَکِ، عَنْ یَعْقُوبَ، عَنْ عَطَائٍ ، وَعَنْ قَتَادَۃ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، قَالَ: الْوَسْقُ سِتُّونَ صَاعًا.",,,10115,,
10116,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْعُشْرُ فِی التَّمْرِ وَالزَّبِیبِ ، وَالْحِنْطَۃِ وَالشَّعِیرِ. (دارقطنی )",,,10116,,
10117,حَدَّثَنَا وَکِیعٌ ، عَنْ عَمْرِو بْنِ عُثْمَانَ ، عَنْ مُوسَی بْنِ طَلْحَۃَ ؛ أَنَّ مُعَاذًا لَمَّا قَدِمَ الْیَمَنَ لَمْ یَأْخُذِ الزَّکَاۃَ إِلاَّ مِنَ الْحِنْطَۃِ ، وَالشَّعِیرِ ، وَالتَّمْرِ ، وَالزَّبِیبِ. (احمد 5/228۔ دارقطنی 8),,,10117,,
10118,حَدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِی مُوسَی الأَشْعَرِیِّ ؛ أَنَّہُ لَمْ یَأْخُذْہَا إِلاَّ مِنَ الْحِنْطَۃِ ، وَالشَّعِیرِ ، وَالتَّمْرِ ، وَالزَّبِیبِ.,,,10118,,
10119,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : الصَّدَقَۃُ مِنْ أَرْبَعٍ : مِنَ الْبُرِّ ، فَإِنْ لَمْ یَکُنْ بُرٌّ فَتَمْرٌ ، فَإِنْ لَمْ یَکُنْ تَمْرٌ فَزَبِیبٌ ، فَإِنْ لَمْ یَکُنْ زَبِیبٌ فَشَعِیرٌ.",,,10119,,
10120,"حَدَّثَنَا وَکِیعٌ ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، قَالَ : سَأَلَ عَبْدُ الْحَمِیدِ مُوسَی بْنَ طَلْحَۃَ عَنْہَا ؟ فَقَالَ : إنَّمَا الصَّدَقَۃُ فِی الْحِنْطَۃِ ، وَالشَّعِیرِ ، وَالتَّمْرِ ، وَالزَّبِیبِ.",,,10120,,
10121,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ لِی عَطَائٌ : لاَ صَدَقَۃَ إِلاَّ فِی نَخْلٍ ، أَوْ عِنَبٍ، أَوْ حَبٍّ، وَقَالَ لِی ذَلِکَ عَمْرُو بْنُ دِینَارٍ.",,,10121,,
10122,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : الزَّکَاۃُ فِی الْبُرِّ ، وَالشَّعِیرِ ، وَالتَّمْرِ ، وَالزَّبِیبِ.",,,10122,,
10123,"حَدَّثَنَا مُعَمَّرُ بْنُ سُلَیْمَانَ الرَّقِّیُّ ، عَنْ خُصَیْفٍ ، عَنْ مُجَاہِدٍ ، قَالَ : فِیمَا أَخْرَجَتِ الأَرْضُ فِیمَا قَلَّ مِنْہُ ، أَوْ کَثُرَ الْعُشْرُ ، أَوْ نِصْفُ الْعُشْرِ.",,,10123,,
10124,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، قَالَ : فِی کُلِّ شَیْئٍ أَخْرَجَتِ الأَرْضُ الْعُشْرُ ، أَوْ نِصْفُ الْعُشْرِ.",,,10124,,
10125,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی حَنِیفَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : فِی کُلِّ شَیْئٍ أَخْرَجَتِ الأَرْضُ زَکَاۃٌ ، حَتَّی فِی عَشْرِ دَسْتَجَات ِدَسْتَجَۃ بَقْلٍ.",,,10125,,
10126,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، أَنَّہُ کَانَ لاَ یُوَقِّتُ فِی الثَّمَرَۃِ شَیْئًا ، وَقَالَ : الْعُشْرُ وَنِصْفُ الْعُشْرِ.",,,10126,,
10127,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنْ رَجُلٍ ، عَنْ مُجَاہِدٍ ؛ مِثْلَہُ.,,,10127,,
10128,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، قَالَ : کَتَبَ بِذَلِکَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ إلَی أَہْلِ الْیَمَنِ.",,,10128,,
10129,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : فِی کُلِّ شَیْئٍ أَخْرَجَتِ الأَرْضُ زَکَاۃٌ.",,,10129,,
10130,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : فِی الْخَضِرَاوَاتِ زَکَاۃٌ.",,,10130,,
10131,"حَدَّثَنَا وَکِیعٌ، عَنْ قَیْسٍ، عَنْ أَبِی إِسْحَاقَ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ، عَنْ عَلِیٍّ، قَالَ: لَیْسَ فِی الْخَضِرِ شَیْئٌ.",,,10131,,
10132,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنْ مُجَالِدٍ، عَنِ الشَّعْبِیِّ، قَالَ: لَیْسَ فِی الْبُقُولِ؛ الْخِیَارِ، وَالْقِثَّائِ، وَنَحْوِہِ صَدَقَۃٌ.",,,10132,,
10133,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَجْلَحِ ، عَنْ عَامِرٍ ، قَالَ : لَیْسَ فِی غَلَّۃِ الصَّیْفِ صَدَقَۃٌ.",,,10133,,
10134,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : لَیْسَ فِی الْخَضِرِ زَکَاۃٌ ، إِلاَّ أَنْ یَصِیرَ مَالاً ، فَیَکُونَ فِیہِ زَکَاۃٌ.",,,10134,,
10135,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، قَالَ : سَمِعْتُ مُجَاہِدًا ، وَإِبْرَاہِیمَ جَالِسٌ یَقُولُ : لَیْسَ فِی الْبُقُولِ ، وَلاَ فِی التُّفَّاحِ ، وَلاَ فِی الْخَضِرِ زَکَاۃٌ.",,,10135,,
10136,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : لَیْسَ فِی الْخَضِرَاوَاتِ صَدَقَۃٌ.",,,10136,,
10137,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حُصَیْنٍ ، عَنْ مُطَرِّفٍ ، قَالَ : سَأَلْتُ الْحَکَمَ عَنِ الْفَصَافِصِ ، وَالأَقْطَانِ ، وَالسَّمَاسِمِ ؟ فَقَالَ : لَیْسَ فِیہَا شَیْئٌ . قَالَ الْحَکَمُ : فِیمَا حَفِظْنَا عَنْ أَصْحَابِنَا أَنَّہُمْ کَانُوا یَقُولُونَ : لَیْسَ فِی شَیْئٍ مِنْ ہَذَا شَیْئٌ ، إِلاَّ فِی الْحِنْطَۃِ ، وَالشَّعِیرِ ، وَالتَّمْرِ ، وَالزَّبِیبِ.",,,10137,,
10138,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، قَالَ : لَیْسَ فِی الْفَاکِہَۃِ عُشُورٌ ؛الْجَوْزُ ، وَاللَّوْزُ ، وَالْبُقُولُ کُلُّہَا ، وَالْخَضِرُ ، وَلَکِنْ مَا بِیعَ مِنْہُ فَبَلَغَ مِئَتَیْ دِرْہَمٍ فَصَاعِدًا ، فَفِیہِ الزَّکَاۃُ.",,,10138,,
10139,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، قَالَ: قَالَ عَطَائٌ: لَیْسَ فِی الْبُقُولِ، وَالْقَصَبِ، وَالْخِرْبَزِ، وَالْقِثَّائِ، وَالْکُرْسُفِ ، وَالْفَوَاکِہِ ، وَالأُتْرُجِّ ، وَالتُّفَّاحِ ، وَالتِّینِ ، وَالرُّمَّانِ ، وَالْفَرْسَکِ ، وَالْفَاکِہَۃِ تُعَدُّ کُلُّہَا صَدَقَۃٌ.",,,10139,,
10140,"حَدَّثَنَا عَبْدُ الصَّمَدِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ الْحَکَمِ ، عَنْ أَبِی الْعَلاَئِ بْنِ الشِّخِّیرِ ، قَالَ : لَیْسَ فِی الأَعْلاَفِ ، وَلاَ فِی الْبُقُولِ صَدَقَۃٌ.",,,10140,,
10141,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الزَّیْتُونِ ، قَالَ : ہُوَ یُکَالُ فِیہِ الْعُشْرُ.",,,10141,,
10142,"حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ عِمْرَانَ الْقَطَّانِ، عَنْ لَیْثٍ، عَنْ طَاوُوسٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: فِی الزَّیْتُونِ الْعُشْرُ",,,10142,,
10143,"حَدَّثَنَا زَیْدُ بْنُ حَبَّابٍ ، عَنْ رَجَائِ بْنِ أَبِی سَلَمَۃَ ، قَالَ : سَأَلْتُ یَزِیدَ بْنَ یَزِیدَ بْنِ جَابِرٍ عَنِ الزَّیْتُونِ ؟ فَقَالَ : عَشَّرَہُ عُمَرُ بْنُ الْخَطَّابِ بِالشَّامِ.",,,10143,,
10144,"حَدَّثَنَا زَیْدُ بْنُ حَبَّابٍ ، عَنْ رَجَائٍ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، قَالَ : فِیہِ الْعُشْرُ.",,,10144,,
10145,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، عَنْ أَبِی سَیَّارَۃَ ، قَالَ : قُلْتُ : یَا رَسُولَ اللہِ ، إنَّ لِی نَحْلاً ، قَالَ : أَدِّیَنَّ الْعُشْرُ ؟ قُلْتُ : یَا رَسُولَ اللہِ ، احْمِہَا لِی ، قَالَ : فَحَمَاہَا لِی. (احمد 236۔ ابن ماجہ 1823)",,,10145,,
10146,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ؛ أَنَّ أَمِیرَ الطَّائِفِ کَتَبَ إلَی عُمَرَ بْنِ الْخَطَّابِ : إِنَّ أَہْلَ الْعَسَلِ مَنَعُونَا مَا کَانُوا یُعْطُونَ مَنْ کَانَ قَبْلَنَا ، قَالَ : فَکَتَبَ إلَیْہِ إِنْ أَعْطَوْک مَا کَانُوا یُعْطُونَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَاحْمِ لَہُمْ ، وَإِلاَّ فَلاَ تَحْمِہَا لَہُمْ ، قَالَ : وَزَعَمَ عَمْرُو بْنُ شُعَیْبٍ أَنَّہُمْ کَانُوا یُعْطُونَ مِنْ کُلِّ عَشْرِ قِرَبٍ قِرْبَۃً. (ابوداؤد 1597)",,,10146,,
10147,"حَدَّثَنَا ابْنُ الْمُبَارَکِ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، عَنْ عُمَرَ ، قَالَ : فِی الْعَسَلِ عُشْرٌ.",,,10147,,
10148,"حَدَّثَنَا صَفْوَانُ بْنُ عِیسَی ، عَنِ الْحَارِثِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ مُنِیرِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِیہِ ، عَنْ سَعْدِ بْنِ أَبِی ذُبَابٍ ؛ أَنَّہُ قَدِمَ عَلَی قَوْمِہِ فَقَالَ لَہُم : فِی الْعَسَلِ زَکَاۃٌ ، فَإِنَّہُ لاَ خَیْرَ فِی مَالٍ لاَ یُزَکَّی ، قَالَ : قَالُوا : فَکَمْ تَرَی ؟ قُلْتُ : الْعُشْرُ ، قَالَ : فَأَخَذَ مِنْہُمَ الْعُشْرَ ، فَقَدِمَ بِہِ عَلَی عُمَرَ وَأَخْبَرَہُ بِمَا فِیہِ ، قَالَ : فَأَخَذَہُ عُمَرُ وَجَعَلَہُ فِی صَدَقَاتِ الْمُسْلِمِینَ.",,,10148,,
10149,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : فِی الْعَسَلِ الْعُشْرُ.",,,10149,,
10150,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ؛ أَنَّ مُعَاذًا لَمَّا أَتَی الْیَمَنَ أُتَیَ بِالْعَسَلِ وَأَوْقَاصِ الْغَنَمِ ، فَقَالَ : لَمْ أُومَر فِیہَا بِشَیْئٍ. (عبدالرزاق 6964۔ بیہقی 128)",,,10150,,
10151,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، قَالَ : بَعَثَنِی عُمَرُ بْنُ عَبْدِ الْعَزِیزِ عَلَی الْیَمَنِ ، فَأَرَدْت أَنْ آخُذَ مِنَ الْعَسَلِ الْعُشْرَ ، قَالَ مُغِیرَۃُ بْنُ حَکِیمٍ الصَّنْعَانِیُّ : لَیْسَ فِیہِ شَیْئٌ ، فَکَتَبْتُ إلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَقَالَ : صَدَقَ ، وَہُوَ عَدْلٌ رضا.",,,10151,,
10152,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، قَالَ : سَأَلَنِی عُمَرُ بْنُ عَبْدِ الْعَزِیزِ عَنْ صَدَقَۃِ الْعَسَلِ ؟ فَقُلْتُ : أَخْبَرَنِی الْمُغِیرَۃُ بْنُ حَکِیمٍ ، أَنَّہُ لَیْسَ فِیہِ صَدَقَۃٌ ، فَقَالَ عُمَرُ : عَدْلٌ مُصَدَّقٌ.",,,10152,,
10153,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ أُذَیْنَۃَ ، سَمِعَ ابْنَ عَبَّاسٍ ، قَالَ : لَیْسَ الْعَنْبَرُ بِرِکَازٍ ، وَإِنَّمَا ہُوَ شَیْئٌ دَسَرَہُ الْبَحْرُ ، لَیْسَ فِیہِ شَیْئٌ.",,,10153,,
10154,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ الثَّوْرِیِّ ، عَنْ عَمْرٍو ، عَنْ أُذَیْنَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَیْسَ فِی الْعَنْبَرِ زَکَاۃٌ ، إنَّمَا ہُوَ شَیْئٌ دَسَرَہُ الْبَحْرُ.",,,10154,,
10155,"حَدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ إسْمَاعِیلَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لَیْسَ فِی الَعَنَبَرِ زَکَاۃٌ ، إنَّمَا ہُوَ غَنِیمَۃٌ لِمَنْ أَخَذَہُ.",,,10155,,
10156,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مَعْمَرٍ ؛ أَنَّ عُرْوَۃَ بْنَ مُحَمَّدٍ کَتَبَ إلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فِی عَنْبَرَۃٍ فِیہَا سَبْعُمِئَۃِ رِطْلٍ ، قَالَ : فِیہَا الْخُمُسُ.",,,10156,,
10157,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ خَمَّسَ الْعَنْبَرَ.,,,10157,,
10158,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَقُولُ : فِی الْعَنْبَرِ الْخُمُسُ ، وَکَذَلِکَ کَانَ یَقُولُ فِی اللُّؤْلُؤِ.",,,10158,,
10159,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : سَأَلَ إبْرَاہِیمُ بْنُ سَعْدٍ ابْنَ عَبَّاسٍ عَنِ الْعَنْبَرِ ؟ فَقَالَ : إِنْ کَانَ فِیہِ شَیْئٌ ، فَفِیہِ الْخُمُسُ.",,,10159,,
10160,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ الثَّوْرِیِّ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ أَنَّ ابْنَ عَبَّاسٍ سُئِلَ عَنِ الْعَنْبَرِ ؟ فَقَالَ : إِنْ کَانَ فِیہِ شَیْئٌ ، فَفِیہِ الْخُمُسُ.",,,10160,,
10161,"حَدَّثَنَا وَکِیعٌ ، قَالَ : کَانَ سُفْیَانُ یَقُولُ : لَیْسَ فِی الْعَنْبَرِ ، وَلاَ فِی الْعَسَلِ ، وَلاَ فِی الأَوْقَاصِ زَکَاۃٌ.",,,10161,,
10162,"حَدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ خُصَیْفٍ، عَنْ عِکْرِمَۃَ ، قَالَ: لَیْسَ فِی حَجَرِ اللُّؤْلُؤِ ، وَلاَ حَجَرِ الزُّمُرُّدِ زَکَاۃٌ، إِلاَّ أَنْ یَکُونَا لِتِجَارَۃٍ ، فَإِنْ کَانَا لِتِجَارَۃٍ فَفِیہِمَا زَکَاۃٌ.",,,10162,,
10163,"حَدَّثَنَا شَرِیکٌ، عَنْ سَالِمٍ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، قَالَ: لَیْسَ فِی الْخَرَزِ وَاللُّؤْلُؤِ زَکَاۃٌ، إِلاَّ أَنْ یَکُونَا لِتِجَارَۃٍ.",,,10163,,
10164,حَدَّثَنَا شَرِیکٌ ، عَنْ خُصَیْفٍ ، عَنْ عِکْرِمَۃَ ؛ مِثْلَہُ.,,,10164,,
10165,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لَیْسَ فِی الْخَرَزِ وَاللُّؤْلُؤِ زَکَاۃٌ ، إِلاَّ أَنْ یَکُونَ لِتِجَارَۃٍ.",,,10165,,
10166,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، وَالزُّہْرِیِّ ، وَمَکْحُولٍ ، قَالُوا : لَیْسَ فِی الْجَوْہَرِ شَیْئٌ ، إِلاَّ أَنْ یَکُونَ لِتِجَارَۃٍ.",,,10166,,
10167,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ أَنَّہُ کَانَ لاَ یَرَی فِی الْحُلِیِّ زَکَاۃً ، إِلاَّ فِی الذَّہَبِ وَالْفِضَّۃِ ، وَلاَ یَرَاہُ فِی الْجَوْہَرِ ، وَاللُّؤْلُؤِ وَہَذَا النَّحْوِ.,,,10167,,
10168,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ طَلْحَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کُلُّ شَیْئٍ أُرِیدَ بِہِ التِّجَارَۃُ فَفِیہِ الزَّکَاۃُ ، وَإِنْ کَانَ لَبَنٌ ، أَوْ طِینٌ . قَالَ : وَکَانَ الْحَکَمُ یَرَی ذَلِکَ.",,,10168,,
10169,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ حَمَّادٍ ، قَالَ : لَیْسَ فِی الْجَوْہَرِ زَکَاۃٌ ، إِلاَّ أَنْ یُشْتَرَی لِتِجَارَۃٍ.",,,10169,,
10170,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْر ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ لِی عَطَائٌ : لاَ صَدَقَۃَ فِی لُؤْلُؤٍ ، وَلاَ زَبَرْجَدٍ ، وَلاَ یَاقُوتٍ ، وَلاَ فُصُوصٍ ، وَلاَ عَرْضٍ ، وَلاَ شَیْئٍ لاَ یُدَارُ ، وَإِنْ کَانَ شَیْئٌ مِنْ ذَلِکَ یُدَارُ فَفِیہِ الصَّدَقَۃُ ، فِی ثَمَنِہِ حِینَ یُبَاعُ.",,,10170,,
10171,"حَدَّثَنَا جَعْفَرُ بْنُ عَوْنٍ ، عَنْ أُسَامَۃَ ، قَالَ : سَأَلْتُ الْقَاسِمَ عَنِ اللُّؤْلُؤِ : ہَلْ فِیہِ زَکَاۃٌ ؟ فَقَالَ : مَا کَانَ مِنْہُ یُلْبَسُ کَالْحُلِیِّ لَیْسَ لِتِجَارَۃٍ ، فَلاَ زَکَاۃَ فِیہِ ، وَمَا کَانَ مِنْ ذَلِکَ لِلتِّجَارَۃِ فَفِیہِ الزَّکَاۃُ.",,,10171,,
10172,حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ أَبِی الْمَلِیحِ ، فِی حَدِیثٍ ذَکَرَہُ ؛ کَأَنَّہُ یَرَی فِیہِ الزَّکَاۃَ ، یَعْنِی اللُّؤْلُؤَ.,,,10172,,
10173,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ، عَنْ أَبِیہِ، عَنْ جَدِّہِ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَا سُقِیَ سَیْحًا فَفِیہِ الْعُشْرُ ، وَمَا سُقِیَ بِالْغُرْبِ فَفِیہِ نِصْفُ الْعُشْرِ. (دارقطنی 7)",,,10173,,
10174,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَتَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی الْیَمَنِ : یُؤْخَذُ مِمَّا سَقَتِ السَّمَائُ ، وَسُقِیَ بِالْغَیْلِ مِنَ الْحِنْطَۃِ ، وَالشَّعِیرِ ، وَالتَّمْرِ ، وَالزَّبِیبِ الْعُشْرُ ، وَمَا سُقِیَ بِالسَّوَانِی نِصْفُ الْعُشْرِ.",,,10174,,
10175,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، قَالَ : کَتَبَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی مُعَاذٍ بِالْیَمَنِ ، إِنَّ فِیمَا سَقَتِ السَّمَائُ ، أَوْ سُقِیَ غَیْلاً الْعُشْرَ ، وَفِیمَا سُقِیَ بِالْغُرْبِ وَالدَّالِیَۃِ نِصْفَ الْعُشْرِ.",,,10175,,
10176,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہَمَّامٍ ، عَنْ قَتَادَۃَ ، عَنْ صَالِحٍ أَبِی الْخَلِیلِ ، قَالَ : سَنَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِیمَا سَقَت السَّمَائُ ، أَوِ الْعَیْنُ السَّائِحَۃُ وَمَائُ الْغَیْلِ ، أَوْ کَانَ بَعْلاً الْعُشْرُ کَامِلاً ، وَمَا سُقِیَ بِالرِّشَائِ فَنِصْفُ الْعُشْرِ.",,,10176,,
10177,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : فِیمَا سقَت السَّمَائُ ، أَوْ کَانَ سَیْحًا الْعُشْرُ ، وَمَا سُقِیَ بِالدَّالِیَۃِ فَنِصْفُ الْعُشْرِ.",,,10177,,
10178,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، قَالَ : سَنَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِیمَا سَقَت السَّمَائُ ، أَوْ سَقَی الْغَیْلُ ، وَکَانَ بَعْلاً الْعُشْرُ کَامِلاً ، وَمَا سُقِیَ بِالرِّشَائِ فَنِصْفُ الْعُشْرِ . قَالَ : وَقَالَ قَتَادَۃُ : وَکَانَ یُقَالُ : فِیمَا یُکَالُ مِنَ الثَّمَرَۃِ الْعُشْرُ ، وَنِصْفُ الْعُشْرِ. (مسلم 1571)",,,10178,,
10179,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی مُوسَی بْنُ عُقْبَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَقُولُ : صَدَقَۃُ الثمَّارِ ، وَالزَّرْعِ ، وَمَا کَانَ مِنْ نَخْلٍ ، أَوْ زَرْعٍ مِنْ حِنْطَۃٍ ، أَوْ شَعِیرٍ ، أَوْ سُلْتٍ مِمَّا کَانَ بَعْلاً، أَوْ یُسْقَی بِنَہَرٍ ، أَوْ یُسْقَی بِالْعَیْنِ ، أَوْ عَثَرِیًّا یُسْقَی بِالْمَطَرِ فَفِیہِ الْعُشْرُ ، مِنْ کُلِّ عَشَرَۃٍ وَاحِدٌ ، وَمَا کَانَ مِنْہُ یُسْقَی بِالنَّضْحِ فَفِیہِ نِصْفُ الْعُشْرِ ، فِی کُلِّ عِشْرِینَ وَاحِدٌ ، وَکَتَبَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی أَہْلِ الْیَمَنِ، إلَی الْحَارِثِ بْنِ عَبْدِ کُلاَلٍ ، وَمَنْ مَعَہُ مِنْ أَہْلِ الْیَمَنِ مِنْ مَعَافِرَ وَہَمْدَانَ : أَنَّ عَلَی الْمُؤْمِنِینَ مِنْ صَدَقَۃِ أَمْوَالِہِمْ عُشُورَ ، مَا سَقَتِ الْعَیْنُ ، وَسَقَتِ السَّمَائُ الْعُشْرُ ، وَعَلَی مَا یُسْقَی بِالْغُرْبِ نِصْفُ الْعُشْرِ. (دارقطنی 130۔ بیہقی 130)",,,10179,,
10180,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : فِیمَا یُسْقَی بِالْکَظَائِمِ مِنْ نَخْلٍ ، أَوْ عِنَبٍ ، أَوْ حَبٍّ ، قَالَ : الْعُشْرُ.",,,10180,,
10181,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، قَالَ: أَخْبَرَنِی أَبُو الزُّبَیْرِ، عَنْ جَابِرٍ، أَنَّہُ سَمِعَہُ یَقُولُ: فِیہَا الْعُشْرُ.",,,10181,,
10182,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ قَالَ : قُلْتُ لِعَطَائٍ : فَکَمْ فِیمَا کَانَ بَعْلاً مِنْ نَخْلٍ ، أَوْ عَثری مِن حَبٍّ ، أَوْ حَرْثٍ ؟ قَالَ : الْعُشْرُ ، قَالَ : فَقُلْتُ : فَکَمْ فِیمَا یُسْقَی غَیْلاً مِنْ نَخْلٍ ، أَوْ عِنَبٍ ، أَوْ حَبٍّ ؟ قَالَ : الْعُشْرُ ، قُلْتُ : فِیمَا یُسْقَی بِالدَّلْوِ وَبِالْمَنَاضِحِ ؟ قَالَ : نِصْفُ الْعُشْرِ.",,,10182,,
10183,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی أَبُو الزُّبَیْرِ ، قَالَ : أَخْبَرَنِی جَابِرُ بْنُ عَبْدِ اللہِ ؛ أَنَّہُ قَالَ : نِصْفُ الْعُشْرِ.",,,10183,,
10184,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ کَانَ لاَ یُوَقِّتُ فِی الثَّمَرَۃِ شَیْئًا ، وَیَقُولُ : الْعُشْرُ وَنِصْفُ الْعُشْرِ.",,,10184,,
10185,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنْ رَجُلٍ ، عَنْ مُجَاہِدٍ ؛ مِثْلَہُ.,,,10185,,
10186,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، قَالَ : کَتَبَ بِذَلِکَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ إلَی أَہْلِ الْیَمَنِ.",,,10186,,
10187,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : فِی الْبُرِّ ، وَالشَّعِیرِ ، وَالتَّمْرِ ، وَالْعِنَبِ ، إذَا کَانَ خَمْسَۃَ أَوْسَاقٍ ، وَذَلِکَ ثَلاَثُ مِئَۃِ صَاعٍ فَفِیہِ نِصْفُ الْعُشْرِ ، إذَا کَانَ یُسْقَی ، وَمَا سَقَت السَّمَائُ وَالْعَیْنُ فَفِیہِ الْعُشْرُ.",,,10187,,
10188,حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ لَیْثِ بْنِ سَعْدٍ ، عَنْ نَافِعٍ ؛ أَنَّ عَبْدَ اللہِ کَانَ یُفْتِی فِی صَدَقَۃِ الزَّرْعِ وَالثِّمَارِ، مَا کَانَ فِیہِمَا یَشْرَبُ بِالنَّہَرِ ، أَوْ بِالْعیون ، أَوْ عَثَرِیًّا ، أَوْ بَعْلٍ ، فَإِنَّ صَدَقَتَہُ الْعُشُورُ ، مِنْ کُلِّ عَشْرَۃٍ وَاحِدٌ، وَمَا کَانَ مِنْہَا یُسْقَی بِالأَنْضَاحِ ، فَإِنَّ صَدَقَتَہُ نِصْفُ الْعُشُورِ ، وَفِی کُلِّ عِشْرِینَ وَاحِدٌ.,,,10188,,
10189,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الزَّرْعِ یَکُونُ عَلَی السَّیْحِ الزَّمَانِ ، ثُمَّ یُسْقَی بِالْبِئْرِ، یَعْنِی بِالدَّالِیَۃِ ؟ قَالَ : یُصَدَّقُ عَلَی أَکْثَرِ ذَلِکَ أَنْ یُسْقَی بِہِ.",,,10189,,
10190,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : إنَّمَا یَکُونُ عَلَی الْعَیْنِ عَامَّۃَ الزَّمَانِ ، ثُمَّ یَحْتَاجُ إلَی الْبِئْرِ فِی الْقِطعَۃِ یُسْقَی بِہَا ، ثُمَّ الْقِطْعَۃِ ، ثُمَّ یَصِیرُ إلَی الْعَیْنِ ، کَیْفَ صَدَقَتُہُ ؟ قَالَ : الْعُشْرُ ، قَالَ : یَکُونُ ذَلِکَ عَلَی أَکْثَرِ ذَلِکَ أَنْ یُسْقَی بِہِ ، إِنْ کَانَ یُسْقَی بِالْعَیْنِ أَکْثَرَ مِمَّا یُسْقَی بِالدَّلْوِ ، فَفِیہِ الْعُشْرُ، وَإِنْ کَانَ یُسْقَی بِالدَّلْوِ ، أَکْثَرَ مِمَّا یُسْقَی بِالنَّجْلِ ، فَفِیہِ نِصْفُ الْعُشْرِ ، قُلْتُ : ہُوَ بِمَنْزِلَۃِ ذَلِکَ أَیْضًا الْمَالُ یَکُونُ بَعْلاً ، أَوْ عَثَرِیًّا عَامَّۃَ الزَّمَانِ ، ثُمَّ یَحْتَاجُ إلَی الْبِئْرِ ؟ قَالَ : نَعَمْ . قَالَ أَبُو الزُّبَیْرِ : وَسَمِعْت ابْنَ عُمَیرَ یَقُولُ ہَذَا الْقَوْلَ ، ثُمَّ سَأَلْتُ سَالِمَ بْنَ عَبْدِ اللہِ ؟ فَقَالَ : مِثْلَ قَوْلِ عُبَیدِِ.",,,10190,,
10191,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ حَبِیبٍ الْمُعَلِّمِ ، قَالَ : کَانَ عَطَائٌ یَقُولُ : فِی الزَّرْعِ إذَا أَعْطَی صَاحِبُہُ أَجْرَ الْحَصَّادِینَ ، وَالَّذِینَ یَذُرُّونَ ، ہَلْ عَلَیْہِ فِیمَا أَعْطَاہُمْ صَدَقَۃٌ ؟ قَالَ : لاَ ، إنَّمَا الصَّدَقَۃُ فِیمَا حَصَلَ فِی یَدِک.",,,10191,,
10192,"حَدَّثَنَا وَکِیعٌ، عَنْ أَبِی عَوَانَۃَ، عَنْ أَبِی بِشْرٍ، عَنْ عَمْرِو بْنِ ہَرِمٍ، عَنْ جَابِرِ بْنِ زَیْدٍ، عَنِ ابْنِ عُمَرَ، وَابْنِ عَبَّاسٍ ؛ فِی الرَّجُلِ یُنْفِقُ عَلَی ثَمَرَتِہِ ؟ فَقَالَ أَحَدُہُمَا : یُزَکِّیہَا ، وَقَالَ الآخَرُ : یَرْفَعُ النَّفَقَۃَ ، وَیُزَکِّی مَا بَقِیَ.",,,10192,,
10193,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : اِرْفَعِ الْبذْرَ ، وَالنَّفَقَۃَ ، وَزَکِّ مَا بَقِیَ.",,,10193,,
10194,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَ سَاعِیًا عَلَی الصَّدَقَۃِ فَأَتَی الْعَبَّاسَ یَسْتَسْلِفہُ ، فَقَالَ لَہُ الْعَبَّاسُ : إنِّی أَسْلَفْتُ صَدَقَۃَ مَالِی إِلَی سَنَتَیْنِ ، فَأَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَخْبَرَہُ فَقَالَ : صَدَقَ عَمِّی. (ترمذی 678۔ ابوداؤد 1621)",,,10194,,
10195,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ یُوسُفَ بْنِ عَبْدَۃَ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ یُعَجِّلَہَا.",,,10195,,
10196,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لاَ بَأْسَ بِتَعْجِیلِ الزَّکَاۃِ.",,,10196,,
10197,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، أَوْ عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ تُعَجِّلَ زَکَاۃَ مَالِکَ ، وَتَحْتَسِبَ بِہَا فِیمَا یَسْتَقْبِلُ.",,,10197,,
10198,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنِ الْحَسَنِ، قَالَ: لاَ بَأْسَ بِتَعْجِیلِ الزَّکَاۃِ إذَا أَخْرَجہَا جَمِیعًا.",,,10198,,
10199,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ حَفْصِ بْنِ سُلَیْمَانَ ، قَالَ : سَأَلْتُ الْحَسَنَ عَنْ رَجُلٍ أَخْرَجَ زَکَاۃَ ثَلاَثَ سِنِینَ ضَرْبَۃً ؟ قَالَ : یُجْزِیہِ.",,,10199,,
10200,"حَدَّثَنَا مُحَمَّدُ بْنُ زَیْدٍ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : لاَ بَأْسَ أَنْ یُعَجِّلَہَا قَبْلَ مَحِلِّہَا.",,,10200,,
10201,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنِ الْحَسَنِ بْنِ صَالِحٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، قَالَ : لاَ بَأْسَ أَنْ یُعَجِّلَہَا.",,,10201,,
10202,حَدَّثَنَا عُمَرُ بْنُ یُونُسَ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یُعَجِّلَ الرَّجُلُ زَکَاتَہُ قَبْلَ الْحِلِّ.,,,10202,,
10203,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : مَا أَدْرِی مَا ہَذَا ، فِی تَعْجِیلِ الزَّکَاۃِ قَبْلَ الْحِلِّ بِشَہْرٍ ، أَوْ شَہْرَیْنِ ؟.",,,10203,,
10204,حَدَّثَنَا ابْنُ الْمُبَارَک ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُخْرِجُ لَہُ الطَّعَامَ مِنْ أَرْضِہِ فَیُزَکِّیہِ ، ثُمَّ یَمْکُثُ عِنْدَہُ السَّنَتَیْنِ وَالثَّلاَثَ فَلاَ یُزَکِّیہ ، وَہُوَ یُرِیدُ أَنْ یَبِیعَہُ.,,,10204,,
10205,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنِ ابْنِ لَہِیعَۃَ ، قَالَ : حدَّثَنِی عَبْدُ اللہِ بْنُ أَبِی جَعْفَرٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ: إذَا أُخِذَ مِنَ الزَّرْعِ الْعُشْرُ ، فَلَیْسَ فِیہِ زَکَاۃٌ ، وَإنْ مَکَثَ عَشْرَ سِنِینَ.",,,10205,,
10206,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا أَخْرَجَ صَدَقَۃَ الزَّرْعِ ، وَالتَّمْرِ ، وَکُلِّ شَیْئٍ أَنْبَتَتِ الأَرْضُ ، فَلَیْسَ فِیہِ زَکَاۃٌ حَتَّی یَحُولَ عَلَیْہِ الْحَوْلُ.",,,10206,,
10207,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : طَعَامٌ أُمْسِکُہُ أُرِیدُ أَکْلَہُ ، فَیَحُولُ عَلَیْہِ الْحَوْلُ ، قَالَ : لَیْسَ عَلَیْک فِیہِ صَدَقَۃٌ ، لَعَمْرِی إنَّا لَنَفْعَلُ ذَلِکَ ، نَبْتَاعُ الطَّعَامَ ، وَمَا نُزَکِّیہِ ، فَإِنْ کُنْت تُرِیدُ بَیْعَہُ فَزَکِّہِ إذَا بِعْتَہُ.",,,10207,,
10208,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ لِی عَبْدُ الْکَرِیمِ فِی الْحَرْثِ : إذَا أَعْطَیْت زَکَاتَہُ أَوَّلَ مَرَّۃٍ فَحَالَ عَلَیْہِ الْحَوْلُ عِنْدَکَ ، فَلاَ تُزَکِّہِ حَسْبُک الأُولَی.",,,10208,,
10209,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی الْیَقْظَانِ ، عَنِ ابْنِ أَبِی لَیْلَی ؛ أَنَّ عَلِیًّا زَکَّی أمْوَالَ بَنِی أَبِی رَافِعٍ ، أَیْتَامٍ فِی حِجْرِہِ ، وَقَالَ : تُرَوْنَ کُنْتُ أَلِی مَالاً لاَ أُزَکِّیہِ ؟!.",,,10209,,
10210,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، قَالَ : کُنَّا أَیْتَامًا فِی حِجْرِ عَائِشَۃَ ، فَکَانَتْ تُزَکِّی أَمْوَالَنَا وَنُبْضِعُہَا فِی الْبَحْرِ.",,,10210,,
10211,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : فِی مَالِ الْیَتِیمِ زَکَاۃٌ.",,,10211,,
10212,حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُزَکِّی مَالَ الْیَتِیمِ.,,,10212,,
10213,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، قَالَ : قَالَ عُمَرُ : ابْتَغُوْا لِلْیَتَامَی فِی أَمْوَالِہِمْ، لاَ تَسْتَغْرِقُہَا الزَّکَاۃُ.",,,10213,,
10214,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی ، وَحَنْظَلَۃَ ، وَحُمَیْدٍ ، عَنِ الْقَاسِمِ ؛ أَنَّ عَائِشَۃَ کَانَتْ تُبْضِعُ أَمْوَالَہُمْ فِی الْبَحْرِ ، وَتُزَکِّیہَا.,,,10214,,
10215,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، عَنْ عَمْرِو بْنِ دِینَارٍ، عَنْ مَکْحُولٍ، قَالَ: قَالَ عُمَرُ: ابْتَغُوا بِأَمْوَالِ الْیَتَامَی، لاَ تَسْتَغْرِقُہَا الصَّدَقَۃُ.",,,10215,,
10216,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنٍ ، عَنِ أَبِی فَرْوَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی مَالِ الْیَتِیمِ زَکَاۃٌ.",,,10216,,
10217,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ فِی مَالِ الْیَتِیمِ : لَہُ حَقٌّ وَعَلَیْہِ حَقٌّ ، وَلاَ أَقُولُ إِلاَّ مَا قَالَ اللَّہُ تَعَالَی.",,,10217,,
10218,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ، عَنِ الْحَسَنِ بْنِ یَزِیدَ، عَنْ طَاوُوسٍ، قَالَ: زَکِّ مَالَ الْیَتِیمِ، وَإِلاَّ فَہُوَ دَیْنٌ فِی عُنُقِکَ.",,,10218,,
10219,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، قَالَ : دُعِی ابْنُ عُمَرَ إلَی مَالِ یَتِیمٍ ، فَقَالَ: إِنْ شِئْتُمْ وَلَّیْتُہُ عَلَی أَنْ أُزَکِّیَہُ حَوْلاً إلَی حَوْلٍ.",,,10219,,
10220,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ رَأَی فِی مَالِ الْیَتِیمِ زَکَاۃً.,,,10220,,
10221,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ مَسْعُودٍ ؛ أَنَّہُ کَانَ یَقُولُ : أَحْصِ مَا یَجِبُ فِی مَالِ الْیَتِیمِ مِنَ الزَّکَاۃِ ، فَإِذَا بَلَغَ وَأُونِسَ مِنْہُ رُشْدُہُ فَأَعْلِمْہُ ، فَإِنْ شَائَ زَکَّاہُ ، وَإِنْ شَائَ تَرَکَہُ.",,,10221,,
10222,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَیْسَ فِی مَالِ الْیَتِیمِ زَکَاۃٌ حَتَّی یَحْتَلِمَ.",,,10222,,
10223,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، مِثْلَہُ.,,,10223,,
10224,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ فِی مَالِ الْیَتِیمِ زَکَاۃٌ حَتَّی یَحْتَلِمَ.",,,10224,,
10225,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ عِنْدَہُ مَالٌ لِبَنِی أَخٍ لَہُ أَیْتَامٍ ، فَلاَ یُزَکِّیہ.,,,10225,,
10226,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ شُرَیْحٍ ، فِی مَالِ الْیَتِیمِ قَالَ : أَوْشَکَ إِذَا أَخَذْتَ مِنْہُ الذَوْدَ وَالذَوْدَین لاَ یَبْقَی مِنْہُ شَیْء .",,,10226,,
10227,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لَیْسَ فِی مَالِ الْیَتِیمِ زَکَاۃٌ.",,,10227,,
10228,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ دِینَارٍ ، قَالَ : سَأَلْتُ الشَّعبیَِّ عَنْ مَالِ الْیَتِیمِ ، فِیہِ زَکَاۃٌ ؟ قَالَ : نَعَمْ ، وَلَوْ کَانَ عِنْدِی مَا زَکَّیْتُہُ.",,,10228,,
10229,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنِ الْحَسَنِ بْنِ زَیْدٍ ، قَالَ : سَمِعْتُ مُجَاہِدًا یَقُولُ : أَحْصِہِ ، فَإِذَا عَلِمْت فَزَکِّہِ.",,,10229,,
10230,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : یُؤْخَذُ مِنَ النَّخْلِ وَالْمَاشِیَۃِ ، فَأَمَّا الْمَالُ فَحَتَّی یَحْتَلِمَ . یَعْنِی مَالَ الْیَتِیمِ.",,,10230,,
10231,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ؛ أَنَّ أَبَا وَائِلٍ قَالَ : کَانَ فِی حِجْرِی یَتِیمٌ لَہُ ثَمَانیَۃُ آلاَفٍ ، فَلَمْ أُزَکِّہَا حَتَّی لَمَّا بَلَغَ دَفَعْتہَا إلَیْہِ.",,,10231,,
10232,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ السَّائِبِ ، قَالَ : کَانَ عِنْدَ ابْنِ عُمَرَ مَالُ یَتِیمٍ ، فَاسْتَسْلَفَ مَالَہُ حَتَّی لاَ یُؤَدِّیَ زَکَاتَہُ.",,,10232,,
10233,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ، عَنْ خُثَیْمِ بْنِ عِرَاکٍ، قَالَ: سَمِعْتُ أَبِی یَقُولُ : سَمِعْت أَبَا ہُرَیْرَۃَ یَقُولُ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: لاَ صَدَقَۃَ عَلَی الْمُسْلِمِ فِی عَبْدِہِ ، وَلاَ فَرَسِہِ.(بخاری 1464۔ مسلم 676)",,,10233,,
10234,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ عِرَاکِ بْنِ مَالِکٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، إِنَّہُ لَیْسَ عَلَی الْمُسْلِمِ فِی فَرَسِہِ ، وَلاَ عَبْدِہِ صَدَقَۃٌ. (بخاری 1463۔ ابوداؤد 1591)",,,10234,,
10235,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ ، عَنْ مَکْحُولٍ ، عَنْ عِرَاکِ بْنِ مَالِکٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنَّہُ لَیْسَ عَلَی الْمُسْلِمِ فِی عَبْدِہِ ، وَلاَ فَرَسِہِ ، وَلاَ وَلِیدَتِہِ صَدَقَۃٌ. (دارقطنی 8)",,,10235,,
10236,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، وسُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنْ عِرَاکِ بْنِ مَالِکٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ عَلَی الْمُسْلِمِ فِی فَرَسِہِ ، وَلاَ عَبْدِہِ صَدَقَۃٌ. (ترمذی 628۔ احمد 2/477)",,,10236,,
10237,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، رَفَعَہُ ، قَالَ : قَدْ تَجَاوَزْتُ لَکُمْ عَنْ صَدَقَۃِ الْخَیْلِ وَالرَّقِیقِ. (ابن ماجہ 1813۔ ابویعلی 294)",,,10237,,
10238,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَمَّا الْخَیْلُ وَالرَّقِیقُ فَقَدْ عَفَوْتُ عَنْ صَدَقَاتِہَا. (احمد 1/121)",,,10238,,
10239,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنِ ابْنِ أَبِی خَالِدٍ ، عَنْ شُبَیْلِ بْنِ عَوْفٍ ، قَالَ : وَقَدْ کَانَ أَدْرَکَ الْجَاہِلِیَّۃَ ، قَالَ : أَمَرَ عُمَرُ بْنُ الْخَطَّابِ النَّاسَ بِالصَّدَقَۃِ ، فَقَالَ النَّاسُ : یَا أَمِیرَ الْمُؤْمِنِینَ ، خَیْلٌ لَنَا وَرَقِیقٌ ، افْرِضْ عَلَیْنَا عَشَرَۃً عَشَرَۃً ، قَالَ : أَمَّا أَنَا فَلاَ أَفْرِضُ ذَلِکَ عَلَیْکُمْ.",,,10239,,
10240,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَبْدُ اللہِ بْنُ أَبِی حُسَیْنٍ ، أَنَّ ابْنَ شِہَابٍ أَخْبَرَہُ ؛ أَنَّ عُثْمَانَ کَانَ یُصَدِّقُ الْخَیْلَ ، وَأَنَّ السَّائِبَ ابْنَ أُخْتِ نَمِرٍ أَخْبَرَہُ ؛ أَنَّہُ کَانَ یَأْتِی عُمَرَ بِصَدَقَۃِ الْخَیْلِ.",,,10240,,
10241,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لَیْسَ عَلَی الْفَرَسِ الْغَازِی فِی سَبِیلِ اللہِ صَدَقَۃٌ.",,,10241,,
10242,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، قَالَ : سُئِلَ ابْنُ الْمُسَیَّبِ : أَفِی الْبَرَاذِینِ صَدَقَۃٌ ؟ قَالَ : أَوَ فِی الْخَیْلِ صَدَقَۃٌ.",,,10242,,
10243,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ عَنْ صَدَقَۃِ الْبَرَاذِینِ ؟ فَقَالَ لِی : أَوَ فِی الْخَیْلِ صَدَقَۃٌ ؟ أَوَ فِی الْخَیْلِ صَدَقَۃٌ ؟.",,,10243,,
10244,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ نَافِعٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، قَالَ : لَیْسَ فِی الْخَیْلِ صَدَقَۃٌ.",,,10244,,
10245,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : لَیْسَ فِی الْخَیْلِ وَلاَ الرَّقِیقِ صَدَقَۃٌ.",,,10245,,
10246,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکٍ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ فِی الْخَیْلِ السَّائِمَۃِ صَدَقَۃٌ.",,,10246,,
10247,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الأَجْلَحِ ، قَالَ : سَأَلْتُ الشَّعْبِیَّ عَنْ صَدَقَۃِ الْخَیْلِ وَالرَّقِیقِ ؟ فَقَالَ : لَیْسَ فِیہا زَکَاۃٌ.",,,10247,,
10248,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ لاَ یَرَی فِی الرَّقِیقِ إذَا کَانُوا لِلتِّجَارَۃِ صَدَقَۃَ الْفِطْرَ ، وَلَکِنْ یُقَوِّمُہُمْ فَیُؤَدِّی عَنْہُمُ الزَّکَاۃَ.,,,10248,,
10249,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ ذَلِکَ.,,,10249,,
10250,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُبَارَکٍ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ فِی الْخَیْلِ وَالْبَرَاذِینِ وَالْحَمِیرِ صَدَقَۃٌ.",,,10250,,
10251,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ؛ فِی الْعَبْدِ لِلتِّجَارَۃِ، قَالَ: لَیْسَ عَلَیْہِ زَکَاۃُ الْفِطْرُ.",,,10251,,
10252,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنِ ابْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ عَلَی الْبَہِیمَۃِ ، وَلاَ عَلَی الْمَمْلُوکِ زَکَاۃٌ ، إِلاَّ أَنْ تَکُونَ لِلتِّجَارَۃِ.",,,10252,,
10253,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : لَیْسَ فِی الْخَیْلِ صَدَقَۃٌ ۔ قَالَ : حَمَّادٌ فِیہَا۔",,,10253,,
10254,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَأَلْتُہُ عَنِ الْحَمِیرِ ، فِیہَا زَکَاۃٌ أَمْ لاَ ؟ قَالَ : أَمَّا أَنَا فَأُشَبِّہُہَا بِالْبَقَرِ ، وَلاَ نَعْلَمُ فِیہَا شَیْئًا۔",,,10254,,
10255,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُبَارَکٍ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ فِی الْحَمِیرِ صَدَقَۃٌ۔",,,10255,,
10256,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ؛ أَنَّ امْرَأَتَیْنِ أَتَتَا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَفِی أَیْدِیہِمَا أَسْوِرَۃٌ مِنَ الذَّہَبِ ، فَقَالَ لَہُمَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَتُحِبَّانِ أَنْ یُسَوِّرَکُمَا رَبُّکُمَا بِأَسْوِرَۃٍ مِنْ نَارٍ ؟ قَالَتَا : لاَ ، قَالَ : فَأَدِّیَا حَقَّ ہَذَا فِی أَیْدِیکُمَا۔ (احمد 2/178۔ دارقطنی 108)",,,10256,,
10257,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، وَوَکِیعٌ ، عَنْ مُسَاوِرٍ الْوَرَّاقِ ، عَنْ شُعَیْبٍ ، قَالَ : کَتَبَ عُمَرُ إلَی أَبِی مُوسَی : أَنْ مُرْ مَنْ قِبَلَک مِنْ نِسَائِ الْمُسْلِمِینَ أَنْ یُصَدِّقْنَ حُلِیَّہنَّ ، وَلاَ یَجْعَلْنَ الْہَدِیَّۃَ وَالزِّیَادَۃَ تَقَارُضًا بَیْنَہُنَّ۔",,,10257,,
10258,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : یُزَکَّی مَرَّۃً۔",,,10258,,
10259,حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ؛ أَنَّہُ کَانَ یَرَی فِی الْحُلِیِّ زَکَاۃً۔,,,10259,,
10260,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : فِی الْحُلِیِّ زَکَاۃٌ۔",,,10260,,
10261,"حَدَّثَنَا شَرِیکٌ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ ، قَالَ : فِی الْحُلِیِّ زَکَاۃٌ۔",,,10261,,
10262,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : فِی حُلِیِّ الذَّہَبِ وَالْفِضَّۃِ زَکَاۃٌ۔ قَالَ: وَہُوَ قَوْلُ سُفْیَانَ۔",,,10262,,
10263,حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرو ؛ أَنَّہُ کَانَ یَأْمُرُ نِسَائَہُ أَنْ یُزَکِّینَ حُلِیَّہُنَّ۔,,,10263,,
10264,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکٍ ، عَنْ عَطَائٍ ، قَالَ : فِی الْحُلِیِّ زَکَاۃٌ۔",,,10264,,
10265,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : فِی الْحُلِیِّ زَکَاۃٌ۔",,,10265,,
10266,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ : ہَلْ فِی الْحُلِیِّ زَکَاۃٌ ؟ قَالَ : نَعَمْ ، إذَا کَانَ عِشْرِینَ مِثْقَالاً ، أَوْ مِئَتَیْ دِرْہَمٍ۔",,,10266,,
10267,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، وَالزُّہْرِیِّ ، وَمَکْحُولٍ قَالُوا : فِی الْحُلِیِّ زَکَاۃٌ ۔ وَقَالُوا : مَضَتِ السُّنَّۃُ أَنَّ فِی الْحُلِیِّ ، الذَّہَبِ وَالْفِضَّۃِ ، زَکَاۃً۔",,,10267,,
10268,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی جَعْفَرٍ الْفَرَّائِ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ، قَالَ : فِی الْحُلِیِّ زَکَاۃٌ ، حَتَّی فِی الْخَاتَمِ۔",,,10268,,
10269,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ جَعْفَرِ بْنِ مَیْمُونٍ ، قَالَ : کَانَ عِنْدَنَا طَوْقٌ قَدْ زَکَّیْنَاہُ ، حَتَّی أُرَاہُ قَدْ أَتَی عَلَی ثَمَنِہِ۔",,,10269,,
10270,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ حُسَیْنٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا بَلَغَ الْحُلِیُّ مَا تَجِبُ فِیہِ الزَّکَاۃُ ، فَفِیہِ الزَّکَاۃُ۔",,,10270,,
10271,حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَرَی فِی الْحُلِیِّ زَکَاۃً۔,,,10271,,
10272,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ اللہِ بْنِ ذَکْوَانَ ، وَعَمْرِو بْنِ مُرَّۃَ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَ مَالُنَا عِنْدَ عَائِشَۃَ ، فَکَانَتْ تُزَکِّیہ إِلاَّ الْحُلِیَّ۔",,,10272,,
10273,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ لاَ تُزَکِّیہ۔,,,10273,,
10274,"حَدَّثَنَا وَکِیعٌ، عَنْ دَلْہَمِ بْنِ صَالِحٍ، عَنْ عَطَائٍ، عَنْ عَائِشَۃَ، قَالَ: کَانَ لِبَنَاتِ أَخِیہَا حُلِیٌّ، فَلَمْ تَکُنْ تُزَکِّیہ۔",,,10274,,
10275,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لاَ زَکَاۃَ فِی الْحُلِیِّ ، قُلْتُ : إِنَّہ یَکُونُ فِیہِ أَلْفُ دِینَارٍ ، قَالَ : یُعَارُ وَیُلْبَسُ۔",,,10275,,
10276,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ فَاطِمَۃَ بِنْتِ الْمُنْذِرِ ، عَنْ أَسْمَائَ ؛ أَنَّہَا کَانَتْ لاَ تُزَکِّی الْحُلِیَّ۔,,,10276,,
10277,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ فَاطِمَۃَ ، عَنْ أَسْمَائَ ؛ أَنَّہَا کَانَتْ تُحَلِّی بَنََاتہَا الذَّہَبَ ، وَلاَ تُزَکِّیہ۔,,,10277,,
10278,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : سَأَلْتُ عَمْرَۃَ عَنْ زَکَاۃِ الْحُلِیِّ ؟ فَقَالَتْ : مَا رَأَیْت أَحَدًا یُزَکِّیِہِ۔",,,10278,,
10279,"حَدَّثَنَا وَکِیعٌ، عَنْ زِیَادِ بْنِ أَبِی مُسْلِمٍ، عَنِ الْحَسَنِ، قَالَ: لاَ نَعْلَمُ أَحَدًا مِنَ الْخُلَفَائِ قَالَ فِی الْحُلِیِّ زَکَاۃٌ۔",,,10279,,
10280,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ فِی الْحُلِیِّ زَکَاۃٌ ، یُعَارُ وَیَلْبَسُ۔",,,10280,,
10281,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَخِلاسٍ ، قَالَ : لاَ زَکَاۃَ فِی الْحُلِیّ۔",,,10281,,
10282,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ (ح) وَأَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الشَّعْبِیِّ قَالَ : زَکَاۃُ الْحُلِیِّ عَارِیَّتُہُ۔",,,10282,,
10283,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : سَمِعْتُ أَبَا جَعْفَرٍ یَقُولُ : لَیْسَ فِی الْحُلِیِّ زَکَاۃٌ ، ثُمَّ قَرَأَ : {وَتَسْتَخْرِجُونَ مِنْہُ حِلْیَۃً تَلْبَسُونَہَا}۔",,,10283,,
10284,"حَدَّثَنَا وَکِیعٌ ، عَنْ حُسَیْنٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : لَیْسَ فِی الْحُلِیِّ زَکَاۃٌ۔",,,10284,,
10285,"وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ : زَکَاۃُ الْحُلِیِّ یُعَارُ وَیُلْبَسُ۔",,,10285,,
10286,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عُمَارَۃَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی بَکْرٍ ، عَنْ عَمْرَۃَ قَالَتْ : کُنَّا أَیْتَامًا فِی حِجْرِ عَائِشَۃَ ، وَکَانَ لَنَا حُلِیٌّ ، فَکَانَتْ لاَ تُزَکِّیہ۔",,,10286,,
10287,"حَدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ ، عَنْ سُہَیْلٍ ، عَنْ أَبِیہِ ، قَالَ : سَأَلْتُ سَعْدًا ، وَابْنَ عُمَرَ ، وَأَبَا ہُرَیْرَۃَ ، وَأَبَا سَعِیدٍ ، فَقُلْتُ : إنَّ لِی مَالاً ، وَأَنَا أُرِیدُ أَنْ أُعْطِیَ زَکَاتَہُ ، وَلاَ أَجِدُ لَہُ مَوْضِعًا ، وَہَؤُلاَئِ یَصْنَعُونَ فِیہَا مَا تَرَوْنَ ؟ فَقَالَ : کُلُّہُمْ أَمَرُونِی أَنْ أَدْفَعَہَا إلَیْہِمْ۔",,,10287,,
10288,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ عَوْنٍ ، عَنْ نَافِعٍ ، قَالَ : قَالَ ابْنُ عُمَرَ : ادْفَعُوا زَکَاۃَ أَمْوَالِکُمْ إلَی مَنْ وَلاَّہُ اللَّہُ أَمْرَکُمْ ، فَمَنْ بَرَّ فَلِنَفْسِہِ ، وَمِنْ أَثِمَ فَعَلَیْہَا۔",,,10288,,
10289,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ حَاتِمِ بْنِ أَبِی صَغِیرَۃَ ، قَالَ : حدَّثَنِی رِیَاحُ بْنُ عَبِیْدَۃَ ، عَنْ قَزَعَۃَ ، قَالَ : قُلْتُ لِاِبْنِ عُمَرَ : إنَّ لِی مَالاً ، فَإِلَی مَنْ أَدْفَعُ زَکَاتَہُ ؟ قَالَ : ادْفَعْہَا إلَی ہَؤُلاَئِ الْقَوْمِ ، یَعْنِی الأُمَرَائَ ، قُلْتُ : إذًا یَتَّخِذُونَ بِہَا ثِیَابًا وَطِیبًا ، قَالَ : وَإِنِ اتَّخَذُوا ثِیَابًا وَطِیبًا ، وَلَکِنْ فِی مَالِکَ حَقٌّ سِوَی الزَّکَاۃِ ، یَا قَزَعَۃَ۔",,,10289,,
10290,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَاجِبِ بْنِ عُمَرَ ، عَنِ الْحَکَمِ بْنِ الأَعْرَجِ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ ؟ فَقَالَ : ادْفَعْہَا إلَیْہِمْ ، وَإِنْ أَکَلُوا بِہَا لُحُومَ الْکِلاَبِ ، فَلَمَّا عَادُوا عَلَیْہِ ، قَالَ : ادْفَعْہَا إلَیْہِمْ۔",,,10290,,
10291,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُثَنَّی بْنِ سَعِیدٍ ، عَنْ أَبِی التَّیَّاحِ ، عَنْ نُعَیْمٍ بن مُجَالِدٍ ؛ سَأَلْتُ ابْنَ عُمَرَ عَنْہَا ؟ فَقَالَ: ادْفَعْہَا إلَیْہِمْ وَإِنْ أَکَلُوا بِہَا البَیْشِیَارَجات۔",,,10291,,
10292,حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ بْنِ الْحَارِثِ ، عَنْ دَاوُدَ بْنِ أَبِی عَاصِمٍ ، عَنِ الْمُغِیرَۃَ بْنِ شُعْبَۃَ ؛ أَنَّہُ کَانَ یَبْعَثُ بِصَدَقَتِہِ إلَی الأُمَرَائِ۔,,,10292,,
10293,حَدَّثَنَا غُنْدَرٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، أَنَّ حُذَیْفَۃَ ، وَسَعِیدَ بْنَ عُمَیْرٍ کَانُوا یَرَوْنَ أَنْ تُدْفَعَ الزَّکَاۃُ إلَی السُّلْطَانِ۔,,,10293,,
10294,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَتِ الصَّدَقَۃُ تُدْفَعُ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمَنْ أَمَرَ بِہِ ، وَإِلَی أَبِی بَکْرٍ وَمَنْ أَمَرَ بِہِ ، وَإِلَی عُمَرَ وَمَنْ أَمَرَ بِہِ ، وَإِلَی عُثْمَانَ وَمَنْ أَمَرَ بِہِ ، فَلَمَّا قُتِلَ عُثْمَانُ اخْتَلَفُوا ، فَمِنْہُمْ مَنْ رَأَی أَنْ یَدْفَعَہَا إلَیْہِمْ ، وَمِنْہُمْ مِنْ رَأَی أَنْ یَقْسِمَہَا ہُوَ ۔ قَالَ مُحَمَّدٌ : فَلْیَتَّقِ اللَّہَ مَنِ اخْتَارَ أَنْ یَقْسِمَہَا ہُوَ ، وَلاَ یَکُونَ یَعِیبُ عَلَیْہِمْ شَیْئًا ، یَأْتِی مِثْلُ الَّذِی یَعِیبُ عَلَیْہِمْ۔",,,10294,,
10295,"حَدَّثَنَا عَبْدَۃُ ، عَنْ حَارِثَۃَ بْنِ أَبِی الرِّجَالِ ، قَالَ : سَأَلْتُ عَمْرَۃَ عَنِ الزَّکَاۃِ ؟ فَقَالَتْ : قَالَتْ عَائِشَۃُ : ادْفَعُوہَا إلَی أُولِی الأَمْرِ مِنْکُمْ۔",,,10295,,
10296,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ اللہِ بْنِ حَبِیبٍ ، قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ عَنِ الزَّکَاۃِ ، أَدْفَعُہَا إلَی الْوُلاَۃِ ؟ فَقَالَ : ادْفَعْہَا إلَیْہِمْ۔",,,10296,,
10297,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَائِشَۃَ ، عَنِ الْحَسَنِ ، قَالَ : أَرْبَعٌ إلَی السُّلْطَانِ ؛ الصَّلاَۃُ ، وَالزَّکَاۃُ ، وَالْحُدُودُ ، وَالْقَضَائُ۔",,,10297,,
10298,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْحَسَنِ ، قَالَ : ضَمِنَ ، أَوْ ضُمِنَ ہَؤُلاَء الْقَوْمُ أَرْبَعًا ؛ الصَّلاَۃَ ، وَالزَّکَاۃَ ، وَالْحُدُودَ ، وَالْحُکْمَ۔",,,10298,,
10299,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، أَنَّہُ سُئِلَ عَنِ الزَّکَاۃِ ؟ قَالَ : ادْفَعْہَا إلَی السُّلْطَانِ ، فَقِیلَ : إنَّہُمْ یَفْعَلُونَ فِیہَا وَیَفْعَلُونَ ، مَرَّتَیْنِ ، قَالَ : فَتَسْتَطِیعُونَ أَنْ تَضَعُوہَا مَوَاضِعَہَا ؟ قَالُوا : لاَ ، قَالَ : فَادْفَعُوہَا إلَیْہِمْ۔",,,10299,,
10300,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ خَیْثَمَۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : أَعْطُوہَا الأُمَرَائَ مَا صَلَّوْا ۔ قَالَ : وَقَالَ خَیْثَمَۃُ : مَا صَلَّوا الصَّلاَۃَ لِوَقْتِہَا۔",,,10300,,
10301,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ کُلْثُومِ بْنِ جَبْرٍ ، عَنْ مُسْلِمِ بْنِ یَسَارٍ ، أَنَّہُ قَالَ : {وَأَقِیمُوا الصَّلاَۃَ وَآتَوُا الزَّکَاۃَ} ، قَالَ : ہَذِہِ الْفَرِیضَۃُ إلَی السُّلْطَانِ۔",,,10301,,
10302,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ کَانَ یَرَی أَنْ تُدْفَعَ الزَّکَاۃُ إلَی السُّلْطَانِ۔,,,10302,,
10303,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ، قَالَ: حدَّثَنَا ہِشَامٌ، عَنْ یَحْیَی، عَنْ عَبْدِالرَّحْمَنِ بْنِ الْبَیْلَمَانِیِّ، قَالَ: قَالَ أَبُو بَکْرٍ الصِّدِّیقُ فِیمَا یُوصِی بِہِ عُمَرَ: مَنْ أَدَّی الزَّکَاۃَ إلَی غَیْرِ وُلاَتِہَا لَمْ تُقْبَلْ مِنْہُ صَدَقَتُہُ، وَلَوْ تَصَدَّقَ بِالدُّنْیَا جَمِیعًا۔",,,10303,,
10304,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَد ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ قَالاَ : أَدِّ زَکَاۃَ مَالِکَ إلَی السُّلْطَانِ۔",,,10304,,
10305,"حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ حَکِیمِ بْنِ الدَّیْلَمِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، وَابْنِ عُمَرَ قَالاَ : ادْفَعْ زَکَاۃَ مَالِکَ إلَی السُّلْطَانِ۔",,,10305,,
10306,"حَدَّثَنَا مُحَمَّدُ بْنُ یَزِیدَ ، عَنِ النُّعْمَانِ ، عَنْ مَکْحُولٍ ، قَالَ : سَأَلَہُ رَجُلٌ عَنِ الزَّکَاۃِ ؟ فَقَالَ : ادْفَعْہَا إلَی الإِمَامِ ۔ وَقَالَ : الإِمَامُ الْقُرْآنُ ، وَکَانَ یُخْفِی ذَلِکَ۔",,,10306,,
10307,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ إبْرَاہِیمَ ، وَالْحَسَنِ قَالاَ : ضَعْہَا مَوَاضِعَہَا وَأَخْفِہَا۔",,,10307,,
10308,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُتْبَۃَ الْکِنْدِیِّ ، عَنْ طَاوُوسٍ ، قَالَ : ضَعْہَا فِی الْفُقَرَائِ۔",,,10308,,
10309,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ حَسَّانَ بْنِ أَبِی یَحْیَی ، قَالَ : سَأَلَ رَجُلٌ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الصَّدَقَۃِ ؟ قَالَ : ہِیَ إلَی وُلاَۃِ الأَمْرِ ۔ قَالَ : فَإِنَّ الْحَجَّاجَ یَبْنِی بِہَا الْقُصُورَ ، وَیَضَعُہَا فِی غَیْرِ مَوَاضِعِہَا ، قَالَ : ضَعْہَا حَیْثُ أُمِرْت بِہِ۔",,,10309,,
10310,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِنْ دَفَعَہَا إلَیْہِمْ أَجْزَأَ عَنْہُ ، وَإِنْ قَسَمَہَا أَجْزَأَ عَنْہُ۔",,,10310,,
10311,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ خَیْثَمَۃَ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنِ الزَّکَاۃِ ؟ فَقَالَ : ادْفَعْہَا إلَیْہِمْ ، ثُمَّ سَأَلْتُہُ بَعْدُ ، فَقَالَ : لاَ تَدْفَعْہَا إلَیْہِمْ ، فَإِنَّہُمْ قَدْ أَضَاعُوا الصَّلاَۃَ۔",,,10311,,
10312,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : جَائَ رَجُلٌ بِزَکَاۃِ مَالِہِ إلَی عَلِیٍّ ، فَقَالَ لَہُ عَلِیٌّ : تَأْخُذُ مِنْ عَطَائِنَا شَیْئًا ؟ قَالَ : لاَ ، قَالَ : لاَ نَجْمَعُ عَلَیْک أَنْ لاَ نُعْطِیَک وَنَأْخُذُ مِنْک ، فَأَمَرَہُ أَنْ یَقْسِمَہَا۔",,,10312,,
10313,حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، قَالَ۔,,,10313,,
10314,"وحَدَّثَنَا شَرِیکٌ، عَنْ أَبِی إِسْحَاقَ، عَنْ عَاصِمٍ، عَنْ عَلِیٍّ، قَالَ: لَیْسَ فِی مَالٍ زَکَاۃٌ، حَتَّی یَحُولَ عَلَیْہِ الْحَوْلُ۔",,,10314,,
10315,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ ، عَنْ عَلِیٍّ ، قَالَ : لَیْسَ فِی مَالٍ زَکَاۃٌ ، حَتَّی یَحُولَ عَلَیْہِ الْحَوْلُ۔",,,10315,,
10316,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : مَنْ أَصَابَ مَالاً فَلاَ زَکَاۃَ عَلَیْہِ حَتَّی یَحُولَ عَلَیْہِ الْحَوْلُ۔",,,10316,,
10317,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ الأَعْمَشِ ، عَنْ رَجُلٍ ، عَنْ جَابِرٍ ، عَنْ أَبِی بَکْر ، قَالَ : لَیْسَ عَلَیْہِ زَکَاۃٌ حَتَّی یَحُولَ عَلَیْہِ الْحَوْلُ۔",,,10317,,
10318,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : أَیُّمَا رَجُلٍ أَفَادَ مَالاً فَلاَ زَکَاۃَ عَلَیْہِ ، حَتَّی یَعُودَ عَلَیْہِ الْحَوْلُ۔",,,10318,,
10319,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَالِمٍ ، قَالَ : لَیْسَ فِیہِ زَکَاۃٌ حَتَّی یَحُولَ عَلَیْہِ الْحَوْلُ۔",,,10319,,
10320,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ فِی مَالٍ زَکَاۃٌ ، حَتَّی یَحُولَ عَلَیْہِ الْحَوْلُ۔",,,10320,,
10321,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، أَوْ غَیْرِہِ، عَنْ َإِبْرَاہِیمَ قَالَ: لاَ زَکَاۃَ فِیہِ حَتَّی یَحُولَ عَلَیْہِ الْحَوْلُ۔",,,10321,,
10322,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حَارِثَۃَ بْنِ مُحَمَّدٍ ، عَنْ عَمْرَۃَ بِنْتِ عَبْدِ الرَّحْمَنِ ، عَنْ عَائِشَۃَ ،قَالَتْ : لَیْسَ فِی مَالٍ زَکَاۃٌ حَتَّی یَحُولَ عَلَیْہِ الْحَوْلُ۔",,,10322,,
10323,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : لَیْسَ فِیہِ زَکَاۃٌ حَتَّی یَحُولَ عَلَیْہِ الْحَوْلُ۔",,,10323,,
10324,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی التَّیْمِیُّ ، عَنْ مَنْصُورٍ ، عَنْ یَعْلَی بْنِ نُعْمَانَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَیْسَ عَلَیْہِ زَکَاۃٌ حَتَّی یَحُولَ عَلَیْہِ حَوْلٌ ، مِنْ حِینَ یَسْتَفِیدُہُ۔",,,10324,,
10325,"حَدَّثَنَا مُعْتَمِر ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : إذَا کَانَ لِلرَّجُلِ شَہْرٌ یُزَکِّی فِیہِ فَأَصَابَ مَالاً فَأَنْفَقَہُ ، فَلَیْسَ عَلَیْہِ زَکَاۃُ مَا أَنْفَقَ ، وَلَکِنْ مَا وَافَی الشَّہْرَ الَّذِی یُزَکِّی فِیہِ مَالَہُ زَکَّاہُ ، فَإِنْ کَانَ لَیْسَ لَہُ شَہْرٌ یُزَکِّی فِیہِ فَاسْتَفَادَ مَالاً ، فَلْیُزَکِّہِ حِینَ یَسْتَفِیدُہُ۔",,,10325,,
10326,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الرَّجُلِ یَسْتَفِیدُ مَالاً ؟ قَالَ : یُزَکِّیہ حِینَ یَسْتَفِیدُہُ۔",,,10326,,
10327,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ کَانَ یَقُولُ : إذَا اسْتَفَادَ الرَّجُلُ مَالاً فَأَرَادَ أَنْ یُنْفِقَہُ قَبْلَ مَجِیئِ شَہْرِ زَکَاتِہِ فَلْیُزَکِّہِ ، ثُمَّ لْیُنْفِقْہُ ، وَإِنْ کَانَ لاَ یُرِیدُ أَنْ یُنْفِقَ فَلْیُزَکِّہِ مَعَ مَالِہِ۔",,,10327,,
10328,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لَیْسَ فِی مَالِ الْمُکَاتَبِ زَکَاۃٌ۔",,,10328,,
10329,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، قَالَ : لَیْسَ فِی مَالِ الْمُکَاتَبِ زَکَاۃٌ۔",,,10329,,
10330,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ صُبَیْحٍ أَبِی الْجَہْمِ مَوْلَی بَنِی عَبْسٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ ، وَابْنَ الْمُسَیَّبِ عَنْ رَجُلٍ مُکَاتَبٍ لَہُ مَالٌ ، أَعَلَی مَالِہِ زَکَاۃٌ ؟ قَالاَ : لاَ۔",,,10330,,
10331,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، عَنْ أَبِیہِ مَیْمُونِ بْنِ مِہْرَانَ ، عَنْ جَدَّتِہِ ، عَنْ مَسْرُوقٍ ، قَالَ: لَیْسَ فِی مَالِ الْمُکَاتَبِ زَکَاۃٌ۔",,,10331,,
10332,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لَیْسَ فِی مَالِ الْمُکَاتَبِ ، وَلاَ الْعَبْدِ زَکَاۃٌ حَتَّی یُعْتَقَا۔",,,10332,,
10333,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَیْسَ فِی مَالِ الْمُکَاتَبِ ، وَلاَ الْعَبْدِ زَکَاۃٌ۔",,,10333,,
10334,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی صَخْرٍ ، عَنْ کَیْسَانَ أَبِی سَعِیدٍ الْمَقْبُرِیِّ ، قَالَ : أَتَیْتُ عُمَرَ بِزَکَاۃِ مَالِی ، مِئَتَیْ دِرْہَمٍ وَأَنَا مُکَاتَبٌ ، فَقَالَ : ہَلْ عُتِقْتَ ؟ قُلْتُ : نَعَمْ ، قَالَ : اذْہَبْ فَاقْسِمْہَا۔",,,10334,,
10335,حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ؛ مِثْلَ قَوْلِ جَابِرٍ۔,,,10335,,
10336,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَیْسَ فِی مَالِ الْعَبْدِ زَکَاۃٌ۔",,,10336,,
10337,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ اللہِ بْنِ نَافِعٍ ، عَنْ أَبِیہِ ، عَنْ عُمَرَ ، قَالَ : لَیْسَ فِی مَالِ الْعَبْدِ زَکَاۃٌ۔",,,10337,,
10338,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : لَیْسَ فِی مَالِ الْعَبْدِ زَکَاۃٌ۔",,,10338,,
10339,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : الْعَبْدُ وَمَالُہُ لِسَیِّدِہِ ، الزَّکَاۃُ عَلَی الْمَوْلَی ، وَلَیْسَ عَلَی الْعَبْدِ زَکَاۃٌ۔",,,10339,,
10340,"حَدَّثَنَا زَیْدُ بْنُ حَبَّابٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَبْدِ اللہِ بْنِ کَثِیرٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لَیْسَ فِی مَالِ الْعَبْدِ زَکَاۃٌ۔",,,10340,,
10341,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : لَیْسَ فِی مَالِ الْعَبْدِ زَکَاۃٌ۔",,,10341,,
10342,"حَدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ عَلَی الْعَبْدِ زَکَاۃٌ۔",,,10342,,
10343,"حَدَّثَنَا غُنْدَرٌ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّہُ سُئِلَ عَنِ الْعَبْدِ : ہَلْ عَلَیْہِ زَکَاۃٌ ؟ قَالَ : ہَلْ عَلَیْہِ صَلاَۃٌ ؟۔",,,10343,,
10344,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : فِی مَالِ الْعَبْدِ زَکَاۃٌ۔",,,10344,,
10345,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ جَابِرٍ الْحَذَّائِ ، قَالَ : قُلْتُ لِاِبْنِ عُمَرَ : فِی مَالِ الْعَبْدِ زَکَاۃٌ ؟ قَالَ : مُسْلِمٌ ہُوَ ؟ قُلْتُ : نَعَمْ ، قَالَ : فِی مِئَتَیْ دِرْہَمٍ خَمْسَۃُ دَرَاہِمَ۔",,,10345,,
10346,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، قَالَ : سُئِلَ عَلِیٌّ عَنِ الرَّجُلِ یَکُونُ لَہُ الدَّیْنُ عَلَی الرَّجُلِ ؟ قَالَ : یُزَکِّیہ صَاحِبُ الْمَالِ ، فَإِنْ تَوَی مَا عَلَیْہِ وَخَشِیَ أَنْ لاَ یَقْضِیَ ، فَإِنَّہُ یُمْہِلُ ، فَإِذَا خَرَجَ أَدَّی زَکَاۃَ مَا مَضَیِ۔",,,10346,,
10347,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : نُبِّئْت أَنَّ عَلِیًّا قَالَ : إِنْ کَانَ صَادِقًا ، فَلْیُزَکِّ إذَا قَبَضَ، یَعْنِی الدَّیْنَ۔",,,10347,,
10348,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : إذَا کَانَ لَکَ دَیْنٌ فَزَکِّہِ۔",,,10348,,
10349,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لِیَنْظُرْ مَا کَانَ عَلَیْہِ مِنْ دَیْنٍ فَلْیَعْزِلْہُ ، وَمَا کَانَ لَہُ مِنْ دَیْنٍ ثِقَۃٍ فَلْیُزَکِّہِ ، وَمَا کَانَ لاَ یَسْتَقِرّ یُعْطِیہ الْیَوْمَ وَیَأْخُذْہُ إِلَی یَوْمَینِ فَلْیُزَکِّہِ۔",,,10349,,
10350,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : یُزَکِّیہِ۔",,,10350,,
10351,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : زَکَاۃُ أَمْوَالِکُمْ حَوْلٌ إلَی حَوْلٍ ، فَمَا کَانَ مِنْ دَیْنٍ ثِقَۃٍ فَزَکُّوہ ، وَمَا کَانَ مِنْ دَیْنِ ظُنُون فَلاَ زَکَاۃَ فِیہِ ، حَتَّی یَقْضِیَہُ صَاحِبُہُ۔",,,10351,,
10352,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : یُزَکِّیہِ۔",,,10352,,
10353,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ یَزِیدَ بْنِ یَزِیدَ بْنِ جَابِرٍ ؛ أَنَّ عَبْدَ الْمَلِکِ بْنَ أَبِی بَکْرٍ أَخْبَرَہُ ، أَنَّ عُمَرَ قَالَ لِرَجُلٍ : إذَا حَلَّتْ فَاحْسُبْ دَیْنَک ، وَمَا عِنْدَک ، فَاجْمَعْ ذَلِکَ جَمِیعًا ، ثُمَّ زَکِّہِ۔",,,10353,,
10354,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : مَا کَانَ مِنْ دَیْنٍ فِیمَا لاَ تَرْجُوہُ فَاحْسُبْہُ ، ثُمَّ أَخْرِجْ مَا عَلَیْک ، ثُمَّ زَکِّ مَا بَقِیَ۔",,,10354,,
10355,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَد ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا کُنْتَ تَعْلَمُ أَنَّہُ خَارِجٌ فَزَکِّہِ۔",,,10355,,
10356,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنْ مُحَمَّدٍ ، عَنْ عُبَیْدَۃَ ، قَالَ : سُئِلَ عَلِیٌّ عَنِ الرَّجُلِ یَکُونُ لَہُ الدَّیْنُ الظَّنُونُ أَیُزَکِّیہِ ؟ فَقَالَ : إِنْ کَانَ صَادِقًا فَلْیُزَکِّہِ لِمَا مَضَی إذَا قَبَضَہُ۔",,,10356,,
10357,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ عُثْمَانَ بْنِ أَبِی عُثْمَانَ ، قَالَ : قُلْتُ لِلْقَاسِمِ بْنِ مُحَمَّدٍ : إنَّ لَنَا قَرْضًا وَقَرْضًا وَدَیْنًا ، فَنُزَکِّیہِ ؟ قَالَ : نَعَمْ ، کَانَتْ عَائِشَۃُ تَأْمُرُنَا نُزَکِّیَ مَا فِی الْبَحْرِ ۔ وَسَأَلْتُ سَالِمًا؟ فَقَالَ : مِثْلَ ذَلِکَ۔",,,10357,,
10358,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزِّنَادِ ، عَنْ عِکْرِمَۃَ ، قَالَ : لَیْسَ فِی الدَّیْنِ زَکَاۃٌ۔",,,10358,,
10359,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ عَبْدِ اللہِ بْنِ الْمُؤَمِّلِ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عَائِشَۃَ ،قَالَتْ : لَیْسَ فِیہِ زَکَاۃٌ حَتَّی یَقْبِضَہُ۔",,,10359,,
10360,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَد ، عَنْ عَطَائٍ ، قَالَ : لاَ یُزَکِّیہِ حَتَّی یَقْبِضَہُ۔",,,10360,,
10361,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ عَلَی صَاحِبِ الدَّیْنِ الَّذِی ہُوَ لَہُ ، وَلاَ الَّذِی ہُوَ عَلَیْہِ زَکَاۃٌ۔",,,10361,,
10362,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : لَیْسَ فِیہِ زَکَاۃٌ حَتَّی یَقْبِضَہُ۔",,,10362,,
10363,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنِ الْحَکَمِ، قَالَ: خَالَفَنِی إبْرَاہِیمُ فِیہِ، فَقُلْتُ: لاَ یُزَکِّی، ثُمَّ رَجَعَ إلَی قَوْلِی۔",,,10363,,
10364,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ الْعُمَرِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : لَیْسَ فِی الدَّیْنِ زَکَاۃٌ۔",,,10364,,
10365,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یُکَافِیَٔ الْعَبْدُ أَصْحَابَہُ ، وَأَنْ یَتَصَدَّقَ مِنَ الْفَضْلِ کَذَلِکَ۔",,,10365,,
10366,"حَدَّثَنَا فُضَیْلُ بْنُ عِیَاضٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : یَتَصَدَّقُ الْعَبْدُ مِنْ قُوتِہِ بِالشَّیْئِ لاَ یُضَرُّ بِہِ۔",,,10366,,
10367,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ سَأَلَہُ رَجُلٌ ، فَقَالَ : أَنَا رَجُلٌ مَمْلُوکٌ وَمَعِی مَالٌ ، فَأَتَصَدَّقُ مِنْہُ ؟ قَالَ : نَعَمْ ، بِثَلاَثَۃِ دَرَاہِمَ ، أَرْبَعَۃِ۔",,,10367,,
10368,"حَدَّثَنَا یَحْیَی بْنُ زَکَرِیَّا بْنِ أَبِی زَائِدَۃَ ، عَنْ دَاوُدَ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ : مَا یَتَصَدَّقُ بِہِ الْعَبْدُ مِنْ مَالِہِ ؟ قَالَ : الصَّاعُ وَشَبَہُہُ۔",,,10368,,
10369,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَتَصَدَّقُ الْعَبْدُ بِمَا دُونَ الدِّرْہَمِ۔",,,10369,,
10370,"حَدَّثَنَا ابْنُ أَبِی زَائِدَۃَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ اللہِ بْنِ نَافِعٍ ، عَنْ أَبِیہِ ، وَکَانَ مَمْلُوکًا لِبَنِی ہَاشِمٍ ؛ أَنَّہُ سَأَلَ عُمَرَ أَیَتَصَدَّقُ ؟ قَالَ : بِالدِّرْہَمِ وَالرَّغِیفِ۔",,,10370,,
10371,"حَدَّثَنَا وَکِیعٌ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، عَنْ سَالِمٍ ، قَالَ : یَتَقَرَّبُ بِمَا اسْتَطَاعَ مِنْ خَیْرٍ۔",,,10371,,
10372,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَخَیْثَمَۃَ ؛ فِی الْعَبْدِ یَتَصَدَّقُ ؟ قَالاَ : لاَ یَتَصَدَّقُ بِمَا فَوْقَ الدِّرْہَمِ۔",,,10372,,
10373,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : یَتَصَدَّقُ بِالشَّیْئِ لَیْسَ بِذِی بَالٍ۔",,,10373,,
10374,"حَدَّثَنَا حَفْصٌ ، عَنْ مُحَمَّدِ بْنِ زَیْدٍ ، عَنْ عُمَیْرٍ مَوْلَی آبِی اللَّحْمِ ، قَالَ : کُنْتُ عَبْدًا مَمْلُوکًا ، وَکُنْت أَتَصَدَّقُ ، فَسَأَلْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَکَانَ مَوْلاَیَ یَنْہَانِی ، أَوْ سَأَلَہُ ، فَقَالَ : الأَجْرُ بَیْنَکُمَا۔ (مسلم 711۔ ابن ماجہ 2297)",,,10374,,
10375,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ، قَالَ : یَتَصَدَّقُ بِالدِّرْہَمِ۔",,,10375,,
10376,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُجِیبُ دَعْوَۃَ الْمَمْلُوکِ۔ (ابن سعد 370)",,,10376,,
10377,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُسْلِمٍ ، عَنْ أَنَسٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُجِیبُ دَعْوَۃَ الْمَمْلُوکِ۔ (ترمذی 1017۔ ابن ماجہ 4178)",,,10377,,
10378,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ عُبَیْدِ بْنِ سَلْمَانَ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ : لاَ یَتَصَدَّقُ الْعَبْدُ عَلَی وَالِدِہِ ، وَلاَ عَلَی أُمِّہِ إِلاَّ بِإِذْنِ سَیِّدِہِ۔",,,10378,,
10379,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ دِرْہمٍ ، قَالَ : سَأَلْتُ أَبَا ہُرَیْرَۃَ ، قُلْتُ : إِنَّہُ قَدْ جَعَلَ عَلَیَّ مَوْلاَیَ دِرْہَمًا فِی الْیَوْمِ ، فَأَتَصَدَّقُ ؟ قَالَ : لاَ یَحِلُّ لَکَ مِنْ دَمِکَ ، وَلاَ مِنْ مَالِکَ شَیْئٌ إِلاَّ بِإِذْنِہِ ، تُنَاوِلُ الْمِسْکِینَ اللُّقْمَۃَ۔",,,10379,,
10380,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : لاَ یَتَصَدَّقُ الْعَبْدُ بِشَیْئٍ مِنْ مَالِہِ ، إِلاَّ بِإِذْنِ مَوْلاَہُ۔",,,10380,,
10381,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ سُلَیْمَانَ ، قَالَ : شَہِدْت الشَّعْبِیَّ ، وَسَأَلَہُ مَمْلُوکٌ ، قَالَ : إنِّی اکْتَسَبْتُ کَذَا وَکَذَا ، فَیَأْخُذُ مَوْلاَیَ کَذَا وَکَذَا ، فَأَتَصَدَّقُ ؟ قَالَ : إِذَنْ یَکُونُ الأَجْرُ لِمَوَالِیک۔",,,10381,,
10382,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّ عَمْرَو بْنَ الْعَاصِ کَانَ یَأْمُرُ لِلْمِسْکِینِ بِالشَّیْئِ ، فَإِذَا لَمْ یُوجَدْ وُضِعَ حَتَّی یُعْطِیَہُ غَیْرَہُ۔,,,10382,,
10383,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ؛ إِنَّہُ کَرِہَ إذَا أُمِرَ لِلسَّائِلِ بِطَعَامٍ فَلَمْ یَقْدِرْ عَلَیْہِ ، أَنْ یَأْکُلَہُ حَتَّی یَتَصَدَّقَ بِہِ۔,,,10383,,
10384,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَبَّابِ بْنِ الْمُخْتَارِ، عَنْ عَمْرِو بْنِ سَعِیدٍ؛ أَنَّ سَائِلاً سَأَلَ حُمَیْدَ بْنَ عَبْدِالرَّحْمَنِ؟ فَقَالَ لَہُ حمَیْدٌ : إنَّک ضَالٌّ ، وَکَأَنَّہُ عِبَادِیٌّ ، فَأَمَرَ لَہُ بِشَیْئٍ فَاسْتَقَلَّہُ وَأَبَی أَنْ یَقْبَلَہُ ، فَقَالَ لَہُ حُمَیْدٌ : مَا شِئْت إِنْ قَبِلْتَہُ ، وَإِلاَّ أَعْطَیْنَاہُ غَیْرَک ، ثُمَّ قَالَ : کَانَ یُقَالُ : رُدُّوا السَّائِلَ وَلَوْ بِمِثْلِ رَأْسِ الْقَطَاۃِ۔",,,10384,,
10385,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ فِی الرَّجُلِ یَخْرُجُ بِالصَّدَقَۃِ إلَی السَّائل فَیَفُوتُ مِنْہُ فَلاَ یَجِدُہُ ؟ قَالَ : یَصْرِفُہَا إلَی غَیْرِہِ۔",,,10385,,
10386,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یُخْرِجُ الصَّدَقَۃَ إلَی الْمِسْکِینَ فَیَفُوتُہُ ، قَالَ : یَحْبِسُہَا حَتَّی یُعْطِیَہَا مِسْکِینًا غَیْرَہُ ، وَلاَ یَرْجِعُ فِی شَیْئٍ جَعَلَہُ لِلَّہِ۔",,,10386,,
10387,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ؛ فِی السَّائِلِ إذَا خَرَجَ إلَیْہِ بِالْکِسْرَۃِ فَلَمْ یَجِدْہُ ، احْبِسْہَا حَتَّی یَجِیئَ غَیْرُہُ۔,,,10387,,
10388,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ ابْنُ الْعَاصِ یَقُولُ : إذَا خَرَجَ إلَیْہِ بِالْکِسْرَۃِ فَلَمْ یُوجَدْ ، حَبَسوہَا حَتَّی یَجِیئَ غَیْرُہُ۔",,,10388,,
10389,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَمْرِو بْنِ الْعَاصِ ، قَالَ : یَضَعُہَا حَتَّی یَجِیئَ غَیْرُہُ۔",,,10389,,
10390,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ، قَالاَ: یَحْبِسُہَا حَتَّی یُعْطِیَہَا غَیْرَہُ۔",,,10390,,
10391,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : یَصْنَعُ بِہَا مَا شَائَ۔",,,10391,,
10392,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، وَعَامِرٍ ، وَعَطَائٍ ، قَالُوا : إِنْ شَائَ أَمْضَاہَا ، وَإِنْ شَائَ أَمْسَکَہَا۔",,,10392,,
10393,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ، عَنْ أَنَسٍ ، وَالْحَسَنِ قَالاَ : مَا أُخِذَ مِنْک عَلَی الْجُسُورِ وَالْقَنَاطِیرِ ، فَتِلْکَ زَکَاۃٌ مَاضِیَۃٌ۔",,,10393,,
10394,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، وَأَبُو بَکْرٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : احْتَسِبْ مَا أَخَذَ مِنْکَ الْعَشَّارُونَ مِنْ زَکَاۃِ مَالِک۔",,,10394,,
10395,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الزِّبْرِقَانِ ، قَالَ : سَأَلْتُ أَبَا رَزِینٍ : مَا یَأْخُذُ الْعَشَّارُ مِنَ التُّجَّارِ ؟ قَالَ : یَحْتَسِبُ بِہِ مِنْ زَکَاتِہِ۔",,,10395,,
10396,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ إبْرَاہِیمَ ، وَالْحَسَنِ ، قَالاَ : مَا أَخَذَ مِنْک الْعَاشِرُ ، فَاحْتَسِبْ بِہِ مِنَ الزَّکَاۃِ۔",,,10396,,
10397,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَحْتَسِبُ بِہِ۔",,,10397,,
10398,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا مَرَّ عَلَی الْعَاشِرِ فَأَخَذَ مِنْہُ ، احْتَسَبَ بِہِ مِنْ زَکَاتِہِ۔",,,10398,,
10399,"حَدَّثَنَا ابْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عَبْدِ اللہِ ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی الرَّجُلِ یَمُرُّ بِالْعَاشِرِ فَیَأْخُذُ مِنْہُ ؟ قَالَ : یَحْتَسِبُ مَا أَخَذُوا مِنْہُ مِنْ زَکَاۃِ مَالِہِ۔",,,10399,,
10400,"حَدَّثَنَا وَکِیعٌ ، عَنْ قَیْسٍ ، عَنْ سَالِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یَحْتَسِبُ بِہِ۔",,,10400,,
10401,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : سَأَلْتُہُ ؟ فَقَالَ : احْتَسِبْ بِمَا أَخَذَ مِنْک الْعَاشِرُ۔",,,10401,,
10402,"حَدَّثَنَا مُحَمَّدُ بْنُ سَوَائٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : لاَ تَحْتَسِبْ بِمَا أَخَذَ مِنْک الْعَاشِرُ۔",,,10402,,
10403,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ الْمَوْصِلِیِّ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : لاَ یَحْتَسِبُ بِہِ۔",,,10403,,
10404,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَطَاوُوسٍ قَالاَ : لاَ تَحْتَسِبْ مَا أَخَذَ مِنْکَ الْعَاشِرُ۔",,,10404,,
10405,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ ثُوَیْرٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ یَحْتَسِبُ بِہِ۔",,,10405,,
10406,"حَدَّثَنَا وَکِیعٌ، عَنْ حَسَنِ بْنِ صَالِحٍ، عَنِ سُدَیرٍ، عَنْ أَبِی جَعْفَرٍ، قَالَ: لاَ تَحْتَسِبْ بِمَا أَخَذَ مِنْک الْعَاشِرُ۔",,,10406,,
10407,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ ہِشَامٍ ، أَوْ غَیْرِہِ ، عَنِ الْحَسَنِ ؛ أَنَّہُمَا کَانَا یَکْرَہَانِ أَنْ تُخْرِجَ الزَّکَاۃَ مِنْ بَلَدٍ إلَی بَلَدٍ۔,,,10407,,
10408,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَرِہَ أَنْ تُحْمَلَ الصَّدَقَۃُ مِنْ بَلَدٍ إلَی بَلَدٍ,,,10408,,
10409,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ أَبِی رَوَّادٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ بُعِثَ إلَیْہِ بِزَکَاۃٍ مِنَ الْعِرَاقِ إلَی الشَّامِ ، فَرَدَّہَا إلَی الْعِرَاقِ۔,,,10409,,
10410,"حَدَّثَنَا الضَّحَّاکُ بْنُ مَخْلَدٍ ، عَنْ عُثْمَانَ بْنِ مُرَّۃَ ، قَالَ : سَأَلْتُ امْرَأَۃَ الْقَاسِمِ ؟ فَقَالَتْ : اجْتَمَعَ عِنْدَنَا دَرَاہِمُ مِنْ زَکَاتِنَا ، فَبَعَثْت بِہَا إلَی الشَّامِ ، فَقَالَ : ادْفَعُوہَا إلَی الأَمِیرِ الَّذِی بِالْمَدِینَۃِ۔",,,10410,,
10411,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی لَیْنۃ ، عَنِ الضَّحَّاکِ ، قَالَ : ضَعِ الزَّکَاۃَ فِی الْقَرْیَۃِ الَّتِی أَنْتَ فِیہَا ، فَإِنْ لَمْ یَکُنْ فِیہَا فُقَراء فَإِلَی الَّتِی تَلِیہَا۔",,,10411,,
10412,"حَدَّثَنَا أَبُو خَالِدٍ وَلَیْسَ بِالأَحْمَرِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ فَرْقَدٍ السَبَخِیِّ ، قَالَ : بُعِثَ مَعِیَ بِزَکَاۃٍ إلَی مَکَّۃَ ، فَلَقِیت سَعِیدَ بْنَ جُبَیْرٍ ، فَقَالَ : رُدَّہَا إلَی الأَرْضِ الَّتِی حَمَلْتہَا مِنْہَا۔",,,10412,,
10413,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی خَلدۃ ، عَنْ أَبِی الْعَالِیَۃِ ؛ أَنَّہُ بَعَثَ بِصَدَقَۃِ مَالِہِ إلَی الْمَدِینَۃِ۔,,,10413,,
10414,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی سَاسَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : ہُمُ الْمُسْلِمُونَ فَأَعْطِہِ حَیْثُ شِئْت۔",,,10414,,
10415,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : کَانَ یَسْتَحِبُّ أَنْ یُرْسِلَ بِالصَّدَقَۃِ إلَی أَبْنَائِ الْمُہَاجِرِینَ وَالأَنْصَارِ الَّذِینَ بِالْمَدِینَۃِ۔",,,10415,,
10416,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، قَالَ : کَانَ طَاوُوس یَرَی أَنْ یَجْلِسَ الْمُصَدِّقُ ، فَإِنْ أُعْطِیَ شَیْئًا أَخَذَ ، وَإِنْ لَمْ یُعْطَ شَیْئًا سَکَتَ۔",,,10416,,
10417,حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ؛ أَنَّ شَیْخَیْنِ مِنْ أَشْجَعَ أَخْبَرَاہُ ، أَنَّ مُحَمَّدَ بْنَ مَسْلَمَۃَ الأَنْصَارِیَّ ، مِنْ أَصْحَابِ بَدْرٍ کَانَ یَقدم عَلَیْہِمْ فَیُصَدِّقُ مَاشِیَتَہُمْ فِی زَمَنِ عُمَرَ بْنِ الْخَطَّابِ ، فَکَانَ یَجْلِسُ ، فَمَنْ أَتَاہُ بِشَاۃٍ فِیہَا وَفَائً مِنْ حَقِّہِ قَبِلَہَا مِنْہُ۔,,,10417,,
10418,"حَدَّثَنَا حَفْصٌ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، عَنْ أَبِی حَارِثَۃَ ، قَالَ : بَعَثَنَا عُمَرُ مُصَدِّقِینَ ، فَکُنَّا إذَا أُوْتیْنَا بِشَیْئٍ فِیہِ وَفَائٌ مِنْ حَقِّنَا قَبِلْنَاہُ مِنْہُ۔",,,10418,,
10419,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ رَجُلٍ ، عَنْ طَاوُوسٍ ، قَالَ : یَأْتِیہِمُ الْمُصَدِّقُ عَلَی مِیَاہِہِمْ ، وَلاَ یَسْتَحْلِفُہُمْ۔",,,10419,,
10420,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ الْمُصَدِّقُ یَجِیئُ ، فَإِنْ رَأَی إبِلاً قَائِمَۃً وَغَنَمًا صَدَّقَہَا ، وَلَمْ یَنْتَظِرْ۔",,,10420,,
10421,"حدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : أَمَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِإِخْرَاجِ زَکَاۃِ الْفِطْرِ قَبْلَ الصَّلاَۃِ۔ (بخاری 1509۔ مسلم 679)",,,10421,,
10422,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُخْرِجُہَا قَبْلَ الصَّلاَۃِ۔,,,10422,,
10423,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ (ح) وَعَنِ الْحَجَّاجِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ مِثْلَہُ۔,,,10423,,
10424,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إنَّ السُّنَّۃَ أَنْ یُخْرِجَ صَدَقَۃَ الْفِطْرِ قَبْلَ الصَّلاَۃِ۔ (دارقطنی 70)",,,10424,,
10425,حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُحِبُّ أَنْ یُخْرِجَ زَکَاۃَ الْفِطْرِ قَبْلَ أَنْ یَخْرُجَ إلَی الْجَبَّانَۃِ۔,,,10425,,
10426,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِم بْن یَسَارٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُعْطِی صَدَقَۃَ الْفِطْرِ قَبْلَ الصَّلاَۃِ۔,,,10426,,
10427,حَدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ؛ أَنَّہُ کَان یُخْرِجہَا قَبْلَ الصَّلاَۃِ۔,,,10427,,
10428,"حَدَّثَنَا غَسَّانُ بْنُ مُضَرَ ، عَنْ سَعِیدِ بْنِ یَزِیدَ ، قَالَ : کَانَ أَبُو نَضْرَۃَ یَقْعُدُ یَوْمَ الْفِطْرِ فِی مَسْجِدِ الْحَیِّ ، فَیُؤْتَی بِزَکوَاتِہِمْ وَیُرْسِلُ فِی مَنْ بَقِیَ ، فَیُؤْتَی بِزَکَاتِہِ فَیَقْسِمُہَا فِی فُقَرَائِ الْحَیِّ ، ثُمَّ یَخْرُجُ۔",,,10428,,
10429,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : لاَ یَخْرُجُ الرَّجُلُ یَوْمَ الْفِطْرِ إلَی الْمُصَلَّی ، حَتَّی یُؤَدِّیَ صَدَقَۃَ الْفِطْرِ ، وَمَا عَلَی أَہْلِہِ۔",,,10429,,
10430,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عِکْرِمَۃَ ، قَالَ : قَدِّمْ زَکَاتَکَ قَبْلَ صَلاَتِک۔",,,10430,,
10431,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنِ الْحَکَمِ ، قَالَ : کَانُوا یَسْتَحِبُّونَ إخْرَاجَہَا قَبْلَ الصَّلاَۃِ ۔ وَقَالَ عَامِرٌ : إِنْ شَائَ عَجَّلَہَا ، وَإِنْ شَائَ أَخَّرَہَا۔",,,10431,,
10432,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ یُعْطِی صَدَقَۃَ الْفِطْرِ بَعْدَ الصَّلاَۃِ۔,,,10432,,
10433,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُطَرِّفٍ ، قَالَ : أَخْبَرَنِی خَتْنُ مُجَاہِدٍ ، عَنْ مُجَاہِدٍ ، قَالَ : صَدَقَۃُ الْفِطْرِ یَوْمَ الْفِطْرِ زَکَاۃٌ ، وَمَنْ أَعْطَاہَا بَعْدَ ذَلِکَ ، فَہِیَ صَدَقَۃٌ۔",,,10433,,
10434,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ زُہَیْرٍ ، قَالَ : حدَّثَنَا أَبُو إِسْحَاقَ ، قَالَ : کَانَ أَبُو مَیْسَرَۃَ یُطْعِمُ بَعْد َمَا یُصَلِّی۔",,,10434,,
10435,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : فَرَضَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَدَقَۃَ الْفِطْرِ عَلَی کُلِّ حُرٍّ ، أَوْ عَبْدٍ ، صَغِیرٍ ، أَوْ کَبِیرٍ ، ذَکَرٍ ، أَوْ أُنْثَی ، صَاعًا مِنْ تَمْرٍ ، أَوْ شَعِیرٍ ، أَوْ نِصْفَ صَاعٍ مِنْ بُرٍّ۔ (ابوداؤد 1619۔ نسائی 2287)",,,10435,,
10436,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ عُثْمَانَ ، قَالَ : صَاعٌ مِنْ تَمْرٍ ، أَوْ نِصْفُ صَاعٍ مِنْ بُرٍّ۔",,,10436,,
10437,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : أَخْبَرَنِی مَنْ أَدَّی إلَی أَبِی بَکْرٍ صَدَقَۃَ الْفِطْرِ ، نِصْفُ صَاعٍ مِنْ طَعَامٍ۔",,,10437,,
10438,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، یَرْفَعُہُ ؛ أَنَّہُ سُئِلَ عَنْ صَدَقَۃِ الْفِطْرِ ؟ فَقَالَ : عَنِ الصَّغِیرِ ، وَالْکَبِیرِ ، وَالْحُرِّ ، وَالْمَمْلُوکِ ، نِصْفُ صَاعٍ مِنْ بُرٍّ ، أَوْ صَاعٌ مِنْ تَمْرٍ، أَوْ شَعِیرٍ۔",,,10438,,
10439,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : صَدَقَۃُ الْفِطْرِ عَنِ الصَّغِیرِ ، وَالْکَبِیرِ ، وَالْحُرِّ ، وَالْعَبْدِ، عَنْ کُلِّ إنْسَانٍ نِصْفُ صَاعٍ مِنْ قَمْحٍ۔",,,10439,,
10440,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : عَنْ کُلِّ إنْسَانٍ نِصْفُ صَاعٍ مِنْ قَمْحٍ ، وَمَنْ خَالَفَ الْقَمْحَ ، مِنْ تَمْرٍ ، أَوْ زَبِیبٍ ، أَوْ أَقِطٍ ، أَوْ شَعِیرٍ ، أَوْ غَیْرِہِ ، فَصَاعٌ تَامٌّ۔",,,10440,,
10441,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ إسْمَاعِیلَ بْنِ سَالِمٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَانَ یَقُولُ : صَدَقَۃُ الْفِطْرِ عَمَّنْ صَامَ مِنَ الأَحْرَارِ ، وَعَنِ الرَّقِیقِ مَنْ صَامَ مِنْہُمْ ، وَمَنْ لَمْ یَصُمْ ، نِصْفُ صَاعٍ مِنْ بُرٍّ ، أَوْ صَاعٌ مِنْ تَمْرٍ ، أَوْ شَعِیرٍ۔",,,10441,,
10442,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ قَالَ مِثْلَ قَوْلِ الشَّعْبِیِّ فِیمَنْ لَمْ یَصُمْ مِنَ الأَحْرَارِ۔,,,10442,,
10443,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ وَالأَسْوَد ، عَنْ عَبْدِ اللہِ ، قَالَ : مُدَّانِ مِنْ قَمْحٍ ، أَوْ صَاعٌ مِنْ تَمْرٍ ، أَوْ شَعِیرٍ۔",,,10443,,
10444,حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ مِثْلَہُ۔,,,10444,,
10445,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : نِصْفُ صَاعٍ مِنْ قَمْحٍ ، أَوْ صَاعٌ مِنْ تَمْرِ۔",,,10445,,
10446,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ قَالَ : صَاعٌ مِنْ تَمْرٍ ، أَوْ صَاعٌ مِنْ شَعِیرٍ۔",,,10446,,
10447,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : مُدَّانِ مِنْ قَمْحٍ ، أَوْ صَاعٌ مِنْ تَمْرٍ ، أَوْ شَعِیرٍ۔",,,10447,,
10448,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرٍو ؛ أَنَّہُ سَمِعَ ابْنَ الزُّبَیْرِ وَہُوَ عَلَی الْمِنْبَرِ ، یَقُولُ : مُدَّانِ مِنْ قَمْحٍ ، أَوْ صَاعٌ مِنْ شَعِیرٍ ، أَوْ تَمْرٍ۔",,,10448,,
10449,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ؛ أَنَّہُ سَأَلَ الْحَکَمَ ، وَحَمَّادًا ؟ فَقَالاَ : نِصْفُ صَاعِ حِنْطَۃٍ ۔ قَالَ : وَسَأَلْتُ عَبْدَ الرَّحْمَن بْنَ الْقَاسِمِ ، وَسَعْدَ بْنِ إبْرَاہِیمَ ؟ فَقَالاَ مِثْلَ ذَلِکَ۔",,,10449,,
10450,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ إِسْحَاقَ بْنِ سُلَیْمَانَ الشَّیْبَانِیِّ ، قَالَ : حدَّثَنِی أَبُو حَبِیبٍ ، قَالَ : سَأَلْتُ عَبْدَ اللہِ بْنَ شَدَّادٍ عَنْ صَدَقَۃِ الْفِطْرِ ؟ فَقَالَ : نِصْفُ صَاعٍ مِنْ حِنْطَۃٍ ، أَوْ دَقِیقٍ۔",,,10450,,
10451,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیٍّ ؛ فِی صَدَقَۃِ الْفِطْرِ صَاعٌ مِنْ تَمْرٍ ، أَوْ صَاعٌ مِنْ شَعِیرٍ ، أَوْ نِصْفُ صَاعٍ مِنْ بُرٍّ۔,,,10451,,
10452,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ فَاطِمَۃَ ، عَنْ أَسْمَائَ ؛ أَنَّہَا کَانَتْ تُعْطِی زَکَاۃَ الْفِطْرِ عَمَّنْ تَمُونُ مِنْ أَہْلِہَا الشَّاہِدِ ، وَالْغَائِبِ ، نِصْفُ صَاعٍ مِنْ بُرٍّ ، أَوْ صَاعٌ مِنْ تَمْرٍ ، أَوْ شَعِیرٍ۔,,,10452,,
10453,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ عَوْفٍ، قَالَ: سَمِعْتُ کِتَابَ عُمَرَ بْنِ عَبْدِالْعَزِیزِ إلَی عَدِیٍّ یُقْرَأُ بِالْبَصْرَۃِ فِی صَدَقَۃِ رَمَضَانَ: عَلَی کُلِّ صَغِیرٍ، أَوَ کَبِیرٍ ، حُرٍّ ، أَوْ عَبْدٍ ، ذَکَرٍ ، أَوْ أُنْثَی ، نِصْفُ صَاعٍ مِنْ بُرٍّ ، أَوْ صَاعٌ مِنْ تَمْرٍ۔",,,10453,,
10454,"حَدَّثَنَا عَبْدُ الرَّحِیم بْنُ سُلَیْمَانَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ: الصَّدَقَۃُ صَاعٌ مِنْ تَمْرٍ، أَوْ نِصْفُ صَاعٍ مِنْ طَعَامٍ۔",,,10454,,
10455,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : فَرَضَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَدَقَۃَ الْفِطْرِ ، صَاعًا مِنْ تَمْرٍ ، أَوْ صَاعًا مِنْ شَعِیرٍ ۔ قَالَ : وَکَانَ ابْنُ عُمَرَ یُعْطِیہِ عَمَّنْ یَعُولُ مِنْ نِسَائِہِ ، وَمَمَالِیکِ نِسَائِہِ ، إِلاَّ عَبْدَیْنِ کَانَا مُکَاتَبَیْنِ ، فَإِنَّہُ لَمْ یَکُنْ یُعْطِی عَنْہُمَا۔ (بخاری 1503۔ مسلم 12)",,,10455,,
10456,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَر ، قَالَ : فَرَضَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَدَقَۃَ الْفِطْرِ : صَاعًا مِنْ تَمْرٍ ، أَوْ صَاعًا مِنْ شَعِیرٍ ، عَلَی کُلِّ عَبْدٍ ، أَوْ حُرٍّ صَغِیرٍ ، أَوْ کَبِیرٍ۔ (بخاری 1512۔ ابوداؤد 1609)",,,10456,,
10457,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنِ ابْنِ أَبِی سَرْحٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ؛ فِی صَدَقَۃِ الْفِطْرِ ، قَالَ : إنِّی وَاللَّہِ لاَ أُخْرِجُ إِلاَّ مَا کُنَّا نُخْرِجُ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَاعًا مِنْ تَمْرٍ ، أَوْ صَاعًا مِنْ شَعِیرٍ ، أَوْ صَاعَ زَبِیبٍ ، أَوْ صَاعَ أَقِطٍ۔ (بخاری 1506۔ ابوداؤد 1612)",,,10457,,
10458,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَد ، عَنْ عَائِشَۃَ ، قَالَتْ : أحبَّ إِلَیَّ أَنَّ إذَا وَسَّعَ اللَّہُ عَلَی النَّاسِ ، أَنْ یُتِمُّوا صَاعًا مِنْ قَمْحٍ عَنْ کُلِّ إنْسَانٍ۔",,,10458,,
10459,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَاصِمٍ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : عَنْ کُلِّ إنْسَانٍ صَاعٌ مِنْ قَمْحٍ فِی صَدَقَۃِ الْفِطْرِ۔",,,10459,,
10460,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ: سَمِعْتُ مَسْرُوقًا یَقُولُ: صَدَقَۃُ الْفِطْرِ: صَاعٌ ، صَاعٌ۔",,,10460,,
10461,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : سَمِعْتُ أَبَا عَبْدِ الرَّحْمَنِ یَقُولُ : صَاعٌ ، صَاعٌ ، عَنْ کُلِّ صَغِیرٍ ، وَکَبِیرٍ مَکْتُوبٍ۔",,,10461,,
10462,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَتَبَ إلَیْنَا ابْنُ الزُّبَیْرِ : {بِئْسَ الْاِسْمُ الْفُسُوقُ بَعْدَ الإِیمَانِ} صَدَقَۃُ الْفِطْرِ : صَاعٌ ، صَاعٌ۔",,,10462,,
10463,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : صَدَقَۃُ الْفِطْرِ عَنِ الصَّغِیرِ ، وَالْکَبِیرِ ، وَالْحُرِّ ، وَالْمَمْلُوکِ ، وَالذَّکَرِ ، وَالأُنْثَی ، قَالَ : إِنْ کَانُوا یُعْطُونَ حَتَّی یُعْطُونَ عَنِ الْحَبْلِ۔",,,10463,,
10464,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ ، وَأَبِی الْعَالِیَۃِ ، وَابْنِ سِیرِینَ قَالُوا : صَدَقَۃُ الْفِطْرِ عَنِ الصَّغِیرِ، وَالْکَبِیرِ ، وَالْحُرِّ ، وَالْعَبْدِ ، وَالشَّاہِدِ ، وَالْغَائِبِ ، وَالذَّکَرِ ، وَالأُنْثَی ، وَالْغَنِیِّ ، وَالْفَقِیرِ۔",,,10464,,
10465,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ أَبِی إِسْحَاقَ، عَنِ الْحَارِثِ، عَنْ عَلِیٍّ، قَالَ: ہِیَ عَلَی مَنْ أَطَاقَ الصَّوْمَ۔",,,10465,,
10466,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیٍّ ، قَالَ : صَدَقَۃُ الْفِطْرِ عَلَی مَنْ تُجْرِی عَلَیْہِ نَفَقَتُک۔",,,10466,,
10467,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَسْتَحِبُّ التَّمْرَ فِی زَکَاۃِ الْفِطْرِ۔,,,10467,,
10468,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : تُجْزِئُ فِی صَدَقَۃِ الْفِطْرِ الْحِنْطَۃُ ، وَالشَّعِیرُ ، وَالتَّمْرُ ، وَالزَّبِیبُ ، وَالسُّلْتُ ، وَشَکَّ فِی الدَّقِیقِ وَالسَّوِیقِ ، وَقَالَ : مِنْ کُلِّ ہَذَا سَوَائٌ۔",,,10468,,
10469,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ عَوْفٍ، قَالَ : سَمِعْتُ کِتَابَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ یُقْرَأُ إلَی عَدِیٍّ بِالْبَصْرَۃِ : یُؤْخَذُ مِنْ أَہْلِ الدِّیوَانِ مِنْ أَعْطِیَّاتِہِمْ ، عَنْ کُلِّ إنْسَانٍ نِصْفُ دِرْہَمٍ۔",,,10469,,
10470,"حَدَّثَنَا وَکِیعٌ ، عَنْ قُرَّۃَ ، قَالَ : جَائَنَا کِتَابُ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فِی صَدَقَۃِ الْفِطْرِ : نِصْفُ صَاعٍ عَنْ کُلِّ إنْسَانٍ ، أَوْ قِیمَتُہُ نِصْفُ دِرْہَمٍ۔",,,10470,,
10471,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ تُعْطِیَ الدَّرَاہِمَ فِی صَدَقَۃِ الْفِطْرِ۔",,,10471,,
10472,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ زُہَیْرٍ ، قَالَ : سَمِعْتُ أَبَا إِسْحَاقَ یَقُولُ : أَدْرَکْتُہُمْ وَہُمْ یُعْطُونَ فِی صَدَقَۃِ رَمَضَانَ ، الدَّرَاہِمَ بِقِیمَۃِ الطَّعَامِ۔",,,10472,,
10473,حَدَّثَنَا عُمَرُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَرِہَ أَنْ یُعْطِیَ فِی صَدَقَۃِ الْفِطْرِ وَرِقًا۔,,,10473,,
10474,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَمْرِو بْنِ مُہَاجِرٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : سَمِعْتُہ یَقُولُ : یُؤَدِّی الرَّجُلُ الْمُسْلِمُ عَنْ مَمْلُوکِہِ النَّصْرَانِیِّ صَدَقَۃَ الْفِطْرِ۔",,,10474,,
10475,"حَدَّثَنَا عَبْدُ اللہِ بْنُ دَاوُد ، عَنِ الأَوْزَاعِیِّ ، قَالَ : بَلَغَنِی عَنِ ابْنِ عُمَرَ أَنَّہُ کَانَ یُعْطِی عَنْ مَمْلُوکِہِ النَّصْرَانِیِّ صَدَقَۃَ الْفِطْرِ۔",,,10475,,
10476,"حَدَّثَنَا وَکِیعٌ ، عَنْ ثَوْرٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی، قَالَ: کَتَبَ إلَی عَطَائٍ یَسْأَلُہُ عَنْ عَبِیدِ یَہُودٍ وَنَصَارَی، أُطْعِمُ عَنْہُمْ زَکَاۃَ الْفِطْرِ ؟ قَالَ : نَعَمْ۔",,,10476,,
10477,حَدَّثَنَا ابْنُ عَیَّاشٍ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ مِثْلَ قَوْلِ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ۔,,,10477,,
10478,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : إذَا کَانَ لَکَ عَبِیدٌ نَصَارَی لاَ یُدَارُونَ ، یَعْنِی لِلتِّجَارَۃِ ، فَزَکِّ عَنْہُمْ یَوْمَ الْفِطْرِ۔",,,10478,,
10479,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الْحَارِثِ بْنِ أَبِی ذُبَابٍ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ کَانَ یُعْطِی عَنْ غِلْمَانٍ لَہُ فِی أَرْضِ عُمَرَ الصَّدَقَۃَ۔,,,10479,,
10480,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ فَاطِمَۃَ ، عَنْ أَسْمَائَ ؛ أَنَّہَا کَانَتْ تُعْطِی صَدَقَۃَ الْفِطْرِ عَمَّنْ تَمُونُ مِنْ أَہْلِہَا ؛ الشَّاہِدِ وَالْغَائِبِ۔,,,10480,,
10481,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ قُسَیْطٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ، وَسَعِیدِ بْنِ الْمُسَیَّبِ ، وَعَطَائِ بْنِ یَسَارٍ ، وَأَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، قَالُوا : مَنْ کَانَ لَہُ عَبْدٌ فِی زَرْعٍ ، أَوْ ضَرْعٍ ، فَعَلَیْہِ صَدَقَۃُ الْفِطْرِ",,,10481,,
10482,"وَرُوِیَ عَنْ أَبِی إِسْحَاقَ ، قَالَ : حدَّثَنِی نَافِعٌ ؛ أَنَّ عَبْدَ اللہِ بْنَ عُمَرَ کَانَ یُخْرِجُ صَدَقَۃَ الْفِطْرِ عَنْ أَہْلِ بَیْتِہِ کُلِّہِمْ ؛ حُرِّہِمْ وَعَبْدِہِمْ ، صَغِیرِہِمْ وَکَبِیرِہِمْ ، وَمُسْلِمِہِمْ وَکَافِرِہِمْ مِنَ الرَّقِیقِ۔",,,10482,,
10483,حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یُعْطِی عَنْ عُمَّالِ أَرْضِہِ۔,,,10483,,
10484,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : ہَلْ عَلَی غُلاَمِ مَاشِیَۃٍ ، أَوْ حَرْثٍ زَکَاۃٌ ؟ قَالَ : لاَ۔",,,10484,,
10485,"حَدَّثَنَا حَفْصٌ، عَنْ عَاصِمٍ، عَنْ أَبِی الْعَالِیَۃِ، وَالشَّعْبِیِّ، وَابْنِ سِیرِینَ، قَالُوا: ہِیَ عَلَی الشَّاہِدِ وَالْغَائِبِ۔",,,10485,,
10486,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی أُمَیَّۃُ بْنُ أَبِی عُثْمَانَ ، عَنْ أُمَیَّۃَ بْنِ عَبْدِ اللہِ ؛ أَنَّ نَافِعَ بْنَ عَلْقَمَۃَ کَتَبَ إلَی عَبْدِ الْمَلِکِ بْنِ مَرْوَانَ یَسْأَلُہُ عَنِ الْعَبْدِ فِی الْحَائِطِ وَالْمَاشِیَۃِ ، عَلَیْہِ زَکَاۃُ یَوْمِ الْفِطْرِ ؟ قَالَ : لاَ ، مِنْ أَجْلِ أَنَّ الْحَائِطَ وَالْمَاشِیَۃَ الَّذِی ہُوَ فِیہَا إنَّمَا صَدَّقْتَ بِہِ ، فَلَیْسَ عَلَیْہِ زَکَاۃٌ۔",,,10486,,
10487,"حَدَّثَنَا حَفْصٌ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ: کَانَ لَہُ مُکَاتَبَانِ فَلَمْ یُعْطِ عَنْہُمَا۔",,,10487,,
10488,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَرَی عَنِ الْمُکَاتَبِ صَدَقَۃَ رَمَضَانَ۔,,,10488,,
10489,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : بَلَغَنِی أَنَّ مَیْمُونًا کَانَ یُؤَدِّی عَنِ الْمُکَاتَبِ صَدَقَۃَ الْفِطْرِ۔",,,10489,,
10490,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ کَانَ مُکَاتَبًا وَطَرَحَ عَنْ نَفْسِہِ فَقَد کَفَی نَفْسَہُ ، وَإِنْ لَمْ یَطْرَحْ عَنْ نَفْسِہِ فَیُطْعِم عَنْہُ سَیِّدُہُ۔",,,10490,,
10491,حَدَّثَنَا ابْنُ الدَّرَاوَرْدِیِّ ، عَنْ مُوسَی بْنِ عُقْبَۃَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَرَی عَلَی الْمُکَاتَبِ زَکَاۃَ الْفِطْرِ۔,,,10491,,
10492,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : یُعْطِی کُلَّ قَوْمٍ بِصَاعِ أَہْلِ الْمَدِینَۃِ۔",,,10492,,
10493,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُثْمَانَ بْنِ الأَسْوَد ، عَنْ مُجَاہِدٍ ، قَالَ : بِالْمُدِّ الَّذِی تَقُوتُ بِہِ أَہْلَک۔",,,10493,,
10494,"حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : کَانَ سَالِمٌ یُخْرِجُ زَکَاۃَ الْفِطْرِ بِصَاعِ السُّوقِ یَوْمَئِذٍ قَبْلَ أَنْ یَغْدُوَ ، وَلاَ یُخْرِجُ إِلاَّ تَمْرًا۔",,,10494,,
10495,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ، قَالَ : یُعْطِی کُلُّ قَوْمٍ بِصَاعِہِمْ۔",,,10495,,
10496,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، أَوْ عَنْ فَاطِمَۃَ ، عَنْ أَسْمَائَ ، قَالَتْ : بِالْمُدِّ وَالصَّاعِ الَّذِی یَمْتَارُونَ بِہِ۔",,,10496,,
10497,"حَدَّثَنَا عُمَر ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إِنْ أَعْطَیْتَ بِمُدِّ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَجْزَأَ عَنْک ، وَإِنْ أَعْطَیْتَ بِالْمُدِّ الَّذِی تَقُوتُ بِہِ أَہْلَک أَجْزَأَ عَنْک۔",,,10497,,
10498,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ عَطَائٌ : أَحَبُّ إلَیَّ أَنْ تُعْطِیَ بِمِکْیَالِکَ الْیَوْمَ بِمِکْیَالٍ تَأْخُذُ بِہِ وَتَقْتَاتُ بِہِ۔",,,10498,,
10499,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ أَشْعَثَ ، عَنْ جَعْفَرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَصَدَّقُوا إِلاَّ عَلَی أَہْلِ دِینِکُمْ ، فَأَنْزَلَ اللَّہُ تَعَالَی : {لَیْسَ عَلَیْک ہُدَاہُمْ} ، إلَی قَوْلِہِ : {وَمَا تُنْفِقُوا مِنْ خَیْرٍ یُوَفَّ إلَیْکُمْ} ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَصَدَّقُوا عَلَی أَہْلِ الأَدْیَانِ۔ (نسائی 11052۔ حاکم 285)",,,10499,,
10500,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ سَالِمٍ الْمَکِّیِّ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، قَالَ : کَرِہَ النَّاسُ أَنْ یَتَصَدَّقُوا عَلَی الْمُشْرِکِینَ ، فَأَنْزَلَ اللَّہُ تَعَالَی : {لَیْسَ عَلَیْک ہُدَاہُمْ} ، قَالَ : فَتَصَدَّقَ النَّاسُ عَلَیْہِمْ۔",,,10500,,
10501,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ: لاَ تَصَدَّقْ عَلَی یَہُودِیٍّ ، وَلاَ نَصْرَانِیٍّ إِلاَّ أَنْ لاَ تَجِدَ غَیْرَہُ۔",,,10501,,
10502,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الزِّبْرِقَانِ السَّرَّاجِ ، عَنْ أَبِی رَزِینٍ ، قَالَ : کُنْتُ مَعَ شَقِیق بْنِ سَلَمَۃَ ، فَمَرَّ عَلَیْہِ أُسَارَی مِنَ الْمُشْرِکِینَ فَأَمَرَنِی أَنْ أَتَصَدَّقَ عَلَیْہِمْ ، ثُمَّ تَلاَ ہَذِہِ الآیَۃَ : {وَیُطْعِمُونَ الطَّعَامَ عَلَی حُبِّہِ مِسْکِینًا وَیَتِیمًا وَأَسِیرًا}۔",,,10502,,
10503,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عِکْرِمَۃَ ، قَالَ : أَطْعِمْہُ ، وَلاَ تُعْطِہِ نَفَقَتَہُ۔",,,10503,,
10504,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ أَبِی إِسْحَاقَ، عَنْ أَبِی مَیْسَرَۃَ؛ أَنَّہُ کَانَ یُعْطِی الرُّہْبَانَ مِنْ صَدَقَۃِ الْفِطْرِ۔,,,10504,,
10505,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ عِکْرِمَۃَ ، قَالَ : لاَ تَصَدَّقْ عَلَی الْیَہُودِی وَالنَّصْرَانِیِّ بِنَفَقَۃٍ۔",,,10505,,
10506,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ (ح) وَعَنْ حجَّاج ، عَنْ عَطَائٍ ؛ {وَیُطْعِمُونَ الطَّعَامَ عَلَی حُبِّہِ مِسْکِینًا وَیَتِیمًا وَأَسِیرًا} ، قَالاَ : مِنْ أَہْلِ الْقِبْلَۃِ وَغَیْرِہِمْ۔",,,10506,,
10507,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُمَرَ بْنِ نَافِعٍ ، عَنْ أَبِی بَکْرٍ الْعَبْسِیِّ ، عَنْ عُمَرَ ؛ فِی قولہ تعالی : {إنَّمَا الصَّدَقَات لِلْفُقَرَائِ} ، قَالَ : ہُمْ زَمْنَی أَہْلِ الْکِتَابِ۔",,,10507,,
10508,حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَطَاوُسٍ ؛ أَنَّہُمَا کَرِہَا الصَّدَقَۃَ عَلَی النَّصْرَانِیِّ۔,,,10508,,
10509,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ عُثْمَانَ الْبَتِّیِّ ، عَنِ الْحَسَنِ ؛ فِی قولہ تعالی : {وَیُطْعِمُونَ الطَّعَامَ عَلَی حُبِّہِ مِسْکِینًا وَیَتِیمًا وَأَسِیرًا} قَالَ : الأَسْرَی مِنْ أَہْلِ الشِّرْکِ۔",,,10509,,
10510,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَبِیبُ بْنُ أَبِی حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : سُئِلَ عَنِ الصَّدَقَۃِ فِی مَنْ تُوضَعُ ؟ فَقَالَ : فِی أَہْلِ الْمَسْکَنَۃِ مِنَ الْمُسْلِمِینَ وَأَہْلِ ذِمَّتِہِمْ ، وَقَالَ : قَدْ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُقْسِمُ فِی أَہْلِ الذِّمَّۃِ مِنَ الصَّدَقَۃِ وَالْخُمُسِ۔ (ابوعبید 1992۔ ابن زنجویہ 2291)",,,10510,,
10511,"حَدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، قَالَ: سَأَلْتُ إبْرَاہِیمَ عَنِ الصَّدَقَۃِ عَلَی غَیْرِ أَہْلِ الإِسْلاَمِ؟ فَقَالَ : أَمَّا الزَّکَاۃُ فَلاَ ، وَأَمَّا إِنْ شَائَ رَجُلٌ أَنْ یَتَصَدَّقَ ، فَلاَ بَأْسَ۔",,,10511,,
10512,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ تُعْطِہِمْ مِنَ الزَّکَاۃِ ، وَأَعْطِہِمْ مِنَ التَّطَوُّعِ۔",,,10512,,
10513,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ مِسْعَرٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ إیَاسٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یُعْطَی الْمُشْرِکُونَ مِنَ الزَّکَاۃِ شَیْئًا۔",,,10513,,
10514,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ رَجُلٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : لاَ تُعْطِ الْیَہُودِیَّ وَالنَّصْرَانِیَّ مِنَ الزَّکَاۃِ ، وَلاَ بَأْسَ أَنْ تََتَصَدَّقَ عَلَیْہِمْ۔",,,10514,,
10515,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ إسْمَاعِیلَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یُعْطَی الْمُشْرِکُونَ مِنَ الزَّکَاۃِ ، وَلاَ مِنْ شَیْئٍ مِنَ الْکَفَّارَاتِ۔",,,10515,,
10516,"حَدَّثَنَا جَرِیرٌ ، عَنْ أَشْعَثَ ، عَنْ جَعْفَرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : یُعْطَی مِنَ الزَّکَاۃِ مَنْ لَہُ الدَّارُ وَالْخَادِمُ وَالْفَرَسُ۔",,,10516,,
10517,"حَدَّثَنَا شَرِیکٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا لاَ یَمْنَعُونَ الزَّکَاۃَ مَنْ لَہُ الْبَیْتُ وَالْخَادِمُ۔",,,10517,,
10518,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لاَ یَرَی بَأْسًا أَنْ یُعْطَی مِنْہَا مَنْ لَہُ الْخَادِمُ وَالْمَسْکَنُ ، إذَا کَانَ مُحْتَاجًا۔",,,10518,,
10519,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ شَبِیبِ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : سَأَلْتُ مُقَاتِلَ بْنَ حَیَّانَ عَنْ رَجُلٍ فِی الدِّیوَانِ لَہُ عَطَائٌ وَفَرَسٌ ، وَہُوَ مُحْتَاجٌ ، أُعْطِیہ مِنَ الزَّکَاۃِ ؟ قَالَ : نَعَمْ۔",,,10519,,
10520,حَدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنْ بَعْضِ أَصْحَابِہِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَشْتَرِیَ مِنْ زَکَاۃِ مَالِہِ رَقَبَۃً یُعْتِقُہَا۔,,,10520,,
10521,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ أَنْ یَشْتَرِیَ مِنَ الزَّکَاۃِ رَقَبَۃً یُعْتِقُہَا۔,,,10521,,
10522,حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ أَنَّہُ کَرِہَ أَنْ یَشْتَرِیَ مِنَ الزَّکَاۃِ رَقَبَۃً یُعْتِقُہَا۔,,,10522,,
10523,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا ہُرَیْمٌ ، وَجَعْفَرٌ الأَحْمَر ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لاَ تُعْتِقْ مِنَ الزَّکَاۃِ ۔ زَادَ جَعْفَرٌ : مَخَافَۃَ جَرِّ الْوَلاَئِ۔",,,10523,,
10524,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ بْنِ سَوَّارٍ ، قَالَ : سُئِلَ الْحَسَنُ عَنْ رَجُلٍ اشْتَرَی أَبَاہُ مِنَ الزَّکَاۃِ فَأَعْتَقَہُ ؟ قَالَ : اشْتَرَی خَیْرَ الرِّقَابِ۔",,,10524,,
10525,حَدَّثَنَا أَبُو جَعْفَرٍ ، عَنِ الأَعْمَشِ ، عَنْ حَسَّانَ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یُعْطِی الرَّجُلُ مِنْ زَکَاتِہِ فِی الْحَجِّ ، وَأَنْ یُعْتِقَ مِنْہَا النَّسَمَۃَ۔,,,10525,,
10526,"حَدَّثَنَا حَفْصٌ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَمْرِو بْنِ دِینَارٍ، قَالَ: قَالَ عُمَرُ: إذَا أَعْطَیْتُمْ فَأَغْنُوا۔ یَعْنِی: مِنَ الصَّدَقَۃِ۔",,,10526,,
10527,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یُعْطُوا مِنَ الزَّکَاۃِ مَا یَکُونُ رَأْسَ المَالِ۔",,,10527,,
10528,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْحَسَنِ بْنِ عُمَرَ أَبِی حَمْزَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُسْتَحَبُّ أَنْ یَسُدَّ بِہَا حَاجَۃَ أَہْلِ الْبَیْتِ ، یَعْنِی بِالزَّکَاۃِ۔",,,10528,,
10529,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ، عَنْ سُفْیَانَ، عَنِ أَبِی حَیَّانَ، عَنِ الضَّحَّاکِ، قَالَ: یُعْطَی مِنْہَا مَا بَیْنَہُ وَبَیْنَ الْمِئَتَیْنِ",,,10529,,
10530,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنِ الرَّبِیعِ بْنِ حَبِیبٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : یُعْطَی مِنْہَا مَا بَیْنَہُ وَبَیْنَ الْمِئَتَیْنِ۔",,,10530,,
10531,"حَدَّثَنَا عُمَرُ بْنُ زُرْعَۃَ ، عَنِ ابْنِ سَالِمٍ ، عَنْ عَامِرٍ ، قَالَ : أَعْطِ مِنَ الزَّکَاۃِ مَا دُونَ أَنْ یَحِلَّ عَلَی مَنْ تُعْطِیہِ الزَّکَاۃَ۔",,,10531,,
10532,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنِ الْحَجَّاجِ ، عَنِ الْحَسَنِ بْنِ سَعْدٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ، قَالاَ : لاَ تَحِلُّ الصَّدَقَۃُ لِمَنْ لَہُ خَمْسُونَ دِرْہَمًا ، أَوْ عَرْضُہَا مِنَ الذَّہَبِ۔",,,10532,,
10533,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَکِیمِ بْنِ جُبَیْرٍ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ بن یَزِیدَ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ سَأَلَ وَلَہُ مَا یُغْنِیہِ کَانَ خُدُوشًا ، أَوْ کُدُوحًا یَوْمَ الْقِیَامۃِ ، قِیلَ : یَا رَسُولَ اللہِ ، وَمَا غِنَاؤُہُ ؟ قَالَ : خَمْسُونَ دِرْہَمًا ، أَوْ حِسَابُہَا مِنَ الذَّہَبِ۔ (ترمذی 651۔ ابوداؤد 1623)",,,10533,,
10534,"حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ یُعْطَی مِنَ الزَّکَاۃِ مَنْ لَہُ خَمْسُونَ دِرْہَمًا ، وَلاَ یُعْطَی مِنْہَا أَکْثَرَ مِنْ خَمْسِینَ دِرْہَمًا۔",,,10534,,
10535,"حَدَّثَنَا وَکِیعٌ ، قَالَ : کَانَ سُفْیَانُ ، وَحَسَنٌ ، یَقُولاَنِ : لاَ یُعْطَی مِنْہَا مَنْ لَہُ خَمْسُونَ دِرْہَمًا ، وَلاَ یُعْطَی مِنْہَا أَکْثَرَ مِنْ خَمْسِینَ ، إِلاَّ أَنْ یَکُونَ عَلَیْہِ دَیْنٌ فَیُقْضَی دَیْنُہُ ، وَیُعْطَی بَعْدَ خَمْسِینَ۔",,,10535,,
10536,"حَدَّثَنَا عَبَّادُ بْنُ عَوَّامٍ ، عَنْ مِسْعَرٍ ، قَالَ : سَمِعْتُ حَمَّادًا یَقُولُ : مَنْ لَمْ یَکُنْ عِنْدَہُ مَالٌ یَبْلُغُ فِیہِ الزَّکَاۃَ، أُعْطِیَ مِنَ الزَّکَاۃِ۔",,,10536,,
10537,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْحَسَنِ ، عَنْ عَمْرٍو ، عَنْ فُضَیْلٍ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ عَنْ أَصْحَابِ الأَہْوَائِ ؟ قَالَ : مَا کَانُوا یَسْأَلُونَ إِلاَّ عَنِ الْحَاجَۃِ۔",,,10537,,
10538,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنِ الْحَجَّاجِ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ طَاوُوسٍ ، قَالَ : بَعَثَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مُعَاذًا إلَی الْیَمَنِ ، وَأَمَرَہُ أَنْ یَأْخُذَ الصَّدَقَۃَ مِنَ الْحِنْطَۃِ ، وَالشَّعِیرِ ۔ فَأَخَذَ الْعُرُوضَ الثِّیَابَ مِنَ الْحِنْطَۃِ وَالشَّعِیرِ۔",,,10538,,
10539,حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ؛ أَنَّ عُمَرَ کَانَ یَأْخُذُ الْعُرُوضَ فِی الصَّدَقَۃِ مِنَ الْوَرِقِ وَغَیْرِہَا۔,,,10539,,
10540,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ، قَالَ : قَالَ مُعَاذٌ : ائْتُونِی بِخَمِیس ، أَوْ لَبِیسٍ آخذ مِنْکُمْ۔",,,10540,,
10541,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ؛ أَنَّ مُعَاذًا کَانَ یَأْخُذُ الْعُرُوضَ فِی الصَّدَقَۃِ۔,,,10541,,
10542,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی سِنَانٍ ، عَنْ عَنْتَرَۃَ ؛ أَنَّ عَلِیًّا کَانَ یَأْخُذُ الْعُرُوضَ فِی الْجِزْیَۃِ مِنْ أَہْلِ الإِبَرِ الإِبَرَ، وَمِنْ أَہْلِ الْمَسالِّ الْمَسالَّ ، وَمِنْ أَہْلِ الْحِبَالِ الْحِبَالَ۔,,,10542,,
10543,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ: کَانُوا یَسْتَحِبُّونَ زَکَاۃَ کُلِّ شَیْئٍ مِنْہُ ؛ الْوَرِقُ مِنَ الْوَرِقِ، وَالذَّہَبُ مِنَ الذَّہَبِ ، وَالْبَقَرُ مِنَ الْبَقَرِ ، وَالْغَنَمُ مِنَ الْغَنَمِ۔",,,10543,,
10544,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَرِہَ الْعَرْضَ فِی الصَّدَقَۃِ۔,,,10544,,
10545,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : سَمِعْتُ ابْنَ أَبِی نَجِیحٍ ، یَزْعُمُ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ فِی صَدَقَۃِ التَّمْرِ : أَنْ یُؤْخَذَ الْبَرْنِیُّ مِنَ الْبَرْنِیِّ ، وَاللَّوْنُ مِنَ اللَّوْنِ ، وَلاَ یُؤْخَذُ اللَّوْنُ مِنَ الْبَرْنِیِّ۔",,,10545,,
10546,"حَدَّثَنَا حَفْصٌ ، وَأَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنِ الْمِنْہَالِ ، عَنْ زِرٍّ ، عَنْ حُذَیْفَۃَ ، قَالَ : إِنْ أَعْطَاہَا فِی صِنْفٍ وَاحِدٍ مِنَ الأَصْنَافِ الثَمَانِیَۃِ الَّتِی سَمَّی اللَّہُ تَعَالَی أَجْزَأَہُ۔",,,10546,,
10547,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، قَالَ : قَالَ حُذَیْفَۃُ : إذَا وَضَعْتَ فِی أَیِّ الأَصْنَافِ شِئْتَ ، أَجْزَأَکَ إذَا لَمْ تَجِدْ غَیْرَہُ۔",,,10547,,
10548,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، أَوْ غَیْرِہِ ، عَنِ الْمِنْہَالِ ، عَنْ زِرٍّ ، عَنْ حُذَیْفَۃَ ، قَالَ : إِنْ جَعَلَہَا فِی صِنْفٍ وَاحِدٍ أَجْزَأَہُ۔",,,10548,,
10549,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ؛ أَنَّ عُمَرَ کَانَ یَأْخُذُ الْعَرْضَ فِی الصَّدَقَۃِ ، وَیُعْطِیہَا فِی صِنْفٍ وَاحِدٍ مِمَّا سَمَّی اللَّہُ تَعَالَی۔,,,10549,,
10550,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ (ح) وَعَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالاَ : یُجْزِئکَ أَنْ تَضَعَ الصَّدَقَۃَ فِی صِنْفٍ مِنَ الأَصْنَافِ الَّتِی سَمَّی اللَّہُ تَعَالَی۔",,,10550,,
10551,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ أَبِی جَعْفَرٍ ، عَنِ الرَّبِیعِ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : لاَ بَأْسَ أَنْ تَجْعَلَہَا فِی صِنْفٍ وَاحِدٍ مِمَا قَالَ اللَّہُ تَعَالَی۔",,,10551,,
10552,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : سَأَلْتُہُ : أُعْطِی الصَّدَقَۃَ فِی صِنْفٍ وَاحِدٍ مِنَ الأَصْنَافِ الثَمَانِیَۃِ ؟ قَالَ : نَعَمْ۔",,,10552,,
10553,"حَدَّثَنَا وَکِیعٌ، عَنْ یَزِیدَ، عَنِ الْحَسَنِ، قَالَ: لاَ بَأْسَ أَنْ تَجْعَلَہَا فِی صِنْفٍ وَاحِدٍ مِنَ الأَصْنَافِ الثَمَانِیَۃِ۔",,,10553,,
10554,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ تَجْعَلَہَا فِی صِنْفٍ وَاحِدٍ مِمَّا سَمَّی اللَّہُ تَعَالَی۔",,,10554,,
10555,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : صَرِّفْہَا فِی الأَصْنَافِ ۔ وَقَالَ الْحَسَنُ : فِی أَیِّہَا وَضَعْتَ أَجْزَأَکَ۔",,,10555,,
10556,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : لَوْ وَضَعْتُ الزَّکَاۃَ فِی ہَذَیْنِ الصِّنْفَیْنِ ؛ الْفُقَرَائِ وَالْمَسَاکِینِ لَرَأَیْتُ أَنَّ ذَلِکَ یُجْزِء عَنِّی۔",,,10556,,
10557,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی سَلَمَۃَ ، أَنْ أَبَا عَمْرِو بْنَ حِمَاسٍ أَخْبَرَہُ ، أَنَّ أَبَاہُ حِمَاسًا کَانَ یَبِیعُ الأَدَمَ وَالْجِعَابَ ، وَأَنَّ عُمَرَ قَالَ لَہُ : یَا حِمَاسُ ، أَدِّ زَکَاۃَ مَالَک ، فَقَالَ : وَاللَّہِ مَا لِی مَالٌ ، إنَّمَا أَبِیعُ الأَدَمَ وَالْجِعَابَ ، فَقَالَ : قَوِّمْہُ وَأَدِّ زَکَاتَہُ۔",,,10557,,
10558,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، وَعَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی سَلَمَۃَ ، عَنْ أَبِی عَمْرِو بْنِ حِمَاسٍ ، أَنَّ أَبَاہُ حِمَاسًا کَانَ یَبِیعُ الأَدَمَ وَالْجِعَابَ ، وَأَنَّ عُمَرَ قَالَ لَہُ : ثُمَّ ذَکَرَ مِثْلَہُ ، أَوْ نَحْوَہُ۔",,,10558,,
10559,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ اشْتَرَی مَتَاعًا فَحَلَّتْ فِیہِ الزَّکَاۃُ ؟ فَقَالَ : یُزَکِّیہ بِقِیمَتِہِ یَوْمَ حَلَّتْ۔",,,10559,,
10560,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لَیْسَ فِی الْعُرُوضِ زَکَاۃٌ ، إِلاَّ عُرْضٍ فِی تِجَارَۃٍ ، فَإِنَّ فِیہِ زَکَاۃٌ۔",,,10560,,
10561,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ، عَنْ أَبِی ہِلاَلٍ، عَنِ ابْنِ سِیرِینَ، قَالَ فِی الْمَتَاعِ: یُقَوَّمُ، ثُمَّ تُؤَدَّی زَکَاتُہُ۔",,,10561,,
10562,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَشْتَرِی الْمَتَاعَ فَیَمْکُثُ السِّنِینَ ، یُزَکِّیِہِ ؟ قَالَ : لاَ۔",,,10562,,
10563,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ طَلْحَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کُلُّ شَیْئٍ أُرِیدَ بِہِ التِّجَارَۃُ فَفِیہِ الزَّکَاۃُ ، وَإِنْ کَانَ لَبَنًا ، أَوْ طِینًا ۔ قَالَ : وَکَانَ الْحَکَمُ یَرَی ذَلِکَ۔",,,10563,,
10564,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَمَّدِ بْنِ عُقْبَۃَ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَ أَبُو بَکْرٍ إذَا أَعْطَی النَّاسَ الْعَطَائَ سَأَلَ الرَّجُلَ : أَلَکَ مَالٌ ؟ فَإِنْ قَالَ : نَعَمْ ، زَکَّی مَالَہُ مِنْ عَطَائِہِ ، وَإِلاَّ سَلَّمَ لَہُ عَطَائَہُ۔",,,10564,,
10565,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : کَانَ یُعْطِینَا العَطَائَ فِی الرَّسَلِ فَنُزَکِّیِہِ۔",,,10565,,
10566,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، قَالَ : کَانَ ابْنُ مَسْعُودٍ یُزَکِّی أَعْطِیَّاتِہِمْ مِنْ کُلِّ أَلْفٍ خَمْسَۃً وَعِشْرِینَ۔",,,10566,,
10567,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدٍ الْقَارِی ، وَکَانَ عَلَی بَیْتِ الْمَالِ فِی زَمَنِ عُمَرَ مَعَ عَبْدِ اللہِ بْنِ الأَرْقَمِ ، فَکَانَ إِذَا خَرَجَ الْعَطَائُ جَمَعَ عُمَرُ أَمْوَالَ التِّجَارَۃِ ، فَحَسَبَ عَاجِلَہَا وَآجِلَہَا ، ثُمَّ یَأْخُذُ الزَّکَاۃَ مِنَ الشَّاہِدِ وَالْغَائِبِ۔,,,10567,,
10568,"حَدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ ، عَنْ مُحَمَّدِ بْنِ عُقْبَۃَ ، عَنِ الْقَاسِمِ ، قَالَ : کَانَ أَبُو بَکْرٍ إذَا أَعْطَی الرَّجُلَ الْعَطَائَ سَأَلَہُ ، ثُمَّ ذَکَرَ نَحْوَ حَدِیثِ وَکِیعٍ۔",,,10568,,
10569,حَدَّثَنَا عَبْدُ الرَّحِیمِ ، وَوَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ مُخَارِقٍ ، عَنْ طَارِقٍ ، أَنَّ عُمَرَ بْنَ الْخَطَّابِ کَانَ یُعْطِیہِمُ الْعَطَائَ وَلاَ یُزَکِّیہِ۔,,,10569,,
10570,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : رَأَیْتُ الأُمَرَائَ إذَا أُعْطَوُا الْعَطَائَ زَکَّوْہُ۔",,,10570,,
10571,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ، عَنْ عُمَرَ بْنِ عَبْدِالْعَزِیزِ؛ أَنَّہُ کَانَ یُزَکِّی الْعَطَائَ وَالْجَائِزَۃَ۔,,,10571,,
10572,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ بَعْضِ أَصْحَابِہِ ، عَنِ ابْنِ مَسْعُودٍ ؛ أَنَّہُ کَانَ یُعْطِی الْعَطَائَ وَیُزَکِّیہِ۔,,,10572,,
10573,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَجَّاجِ ، عَنِ الْحَکَمِ ، عَنِ ابْنِ عَبَّاسٍ (ح) وَعَنْ سَالِمٍ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ؛ فِی قولہ تعالی : {وَآتُوا حَقَّہُ یَوْمَ حَصَادِہِ} قَالاَ : نَسَخَتْہَا الْعُشْرُ وَنِصْفُ الْعُشْرِ۔",,,10573,,
10574,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ شِبَاکٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : نَسَخَتْہَا الْعُشْرُ وَنِصْفُ الْعُشْرِ۔",,,10574,,
10575,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ عَاصِمٍ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : کَانُوا یُعْطُونَ شَیْئًا غَیْرَ الصَّدَقَۃِ۔",,,10575,,
10576,"حَدَّثَنَا ابْنُ الْمُبَارَکِ ، عَنْ مُحَمَّدِ بْنِ سُلَیْمَانَ ، عَنْ حَیَّانَ الأَعْرَجِ ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛فِی قولہ تعالی : {وَآتُوا حَقَّہُ یَوْمَ حَصَادِہِ}قَالَ : الزَّکَاۃُ۔",,,10576,,
10577,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ إبْرَاہِیمَ بْنِ نَافِعٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : الزَّکَاۃُ۔",,,10577,,
10578,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، وَنَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ {وَآتُوا حَقَّہُ یَوْمَ حَصَادِہِ} قَالَ : کَانُوا یُعْطُونَ مَن اعْتَرَاہم شَیئًا سِوَی الصَّدَقَۃِ۔",,,10578,,
10579,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ عَطَاء ؛ فِی قولہ : {وَآتُوا حَقَّہُ یَوْمَ حَصَادِہِ} قَالَ : مَنْ حَضَرَک یَوْمَئِذٍ أَنْ تُعْطِیَہُ الْقَبَضَاتِ ، وَلَیْسَ بِزَکَاۃٍ۔",,,10579,,
10580,"حَدَّثَنَا جَرِیرٌ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ؛ فِی قولہ تعالی : {وَآتُوا حَقَّہُ یَوْمَ حَصَادِہِ} قَالَ : إذَا حَصَدْتَہُ فَحَضَرَک الْمَسَاکِینُ طَرَحْتَ لَہُمْ مِنْہُ ، وَإِذَا طَبَنْتَہُ طَرَحْتَ لَہُمْ مِنْہُ ، وَإِذَا کَدَّسْتَہُ طَرَحْتَ لَہُمْ مِنْہُ ، وَإِذَا نَقَّیْتَہُ وَأَخَذْتَ فِی کَیْلِہِ حَثَوْتَ لَہُمْ مِنْہُ ، وَإِذَا عَلِمْتَ کَیْلَہُ عَزَلْتَ زَکَاتَہُ ، وَإِذَا أَخَذْتَ فِی جُذَاذِ النَّخْلِ طَرَحْتَ لَہُمْ مِنَ الثَّفَارِیقِ وَالتَّمْرِ ، وَإِذَا أَخَذْتَ فِی کَیْلِہِ حَثَوْت لَہُمْ مِنْہُ ، وَإِذَا عَلِمْتَ کَیْلَہُ عَزَلْتَ زَکَاتَہُ۔\n\n حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ فِی قولہ تعالی : {وَآتُوا حَقَّہُ یَوْمَ حَصَادِہِ} قَالَ: زَکَاتُہُ یَوْمَ کَیْلِہِ۔",,,10580,,
10581,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ السُّدِّیِّ ، قَالَ : ہَذِہِ مَدَنِیَّۃٌ مَکِّیَّۃٌ ، نَسَخَتْہَا الْعُشْرُ وَنِصْفُ الْعُشْرِ ، قُلْتُ : عَمَّنْ ؟ قَالَ : عَنِ الْفُقَہَائِ ۔ یَعْنِی قَوْلَہُ تَعَالَی : {وَآتُوا حَقَّہُ یَوْمَ حَصَادِہِ}۔",,,10581,,
10582,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ (ح) وَعَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ قَالاَ : {وَآتُوا حَقَّہُ یَوْمَ حَصَادِہِ} قَالاَ : یُعْطِی ضِغْثًا۔",,,10582,,
10583,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : نَحْوَ الضِّغْثِ۔",,,10583,,
10584,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : نَسَخَتْہَا الزَّکَاۃُ۔",,,10584,,
10585,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ ، عَنِ الضَّحَّاکِ ، قَالَ : نَسَخَتِ الزَّکَاۃُ کُلَّ صَدَقَۃٍ فِی الْقُرْآنِ۔",,,10585,,
10586,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ عَطِیَّۃَ ، قَالَ : نَسَخَتْہَا الْعُشْرُ ، وَنِصْفُ الْعُشْرِ۔",,,10586,,
10587,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ؛ فِی قَوْلِہِ تَعَالَی : {وَآتُوا حَقَّہُ یَوْمَ حَصَادِہِ} قَالَ: زَکَاتُہُ یَوْمَ کَیْلِہِ۔",,,10587,,
10588,حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ حَجَّاجٍ، عَنِ الْحَکَمِ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ؛ {وَآتُوا حَقَّہُ یَوْمَ حَصَادِہِ} نَسَخَتْہَا الْعُشْرُ ، وَنِصْفُ الْعُشْرِ۔,,,10588,,
10589,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : یُخْرِجُ مَکَانَہَا۔",,,10589,,
10590,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَصْحَابِہِ قَالُوا : إذَا أَخْرَجَ زَکَاۃَ مَالِہِ فَضَاعَتْ ، فَلْیُزَکِّ مَرَّۃً أُخْرَی۔",,,10590,,
10591,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ مَعْمَرٍ ، عَنْ حَمَّادٍ ؛ فِی الرَّجُلِ یَبْعَثُ بِصَدَقَتِہِ فَتَہْلِکُ قَبْلَ أَنْ تَصِلَ إلَی أَہْلِہَا ، قَالَ : ہِیَ بِمَنْزِلَۃِ رَجُلٍ بَعَثَ إلَی غَرِیمِہِ بِدَیْنٍ ، فَلَمْ یَصِلْ إلَیْہِ الْمَالُ حَتَّی ہَلَکَ۔",,,10591,,
10592,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : لاَ تُجْزِیئُ۔",,,10592,,
10593,حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ حَسَّانَ بْنِ إبْرَاہِیمَ ، عَنْ إبْرَاہِیمَ الصَّائِغِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ إذَا أَخْرَجَ زَکَاۃَ مَالِہِ فَضَاعَتْ ، أَنَّہَا تُجْزِیئُ عَنْہُ۔,,,10593,,
10594,"حَدَّثْنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ أَخْرَجَ زَکَاۃَ مَالِہِ فَضَاعَتْ ، قَالَ : لاَ تُجْزِیئُ عَنْہُ حَتَّی یَضَعَہَا مَوَاضِعَہَا۔",,,10594,,
10595,"حَدَّثَنَا أَبُو بَحْرٍ الْبَکْرَاوِیُّ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : یُخْرِجُ مَکَانَہَا۔",,,10595,,
10596,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْن جُرَیْجٍ ، قَالَ : أَخْبَرَنِی عَمْرُو بْنُ دِینَارٍ ، عَنْ طَاوُوسٍ قَالاَ : إذَا کَانَ الْخَلِیطَانِ یَعْمَلاَنِ فِی أَمْوَالِہِمَا ، فَلاَ تُجْمَعُ أَمْوَالُہُمَا فِی الصَّدَقَۃِ۔",,,10596,,
10597,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرْت عَطَائً عَنْ قَوْلِ طَاوُوس ، فَقَالَ : مَا أُرَاہُ إِلاَّ حَقًّا۔",,,10597,,
10598,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، أَنَّہُ کَانَ یَقُولُ : إذَا کَانَ لِلرَّجُلِ عِشْرُونَ شَاۃ ، وَلِرَجُلٍ آخَر عِشْرُونَ شَاۃ ، وَرَاعِیہِمَا وَاحِدٌ ، یَشْرَعَانِ مَعًا وَیَرِدَانِ مَعًا ، قَالَ : فِیہَا الزَّکَاۃُ۔",,,10598,,
10599,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ یَزِیدَ مَوْلَی سَلَمَۃَ ، قَالَ : کَانَ یُعْرَضُ عَلَی سَلَمَۃَ صَدَقَۃُ إبِلِہِ فَیَأْبَی أَنْ یَشْتَرِیَہَا۔",,,10599,,
10600,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ یَعْلَی بْنِ عَطَائٍ ، عَنْ مُسْلِمِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لاَ تَشْتَرِی طُہرَۃَ مَالِک۔",,,10600,,
10601,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی أَبُو الزُّبَیْرِ ، أَنَّہُ سَمِعَ جَابِرًا یَقُولُ : إذَا جَائَ الْمُصَدِّقُ فَادْفَعْ إلَیْہِ صَدَقَتَکَ ، وَلاَ تَبْتَعْہَا ، قَالَ : فَإِنَّہُمَ یَقُولُونَ ابْتَعْہَا فَأَقُولُ : لاَ ، إنَّمَا ہِیَ لِلَّہِ۔",,,10601,,
10602,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : سَأَلْتُہُ : أَیَشْتَرِی الرَّجُلُ صَدَقَتَہُ ؟ فَقَالَ : لاَ یَشْتَرِیہَا مِنَ الْمُصَدِّقِ حَتَّی یُخْرِجَہَا ، وَلاَ یَشْتَرِیہَا إذَا أَخْرَجَہَا حَتَّی تَخْتَلِطَ بِغَنَمٍ کَثِیرٍ۔",,,10602,,
10603,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّ مَنْ مَضَی کَانُوا یَکْرَہُونَ ابْتِیَاعَ صَدَقَاتِہِمْ ، قَالَ : وَإِنْ فَعَلْتَ بَعْدَ مَا تُقْبَضَ مِنْک فَلاَ بَأْسَ بِہِ۔",,,10603,,
10604,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن أَبِیہِ ، قَالَ : حُمِلَ عُمَرُ عَلَی فَرَسٍ فِی سَبِیلِ اللہِ فَرَآہُ ، أَوْ شَیْئًا مِنْ ثِیَابِہِ تُبَاعُ فِی السُّوقِ ، فَأَرَادَ أَنْ یَشْتَرِیَہُ فَسَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَ : اُتْرُکْہُ حَتَّی تُوَافِیَک یَوْمَ الْقِیَامَۃِ۔ (مسلم 1239۔ احمد 1/25)",,,10604,,
10605,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ ، عَنْ عَبْدِ اللہِ بْنِ عَامِرٍ ، عَنِ الزُّبَیْرِ بْنِ الْعَوَّامِ ؛ أَنَّ رَجُلاً حَمَلَ عَلَی فَرَسٍ فِی سَبِیلِ اللہِ ، فَرَأَی فَرَسًا ، أَوْ مُہْرَۃً تُبَاعُ یُنْسَبُ إلَی فَرَسِہِ ، فنہیَ عَنْہَا۔ (ابن ماجہ 2393۔ احمد 1/164),,,10605,,
10606,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیم (ح) وَعَنْ دَاوُدَ ، عَنْ أَبِی الْعَالِیَۃِ ؛ أَنَّ أَبَا أُسَامَۃَ حَمَلَ عَلَی مُہْرٍ لَہُ فِی سَبِیلِ اللہِ ، فَرَآہُ بَعْدَ ذَلِکَ نِضْوًا یُبَاعُ ، قَالَ : فَقُلْتُ لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : قَدْ عَرَفْتُ عُرْفَہُ ، فَنَہَانِی عَنْہُ۔ (طبرانی 4668)",,,10606,,
10607,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ عُمَرُ : إذَا تَحَوَّلَتِ الصَّدَقَۃُ إلَی غَیْرِ الَّذِی تُصُدِّقَ عَلَیْہِ ، فَلاَ بَأْسَ أَنْ یَشْتَرِیَہَا۔",,,10607,,
10608,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ عُمَرَ حَمَلَ عَلَی فَرَسٍ فِی سَبِیلِ اللہِ ، فَرَآہَا فِی السُّوقِ تُبَاعُ ، فَسَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَشْتَرِیَہَا ، فَقَالَ : لاَ ، دَعْہَا حَتَّی تُوَافِیَک یَوْمَ الْقِیَامَۃِ۔ (بخاری 2775۔ مسلم 4)",,,10608,,
10609,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنِ الشَّعْبِیِّ ، عَنْ زَیْدِ بْنِ حَارِثَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، نَحْوًا مِنْ حَدِیثِ أُسَامَۃَ۔",,,10609,,
10610,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ؛ أَنَّہُ سُئِلَ عَنِ الرَّجُلِ یُصِیبُ مِنْ صَدَقَتِہِ ؟ قَالَ : یَنْقُصُ مِنْ أَجْرِہِ بِقَدْرِ مَا أَصَابَ مِنْہَا۔",,,10610,,
10611,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَہْضَمِ بْنِ عَبْدِ اللہِ ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَن مُحَمَّدِ بْنِ زَیْدٍ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ شِرَائِ الصَّدَقَاتِ حَتَّی تُقْبَضَ۔ (ابن ماجہ 2196۔ دارقطنی 44)",,,10611,,
10612,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ؛ سُئِلَ : أَیَشْتَرِی صَدَقَتَہُ قَبْلَ أَنْ تُعْقَلَ؟ فَکَرِہَہُ۔",,,10612,,
10613,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ الشُّعَیثیِّ ، عَنْ مَکْحُولٍ قَالَ : لاَ تُشْتَرَی الصَّدَقَۃُ حَتَّی تُوسَمَ وَتُعْقَلَ۔",,,10613,,
10614,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مُحَمَّدِ بْنِ رَاشِدٍ ، عَنْ مَکْحُولٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُشْتَرَی الصَّدَقَۃُ حَتَّی تُوسَمَ۔",,,10614,,
10615,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَرِہَا أَنْ یَشْتَرِیَ الرَّجُلُ شَیْئًا مِنْ صَدَقَۃِ مَالِہِ ، حَتَّی یَحُولَ مِنْ عِنْدِ الْمُصَدِّقِ۔,,,10615,,
10616,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی أَبُو الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّہُ سَمِعَہُ یَنْہَی عَنْ بَیْعِ الصَّدَقَۃِ قَبْلَ أَنْ تُخْرَج۔",,,10616,,
10617,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی مُوسَی بْنُ عُقْبَۃَ ، عَنْ غَیْرِ وَاحِدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَہَی أَنْ تُبَاعَ الصَّدَقَۃُ حَتَّی تُعْقَلَ وَتُوسَمَ۔",,,10617,,
10618,"حَدَّثَنَا ابْن عُیَیْنَۃَ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ، أَنَّ عُمَرَ سَأَلَ رَجُلاً عَنْ أَرْضٍ لَہُ بَاعَہَا ؟ فَقَالَ لَہُ : احْرُزْ مَالَک ، وَاحْفِرْ لَہُ تَحْتَ فِرَاشِ امْرَأَتِکَ ، قَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ ، أَلَیْسَ بِکَنْزٍ ؟ فَقَالَ : لَیْسَ بِکَنْزٍ مَا أُدِّیَ زَکَاتُہُ۔",,,10618,,
10619,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنْ مُحَمَّدِ بْنِ أَبِی حَرْمَلَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : مَا أُدِّیَ زَکَاتُہُ فَلَیْسَ بِکَنْزٍ۔",,,10619,,
10620,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ، عَنْ حَجَّاجٍ، عَنْ أَبِی الزُّبَیْرِ، عَنْ جَابِرٍ، قَالَ: أَیُّ مَالٍ أُدِّیَ زَکَاتُہُ فَلَیْسَ بِکَنْزٍ۔",,,10620,,
10621,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ مَکْحُولٍ ، عَنِ ابْنِ عُمَرَ ، مِثْلَہُ۔,,,10621,,
10622,"حَدَّثَنَا وَکِیعٌ، عَنْ شَرِیکٍ، عَنْ أَبِی إِسْحَاقَ، عَنْ عِکْرِمَۃَ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: مَا أُدِّیَ زَکَاتُہُ فَلَیْسَ بِکَنْزٍ۔",,,10622,,
10623,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حَنْظَلَۃَ ، عَنْ مُجَاہِدٍ ، وَعَطَائٍ قَالاَ : لَیْسَ مَالٌ بِکَنْزٍ أُدِّیَ زَکَاتُہُ ، وَإِنْ کَانَ تَحْتَ الأَرْضِ ، وَإِنْ کَانَ لاَ یُؤَدَّی زَکَاتُہُ فَہُوَ کَنْزٌ ، وَإِنْ کَانَ عَلَی وَجْہِ الأَرْضِ۔",,,10623,,
10624,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَطِیَّۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : وُجِدَ لِرَجُلٍ عَشَرَۃُ آلاَفٍ بَعْدَ مَوْتِہِ مَدْفُونَۃً ، قَالَ : فَقَالُوا : ہَذَا کَنْزٌ ، مَا کَانَ یُؤَدِّی زَکَاتَہُ ، فَقَالَ ابْنُ عُمَرَ : لَعَلَّہُ کَانَ یُؤَدِّی عَنْہَا مِنْ غَیْرِہَا۔",,,10624,,
10625,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَرَوْنَ فِی أَمْوَالِہِمْ حَقًّا سِوَی الزَّکَاۃِ۔",,,10625,,
10626,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، وَابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ؛ {فِی أَمْوَالِہِمْ حَقٌّ مَعْلُومٌ} ، قَالَ : سِوَی الزَّکَاۃِ۔",,,10626,,
10627,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ بَیَانٍ ، عَنْ عَامِرٍ ، قَالَ : فِی الْمَالِ حَقٌّ سِوَی الزَّکَاۃِ۔",,,10627,,
10628,"حَدَّثَنَا مُعَاذٌ ، قَالَ : حدَّثَنَا حَاتِمُ بْنُ أَبِی صَغِیرَۃَ أَبُو یُونُسَ ، قَالَ : حَدَّثَنَا رِیَاحُ بنُ عَبِیْدَۃَ ، عَنْ قَزَعَۃَ ، قَالَ : قُلْتُ لِاِبْنِ عُمَرَ : إنَّ لِی مَالاً ، فَمَا تَأْمُرُنِی إلَی مَنْ أَدْفَعُ زَکَاتَہُ ؟ قَالَ : ادْفَعْہَا إلَی وَلِیِّ الْقَوْمِ ، یَعْنِی الأُمَرَائَ ، وَلَکِنْ فِی مَالِکَ حَقٌّ سِوَی ذَلِکَ یَا قَزَعَۃُ۔",,,10628,,
10629,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ أَبِی حَیَّانَ ، قَالَ : حدَّثَنِی مُزَاحِمُ بْنُ زُفَرَ ، قَالَ : کُنْتُ جَالِسًا عِنْدَ عَطَائٍ ، فَأَتَاہُ أَعْرَابِیٌّ فَسَأَلَہُ : إنَّ لِی إبِلاً ، فَہَلْ عَلَیَّ فِیہَا حَقٌّ بَعْدَ الصَّدَقَۃِ ؟ قَالَ : نَعَمْ۔",,,10629,,
10630,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَنْ أَدَّی زَکَاۃَ مَالِہِ فَلَیْسَ عَلَیْہِ جُنَاحٌ أَنْ لاَ یَتَصَدَّقَ۔",,,10630,,
10631,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : فِی الْمَالِ حَقٌّ سِوَی الزَّکَاۃِ۔",,,10631,,
10632,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : جَائَتِ امْرَأَۃُ عَبْدِ اللہِ إلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَتْ : إنَّ فِی حِجْرِی بَنِی أَخٍ لِی کَلاَلَۃً ، فَیُجْزِینِی أَنْ أَجْعَلَ زَکَاۃَ حُلِیِّی فِیہِمْ ؟ قَالَ : نَعَمْ۔ (بخاری 1466۔ مسلم 45)",,,10632,,
10633,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ أَنْ تَجْعَلَ زَکَاتَکَ فِی ذَوِی قَرَابَتِکَ ، مَا لَمْ یَکُونُوا فِی عِیَالِک۔",,,10633,,
10634,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الْخَالِقِ الشَّیْبَانِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : إنَّ أَحَقَّ مَنْ دَفَعْتُ إلَیْہِ زَکَاتِی یَتِیمِی وَذُو قَرَابَتِی۔",,,10634,,
10635,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّ امْرَأَتَہُ سَأَلَتْہُ عَنْ بَنِی أَخٍ لَہَا أَیْتَامٍ فِی حِجْرِہَا ، تُعْطِیہِمْ مِنَ الزَّکَاۃِ ؟ قَالَ : نَعَمْ۔",,,10635,,
10636,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إِبْرَاہِیمَ بْنِ أَبِی حَفْصَۃَ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الْخَالَۃِ ، تُعْطَی مِنَ الزَّکَاۃِ ؟ فَقَالَ سَعِید : مَا لَمْ یُغْلَقُ عَلَیْکُمْ بَابٌ۔",,,10636,,
10637,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ ہِشَامٍ ، أَوْ غَیْرِہِ ، عَنِ الْحَسَنِ ؛ أَنَّہُمَا رَخَّصَا فِی ذِی الْقَرَابَۃِ۔,,,10637,,
10638,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : قُلْتُ لِعَطَائٍ : أَیَجْزِی الرَّجُلَ أَنْ یَضَعَ زَکَاتَہُ فِی أَقَارِبِہِ ؟ قَالَ : نَعَمْ ، إذَا لَمْ یَکُونُوا فِی عِیَالِہِ۔",,,10638,,
10639,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ بْنِ نُبَیْطٍ ، عَنِ الضَّحَّاکِ ، قَالَ : إذَا کَانَ لَکَ أَقَارِبُ فُقَرَائُ فَہُمْ أَحَقُّ بِزَکَاتِکَ مِنْ غَیْرِہِمْ۔",,,10639,,
10640,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زُبَیْدٍ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ عَنِ الأُخْتِ ، تُعْطَی مِنَ الزَّکَاۃِ ؟ قَالَ : نَعَمْ۔",,,10640,,
10641,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُعْطِی زَکَاتَہُ ذَوِی قَرَابَتِہِ ؟ قَالَ : نَعَمْ ، مَا لَمْ یَکُونُوا فِی عِیَالِہِ۔",,,10641,,
10642,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَنْظَلَۃَ ، عَنْ طَاوُوسٍ ، قَالَ: سَأَلَہُ رَجُلٌ ، فَقَالَ: إنَّ عِنْدِی نَاسًا مِنْ أَہْلِی فُقَرَائَ؟ فَقَالَ : أَخْرِجْہَا مِنْک وَمِنْ أَہْلِک۔",,,10642,,
10643,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ ابْنَۃِ سِیرِینَ ، عَنْ أُمِّ الرَّائِحِ بِنْتِ صُلَیْعٍ ، عَنْ عَمِّہَا سَلْمَانَ بْنِ عَامِرٍ الضَّبِّیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الصَّدَقَۃُ عَلَی غَیْرِ ذِی الرَّحِمِ صَدَقَۃٌ ، وَعَلَی ذِی الرَّحِمِ اثْنَتَانِ ؛ صَدَقَۃٌ وَصِلَۃٌ۔ (ترمذی 658۔ نسائی 2363)",,,10643,,
10644,"قَالَ أَبُو بَکْرٍ : وَسَمِعْتُ وَکِیعًا یَذْکُرُ ، عَنْ سُفْیَانَ ، أَنَّہُ قَالَ : لاَ یُعْطِیہَا مَنْ یُجْبَر عَلَی نَفَقَتِہِ۔",,,10644,,
10645,"حَدَّثَنَا جَرِیرٌ ، عَنْ ثَعْلَبَۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تُقْبَلُ وَرَحِمٌ مُحْتَاجَۃٌ۔",,,10645,,
10646,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُعْطِی زَکَاتَہُ إلَی فَقِیرٍ ، ثُمَّ یَتَبَیَّنُ لَہُ أَنَّہُ غَنِیٌّ ؟ قَالَ : أَجْزَأَ عَنْہُ۔",,,10646,,
10647,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إسْمَاعِیلَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یُعْطِی مِنْ زَکَاتِہِ الْغَنِیَّ ، وَہُوَ لاَ یَعْلَمُ ؟ قَالَ : لاَ یُجْزئہُ۔",,,10647,,
10648,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ الأَلْہَانِیِّ ، قَالَ : سَمِعْتُ أَبَا أُمَامَۃَ الْبَاہِلِیَّ یَقُولُ : حِلْیَۃُ السَّیْفِ مِنَ الْکُنُوزِ",,,10648,,
10649,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عُبَیدِ اللہِ بْنِ عُبَیْدٍ ، قَالَ : قُلْتُ لِمَکْحُولٍ : یَا أَبَا عَبْدِ اللہِ ، إنَّ لِی سَیْفًا فِیہِ خَمْسُونَ وَمِئَۃُ دِرْہَمٍ ، عَلَیَّ فِیہَا زَکَاۃٌ ؟ فَقَالَ : أَضِفْ إلَیْہَا مَا کَانَ لَکَ مِنْ ذَہَبٍ وَفِضَّۃٍ ، فَعَلَیْک فِیہِ الزَّکَاۃُ۔",,,10649,,
10650,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ عَطَائً ، وَحَمَّادًا ، وَإِبْرَاہِیمَ عَنِ الْقَدَحِ الْمُفَضَّضِ ، وَالسَّیْفِ الْمُحَلَّی ، وَالْمِنْطَقَۃِ الْمُحَلاَّۃِ ، إِذَا جَمَعْتُہُ فَکَانَ فِیہِ مِئَتَا دِرْہَمٍ ، أُزَکِّیہِ ؟ قَالُوا : لاَ",,,10650,,
10651,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ مَالِکِ بْنِ عَبْدِ اللہِ الْکِلاَعِیِّ ، قَالَ : سَمِعْتُ مَالِکَ بْنَ مِغْوَلٍ یَقُولُ : حِلْیَۃُ السَّیْفِ مِنَ الْکُنُوزِ۔",,,10651,,
10652,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : إذَا کَانَ عَلَیْک دَیْنٌ فَلاَ تُزَکِّہِ۔",,,10652,,
10653,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَکُونُ عَلَیْہِ الدَّیْنُ السَّنَۃَ وَالسَّنَتَیْنِ ، أَیُزَکِّیہِ ؟ قَالَ : لاَ۔",,,10653,,
10654,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا کَانَ حِینَ یُزَکِّی الرَّجُلُ لِلرَّجُلِ مَالَہُ ، نَظَرَ مَا لِلنَّاسِ عَلَیْہِ فَیَعْزِلُہُ۔",,,10654,,
10655,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ فُضَیْلٍ ، قَالَ : لاَ تُزَکِّ مَا لِلنَّاسِ عَلَیْک۔",,,10655,,
10656,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لِلزَّکَاۃِ حَدٌّ مَعْلُومٌ ، فَإِذَا جَائَ ذَلِکَ حَسَبَ مَالَہُ الشَّاہِدَ وَالْغَائِبَ ، فَیُؤَدِّی عَنْہُ إِلاَّ مَا کَانَ مِنْ دَیْنٍ عَلَیْہِ۔",,,10656,,
10657,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : اطْرَحْ مَا کَانَ عَلَیْک مِنَ الدَّیْنِ ، ثُمَّ زَکِّ مَا بَقِیَ۔",,,10657,,
10658,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنِ السَّائِبِ بْنِ یَزِیدَ ، قَالَ : سَمِعْتُ عُثْمَانَ یَقُولُ : ہَذَا شَہْرُ زَکَاتِکُمْ ، فَمَنْ کَانَ عَلَیْہِ دَیْنٌ فَلْیَقْضِہِ ، وَزَکُّوا بَقِیَّۃَ أَمْوَالِکُمْ۔",,,10658,,
10659,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا عَنِ الرَّجُلِ یَکُونُ عَلَیْہِ الدَّیْنُ وَفِی یَدِہِ مَالٌ ، أَیُزَکِّیہِ ؟ قَالَ : نَعَمْ ، عَلَیْہِ زَکَاتُہُ ، أَلاَ تَرَی أَنَّہُ ضَامِنٌ ۔ وَسَأَلْت رَبِیعَۃَ ؟ فَقَالَ : مِثْلَ قَوْلِ حَمَّادٍ۔",,,10659,,
10660,"حَدَّثَنَا حَفْصٌ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَ عَبْدَ اللہِ بْنَ رَوَاحَۃَ إلَی الْیَمَنِ یَخْرُصُ عَلَیْہِمُ النَّخْلَ ۔ قَالَ : فَسَأَلْتُ الشَّعْبِیَّ : أَفَعَلَہُ ؟ قَالَ : لاَ۔ (طبرانی 2136)",,,10660,,
10661,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِی بَکْرِ بْنِ حَزْمٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا بَعَثَ الْخَارِصَ ، أَمَرَہُ أَنْ لاَ یَخْرُصَ النَّخْلَ الْعَرَایَا۔ (عبدالرزاق 721)",,,10661,,
10662,"حَدَّثَنَا أَبُو دَاوُدَ ، وَغُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ خُبَیْبِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : سَمِعْتُ عَبْدَ الرَّحْمَن بْنَ مَسْعُودٍ یَقُولُ : جَائَ سَہْلُ بْنُ أَبِی حَثْمَۃَ إلَی مَجْلِسَنا ، فَحَدَّثَ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : إذَا خَرَصْتُمْ فَخُذُوا وَدَعُوا الثُّلُثَ ، فَإِنْ لَمْ تَجِدُوا الثُّلُثَ فَالرُّبْعَ۔ (ترمذی 643۔ ابوداؤد 1601)",,,10662,,
10663,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ بُشَیْرِ بْنِ یَسَارٍ ؛ أَنَّ عُمَرَ کَانَ یَبْعَثُ أَبَا خَیْثَمَۃَ خَارِصًا لِلنَّخْلِ ، فَقَالَ : إذَا أَتَیْتَ أَہْلَ الْبَیْتِ فِی حَائِطِہِمْ فَلاَ تَخْرُصْ عَلَیْہِمْ قَدْرَ مَا یَأْکُلُونَ۔",,,10663,,
10664,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، أَنَّہُ سَمِعَہُ یَقُولُ : خَرَصَہَا ابْنُ رَوَاحَۃَ ، یَعْنِی خَیْبَرَ أَرْبَعِینَ أَلْفَ وَسْقٍ ، وَزَعَمَ أَنَّ الْیَہُودَ لَمَّا خَیَّرَہُمُ ابْنُ رَوَاحَۃَ أَخَذُوا التَّمْرَ وَعَلَیْہِمْ عِشْرُونَ أَلْفَ وَسْقٍ۔",,,10664,,
10665,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : خَفِّفْ عَلَی النَّاسِ فِی الْخَرْصِ ، فَإِنَّ فِی الْمَالِ الْعَرِیَّۃَ وَالْوَطِیَّۃَ۔\n\nقَالَ : الْعَرِیَّۃُ النَّخْلَۃُ یَرِثُہَا الرَّجُلُ فِی حَائِطِ الرَّجُلِ ۔ وَالْوَطِیَّۃُ الرَّجُلُ یُوصِی بِالْوَطِیَّۃِ لِلْمَسَاکِینِ۔ (ابوعبید 1453)",,,10665,,
10666,حَدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ عَتَّابَ بْنَ أُسَیْدٍ أَنْ یَخْرُصَ الْعِنَبَ کَمَا یُخْرَصُ النَّخْلَ ، فَتُؤَدَّی زَکَاتُہُ زَبِیبًا ، کَمَا تُؤَدَّی زَکَاۃُ النَّخْلِ تَمْرًا ، فَتِلْکَ سُنَّۃُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی النَّخْلِ وَالْعِنَبِ۔ (ترمذی 644۔ ابوداؤد 1599),,,10666,,
10667,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قَالَ لِی عَبْدُ الْکَرِیمِ ، وَعَمْرُو بْنُ دِینَارٍ : یُخْرَصُ النَّخْلَ وَالْعِنَبَ ، وَلاَ یُخْرُصُ الْحَبَّ۔",,,10667,,
10668,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : مَتَی یُخْرَصُ النَّخْلُ ؟ قَالَ : حینَ یُطْعَمُ۔",,,10668,,
10669,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، قَالَ : قَالَ ابْنُ جُرَیْجٍ : کَذَلِکَ أَخْبَرَنَا عَبْدُ اللہِ بْنُ فُلاَنٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِخَرْصِ خَیْبَرَ حِینَ طَابَ تَمْرُہُمْ ۔ فَقَالَ : وَقَالَ ابْنُ شِہَابٍ : أَمَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُخَرْصَ خَیْبَرَ حِینَ یَطِیب أَوَّلُ التَّمْرِ۔ (عبدالرزاق 7216)",,,10669,,
10670,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : حَرْثٌ لِرَجُلٍ دَیْنُہُ أَکْثَرُ مِنْ مَالِہِ فَحُصِدَ ، أَیُؤَدِّی حَقَّہُ یَوْمَ حَصَادِہِ ؟ فَقَالَ : مَا نَرَی عَلَی الرَّجُلِ دَیْنُہُ أَکْثَرُ مِنْ مَالِہِ مِنْ صَدَقَۃٍ فِی مَاشِیَۃٍ ، وَلاَ فِی أَصْلٍ ، إِلاَّ أَنْ یُؤَدِّیَ حَقَّہُ یَوْمَ حَصَادِہِ ، یَوْمَ یَحْصُدُہُ۔",,,10670,,
10671,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ، عَنِ ابْنِ جُرَیْجٍ، قَالَ: قَالَ لِی أَبُو الزُّبَیْرِ: سَمِعْتُ طَاوُوسًا یَقُولُ: لَیْسَ عَلَیْہِ صَدَقَۃٌ۔",,,10671,,
10672,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ الزِّبْرِقَانِ ، عَنْ عَبْدِ اللہِ بْنِ مِعْقَلٍ ؛ أَنَّہُ کَانَ عَلَی الْعُشُورِ ، فَکَانَ یَسْتَحْلِفُہُمْ ، فَمَرَّ بِہِ أَبُو وَائِلٍ ، فَقَالَ : لِمَ تَسْتَحْلِفُ النَّاسَ عَلَی أَمْوَالِہِمْ ، تَرْمِی بِہِمْ فِی جَہَنَّمَ ؟ فَقَالَ : إنِّی لَوْ لَمْ أَسْتَحْلِفْہُمْ لَمْ یُعْطُوا شَیْئًا ، قَالَ : إنَّہُمْ أَنْ لاَ یُعْطُوک خَیْرٌ مِنْ أَنْ تَسْتَحْلِفَہُمْ۔",,,10672,,
10673,"حَدَّثَنَا حَفْصٌ ، عَنْ إسْمَاعِیلَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ مَسْرُوقٌ عَلَی السَّلْسَلَۃِ ، فَکَانَ مَنْ مَرَّ بِہِ أَعْطَاہُ شَیْئًا قَبِلَ مِنْہُ وَیَقُولُ : مَعَکَ شَیْئٌ لَنَا فِیہِ حَقٌّ ؟ فَإِنْ قَالَ نَعَمْ ، وَإِلاَّ قَالَ لہ : اذْہَبْ۔",,,10673,,
10674,"حَدَّثَنَا مُعْتَمِر ، عَنْ قُرَّۃَ ، عَمَّنْ حَدَّثَہُ ، قَالَ : مَرَرْت عَلَی حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ بِسَفِینَۃٍ ، فَمَا تَرَکَنِی حَتَّی اسْتَحْلَفَنِی مَا فِیہَا۔",,,10674,,
10675,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ أَبِیہِ ، عَنْ زِیَادِ بْنِ حُدَیْرٍ ، قَالَ : بَعَثَنِی عُمَرُ عَلَی الْعُشُورِ ، وَأَمَرَنِی أَنْ لاَ أُفَتِّشَ أَحَدًا۔",,,10675,,
10676,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : إنَّمَا کَانَ الْعَاشِرُ یُرْشِدُ ابْنَ السَّبِیلِ ، وَمَنْ أَتَاہُ بِشَیْئٍ قَبِلَہُ۔",,,10676,,
10677,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ حَرْبِ بْنِ عُبَیْدِ اللہِ ، عَنْ جَدِّہِ أَبِی أُمہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَیْسَ عَلَی الْمُسْلِمِینَ عُشُورٌ ، إنَّمَا الْعُشُورُ عَلَی الْیَہُودِ وَالنَّصَارَی۔ (ابوداؤد 3041)",,,10677,,
10678,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ حَرْبِ بْنِ عُبَیْدِ اللہِ ، عَنْ خَالِہ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، مِثْلَ حَدِیثِ أَبِی الأَحْوَصِ۔ (ابوداؤد 3042۔ احمد 3/474),,,10678,,
10679,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إسْرَائِیلَ ، عَنْ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، قَالَ : حدَّثَنِی مَنْ سَمِعَ عَمْرَو بْنَ حُرَیْثٍ ، عَنْ سَعِیدِ بْنِ زَیْدٍ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : یَا مَعْشَرَ الْعَرَبِ ، احْمَدُوا اللَّہَ الَّذِی وَضَعَ عَنْکُمَ الْعُشُورَ۔ (احمد 1/190۔ ابویعلی 964)",,,10679,,
10680,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ قَابُوسَ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَصْلُحُ قِبْلَتَانِ فِی أَرْضٍ ، وَلَیْسَ عَلَی مُسْلِمٍ جِزْیَۃٌ۔ (ابوداؤد 3048۔ احمد 1/223)",,,10680,,
10681,"حَدَّثَنَا شَرِیکٌ ، عَنْ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ زِیَادِ بْنِ حُدَیْرٍ ، قَالَ : بَعَثَنِی عُمَرُ عَلَی السَّوَادِ ، وَنَہَانِی أَنْ أُعَشِّرَ مُسْلِمًا ، أَوْ ذَا ذِمَّۃٍ یُؤَدِّی الْخَرَاجَ۔",,,10681,,
10682,"حَدَّثَنَا عَفَّانُ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ ، عَنْ عُثْمَانَ بْنِ أَبِی الْعَاصِ ؛ أَنَّ وَفْدَ ثَقِیفٍ قَدِمُوا عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَاشْتَرَطُوا عَلَیْہِ أَنْ لاَ یُحْشَرُوا ، وَلاَ یُعْشَرُوا ، وَلاَ یُجَبُّوا ، فَقالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَکُم أَنْ لاَ تُحْشَرُوا ، وَلاَ تُعْشَرُوا ، وَلاَ یُسْتَعْمَلَ عَلَیْکُمْ غَیْرُکُمْ۔ (ابوداؤد 3020۔ احمد 4/218)",,,10682,,
10683,"حَدَّثَنَا شَرِیکٌ ، عَنْ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ زِیَادِ بْنِ حُدَیْرٍ ، قَالَ : بَعَثَنِی عُمَرُ إلَی نَصَارَی بَنِی تَغْلِبَ ، وَأَمَرَنِی أَنْ آخُذَ نِصْفَ عُشْرِ أَمْوَالِہِمْ۔",,,10683,,
10684,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ السَّفَّاحِ بْنِ مَطَرٍ ، عَنْ دَاوُدَ بْنِ کُرْدُوسٍ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ؛ أَنَّہُ صَالَحَ نَصَارَی بَنِی تَغْلِبَ عَلَی أَنْ تُضَعَّفَ عَلَیْہِمُ الزَّکَاۃُ مَرَّتَیْنِ ، وَعَلَی أَنْ لاَ یُنَصِّرُوا صَغِیرًا ، وَعَلَی أَنْ لاَ یُکْرَہُوا عَلَی دِینِ غَیْرِہِمْ ۔ قَالَ دَاوُد : لَیْسَتْ لَہُمْ ذِمَّۃٌ ، قَدْ نَصَّرُوا۔",,,10684,,
10685,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ زِیَادِ بْنِ حُدَیْرٍ ، قَالَ : کُنْتُ مَعَ جَدِّی فَمَرَّ عَلَی نَصْرَانِیٍّ بِفَرَسٍ قِیمَتُہُ عِشْرُونَ أَلْفًا ، فَقَالَ لَہُ : إِنْ شِئْتَ أَعْطَیْتَ أَلْفَیْنِ ، وَإِنْ شِئْتَ أَخَذْتُ الْفَرَسَ وَأَعْطَیْنَاک قِیمَتَہُ ، ثَمَانیَۃَ عَشَرَ أَلْفًا۔",,,10685,,
10686,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی مِجْلَزٍ ؛ أَنَّ عُمَرَ بَعَثَ عُثْمَانَ بْنَ حُنَیْفٍ ، فَجَعَلَ عَلَی أَہْلِ الذِّمَّۃِ فِی أَمْوَالِہِمَ الَّتِی یَخْتَلِفُونَ بِہَا فِی کُلِّ عِشْرِینَ دِرْہَمًا دِرْہَمًا ، وَکَتَبَ بِذَلِکَ إلَی عُمَرَ بْنِ الْخَطَّابِ فَرَضِیَ وَأَجَازَہُ ، وَقَالَ لِعُمَرَ : کَمْ تَأْمُرُنَا أَنْ نَأْخُذَ مِنْ تُجَّارِ أَہْلِ الْحَرْبِ ؟ قَالَ : کَمْ یَأْخُذُونَ مِنْکُمْ إذَا أَتَیْتُمْ بِلاَدَہُمْ ؟ قَالُوا : الْعُشْرَ ، قَالَ : فَکَذَلِکَ فَخُذُوا مِنْہُمْ۔",,,10686,,
10687,حَدَّثَنَا عَبْدُ الأَعْلَی، عَنْ مَعْمَرٍ، عَنِ الزُّہْرِیِّ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ اسْتَعْمَلَ أَبَاہُ وَرَجُلاً آخَرَ عَلَی صَدَقَاتِ أَہْلِ الذِّمَّۃِ مِمَّا یَخْتَلِفُونَ بِہِ إلَی الْمَدِینَۃِ ، فَکَانَ یَأْمُرُہُمْ أَنْ یَأْخُذُوا مِنَ الْقَمْحِ نِصْفَ الْعُشْرِ ، تَخْفِیفًا عَلَیْہِمْ ، لِیَحْمِلُوا إلَی الْمَدِینَۃِ ، وَمِنَ الْقُطْنِیَّۃِ ، وَہِیَ الْحُبُوبُ الْعُشْرَ۔,,,10687,,
10688,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَبِیہِ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُؤْخَذُ مِنْ أَہْلِ الذِّمَّۃِ مِنْ کُلِّ عِشْرِینَ دِرْہَمًا دِرْہَمٌ ، وَمِنْ أَہْلِ الْحَرْبِ مِنْ کُلِّ عَشَرَۃِ دَرَاہِمَ دِرْہَمٌ ، وَمِنْ أَہْلِ الذِّمَّۃِ إذَا اتَّجَرُوا فِی الْخَمْرِ ، مِنْ کُلِّ عَشَرَۃِ دَرَاہِمَ دِرْہَمٌ۔",,,10688,,
10689,"حَدَّثَنَا یَعْلَی ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ رُزَیْقٍ مَوْلَی بَنِی فَزَارَۃَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَتَبَ إلَیْہِ : خُذْ مِمَّنْ مَرَّ بِکَ مِنْ تُجَّارِ أَہْلِ الذِّمَّۃِ فِیمَا یُظْہِرُونَ مِنْ أَمْوَالِہِمْ وَیُدِیرُونَ مِنَ التِّجَارَاتِ ، مِنْ کُلِّ عِشْرِینَ دِینَارًا دِینَارًا ، فَمَا نَقَصَ مِنْہَا فَبِحِسَابِ مَا نَقَصَ ، حَتَّی تَبْلُغَ عَشَرَۃً ، فَإِذَا نَقَصَتْ ثَلاَثَۃَ دَنَانِیرَ فَدَعْہَا لاَ تَأْخُذْ مِنْہَا شَیْئًا ، وَاکْتُبْ لَہُمْ بَرَائَۃً إلَی مِثْلِہَا مِنَ الْحَوْلِ بِمَا تَأْخُذُ مِنْہُمْ۔",,,10689,,
10690,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، قَالَ : وَسَأَلْت الزُّہْرِیَّ عَنْ جِزْیَۃِ نَصَارَی کَلْبٍ وَتَغْلِبَ ؟ فَقَالَ : بَلَغَنَا أَنَّہُ یُؤْخَذُ مِنْہُمْ نِصْفُ الْعُشْرِ مِنْ مَوَاشِیہِمْ۔",,,10690,,
10691,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ زِیَادِ بْنِ حُدَیْرٍ ، قَالَ : اسْتَعْمَلَنِی عُمَرُ عَلَی الْمَاصِر ، فَکُنْتُ أُعَشِّرُ مَنْ أَقْبَلَ وَأَدْبَرَ ، فَخَرَجَ إلَیْہِ رَجُلٌ فَأَعْلَمَہُ ، فَکَتَبَ إلَیَّ : أَنْ لاَ تُعَشِّرْ إِلاَّ مَرَّۃً وَاحِدَۃً ، یَعْنِی فِی السَّنَۃِ۔",,,10691,,
10692,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ غَالِبِ بْنِ الْہُذَیْلِ ، عَنْ إبْرَاہِیمَ ، قَالَ : جَائَ نَصْرَانِیٌّ إلَی عُمَرَ ، فَقَالَ: إنَّ عَامِلَک عَشَّرَ فِی السَّنَۃِ مَرَّتَیْنِ ، فَقَالَ : مَنْ أَنْتَ ؟ فَقَالَ : أَنَا الشَّیْخُ النَّصْرَانِیُّ ، فَقَالَ عُمَرُ : وَأَنَا الشَّیْخُ الْحَنِیفِی ، فَکَتَبَ إلَی عَامِلِہِ : أَنْ لاَ تُعَشِّرْ فِی السَّنَۃِ إِلاَّ مَرَّۃً۔",,,10692,,
10693,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ زِیَادِ بْنِ حُدَیْرٍ ، قَالَ : أَنَا أَوَّلُ مَنْ عَشَّرَ فِی الإِسْلاَمِ۔",,,10693,,
10694,"حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ إِبْرَاهِيمَ بْنِ الْمُهَاجِرِ، عَنْ زِيَادِ بْنِ حُدَيْرٍ، قَالَ: حَدَّثَنَا رَجُلٌ، عَنْ جَابِرِ بْنِ زَيْدٍ، أَنَّهُ سُئِلَ عَنِ الْفُقَرَاءِ وَالْمَسَاكِينِ، فَقَالَ: "" الْفُقَرَاءُ: الْمُتَعَفِّفُونَ، وَالْمَسَاكِينُ: الَّذِي يَسْأَلُونَ """,,,10694,,
10695,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنِی جَرِیرُ بْنُ حَازِمٍ ، قَالَ : حدَّثَنِی رَجُلٌ ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ أَنَّہُ سُئِلَ عَنِ الْفُقَرَائِ وَالْمَسَاکِینِ ؟ فَقَالَ : الْفُقَرَائُ : الْمُتَعَفِّفُونَ ، وَالْمَسَاکِینُ : الَّذِین یَسْأَلُونَ۔",,,10695,,
10696,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ عَلِیِّ بْنِ الْحَکَمِ ، قَالَ : سَمِعْتُ الضَّحَّاکَ بْنَ مُزَاحِمٍ یَقُولُ: {إنَّمَا الصَّدَقَاتُ لِلْفُقَرَائِ وَالْمَسَاکِینِ} ، قَالَ : الْفُقَرَائُ : الَّذِینَ ہَاجَرُوا ، وَالْمَسَاکِینُ : الَّذِینَ لَمْ یُہَاجِرُوا۔",,,10696,,
10697,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، قَالَ : حدَّثَنَا مَعْقَلٌ ، قَالَ : سَأَلْتُ الزُّہْرِیَّ عَنْ قَوْلِ اللہِ تَعَالَی : {إنَّمَا الصَّدَقَاتُ لِلْفُقَرَائِ} ؟ قَالَ : الْفُقَرَائُ : الَّذِینَ فِی بُیُوتِہِمْ وَلاَ یَسْأَلُونَ ، وَالْمَسَاکِینُ : الَّذِینَ یَخْرُجُونَ فَیَسْأَلُونَ۔",,,10697,,
10698,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَمْعَۃَ بْنِ صَالِحٍ ، عَنْ یُحَنَّسَ ، عَنِ ابْنِ الزُّبَیْرِ ، قَالَ : عَلَی الأَعْرَابِ صَدَقَۃُ الْفِطْرِ",,,10698,,
10699,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ عَلَی الأَعْرَابِ زَکَاۃُ الْفِطْرِ۔",,,10699,,
10700,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ إِسْحَاقَ بْنِ طَلْحَۃَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ بْنِ سَعِیدِ بْنِ الْعَاصِ ، قَالَ : کَانَ أَبُو بَکْرٍ الصِّدِّیقُ یَأْخُذُ مِنَ الأَعْرَابِ صَدَقَۃَ الْفِطْرِ الأَقِطَ۔",,,10700,,
10701,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، عَنِ الْحَسَنِ ، قَالَ : یُعْطُونَ مِنَ اللَّبَنِ۔",,,10701,,
10702,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ، أَنَّہُ قَالَ : عَلَی الأَعْرَابِ صَدَقَۃُ الْفِطْرِ ، صَاعٌ مِنْ لَبَنٍ۔",,,10702,,
10703,"حَدَّثَنَا حَفْصٌ، عَنِ ابن أَبِی خَالِدٍ، عَنِ الشَّعْبِیِّ؛ فِی الرَّجُلِ یُعْتِقُ الْعَبْدَ النَّصْرَانِیَّ، قَالَ: ذِمَّتُہُ ذِمَّۃُ مَوَالِیہ۔",,,10703,,
10704,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ عَلَیْہِ الْجِزْیَۃُ۔",,,10704,,
10705,"حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یُعْتِقُ الْعَبْدَ النَّصْرَانِیَّ ، قَالَ : عَلَیْہِ الْجِزْیَۃُ۔",,,10705,,
10706,حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ سُفْیَانَ، عَنْ سِنَانٍ؛ أَنَّ عُمَرَ بْنَ عَبْدِالْعَزِیزِ أَخَذَ الْجِزْیَۃَ مِنْ نَصْرَانِیٍّ أَعْتَقَہُ مُسْلِمٌ۔,,,10706,,
10707,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ: سَأَلْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ عَنْ أَرْضِ الْخَرَاجِ، عَلَیْہَا زَکَاۃٌ ؟ فَقَالَ : الْخَرَاجُ عَلَی الأَرْضِ ، وَالزَّکَاۃُ عَلَی الْحَبِّ۔",,,10707,,
10708,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : الْخَرَاجُ عَلَی الأَرْضِ ، وَالْعُشْرُ عَلَی الْحَبِّ۔",,,10708,,
10709,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَقُولُ : لَیْسَ فِی التَّمْرِ زَکَاۃٌ إذَا کَانَ یُؤْخَذُ مِنْہُ الْعُشْرُ ، وَإِنْ کَانَ بِمِئَۃِ أَلْفٍ۔",,,10709,,
10710,"حَدَّثَنَا وَکِیعٌ ، قَالَ : کَانَ حَسَنٌ وَسُفْیَانُ یَقُولاَنِ : عَلَیْہِ۔",,,10710,,
10711,"حَدَّثَنَا إبْرَاہِیمُ بْنُ الْمُغِیرَۃِ خَتَنٌ لِعَبْدِ اللہِ بْنِ الْمُبَارَکِ ، عَنْ أَبِی حَمْزَۃَ السَّکُرِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ یَجْتَمِعُ خَرَاجٌ وَعُشْرٌ فِی أَرْضٍ وَاحِدٍ۔",,,10711,,
10712,"حَدَّثَنَا أَبُو تُمَیْلَۃَ یَحْیَی بْنُ وَاضِحٍ، عَنْ أَبِی الْمُنِیبِ، عَنْ عِکْرِمَۃَ، قَالَ: لاَ یَجْتَمِعُ خَرَاجٌ وَعُشْرٌ فِی مَالٍ۔",,,10712,,
10713,"حَدَّثَنَا وَکِیعٌ ، قَالَ : کَانَ أَبُو حَنِیفَۃَ یَقُولُ : لاَ یَجْتَمِعُ خَرَاجٌ وَزَکَاۃٌ عَلَی رَجُلٍ۔",,,10713,,
10714,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمِ بْنِ مُحَمَّدٍ ؛ فِی قَوْلِہِ : {وَالَّذِینَ فِی أَمْوَالِہِمْ حَقٌّ مَعْلُومٌ} ، قَالَ : الزَّکَاۃُ۔",,,10714,,
10715,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ {وَالَّذِینَ فِی أَمْوَالِہِمْ حَقٌّ مَعْلُومٌ} ، قَالَ : الزَّکَاۃُ الْمَفْرُوضَۃُ۔",,,10715,,
10716,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی الْہَیْثُمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا إذَا خَرَجَتْ أَعْطِیَاتُہُمْ تَصَدَّقُوا مِنْہَا",,,10716,,
10717,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : أَخَذَ الوَلِیدُ بن عَبْدِ الْمَلِکِ مَالَ رَجُلٍ مِنْ أَہْلِ الرَّقَّۃِ یُقَالُ لَہُ : أَبُو عَائِشَۃَ عِشْرِینَ أَلْفًا ، فَأَلقَاہَا فِی بَیْتِ الْمَالِ ، فَلَمَّا وَلِیَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ أَتَاہُ وَلَدُہُ ، فَرَفَعُوا مَظْلِمَتَہُمْ إلَیْہِ ، فَکَتَبَ إلَی مَیْمُونٍ : ادْفَعُوا إلَیْہِمْ أَمْوَالَہُمْ ، وَخُذُوا زَکَاۃَ عَامِہِ ہَذَا ، فَلَوْلا أَنَّہُ کَانَ مَالاً ضِمَارًا أَخَذْنَا مِنْہُ زَکَاۃَ مَا مَضَی۔",,,10717,,
10718,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مَیْمُونٍ ؛ أَنَّ رَجُلاً ذَہَبَ لَہُ مَالٌ فِی بَعْضِ الْمَظَالِمِ ، فَوَقَعَ فِی بَیْتِ الْمَالِ ، فَلَمَّا وَلِیَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ رُفِعَ إلَیْہِ ، فَکَتَبَ عُمَرُ : أَنِ ادْفَعُوا إلَیْہِ ، وَخُذُوا مِنْہُ زَکَاۃَ مَا مَضَی ، ثُمَّ تَبعَہُمْ بَعْدُ کِتَاب : أَنِ ادْفَعُوا إلَیْہِ مَالَہُ ، ثُمَّ خُذُوا مِنْہُ زَکَاۃَ ذَلِکَ الْعَامِ ، فَإِنَّہُ کَانَ مَالاً ضِمَارًا۔",,,10718,,
10719,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : عَلَیْہِ زَکَاۃُ ذَلِکَ الْعَامِ۔",,,10719,,
10720,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنِ الْحَارِثِ بْنِ سُوَیْد ، عَنْ عَبْدِ اللہِ : {وَیَمْنَعُونَ الْمَاعُونَ}، قَالَ : ہُوَ مَا تَعَاوَر النَّاسُ بَیْنَہُمَ ؛ الْفَأْسُ ، وَالْقِدْرُ ، وَالدَّلْوُ ، وَأَشْبَاہُہُ۔",,,10720,,
10721,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنِ الْحَکَمِ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ، عَنْ أَبِی الْعُبَیْدَیْنِ ، عَنْ عَبْدِ اللہِ ، قَالَ : ہُوَ مَا تَعَاوَر النَّاسُ بَیْنَہُمْ۔",,,10721,,
10722,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَلِیٍّ ؛ {وَیَمْنَعُونَ الْمَاعُونَ} قَالَ : الزَّکَاۃُ الْمَفْرُوضَۃُ ۔ وَقَالَ ابْنُ عَبَّاسٍ : عَارِیَۃُ الْمَتَاعِ۔",,,10722,,
10723,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ مُجَاہِدٍ ، عَنْ عَلِیٍّ ، قَالَ : الْمَاعُونُ الزَّکَاۃُ۔",,,10723,,
10724,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ عُبَیْدٍ ، عَنْ عَلِیِّ بْنِ رَبِیعَۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : ہُوَ الْمَالُ الَّذِی لاَ یُعْطَی حَقُّہُ۔",,,10724,,
10725,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ سَعِیدِ بْنِ عُبَیْدٍ ، عَنْ عَلِیِّ بْنِ رَبِیعَۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : ہُوَ الْمَالُ الَّذِی لاَ یُؤَدَّی حَقُّہُ۔",,,10725,,
10726,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ (ح) وَغُنْدَرٍ ، عَنْ َشُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعْدِ بْنِ عِیَاضٍ ، عَنْ أصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنَّہُمْ قَالُوا : الْمَاعُونُ مَنْعُ الْفَأْسِ وَالْقِدْرِ وَالدَّلْوِ۔",,,10726,,
10727,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ جَابِرِ بْنِ صُبْحٍ ، عَنْ أُمِّ شَرَاحِیلَ ، عَنْ أُمِّ عَطِیَّۃَ قَالَتْ : الْمَہْنَۃُ۔",,,10727,,
10728,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : الْمَاعُونُ مَنْعُ الْفَأْسِ وَالْقِدْرِ وَالدَّلْوِ۔",,,10728,,
10729,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَمْ یَجِیْٔ أَہْلُہَا بَعْد۔",,,10729,,
10730,"حَدَّثَنَا جَرِیرٌ ، عَنْ إبْرَاہِیمَ ، قَالَ : الْقِدْرُ وَالرَّحَی ۔ وَقَالَ بَعْضُہُمْ : الْفَأْسُ۔",,,10730,,
10731,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ بْنِ نُبَیْطٍ ، عَنِ الضَّحَّاکِ ، قَالَ : الزَّکَاۃُ",,,10731,,
10732,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنِ الْحَارِثِ ، عَنْ عَبْدِ اللہِ ، قَالَ : الْقِدْرُ وَالدَّلْوُ۔",,,10732,,
10733,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ ، مِثْلَہُ,,,10733,,
10734,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ أَبِی الْمُغِیرَۃِ ، عَنِ ابْنِ عُمَرَ ، قَالَ : ہِیَ الزَّکَاۃُ۔",,,10734,,
10735,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، مِثْلَ حَدِیثِ ابْنِ مَسْعُودٍ۔,,,10735,,
10736,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنِ الْحَکَمِ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ؛ أَنَّ أَبَا العُبَیدِین سَأَلَ عَبْدَ اللہِ عَنِ الْمَاعُونِ ؟ قَالَ : ہُوَ الْفَأْسُ وَالْقِدْرُ وَالدَّلْوُ۔",,,10736,,
10737,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ أَبِی عُمَر ، عَنْ یَحْیَی ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، قَالَ : الْمَاعُونُ الزَّکَاۃُ۔",,,10737,,
10738,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : الْمَاعُونُ ہُوَ الْمَالُ بِلِسَانِ قُرَیْشٍ۔",,,10738,,
10739,"حَدَّثَنَا وَکِیعٌ ، عَنْ بسَّامٍ ، قَالَ : سَأَلْتُ عِکْرِمَۃَ عَنِ الْمَاعُونِ ؟ فَقَالَ : الْفَأْسُ وَالْقِدْرُ وَالدَّلْوُ۔",,,10739,,
10740,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : ہُوَ الْمَتَاعُ ۔ وَقَالَ عَلِیٌّ : ہُوَ الزَّکَاۃُ۔",,,10740,,
10741,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : الْمَاعُونُ الزَّکَاۃُ الْمَفْرُوضَۃُ۔",,,10741,,
10742,"حَدَّثَنَا جَرِیرٌ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : عَیَّرْنَا صَاعَ الْمَدِینَۃِ فَوَجَدْنَاہُ یَزِیدُ مِکْیَالاً عَلَی الْحَجَّاجِیِّ۔",,,10742,,
10743,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مُوسَی بْنِ طَلْحَۃَ ، قَالَ : الْحَجَّاجِیُّ صَاعُ عُمَرَ بْنِ الْخَطَّابِ۔",,,10743,,
10744,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ أَبِی شِہَابٍ ، عَنْ حَجَّاجٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : الْقَفِیزُ الْحَجَّاجِیُّ ہُوَ الصَّاعُ۔",,,10744,,
10745,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، قَالَ: مَا کَانَ یُفْتِی فِیہِ إبْرَاہِیمُ فِی کَفَّارَۃِ یَمِینٍ ، أَوْ فِی الشِّرَائِ ، أَوْ فِی إطْعَامِ سِتِّینَ مِسْکِینًا، وَفِیمَا قَالَ فِیہِ: الْعُشْرُ وَنِصْفُ الْعُشْرِ، قَالَ: کَانَ یُفْتِی بِقَفِیزِ الْحَجَّاجِیِّ، قَالَ: ہُوَ الصَّاعُ۔",,,10745,,
10746,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : سَمِعْتُ حَسَنًا یَقُولُ : صَاعُ عُمَرَ ثَمَانیَۃُ أَرْطَالٍ ۔ وَقَالَ شَرِیکٌ : أَکْثَرُ مِنْ سَبْعَۃِ أَرْطَالٍ وَأَقَلُّ مِنْ ثَمَانِیَۃٍ۔",,,10746,,
10747,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ بْنِ سَوَّارٍ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ ، قَالَ : بَعَثَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِینَا سَاعِیًا ، فَأَخَذَ الصَّدَقَۃَ مِنْ أَغْنِیَائِنَا ، فَقَسَمَہَا فِی فُقَرَائِنَا ، وَکُنْت غُلاَمًا یَتِیمًا فَأَعْطَانِی مِنْہَا قَلُوصًا۔ (ترمذی 649۔ دارقطنی 7)",,,10747,,
10748,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ حَجَّاجٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ أَبِیہِ ، قَالَ : سُئِلَ عُمَرُ عَمَّا یُؤْخَذُ مِنْ صَدَقَاتِ الأَعْرَابِ ، کَیْفَ یُصْنَعُ بِہَا ؟ فَقَالَ عُمَرُ : وَاللَّہِ ، لأَرُدَّنَّ عَلَیْہِمُ الصَّدَقَۃَ ، حَتَّی تَرُوحَ عَلَی أَحَدِہِمْ مِئَۃ نَاقَۃٍ ، أَوْ مِئَۃ بَعِیرٍ۔",,,10748,,
10749,حَدَّثَنَا جَرِیر بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مُغِیرَۃَ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛ أَخَذَ نِصْفَ صَدَقَاتِ الأَعْرَابِ ، وَرَدَّ نِصْفَہَا فِی فُقَرَائنَا۔,,,10749,,
10750,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ سَالِمُ بْنُ عَبْدِ اللہِ یَقْسِمُ صَدَقَۃَ عُمَرَ ، فَیَأْتِیہِ الرَّجُلُ ذُو ہِیئَۃٍ قَدْ أَعْطَاہُ ، فَیَقُولُ : أَعْطِنِی ، فَیُعْطِیہ وَلاَ یَسْأَلُہُ۔",,,10750,,
10751,"حَدَّثَنَا بِشْرُ بْنُ مُفَضَّلٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَمْرِو بْنِ سَہلٍ، قَالَ : لَقَدْ رَأَیْتُ عُثْمَانَ فِی طَرِیقِ مَکَّۃَ ، وَإِنَّ الصَّدَقَاتِ لَتُسَاقُ مَعَہُ ، فَیَحْمِلُ عَلَیْہَا الرَّاجِلَ المُنْقَطِع بِہِ۔",,,10751,,
10752,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ شَرِیکِ بْنِ نَمْلَۃَ ، قَالَ : بَعَثَنِی عَلِیٌّ سَاعِیًا عَلَی الصَّدَقَۃِ ، قَالَ : فَصَحِبَنِی أَخِی ، فَتَصَدَّقْت ، قَالَ : فَحَمَلْت أَخِی عَلَی بَعِیرٍ ، فَقُلْتُ : إِنْ أَجَازَہُ عَلِیٌّ ، وَإِلاَّ فَہُوَ مِنْ مَالِی ، فَلَمَّا قَدِمْت عَلَیْہِ قَصَصْت عَلَیْہِ قِصَّۃَ أَخِی ، فَقَالَ : لَکَ فِیہِ نَصِیبٌ۔",,,10752,,
10753,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَالِمٍ ، عَنْ أَسْلَمَ ؛ أَنَّ عُمَرَ بَعَثَہُ بِإِبِلٍ مِنَ الصَّدَقَۃِ إلَی الْحِمَی ، فَلَمَّا أَرَدْتُ أَنْ أَصْدُرَ ، قَالَ : اعْرِضْہَا عَلَیَّ ، فَعَرَضْتہَا عَلَیْہِ وَقَدْ جَعَلْتُ جَہَازِی عَلَی نَاقَۃٍ مِنْہَا ، فَقَالَ : لاَ أُمَّ لَکَ ، عَمَدْت إلَی نَاقَۃٍ تُحْیِی أَہْلَ بَیْتٍ مِنَ الْمُسْلِمِینَ تَحْمِلُ عَلَیْہَا جَہَازَک ؟ أَفَلاَ ابْنَ لَبُونٍ بَوَّالاً ، أَوْ نَاقَۃً شَصُوصًا۔",,,10753,,
10754,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الْحُوَیْرِثِ ، عَنْ أَبِی عَمَّارٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : لَیْسَ فِی الْمَمْلُوکِ زَکَاۃٌ إِلاَّ مَمْلُوکٌ تَمْلِکُہُ۔",,,10754,,
10755,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ عَمْرِو بْنِ مَیْمُونِ بْنِ مِہْرَانَ ، عَنْ زِیَادِ بْنِ أَبِی مَرْیَمَ ، عَنْ أُمِّہِ قَالَتْ أَتَیْتُ عَبْدَ اللہِ بْنَ الأَرْقَمِ ، قَالَ وَکَانَ عَلَی بَیْتِ الْمَالِ فِی إمْرَۃِ عُمَر وَفِی إمْرَۃِ عُثْمَانَ وَہُوَ یَقْسِمُ صَدَقَۃً بِالْمَدِینَۃِ ، فَلَمَّا رَآنِی ، قَالَ : مَا جَائَ بِکَ یَا أُمَّ زِیَادٍ ، قَالَتْ قُلْتُ لَہُ : لِمَا جَائَ لَہُ النَّاسُ ، قَالَ ہَلْ عَتَقْتِ بَعْدُ ؟ قُلْتُ : لاَ ، فَبَعَثَ إلَی بَیْتِہِ فَأُتِیَ بِبُرْدٍ فَأَمَرَ لِی بِہِ ، وَلَمْ یَأْمُرْ لِی مِنَ الصَّدَقَۃِ بِشَیْئٍ لأَنِّی کُنْت مَمْلُوکَۃً۔",,,10755,,
10756,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَر بْنِ ذَرٍّ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تُطْعِمُوا ہَؤُلاَئِ السُّودَانِ مِنْ أَضَاحِیکُمْ فَإِنَّمَا ہِیَ أَمْوَالُ أَہْلِ مَکَّۃَ۔",,,10756,,
10757,حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ سَالِمٍ ، أَنَّہُ کَرِہَ أَنْ یُتَصَدَّقَ عَلَی عَبِیدِ الأَعْرَابِ۔ (طبرانی 3233),,,10757,,
10758,حَدَّثَنَا عبد الرحمن وَ وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ عَبَّاسِ بْنِ عَبْدِ الرَّحْمَنِ الْمَدَنِیِّ ، قَالَ خَصْلَتَانِ لَمْ یَکُنِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَکِلُہُمَا إلَی أَحَدٍ مِنْ أَہْلِہِ کَانَ یُنَاوِلُ الْمِسْکِینَ بِیَدِہِ وَیَضَعُ الطَّہُورَ لِنَفْسِہِ۔,,,10758,,
10759,"وَکِیعٌ، عَنْ أَبِی الْمِنْہَالِ، قَالَ: رَأَیْتُ عَلِیَّ بْنَ حُسَیْنٍ لَہُ جُمَّۃٌ وَعَلَیْہِ مِلْحَفَۃٌ وَرَأَیْتُہ یُنَاوِلُ الْمِسْکِینَ بِیَدِہِ۔",,,10759,,
10760,"حَدَّثَنَا عَبْدُ الرَّحِیمِ بْنُ سُلَیْمَانَ ، عَنْ أَشْعَثَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : سَأَلْتُہ عَنِ الرَّجُلِ یُسَلِّفُ إلَی أَہْلِ الأَرْضِ أو یَکُونُ لَہُ الدَّیْنُ أَیُزَکِّیہِ ؟ قَالَ : نَعَمْ۔",,,10760,,
10761,"وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ رَجُلٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ فِی مُضَارَبَۃٍ زَکَاۃٌ لأَنَّہُ لاَ یَدْرِی مَا صُنِعَ۔",,,10761,,
10762,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ (وَالْغَارِمِینَ) ، قَالَ : الْمُنْفِقِینَ فِی غَیْرِ فَسَادٍ ، (وَابْنِ السَّبِیلِ) الْمُجْتَازُ عَلَی الأَرْضِ إلَی الأَرْضِ۔",,,10762,,
10763,"عُبَیْدُ اللہِ بْنُ مُوسَی، عَنْ عُثْمَانَ بْنِ الأَسْوَد ، عَنْ مُجَاہِدٍ ، قَالَ ثَلاَثَۃٌ مِنَ الْغَارِمِینَ: رَجُلٌ ذَہَبَ السَّیْلُ بِمَالِہِ وَرَجُلٌ أَصَابَہُ حَرِیقٌ فَذَہَبَ بِمَالِہِ , وَرَجُلٌ لَہُ عِیَالٌ وَلَیْسَ لَہُ مَالٌ, فَہُوَ یَدَّانُ وَیُنْفِقُ عَلَی عِیَالِہِ۔",,,10763,,
10764,"وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ لِلْغَارِمِ : یَنْبَغِی الإِمَامُ أَنْ یَقْضِیَ عَنْہُ۔",,,10764,,
10765,"الزُّبَیْرِیُّ أَبُو أَحْمَدَ ، قَالَ : حدَّثَنَا مَعْقِلٌ ، قَالَ : سَأَلْتُ الزُّہْرِیَّ ، عَنِ الْغَارِمِینَ : قَالَ أَصْحَابُ الدَّیْنِ ، وَابْنُ السَّبِیلِ ، وَإِنْ کَانَ غَنِیًّا۔",,,10765,,
10766,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن رَیْحَانَ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَحِلُّ الصَّدَقَۃُ لِغَنِیٍّ ، وَلاَ لِذِی مِرَّۃٍ سَوِیٍّ۔ (ترمذی 652۔ ابوداؤد 1631)",,,10766,,
10767,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی حَصِینٍ ، عَنْ سَالِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَحِلُّ الصَّدَقَۃُ لِغَنِیٍّ ، وَلاَ لِذِی مِرَّۃٍ سَوِیٍّ۔",,,10767,,
10768,"عَبْدُ الرَّحِیمِ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ حُبْشِیِّ بْنِ جُنَادَۃَ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : الْمَسْأَلَۃُ لاَ تَحِلُّ لِغَنِیٍّ ، وَلاَ لِذِی مِرَّۃٍ سَوِیٍّ",,,10768,,
10769,"عَبْدُ الرَّحِیمِ ، وَابْنُ نُمَیْرٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ عُبَیْدِ اللہِ بْنِ عَدِیِّ بْنِ الْخِیَارِ ، قَالَ : أَخْبَرَنِی رَجُلاَنِ أَنَّہُمَا أَتَیَا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْأَلاَنِہِ الصَّدَقَۃَ ، قَالَ فَرَفَّعَ فِیہِم الْبَصَرَ وَصَوَّبَہُ ، وَقَالَ : إنَّکُمَا لَجَلْدَانِ ، فَقَالَ : أَمَا إِنْ شِئْتُمَا أَعْطَیْتُکُمَا وَلاَ حَظَّ فِیہَا لِغَنِیٍّ ، وَلاَ لِقَوِیٍّ مُکْتَسِبٍ۔\n\n(ابوداؤد 1630۔ احمد 5/362)",,,10769,,
10770,"ابْنُ مَہْدِیٍّ ، عَنْ مُوسَی بْنِ عُلَیٍّ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : لاَ تَنْبَغِی الصَّدَقَۃُ لِغَنِیٍّ ، وَلاَ لِذِی مِرَّۃٍ سَوِیٍّ۔",,,10770,,
10771,"حَدَّثَنَا عَبْدُ الأَعْلَی بْنُ عَبْدِ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ أَخِی الزُّہْرِیِّ ، عَنْ حَمْزَۃَ بْنِ عَبْدِ اللہِ ، عَنْ أَبِیہِ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ تَزَالُ الْمَسْأَلَۃُ بِأَحَدِکُمْ حَتَّی یَلْقَی اللَّہَ وَلَیْسَ فِی وَجْہِہِ مُزْعَۃُ لَحْمٍ۔ (بخاری 1474۔ مسلم 103)",,,10771,,
10772,جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ قَابُوسَ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ لَوْ یَعْلَمُ صَاحِبُ الْمَسْأَلَۃِ مَا فِیہَا مَا سَأَلَ۔ (طبرانی 12616),,,10772,,
10773,"أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مَسْرُوقٍ ، قَالَ : مَنْ سَأَلَ النَّاسَ مِنْ غَیْرِ فَاقَۃٍ جَائَ یَوْمَ الْقِیَامَۃِ وَفِی وَجْہِہِ خُدُوشٌ ، أَوْ خُمُوشٌ۔",,,10773,,
10774,"ابْنُ نُمَیْرٍ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : قَالَتْ أُمُّ الدَّرْدَائِ لأَبِی الدَّرْدَائِ : إِنِ احْتَجْتُ بَعْدَکَ آکُلُ الصَّدَقَۃَ؟ قَالَ: لاَ ، اعْمَلِی وَکُلِی قَالَتْ: إِنْ ضَعُفْت عَنِ الْعَمَلِ ، قَالَ: الْتَقِطِی السُّنْبُلَ، وَلاَ تَأْکُلِی الصَّدَقَۃَ۔",,,10774,,
10775,"جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ عَبْدِ الْمَلِکَ بْنِ عُمَیْرٍ ، عَنْ عُقْبَۃَ ، أَوْ فُلاَنِ بْنِ عُقْبَۃَ ، عَنِ ابْنِ جُنْدُبٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کُلُّ الْمَسْأَلَۃِ کَدٌّ فِی وَجْہِ الرَّجُلِ یَوْمَ الْقِیَامَۃِ إِلاَّ أَنْ یَسْأَلَ سُلْطَانًا، أَوْ فِی أَمْرٍ لاَ بُدَّ مِنْہُ۔ (ترمذی 681۔ ابوداؤد 1636)",,,10775,,
10776,"ابْنُ فُضَیْلٍ ، عَنْ عُمَارَۃَ بْنِ الْقَعْقَاعِ ، عَنْ أَبِی زُرْعَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ سَأَلَ النَّاسَ أَمْوَالَہُمْ تَکَثُّرًا فَإِنَّمَا یَسْأَلُ جَمْرَۃً فَلْیَسْتَقِلَّ مِنْہُ ، أَوْ لِیَسْتَکْثِرْ۔ (مسلم 105۔ احمد 2/231)",,,10776,,
10777,"ابْنُ نُمَیْرٍ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ حُبْشِیِّ السَّلُولِیِّ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ سَأَلَ النَّاسَ لِیُثْرِیَ بِہِ مَالَہُ ، فَإِنَّہُ خُمُوشٌ فِی وَجْہِہِ وَرَضْفٌ مِنْ جَہَنَّمَ یَأْکُلُہُ یَوْمَ الْقِیَامَۃِ , وَذَلِکَ فِی حَجَّۃِ الْوَدَاعِ۔",,,10777,,
10778,"أَبُو مُعَاوِیَۃَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : قَالَ عُمَرُ مَنْ سَأَلَ النَّاسَ لِیَثْرَی بِہِ مَالَہُ فَإِنَّمَا ہُوَ رُضَفٌ مِنْ جَہَنَّمَ , فَمَنْ شَائَ فَلْیُقِلَّ وَمَنْ شَائَ فَلْیُکْثِرْ۔",,,10778,,
10779,"ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لأَنْ یَأْخُذَ أَحَدُکُمْ أَحْبُلاً فَیَأْتِیَ الْجَبَلَ , فَیَحْتَطِبَ مِنْہُ فَیَبِیعَہُ , وَیَأْکُلَ وَیَتَصَدَّقَ , خَیْرٌ مِنْ أَنْ یَسْأَلَ النَّاسَ۔ (بخاری 1480۔ مسلم 107)",,,10779,,
10780,"ابْنُ نُمَیْرٍ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنِ الزُّبَیْرِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لأَنْ یَأْخُذَ أَحَدُکُمْ أَحْبُلاً فَیَذْہَبَ فَیَأْتِیَ بِحُزْمَۃٍ مِنْ حَطَبٍ عَلَی ظَہْرِہِ فَیَبِیعَہَا فَیَکُفَّ اللَّہُ بِہَا وَجْہَہُ , خَیْرٌ لَہُ مِنْ أَنْ یَسْأَلَ النَّاسَ شَیْئًا , أَعْطَوْہُ ، أَوْ مَنَعُوہُ۔ (بخاری 3075۔ احمد 1/167)",,,10780,,
10781,حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ وَالْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مِسْعَرٍ ، عَنْ عُبَیْدِ بْنِ الْحَسَنِ ، عَنِ ابْنِ مَعْقِلٍ ، قَالَ مَنْ سَأَلَ تَکَثُّرًا جَائَ یَوْمَ الْقِیَامَۃِ وَفِی وَجْہِہِ خُمُوشٌ۔,,,10781,,
10782,"حَفْصٌ وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : جَائَ سَائِلٌ فَسَأَلَ فَأَعْطَاہُ شَیْئًا ، فَقِیلَ لَہُ : تُعْطِیہ وَہُوَ مُوسِرٌ ؟ فَقَالَ : إِنَّہُ سَائِلٌ وَلِلسَّائِلِ حَقٌّ وَلَیَتَمَنَّیَنَّ یَوْمَ الْقِیَامَۃِ ، أَنَّہَا کَانَتْ رَضْفَۃً فِی یَدِہِ۔",,,10782,,
10783,"ابْنُ عُیَیْنَۃَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عَنْ عَطَائِ بْنِ یَسَارٍ یَبْلُغُ بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ سَأَلَ وَلَہُ أُوقِیَّۃٌ ، أَوْ عَدْلُہَا فَہُوَ یَسْأَلُ النَّاسَ إلْحَافًا۔ (ابوداؤد 1624۔ مالک 11)",,,10783,,
10784,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطِیَّۃَ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَحِلُّ الصَّدَقَۃُ لِغَنِیٍّ إِلاَّ لِثَلاَثَۃٍ : فِی سَبِیلِ اللہِ ، أَوِ ابْنِ السَّبِیلِ ، أَوْ رَجُلٍ کَانَ لَہُ جَارٌ فَتُصُدِّقَ عَلَیْہِ فَأَہْدَی لَہُ۔ (ابوداؤد 1634۔ بیہقی 23)",,,10784,,
10785,"وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَحِلُّ الصَّدَقَۃُ إِلاَّ لِخَمْسَۃٍ : رَجُلٍ اشْتَرَاہَا بِمَالِہِ ، أَوْ رَجُلٍ عَمِلَ عَلَیْہَا ، أَوِ ابْنِ السَّبِیلِ ، أَوْ فِی سَبِیلِ اللہِ ، أَوْ رَجُلٍ کَانَ لَہُ جَارٌ فَتُصُدِّقَ عَلَیْہِ فَأَہْدَی لَہُ۔ (مالک 29)",,,10785,,
10786,"ابْنُ نُمَیْرٍ، عَنِ الْمُجَالِدِ، عَنِ الشَّعْبِیِّ، عَنْ حُبْشِیِّ بْنِ جُنَادَۃَ السَّلُولِیِّ، قَالَ: سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ وَأَتَاہُ أَعْرَابِیٌّ فَسَأَلَہُ ، فَقَالَ : إنَّ الْمَسْأَلَۃَ لاَ تَحِلُّ إِلاَّ لِفَقْرٍ مُدْقِعٍ ، أَوْ غُرْمٍ مُفْظِعٍ۔",,,10786,,
10787,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، أَنَّ سَائِلاً سَأَلَ ابْنَ عُمَرَ وَالْحَسَنَ وَالْحُسَیْنَ ، وَعَبْدَ اللہِ بْنَ جَعْفَرٍ فَقَالُوا : إِنْ کُنْت تَسْأَلُ لِدَیْنٍ مُفْظِعٍ ، أَوْ فَقْرٍ مُدْقِعٍ ، أَوَ قَالَ دَمٍ مُوجِعٍ فَإِنَّ الصَّدَقَۃَ تَحِلُّ لَک۔",,,10787,,
10788,"الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ ہَارُونَ بْنِ رِئَابٍ ، عَنْ کِنَانَۃَ بْنِ نُعَیْمٍ ، عَنْ قَبِیصَۃَ بْنِ الْمُخَارِقِ الْہِلاَلِیِّ ، قَالَ تَحَمَّلْت حَمَالَۃً فَأَتَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَسْأَلُہُ فِیہَا ، فَقَالَ : أَقِمْ یَا قَبِیصَۃُ ، حَتَّی تَأْتِیَنَا الصَّدَقَۃُ نَأْمُرْ لَکَ بِہَا ، قَالَ : قَالَ لِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : یَا قَبِیصَۃُ ، إنَّ الْمَسْأَلَۃَ لاَ تَحِلُّ إِلاَّ لأَحَدِ ثَلاَثَۃٍ : رَجُلٍ تَحَمَّلَ حَمَالَۃً فَحَلَّتْ لَہُ الْمَسْأَلَۃُ حَتَّی یُصِیبَہَا ، ثُمَّ یُمْسِکُ , وَرَجُلٍ أَصَابَتْہُ جَائِحَۃٌ فَاجْتَاحَتْ مَالَہُ فَحَلَّتْ لَہُ الْمَسْأَلَۃُ حَتَّی یُصِیبَ قِوَامًا مِنْ عَیْشٍ ، ثُمَّ یُمْسِکُ , وَرَجُلٍ أَصَابَتْہُ فَاقَۃٌ حَتَّی یَقُولَ ثَلاَثَۃٌ مِنْ ذَوِی الْحِجَا مِنْ قَوْمِہِ قَدْ أَصَابَتْ فُلاَنًا فَاقَۃٌ , فَحَلَّتْ لَہُ الْمَسْأَلَۃُ حَتَّی یُصِیبَ قِوَامًا مِنْ عَیْشٍ ، ثُمَّ یُمْسِکُ ، یَا قَبِیصَۃُ ، مَا سِوَاہُنَّ مِنَ الْمَسْأَلَۃِ سُحْتٌ یَأْکُلُہَا صَاحِبُہَا۔ (مسلم 109۔ ابوداؤد 1637)",,,10788,,
10789,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ فِی رَجُلٍ سَافَرَ وَہُوَ غَنِیٌّ فَنَفِدَ مَا مَعَہُ فِی سَفَرِہِ وَاحْتَاجَ ؟ قَالَ : یُعْطَی مِنَ الصَّدَقَۃِ فِی سَفَرِہِ لأَنَّہُ ابْنُ السَّبِیلِ۔",,,10789,,
10790,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، عَنْ حَکِیمِ بْنِ حِزَامٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ یَسْتَغْنِ یُغْنِہِ اللَّہُ , وَمَنْ یَسْتَعْفِفْ یُعِفَّہُ اللَّہُ , وَالْیَدُ الْعُلْیَا خَیْرٌ مِنَ الْیَدِ السُّفْلَی۔ (بخاری 1427۔ مسلم 95)",,,10790,,
10791,"ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدٍ وَعُرْوَۃَ ، عَنْ حَکِیمِ بْنِ حِزَامٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : الْیَدُ الْعُلْیَا خَیْرٌ مِنَ الْیَدِ السُّفْلَی۔ (بخاری 2750۔ ترمذی 2463)",,,10791,,
10792,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَمِعْتُ أَبَا حَمْزَۃَ یُحَدِّثُ عَنْ ہِلاَلِ بْنِ حِصْنٍ ، قَالَ : نَزَلْتُ دَارَ أَبِی سَعِیدٍ فَضَمَّنِی وَإِیَّاہُ الْمَجْلِسُ فَحَدَّثَنِی ، أَنَّہُ أَصْبَحَ ذَاتَ یَوْمٍ وَقَدْ عَصَبَ عَلَی بَطْنِہِ مِنَ الْجُوعِ ، قَالَ : فَأَتَیْت النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَدْرَکْتُ مِنْ قَوْلِہِ وَہُوَ یَقُولُ : مَنْ یَسْتَعْفِفْ یُعِفُّہُ اللَّہُ وَمَنْ یَسْتَغْنِ یُغْنِہِ اللَّہُ وَمَنْ سَأَلَنَا إمَّا أَنْ نَبْذُلَ لَہُ , وَإِمَّا أَنْ نُوَاسِیَہُ وَمَنْ یَسْتَغْنِ ، أَو یَسْتَعْفِفْ عَنَّا خَیْرٌ لَہُ مِنْ أَنْ یَسْأَلَنَا ، قَالَ : فَرَجَعْت فَمَا سَأَلْتُہُ شَیْئًا۔ (نسائی 2369۔ احمد 3/44)",,,10792,,
10793,"عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اسْتَغْنِ عَنِ النَّاسِ وَلَوْ بِقِصْمَۃِ سِوَاکٍ۔ (بزار 913)",,,10793,,
10794,أَبُو مُعَاوِیَۃَ ، وَابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ، عَنِ الْحَکَمِ، عَنْ عَبْدِالرَّحْمَنِ بْنِ أَبِی لَیْلَی، بِمِثْلِہِ، وَلَمْ یَرْفَعْہُ۔,,,10794,,
10795,"وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ عَبْدِاللہِ بْنِ دِینَارٍ، عَنِ ابْنِ عُمَرَ، قَالَ: کُنَّا نَتَحَدَّثُ أَنَّ الْیَدَ الْعُلْیَا ہِیَ الْمُتَعَفِّفَۃُ۔",,,10795,,
10796,"ابْنُ فُضَیْلٍ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : الْیَدُ الْعُلْیَا خَیْرٌ مِنَ الْیَدِ السُّفْلَی وَخَیْرُ الصَّدَقَۃِ مَا أَبْقَتْ غِنًی وَابْدَأْ بِمَنْ تَعُولُ۔",,,10796,,
10797,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ أَسْوَدَ بْنِ ہِلاَلٍ ، عَنْ ثَعْلَبَۃَ بْنِ زَہْدَمٍ ، قَالَ : انْتَہَی قَوْمٌ مِن ثَعْلَبَۃَ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یَخْطُبُ وَہُوَ یَقُولُ : یَدُ الْمُعْطِی : الْعُلْیَا وَیَدُ السَّائِلِ : السُّفْلَی , وَابْدَأْ بِمَنْ تَعُولُ : أُمَّک وَأَبَاک وَأُخْتَکَ وَأَخَاک وَأَدْنَاک فَأَدْنَاک۔ (طیالسی 1257۔ مسندہ 634)",,,10797,,
10798,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الْمُغِیرَۃِ بْنِ النُّعْمَانِ ، عَنْ عَبْدِ اللہِ بْنِ الأَقْنَعِ الْبَاہِلِیِّ، عَنِ الأَحْنَفِ بْنِ قَیْسٍ ، قَالَ : کُنْتُ جَالِسًا فِی مَجْلِسٍ فِی الْمَدِینَۃِ , فَأَقْبَلَ رَجُلٌ لاَ تَرَی حَلْقَۃٌ إِلاَّ فَرُّوا مِنْہُ حَتَّی انْتَہَی إلَی الْحَلْقَۃِ الَّتِی کُنْت فِیہَا , فَثَبَتُّ وَفَرُّوا ، فَقُلْت : مَنْ أَنْتَ ؟ قَالَ : أَبُو ذَرٍّ صَاحِبُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَقُلْت : مَا یَفِرُّ النَّاسُ مِنْک ؟ قَالَ : إنِّی أَنْہَاہُمْ ، عَنِ الْکُنُوزِ ، قَالَ : قُلْتُ : إنَّ أَعْطِیَاتِنَا قَدْ بَلَغَتْ وَارْتَفَعَتْ فَتَخَافُ عَلَیْنَا مِنْہَا ، قَالَ : أَمَّا الْیَوْمُ فَلاَ وَلَکِنَّہَا یُوشِکُ أَنْ تَکُونَ أَثْمَانَ دِینِکُمْ فَدَعُوہُمْ وَإِیَّاہَا۔",,,10798,,
10799,"ابْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، قَالَ مَرَرْنَا عَلَی أَبِی ذَرٍّ بِالرَّبَذَۃِ فَسَأَلْنَاہ عَنْ مَنْزِلِہِ ، قَالَ: کُنْتُ بِالشَّامِ فَقَرَأَتْ ہَذِہِ الآیَۃَ (وَالَّذِینَ یَکْنِزُونَ الذَّہَبَ وَالْفِضَّۃَ ، وَلاَ یُنْفِقُونَہَا فِی سَبِیلِ اللہِ فَبَشِّرْہُمْ بِعَذَابٍ أَلِیمٍ) ، فَقَالَ : مُعَاوِیَۃُ إنَّمَا ہِیَ فِی أَہْلِ الْکِتَابِ فَقُلْنَا : إِنَّہَا لَفِینَا وَفِیہِمْ۔",,,10799,,
10800,"ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنْ مَسْرُوقٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : وَالَّذِی لاَ إلَہَ غَیْرُہُ لاَ یُعَذِّبُ اللَّہُ رَجُلاً یَکْنِزُ فَیَمَسُّ دِرْہَمٌ دِرْہَمًا ، وَلاَ دِینَارٌ دِینَارًا , وَلَکِنْ یُوَسِّعُ جِلْدَہُ حَتَّی یُوضَعَ کُلُّ دِرْہَمٍ وَدِینَارٍ عَلَی حِدَتِہِ۔",,,10800,,
10801,"أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی وَائِلٍ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ یَقُولُ فِی قولہ تعالی : {سَیُطَوَّقُونَ مَا بَخِلُوا بِہِ یَوْمَ الْقِیَامَۃِ} قَالَ {یُطَوَّقُونَ} ثُعْبَانًا بِفِیہِ زَبِیبَتَانِ یَنْہَشُہُ یَقُولُ أَنَا مَالُکَ الَّذِی بَخِلْتَ بِہِ۔",,,10801,,
10802,"یَعْلَی بْنُ عُبَیْدٍ ، قَالَ : حدَّثَنَا عَبْدُ الْمَلِکِ بْنُ أَبِی سُلَیْمَانَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا مِنْ صَاحِبِ إبِلٍ ، وَلاَ بَقَرٍ ، وَلاَ غَنَمٍ لاَ یُؤَدِّی حَقَّہَا إِلاَّ قَعَدَ لَہَا یَوْمَ الْقِیَامَۃِ بِقَاعٍ قَرْقَرٍ , تَطَؤُہُ ذَاتُ الظِّلْفِ بِظِلْفِہَا , وَتَنْطَحُہُ ذَاتُ الْقَرْنِ بِقَرْنِہَا , وَلَیْسَ فِیہَا یَوْمَئِذٍ جَمَّائُ ، وَلاَ مَکْسُورَۃُ الْقَرْنِ قَالُوا : یَا رَسُولَ اللہِ ، وَمَا حَقُّہَا ؟ قَالَ إطْرَاقُ فَحْلِہَا , وَإِعَارَۃُ دَلْوِہَا , وَمَنِیحَتُہَا وَحَلْبُہَا عَلَی الْمَاء وَحَمْلٌ عَلَیْہَا فِی سَبِیلِ اللہِ۔ (مسلم 27۔ احمد 3/321)",,,10802,,
10803,"زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنِی مُوسَی بْنُ عُبَیْدَۃَ ، قَالَ : حَدَّثَنِی عِمْرَانُ بْنُ أَبِی أُنَیْسٍ ، عَنْ مَالِکِ بْنِ أَوْسِ بْنِ الْحَدَثَانِ ، عَنْ أَبِی ذَرٍّ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَوْ حَبِیبِی یَقُولُ : فِی الإِبِلِ صَدَقَتُہَا مَنْ جَمَعَ دِینَارًا ، أَوْ دِرْہَمًا ، أَوْ تِبْرًا ، أَوْ فِضَّۃً ، لاَ یُعِدُّہُ لِغَرِیمٍ ، وَلاَ یُنْفِقُہُ فِی سَبِیلِ اللہِ فَہُوَ کَیٌّ یُکْوَی بِہِ یَوْمَ الْقِیَامَۃِ۔ (دارقطنی 27۔ بیہقی 147)",,,10803,,
10804,"جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ فِی قولہ تعالی : {سَیُطَوَّقُونَ مَا بَخِلُوا بِہِ یَوْمَ الْقِیَامَۃِ} قَالَ : طَوْقٌ مِنْ نَارٍ۔",,,10804,,
10805,"خَلَفُ بْنُ خَلِیفَۃَ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ مَسْرُوقٍ فِی قولہ تعالی : (سَیُطَوَّقُونَ مَا بَخِلُوا بِہِ یَوْمَ الْقِیَامَۃِ) قَالَ : ہُوَ الرَّجُلُ یَرْزُقُہُ اللَّہُ الْمَالَ فَیَمْنَعُ قَرَابَتَہُ الْحَقَّ الَّذِی فِیہِ فَیُجْعَلُ حَیَّۃً فَیُطَوَّقُہَا فَیَقُولُ : مَا لِی وَمَا لَکَ ؟ فَیَقُولُ الْحَیَّۃُ : أَنَا مَالُک۔",,,10805,,
10806,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ مُحَمَّدِ بْنِ زِیَادٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أُتِیَ بِتَمْرٍ مِنْ تَمْرِ الصَّدَقَۃِ فَتَنَاوَلَ الْحَسَنُ بْنُ عَلِیٍّ تَمْرَۃً فَلاَکَہَا فِی فِیہِ ، فَقَالَ لَہُ : رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کَخٍْ کَخٍْ إنَّا لاَ تَحِلُّ لَنَا الصَّدَقَۃُ۔ (بخاری 1491۔ مسلم 161)",,,10806,,
10807,"حَدَّثَنَا وَکِیعٌ وَأَبُو أُسَامَۃَ ، عَنْ ثَابِتِ بْنِ عُمَارَۃَ ، عَنْ شَیْخٍ یُقَالُ لَہُ رَبِیعَۃُ بْنُ شَیْبَانَ ، قَالَ : قُلْتُ لِلْحَسَنِ بْنِ عَلِیٍّ رضی اللَّہُ عَنْہُما مَا تَذْکُرُ ، عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَمَا تَعْقِلُ عَنْہُ ، قَالَ أَخَذْت تَمْرَۃً مِنْ تَمْرِ الصَّدَقَۃِ فَلُکْتہَا ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّا لاَ تَحِلُّ لَنَا الصَّدَقَۃُ۔\n\n(احمد 1/200۔ طبرانی 2741)",,,10807,,
10808,"وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ طَلْحَۃَ ، عَنْ أَنَسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَجَدَ تَمْرَۃً ، فَقَالَ : لَوْلاَ أَنْ تَکُونَ مِنَ الصَّدَقَۃِ لأَکَلْتہَا۔ (بخاری 2055۔ مسلم 166)",,,10808,,
10809,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عِکْرِمَۃَ ، قَالَ : لاَ تَحِلُّ الصَّدَقَۃُ لِبَنِی ہَاشِمٍ ، وَلاَ لِمَوَالِیہِمْ۔",,,10809,,
10810,"غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنِ ابْنِ أَبِی رَافِعٍ ، عَنْ أَبِی رَافِعٍ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعَثَ رَجُلاً مِنْ بَنِی مَخْزُومٍ عَلَی الصَّدَقَۃِ ، فَقَالَ لأَبِی رَافِعٍ تَصْحَبُنِی کَیْمَا تُصِیبَ مِنْہَا ، فَقَالَ : لاَ حَتَّی آتِیَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَانْطَلَقَ إلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَسَأَلَہُ فَقَالَ لَہُ : إنَّ الصَّدَقَۃَ لاَ تَحِلُّ لَنَا , وَمَوْلَی الْقَوْمِ مِنْ أَنْفُسِہِمْ۔ (ترمذی 657۔ ابوداؤد 1647)",,,10810,,
10811,حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ شَرِیکٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، أَنَّ خَالِدَ بْنَ سَعِیدٍ بَعَثَ إلَی عَائِشَۃَ بِبَقَرَۃٍ مِنَ الصَّدَقَۃِ فَرَدَّتْہَا وَقَالَتْ إنَّا آلَ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ تَحِلُّ لَنَا الصَّدَقَۃُ۔,,,10811,,
10812,"عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی قُرَّۃَ الْکِنْدِیِّ ، عَنْ سَلْمَانَ ، قَالَ احْتَطَبْت حَطَبًا فَبِعْتُہُ ، فَأَتَیْت بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَوَضَعْتُہُ بَیْنَ یَدَیْہِ ، فَقَالَ : مَا ہَذَا قُلْتُ صَدَقَۃٌ، فَقَالَ لأَصْحَابِہِ کُلُوا ، وَلَمْ یَأْکُلْ۔ (احمد 5/438۔ حاکم 108)",,,10812,,
10813,"وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : أَتَیْتُ أُمَّ کُلْثُومٍ ابْنَۃَ عَلِیٍّ بِشَیْئٍ مِنَ الصَّدَقَۃِ فَرَدَّتْہَا وَقَالَتْ حَدَّثَنِی مَوْلًی لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُقَالُ لَہُ مِہْرَانُ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّا آلَ مُحَمَّدٍ لاَ تَحِلُّ لَنَا الصَّدَقَۃُ وَمَوْلَی الْقَوْمِ مِنْہُمْ۔ (احمد 3/448۔ عبدالرزاق 6942)",,,10813,,
10814,"الْحَسَنُ بْنُ مُوسَی ، عَنْ زُہَیْرٍ ، عَنْ عَبْدِ اللہِ بْنِ عِیسَی ، عَنْ أَبِیہِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی بَیْتِ الصَّدَقَۃِ ، قَالَ : فَجَائَ الْحَسَنُ بْنُ عَلِیٍّ فَأَخَذَ تَمْرَۃً فَأَخَذَہَا مِنْہُ فَاسْتَخْرَجَہَا ، وَقَالَ : إنَّا لاَ تَحِلُّ لَنَا الصَّدَقَۃُ۔ (احمد 4/348۔ دارمی 1643)",,,10814,,
10815,"ابْنُ فُضَیْلٍ ، عَنْ أَبِی حَیَّانَ ، عَنْ یَزِیدَ بْنِ حَیَّانَ ، قَالَ : انْطَلَقْت أَنَا وَحُصَیْنُ بْنُ عُقْبَۃَ إلَی زَیْدِ بْنِ أَرْقَمَ ، فَقَالَ لَہُ یَزِیدُ وَحُصَیْنٌ مَنْ أَہْلُ بَیْتِہِ , أَلَیْسَ نِسَاؤُہُ مِنْ أَہْلِ بَیْتِہِ ؟ قَالَ : نِسَاؤُہُ مِنْ أَہْلِ بَیْتِہِ , وَلَکِنْ أَہْلُ بَیْتِہِ مَنْ حُرِمَ الصَّدَقَۃَ بعدہ، فَقَالَ لَہُ حُصَیْنٌ : وَمَنْ ہُمْ ؟ قَالَ : ہُمْ آلُ عَبَّاسٍ ، وَآلُ عَلِیٍّ ، وَآلُ جَعْفَرٍ ، وَآلُ عَقِیلٍ، فَقَالَ لَہُ حُصَیْنٌ عَلَی ہَؤُلاَئِ تَحْرُمُ الصَّدَقَۃُ ، قَالَ نَعَمْ۔ (مسلم 36۔ احمد 4/367)",,,10815,,
10816,"کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : حدَّثَنَا ثَابِتُ بْنُ الْحَجَّاجِ ، قَالَ بَلَغَنِی ، أَنَّ رَجُلَیْنِ مِنْ بَنِی عَبْدِ الْمُطَّلِبِ أَتَیَا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْأَلاَنِہِ مِنَ الصَّدَقَۃِ ، فَقَالَ : لاَ وَلَکِنْ إذَا رَأَیْتُمَا عِنْدِی شَیْئًا مِنَ الْخُمُسِ فَأْتِیَانِی۔",,,10816,,
10817,"وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ خُصَیْفٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ آلُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ تَحِلُّ لَہُمُ الصَّدَقَۃُ فَجَعَلَ لَہُمْ خُمُسَ الْخُمْسِ۔ (نسائی 4449)",,,10817,,
10818,"الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا مُعَرِّفُ بْنُ وَاصِلٍ ، قَالَ حَدَّثَتْنِی حَفْصَۃُ بِنْتُ طَلْقٍ قَالَتْ حَدَّثَنِی جَدِّی رُشَیْدُ بْنُ مَالِکٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّا لاَ تَحِلُّ لَنَا الصَّدَقَۃُ۔ (بخاری 1131۔ احمد 3/489)",,,10818,,
10819,"حَدَّثَنَا عَبْدُ الرَّحِیمِ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ عُمَرَ ، عَنْ مَحْمُودِ بْنِ لَبِیدٍ ، عَنْ رَافِعِ بْنِ خَدِیجٍ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : الْعَامِلُ عَلَی الصَّدَقَۃِ بِالْحَقِّ کَالْغَازِی فِی سَبِیلِ اللہِ حَتَّی یَرْجِعَ إلَی بَیْتِہِ۔ (ترمذی 645۔ ابوداؤد 2929)",,,10819,,
10820,"أَبُو أُسَامَۃَ ، عَنْ بُرِیدِ بْنِ عبد اللہِ بْنِ أَبِی بُرْدَۃَ ، عَنْ جَدِّہِ ، عَنْ أَبِی مُوسَی ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ الْخَازِنَ الأَمِینَ الَّذِی یُعْطِی مَا أُمِرَ بِہِ کَامِلاً مُوَفَّرًا طَیِّبَۃً بِہِ نَفْسُہُ حِینَ یَدْفَعُہُ إلَی الَّذِی أُمِرَ لہ بِہِ أَحَدُ الْمُتَصَدِّقَیْنِ۔ (بخاری 1438۔ ابوداؤد 1681)",,,10820,,
10821,"غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنِ الْحَسَنِ بْنِ مُسْلِمٍ الْمَکِّیِّ ، قَالَ بَعَثَ عُمَرُ بْنُ الْخَطَّابِ رَجُلاً مِنْ ثَقِیفٍ عَلَی الصَّدَقَۃِ فَرَآہُ بَعْدَ ذَلِکَ الْیَوْمِ ، فَقَالَ : أَلاَ أَرَاک وَلَکَ کَأَجْرِ الْغَازِی فِی سَبِیلِ اللہِ۔",,,10821,,
10822,أَبُو أُسَامَۃَ وَوَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زِیَادِ بْنِ أَبِی عُثْمَانَ ، عَنْ ثَابِتٍ ، عَنِ الْحَسَنِ ، قَالَ مَنْ دُفِعَتْ إلَیْہِ الصَّدَقَۃُ فَوَضَعَہَا مَوَاضِعَہَا فَلَہُ أَجْرُ صَاحِبِہَا۔,,,10822,,
10823,حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، أن عُمَرَ بْنِ الْخَطَّابِ جَعَلَ عَلَی أَہْلِ السَّوَادِ عَلَی کُلِّ جَرِیبٍ قَفِیزًا وَدِرْہَمًا۔,,,10823,,
10824,حَفْصٌ، عَنِ ابْنِ أَبِی عَرُوبَۃَ، عَنْ قَتَادَۃَ، عَنْ أَبِی مِجْلَزٍ، أَنَّ عُمَرَ جَعَلَ عَلَی جَرِیبِ النَّخْلِ ثَمَانیَۃَ دَرَاہِمَ۔,,,10824,,
10825,"عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ أَبِی عَوْنٍ مُحَمَّدِ بْنِ عُبَیْدِ اللہِ الثَّقَفِیِّ ، قَالَ وَضَعَ عُمَرُ بْنُ الْخَطَّابِ عَلَی أَہْلِ السَّوَادِ عَلَی کُلِّ جَرِیبِ أَرضٍ یَبْلُغُہُ الْمَائُ عَامِرًا وَغَامِرًا دِرْہَمًا وَقَفِیزًا مِنْ طَعَامٍ , وَعَلَی الْبَسَاتِینِ عَلَی کُلِّ جَرِیبِ أَرضٍ عَشَرَۃَ دَرَاہِمَ وَعَشَرَۃَ أَقْفِزَۃً من طَعَامٍ وَعَلَی الْکُرُومِ عَلَی کُلِّ جَرِیبِ أَرْضٍ عَشَرَۃَ دَرَاہِمَ وَعَشَرَۃَ أَقْفِزَۃً طَعَامٍ , وَعَلَی الرِّطَابِ عَلَی کُلِّ جَرِیبِ أَرْضٍ خَمْسَۃَ دَرَاہِمَ , وَخَمْسَۃَ أَقْفِزَۃَ طَعَامٍ ، وَلَمْ یَضَعْ عَلَی النَّخْلِ شَیْئًا , وَجَعَلَہُ تَبَعًا لِلأَرْضِ , وَعَلَی رُؤُوسِ الرِّجَالِ عَلَی الْغَنِیِّ ثَمَانِیَۃً وَأَرْبَعِینَ دِرْہَمًا , وَعَلَی الْوَسَطِ أَرْبَعَۃً وَعِشْرِینَ دِرْہَمًا , وَعَلَی الْفَقِیرِ اثْنَیْ عَشَرَ دِرْہَمًا۔",,,10825,,
10826,أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ مُحَمَّدِ بْنِ عُبَیْدِ اللہِ ، قَالَ وَضَعَ عُمَرُ عَلَی السَّوَادِ فَذَکَرَ مِثْلَ حَدِیثِ ابْنِ مُسْہِرٍ۔ (ابو عبید 174),,,10826,,
10827,أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ بَعَثَ عُمَرُ عُثْمَانَ بْنَ حُنَیْفٍ عَلَی مِسَاحَۃِ الأَرْضِ فَوَضَعَ عُثْمَانُ عَلَی الْجَرِیبِ مِنَ الْکَرْمِ عَشَرَۃَ دَرَاہِمَ وَعَلَی جَرِیبِ النَّخْلِ ثَمَانیَۃَ دَرَاہِمَ وَعَلَی جَرِیبِ الشَّعِیرِ دِرْہَمَیْنِ، وَجَعَلَ عَلَی کُلِّ رَأْسٍ فِی السَّنَۃِ أَرْبَعَۃً وَعِشْرِینَ دِرْہَمًا، وَعَطَّلَ النِّسَائَ وَالصِّبْیَانَ۔,,,10827,,
10828,"وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ عُمَرَ ، أَنَّہُ بَعَثَ عُثْمَانَ بْنَ حُنَیْفٍ عَلَی السَّوَادِ فَوَضَعَ عَلَی کُلِّ جَرِیبٍ عَامِرًا وَغَامِرًا یَنَالُہُ الْمَائُ دِرْہَمًا وَقَفِیزًا , یَعْنِی الْحِنْطَۃَ وَالشَّعِیرَ , وَعَلَی کُلِّ جَرِیبِ الْکَرْمِ عَشَرَۃَ دَرَاہِمَ , وَعَلَی کُلِّ جَرِیبِ الرَّطْبِ خَمْسَۃً۔",,,10828,,
10829,"وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، عَنْ أَبَانَ بْنِ تَغْلِبَ ، عَنْ رَجُلٍ ، عَنْ عُمَرَ ، أَنَّہُ وَضَع عَلَی النَّخْلِ عَلَی الرَّقْلَتَیْنِ دِرہَمًا وَعَلَی الْفَارِسِیَّۃِ دِرْہَمًا۔\n\nوَقَالَ وَکِیعٌ مَرَّۃً : عَنْ أَبَانَ ، عَنْ إبْرَاہِیمَ۔",,,10829,,
10830,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّہُ قَالَ ؛ فِی الرَّجُلِ إذَا أُعْطِیَ مِنْ صَدَقَۃِ الْفِطْرِ ، قَالَ : إذَا اجْتَمَعَتْ عِنْدَہُ الآصع أَعْطَی۔",,,10830,,
10831,"حَفْصٌ ، عَنْ عَاصِمٍ ، عَنْ أَبِی الْعَالِیَۃِ وَالشَّعْبِیِّ ، وَابْنِ سِیرِینَ قَالُوا : صَدَقَۃُ الْفِطْرِ عَلَی الْغَنِیِّ وَالْفَقِیرِ۔",,,10831,,
10832,وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُثَنًّی ، عَنْ عَطَائٍ ، قَالَ یَأْخُذُ وَیُعْطِی۔,,,10832,,
10833,"مَالِکُ بْنُ إسْمَاعِیلَ ، عَنْ مِنْدَلٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ تُعْطِی صَدَقَۃَ الْفِطْرِ مَنْ تَحِلُّ لَہُ الصَّدَقَۃُ ، قَالَ : وَقَالَ الزُّہْرِیُّ یُؤَدِّی حَقَّ اللہِ وَیَأْخُذُ۔",,,10833,,
10834,"عَفَّانُ ، قَالَ : حدَّثَنَا أَبُو عَوَانَۃَ ، عَنْ قَتَادَۃَ ، قَالَ یُعْطِی۔",,,10834,,
10835,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، قَالَ لَمْ یَبْلُغْنَا أن أَحَدا مِنْ وُلاَۃِ ہَذِہِ الأُمَّۃِ الَّذِینَ کَانُوا بِالْمَدِینَۃِ , أَبُو بَکْرٍ ، وَعُمَرُ , وَعُثْمَانَ , أَنَّہُمْ کَانُوا یَثْنُونَ الصَّدَقَۃَ لَکِنْ یَبْعَثُونَ عَلَیْہَا کُلَّ عَامٍ فِی الْخِصْبِ وَالْجَدْبِ لأَنَّ أَخْذَہَا سُنَّۃٌ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,10835,,
10836,"مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی سُلَیْمَانُ الأَحْوَلُ ، عَنْ طَاوُوسٍ ، أَنَّہُ قَالَ إذْ تَدَارَکَتِ الصَّدَقَتَانِ فَلاَ یُؤْخَذُ الأُولَی کَالْجِزْیَۃِ۔",,,10836,,
10837,"سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الْوَلِیدِ بْنِ کَثِیرٍ ، عَنْ حَسَنِ بْنِ حَسَنٍ ، عَنْ أُمِّہِ فَاطِمَۃَ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ ثِنَا فِی الصَّدَقَۃِ",,,10837,,
10838,"حَدَّثَنَا ہُشَیْمٌ، عَنْ رَہْطٍ ثَلاَثَۃٍ، عَنْ أَبِی جَعْفَرٍ، قَالَ: لاَ بَأْسَ بِالصَّدَقَۃِ مِنْ بَنِی ہَاشِمٍ بَعْضِہِمْ عَلَی بَعْضٍ۔",,,10838,,
10839,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ قَالَ: کَانَ یُقَالُ إنَّمَا الصَّدَقَاتُ لِلْفُقَرَائِ وَالْمُہَاجِرِینَ۔",,,10839,,
10840,"حَدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن حُمَیْدٍ ، عَن بَکر : أَنَّ عُثْمَانَ کَانَ یُعْطِی صَدَقَۃَ الْفِطْرِ ، عَنِ الْحَبَلِ۔",,,10840,,
10841,"عَبْدُالْوَہَّابِ الثَّقَفِیُّ، عَنْ أَیُّوبَ، عَنْ أَبِی قِلاَبَۃَ، قَالَ: کَانُوا یُعْطُونَ صَدَقَۃَ الْفِطْرِ حَتَّی یُعْطُونَ، عَنِ الْحَبَلِ۔",,,10841,,
10842,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَخَذَ الْمُصَدِّقُ سِنًّا فَوْقَ سِنٍّ رَدَّ عَلَیْہِمْ شَاتَیْنِ ، أَوْ عِشْرِینَ دِرْہَمًا ، وَإِذَا أَخَذَ سِنًّا دُونَ سِنٍّ رَدُّوا عَلَیْہِ شَاتَیْنِ ، أَوْ عِشْرِینَ دِرْہَمًا۔",,,10842,,
10843,"مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : أَخْبَرَنِی خَلاَّدٌ ، عَنْ عَمْرِو بْنِ شُعَیْبٍ ، أَنَّہُ قَالَ لَہُ ، فَإِنْ لَمْ تَجِدِ السِّنَّ الَّذِی دُونَہَا أَخَذْت السِّنَّ الَّذِی فَوْقَہَا وَرَدَدْت إلَی صَاحِبِ الْمَاشِیَۃِ شَاتَیْنِ ، أَوْ عِشْرِینَ دِرْہَمًا۔",,,10843,,
10844,مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ الأَنْصَارِیِّ ، أَنَّ عُمَرَ کَتَبَ إلَی بَعْضِ عُمَّالِہِ أَنْ لاَ تَأْخُذُوا مِنْ رَجُلٍ لَمْ تَجِدُوا فِی إبِلِہِ السِّنَّ الَّتِی عَلَیْہِ إِلاَّ تِلْکَ السِّنَّ خُذُوا شَروی إبِلِہِ ، أَوْ قِیمَۃَ عَدْلٍ۔,,,10844,,
10845,"غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ فِی رَجُلٍ وَجَبَتْ عَلَیْہِ فَرِیضَۃٌ فِی إبِلِہِ لَمْ تَکُنْ عِنْدَہُ ، قَالَ : فَقَالَ : یَتَرَادَّانِ الْفَضْلَ فِیمَا بَیْنَہُمَا۔",,,10845,,
10846,"الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ إِنْ أَخَذَ سِنًّا دُونَ سِنٍّ رَدَّ شَاتَیْنِ ، أَوْ عَشَرَۃَ دَرَاہِمَ",,,10846,,
10847,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عَبْدُ اللہِ بْنُ الْمُسْتَوْرِدِ ، قَالَ : سَمِعْتُ أَبَا قِلاَبَۃَ یُحَدِّثُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ ، قَالَ : بَعَثَ أَبُو بَکْرٍ الْمُصَدِّقِینَ فَأَمَرَہُمْ أَنْ یَبِیعُوا الْجَذَعَۃَ بِأَرْبَعِینَ وَالْحِقَّۃَ بِثَلاَثِینَ ، وَابْنَ لَبُونٍ بِعِشْرِینَ , وَبِنْتَ مَخَاضٍ بِعَشَرَۃٍ , فَانْطَلَقُوا فَبَاعُوا مَا بَاعُوا بِقِیمَۃِ أَبِی بَکْرٍ ، ثُمَّ رَجَعُوا حَتَّی إذَا کَانَ الْعَامُ الْمُقْبِلُ بَعَثَہُمْ فَقَالُوا : لَوْ شِئْنَا أَنْ نَزْدَادَ ازْدَدْنَا ، فَقَالَ : زِیدُوا فِی کُلِّ سِنٍّ عَشَرَۃً ، فَلَمَّا أن کَانَ الْعَامُ الْمُقْبِلُ بَعَثَہُمْ فَقَالُوا : لَوْ شِئْنَا أَنْ نَزْدَادَ ازْدَدْنَا شَیْئًا ، فَلَمَّا وَلِیَ عُمَرُ بَعَثَ عُمَّالَہُ بِقِیمَۃِ أَبِی بَکْرٍ الآخِرَۃِ حَتَّی إذَا کَانَ الْعَامُ الْمُقْبِلُ ، قَالَ الْعُمَّالُ لَوْ شِئْنَا أَنْ نَزْدَادَ ازْدَدْنَا ، فَقَالَ : زِیدُوا فِی کُلِّ سِنٍّ عَشْرَۃً حَتَّی إذَا کَانَ الْعَامُ الْمُقْبِلُ بَعَثَہُمْ بِالْقِیمَۃِ الآخِرَۃِ فَقَالُوا : لَوْ شِئْنَا أَنْ نَزْدَادَ ازْدَدْنَا ، قَالَ : لاَ حَتَّی إذَا وَلِیَ عُثْمَانُ بَعَثَ بِقِیمَۃِ عُمَرَ الآخِرَۃِ حَتَّی إذَا کَانَ الْعَامُ الْمُقْبِلُ قَالُوا : لَوْ شِئْنَا أَنْ نَزْدَادَ ازْدَدْنَا ، قَالَ : زِیدُوا فِی کُلِّ سِنٍّ عَشَرَۃً حَتَّی إذَا کَانَ الْعَامُ الْمُقْبِلُ قَالُوا : لَوْ شِئْنَا أَنْ نَزْدَادَ ازْدَدْنَا ، قَالَ : لاَ , فَلَمَّا وَلِیَ مُعَاوِیَۃُ بَعَثَ بِقِیمَۃِ عُثْمَانَ الآخِرَۃِ ، فَلَمَّا کَانَ الْعَامُ الْمُقْبِلُ قَالُوا : لَوْ شِئْنَا أَنْ نَزْدَادَ ازْدَدْنَا ، قَالَ : زِیدُوا فِی کُلِّ سِنٍّ عَشَرَۃً , حَتَّی إذَا کَانَ الْعَامُ الْمُقْبِلُ قَالُوا : لَوْ شِئْنَا أَنْ نَزْدَادَ ازْدَدْنَا ، قَالَ : خُذُوا الْفَرَائِضَ بِأَسْنَانِہَا ، ثُمَّ سَمُّوہَا وَأَعْلِنُوہَا ، ثُمَّ خالِسُوہُمْ لِلْبَیْعِ فَمَا اسْتَطَاعُوا أن ینتقصوا وَمَا اسْتَطَعْتُمْ أَنْ تَزْدَادُوا فَازْدَادُوا ، قَالَ عَبْدُ اللہِ : فَرَأَیْت عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَأَنَّہُ لَمْ یَرَ بِذَلِکَ بَأْسًا ، فَقَالَ لأَبِی قِلاَبَۃَ : فَکَیْفَ کَانَتْ صَدَقَۃُ الْغَنَمِ ؟ قَالَ : کَانَتِ الصَّدَقَۃُ تُؤْخَذُ فَتُقْسَمُ فِی فُقَرَائِ أَہْلِ الْبَادِیَۃِ حَتَّی إذْ کَانَ عَبْدُ الْمَلِکِ بْنُ مَرْوَانَ أَمَرَ بِہَا فَقُسِمَتْ أَخْمَاسًا فَجَعَلَ لِلْمِسْکِینَۃِ خُمُسًا مِنْہَا ، ثُمَّ لَمْ یَزَلْ ذَلِکَ إلَی الْیَوْمِ۔",,,10847,,
10848,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أنَّہُ کَانَ یقول : الجوامیس بمنزلۃ البقر۔",,,10848,,
10849,حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ قَالَ فِی رَجُلٍ فَرَّطَ فِی زَکَاتِہِ حَتَّی ذَہَبَ مَالُہُ ، قَالَ ہُوَ دَیْنٌ عَلَیْہِ حَتَّی یَقْضِیَہُ۔,,,10849,,
10850,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، أَنَّہُ قَالَ : إذَا کَانَ فِی الأَرْضِ بُرٌّ وَشَعِیرٌ کُلُّ وَاحِدٍ مِنْہَا أَقَلُّ مِنْ خَمْسَۃِ أَوْسَاقٍ فَإِذَا جَمَعَہُمَا کَانَ فیہِمَا خَمْسَۃُ أَوْسَاقٍ ، أَوْ أَکْثَرُ کَانَ فِیہِمَا الصَّدَقَۃُ لأَنَّ کُلَّہُ زَرْعٌ فَإِذَا کَانَ بُرٌّ وَزَبِیبٌ وَہُوَ لاَ یَبْلُغُ خَمْسَۃَ أَوْسَاقٍ فَلَیْسَ فِیہِ شَیْئٌ حَتَّی یَبْلُغَ مِنْ کُلِّ صِنْفٍ خَمْسَۃَ أَوْسَاقٍ فَإِذَا بَلَغَ فَفِیہِ الْعُشْرُ۔",,,10850,,
10851,"عَبْدُ السَّلاَمِ ، عَنْ لَیْثٍ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، قَالَ : فِی کُلِّ عَشَرَۃٍ مِنَ الْبَقَرِ شَاۃٌ , وَفِی کُلِّ عِشْرِینَ شَاتَانِ وَفِی کُلِّ ثَلاَثِینَ تَبِیعٌ۔",,,10851,,
10852,"عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ ، قَالَ : اسْتُعْمِلْت عَلَی صَدَقَاتِ عَکٍّ , فَلَقِیت أَشْیَاخًا مِمَّنْ صَدَّقَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ البقر , وَسَأَلْتُہُمْ فَاخْتَلَفُوا عَلَیَّ , فَمِنْہُمْ مَنْ قَالَ اجْعَلْہَا مِثْلَ صَدَقَۃِ الإِبِلِ , وَمِنْہُمْ مَنْ قَالَ فِی ثَلاَثِینَ تَبِیعٌ , وَمِنْہُمْ مَنْ قَالَ فِی أَرْبَعِینَ بَقَرَۃً بَقَرَۃٌ مُسِنَّۃٌ۔",,,10852,,
10853,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : أَخْبَرَنَا أَشْعَثُ ، عَنِ الْحَسَنِ ، أَنَّہُ قَالَ فِی رَجُلٍ اشْتَرَی مِنْ زَکَاتِہِ نَسَمَۃً فَأَعْتَقَہَا فَمَاتَتِ النَّسَمَۃُ وَتَرَکَتْ مِیرَاثًا ، قَالَ یُوَجِّہُہَا فِی مَوَاضِعِ الزَّکَاۃِ۔",,,10853,,
10854,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ عِمْرَانَ الْقَطَّانِ ، قَالَ : سُئِلَ الْحَسَن ہَلْ عَلَی الْمَرْأَۃِ زَکَاۃٌ فِی مَالِہَا عَلَی ظَہْرِ زَوْجِہَا ، قَالَ إِنْ کَانَ مَلِیًّا فَعَلَیْہَا زَکَاتُہُ۔",,,10854,,
10855,"إِسْحَاقُ الأَزْرَقُ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، أَنَّہُ قَالَ : عَلَی الْمَرْأَۃِ أَنْ تُزْکِیَ مَہْرَہَا إذَا کَانَ عَلَی زَوْجِہَا إِنْ کَانَ مُوسِرًا ، وَإِنْ کَانَ فَقِیرًا فَلَیْسَ عَلَیْہَا شَیْئٌ۔",,,10855,,
10856,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لَہُ لَوْ کَانَتْ لِرَجُلٍ تِسْعَۃَ عَشَرَ دِینَارًا لَیْسَ لَہُ غَیْرُہَا وَالصَّرْفُ اثْنا عَشَرَ ، أَوْ ثَلاَثَۃَ عَشَرَ فِیہَا صَدَقَۃٌ ؟ قَالَ : نَعَمْ , إذَا کَانَتْ لَوْ صُرِفَتْ مِئَتَیْ دِرْہَمٍ إنَّمَا کَانَ إذْ ذَاکَ الْوَرِقُ ، وَلَمْ یَکُنِ الذَّہَبُ۔",,,10856,,
10857,"عَبْدُ السَّلاَمِ ، قَالَ : حدَّثَنَا یَحیی بْنُ سَعِیدٍ ، قَالَ : مِنَ السُّنَّۃِ فِی الصَّدَقَۃِ أَنْ یُؤْخَذَ مَعَ کُلِّ بَعِیرٍ عِقَالٌ ، وَمَعَ کُلِّ بَعِیرَیْنِ عِقَالین وَقِرَانًا۔",,,10857,,
10858,"حَدَّثَنَا شَرِیکٌ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ أَبُو بَکْرٍ : لَوْ مَنَعُونِی عِقَالاً مِمَّا أَعْطَوْا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لَجَاہَدْتہمْ علیہ۔",,,10858,,
10859,"حَدَّثَنَا جَرِیرٌ ، عَنِ أَبِی حَیَّانَ ، عَنِ الْحَارِثِ فِی قولہ تعالی : (وَأَقِیمُوا الصَّلاَۃَ وَآتُوا الزَّکَاۃَ) قَالَ : عَنَی بِہِ صَدَقَۃَ الْفِطْرِ۔",,,10859,,
10860,"غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ ، قَالَ : صَدَقَۃُ الْفِطْرِ صَاعًا مَکْتُوبٌ۔",,,10860,,
10861,"وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی الْعَالِیَۃِ ، وَابْنِ سِیرِینَ قَالاَ : صَدَقَۃُ الْفِطْرِ فَرِیضَۃٌ۔",,,10861,,
10862,"أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : فَرَضَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَدَقَۃَ الْفِطْرِ۔ (بخاری 1504۔ ابوداؤد 1607)",,,10862,,
10863,یَزِیدُ بْنُ ہَارُونَ وَسَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ فَرَضَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَدَقَۃَ الْفِطْرِ۔,,,10863,,
10864,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إنَّمَا کَانَتِ الْمُؤَلَّفَۃُ قُلُوبُہُمْ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا وَلِیَ أَبُو بَکْرٍ انْقَطَعَتْ۔",,,10864,,
10865,وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ الْیَوْمَ مُؤَلَّفَۃٌ۔,,,10865,,
10866,"حَدَّثَنَا عَفَّانُ ، قَالَ : سُئِلَ حَمَّادٌ ، عَنِ الْمُؤَلَّفَۃِ قُلُوبُہُمْ فحَدَّثَنَا عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ الَّذِینَ یَدْخُلُونَ فِی الإِسْلاَمِ۔",,,10866,,
10867,"مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیِّ ، قَالَ : حدَّثَنَا مَعْقِلٌ ، قَالَ : سَأَلْتُ الزُّہْرِیَّ : عَنِ الْمُؤَلَّفَۃِ قُلُوبُہُمْ ، قَالَ : ہُوَ مَنْ أَسْلَمَ مِنْ یَہُودِیٍّ ، أَوْ نَصْرَانِیٍّ قُلْتُ : وَإِنْ کَانَ غَنِیًّا ، قَالَ : وَإِنْ کَانَ غَنِیًّا۔",,,10867,,
10868,"عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ ، عَنْ حَیَّانَ السُّلَمِیِّ ، قَالَ : قُلْتُ لِاِبْنِ عُمَرَ یَجِیئُنِی مُصَدِّقُوا ابْنِ الزُّبَیْرِ فَیَأْخُذُونَ صَدَقَۃَ مالی وَیَجِیئُ مُصَدِّقُوا نَجْدۃَ فَیَأْخُذُونَ ؟ قَالَ : أَیُّہُمَا أَعْطَیْت أَجْزَأَک۔",,,10868,,
10869,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَشْعَثَ ، عَنِ الزُّہْرِیِّ ، قَالَ أَخَذَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ مَجُوسِ ہَجَرَ مِنْ کُلِّ حَالِمٍ دِینَارًا۔,,,10869,,
10870,"حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ وَہُوَ فِی مَجْلِسٍ بَیْنَ الْقَبْرِ وَالْمِنْبَرِ مَا أَدْرِی کَیْفَ أَصْنَعُ بِالْمَجُوسِ وَلَیْسُوا بِأَہْلِ کِتَابٍ ، فَقَالَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : سُنُّوا بِہِمْ سُنَّۃَ أَہْلِ الْکِتَابِ۔ (مالک 42۔ عبدالرزاق 10025)",,,10870,,
10871,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ سَعد ، قَالَ : حَدَّثَنِی عمْرُو بْنُ شُعَیْبٍ ، عَنْ أَبِیہِ، عَنْ جَدِّہِ ، قَالَ : قَالَ رَجُلٌ یَا رَسُولَ اللہِ مَا کَانَ فِی الطَّرِیقِ غَیرِ المِیتَائِ ، أَوْ فِی الْقَرْیَۃِ الْمَسْکُونَۃِ ، قَالَ فِیہِ، وَفِی الرِّکَازِ الْخُمْسُ۔ (احمد 2/180۔ حمیدی 597)",,,10871,,
10872,"عَبْدُ الْوَہَّابِ ، عَن أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : فِی الرِّکَازِ الْخُمْسُ۔",,,10872,,
10873,وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ مِثْلُہُ۔,,,10873,,
10874,"عَبْدُ الرَّحِیمِ ، عَنِ ابْنِ أَبِی خَالِدٍ وَزَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فِی الرِّکَازِ الْخُمْسُ۔ (احمد 2/493)",,,10874,,
10875,عَبْدُ الرَّحِیمِ ، عَنْ أَشْعَثَ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِثْلُہُ۔,,,10875,,
10876,أَبُو أُسَامَۃَ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، أَنَّ غُلاَمًا مِنَ الْعَرَبِ وَجَدَ سَتُّوقَۃً فِیہَا عَشَرَۃُ آلاَفٍ فَأَتَی بِہَا عُمَرَ فَأَخَذَ مِنْہَا خُمْسَہَا أَلْفَیْنِ وَأَعْطَاہُ ثَمَانیَۃَ آلاَفٍ۔,,,10876,,
10877,"وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، أَنَّ رَجُلاً وَجَدَ فِی خَرِبَۃٍ أَلْفًا وَخَمْسَمِئَۃٍ فَأَتَی عَلِیًّا، فَقَالَ : أَدِّ خُمْسَہَا وَلَک ثَلاَثَۃُ أَخْمَاسِہَا وَسَنُطَیِّبُ لَکَ الْخُمْسَ الْبَاقِیَ۔",,,10877,,
10878,"مُعْتَمِرٌ ، عَنْ مَعْمَرٍ الضَّبِّیِّ ، قَالَ بَیْنَمَا قَوْمٌ عِنْدِی بِسَابُور یُلَیّنون ، أَوْ یُثِیرُونَ الأَرْضَ إذْ أَصَابُوا کَنْزًا وَعَلَیْہَا مُحَمَّدُ بْنُ جَابِرٍ الرَّاسِبِیُّ ، فَکَتَبَ فِیہِ إلَی عَدِیٍّ , فَکَتَبَ عَدِیٌّ إلَی عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَکَتَبَ عُمَرُ أَنْ خُذُوا مِنْہُ الْخُمْسَ ، وَاکْتُبُوا لَہُمُ الْبَرَائَۃَ , وَدَعُوا سَائرہ لہم فدفع إلیہم الماء وأخذ منہم الخمس۔",,,10878,,
10879,"ہُشَیْمٌ ، عَنْ حُصَیْنٍ عَمَّنْ شَہِدَ الْقَادِسِیَّۃَ قَالَ : بَیْنَمَا رَجُلٌ یَغْتَسِلُ إذْ فَحَصَ لَہُ الْمَائُ التُّرَابَ عَنْ لَبِنَۃٍ مِنْ ذَہَبٍ فَأَتَی سَعْدَ بْنَ أَبِی وَقَّاصٍ فَأَخْبَرَہُ ، فَقَالَ : اجْعَلْہَا فِی غَنَائِمِ الْمُسْلِمِینَ۔",,,10879,,
10880,"ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ أَبِی قَیْسٍ عَبْدِ الرَّحْمَنِ بْنِ ثَرْوَانَ ، عَنْ ہُزَیْلٍ ، قَالَ : جَائَ رَجُلٌ إلَی عَبْدِ اللہِ ، فَقَالَ : إنِّی وَجَدْت مِئِینَ مِنَ دَرَاہِمٍ ، فَقَالَ عَبْدُ اللہِ : لاَ أَرَی الْمُسْلِمِینَ بَلَغَتْ أَمْوَالُہُمْ ہَذَا , أُرَاہُ رِکَازَ مَالٍ عَادِیٍّ , فَأَدِّ خُمْسَہُ فِی بَیْتِ الْمَالِ , وَلَکَ مَا بَقِیَ۔",,,10880,,
10881,"عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : الرِّکَازُ الْکَنْزُ الْعَادِیُّ , وَفِیہِ الْخُمْسُ۔",,,10881,,
10882,"أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا وُجِدَ الْکَنْزُ فِی أَرْضِ الْعَدُوِّ فَفِیہِ الْخُمْسُ ، وَإِذَا وُجِدَ فِی أَرْضِ الْعَرَبِ فَفِیہِ الزَّکَاۃُ۔",,,10882,,
10883,"غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ إبْرَاہِیمَ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ، أَنَّ رَجُلاً سَأَلَ عَائِشَۃَ ، فَقَالَ : إنِّی وَجَدْت کَنْزًا فَدَفَعْتُہُ إلَی السُّلْطَانِ ، فَقَالَتْ فِی فِیک الْکَِثْکَِتِ ، أَوْ کَلِمَۃٍ نَحْوِہَا , الشَّکُّ مِنِّی۔",,,10883,,
10884,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فِی الرِّکَازِ الْخُمْسُ۔ (بخاری 1499۔ مسلم 1335)",,,10884,,
10885,"خَالِدُ بْنُ مَخْلَدٍ ، عَنْ کَثِیرِ بْنِ عَبْدِ اللہِ الْمُزَنِیّ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فِی الرِّکَازِ الْخُمْسُ۔ (ابن ماجہ 2674۔ طبرانی 6)",,,10885,,
10886,"الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إسْرَائِیلَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : قَضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الرِّکَازِ الْخُمْسُ۔ (احمد 314)",,,10886,,
10887,"الْفَضْلُ ، قَالَ : حدَّثَنَا عُمَرُ بْنُ الْوَلِیدِ الشَّنِّی ، عَنْ عِکْرِمَۃَ ، قَالَ : سُئِلَ عَنْ رَجُلٍ وَجَدَ مَطْمُورَۃً ، قَالَ أَدِّ خُمُسَہَا۔",,,10887,,
10888,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ حُمَیْدِ بْنِ صَخْرٍ ، عَنْ عُمَرَ بْنِ أَبِی بَکْرٍ ، قَالَ : حدَّثَنِی أَبِی ، قَالَ : دَخَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَسْجِدَ وَأَقْنَائٌ فِی الْمَسْجِدِ مُعَلَّقَۃٌ ، وَإِذَا فِیہِ قِنْوٌ فِیہِ جَدَرٌ، وَمَعَہُ عُرْجُونٌ ، أَوْ عَصًا ، فَطَعَنَ فِیہِ ، وَقَالَ : مَنْ جَائَ بِہَذَا ؟ قَالُوا : فُلاَنٌ ، قَالَ : بَؤُسَ أُنَاسٌ یُمْسِکُونَ صَدَقَاتِہِمْ، ثُمَّ یُطْرَحُ بِالْعَرَائِ فَلاَ تَأْکُلُہَا الْعَافِیَۃُ یہَاجر کَل بَرْقِۃ وَرَعْدَۃ إلَی الشَّامِ۔(ابوداؤد 1604۔ احمد 6/28)",,,10888,,
10889,"أَبُو أُسَامَۃَ ، عَنْ مُحَمَّدِ بْنِ أَبِی حَفْصَۃَ ، قَالَ : حدَّثَنِی الزُّہْرِیُّ ، عَنْ أَبِی أُمَامَۃَ بْنِ سَہْلٍ ، قَالَ : کَانَ نَاسٌ یَتَصَدَّقُونَ بِشِرَارِ ثِمَارِہِمْ حَتَّی نَزَلَتْ {وَلاَ تَیَمَّمُوا الْخَبِیثَ مِنْہُ تُنْفِقُونَ وَلَسْتُمْ بِآخِذِیہِ إِلاَّ أَنْ تُغْمِضُوا فِیہِ}۔",,,10889,,
10890,"ابْنُ عُلَیَّۃَ ، عَنْ سَلَمَۃَ بْنِ عَلْقَمَۃَ ، عَنِ ابْنِ سِیرِینَ ، أَنَّہُ سَأَلَ عَبِیدَۃَ ، عَنْ قولہ تعالی : (وَلاَ تَیَمَّمُوا الْخَبِیثَ مِنْہُ تُنْفِقُونَ وَلَسْتُمْ بِآخِذِیہِ) إنَّمَا ذَلِکَ فِی الزَّکَاۃِ , وَالدَّرَاہِمُ الزَّیْفُ أَحَبُّ إلَیَّ مِنَ التَّمْرِ۔",,,10890,,
10891,"وَکِیعٌ ، عَنْ یَزِیدَ ، عَنِ الْحَسَنِ {وَلاَ تَیَمَّمُوا الْخَبِیثَ مِنْہُ تُنْفِقُونَ} قَالَ : کَانَ الرَّجُلُ یَتَصَدَّقُ بِرَذَاذَۃِ مَالِہِ۔",,,10891,,
10892,"عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ إسْرَائِیلَ ، عَنِ السُّدِّیِّ ، عَنْ أَبِی مَالِکٍ ، عَنِ الْبَرَائِ فِی قولہ تعالی : {وَلاَ تَیَمَّمُوا الْخَبِیثَ} قَالَ : نَزَلَتْ فِینَا کُنَّا أَصْحَابَ نَخْلٍ ، فَکَانَ الرَّجُلُ یَأْتِی مِنْ نَخْلِہِ کَقَدْرِ قِلَّتِہِ وَکَثْرَتِہِ ، قَالَ : فَکَانَ الرَّجُلُ یَأْتِی بِالْقِنْوِ وَالرَّجُلُ یَأْتِی بِالْقِنْوَیْنِ , فَیُعَلِّقُہُ فِی الْمَسْجِدِ ، قَالَ وَکَانَ أَہْلُ الصُّفَّۃِ لَیْسَ لَہُمْ طَعَامٌ، فَکَانَ أَحَدُہُمْ إذَا جَائَ أتی الْقِنْوِ فَضَرَبَہُ بِعَصًا فَیَسْقُطُ مِنَ التَّمْرِ وَالْبُسْرِ فَیَأْکُلُ وَکَانَ أُنَاسٌ مِمَّنْ لاَ یَرْغَبُ فِی الْخَیْرِ فَیَأْتِی أَحَدُہُمْ بِالْقِنْوَ فِیہِ الْحَشَفُ , وَفِیہِ الشِّیصُ , وَیَأْتِی بِالْقِنْوِ قَدِ انْکَسَرَ فَیُعَلِّقُہُ ، قَالَ : فَأَنْزَلَ اللَّہُ تعالی: {وَلاَ تَیَمَّمُوا الْخَبِیثَ مِنْہُ تُنْفِقُونَ وَلَسْتُمْ بِآخِذِیہِ إِلاَّ أَنْ تُغْمِضُوا فِیہِ} قَالَ : لَوْ أَنَّ أَحَدَکُمْ أُہْدِیَ إلَیْہِ مِثْلُ مَا أَعْطَی لَمْ یَأْخُذْہُ إِلاَّ عَلَی إغْمَاضٍ وَحَیَائٍ ، قَالَ : فَکَانَ بَعْدَ ذَلِکَ یَأْتِی الرَّجُلُ بِصَالِحِ مَا عِنْدَہُ۔ (ترمذی 2987۔ ابن ماجہ 1822)",,,10892,,
10893,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : أَخْبَرَنَا أَشْعَثُ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ خُرِصَتْ عَلَیْہِ ثَمَرَتُہُ ، فَکَانَ فِیہَا فَضل عَلَی مَا خُرِصَ عَلَیْہِ ، قَالَ : مَا زَادَ فَلَہُ وَمَا نَقَصَ فَعَلَیْہِ۔",,,10893,,
10894,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : سَأَلَنَا لإبْرَاہِیمَ مَرَّتَیْنِ الزَّکَاۃَ۔",,,10894,,
10895,"ہُشَیْمٌ، عَنْ عُبَیْدَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: أَتَیْتُہ بِزَکَاۃٍ فَقَبِلَہَا، قَالَ: وَأَخْبَرَنِی أَنَّ بَعْضَ أَہْلِ بَدْرٍ کَانَ یَقْبَلُہَا۔",,,10895,,
10896,عَبْدُ السَّلاَمِ ، عَنْ عَمرو بْنِ مُسَاوِرٍ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یُعَجِّلَ الرَّجُلُ صَدَقَۃَ الْفِطْرِ قَبْلَ الْفِطْرِ بِیَوْمٍ ، أَوْ یَوْمَیْنِ۔,,,10896,,
10897,"أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ إذَا جَلَسَ مَنْ یَقْبِضُ الْفِطْرَ قَبْلَ الفطر بیَوْمَیْنِ ، أَوْ یَوْمٍ أَعْطَاہَا إِیاہ قَبْلَ الْفِطْرِ بِیَوْمٍ ، أَوْ یَوْمَیْنِ ، وَلاَ یَرَی بِذَلِکَ بَأْسًا۔",,,10897,,
10898,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ مُسْلِمٍ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ یَعْقُوبَ بْنِ عَاصِمٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ مَنْ سُئِلَ بِاللَّہِ فَأَعْطَی فَلَہُ سَبْعُونَ أَجْرًا۔ (بیہقی 3540)",,,10898,,
10899,"حَدَّثَنَا وَکِیعٌ ، قَالَ : أَخْبَرَنَا سُفْیَانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، أَنَّہُ کَرِہَ أَنْ یُسْأَلَ بِوَجْہِ اللہِ ، أَوْ بِالْقُرْآنِ لِشَیْئٍ مِنْ أَمْرِ الدُّنْیَا۔",,,10899,,
10900,"حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ یَزِیدَ مَوْلَی سَلَمَۃَ ، قَالَ : کَانَ سَلَمَۃُ لاَ یَسْأَلُہُ إنْسَانٌ بِوَجْہِ اللہِ شَیْئًا إِلاَّ أَعْطَاہُ وَیَکْرَہُہَا وَیَقُولُ ہِیَ إلْحَافٌ۔",,,10900,,
10901,"عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عُمَرَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ سَأَلَ بِاَللَّہِ فَأَعْطُوہُ۔ (ابوداؤد 5068۔ طبرانی 13540)",,,10901,,
10902,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنِ الْمُثَنَّی ، قَالَ قُرِئَ عَلَیْنَا کِتَابُ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، وَلاَ یُعَشِّرُ الْخَمْرَ مُسْلِمٌ,,,10902,,
10903,وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ یُعَشِّرُ الْخَمْرَ وَیُضَاعِفُ عَلَیْہِ۔,,,10903,,
10904,وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، أَنَّ عُمَّالَ عُمَرَ کَتَبُوا إلَیْہِ فِی شَأْنِ الْخَنَازِیرِ وَالْخَمْرِ یَأْخُذُونَہَا فِی الْجِزْیَۃِ فَکَتَبَ عُمَرُ أَنْ وَلُّوہَا أَرْبَابَہَا۔,,,10904,,
