{"metadata":{"name":"Sunan Ibn Majah","section":{"7":"Fasting"},"section_detail":{"7":{"hadithnumber_first":1638,"hadithnumber_last":1782,"arabicnumber_first":1638,"arabicnumber_last":1782}}},"hadiths":[{"hadithnumber":1705,"arabicnumber":1705,"text":"Rapporté par ‘Abdullah bin Shikhkhir, de la part de son père : Le Prophète (ﷺ) a dit : “Celui qui jeûne sans interruption, il ne jeûne pas vraiment et ne rompt pas non plus son jeûne.”","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Sahih"},{"name":"Zubair Ali Zai","grade":"Isnaad Sahih"}],"reference":{"book":7,"hadith":68}}]}