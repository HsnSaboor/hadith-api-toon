{"hadithnumber": "3753", "text": "مجھ سے محمد بن بشار نے بیان کیا، کہا کہ ہم سے غندر نے بیان کیا، ان سے شعبہ نے بیان کیا، ان سے محمد ب"}
{"hadithnumber": "3754", "text": "ہم سے ابونعیم نے بیان کیا، کہا ہم سے عبدالعزیز بن ابی سلمہ نے بیان کیا، ان سے محمد بن منکدر نے کہا ہ"}
{"hadithnumber": "3755", "text": "ہم سے ابن نمیر نے بیان کیا، ان سے محمد بن عبید نے کہا، ہم سے اسماعیل نے بیان کیا، اور ان سے قیس نے ک"}
{"hadithnumber": "3756", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے عبدالوارث نے بیان کیا، ان سے خالد نے، ان سے عکرمہ نے کہ  ابن عباس"}
{"hadithnumber": "3756", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے عبدالوارث نے بیان کیا، ان سے خالد نے، ان سے عکرمہ نے کہ  ابن عباس"}
{"hadithnumber": "3757", "text": "ہم سے احمد بن واقد نے بیان کیا، کہا ہم سے حماد بن زید نے بیان کیا، ان سے ایوب نے ان سے حمید بن ہلال"}
{"hadithnumber": "3758", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے عمرو بن مرہ نے، ان سے ابراہیم نے"}
{"hadithnumber": "3760", "text": "اور آپ نے فرمایا کہ قرآن مجید چار آدمیوں سے سیکھو، عبداللہ بن مسعود، ابوحذیفہ کے مولیٰ سالم، ابی بن"}
{"hadithnumber": "3761", "text": "ہم سے موسیٰ نے بیان کیا، ان سے ابوعوانہ نے، ان سے مغیرہ نے، ان سے ابراہیم نے، ان سے علقمہ نے کہ  میں"}
{"hadithnumber": "3762", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے ابواسحٰق نے، ان سے عبدالرحمٰن بن"}
{"hadithnumber": "3763", "text": "مجھ سے محمد بن علاء نے بیان کیا، کہا ہم سے ابراہیم بن یوسف بن ابی اسحٰق نے بیان کیا، کہا کہ مجھ سے م"}
{"hadithnumber": "3764", "text": "کہا ہم سے حسن بن بشیر نے بیان کیا، ان سے عثمان بن اسود نے اور ان سے ابن ابی ملیکہ نے بیان کیا کہ  مع"}
{"hadithnumber": "3765", "text": "ہم سے ابن ابی مریم نے بیان کیا، کہا ہم سے نافع بن عمر نے بیان کیا، کہا مجھ سے ابن ابی ملیکہ نے بیان"}
{"hadithnumber": "3766", "text": "مجھ سے عمرو بن عباس نے بیان کیا، کہا ہم سے محمد بن جعفر نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان"}
{"hadithnumber": "3767", "text": "ہم سے ابوالولید نے بیان کیا، کہا ہم سے ابن عیینہ نے بیان کیا، ان سے عمرو بن دینار نے، ان سے ابن ابی"}
{"hadithnumber": "3768", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا ہم سے لیث نے بیان کیا، ان سے یونس نے، ان سے ابن شہاب نے بیان کی"}
{"hadithnumber": "3769", "text": "ہم سے آدم نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا (امام بخاری رحمہ اللہ نے) اور ہم سے عمرو نے ب"}
{"hadithnumber": "3770", "text": "ہم سے عبدالعزیز بن عبداللہ نے بیان کیا، کہا کہ مجھ سے محمد بن جعفر نے بیان کیا، ان سے عبداللہ بن عبد"}
{"hadithnumber": "3771", "text": "محمد بن بشار نے مجھ سے بیان کیا، کہا ہم سے عبدالوہاب بن عبدالمجید نے بیان کیا، ہم سے ابن عون نے بیان"}
{"hadithnumber": "3772", "text": "ہم سے محمد بن بشار نے بیان کیا، کہا ہم سے غندر نے بیان کیا، ان سے شعبہ نے بیان کیا، ان سے حکم نے اور"}
