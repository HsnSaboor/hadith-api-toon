{"metadata":{"name":"Sunan Ibn Majah","section":{"6":"Chapters Regarding Funerals"},"section_detail":{"6":{"hadithnumber_first":1433,"hadithnumber_last":1637,"arabicnumber_first":1433,"arabicnumber_last":1637}}},"hadiths":[{"hadithnumber":1464,"arabicnumber":1464,"text":"Rapporté par ‘Aishah : Si j’avais su à l’époque ce que je sais maintenant, personne n’aurait lavé le Prophète (ﷺ) à part ses épouses","grades":[{"name":"Al-Albani","grade":"Sahih"},{"name":"Muhammad Fouad Abd al-Baqi","grade":"Sahih"},{"name":"Shuaib Al Arnaut","grade":"Hasan"},{"name":"Zubair Ali Zai","grade":"Isnaad Hasan"}],"reference":{"book":6,"hadith":32}}]}