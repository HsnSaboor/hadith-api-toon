{"hadithnumber": "3394", "text": "سالم بن عبداللہ بن عمر نے خبر دی کہ  ابن عمر رضی اللہ عنہما اپنی زمین بٹائی پر دیا کرتے تھے، پھر جب"}
{"hadithnumber": "3395", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے زمانہ میں  ( بٹائی پر )  ک"}
{"hadithnumber": "3396", "text": "ایوب کہتے ہیں: یعلیٰ بن حکیم نے مجھے لکھا کہ  میں نے سلیمان بن یسار سے عبیداللہ کی سند اور ان کی حدی"}
{"hadithnumber": "3397", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں  ہمارے پاس ابورافع رضی اللہ عنہ رسول اللہ صلی اللہ علیہ وسلم کے پ"}
{"hadithnumber": "3398", "text": "اسید بن ظہیر کہتے ہیں  ہمارے پاس رافع بن خدیج رضی اللہ عنہ آئے اور کہنے لگے: رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "3399", "text": "ابوجعفر خطمی کہتے ہیں  میرے چچا نے مجھے اور اپنے ایک غلام کو سعید بن مسیب کے پاس بھیجا، تو ہم نے ان"}
{"hadithnumber": "3400", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے محاقلہ اور مزابنہ سے منع کیا ہے"}
{"hadithnumber": "3401", "text": "عثمان بن سہل بن رافع بن خدیج کہتے ہیں  میں رافع بن خدیج رضی اللہ عنہ کے زیر پرورش ایک یتیم تھا، میں"}
{"hadithnumber": "3402", "text": "ابن ابی نعم سے روایت ہے کہ  مجھ سے رافع بن خدیج رضی اللہ عنہ نے بیان کیا کہ انہوں نے ایک زمین میں کھ"}
{"hadithnumber": "3403", "text": "رافع بن خدیج رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس نے دوسرے لوگوں کی"}
{"hadithnumber": "3404", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے محاقلہ ۱؎ مزابنہ ۲؎ مخاب"}
{"hadithnumber": "3405", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مزابنہ  ( درخت پر لگے ہو"}
{"hadithnumber": "3406", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا ہ"}
{"hadithnumber": "3407", "text": "زید بن ثابت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مخابرہ سے روکا ہے، میں نے پوچھ"}
{"hadithnumber": "3408", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے اہل خیبر کو زمین کے کام پر"}
{"hadithnumber": "3409", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے خیبر کے یہودیوں کو خیبر کے"}
{"hadithnumber": "3410", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے خیبر فتح کیا، اور یہ شرط لگ"}
{"hadithnumber": "3411", "text": "جعفر بن برقان سے اسی مفہوم کی حدیث اسی طریق سے مروی ہے  اس میں لفظ «فحزر» ہے اور «وكل صفراء وبيضاء»"}
{"hadithnumber": "3412", "text": "مقسم سے (مرسلاً) روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے جس وقت خیبر فتح کیا، پھر آگے انہوں نے ز"}
{"hadithnumber": "3413", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں  نبی اکرم صلی اللہ علیہ وسلم عبداللہ بن رواحہ رضی اللہ عنہ"}
{"hadithnumber": "3414", "text": "جابر رضی اللہ عنہ کہتے ہیں  اللہ نے اپنے رسول کو خیبر دیا تو رسول اللہ صلی اللہ علیہ وسلم نے خیبر وا"}
{"hadithnumber": "3415", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  ابن رواحہ رضی اللہ عنہ نے چالیس ہزار وسق  ( کھجور )  کا"}
