{"hadithnumber": "1401", "text": "عمرو بن العاص رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ان کو قرآن مجید میں  ( ۱۵"}
{"hadithnumber": "1402", "text": "عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے پوچھا: اللہ کے رسول! ک"}
{"hadithnumber": "1403", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  مکہ سے مدینہ آ جانے کے بعد رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "1404", "text": "زید بن ثابت رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو سورۃ النجم پڑھ کر سنائی"}
{"hadithnumber": "1405", "text": "اس سند سے بھی  زید بن ثابت رضی اللہ عنہ سے اسی مفہوم کی حدیث مرفوعاً آئی ہے۔ ابوداؤد کہتے ہیں: زید ا"}
{"hadithnumber": "1406", "text": "عبداللہ بن مسعود رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے سورۃ النجم پڑھی اور اس"}
{"hadithnumber": "1407", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں  ہم نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ سورۃ «إذا السماء انشقت» ا"}
{"hadithnumber": "1408", "text": "ابورافع نفیع الصائغ بصریٰ کہتے ہیں کہ  میں نے ابوہریرہ رضی اللہ عنہ کے ساتھ عشاء پڑھی، آپ نے «إذا ال"}
{"hadithnumber": "1409", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  سورۃ ص کا سجدہ تاکیدی سجدوں میں سے نہیں لیکن میں نے رسول"}
{"hadithnumber": "1410", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے سورۃ  ص  پڑھی، آپ منبر پر تھ"}
{"hadithnumber": "1411", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فتح مکہ کے سال سجدے وا"}
{"hadithnumber": "1412", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہمیں سورۃ پڑھ کر سناتے  ( اب"}
{"hadithnumber": "1413", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ہم کو قرآن سناتے، جب کسی سجد"}
{"hadithnumber": "1414", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم رات میں قرآن کے سجدوں میں"}
{"hadithnumber": "1415", "text": "ابوتمیمہ طریف بن مجالد ہجیمی کہتے ہیں کہ  جب ہم قافلہ کے ساتھ مدینہ آئے تو میں فجر کے بعد وعظ کہا کر"}
