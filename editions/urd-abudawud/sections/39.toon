hadiths[60]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
4291,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ اس امت کے لیے ہر صد",,,,,4291
4292,"حسان بن عطیہ کہتے ہیں کہ  مکحول اور ابن ابی زکریا: خالد بن معدان کی طرف چلے، میں بھی ان کے ساتھ چلا ",,,,,4292
4293,"اس سند سے بھی حسان بن عطیہ سے یہی حدیث مروی ہے  اس میں یہ اضافہ ہے:  پھر جلدی سے مسلمان اپنے ہتھیارو",,,,,4293
4294,"معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بیت المقدس کی آبادی م",,,,,4294
4295,"معاذ بن جبل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بڑی جنگ، قسطنطنیہ کی ",,,,,4295
4296,"عبداللہ بن بسر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بڑی جنگ اور فتح",,,,,4296
4297,"ثوبان رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قریب ہے کہ دیگر قومیں تم پر",,,,,4297
4298,"ابوالدرداء رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:   ( دجال سے )  جنگ کے ر",,,,,4298
4299,"عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قریب ہے کہ مسلما",,,,,4299
4300,زہری کہتے ہیں  سلاح خیبر کے قریب  ( ایک جگہ )  ہے۔,,,,,4300
4301,"عوف بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ تعالیٰ اس امت پر",,,,,4301
4302,"ایک صحابی رسول رضی اللہ عنہ روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  حبشہ کے کافرو",,,,,4302
4303,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قیامت قائم نہیں ہو گی جب",,,,,4303
4304,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قیامت قائم نہیں ہو گی ",,,,,4304
4305,"بریدہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم فرماتے ہیں:  تم سے ایک ایسی قوم لڑے گی ج",,,,,4305
4306,"ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میری امت کے کچھ لوگ دجلہ ",,,,,4306
4307,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  لوگ شہر بسائیں گے انہیں شہروں میں سے ایک شہر ہو گا جسے بصرہ یا,,,,,4307
4308,"صالح بن درہم کہتے ہیں کہ  ہم حج کے ارادہ سے چلے تو اچانک ہمیں ایک شخص ملا ۱؎ جس نے ہم سے پوچھا: کیا ",,,,,4308
4309,"عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اہل حبشہ کو چ",,,,,4309
4310,ابوزرعہ کہتے ہیں کہ  کچھ لوگ مروان کے پاس مدینہ آئے تو وہاں اسے  ( قیامت کی )  نشانیوں کے متعلق بیان,,,,,4310
4311,حذیفہ بن اسید غفاری رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے کمرے کے زیر سایہ بی,,,,,4311
4312,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قیامت اس وقت تک قائم نہی",,,,,4312
4313,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قریب ہے کہ فرات کے اندر ",,,,,4313
4314,ابوہریرہ رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے اسی جیسی حدیث روایت کی ہے  مگر اس میں ہے کہ ,,,,,4314
4315,"ربعی بن حراش کہتے ہیں کہ  حذیفہ رضی اللہ عنہ اور ابن مسعود رضی اللہ عنہ اکٹھا ہوئے تو حذیفہ نے کہا: ",,,,,4315
4316,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  کوئی ایسا نبی نہیں بھی",,,,,4316
4317,شعبہ سے  ک ف ر  مروی ہے۔,,,,,4317
4318,"انس بن مالک رضی اللہ عنہ نبی اکرم صلی اللہ علیہ وسلم سے یہی حدیث روایت کرتے ہیں  اس میں ہے:  اسے ہر ",,,,,4318
4319,"عمران بن حصین رضی اللہ عنہما کو کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو دجال کے متع",,,,,4319
4320,"عبادہ بن صامت رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں دجال کے متعلق ت",,,,,4320
4321,نواس بن سمعان کلابی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے دجال کا ذکر کیا تو فرم,,,,,4321
4322,ابوامامہ رضی اللہ عنہ نے بھی اسی طرح کی حدیث  نبی اکرم صلی اللہ علیہ وسلم سے روایت کی ہے اور نمازوں ,,,,,4322
4323,"ابوالدرداء رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس نے سورۃ الکہف کی ",,,,,4323
4324,"ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  میرے اور ان یعنی عیسیٰ",,,,,4324
4325,فاطمہ بنت قیس رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک رات عشاء پڑھنے میں د,,,,,4325
4326,"فاطمہ بنت قیس رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کے منادی کو پکارتے سنا:",,,,,4326
4327,فاطمہ بنت قیس رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ظہر پڑھی، پھر آپ منبر پر چڑھ,,,,,4327
4328,"جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک دن منبر پر فرمایا:  کچھ لوگ سمندر",,,,,4328
4329,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم اپنے صحابہ کی ایک جماعت کے سا,,,,,4329
4330,"نافع سے روایت ہے کہ  ابن عمر رضی اللہ عنہما کہتے تھے: قسم اللہ کی مجھے اس میں شک نہیں کہ مسیح دجال ا",,,,,4330
4331,محمد بن منکدر کہتے ہیں کہ  میں نے جابر بن عبداللہ رضی اللہ عنہما کو دیکھا کہ وہ اللہ کی قسم کھا کر ک,,,,,4331
4332,جابر رضی اللہ عنہ کہتے ہیں کہ  ابن صیاد ہم کو یوم حرہ ۱؎ کو غائب ملا۔,,,,,4332
4333,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قیامت اس وقت تک قائم نہی",,,,,4333
4334,"ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قیامت قائم نہیں ہو گی جب",,,,,4334
4335,"ابراہیم کہتے ہیں: عبیدہ سلمانی نے اسی طرح کی حدیث بیان کی  تو میں نے ان سے پوچھا: کیا آپ اسے یعنی مخ",,,,,4335
4336,"عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پہلی خرابی جو بن",,,,,4336
4337,عبداللہ بن مسعود رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے اسی جیسی حدیث روایت کی ہے  اس میں یہ,,,,,4337
4338,"قیس بن ابی حازم کہتے ہیں کہ  ابوبکر رضی اللہ عنہ نے اللہ کی حمد و ثنا کے بعد فرمایا: لوگو! تم آیت کر",,,,,4338
4339,"جریر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو آدمی کسی ایسی ",,,,,4339
4340,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  جو کوئی ",,,,,4340
4341,"ابوامیہ شعبانی کہتے ہیں کہ  میں نے ابوثعلبہ خشنی رضی اللہ عنہ سے پوچھا: ابوثعلبہ! آپ آیت کریمہ «عليك",,,,,4341
4342,"عبداللہ بن عمرو بن العاص رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تمہ",,,,,4342
4343,عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے گرد بیٹھے ہو,,,,,4343
4344,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  سب سے افضل جہاد ظال",,,,,4344
4345,"عرس بن عمیرہ کندی رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب زمین پر گن",,,,,4345
4346,عدی بن عدی رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے اسی طرح کی حدیث روایت کی ہے اس میں ہے کہ  ,,,,,4346
4347,ابوالبختری کہتے ہیں کہ  مجھے اس شخص نے خبر دی ہے جس نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے سنا ہے،,,,,,4347
4348,عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنی آخری عمر میں ایک رات,,,,,4348
4349,"ابوثعلبہ خشنی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ اس امت کو قیام",,,,,4349
4350,"سعد بن ابی وقاص رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  میں امید رکھتا ",,,,,4350
