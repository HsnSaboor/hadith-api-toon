{"hadithnumber": "4342", "text": "لیث نے یحییٰ بن سعید سے ،  انہوں نے بشیر بن یسار سے اور انہوں نے حضرت سہل بن ابی حثمہ اور حضرت رافع"}
{"hadithnumber": "4343", "text": "حماد بن زید نے کہا :  ہمیں یحییٰ بن سعید نے بشیر بن یسار سے ،  انہوں نے سہل بن ابی حثمہ اور رافع بن"}
{"hadithnumber": "4344", "text": "بشر بن مفضل نے کہا :  ہمیں یحییٰ بن سعید نے بشیر بن یسار سے ،  انہوں نے سہل بن ابی حثمہ سے اور انہوں"}
{"hadithnumber": "4345", "text": "سفیان بن عیینہ اور عبدالوہاب ثقفی نے یحییٰ بن سعید سے ،  انہوں نے بشیر بن یسار سے اور انہوں نے سہل ب"}
{"hadithnumber": "4346", "text": "سلیمان بن بلال نے یحییٰ بن سعید سے ،  انہوں نے بشیر بن یسار سے روایت کی کہ رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "4347", "text": "ہشیم نے یحییٰ بن سعید سے ،  انہوں نے بشیر بن یسار سے روایت کی کہ انصار میں سے بنو حارثہ کا ایک آدمی"}
{"hadithnumber": "4348", "text": "سعید بن عبید نے ہمیں حدیث بیان کی ،   ( کہا :   )  ہمیں بشیر بن یسار انصاری نے سہل بن ابی حثمہ انصار"}
{"hadithnumber": "4349", "text": "ابولیلیٰ بن عبداللہ بن عبدالرحمان بن سہل  ( بن زید انصاری )  نے سہل بن ابی حثمہ  ( انصاری )  سے حدیث"}
{"hadithnumber": "4350", "text": "یونس نے ابن شہاب سے خبر دی ،  کہا :  مجھے ابوسلمہ بن عبدالرحمان اور نبی صلی اللہ علیہ وسلم کی زوجہ م"}
{"hadithnumber": "4351", "text": "ابن جریج نے ابن شہاب سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی اور یہ اضافہ کیا :  رسول اللہ صلی"}
{"hadithnumber": "4352", "text": "صالح نے ابن شہاب سے روایت کی کہ انہیں ابوسلمہ بن عبدالرحمان اور سلیمان بن یسار نے انصار کے کچھ لوگوں"}
{"hadithnumber": "4353", "text": "عبدالعزیز بن صہیب اور حمید نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی کہ عرینہ کے کچھ لوگ رسول الل"}
{"hadithnumber": "4354", "text": "ابوجعفر محمد بن صباح اور ابوبکر بن ابی شیبہ نے ہمیں حدیث بیان کی ،  الفاظ ابوبکر کے ہیں ،  کہا :  ہم"}
{"hadithnumber": "4355", "text": "ایوب نے ابوقلابہ کے آزاد کردہ غلام ابو رجاء سے روایت کی ،  کہا :  ابوقلابہ نے کہا :  ہمیں حضرت انس ب"}
{"hadithnumber": "4356", "text": "ابن عون نے کہا :  ہمیں ابو رجاء مولیٰ ابی قلابہ نے ابوقلابہ سے حدیث بیان کی ،  انہوں نے کہا :  میں ع"}
{"hadithnumber": "4357", "text": "یحییٰ بن ابی کثیر نے ابو قلابہ سے اور انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی ،  انہوں نے"}
{"hadithnumber": "4358", "text": "معاویہ بن قرہ نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  عرینہ کے کچھ افراد رسو"}
{"hadithnumber": "4359", "text": "ہمام اور سعید نے قتادہ کے حوالے سے حضرت انس رضی اللہ عنہ سے روایت کی ،  ہمام کی حدیث میں ہے :  عُرین"}
{"hadithnumber": "4360", "text": "سلیمان تیمی نے حضرت انس رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  نبی صلی اللہ علیہ وسلم نے  ( لوہ"}
{"hadithnumber": "4361", "text": "بن جعفر نے کہا :  ہمیں شعبہ نے ہشام بن زید سے حدیث بیان کی ،  انہوں نے حضرت انس بن مالک رضی اللہ عنہ"}
{"hadithnumber": "4362", "text": "خالد بن حارث اور ابن ادریس دونوں نے شعبہ سے اسی سند کے ساتھ اسی طرح حدیث بیان کی اور ابن ادریس کی حد"}
{"hadithnumber": "4363", "text": "عبدالرزاق نے کہا :  ہمیں معمر نے ایوب سے خبر دی ،  انہوں نے ابوقلابہ سے اور انہوں نے حضرت انس رضی ال"}
{"hadithnumber": "4364", "text": "ابن جریج نے کہا :  مجھے معمر نے ایوب سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی"}
{"hadithnumber": "4365", "text": ")  قتادہ نے ہمیں حضرت انس بن مالک رضی اللہ عنہ سے حدیث بیان کی کہ ایک لڑکی کا سر دو پتھروں کے درمیان"}
{"hadithnumber": "4366", "text": "محمد بن مثنیٰ اور ابن بشار نے کہا :  ہمیں محمد بن جعفر نے حدیث بیان کی ،  کہا :  ہمیں شعبہ نے قتادہ"}
{"hadithnumber": "4367", "text": "یعلیٰ رضی اللہ عنہ کے بیٹے نے یعلیٰ رضی اللہ عنہ سے ،  انہوں نے نبی صلی اللہ علیہ وسلم سے اسی کے مان"}
{"hadithnumber": "4368", "text": "ہشام نے قتادہ سے ،  انہوں نے زرارہ بن اوفیٰ سے اور انہوں نے حضرت عمران بن حصین رضی اللہ عنہ سے روایت"}
{"hadithnumber": "4369", "text": "بدیل نے عطاء بن ابی رباح سے اور انہوں نے صفوان بن یعلیٰ سے روایت کی کہ یعلیٰ بن منیہ رضی اللہ عنہ کا"}
{"hadithnumber": "4370", "text": "محمد بن سیرین نے حضرت عمران بن حصین رضی اللہ عنہ سے روایت کی کہ ایک آدمی نے دوسرے آدمی کے ہاتھ کو دا"}
{"hadithnumber": "4371", "text": "ہمام نے کہا :  ہمیں عطاء نے صفوان بن یعلیٰ بن منیہ سے ،  انہوں نے اپنے والد سے روایت کی ،  انہوں نے"}
{"hadithnumber": "4372", "text": "ابواسامہ نے کہا :  ہمیں ابن جریج نے خبر دی ،  کہا :  مجھے عطاء نے خبر دی ،  کہا :  مجھے صفوان بن یعل"}
{"hadithnumber": "4373", "text": "اسماعیل بن ابراہیم نے ابن جریج سے اسی سند کے ساتھ اسی طرح حدیث بیان کی"}
{"hadithnumber": "4374", "text": "حضرت انس رضی اللہ عنہ سے روایت ہے کہ رُبیع رضی اللہ عنہا  ( بنت نضر بن ضمضم )  کی بہن ،  ام حارثہ نے"}
{"hadithnumber": "4375", "text": "حفص بن غیاث ،  ابومعاویہ اور وکیع نے اعمش سے ،  انہوں نے عبداللہ بن مرہ سے ،  انہوں نے مسروق سے اور"}
{"hadithnumber": "4376", "text": "عبداللہ بن نمیر ،  سفیان  ( ابن عیینہ )  اور عیسیٰ بن یونس سب نے اعمش سے اسی سند کے ساتھ اسی کے مانن"}
{"hadithnumber": "4377", "text": "سفیان نے اعمش سے ،  انہوں نے عبداللہ بن مرہ سے ،  انہوں نے مسروق سے اور انہوں نے حضرت عبداللہ رضی ال"}
{"hadithnumber": "4378", "text": "شیبان نے اعمش سے  ( سابقہ )  دونوں سندوں کے ساتھ سفیان کی حدیث کی طرح بیان کی اور انہوں نے حدیث میں"}
{"hadithnumber": "4379", "text": "ابومعاویہ نے اعمش سے ،  انہوں نے عبداللہ بن مرہ سے ،  انہوں نے مسروق سے اور انہوں نے حضرت عبداللہ رض"}
{"hadithnumber": "4380", "text": "جریر ،  عیسیٰ بن یونس اور سفیان سب نے اعمش سے اسی سند کے ساتھ حدیث بیان کی اور جریر اور عیسیٰ بن یون"}
{"hadithnumber": "4381", "text": "عبدہ بن سلیمان اور وکیع نے اعمش سے ،  انہوں نے ابووائل سے اور انہوں نے حضرت عبداللہ رضی اللہ عنہ سے"}
{"hadithnumber": "4382", "text": "معاذ بن معاذ ،  خالد بن حارث ،  محمد بن جعفر اور ابن ابی عدی سب نے شعبہ سے روایت کی ،  انہوں نے اعمش"}
{"hadithnumber": "4383", "text": "ابوبکر بن ابی شیبہ اور یحییٰ بن حبیب حارثی  ۔  ۔  دونوں کے الفاظ قریب قریب ہیں  ۔  ۔  دونوں نے کہا :"}
{"hadithnumber": "4384", "text": "یزید بن زریع نے کہا :  ہمیں عبداللہ بن عون نے محمد بن سیرین سے حدیث بیان کی ،  انہوں نے عبدالرحمان ب"}
{"hadithnumber": "4385", "text": "حماد بن مسعدہ نے ہمیں ابن عون سے حدیث بیان کی ،  انہوں نے کہا :  محمد  ( بن سیرین )  نے کہا :  عبدال"}
{"hadithnumber": "4386", "text": "یحییٰ بن سعید نے کہا :  ہمیں قرہ بن خالد نے حدیث سنائی ،  کہا :  ہمیں محمد بن سیرین نے عبدالرحمان بن"}
{"hadithnumber": "4387", "text": "سماک بن حرب نے علقمہ بن وائل سے حدیث بیان کی کہ ان کے والد نے انہیں حدیث سنائی ،  انہوں نے کہا :  می"}
{"hadithnumber": "4388", "text": "اسماعیل بن سالم نے علقمہ بن وائل سے ،  انہوں نے اپنے والد سے روایت کی ،  انہوں نے کہا :  رسول اللہ ص"}
{"hadithnumber": "4389", "text": "امام مالک نے ابن شہاب سے ،  انہوں نے ابوسلمہ سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی"}
{"hadithnumber": "4390", "text": "لیث نے ابن شہاب سے ،  انہوں نے ابن مسیب سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ ان"}
{"hadithnumber": "4391", "text": "یونس نے ابن شہاب سے ،  انہوں نے ابن مسیب اور ابوسلمہ بن عبدالرحمان سے روایت کی کہ حضرت ابوہریرہ رضی"}
{"hadithnumber": "4392", "text": "معمر نے زہری سے ،  انہوں نے ابوسلمہ سے اور انہوں نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی ،  انہوں"}
{"hadithnumber": "4393", "text": "جریر نے منصور سے ،  انہوں نے ابراہیم سے ،  انہوں نے عبید بن نضیلہ خزاعی سے اور انہوں نے حضرت مغیرہ ب"}
{"hadithnumber": "4394", "text": "مفضل نے منصور سے ،  انہوں نے ابراہیم سے ،  انہوں نے عبید بن نضیلہ سے اور انہوں نے حضرت مغیرہ بن شعبہ"}
{"hadithnumber": "4395", "text": "سفیان نے منصور سے اسی سند کے ساتھ جریر اور مفضل کی حدیث کے ہم معنیٰ روایت کی"}
{"hadithnumber": "4396", "text": "شعبہ نے منصور سے انہی کی  ( سابقہ )  سندوں کے ساتھ مکمل قصے سمیت حدیث روایت کی ،  البتہ اس میں ہے :"}
{"hadithnumber": "4397", "text": "مسور بن مخرمہ رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  حضرت عمر بن خطاب رضی اللہ عنہ نے لوگوں سے"}
