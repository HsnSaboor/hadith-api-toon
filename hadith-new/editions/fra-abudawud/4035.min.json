{"metadata":{"name":"Sunan Abu Dawud","section":{"34":"Clothing (Kitab Al-Libas)"},"section_detail":{"34":{"hadithnumber_first":4020,"hadithnumber_last":4158,"arabicnumber_first":4020,"arabicnumber_last":4158}}},"hadiths":[{"hadithnumber":4035,"arabicnumber":4035,"text":"Rapporté par Ishaq ibn Abdullah ibn al-Harith رضي الله عنه : Le Messager d’Allah ﷺ a acheté un ensemble de vêtements pour vingt chamelles et un peu plus, puis il l’a offert à Dhu Yazan","grades":[{"name":"Al-Albani","grade":"Daif"},{"name":"Muhammad Muhyi Al-Din Abdul Hamid","grade":"Daif"},{"name":"Shuaib Al Arnaut","grade":"Daif"},{"name":"Zubair Ali Zai","grade":"Daif"}],"reference":{"book":34,"hadith":16}}]}