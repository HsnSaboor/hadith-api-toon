{"hadithnumber": "5897", "text": "عمرو ناقد  ، اسحٰق بن ابراہیم اور ابن ابی عمر ، سب نے ابن عیینہ سے روایت کی ،  الفاظ ابن ابی عمر کے"}
{"hadithnumber": "5898", "text": "ابن ابی عمر نے کہا  :  ہمیں سفیان نے آل طلحہ کے آزاد کردہ غلام محمد بن عبد الرحمٰن سعید کے دوبیٹوں ع"}
{"hadithnumber": "5899", "text": "یو نس اور معمر دونوں نے زہری سے اسی سند کے ساتھ روایت بیان کی ،  ان دونوں کی حدیث میں یہ الفا ظ نہیں"}
{"hadithnumber": "5900", "text": "ابو سلمہ بن عبد الرحمان نے کہا  :  میں نے حضرت ابو قتادہ رضی اللہ تعالیٰ عنہ  سے سنا ، کہتے تھے :  م"}
{"hadithnumber": "5901", "text": "قتیبہ اور محمد بن رمح نے لیث بن سعد سے روایت کی ، محمد بن مثنیٰ نے کہا  :  ہمیں عبد لواہاب ثقفی نے ح"}
{"hadithnumber": "5902", "text": "عمرو بن حارث نے عبد ربہ بن سعید سے ، انھوں نے ابو سلمہ بن عبد الرحمٰن سے ،  انھوں نے حضرت ابوقتادہ ر"}
{"hadithnumber": "5903", "text": "شعبہ نے عبدربہ بن سعید سے  ، انھوں نے ابو سلمہ سے روایت کی  ، کہا :  بعض اوقات میں ایسا خواب دیکھتا"}
{"hadithnumber": "5904", "text": "حضرت جا بر رضی اللہ تعالیٰ عنہ  نے رسول اللہ  صلی اللہ علیہ وسلم  سے روایت کی کہ آپ نے فرما یا  :  "}
{"hadithnumber": "5905", "text": "عبد الو ہاب ثقفیٰ نے ایوب سختیانی سے ،  انھوں نے محمد بن سیرین سے ،  انھوں نے حضرت ابو ہریرہ رضی الل"}
{"hadithnumber": "5906", "text": "معمر نے ایوب سے اسی سند کے ساتھ خبر دی اور حدیث میں کہا کہ حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ نے کہا"}
{"hadithnumber": "5907", "text": "حماد بن زید نے کہا  :  ہمیں ایو ب اور ہشام نے محمد  ( بن سیرین  )  سے حدیث بیان کی  ، انھوں نے حضرت"}
{"hadithnumber": "5908", "text": "قتادہ نے محمد بن سیرین سے ،  انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے ،  انھوں نے نبی  صلی الل"}
{"hadithnumber": "5909", "text": "محمد بن جعفر  ، ابو داود عبد الرحمٰن بن مہدی اور معاذ عنبری ۔ الفاظ انھی کے ہیں  ۔ ان سب نے شعبہ سے"}
{"hadithnumber": "5910", "text": "ثابت بُنانی نے انس بن مالک رضی اللہ تعالیٰ عنہ  سے انھوں نے نبی  صلی اللہ علیہ وسلم  سے اسی کے مانند"}
{"hadithnumber": "5911", "text": "ابن مسیب نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ،  کہا  :  نبی  صلی اللہ علیہ وسلم  نے ف"}
{"hadithnumber": "5912", "text": "علی بن مسہر اور عبدا للہ بن نمیر نے اعمش سے ،  انھوں نے ابو صالح سے ،  انھوں نے حضرت ابو ہریرہ رضی ا"}
{"hadithnumber": "5913", "text": "عبد اللہ بن یحییٰ بن ابی کثیر نے کہا  :  میں نے اپنے والد سے سنا ،  وہ کہہ رہے تھے  : ہمیں ابو سلمہ"}
{"hadithnumber": "5914", "text": "علی بن مبارک اور حرب بن شداددونوں نے یحییٰ بن ابی کثیر سے اسی سند کے ساتھ روایت کی ۔"}
{"hadithnumber": "5915", "text": "ہمام بن منبہ نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ سے  ، انھوں نے نبی  صلی اللہ علیہ وسلم  سے ،  عبد"}
{"hadithnumber": "5916", "text": "ابو اسامہ اور عبد اللہ بن نمیردونوں نے کہا  : ہمیں عبید اللہ نے نافع سے حدیث بیان کی  ، انھوں نے حضر"}
{"hadithnumber": "5917", "text": "یحییٰ نے عبید اللہ سے اسی سند کے ساتھ  ( یہی )  حدیث بیان کی ۔"}
{"hadithnumber": "5918", "text": "نافع نے کہا  :  میں سمجھتا ہوں کہ حضرت ابن عمر رضی اللہ تعالیٰ عنہ  نے \"  نبوت کےستر حصوں میں سے ایک"}
{"hadithnumber": "5919", "text": "محمد  ( بن سیرین  )  نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی  ،  کہا  :  رسول اللہ  صلی ا"}
{"hadithnumber": "5920", "text": "یو نس نے ابن شہاب سے روایت کی ،  کہا  :  مجھے ابو سلمہ بن عبدالرحمٰن نے حدیث بیان کی کہ حضرت ابو ہری"}
{"hadithnumber": "5921", "text": "۔  ( ابن شہاب نے )  کہا  :  ابو سلمہ نے کہا  :  حضرت ابوقتادہ رضی اللہ تعالیٰ عنہ نے کہا کہ رسول الل"}
{"hadithnumber": "5922", "text": "زہری کے بھتیجے نے کہا  :  مجھے میرے چچا نے حدیث بیان کی  ، پھر دونوں احادیث اکٹھی ان کی دونوں سندوں"}
{"hadithnumber": "5923", "text": "لیث نے ابو زبیر سے ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ"}
{"hadithnumber": "5924", "text": "زکریا بن اسحاق نے کہا : مجھے ابو زبیر نے حدیث بیان کی کہ انھوں نے حضرت جابر بن عبداللہ رضی اللہ تعال"}
{"hadithnumber": "5925", "text": "ابو زبیر نے حضرت جابر  رضی اللہ تعالیٰ عنہ  سے اور انھوں نے رسول اللہ  صلی اللہ علیہ وسلم  سے روایت"}
{"hadithnumber": "5926", "text": "جریر نے اعمش سے ، انھوں نے ابو سفیان سے ، انھوں نے حضرت جابر رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہا"}
{"hadithnumber": "5927", "text": "ابو بکر بن ابی شیبہ اور ابو سعید اشج نے کہا : ہمیں وکیع نے اعمش سے حدیث بیان کی ، انھوں نے ابو سفیان"}
{"hadithnumber": "5928", "text": "محمد بن حرب نے یونس زبیدی سے روایت کی ، انھوں نےکہا : مجھے زہری نے عبیداللہ بن عبداللہ سے خبر دی کہ"}
{"hadithnumber": "5929", "text": "سفیان نے زہری سے ، انھوں نے عبیداللہ بن عبداللہ سے ، انھوں نے حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "5930", "text": "عبدالرزاق نے ہمیں حدیث بیان کی ، کہا : ہمیں معمر نے زہری سے خبر دی انھوں نےعبیداللہ بن عبداللہ سے بن"}
{"hadithnumber": "5931", "text": "سلمان بن کثیر نے زہری سے ، انھوں نے عبیداللہ بن عبداللہ سے  ، انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ"}
{"hadithnumber": "5932", "text": "سیدنا انس بن مالک رضی اللہ عنہ کہتے ہیں کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :  میں نے ایک رات"}
{"hadithnumber": "5933", "text": "صخر بن جویریہ نے ہمیں نافع سے حدیث سنائی کہ حضرت عبداللہ بن عمر رضی اللہ تعالیٰ عنہ  نے انھیں بتایا"}
{"hadithnumber": "5934", "text": "سیدنا ابوموسیٰ اشعری رضی اللہ عنہ نبی کریم صلی اللہ علیہ وسلم سے روایت کرتے ہیں کہ آپ صلی اللہ علیہ"}
{"hadithnumber": "5936", "text": "ہمام بن منبہ نے حدیث بیان کی ، کہا : یہ احادیث ہیں جو ہمیں ابوہریرہ رضی اللہ تعالیٰ عنہ  نے رسول الل"}
{"hadithnumber": "5937", "text": "حضرت سمرہ بن جندب رضی اللہ تعالیٰ عنہ  سے روایت ہے ، کہا : نبی کریم صلی اللہ علیہ وسلم  صبح کی نماز"}
