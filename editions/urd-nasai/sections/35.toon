hadiths[96]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
3761,"عطاء کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس شخص کو کوئی چیز صرف زندگی بھر برتنے کے",,,,,3761
3762,"جابر رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم لوگ رقبیٰ اور عمریٰ نہ",,,,,3762
3763,"عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”عمریٰ اور رقب",,,,,3763
3764,حبیب بن ابی ثابت ابن عمر سے روایت کرتے ہیں، (اور امام نسائی کہتے ہیں انہوں نے ان سے سنا نہیں ہے) ۱؎ ,,,,,3764
3765,عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے رقبیٰ کرنے سے منع کیا ہے ,,,,,3765
3766,"جابر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس کسی کو کوئی چیز عمریٰ میں",,,,,3766
3767,"جابر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اے انصار کی جماعت! اپنے مال ",,,,,3767
3768,"جابر رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”اپنا مال اپنے پاس روک کر ",,,,,3768
3769,"جابر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”رقبیٰ اس کا ہے جس کے لیے رقب",,,,,3769
3770,"جابر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”عمریٰ جس کو دیا گیا ہے اس کے",,,,,3770
3771,"جابر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس شخص کو کوئی چیز عمر بھر ک",,,,,3771
3772,"جابر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”عمریٰ اس شخص کا ہے جس کے لیے",,,,,3772
3773,"جابر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”عمریٰ اس کا ہے جس کے لیے عمر",,,,,3773
3774,"عبداللہ بن زبیر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس آدمی نے ک",,,,,3774
