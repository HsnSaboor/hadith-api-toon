{"hadithnumber": "2299", "text": "ہم سے قبیصہ بن عقبہ نے بیان کیا، کہا کہ ہم سے سفیان ثوری نے بیان کیا، ان سے ابن ابی نجیح نے بیان کی،"}
{"hadithnumber": "2300", "text": "ہم سے عمرو بن خالد نے بیان کیا، ان سے لیث نے بیان کیا، ان سے یزید نے، ان سے ابوالخیر نے اور ان سے عق"}
{"hadithnumber": "2301", "text": "ہم سے عبدالعزیز بن عبداللہ نے بیان کیا، کہا کہ مجھ سے یوسف بن ماجشون نے بیان کیا، ان سے صالح بن ابرا"}
{"hadithnumber": "2303", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، انہوں نے کہا کہ ہم کو امام مالک نے خبر دی، انہیں عبدالمجید بن سہل"}
{"hadithnumber": "2304", "text": "ہم سے اسحاق بن ابراہیم نے بیان کیا، انہوں نے معتمر سے سنا، انہوں نے کہا کہ ہم کو عبیداللہ نے خبر دی،"}
{"hadithnumber": "2305", "text": "ہم سے ابونعیم فضل بن دکین نے بیان کیا، کہا کہ ہم سے سفیان ثوری نے بیان کیا، ان سے سلمہ بن کہیل نے بی"}
{"hadithnumber": "2306", "text": "ہم سے سلیمان بن حرب نے بیان کیا، کہا کہ ہم سے شعبہ نے بیان کیا، ان سے سلمہ بن کہیل نے بیان کیا، انہو"}
{"hadithnumber": "2308", "text": "ہم سے سعید بن عفیر نے بیان کیا، کہا کہ مجھ سے لیث نے بیان کیا، کہا کہ مجھ سے عقیل نے بیان کیا، ان سے"}
{"hadithnumber": "2309", "text": "ہم سے مکی بن ابراہیم نے بیان کیا، کہا کہ ہم سے ابن جریج نے بیان کیا، ان سے عطاء بن ابی رباح اور کئی"}
{"hadithnumber": "2310", "text": "ہم سے عبداللہ بن یوسف نے بیان کیا، کہا کہ ہم کو امام مالک رحمہ اللہ نے خبر دی، انہیں ابوحازم نے، انہ"}
{"hadithnumber": "2311", "text": "اور عثمان بن ہیثم ابوعمرو نے بیان کیا کہ ہم سے عوف نے بیان کیا، ان سے محمد بن سیرین نے، اور ان سے اب"}
{"hadithnumber": "2312", "text": "ہم سے اسحاق بن راہویہ نے بیان کیا، ان سے یحییٰ بن صالح نے بیان کیا، ان سے معاویہ بن سلام نے بیان کیا"}
{"hadithnumber": "2313", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا کہ ہم سے سفیان بن عیینہ نے بیان کیا، ان سے عمرو بن دینار نے، ان"}
{"hadithnumber": "2315", "text": "ہم سے ابوالولید نے بیان کیا، انہوں نے کہا کہ ہم کو لیث بن سعد نے خبر دی، انہیں ابن شہاب نے، انہیں عب"}
{"hadithnumber": "2316", "text": "ہم سے ابن سلام نے بیان کیا، کہا کہ ہم کو عبدالوہاب ثقفی نے خبر دی، انہیں ایوب نے، انہیں ابن ابی ملکی"}
{"hadithnumber": "2317", "text": "ہم سے اسماعیل بن عبداللہ نے بیان کیا، کہا کہ مجھ سے امام مالک نے بیان کیا، ان سے عبداللہ بن ابی بکر"}
{"hadithnumber": "2318", "text": "مجھ سے یحییٰ بن یحییٰ نے بیان کیا، کہا کہ میں نے امام مالک کے سامنے قرآت کی بواسطہ اسحاق بن عبداللہ"}
{"hadithnumber": "2319", "text": "ہم سے محمد بن علاء نے بیان کیا، انہوں نے کہا کہ ہم سے ابواسامہ نے بیان کیا، انہوں نے کہا کہ ہم سے بر"}
