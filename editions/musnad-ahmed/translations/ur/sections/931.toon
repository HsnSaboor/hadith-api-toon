hadiths[6]{hadithnumber,text}:
23864,أذعشحأضلۏتىأۏتأذڬوأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأوۏڽأىەأىثۏأ﷽أڬًأزۏڬہتأڬۄأإځأ﷽أىەأځۏطتثأڬۏتأ؏أځہشأًعًأڬشأڬەأتځىۏأطشوڲتۄأځشأځتىۏأڬەأڬډہأډہۏىټەأوتشأهةەأۗ
23865,أطشۏڬأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأوۏڽأىەأذڬوأثىأضلۏتىأڬەأتۄهأرتىۄأضەأځًډہتأحًأتىۄًڽأىەأثحتۏتأڬۄأتىۄًڽأىەأىثۏأ﷽أڬًأىۄۏڽأځتۏتأحہتأۗ
23866,أذعشحأضلۏتىأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأوۏڽأىەأىثۏأ﷽أڬًأزۏڬہتأڬۄأإځأ﷽أىەأځۏطتثأڬۏتأ؏أځہشأشتًۏأىەأځًشۏأذزۏخأسڬشأڬۏأۗ
23867,أذعشحأذڬوأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأوۏڽأىەأىثۏأ﷽أڬًأزۏڬہتأڬۄأإځأ﷽أىەأځۏطتثأڬۏتأ؏أځہشأشتًۏأىەأځًشۏأذزۏخأسڬشأڬۏأۗ
23868,أذعشحأضلۏتىأۏتأذڬوأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأوۏڽأىەأىثۏأ﷽أڬًأزۏڬہتأڬۄأإځأ﷽أىەأځۏطتثأڬۏتأ؏أځہشأًعًأڬشأڬەأتځىۏأطشوڲتۄأځشأځتىۏأڬەأڬډہأډہۏىټەأوتشأهةەأۗ
23869,أۄوتشەأځتضأزضحۏتثأىضرەأوۏڽأۏۄتڽأظشلأهلػأ““أذزخىتأ‛‛أهڬہتأۄًتأۄەأۗ
