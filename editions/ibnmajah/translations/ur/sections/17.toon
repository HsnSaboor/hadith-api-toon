{"hadithnumber": "2492", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کے پاس کھجور کے درخت ہوں"}
{"hadithnumber": "2493", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس کے پاس زمین ہ"}
{"hadithnumber": "2494", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پڑوسی اپنے پڑوسی کے شفعہ کا"}
{"hadithnumber": "2495", "text": "ابورافع رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  پڑوسی اپنے نزدیکی مکان"}
{"hadithnumber": "2496", "text": "شرید بن سوید رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! ایک زمین ہے جس میں کسی کا حصہ ن"}
{"hadithnumber": "2497", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایسی جائیداد میں شفعہ کا حکم د"}
{"hadithnumber": "2498", "text": "ابورافع رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شریک  ( ساجھی دار )  اپنی"}
{"hadithnumber": "2499", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے شفعہ ہر اس جائیداد میں ٹ"}
{"hadithnumber": "2500", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شفعہ اونٹ کی رسی"}
{"hadithnumber": "2501", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شریک کو شریک پر"}
