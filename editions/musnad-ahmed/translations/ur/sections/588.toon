أزًضشتأطرظأثًهتأتهۄٳۏأ$أحًأًتملأۄەأڬۄأتۏڬأؼًشحأدًأوۏشۏأىػشأوۏڽأضثأضەأصۏتزۄأوذثًثأحہۏأ؏أوۏڽأىەأثۄهتأڬشأتضأضەأڬتشأثشإشۏأڬشىتأډتۄۏأهۏڬىأتضأىەأثؽۏشأضًأزۏىتشأهةەأ+أًظهأضەأ,أتىڬتشأڬشأزۏتأ؏أوۏڽأىەأڬًططأڬشأڬەأضًأزۏىتشأذتظهأڬةەأتًشأدثأًۄأوۏشەأمثعۄأوۏڽأإأڲةەأحًأوۏڽأىەأهەأدتأڬشأتضأڬًأزەأزۏةەأ؏أتضأىەأتځىەأىلضأڬًأوۏشەأمثعۄأوۏڽأزەأزۏتأ؏أدثأوۏڽأتضأڬۏأټتىڲًڽأڬەأزشوۏتىأثۏټہتأحًأًۄأڬۄىەأهڲۏأرزتأڬتأرًلأڬشأتًشأثؽۏشأذمأڬەأوۄشأىۄأحًڔأ؏أوۏڽأحًألًشتَأتټہأڬہڔتأۄًتأتًشأضًأزۏىتشأثہۏأډہًڔأزةۏەأ؏أتهۄٳۏأ$أتڲشأوۏشتأۏۄألؼهأظشلأحۏشەأرًلأڬۏأًدۄأضەأحہتأحًأۏۄأوظۏثحأۄوأضەأزًشأڬشأزەأډىتىډۄأًۄأځحہشأوصۏزأۄټأڲۏتأتًشأًۄأثتۄشأڬۏأډۏصۏڽأزۏڬہىەأهڲەأۗ
أحۏضشتأطرظأڬۄىەأهڲتأتهۄٳۏأ$أحًأًتملأۄەأڬۄأوۏشەأًتهزۏىأثۄحأثًڔہەأحہەأ؏أوۏڽأتىأڬًأشًصتىۄأطتوأڬًأتځىۏأثڬشۏًڽأڬتأزًزہأ+أزًۄأڬشأ,أزۏتأڬشحتأحہتأ؏أتۏڬأشًصأودہەأ+أدىڲهأضەأإىەأوۏڽأ
أزۏشأۄًأڲةۏأ؏أدضأًمحأوۏڽأإۏتأحًأًۄأضًأډڬەأحہەأتًشأوۏشۏأثۏًۏأثډەأثہًڬأڬۏأًدۄأضەأډهتأشۄەأحہەأ؏أهۏڬىأوۏشتأمتؼزۄأحہتأڬۄأدثأحڬأوۏشەأوتڽأثتځأىۄأځۏأهۏحەأحہەأوۏڽأتىأڬًأىۄأځهتحتأحہتأ+أتضأهةەأثڔتأذۏشتىأۄًتأ,أىۄأحًأتىأڬًأثۏزتشأڬشىتأوىتضثأوؼهًوأۄًتأىۄأۏۄأڬډہأتډہتأوؼهًوأۄًتأڬۄأتىأڬًأتۏضەأۄۏأډہًڔأزًڽأڬۄأ+أىۄأڬہتىەأضەأ
أتىأڬًأڬوصًشۏأۄًأدتةەأتًشأظثذأحڬأوۏڽأتىأڬۏأ+أإىڬہأڬہهىەأڬەأ,أتىحػتشأوۏڽأ+أڬہڔتأ
18608,أذعشحأىؼوتىأثىأثطۏشأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدىتثأشضًهأتههۄأ﷽أىەأتشطتزألشوتۏتأذهتهأثہۏأًتعذأۄەأتًشأذشتوأثہۏأًتعذأۄەأ؏أتىأزًىًڽأڬەأزشوۏتىأدًأڬډہأۄەأًۄأوحطتثۄتحأۄۏڽأ؏أدًأطرظأتىأوحطتثۄتحأڬًأډہًڔأزەأڲتأًۄأذشتوأڬًأثإضتىۏأډہًڔأضڬەأڲتأ؏أتًشأدًأطرظأوحطتثۄتحأوۏڽأځڔأدتةەأڲتأ؏أځہشأًتعذأذشتوأډۏصًڽأځشأثہۏأدشئحأڬشىەأهڲەأڲتأ؏أتًشأدًأطرظأډشتڲتۄأڬەأإضأځتضأتځىەأدتىًشًڽأڬًأډشتحتأۄەأ؏أتىزۏطۄأۄًحتأۄەأڬۄأًۄأډشتڲتۄأوۏڽأڲہضأدتةەأۗ
