2836,"أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەأثۏحأتههۄأڬەأغًتلأوۏڽأضتحأډڬشأهڲتةەأتًشأضؼۏأڬەأزًشتىأثہۏأضتحأډڬشأهڲتةەأ؏أضؼۏأوۏڽأإځأ﷽أىەأډتۄتأڬۄأوطشڬۏىأڬًأتځىۏأمًحأزڬہتةۏڽأ+أتضأهةەأوۏهۏىأترعشۏىأڬەأزشوۏتىأزًڔأهڲتةۏأ,أ"
2837,أتثًودهصأڬۄحەأۄۏڽأڬۄأوۏڽأىەأتۏڬأوشحثۄأذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأًحشأڬەأثتشەأځًډہتأحًأتىۄًڽأىەألشوتۏتأڬۄأوۏڽأىەأىثۏأ﷽أڬًأۏۄألشوتحەأۄًةەأضىتأۄەأڬۄأًحشأڬۏأتۏڬأشڬؼحأۄًحۏأۄەأشتحأڬەأإرشۏأذظەأوۏڽأ؏أځہشأوۏڽأىەأذعشحأتثىأؼوشأشعۏأتههۄأؼىۄأضەأتضأڬەأوحؼهمأځًډہتأحًأتىۄًڽأىەأثہۏأۏۄۏأدًتثأزۏتأۗأ
2838,أطۄتثأؼىثشۏأڬۄحەأۄۏڽأڬۄأتۏڬأوشحثۄأوۏڽأتځىەأتۏڬأزًضحأڬەأضتحہأذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأڬۏأرزوحأوۏڽأذتعشأۄًتأًۄتڽأذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأڬەأڲہشأڬەأزشًتصەأځشأۄۏأذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوهتمتحأۄًأڲةۏأ؏أتىۄًڽأىەأځًډہتأحوأزًىًڽأڬًىأۄًأآأۄوأىەأتىۄۏڽأتځىەأوحؼهمأثحتۏتأ؏أتىۄًڽأىەألشوتۏتأڬۄأهًڲأڬہدًشۏڽأتًشأځتىۏأڬہتأځۏأشۄەأۄۏڽأ؏أحوأثہۏأًۄتڽأډهەأدتاأ؏أۄشأًتزۏأڬتأثۄتاأتضأڬۏأًضؼحأڬەأثمزشأۄًحتأۄەأ؏أۄوأىەأؼشعأڬۏتأڬۄأإځأڬۏأرۏشأوۏڽأتًشأتعتلۄأۄًأ؏أدثأإځأتىزشأدتةۏڽأحًأۄوتشەأهةەأثہۏأذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأتدتصحأهۏدةەأڲتأ؏أډىتىډۄأتىۄًڽأىەأۄوتشەأهةەأثہۏأتدتصحأذتظهأڬۏأۗأتضأوًمؼأځشأۄوأىەأذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأڬًأىثۏأ﷽أڬەأذًتهەأضەأۏۄأذزۏخأثۏتىأڬشحەأۄًةەأضىتأڬۄأىثۏأ﷽أىەأؽصًۄأحثًڬأڬەأوًمؼأځشأرغثۄأزۏحەأۄًةەأتشطتزألشوتۏتأهًڲًڽأوۏڽأتضأطرظأڬۏأوختهأۄۏأىۄۏڽأۄەأدًأتځىەأڲہًڔەأڬۏأهڲتوأځڬڔەأۄًةەأۄًأ؏أشتۄأرزتأوۏڽأدۄتزأڬشحتأۄًأتًشأثشەأهًڲًڽأضەأثډحتأۄًأ؏أتضۏأغشذأًۄأإزوۏأدًأزۏۄتحأوۏڽأتځىۏأثڬشۏًڽأوۏڽأوڲىأشۄحتأۄًأ؏أوۄوتىًڽأڬۏأوۄوتىأىًتصۏأڬشحتأۄًأتًشأتىأڬتأذمأتزتأڬشحتأۄًأ؏أوۏڽأىەأحۏىأوشحثۄأتىأضەأځًډہتأڬۏتأىثۏأ﷽أىەأۏۄأثتحألشوتةۏأۄەأآأتًشأتىۄًڽأىەأحۏىًڽأوشحثۄأۏۄۏأدًتثأزۏتأڬۄأىثۏأ﷽أىەأۏۄأثتحألشوتةۏأۄەأ؏أتضأځشأوۏڽأىەأتههۄأتڬثشأڬۄتأتًشأتههۄأڬتأطڬشأتزتأڬۏتأۗأ
2839,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أتىۄۏڽأۏۄأزؼتأتضأغشذأضڬہتحەأحہەأدۏضەأمشإىأڬشۏوأڬۏأڬًةۏأضًشحأضڬہتحەأحہەأتًشألشوتحەأحہەأڬۄأۏًڽأڬۄتأڬشًأ؏أتەأتههۄأ$أوۏڽأؼستثأدۄىوأضەأ؏أؼستثأمثشأضەأ؏أوضۏذأزدتهأڬەألحىۄأضەأتًشأصىزڲۏأتًشأوًحأڬۏأإصوتةطأضەأإځأڬۏأځىتۄأوۏڽأإحتأۄًڽأۗأ
2840,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأإزوۏأىثۏأ﷽أڬەأځتضأإۏتأتًشأڬۄىەأهڲتأڬۄأودہأځشأتۏڬأتًىټأًتدثأۄەأوۏشەأځتضأڲىدتةطأثہۏأۄەأ؏أهۏڬىأودہەأتًىټأوهأۄۏأىۄۏڽأشۄەأڬۄأوۏڽأتىۄۏڽأرشۏزأضڬًڽأآأىثۏأ﷽أىەأتضەأذڬوأزۏتأڬۄأتضأڬۏأدڲۄأضتحأثڬشۏتڽأرشۏزأڬشأتىۄۏڽأسثذأڬشأزًأۗأ
2841,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەأتشطتزألشوتۏتأدًأطرظأؼهوأىدًوأڬًأضۏڬہحتأۄەأًۄأدتزًأڬتأتۏڬأطؼثۄأضۏڬہحتأۄەأ؏أدحىتأًۄأؼهوأىدًوأوۏڽأإڲەأثڔہحتأدتةەأڲتأتضۏأمزشأدتزًأوۏڽأإڲەأىڬهحتأدتةەأڲتأۗأ
2842,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أىەأۄوأثىًأؼثزتهوغهثأڬەأڬډہأىًؼوشأهڔڬًڽأڬًأوصزهلۄأضەأۄوتشەأتځىەأڲزہًڽأځشأضًتشأڬشتأڬەأځۄهەأۄۏأثہۏدأزۏتأحہتأتًشأۄوتشۏأټتىڲًڽأځشأۄتحہأوتشحەأۄًةەألشوتۏتأحہتأځۏتشەأثډًأ$أغهًؼأإلحتثأضەأځۄهەأدوشۄأؼمثۄأڬۏأشوۏأىۄأڬشىتأ؏أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأتثأوۏشتأرۏتهأىۄۏڽأۄەأڬۄأڬًةۏأؼمهوىزأغهًؼأإلحتثأضەأځۄهەأشوۏأڬشەأڲتأۗأ
2843,أتثًتهغلۏهأڬۄحەأۄۏڽأڬۄأوۏڽأىەأتۏڬأوشحثۄأذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأؼشعأڬۏتأڬۄأإځأڬۏأمًوأڬتأۏۄأرۏتهأۄەأڬۄأىثۏأ﷽أىەأظلتأوشًۄأڬەأزشوۏتىأضؼۏأتًىټأځشأثۏټہأڬشأڬۏأۄەأتًشأۏۄأضىحأۄەأآأذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأىەألشوتۏتأۏۄأهًڲأڬډہأظذۏذأتًشأڬډہأؽهغأڬۄحەأۄۏڽأ؏أوۏڽأىەأؼشعأڬۏتأظذۏذأڬۏتأۄەأتًشأؽهغأڬۏتأۄەأآألشوتۏتأۏۄأثتحأحًأظذۏذأۄەأڬۄأىثۏأ﷽أىەأتًىټأځشأثۏټہأڬشأضؼۏأڬۏأۄەأ؏أهۏڬىأتضەأضىحأمشتشأزۏىتأؽهغأۄەأ؏أتظهأوۏڽأهًڲأىثۏأ﷽أڬەأځتضأضەأۄټحەأىۄۏڽأحہەأتًشأىۄأۄۏأتىۄۏڽأۄټتۏتأدتأضڬحتأحہتأ؏أتضأهةەأىثۏأ﷽أىەأتًىټأځشأثۏټہأڬشأضؼۏأڬۏأحتڬۄأًۄأىثۏأ﷽أڬتأڬهتوأثہۏأضىأهۏڽأتًشأتىأڬۏأصۏتشحأثہۏأڬشأهۏڽأتًشأتىأڬەأۄتحہأثہۏأىثۏأ﷽أحڬأىۄأځۄىډۏڽأۗأ
2844,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأدىتثأشضًهأتههۄأ﷽أىەأتضأطرظأڬەأثتشەأدضأىەأتۏتوأڬۏأذتهحأوۏڽأتځىۏأثۏًۏأضەأمشثحأڬۏأۄًأ؏أۏۄألشوتۏتأڬۄأًۄأتۏڬأۏتأإزہتأزۏىتشأظزمۄأڬشەأۗأ
2845,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأذعًشأىثۏأوڬشوأ؏أضشًشأزًأؼتهوأ﷽ألشوتۏتأڬشحەأحہەأتضهتوأوۏڽأڲًطۄأىطۏىۏأڬۏأڬًةۏأذۏخۏحأىۄۏڽأۄەأۗأ
2846,أورحهلأتضتىۏزأضەأ““أدىأوۏڽأضەأثؼعأوۏڽأذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأڬتأىتوأۄەأتًشأثؼعأوۏڽأىۄۏڽأ‛‛أوشًۏأۄەأڬۄأىثۏأ﷽أىەأځۄهۏأًذۏأىتصهأۄًىەأڬەأثؼزأذعشحأرزۏدۄأشعۏأتههۄأؼىۄتأضەألشوتۏتأودہەأشًطىۏأزڬہتةۏأزۏحۏأۄەأتًشأڬًةۏأإًتصأضىتةۏأزۏحۏأۄەأ؏أودہەأڋشأۄەأڬۄأڬۄۏڽأودہەأدىًىأىۄأۄًأدتةەأ؏أذعشحأرزۏدۄأشعۏأتههۄأؼىۄتأىەأؼشعأڬۏتأڬۄأتەأرًتدۄأؼثزتههۄأڬەأظتذثصتزۄأڲشتوۏأمزشأ$أتههۄأإځأڬەأضتحہأڬثہۏأتۏضتأىۄۏڽأڬشەأڲتأ؏أځہشأًۄأًشمۄأثىأىًلهأڬەأځتضأڲةۏڽأتًشأۏۄأثتحأتىأضەأسڬشأڬۏأ؏أًۄأڬۄىەأهڲەأڬۄأتڲشأۏۄأضډأثًهأشۄەأۄۏڽأحًأتىأڬەأځتضأإىەأًتهتألشطحۄأًۄۏأىتوًضأۄەأدًأذعشحأوًضۏٳأؼهۏۄأتهضهتوأڬەأځتضأإۏتأڬشحتأحہتأ؏أتڲشأًۄأوۏشۏأصىزڲۏأوۏڽأوثؼًخأۄًأڲةەأحًأوۏڽأتىۄۏڽأحمًۏحأځۄىډتاڽأڲتأ؏أتىأڬۏأوززأڬشًڽأڲتأتًشأتىأځشأتۏوتىأهەأإاڽأڲتأۗأ
2847,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأىثۏأ﷽أځىزشۄأضتهأوڬۄأوڬشوۄأوۏڽأومۏوأشۄەأ؏أضتحأضتهأتضأغشذأڬۄأإځأشًطىۏأزۏڬہحەأحہەأتًشأإًتصأضىحەأحہەأتًشأإټہأضتهأتضأغشذأڬۄأإځأ﷽أځشأًذۏأىتصهأۄًحۏأحہۏأتًشأوزۏىۄأوىًشۄأوۏڽأإځأ﷽أزضأضتهأحڬأتمتوحأڲصۏڽأشۄەأۗأ
2848,أذعشحأتثىأؼثتضأشعۏأتههۄأؼىۄألشوتحەأۄۏڽأڬۄأتۏڬأوشحثۄأوۏڽأتځىەأًتهزأڬەأضتحہأىثۏأ﷽أڬەأځتضأإۏتأ؏أىثۏأ﷽أڬەأځتضأتضأًمحأتۏڬأإزوۏأوًدًزأحہتأدضأضەأًۄأضشڲًطۏأڬشأشۄەأحہەأ؏أتۏضتأوذضًضأۄًتأدۏضەأىثۏأ﷽أىەأوۏشەأًتهزأڬۏأغشلأحًدۄأۄۏأىۄۏڽأڬۏأ؏أدثأۄوأًۄتڽأضەأىڬهەأحًأًتهزأظتذثأودہأضەأڬۄىەأهڲەأثۏټتأ$أحوأىەأتځىەأډډتأصتزأڬًأزۏڬہتأڬۄأًۄأڬۏضەأۄوتشۏأغشلأحًدۄأۄۏأىۄۏڽأڬشأشۄەأحہەأآأوۏڽأىەأؼشعأڬۏتأتثتأدتىأ$أتىأڬەأځتضأتۏڬأإزوۏأحہتأدضأضەأًۄأضشڲًطۏأڬشأشۄەأحہەأ؏أۄوأځہشأىثۏأ﷽أڬەأځتضأًتځضأإأڲةەأ؏أًتهزأظتذثأڬۄىەأهڲەأۏتأشضًهأتههۄأ$أوۏڽأىەأؼثزتههۄأضەأتضأغشذأتۏڬأثتحأڬۄۏأحًأتضأىەأودہەأثحتۏتأڬۄأإځأڬەأځتضأڬًةۏأإزوۏأحہتأدًأإځأضەأضشڲًطۏأڬشأشۄتأحہتأ؏أحًأڬۏتأًتمؼۏأإځأڬەأځتضأڬًةۏأحہتأآأىثۏأ﷽أىەألشوتۏتأؼثزتههۄأ$أڬۏتأحوأىەأًتمؼۏأتضەأزۏڬہتأۄەأآأوۏڽأىەأؼشعأڬۏتأدۏأۄتڽأ$ألشوتۏتأًۄأدثشۏهأحہەأتًشأتضۏأًدۄأضەأوۏڽأإځأڬۏأغشلأوحًدۄأىۄۏڽأۄًأضڬتأحہتأۗأ
