{"hadithnumber": "2287", "text": "سائب رضی اللہ عنہ کہتے ہیں کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم سے عرض کیا: اللہ کے رسول! زمانہ"}
{"hadithnumber": "2288", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  میں سعد اور عمار تینوں بدر کے دن مال غنیمت میں شریک ہوئے،"}
{"hadithnumber": "2289", "text": "صہیب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تین چیزوں میں برکت ہے: پہلی"}
{"hadithnumber": "2290", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تمہارے کھانوں"}
{"hadithnumber": "2291", "text": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  ایک شخص نے کہا: اللہ کے رسول! میرے پاس مال اور اولاد"}
{"hadithnumber": "2292", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نے رسول اللہ صلی اللہ علیہ وسلم کے پاس"}
{"hadithnumber": "2293", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ہند رضی اللہ عنہا نبی اکرم صلی اللہ علیہ وسلم کی خدمت م"}
{"hadithnumber": "2294", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب عورت اپنے ش"}
{"hadithnumber": "2295", "text": "ابوامامہ باہلی رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے سنا:  عورت اپ"}
{"hadithnumber": "2296", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم غلام کی دعوت قبول کرتے تھے۔"}
{"hadithnumber": "2297", "text": "عمیر مولی آبی اللحم رضی اللہ عنہما کہتے ہیں کہ  میرے مالک مجھے کوئی چیز دیتے تو میں اس میں سے اوروں"}
{"hadithnumber": "2298", "text": "ابوبشر جعفر بن أبی ایاس کہتے ہیں  میں نے عباد بن شرحبیل رضی اللہ عنہ جو بنی غبر کے ایک فرد ہیں کو ک"}
{"hadithnumber": "2299", "text": "رافع بن عمرو غفاری رضی اللہ عنہ کہتے ہیں کہ  میں اور ایک لڑکا دونوں مل کر اپنے یا انصار کے کھجور کے"}
{"hadithnumber": "2300", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب تم کسی چرواہے کے"}
{"hadithnumber": "2301", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کوئ"}
{"hadithnumber": "2302", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کھڑے ہوئے اور فرمایا:  کوئی"}
{"hadithnumber": "2303", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ایک سفر میں تھے کہ اتنے م"}
{"hadithnumber": "2304", "text": "ام ہانی رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے ان سے فرمایا:  تم بکریاں پالو، اس"}
{"hadithnumber": "2305", "text": "عروہ بارقی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اونٹ ان کے مالکوں کے ل"}
{"hadithnumber": "2306", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بکری تو جنت کے ج"}
{"hadithnumber": "2307", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مالدار لوگوں کو بکریاں اور محتاج"}
