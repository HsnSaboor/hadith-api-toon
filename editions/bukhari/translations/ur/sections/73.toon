{"hadithnumber": "5545", "text": "ہم سے محمد بن بشار نے بیان کیا، کہا ہم سے غندر نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے زبید ا"}
{"hadithnumber": "5546", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے اسماعیل نے بیان کیا، ان سے ایوب نے، ان سے محمد بن سیرین نے اور ان"}
{"hadithnumber": "5547", "text": "ہم سے معاذ بن فضالہ نے بیان کیا، کہا ہم سے ہشام بن عروہ نے بیان کیا، ان سے یحییٰ نے اور ان سے بعجہ ا"}
{"hadithnumber": "5548", "text": "ہم سے مسدد نے بیان کیا، ہم سے سفیان نے بیان کیا، ان سے عبدالرحمٰن بن قاسم نے، ان سے ان کے والد نے او"}
{"hadithnumber": "5549", "text": "ہم سے صدقہ نے بیان کیا، کہا ہم کو ابن علیہ نے خبر دی، انہیں ایوب نے، انہیں محمد بن سیرین نے اور ان س"}
{"hadithnumber": "5550", "text": "ہم سے محمد بن سلام نے بیان کیا، کہا ہم سے عبدالوہاب نے بیان کیا، کہا ہم سے ایوب سختیانی نے بیان کیا،"}
{"hadithnumber": "5551", "text": "ہم سے محمد بن ابی بکر مقدمی نے بیان کیا، کہا ہم سے خالد بن حارث نے بیان کیا، کہا ہم سے عبیداللہ نے ب"}
{"hadithnumber": "5552", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا ہم سے لیث نے بیان کیا، ان سے کثیر بن فرقد نے، ان سے نافع نے اور"}
{"hadithnumber": "5553", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، انہوں نے کہا ہم سے شعبہ نے بیان کیا، ان سے عبدالعزیز بن صہیب نے ب"}
{"hadithnumber": "5554", "text": "ہم سے قتیبہ بن سعید نے بیان کیا، کہا ہم سے عبدالوہاب نے بیان کیا، ان سے ایوب نے، ان سے ابوقلابہ نے ا"}
{"hadithnumber": "5555", "text": "ہم سے عمرو بن خالد نے بیان کیا، کہا ہم سے لیث نے بیان کیا، ان سے یزید نے، ان سے ابوالخیر نے اور ان س"}
{"hadithnumber": "5556", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے خالد بن عبداللہ نے بیان کیا، کہا ہم سے مطرف نے بیان کیا، ان سے عام"}
{"hadithnumber": "5557", "text": "ہم سے محمد بن بشار نے بیان کیا، کہا ہم سے محمد بن جعفر نے بیان کیا، ان سے شعبہ نے بیان کیا، ان سے سل"}
{"hadithnumber": "5558", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا ہم سے قتادہ نے بیان کیا، ان سے ان"}
{"hadithnumber": "5559", "text": "ہم سے قتیبہ نے بیان کیا، کہا ہم سے سفیان نے بیان کیا، ان سے عبدالرحمٰن بن قاسم نے، ان سے ان کے والد"}
{"hadithnumber": "5560", "text": "ہم سے حجاج بن منہال نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا کہ مجھے زبید نے خبر دی، کہا کہ میں"}
{"hadithnumber": "5561", "text": "ہم سے علی بن عبداللہ نے بیان کیا، کہا ہم سے اسماعیل بن ابراہیم نے بیان کیا، ان سے ایوب نے، ان سے محم"}
{"hadithnumber": "5562", "text": "ہم سے آدم نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، کہا ہم سے اسود بن قیس نے بیان کیا، کہا میں نے جند"}
{"hadithnumber": "5563", "text": "ہم سے موسیٰ بن اسماعیل نے بیان کیا، کہا ہم سے ابوعوانہ نے، ان سے فراس نے، ان سے عامر نے، ان سے براء"}
{"hadithnumber": "5564", "text": "ہم سے حجاج بن منہال نے بیان کیا، کہا ہم سے ہمام نے بیان کیا، ان سے قتادہ نے، انہوں نے کہا کہ ہم سے ا"}
{"hadithnumber": "5565", "text": "ہم سے قتیبہ نے بیان کیا، کہا ہم سے ابوعوانہ نے بیان کیا، ان سے قتادہ نے اور ان سے انس رضی اللہ عنہ ن"}
{"hadithnumber": "5566", "text": "ہم سے احمد بن محمد نے بیان کیا، کہا ہم کو عبداللہ نے خبر دی، انہیں اسماعیل نے خبر دی، انہیں شعبی نے،"}
{"hadithnumber": "5567", "text": "ہم سے علی بن عبداللہ نے بیان کیا، ان سے سفیان نے بیان کیا کہ عمرو نے بیان کیا، انہیں عطاء نے خبر دی،"}
{"hadithnumber": "5568", "text": "ہم سے اسماعیل نے بیان کیا، کہا کہ مجھ سے سلیمان نے بیان کیا، ان سے یحییٰ بن سعید نے، ان سے قاسم نے،"}
{"hadithnumber": "5569", "text": "ہم سے ابوعاصم نے بیان کیا، ان سے یزید بن ابی عبید نے اور ان سے سلمہ بن الاکوع رضی اللہ عنہ نے بیان ک"}
{"hadithnumber": "5570", "text": "ہم سے اسماعیل بن عبداللہ نے بیان کیا، کہا کہ مجھ سے میرے بھائی نے بیان کیا، ان سے سلیمان نے اور ان س"}
{"hadithnumber": "5571", "text": "ہم سے حبان بن موسیٰ نے بیان کیا، انہوں نے کہا ہم کو عبداللہ نے خبر دی، انہوں نے کہا کہ مجھے یونس نے"}
{"hadithnumber": "5572", "text": "ابو عبید نے بیان کیا کہ  پھر میں عثمان بن عفان رضی اللہ عنہ کے ساتھ  ( ان کی خلافت کے زمانہ میں عیدگ"}
{"hadithnumber": "5573", "text": "ابوعبید نے بیان کیا کہ  پھر میں عید کی نماز میں علی بن ابی طالب رضی اللہ عنہ کے ساتھ آیا۔ انہوں نے ب"}
{"hadithnumber": "5574", "text": "ہم سے محمد بن عبدالرحیم نے بیان کیا، انہوں نے کہا ہم کو یعقوب بن ابراہیم بن سعد نے خبر دی، انہیں ابن"}
