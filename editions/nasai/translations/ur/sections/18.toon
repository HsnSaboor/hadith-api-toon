{"hadithnumber": "1529", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  ۔ ( ایک بار )  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں لوگوں"}
{"hadithnumber": "1530", "text": "ثعلبہ بن زہدم کہتے ہیں کہ  ہم سعید بن عاصی کے ساتھ طبرستان میں تھے، ہمارے ساتھ حذیفہ بن یمان رضی الل"}
{"hadithnumber": "1531", "text": "ثعلبہ بن زہدم کہتے ہیں کہ  ہم سعید بن عاصی کے ساتھ طبرستان میں تھے، تو انہوں نے پوچھا: تم لوگوں میں"}
{"hadithnumber": "1532", "text": "زید بن ثابت رضی اللہ عنہ نے  نبی اکرم صلی اللہ علیہ وسلم سے حذیفہ رضی اللہ عنہ کی نماز کے مثل روایت"}
{"hadithnumber": "1533", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں کہ  اللہ تعالیٰ نے تمہارے نبی کریم صلی اللہ علیہ وسلم کی زبان"}
{"hadithnumber": "1534", "text": "عبداللہ بن عباس رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ذی قرد ۱؎ میں نماز پڑھ"}
{"hadithnumber": "1535", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم  ( خوف کی نماز پڑھانے )  کھڑ"}
{"hadithnumber": "1536", "text": "عبداللہ بن عباس رضی اللہ عنہم کہتے ہیں کہ  خوف کی نماز صرف دو سجدوں پر مشتمل تھی، جیسے آج کل تمہارے"}
{"hadithnumber": "1537", "text": "سہل بن ابی حثمہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے لوگوں کو خوف کی نماز پڑ"}
{"hadithnumber": "1538", "text": "صالح بن خوات اس شخص سے روایت کرتے ہیں کہ  جس نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ غزوہ ذات الرقاع"}
{"hadithnumber": "1539", "text": "عبداللہ بن عمر رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے دو گروہوں میں سے ایک گر"}
{"hadithnumber": "1540", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ نجد کی طرف غزو"}
{"hadithnumber": "1541", "text": "عبداللہ بن عمر رضی اللہ عنہم بیان کرتے تھے کہ  انہوں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ خوف کی"}
{"hadithnumber": "1542", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے خوف کی نماز پڑھائی، تو آپ"}
{"hadithnumber": "1543", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنے بعض غزوات میں خوف کی"}
{"hadithnumber": "1544", "text": "مروان بن حکم سے روایت ہے کہ  انہوں نے ابوہریرہ رضی اللہ عنہ سے پوچھا کہ کیا آپ نے رسول اللہ صلی اللہ"}
{"hadithnumber": "1545", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ضجنان اور عسفان کے درمیان اترے آپ مش"}
{"hadithnumber": "1546", "text": "جابر بن عبداللہ رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے لوگوں کو خوف کی نماز پ"}
{"hadithnumber": "1547", "text": "جابر بن عبداللہ رضی اللہ عنہم کہتے ہیں کہ  ہم  ( ایک غزوہ میں )  رسول اللہ صلی اللہ علیہ وسلم کے سات"}
{"hadithnumber": "1548", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ خوف کی نماز میں موجود تھے، ہم"}
{"hadithnumber": "1549", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ نبی اکرم صلی اللہ علیہ وسلم کے ساتھ کچھ کھجور کے باغات میں تھے"}
{"hadithnumber": "1550", "text": "ابوعیاش زرقی رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم مقام عسفان میں دشمن کے مقابلہ"}
{"hadithnumber": "1551", "text": "ابوعیاش زرقی رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ مقام عسفان میں تھ"}
{"hadithnumber": "1552", "text": "ابوبکرہ رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے کچھ لوگوں کو خوف کی نماز دو رکع"}
{"hadithnumber": "1553", "text": "جابر بن عبداللہ رضی اللہ عنہم سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے اپنے صحابہ میں سے ایک گ"}
{"hadithnumber": "1554", "text": "سہل بن ابی حثمہ رضی اللہ عنہ نماز خوف کے سلسلہ میں کہتے ہیں  امام قبلہ رو کھڑا ہو گا، اور اس کے لشکر"}
{"hadithnumber": "1555", "text": "جابر بن عبداللہ رضی اللہ عنہم سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے اپنے صحابہ کو خوف کی ن"}
