أتىأهًڲًڽأڬەأځتضأڲۏتأتًشأتىأهًڲًڽأىەأتضەأمحهأڬشأزۏتأۗأ
أځہشأذعشحأزذۏۄأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬەأځتضأًتځضأإأڲةەأ؏أتضأًمحأظىؼتؤأوۏڽأوًدًزأڬضشۏٳأڬەأومششأڬشزۄأڲًشىشأڬەأىوتةىزەأىثۏأتڬشوأ﷽أڬەأځتضأوًدًزأحہەأ؏أإځأىەأتىأهًڲًڽأڬًأڬضشۏٳأڬۏأغشلأثہۏدتأحہتأتًشأتضأىەأظىؼتؤأڬەأڲًشىشأڬًأرغأهڬہتأحہتأ؏أدضأوۏڽأتضأضەأۏۄأڬۄتأحہتأ=أڬۄأحوأتىأظتذثأځشأمتثًأځتأهًأ؏أدًأحوۄتشۏأضشصوۏىأځشأوثؼًخأۄًةەأۄۏڽأ؏أتًشأودہەأتځىەأزۏىأڬۏأغشلأزؼًحأزەأشۄەأۄۏڽأڬۄأۏتأحًأوۏڽأتىأڬتأزۏىأمثًهأڬشأهًڽأ؏أۏتأدصۏۄأزەأزًڽأ؏أًشىۄأوۏڽأحوۄۏڽأمحهأڬشأزًڽأڲتأ؏أۏتأوۏڽأحوۄۏڽأۏۄأڬشًڽأڲتأ؏أحًأظىؼتؤأڬەأڲًشىشأىەأىثۏأتڬشوأ﷽أڬۏأغشلأځىزشۄأتلشتزأثہۏدەأ؏أذعشحأزذۏۄأشعۏأتههۄأؼىۄأىەأتىأتلشتزأڬًأىثۏأتڬشوأ﷽أڬەأځتضأځتۏتأحہتأ؏أدثأىثۏأتڬشوأ﷽أىەأتىأڬەأإمتأڬتأوڬحًثأځڔہتأ؏أحًأإځأىەأځىزشۄأزىأتىۄۏڽأتۏضەأۄۏأشۄىەأزۏتأ؏أدثأځىزشۄأزىأڲصشأڲةەأحًأتۏڬأشتحأإځأتىأڬەأځتضأإةەأ؏أدثأإځأىەأتىۄۏڽأوهتذػۄأڬۏتأحًأتىۄۏڽأثهتۏتأتًشأتشطتزألشوتۏتأ=أحوأتځىەأإمتأ+أۏؼىۏأظىؼتؤأڬەأڲًشىشأ,أڬەأځتضأدتاأ$أتًشأتضأضەأۏۄأڬۄًأڬۄأوۏشەأځشًشزڲتشأىەأڲصطحۄأشتحأتضأڬەأإمتأ+أۏؼىۏأڬضشۏٳأ
أڬًأمحهأڬشأزۏتأۄەأ؏أًۄأهًڲأڲةەأتًشأتضأثتشەأوۏڽأتضأڲًشىشأڬًأثحتۏتأ؏أحًأتضأىەأڬۄتأ=أحوأهًڲأتضأشتحأڬتأذضتثأهڲتاأڬۄأًۄأڬًىأضۏأشتحأحہۏأآأتضأىەأۏۄأثہۏأڬۄتأ=أڬۄأحوأهًڲأثحتاأڬۄأحوأىەأتىأڬًأڬۏضتأځتۏتأآأحًأتىأهًڲًڽأىەأثحتۏتأ=أڬۄأۄوأىەأتىأضەأصۏتزۄأۄۏثحأىتڬأ+أۏؼىۏأثتشؼثأ,أڬًةۏأثتزطتۄأىۄۏڽأزۏڬہتأ؏أًۄأهًڲًڽأڬەأزشوۏتىأډهحەأۄۏڽأتًشأتىۄۏڽأڬضۏأضەأڬًةۏأرًلأىۄۏڽأۄًحتأ؏أًۄأؼتوأڬۏأذتهحأوۏڽأشۄحەأۄۏڽأ؏أتىأڬۏأذلتػحأىۄۏڽأڬۏأدتحۏأ؏أهۏڬىأتىأڬەأځتضأإًتصأثہۏأثهىزأىۄۏڽأڬۏأدتحۏأ؏أذعشحأزذۏۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أځہشأۏۄأتغهتؼأإأڲةۏأڬۄأتْضأشتحأڬضشۏٳأمحهأۄًأڲۏتأحہتأۗأ أۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتثشتۄۏوأثىأتضوتؼۏهأثىأتثشتۄۏوأثىأۏذۏۏأۄەأتًشأًۄأعؼۏلأۄەأۗ
13896,"أؼهموۄأثىأًمتظأثۏتىأڬشحەأۄۏڽأ=أذعشحأؼوشًأثىأتهؼتظأشعۏأتههۄأؼىۄأىەأۏۄأثتحأثۏتىأڬۏأڬۄأوضهوتىًڽأڬتأتۏڬأهطڬشأثہۏدتأڲۏتأ؏أوۏڽأتىأهًڲًڽأڬتأتوۏشأحہتأ؏أۄوأىەأتضڬىزشۏۄأڬەأومتوأځشأځڔتاأڬۏتأ؏أحًأزطوىأڬەأتۏڬأثڔەألشزأىەأۏۄأڬۄتأ=أڬضۏأطرظأڬًأوۏشەأځتضأثہۏدًأحتڬۄأوۏڽأتضأڬەأضتحہأثتحأډۏحأڬشًڽأتًشأًۄأوۏشەأضتحہأثتحأڬشەأ+أذعشحأؼوشًأثىأتهؼتظأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أ,أحًأوۏڽأىەأڬۄتأ=أوۏشەأؼهتًۄأتًشأڬًةۏأتضأڬۏأغشلأىۄۏڽأدتةەأڲتأ؏أحًأوۏڽأتضأڬەأمتظزأڬەأۄوشتۄأىڬهتأ؏أۏۄتڽأحڬأڬۄأۄوتشەأهةەأزًأوىثشأشڬہەأڲةەأ؏أتضأىەأزشۏتلحأڬۏتأ=أحوأهًڲأڬًىأۄًأآأوۏڽأىەأدًتثأزۏتأ=أۄوأؼشثأۄۏڽأ؏أۄوأڬتىټًڽأتًشأځحًڽأوۏڽأشۄىەأًتهەأهًڲأۄۏڽأ؏أۄوأتههۄأڬەأڲہشأڬەأځتضأشۄىەأًتهەأهًڲأۄۏڽأ؏أۄوأشًةەأصوۏىأځشأضثأضەأصۏتزۄأحىڲۏأڬتأطڬتشأهًڲأحہەأ؏أتًشأۄوتشۏأصىزڲۏأضثأضەأصۏتزۄأوطڬهأحہۏأ؏أۄوأوشزتشأتًشأرًىأڬہتأهۏتأڬشحەأحہەأتًشأتۏڬأزًضشەأځشأذوهۄأإًشأۄًأدتۏتأڬشحەأحہەأ؏أۄوأتضأضثأضەأثشەأغشۏمەأضەأصىزۄأشۄەأحہەأدضأڬەأضتحہأهًڲأشۄأضڬحەأۄۏڽأ؏أۏۄتڽأحڬأڬۄأۄوتشەأزشوۏتىأتۏڬأظتذثأڬتأػۄًشأۄًتأ؏أدًأىۄأحًأوؼتطشحۏأغًشأځشأضثأضەأصۏتزۄأىوتۏتڽأذۏخۏحأڬەأوتهڬأحہەأتًشأىۄأۄۏأضثأضەأصۏتزۄأوتهأزتشأحہەأ؏أتىۄًڽأىەأڬۄتأ=أوۏڽأحوأهًڲًڽأڬۏأغشلأتههۄأڬتأشضًهأۄًڽأ؏أتىۄًڽأىەأۄوۏڽأتۏضۏأثتحًڽأڬتأذڬوأزۏتأ؏أدىأضەأۄوأًتملأىۄۏڽأحہەأتًشأتىۄًڽأىەأۄوۏڽأتۏضۏأډۏصًڽأضەأوىؼأڬۏتأدىأځشأۄوأؼوهأځۏشتأحہەأ؏أتًشأۄوتشەأإثتاأتدزتزأتىأځشأؼوهأځۏشتأحہەأ؏أحًأۄوأىەأتىأڬۏأورتهلحأڬۏأ؏أتىأڬۏأحڬسۏثأڬۏأ؏أتىأڬۏأثتحأڬًأوضحشزأڬۏتأۗ أۏۄتڽأحڬأڬۄأۄوتشەأؼهتًۄأتۏڬأتًشأمًوأتىأڬەأځتضأإةۏأتًشأتضأمًوأڬەأهًڲًڽأىەأڬۄتأ=أڬۄأۄوأإځأڬۏأحظزۏمأڬشحەأۄۏڽأتًشأإځأځشأتۏوتىأهتحەأۄۏڽأتًشأإځأڬۏأځۏشًۏأڬشحەأۄۏڽأ؏أدًأطرظأإځأڬەأضتحہأهڔتةۏأڬشەأڲتأ؏أۄوأتضأڬەأضتحہأدىڲأڬشۏڽأڲەأ؏أحًأًۄأظتذثأتىأهًڲًڽأڬەأځتضأحطشۏلأهەأڲةەأ؏أځہشأۄوأتىأڬەأځۏډہەأڲةەأ؏أۄوأىەأتىأڬەأضتحہأهڔتةۏأڬۏأ؏أحًأًۄأۄوأځشأؽتهثأإأڲةەأتًشأځہشأتىۄًڽأىەأؼشثًڽأڬەأزۏڲشأهًڲًڽأڬۏأغشلأوحًدۄأۄًأڬشأتىأضەأهڔتةۏأڬۏأ؏أۏۄتڽأحڬأڬۄأًۄأتىأځشأثہۏأؽتهثأإأڲةەأ؏أتڲشأوۏشەأځۏډہەأوًدًزأؼشثأهًڲًڽأڬًأۏۄأځحۄأډهأدتةەأڬۄأحوأهًڲأڬضأغشذأڬۏأرًطذتهأصىزڲۏأڲصتشأشۄەأۄًأ؏أحًأًۄأضثأهًڲأحوۄتشەأځتضأإأدتةۏڽأڲەأتًشأحوأهًڲأدضأرًطذتهأصىزڲۏأڬًأثضشأڬشأشۄەأۄًأ؏أًۄأتضأوۏڽأحوۄتشەأذظەأزتشأثىأدتةۏڽأڲەأۗ أحًأزطوىأڬتأتوۏشأۄىضأځڔتأتًشأثًهتأ=أثەأطڬأتههۄأڬەأشضًهأ﷽أىەأضډأڬۄتأۄەأ؏أۄوتشەأځتضأثہۏأشضًهأتضۏأڬۏأوتىىزأحؼهۏوتحأهەأڬەأإةەأحہەأ؏أدًأحوۄتشەأشضًهأهەأڬەأإةەأۄۏڽأ؏أتًشأۄوتشەأثڔەأتىأحؼهۏوتحأځشأؼوهأځۏشتأشۄەأ؏أۏۄتڽأحڬأڬۄأۄوتشەأزشوۏتىأڬډہأهًڲأإةەأ؏أدىۄًڽأىەأتځىۏأىلضتىۏأرًتۄطتحأځشأؼوهأڬشىتأطشًؼأڬشأزۏتأتًشأتىثۏتؤأڬەأذڬوأڬًأحشڬأڬشأزۏتأ؏أدثأحڬأحوأهًڲأتځىەأىثۏأڬەأذڬوأځشأؼوهأځۏشتأشۄًأڲەأ؏أدًأثہۏأحوۄتشەأومتثهەأوۏڽأإةەأڲتأ؏أحوأتضأځشأؽتهثأإأدتاأڲەأتًشأدًأثہۏأحوۄتشەأضتوىەأإةەأڲتأ؏أحوأتضأځشأؽهثۄأځتأهًأڲەأتًشأدثأحوأهًڲأتضأغشذأڬەأڬتوأڬشًأڲەأ؏أدضأغشذأڬەأۄوأىەأڬۏەأتًشأحوأهًڲأتځىەأىثۏأڬەأذڬوأڬًأحشڬأڬشأزًأڲەأتًشأتضأڬۏأوتىىزأؼوهأڬشًأڲەأدًأتىأهًڲًڽأىەأؼوهأڬۏتأدًأتځىۏأىلضتىۏأرًتۄطتحأځشأؼوهأڬشحەأحہەأ؏أحًأځہشأحوۄۏڽأحوۄتشەأذتهأځشأډہًڔأزۏتأدتةەأڲتأڬۏًىڬۄأحوأحؼزتزأوۏڽأۄوأضەأصۏتزۄأىۄۏڽأۄًأ؏أتًشأمًحأوۏڽأۄوأضەأصۏتزۄأوعثًغأىۄۏڽأۄًأۗ أذعشحأؼوشًأثىأتهؼتظأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أوۏڽأىەأتْضأضەأصۏتزۄأضودہأزتشأڬضۏأطرظأضەأثتحأىۄۏڽأڬۏأۗأ أۏۄأشًتۏحأتوتوأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأ““أظذۏذأ‛‛أڬەأشدتهأۄۏڽأ؏أظشلأؼوشًأثىأؼهموۄأڬتأوؼتوهۄأورحهلأۄەأ؏أتًشأًۄأشتًۏأخمۄأۄەأۗ"
13897,أذعشحأڬشصأثىأؼهموۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىدشتىأڬەأؼۏضتةۏًڽأڬتأًلزأىثۏأتڬشوأ﷽أڬۏأرزوحأوۏڽأذتعشأۄًتأ؏أتضأًلزأوۏڽأتىأڬەأډًثۏضأضشڬشزۄأتلشتزأحہەأ؏أتًشأتىأډًثۏضأتلشتزأوۏڽأضەأحۏىأتلشتزأتۏضەأحہەأ؏أدىأڬۏأغشلأتىأهًڲًڽأڬەأوؼتوهتحأوۏڽأشدًؼأڬۏتأدتحتأحہتأ؏أتىأوۏڽأضەأتۏڬأ““أؼتمثأ‛‛أىتوأڬتأطرظأحہتأ؏أدًأتىأهًڲًڽأڬتأتوۏشأحہتأتًشأتىأڬتأحدشثۄأڬتشأإزوۏأتًشأوطًشۄأزۏىەأًتهتألشزأحہتأ؏أًۄأهًڲأتضأڬۏأشتةەأتًشأتضأڬەأذڬوأضەأؼزًهأىۄۏڽأڬشحەأحہەأ؏أتضأڬتأىتوأؼثزتهوضۏذأحہتأ؏أتۏڬأطرظأڬتأىتوأ““أضۏزأ‛‛أحہتأ؏أًۄأتىأڬتأؼتهوأحہتأتًشأتىأڬەأتوًشأڬتأىڲشتىأحہتأ؏أتۏڬأطرظأ““أتثًذتشخۄأثىأؼهموۄأ‛‛أحہتأ؏أدًأثڬشأثىأًتةهأضەأحؼهمأشڬہحتأحہتأ؏أًۄأتىأڬتأځتزشۏأتىأڬتأثڔتأؼتهوأتًشأتىأڬتأځۏطًتأتًشأتىأڬەأزشضأًأحزشۏضأڬەأتوًشأڬتأىڲشتىأحہتأ؏أتثًذتشخۄأڬًأتىأڬەأزشوۏتىأىوتۏتڽأذۏخۏحأذتظهأحہۏأ؏أتىأهًڲًڽأڬەأزۏىأڬەأثتشەأوۏڽأًۄأثہشځًشأؼتهوأحہتأ؏أؼۏضتةۏًڽأڬەأثتزطتۄأتضەأؼصحأزۏحەأحہەأ؏أتضأڬۏأثتحأڬًأمثًهأڬشحەأحہەأ؏أتىأهًڲًڽأىەأتضأڬەأهةەأؼثتزحأرتىەأحؼوۏشأڬۏەأحہەأ؏أتًشأزۏىأوۏڽأتضأڬۏأثہشځًشأڬًططأڬۏأًدۄأضەأتضەأثۄحأضەأتؼصتصأًأتذحشتوأضەأىًتصتأحہتأۗ
أدثأۏۄأهًڲأىدشتىأضەأډهأڬەأىثۏأتڬشوأ﷽أڬۏأغشلأدتىەأڬەأهةەأشًتىۄأۄًةەأ؏أحًأتثًذتشخۄأىثۏأتڬشوأ﷽أڬۏأغشلأدتىەأڬەأهةەأتځىەأرډشأځشأثۏټہتأ؏أتضأڬەأځۄهًأوۏڽأتضأڬتأثہتةۏأحہتأ؏أدضأڬتأىتوأڬشصأثىأؼهموۄأحہتأ؏أًۄأتضأضەأثتحأډۏحأڬشأشۄتأحہتأ؏أتضۏأزًشتىأتثًذتشخۄأڬەأرډشأڬًأټہًڬشأهڲۏأحًأڬشصأىەأڬۄتأ=أزًشأڬتأطرظأ؏أثشثتزأۄًأدتةەأ؏أتضأڬۏأوشتزأىثۏأتڬشوأ﷽أحہەأ؏أحًأتثًذتشخۄأىەأڬۄتأ=أثهڬۄأحوأثشثتزأۄًأدتاأ$أڬشصأىەأزشۏتلحأڬۏتأ=أًۄأڬۏًڽأتەأثہتةۏأدتىأآأتضأىەأڬۄتأ=أتههۄأڬۏأمضوأ$أۏۄأًۄۏأىثۏأۄۏڽأ؏أدىأڬتأۄوأتىحػتشأڬشأشۄەأحہەأ؏أڬشصأىەأتضأضەأزشۏتلحأڬۏتأ=أدثأحوأۏۄأثتحأدتىحەأۄًأ؏أحًأځہشأحوۄتشەأهةەأشڬتًټأڬۏتأۄەأآأتضأىەأڬۄتأ=أشڬتًټأۏۄأۄەأڬۄأدًأتىأ+أؼۏضتةۏأ,أهًڲًڽأىەأۄوتشەأضتحہأضهًڬأڬۏتأۄًتأۄەأ؏أتىأهًڲًڽأىەأۄوۏڽأؼصحأزۏأۄەأ؏أۏۄأهًڲأۄوتشتأتذحشتوأڬشحەأۄۏڽأتًشأۏۄأهًڲأتضأثتحأڬًأىۄۏڽأوتىۏڽأڲەأڬۄأۄوأتْىأ+أۏؼىۏأىثۏأتڬشوأ﷽أ
13898,أذعشحأؼثزتههۄأثىأضهتوأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أدثأتههۄأحؼتهۏٳأىەأذعشحأصۏزأثىأضؼىۄأشعۏأتههۄأؼىۄأڬًأۄزتۏحأزۏىەأڬتأتشتزۄأڬۏتأ؏أحًأصۏزأثىأضؼىۄأىەأڬۄتأ=أىثًحأڬۏأؼهتوتحأضەأوحؼهمأدًأثہۏأډۏصأۄەأ؏أًۄأودہەأذعشحأوذوزأ﷽أڬەأډۄشەأوۏڽأځحۄأډهأڲةۏأ؏أدثأوۏڽأىەأتىأڬۏأغشلأزۏڬہتأحہتأ؏أتهثحۄأزًأډۏصًڽأڬتأوؼتوهۄأورحهلأۄەأ؏أتىأڬەأذًتهەأضەأوۏڽأتىۄۏڽأإصوتأهۏحتأۄًڽأ؏أتۏڬأۏۄأڬۄأتْىأڬۏأثشزثتشۏأ؏أتىأڬۏأضرحۏأځشأضثمحأهەأدتحۏأۄًأڲۏأتًشأتىأڬەأرهتلأدحىۏأطزحأڬەأضتحہأثزحوۏصۏأڬۏأدتةەأڲۏأ؏أًۄأتحىەأۄۏأصۏتزۄأثشزثتشأۄًڽأڲەأ؏أحًأوۏڽأتىأڬەأضتحہأشۄىەأهڲتأ؏أحتڬۄأتىأڬەأضتحہأڲہهأوهأڬەأضرحۏأڬەأومتثهەأوۏڽأ؏أتْىأڬۏأثشزثتشۏأڬتأدتةصۄأهًڽأ؏أصۏزأثىأضؼىۄأثۏتىأڬشحەأۄۏڽأ=
أتۏڬأزىأىثۏأتڬشوأ﷽أذدشًڽأضەأحطشۏلأهتةەأ؏أإځأڬەأضتحہأذعشحأؼهۏأثىأتثًغتهثأشعۏأتههۄأؼىۄأثہۏأحہەأ؏أتۏڬأطرظأضًتشۏأځشأضًتشأۄًأڬەأإځأڬەأځتضأإۏتأ؏أًۄأثزًۏأهڲأشۄتأحہتأ؏أتضأىەأڬۄتأ=أۏتأشضًهأتههۄأ$أثىًلهتڽأڬەأؼهتمەأوۏڽأ؏أوۏشەأضتحہۏأڬډہأهًڲأۄۏڽأ؏أًۄأتضهتوأمثًهأڬشأډڬەأۄۏڽأ؏أًۄأهًڲأتضهتوأوۏڽأزترهأۄًأډڬەأۄۏڽأ؏أوۏڽأىەأتىۄۏڽأۏۄأثحتۏتأحہتأڬۄأدثأًۄأتضهتوأمثًهأڬشأهۏڽأڲەأ؏أحًأتىأڬەأځتضأثۄحأضتأشصمأإةەأڲتأ؏أهۏڬىأتىۄۏڽأحًأمذغأضتهۏأتًشأوظۏثحأىەأتځىۏأهځۏټأوۏڽأهەأهۏتأۄەأ؏أتًشأثتشطأۄًأىۄۏڽأشۄۏأۄۏڽأ؏أۏتأشضًهأتههۄأ$أودہەأۏۄأتىزۏطۄأۄەأڬۄأًۄأهًڲأدضأغشذأهتهډأڬۏأثىۏتزأځشأتضهتوأوۏڽأزترهأۄًةەأحہەأ؏أتضۏأغشذأهتهډأڬۏأًدۄأضەأتضهتوأضەأىڬهأدتةۏڽأڲەأ؏أحًأتڲشأإځأوىتضثأضودہۏڽأڬۄأتىأڬۏأغشلأڬًةۏأډۏصأثہۏدأزۏڽأ؏أدضأڬەأسشۏؼەأإځأتىأهًڲًڽأڬۏأوززأڬشأزۏڽأ؏أحًأۏۄأوىتضثأۄًأڲتأ؏أىثۏأتڬشوأ﷽أىەأتځىەأځۄهًأوۏڽأوًدًزأطرظأڬۏأغشلأزۏڬہتأ؏أوۏشتأرۏتهأۄەأًۄأذعشحأؼهۏأشعۏأتههۄأؼىۄأحہەأ؏أتىۄًڽأىەأؼشعأڬۏأ=أۏتأشضًهأتههۄأڬًةۏأثہۏأډۏصأثتمۏأىۄۏڽأۄەأ؏أصۏزأثىأضؼىۄأڬۄحەأۄۏڽأ=أوۏڽأىثۏأتڬشوأ﷽أڬەأځتضأڲۏتأ؏أوۏڽأىەأڬۄتأ=أتەأذعشحأوذوزأ+أ﷽أ,أ$أڬۏتأإځأتضأثتحأوۏڽأزهډضځۏأشڬہحەأۄۏڽأڬۄأوحؼۏىأوزحأڬەأثؼزأثىًألهتڽأڬەأثتؽأوۏڽأهڲىەأًتهۏأوحؼۏىأڬہدًشًڽأڬەأؼًعأوۏڽأوۏشەأضتحہأضًزتأڬشأهۏڽأ؏أتًشأتضأڬۏأوزحأتحىۏأتحىۏأۄًأڲۏأ؏أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أدۏأىۄۏڽأ$أتەأۏۄًزۏأ$أوۏڽأحوۄتشەأضتحہأڬہدًشًڽأڬتأضًزتأڬشًڽأڲتأ؏أدًأوحؼۏىأۄًڽأڲۏأتًشأتضأڬۏأوزحأوحؼۏىأۄًأڲۏأ؏أدًألهتڽأوزحأۄًأڲۏأ؏أهۏڬىأحوأتضأوۏڽأڬضۏأورظًظأثتؽأڬًأوحؼۏىأىۄۏڽأڬشأضڬحەأ؏أوۏڽأىەأڬۄتأ=أټہۏڬأۄەأ؏أىثۏأتڬشوأ﷽أىەأوۏشەأضتحہأۏۄأضًزتأغەأڬۏتأ؏أوۏڽأىەأتځىۏأحہۏهۏأڬًأڬہًهتأتًشأتضأوۏڽأضەأوحؼۏىأڬہدًشًڽأڬەأؼًعأوۏڽأوحؼۏىأوزحأڬەأوؼتۄزەأڬەأضتحہأضًىەأڬەأتضٔۏأوخمتهأىثۏأتڬشوأ﷽أڬًأزۏزۏەأ؏أىثۏأتڬشوأ﷽أىەأًۄأوخمتهأتىأظتذثأڬًأزۏەأتًشألشوتۏتأ=أحوأتىأهًڲًڽأڬەأځتضأدتاأتًشأتىأڬەأسشۏؼەأتْىأهًڲًڽأڬۏأوززأڬشًأۗ
أذعشحأصۏزأثىأضؼىۄأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أدثأتضأوحؼۏىأوزحأڬەأرحوأۄًىەأوۏڽأزًأۏتأحۏىأزىأثتمۏأشۄأڲةەأحًأتۏڬأزىأىثۏأتڬشوأ﷽أثتۄشأىڬهەأ؏أإځأڬەأضتحہأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأ؏أذعشحأؼوشأشعۏأتههۄأؼىۄأ؏أذعشحأؼخوتىأشعۏأتههۄأؼىۄأحہەأتًشأڬډہأزۏڲشأتظذتثأحہەأ؏أإځأىەأىوتصأدىتصۄأتزتأڬۏأ؏أځہشأإځأتۏڬأزۏًتشأڬۏأغشلأثڔہأڲةەأ؏أحتڬۄأتضأڬەأځتضأثۏټہأدتةۏڽأ؏أوۏڽأإځأڬەأځتضأإۏتأ؏أوۏڽأىەأإځأڬۏأموۏظأڬەأڲشۏثتىأتًشأإځأڬۏأډتزشأڬًأځڬڔتأتًشأضرحأىػشًڽأضەأإځأڬۏأغشلأزۏڬہتأتًشأإځأضەأڬۄتأ=أتەأذعشحأوذوزأ+أ﷽أ,أ$أإځأوۏشتأذمأودہەأڬۏًڽأىۄۏڽأتزتأڬشأشۄەأۄۏڽأآأإځأهًڲًڽأ؏أثىًأؼثزتهوغهثأڬەأثتشەأوۏڽأودہەأځحۄأۄەأڬۄأإځأهًڲأټتهأوټًهأضەأڬتوأهۏحەأۄۏڽأتًشأإځأهًڲًڽأڬەأضتحہأوۏهأدًهأشڬہأڬشأودہەأتضأثتحأڬتأځحۄأډهأډڬتأۄەأ؏أځہشأوۏڽأىەأذعشحأؼوشأشعۏأتههۄأؼىۄأڬۏأغشلأزۏڬہتأ؏أحًأتىأڬۏأإىڬہۏڽأتْثهأشۄۏأحہۏڽأ؏أتىۄًڽأىەأوۏشۏأغشلأزۏڬہأڬشأڬۄتأ=أتەأتههۄأڬەأزطوىأ$أڬۏتأحوأتههۄأڬەأشضًهأڬًأۏۄأثتحأڬۄۄأشۄەأۄًأآأدًأوۏڽأضىأشۄتأۄًڽأتًشأتىأڬەأضتحہأۏۄأڬشأشۄەأۄًأ؏أدًأوۏڽأزۏڬہأشۄتأۄًڽأ؏أتضأستحأڬۏأمضوأ$أدضأڬەأزضحأمزشحأوۏڽأوۏشۏأدتىأۄەأ؏أتڲشأًۄأډۏصأىۄأۄًحۏأدضأڬەأعتةؼأۄًىەأضەأوۏڽأثډأشۄتأۄًڽأحًأوۏڽأىەأتځىۏأحهًتشأڬەأسشۏؼەأحوۄتشتأضشأتْڔتأزۏىتأحہتأ؏أىثۏأتڬشوأ﷽أضڬًىأتًشأىشوۏأڬەأضتحہأوۏشۏأغشلأزۏڬہحەأشۄەأ؏أإځأىەألشوتۏتأ=أتەأؼوشأ$أوۏڽأتًشأۏۄأ؏أۄوأتضأڬەأؼهتًۄأظًشحأذتهأڬەأثتشەأوۏڽأصۏتزۄأوذحتدأۄۏڽأ؏أتًشأًۄأۏۄأۄەأڬۄأحوأودہأضەأۏۄأڬۄًأ=أڬۄأإځأتډہەأغشۏمەأضەأتزتةۏڲۏأڬشۏڽأ؏أتًشأحوأتضأڬًأۏۄأڬۄًأ=أڬۄأۏۄأتډہەأغشۏمەأضەأًظًهۏأڬشەأ؏أتًشأتەأؼوشأ$أحوأتضەأهەأدتاأتضەأتضأڬتأذمأزەأزًأ؏أتًشأتضەأڬہدًشًڽأڬەأثۏضأظتؼأصۏتزۄأزۏىتأ؏أدًأتْضأډۏصأڬتأثزهۄأۄًڽأڲەأ؏أدًأحوأىەأتضەأزہوڬۏأزۏأۄەأۗأ أذعشحأصۏزأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ=أذعشحأؼوشأشعۏأتههۄأؼىۄأودہەأضتحہأهەأڲةەأ؏أتىۄًڽأىەأوۏشتأذمأودہەأتزتأڬۏتأتًشأڬہدًشًڽأڬەأوصۏزأثۏضأظتؼأودہەأزۏەأ؏أحًأوۏڽأىەأڬۄتأ=أتەأؼوشأ$أۏۄأتعتلۏأتزتةۏڲۏأڬضأهةەأۄەأآأتىۄًڽأثحتۏتأڬۄأتههۄأڬەأشضًهأىەأودہەأۏۄأذڬوأزۏتأۄەأڬۄأوۏڽأىەأدًأحوۄۏڽأزہوڬۏأزۏأحہۏأ؏أتضأڬۏأدڲۄأوۏڽأحوۄۏڽأوصۏزأتزتةۏڲۏأڬشًڽأ؏أحًأذعشحأصۏزأثىأضؼىۄأشعۏأتههۄأؼىۄأىەأڬۄتأ=أتەأؼوشأ$أڬۏتأحوأودہەأدتىحەأۄًأآأذعشحأؼوشأشعۏأتههۄأؼىۄأىەأڬۄتأ=أىۄۏڽأ$أحوأڬًىأۄًأآأوۏڽأىەأڬۄتأ=أوۏڽأصۏزأثىأضؼىۄأۄًڽأ؏أذعشحأؼوشأشعۏأتههۄأؼىۄأىەأزشۏت