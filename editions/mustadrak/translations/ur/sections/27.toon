أ®تّهّٔسٓۏٕىّأڬّلّشًْٕتأًّأظّزًْٕٔتأؼّىٕأضّثٓۏٕهٓأتههٔٳۄٓأتّعّهّٔأتّؼٕوّتهّہْوٕأ+أوذوزأ=أ4أ,¾ أ““أدىۄًڽأىەأڬلشأڬۏتأتًشأتههۄأڬۏأشتۄأضەأشًڬتأتههۄأىەأتىأڬەأتؼوتهأثشثتزأڬۏەأۗ‛‛أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ أڬەأوحؼهمألشوتحەأۄۏڽأ=أتىأوۏڽأضەأتۄهأوڬۄأثہۏأۄۏڽأتًش
أ®ًّأتهّٔسٓۏٕىّأٳتوّىًْٕتأًّأؼّوٓهًْتأتهظٔٳهٓذٳحٓأ,أ+أوذوزأ=أ5أ,¾ أ““أتًشأدًأتۏوتىأهتةەأتًشأتډہەأؼوهأڬۏەأتًشأتضأځشأتۏوتىأهتةەأدًأوذوزأځشأتحتشتأۄەأۗ‛‛أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ أۏۄأتىظتشأۄۏڽأۗأتًش
أ®ًّأتّظٕهّذّأثّتهّہْوٕأ+أوذوزأ=أ5أ,¾ أ““أتًشأتىأڬۏأذتهحۏڽأضىًتشأزۏڽأۗ‛‛أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ
أ+أضەأوشتزأۄەأ,أتىأڬەأتوًشأڬۏأتظهتذألشوتأزۏأۗ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأتضەأىمهأىۄۏڽأڬۏتأۗ%أ"
3704,"%أذعشحأتثًتوتوۄأشعۏأتههۄأؼىۄأتههۄأحؼتهۏٳأڬەأتشطتزأ=
أ®ًّأۏْضٕمٳۏأوٓىٕأؤّإؤِأظّزٓۏٕزِأۏّٔحّدّشّٔؼْۄٚأ,أ+أتثشتۄۏوأ=أ49أ؏أ4:أ أ““أتًشأتضەأځۏځأڬتأځتىۏأځهتۏتأدتةەأڲتأ؏أثوطڬهأتضأڬتأحہًڔتأحہًڔتأڲہًىټأهەأڲتأۗ‛‛أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ أڬەأوحؼهمأىثۏأتڬشوأ﷽أڬتأۏۄأتشطتزأىمهأڬشحەأۄۏڽأ=أًۄأځتىۏأتىأڬًأزۏتأدتةەأڲتأحًأًۄأتضأڬًأىتځضىزأڬشۏڽأڲەأدثأتضأڬًأوىۄأڬەأمشۏثأڬشۏڽأڲەأحًأتىأڬتأډۄشۄأدہهضأدتةەأڲتأتًشأتضأڬەأضشأڬۏأڬہتهأدہڔأڬشأتضأوۏڽأڲشأدتةەأڲۏأ؏أدثأًۄأتضأڬًأځةۏڽأڲەأتىأڬۏأتىحڔۏتڽأځڲہهأڬشأځترتىەأڬەأشتضحەأىڬهأدتةۏڽأڲۏأۗأتههۄأحؼتهۏٳألشوتحتأۄەأ=
أ®ًّأضْمًْٕتأوّإؤَأذّوٓۏٕوَتألّمّغّٔؼّأتّوٕؼّإةّہْوٕأ,أ+أوذوزأ=أ48أ,¾ أ““أتًشأتىۄۏڽأڬہًهحتأۄًتأځتىۏأځهتۏتأدتةەأڲتأڬۄأإىحًڽأڬەأټڬڔەأټڬڔەأڬشأزەأۗ‛‛أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ أتههۄأحؼتهۏٳألشوتحتأۄەأ=
أ®ًّأتٓىٕأۏّٔضٕحّؽٓۏٕخًْٕتأۏْؽّتخًْٕتأثٓوّإؤِأڬّتهٕوْہٕهٓأۏّطًٕٓۏأتهًْٕدًْٕۄّأثٓةٕضّأتهطّٔشّتثْأ+أتهڬہلأ=أ5<أ,¾
أ““أتًشأتڲشأځتىۏأڬەأهۏەألشۏتزأڬشۏڽأحًأتىأڬۏألشۏتزأشضۏأۄًأڲۏأتضأځتىۏأضەأڬۄأډشرأزۏەأ+أڬہًهحەأۄًةەأ,أزہتحأڬۏأغشذأۄەأڬۄأتىأڬەأوىۄأثہًىأزەأڲتأڬۏتأۄۏأثشتأځۏىتأۄەأۗ‛‛أ+أحشدوۄأڬىصتهتۏوتىأ؏أتوتوأتذوزأشعتأشذوۆأتههۄأؼهۏۄأ أٰٰأۏۄأذزۏخأظذۏذأتهتضىتزأۄەأهۏڬىأتوتوأثرتشۏأشذوۆأتههۄأؼهۏۄأتًشأتوتوأوضهوأشذوۆأتههۄأؼهۏۄأىەأتضەأىمهأىۄۏڽأڬۏتأۗ%أ"
