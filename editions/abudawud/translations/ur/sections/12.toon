{"hadithnumber": "2122", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے جب ان سے نکاح کیا"}
{"hadithnumber": "2123", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم نے صفیہ رضی اللہ عنہا سے نکاح"}
{"hadithnumber": "2124", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  جب کوئی ثیبہ کے رہتے ہوئے کنواری سے شادی کرے تو اس کے ساتھ سات"}
{"hadithnumber": "2125", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  جب علی رضی اللہ عنہ نے فاطمہ رضی اللہ عنہا سے شادی کی تو"}
{"hadithnumber": "2126", "text": "محمد بن عبدالرحمٰن بن ثوبان سے روایت ہے  وہ نبی اکرم صلی اللہ علیہ وسلم کے اصحاب میں سے ایک شخص سے ر"}
{"hadithnumber": "2127", "text": "اس سند سے ابن عباس رضی اللہ عنہما سے بھی  اسی کے مثل مروی ہے۔"}
{"hadithnumber": "2128", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مجھے ایک عورت کو اس کے"}
{"hadithnumber": "2129", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس عور"}
{"hadithnumber": "2130", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جب کسی شخص کو شادی کی مبارکباد دیت"}
{"hadithnumber": "2131", "text": "بصرہ انصاری رضی اللہ عنہ کہتے ہیں کہ  میں نے ایک کنواری پردہ نشین عورت سے نکاح کیا، میں اس کے پاس گی"}
{"hadithnumber": "2132", "text": "سعید بن مسیب سے روایت ہے کہ  بصرہ بن اکثم نامی ایک شخص نے ایک عورت سے نکاح کیا پھر راوی نے اسی مفہوم"}
{"hadithnumber": "2133", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس کے پاس دو بیویاں ہو"}
{"hadithnumber": "2134", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم  ( اپنی بیویوں کی )  باری"}
{"hadithnumber": "2135", "text": "عروہ کہتے ہیں  ام المؤمنین عائشہ رضی اللہ عنہا نے کہا: میرے بھانجے! رسول اللہ صلی اللہ علیہ وسلم ہم"}
{"hadithnumber": "2136", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  آیت کریمہ: «ترجي من تشاء منهن وتؤوي إليك من تشاء»  آپ ا"}
{"hadithnumber": "2137", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے مرض الموت کے موقع پر"}
{"hadithnumber": "2138", "text": "ابن شہاب زہری سے روایت ہے کہ  عروہ بن زبیر رضی اللہ عنہ نے ان سے بیان کیا کہ ام المؤمنین عائشہ رضی ا"}
{"hadithnumber": "2139", "text": "عقبہ بن عامر رضی اللہ عنہ سے روایت ہے کہ  کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پورا کئے جانے"}
{"hadithnumber": "2140", "text": "قیس بن سعد رضی اللہ عنہ کہتے ہیں کہ  میں حیرہ آیا، تو دیکھا کہ لوگ اپنے سردار کو سجدہ کر رہے ہیں تو"}
{"hadithnumber": "2141", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب آدمی اپنی بیوی کو ا"}
{"hadithnumber": "2142", "text": "معاویہ بن حیدہ رضی اللہ عنہ کہتے ہیں کہ  میں نے عرض کیا: اللہ کے رسول! ہمارے اوپر ہماری بیوی کا کیا"}
{"hadithnumber": "2143", "text": "معاویہ بن حیدہ قشیری رضی اللہ عنہ کہتے کہ  میں نے عرض کیا: اللہ کے رسول! ہم اپنی عورتوں کے پاس کدھر"}
{"hadithnumber": "2144", "text": "معاویہ قشیری رضی اللہ عنہ کہتے ہیں کہ  میں رسول اللہ صلی اللہ علیہ وسلم کی خدمت میں آیا اور عرض کیا:"}
{"hadithnumber": "2145", "text": "ابوحرہ رقاشی اپنے چچا سے روایت کرتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اگر تم ان کی ناف"}
{"hadithnumber": "2146", "text": "ایاس بن عبداللہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ کی بندیوں کو نہ مارو ، چن"}
{"hadithnumber": "2147", "text": "عمر بن خطاب رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  آدمی سے اپنی بیوی ک"}
{"hadithnumber": "2148", "text": "جریر رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے  ( اجنبی عورت پر )  اچانک نظر"}
{"hadithnumber": "2149", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے علی رضی اللہ عنہ سے کہا: علی!  ( اجن"}
{"hadithnumber": "2150", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  عورت عورت سے بدن"}
{"hadithnumber": "2151", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک عورت کو دیکھا تو  ( اپنی بیوی"}
{"hadithnumber": "2152", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  میں نے  ( قرآن میں وارد لفظ )  «لمم»  ( چھوٹے گناہ )  کے"}
{"hadithnumber": "2153", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ہر انسان کے لیے زنا کا حص"}
{"hadithnumber": "2154", "text": "اس سند سے بھی ابوہریرہ رضی اللہ عنہ  نبی اکرم صلی اللہ علیہ وسلم سے یہ قصہ روایت کرتے ہیں اس میں ہے"}
{"hadithnumber": "2155", "text": "ابوسعید خدری رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے غزوہ حنین کے دن مقام اوطاس"}
{"hadithnumber": "2156", "text": "ابو الدرداء رضی اللہ عنہ سے روایت ہے کہ رسول اللہ صلی اللہ علیہ وسلم کسی غزوہ میں تھے کہ آپ کی نظر ا"}
{"hadithnumber": "2157", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہرسول اللہ صلی اللہ علیہ وسلم نے جنگ اوطاس کی قیدی عورتوں کے مت"}
{"hadithnumber": "2158", "text": "حنش صنعانی کہتے ہیں کہرویفع بن ثابت انصاری ہم میں بحیثیت خطیب کھڑے ہوئے اور کہا: سنو! میں تم سے وہی"}
{"hadithnumber": "2159", "text": "اس سند سے بھی ابن اسحاق سے یہی حدیث مروی ہے  اس میں ہے:  یہاں تک کہ وہ ایک حیض کے ذریعہ استبراء رحم"}
{"hadithnumber": "2160", "text": "عبداللہ بن عمرو بن العاص رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم میں"}
{"hadithnumber": "2161", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اگر تم میں سے ک"}
{"hadithnumber": "2162", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو شخص اپنی بیوی کی دبر"}
{"hadithnumber": "2163", "text": "محمد بن منکدر کہتے ہیں کہ  میں نے جابر رضی اللہ عنہ کو یہ کہتے ہوئے سنا کہ یہود کہتے تھے کہ اگر آدمی"}
{"hadithnumber": "2164", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  اللہ ابن عمر رضی اللہ عنہما کو بخشے ان کو «أنى شئتم» کے"}
{"hadithnumber": "2165", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  یہودیوں میں جب کوئی عورت حائضہ ہو جاتی تو اسے گھر سے نکال د"}
{"hadithnumber": "2166", "text": "خلاس بن عمرو ہجری کہتے ہیں کہ  میں نے ام المؤمنین عائشہ رضی اللہ عنہا کو کہتے ہوئے سنا: میں اور رسول"}
{"hadithnumber": "2167", "text": "عبداللہ بن شداد اپنی خالہ میمونہ بنت حارث رضی اللہ عنہا سے روایت کرتے ہیں کہ  رسول اللہ صلی اللہ علی"}
{"hadithnumber": "2168", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے اس شخص کے بارے میں جو"}
{"hadithnumber": "2169", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  اگر دوران خون صحبت کی تو ایک دینار، اور خون بند ہو جانے"}
{"hadithnumber": "2170", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے سامنے عزل ۱؎ کا ذکر کیا گیا"}
{"hadithnumber": "2171", "text": "ابوسعید خدری رضی اللہ عنہ سے روایت ہے کہ  ایک شخص نے کہا: اللہ کے رسول! میری ایک لونڈی ہے جس سے میں"}
{"hadithnumber": "2172", "text": "عبداللہ بن محیریز کہتے ہیں کہ  مسجد میں داخل ہوا تو میں نے ابو سعید خدری رضی اللہ عنہ کو دیکھا اور ا"}
{"hadithnumber": "2173", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  انصار کا ایک آدمی رسول اللہ صلی اللہ علیہ وسلم کی خدمت میں حاضر ہوا ا"}
{"hadithnumber": "2174", "text": "ابونضرہ کہتے ہیں: مجھ سے قبیلہ طفاوہ کے ایک شیخ نے بیان کیا کہ  مدینہ میں میں ایک بار ابوہریرہ رضی ا"}
