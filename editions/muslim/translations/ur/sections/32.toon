{"hadithnumber": "4656", "text": "سفیان بن اسود بن قیس سے روایت کی کہ انہوں نے جندب رضی اللہ عنہ کو یہ کہتے ہوئے سنا کہ ایک بار رسول ا"}
{"hadithnumber": "4657", "text": "زہیر نے اسود بن قیس سے حدیث بیان کی ،  انہوں نے کہا :  میں نے جندب بن سفیان رضی اللہ عنہ سے سنا ،  ک"}
{"hadithnumber": "4658", "text": "شعبہ اور سفیان  ( ثوری )  نے اسود بن قیس سے اسی سند کے ساتھ ان دونوں کی حدیث کی طرح بیان کی"}
{"hadithnumber": "4659", "text": "معمر نے زہری سے ،  انہوں نے عروہ  ( بن زبیر )  سے خبر دی کہ اسامہ بن زید رضی اللہ عنہ نے انہیں بتایا"}
{"hadithnumber": "4660", "text": "عقیل نے ابن شہاب  ( زہری )  سے اسی سند کے ساتھ اسی کے مانند روایت کی اور یہ اضافہ کیا : یہ عبداللہ"}
{"hadithnumber": "4661", "text": "حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے ،  کہا :  نبی صلی اللہ علیہ وسلم سے عرض کی گئی :   ( کیا ہ"}
{"hadithnumber": "4662", "text": "اسماعیل ابن علیہ نے کہا :  ہمیں سلیمان تیمی نے حدیث بیان کی ،  کہا :  ہمیں حضرت انس بن مالک رضی اللہ"}
{"hadithnumber": "4663", "text": "ہمیں معتمر نے کہا :  میں نے اپنے والد  ( سلیمان تیمی )  سے سنا ،  وہ کہ رہے تھے :  ہمیں حضرت انس رضی"}
{"hadithnumber": "4664", "text": "ہمیں سفیان نے عمرو سے حدیث بیان کی ،  کہا :  میں نے حضرت جابر رضی اللہ عنہ سے سنا ،  وہ کہہ رہے تھے"}
{"hadithnumber": "4665", "text": "عبدالعزیز بن صہیب نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے خی"}
{"hadithnumber": "4666", "text": "ثابت نے حضرت انس رضی اللہ عنہ سے حدیث بیان کی ،  انہوں نے کہا :  خیبر کے دن میں سواری پر حضرت ابوطلح"}
{"hadithnumber": "4667", "text": "قتادہ نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  جب رسول اللہ صلی اللہ علیہ وسل"}
{"hadithnumber": "4668", "text": "قتیبہ بن سعید اور محمد بن عباد نے  ۔  ۔  الفاظ ابن عباد کے ہیں  ۔  ۔  ہمیں حدیث بیان کی ،  ان دونوں"}
{"hadithnumber": "4669", "text": "ابوطاہر نے مجھے حدیث بیان کی ،  کہا :  ہمیں ابن وہب نے خبر دی ،  کہا :  مجھے یونس نے ابن شہاب سے خبر"}
{"hadithnumber": "4670", "text": "محمد بن جعفر نے ہمیں حدیث بیان کی ،  کہا :  ہمیں شعبہ نے ابواسحاق سے حدیث بیان کی ،  انہوں نے کہا :"}
{"hadithnumber": "4671", "text": "عبدالرحمان بن مہدی نے ہمیں حدیث بیان کی ،  کہا :  ہمیں شعبہ نے ابواسحاق سے حدیث بیان کی ،  انہوں نے"}
{"hadithnumber": "4672", "text": "حضرت سہل بن سعد رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم ہمارے پاس ت"}
{"hadithnumber": "4673", "text": "معاویہ بن قرہ نے حضرت انس بن مالک رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے روایت کی کہ"}
{"hadithnumber": "4674", "text": "شعبہ نے ہمیں قتادہ سے حدیث بیان کی ،  کہا :  ہمیں حضرت انس بن مالک رضی اللہ عنہ نے حدیث بیان کی کہ ر"}
{"hadithnumber": "4675", "text": "یحییٰ بن یحییٰ اور شیبان بن فروخ نے ہمیں حدیث بیان کی ،  یحییٰ نے کہا :  ہمیں عدالوارث نے ابوتیاح سے"}
{"hadithnumber": "4676", "text": "حماد بن سلمہ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ثابت نے حضرت انس رضی اللہ عنہ سے حدیث بیان کی کہ خن"}
{"hadithnumber": "4677", "text": "سلمہ بن الاکوعؓ سے روایت ہے میں صبح کی اذان سے پہلے نکلا او رآپ کی دو ہیلی اونٹنیاں ذی قرد میں چرتی"}
{"hadithnumber": "4678", "text": "4678. ہاشم بن قاسم، ابو عامر عقدی اور ابو علی عبید اللہ بن عبدالمجید حنفی نے عکرمہ بن عمار سے حدیث ب"}
{"hadithnumber": "4679", "text": "انس بن مالک رضی اﷲ عنہ سے روایت ہے اسی آدمی مکہ والے رسول اﷲؐ کے اوپر اترے تنعیم کے پہاڑ سے ،  وہ چا"}
{"hadithnumber": "4682", "text": "حضرت انس رضی اللہ عنہ سے روایت ہے ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم جب جنگ کرتے تو ام"}
{"hadithnumber": "4683", "text": "عبدالعزیز بن صہیب نے حضرت انس رضی اللہ عنہ سے حدیث بیان کی ،  انہوں نے کہا :  جب اُحد کا دن تھا ،  ل"}
{"hadithnumber": "4684", "text": "سلیمان بن بلال نے ہمیں جعفر بن محمد سے ،  انہوں نے اپنے والد سے حدیث بیان کی ،  انہوں نے یزید بن ہرم"}
{"hadithnumber": "4685", "text": "ابوبکر بن ابی شیبہ اور اسحاق بن ابراہیم دونوں نے ہمیں حاتم بن اسماعیل سے حدیث بیان کی ،  انہوں نے جع"}
{"hadithnumber": "4686", "text": "ہمیں ابن ابی عمر نے حدیث بیان کی ،  کہا :  ہمیں سفیان نے اسماعیل بن امیہ سے حدیث بیان کی ،  انہوں نے"}
{"hadithnumber": "4687", "text": "عبدالرحمان بن بشر عبدی نے ہمیں یہی حدیث بیان کی ،  کہا :  ہمیں سفیان نے حدیث بیان کی ،  کہا :  ہمیں"}
{"hadithnumber": "4688", "text": "قیس بن سعد نے مجھے یزید بن ہرمز سے حدیث بیان کی ،  انہوں نے کہا :  نجدہ بن عامر نے حضرت ابن عباس رضی"}
{"hadithnumber": "4689", "text": "مختار بن صیفی نے یزید بن ہرمز سے روایت کی ،  انہوں نے کہا :  نجدہ نے حضرت ابن عباس رضی اللہ عنہ کی ط"}
{"hadithnumber": "4690", "text": "عبدالرحیم بن سلیمان نے ہمیں ہشام  ( بن حسان )  سے حدیث بیان کی ،  انہوں نے حفصہ بنت سیرین سے اور انہ"}
{"hadithnumber": "4691", "text": "یزید بن ہارون نے ہشام بن حسان سے اسی سند کے ساتھ اسی طرح حدیث بیان کی"}
{"hadithnumber": "4692", "text": "شعبہ نے ہمیں ابواسحاق سے حدیث بیان کی کہ  ( ابن زبیر رضی اللہ عنہ کی طرف سے کوفہ کے امیر )  عبداللہ"}
{"hadithnumber": "4693", "text": "زہیر نے ہمیں ابواسحاق سے حدیث بیان کی ،  انہوں نے حضرت زید بن ارقم رضی اللہ عنہ سے یہ حدیث سنی کہ رس"}
{"hadithnumber": "4694", "text": "حضرت جابر بن عبداللہ رضی اللہ عنہ نے کہا :  میں نے رسول اللہ صلی اللہ علیہ وسلم کے ساتھ انیس غزوات م"}
{"hadithnumber": "4695", "text": "ابوبکر بن ابی شیبہ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں زید بن حباب نے حدیث بیان کی ،  نیز سعید بن مح"}
{"hadithnumber": "4696", "text": "کہمس نے ابن بریدہ سے اور انہوں نے اپنے والد سے روایت کی ،  انہوں نے کہا کہ انہوں نے رسول اللہ صلی ال"}
{"hadithnumber": "4697", "text": "ہمیں محمد بن عباد نے حدیث بیان کی ،  کہا :  ہمیں حاتم بن اسماعیل نے یزید بن ابی عبید سے حدیث بیان کی"}
{"hadithnumber": "4698", "text": "قتیبہ بن سعید نے حاتم سے اسی سند کے ساتھ حدیث بیان کی ،  مگر انہوں نے دونوں جگہ سات غزوات کہے"}
{"hadithnumber": "4699", "text": "ابواسامہ نے ہمیں بریدہ بن ابی بردہ سے حدیث بیان کی ،  انہوں نے ابوبردہ سے اور انہوں نے حضرت ابو موسی"}
{"hadithnumber": "4700", "text": "نبی صلی اللہ علیہ وسلم کی زوجہ محترمہ حضرت عائشہ رضی اللہ عنہا سے روایت ہے ،  انہوں نے کہا :  رسول ا"}
