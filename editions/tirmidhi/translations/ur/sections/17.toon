{"hadithnumber": "1423", "text": "علی رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تین طرح کے لوگ مرفوع القلم"}
{"hadithnumber": "1424", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جہاں تک تم سے"}
{"hadithnumber": "1424", "text": "ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جہاں تک تم سے"}
{"hadithnumber": "1425", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے کسی مومن سے دنیا ک"}
{"hadithnumber": "1425", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس نے کسی مومن سے دنیا ک"}
{"hadithnumber": "1426", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مسلمان مسلمان"}
{"hadithnumber": "1427", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ماعز بن مالک رضی الله"}
{"hadithnumber": "1428", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  ماعز اسلمی رضی الله عنہ نے رسول اللہ صلی اللہ علیہ وسلم کے پاس آ"}
{"hadithnumber": "1429", "text": "جابر بن عبداللہ رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کی خدمت میں قبیلہ اسلم کے"}
{"hadithnumber": "1430", "text": "ام المؤمنین عائشہ رضی الله عنہا سے روایت ہے کہ  قریش قبیلہ بنو مخزوم کی ایک عورت ۱؎ کے معاملے میں جس"}
{"hadithnumber": "1431", "text": "عمر بن خطاب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے رجم کیا، ابوبکر رضی الله عنہ ن"}
{"hadithnumber": "1432", "text": "عمر بن خطاب رضی الله عنہ کہتے ہیں کہ  اللہ نے محمد صلی اللہ علیہ وسلم کو حق کے ساتھ مبعوث فرمایا، او"}
{"hadithnumber": "1433", "text": "ابوہریرہ، زید بن خالد اور شبل رضی الله عنہم سے روایت ہے کہ  یہ لوگ نبی اکرم صلی اللہ علیہ وسلم کے پا"}
{"hadithnumber": "1433", "text": "ابوہریرہ، زید بن خالد اور شبل رضی الله عنہم سے روایت ہے کہ  یہ لوگ نبی اکرم صلی اللہ علیہ وسلم کے پا"}
{"hadithnumber": "1433", "text": "ابوہریرہ، زید بن خالد اور شبل رضی الله عنہم سے روایت ہے کہ  یہ لوگ نبی اکرم صلی اللہ علیہ وسلم کے پا"}
{"hadithnumber": "1434", "text": "عبادہ بن صامت رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ” ( دین خاص طور پر ز"}
{"hadithnumber": "1435", "text": "عمران بن حصین رضی الله عنہ کہتے ہیں کہ  قبیلہ جہینہ کی ایک عورت نے نبی اکرم صلی اللہ علیہ وسلم کے پا"}
{"hadithnumber": "1436", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک یہودی مرد اور ایک یہو"}
{"hadithnumber": "1437", "text": "جابر بن سمرہ رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک یہودی مرد اور ایک یہودی"}
{"hadithnumber": "1438", "text": "عبداللہ بن عمر رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے  ( غیر شادی شدہ زانی او"}
{"hadithnumber": "1439", "text": "عبادہ بن صامت رضی الله عنہ کہتے ہیں کہ  ہم لوگ نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک مجلس میں موجود"}
{"hadithnumber": "1440", "text": "ابوہریرہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب تم میں سے کسی کی لونڈ"}
{"hadithnumber": "1441", "text": "ابوعبدالرحمٰن سلمی کہتے ہیں کہ  علی رضی الله عنہ نے خطبہ کے دوران کہا: لوگو! اپنے غلاموں اور لونڈیوں"}
{"hadithnumber": "1442", "text": "ابو سعید خدری رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے حد قائم کرتے ہوئے چالیس ج"}
{"hadithnumber": "1443", "text": "انس رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس ایک ایسا آدمی لایا گیا جس نے شر"}
{"hadithnumber": "1444", "text": "معاویہ رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جو شراب پئیے اسے کوڑے لگاو"}
{"hadithnumber": "1445", "text": "ام المؤمنین عائشہ رضی الله عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم چوتھائی دینار ۱؎ اور اس"}
{"hadithnumber": "1446", "text": "عبداللہ بن عمر رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ایک ڈھال کی چوری پر ہاتھ"}
{"hadithnumber": "1447", "text": "عبدالرحمٰن بن محیریز کہتے ہیں کہ  میں نے فضالہ بن عبید سے پوچھا: کیا چور کا ہاتھ کاٹنے کے بعد اس کی"}
{"hadithnumber": "1448", "text": "جابر رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”خیانت کرنے والے، ڈاکو اور"}
{"hadithnumber": "1449", "text": "رافع بن خدیج رضی الله عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا: ”پھل"}
{"hadithnumber": "1450", "text": "بسر بن ارطاۃ رضی الله عنہ کہتے ہیں کہ  میں نے نبی اکرم صلی اللہ علیہ وسلم کو فرماتے سنا: ”جنگ کے دور"}
{"hadithnumber": "1451", "text": "حبیب بن سالم کہتے ہیں کہ  نعمان بن بشیر رضی الله عنہما کے پاس ایک ایسے شخص کا مقدمہ پیش ہوا جس نے اپ"}
{"hadithnumber": "1452", "text": "اس سند سے بھی  نعمان بن بشیر سے اسی جیسی حدیث آئی ہے۔ قتادہ کہتے ہیں کہ انہوں نے کہا: حبیب بن سالم"}
{"hadithnumber": "1453", "text": "وائل بن حجر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ایک عورت کے ساتھ زبر"}
{"hadithnumber": "1454", "text": "وائل بن حجر کندی رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ایک عورت نما"}
{"hadithnumber": "1455", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس آدمی کو جان"}
{"hadithnumber": "1456", "text": "عبداللہ بن عباس رضی الله عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”تم لوگ جسے قوم"}
{"hadithnumber": "1457", "text": "جابر رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”مجھے اپنی امت کے بارے میں جس"}
{"hadithnumber": "1458", "text": "عکرمہ سے روایت ہے کہ  علی رضی الله عنہ نے کچھ ایسے لوگوں کو زندہ جلا دیا جو اسلام سے مرتد ہو گئے تھے"}
{"hadithnumber": "1459", "text": "ابوموسیٰ اشعری رضی الله عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جو ہمارے خلاف ہت"}
{"hadithnumber": "1460", "text": "جندب رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جادوگر کی سزا تلوار سے گردن"}
{"hadithnumber": "1461", "text": "عمر رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جس شخص کو اللہ کی راہ میں"}
{"hadithnumber": "1462", "text": "عبداللہ بن عباس رضی الله عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: ”جب کوئی آدمی"}
{"hadithnumber": "1463", "text": "ابوبردہ بن نیار رضی الله عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم فرمایا: ”دس سے زیادہ کسی کو ک"}
