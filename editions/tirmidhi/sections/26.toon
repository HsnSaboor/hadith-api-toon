hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
1884.2,حَدَّثَنَا قُتَيْبَةُ، وَيُوسُفُ بْنُ حَمَّادٍ، قَالَا:‏‏‏‏ حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيد,,"Book 26, Hadith 25",1884,,The Book on Drinks
1861,حَدَّثَنَا أَبُو زَكَرِيَّا يَحْيَى بْنُ دُرُسْتَ الْبَصْرِيُّ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَن,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأشربة ۱ (۵۵۷۵)، (الشطر الأخیر)، صحیح مسلم/الأشربة ۸ (۲۰۰۳)، سنن ابی داود/ الأشربة ۵ (۳۶۷۹)، سنن النسائی/الأشربة ۲۲ (۵۵۸۵)، ۵۵۸۷، ۵۵۸۹)، (الشطر الأول) و ۴۵ (۵۶۷۴)، (الشطر الأخیر) و ۴۶ (۵۶۷۶، ۵۶۷۷)، (الشطر الأخیر)، سنن ابن ماجہ/الأشربة ۲ (۳۳۷۳)، (الشطر الأخیر و۹ (۳۶۸۷)، (الشطر الأول)، (تحفة الأشراف : ۷۵۱۶)، و مسند احمد (۲/۱۶، ۱۹، ۲۲، ۲۸، ۲۹، ۳۱، ۹۱، ۴۹۸),1861,,The Book on Drinks
1862,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا جَرِيرُ بْنُ عَبْدِ الْحَمِيدِ، عَنْ عَطَاءِ بْنِ السَّائِبِ، عَنْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۷۳۱۸),1862,,The Book on Drinks
1863,حَدَّثَنَا إِسْحَاق بْنُ مُوسَى الْأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الوضوء ۷۱ (۲۴۲)، والأشربة ۴ (۵۵۸۵)، صحیح مسلم/الأشربة ۷ (۲۰۰۱)، سنن ابی داود/ الأشربة ۵ (۳۶۸۲)، سنن النسائی/الأشربة ۲۳ (۵۵۹۷)، سنن ابن ماجہ/الأشربة ۹ (۳۳۸۶)، (تحفة الأشراف : ۱۷۷۶۴)، وط/الأشربة ۴ (۹)، و مسند احمد (۶/۳۸، ۹۷، ۱۹۰، ۲۲۶),1863,,The Book on Drinks
1864,حَدَّثَنَا عُبَيْدُ بْنُ أَسْبَاطِ بْنِ مُحَمَّدٍ الْقُرَشِيُّ الْكُوفِيُّ، وَأَبُو سَعِيدٍ الْأَشَج,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۱۸۶۱ (تحفة الأشراف : ۸۵۸۴),1864,,The Book on Drinks
1865,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا إِسْمَاعِيل بْنُ جَعْفَرٍ. ح وحَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْ,Ahmad Muhammad Shakir: Hasan Sahih; Al-Albani: Hasan Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأشربة ۵ (۳۶۸۱)، سنن ابن ماجہ/الأشربة ۱۰ (۳۳۹۳)، (تحفة الأشراف : ۳۰۱۴)، و مسند احمد (۳/۳۴۳),1865,,The Book on Drinks
1866,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الْأَعْلَى بْنُ عَبْدِ الْأَعْلَى، عَنْ هِشَام,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأشربة ۵ (۳۶۸۷)، (تحفة الأشراف : ۱۷۵۶۵)، و مسند احمد (۶/۷۲),1866,,The Book on Drinks
1867,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا ابْنُ عُلَيَّةَ، وَيَزِيدُ بْنُ هَارُونَ، قَالَا:‏‏‏‏ أ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۶ (۱۹۹۷/۵۰)، سنن النسائی/الأشربة ۲۸ (۵۶۱۷)، (تحفة الأشراف : ۷۰۹۸)، و مسند احمد (۲/۲۹، ۳۵، ۴۷، ۵۶، ۱۰۱، ۱۵۵),1867,,The Book on Drinks
1868,حَدَّثَنَا أَبُو مُوسَى مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا أَبُو دَاوُدَ الطَّيَالِسِيُّ، حَدَّث,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۶ (۱۹۹۷/۵۷)، سنن النسائی/الأشربة ۳۷ (۵۶۴۸)، (تحفة الأشراف : ۶۷۱۶)، و مسند احمد (۲/۵۶),1868,,The Book on Drinks
1869,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَالْحَسَنُ بْنُ عَلِيٍّ، وَمَحْمُودُ بْنُ غَيْلَانَ، قَالُوا:‏‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۶ (۹۷۷/۶۴)، و (انظر أیضا: الجنائز ۳۶ (۹۷۷/۱۰۶) والأضاحي ۵ (۹۷۷/۳۷)، (تحفة الأشراف : ۱۹۳۲),1869,,The Book on Drinks
1870,حَدَّثَنَا مَحْمُودُ بْنُ غَيْلَانَ، حَدَّثَنَا أَبُو دَاوُدَ الْحَفَرِيُّ، عَنْ سُفْيَانَ، عَنْ مَن,Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأشربة ۸ (۵۵۹۲)، سنن ابی داود/ الأشربة ۷ (۳۶۹۹)، سنن النسائی/الأشربة ۴۰ (۵۶۵۹)، (تحفة الأشراف : ۲۲۴۰),1870,,The Book on Drinks
1871,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، عَنْ يُونُسَ بْنِ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۹ (۱۰۰۵)، سنن ابی داود/ الأشربة ۱۰ (۳۷۱۱)، سنن ابن ماجہ/الأشربة ۱۲ (۳۳۹۸)، (تحفة الأشراف : ۷۸۳۶),1871,,The Book on Drinks
1872,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، حَدَّثَنَا إِسْرَائِيلُ، حَدَّ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأشربة ۴ (۳۶۷۶)، سنن ابن ماجہ/الأشربة ۵ (۳۳۷۹)، (تحفة الأشراف : ۱۱۶۲۶),1872,,The Book on Drinks
1873,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ إِسْرَائِيلَ نَحْ,Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: انظر ما یأتي,1873,,The Book on Drinks
1874,حَدَّثَنَا بِذَلِكَ أَحْمَدُ بْنُ مَنِيعٍ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ أَبِي حَيَّ,Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/تفسیر سورة المائدة ۱۰ (۴۶۱۹)، والأشربة ۲ (۵۵۸۱)، و ۵ (۵۵۸۸)، صحیح مسلم/التفسیر ۶ (۳۰۳۲)، سنن ابی داود/ الأشربة ۱ (۳۶۶۹)، سنن النسائی/الأشربة ۲۰ (۵۵۸۱)، (تحفة الأشراف : ۱۰۵۳۸),1874,,The Book on Drinks
1875,حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، حَدَّثَنَا الْأَوْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۴ (۱۹۸۵)، سنن ابی داود/ الأشربة ۴ (۳۶۷۸)، سنن النسائی/الأشربة ۱۹ (۵۵۷۵)، سنن ابن ماجہ/الأشربة ۵ (۳۳۷۸)، (تحفة الأشراف : ۱۴۸۴۱)، و مسند احمد (۲/۲۷۹، ۴۰۸، ۴۰۹، ۴۹۶، ۵۱۸، ۵۲۶)، سنن الدارمی/الأشربة ۷ (۲۱۴۱),1875,,The Book on Drinks
1876,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ عَطَاءِ بْنِ أَبِي رَبَاحٍ، عَنْ جَابِ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأشربة (۵۶۰۱)، صحیح مسلم/الأشربة ۵ (۱۹۸۶)، سنن ابی داود/ الأشربة ۸ (۳۷۰۳)، سنن النسائی/الأشربة ۸ (۵۵۶۲)، سنن ابن ماجہ/الأشربة ۱۱ (۳۳۹۵)، (تحفة الأشراف : ۲۴۷۸)، و مسند احمد (۳/۲۹۴، ۳۰۰، ۳۰۲، ۳۱۷، ۳۶۳، ۳۶۹),1876,,The Book on Drinks
1877,حَدَّثَنَا سُفْيَانُ بْنُ وَكِيعٍ، حَدَّثَنَا جَرِيرٌ، عَنْ سُلَيْمَانَ التَّيْمِيِّ، عَنْ أَبِي نَض,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۵ (۱۹۸۷)، سنن النسائی/الأشربة ۱۶ (۵۵۷۱)، (تحفة الأشراف : ۴۳۵۱)، و مسند احمد (۳/۳، ۹، ۴۹، ۶۲، ۷۱، ۹۰) سنن الدارمی/الأشربة ۱۴ (۱۲۵۷),1877,,The Book on Drinks
1878,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ ال,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأطعمة ۲۹ (۵۴۲۶)، والأشربة ۲۷ (۵۶۳۲)، و ۲۸ (۵۶۳۳)، واللباس ۲۵ (۵۸۳۱)، و ۲۷ (۵۸۳۷)، صحیح مسلم/اللباس ۱ (۲۰۶۷)، سنن ابی داود/ الأشربة ۱۷ (۳۷۲۳)، سنن النسائی/الزینة ۳۳ (۵۳۰۳)، سنن ابن ماجہ/الأشربة ۱۷ (۳۴۱۴)، (تحفة الأشراف : ۳۳۷۳)، و مسند احمد (۵/۳۸۵، ۳۹۰، ۳۹۶، ۳۹۸، ۴۰۰، ۴۰۸),1878,,The Book on Drinks
1879,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنْ سَعِيدِ بْنِ أَبِي عَرُوبَة,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۱۴ (۲۰۲۴)، سنن ابی داود/ الأشربة ۱۳ (۳۷۱۷)، سنن ابن ماجہ/الأشربة ۲۱ (۳۴۲۴)، (تحفة الأشراف : ۱۱۸۰)، و مسند احمد (۳/۱۱۸، ۱۸۲، ۲۷۷) سنن الدارمی/الأشربة ۲۴ (۲۱۷۳),1879,,The Book on Drinks
1880,حَدَّثَنَا أَبُو السَّائِبِ سَلْمُ بْنُ جُنَادَةَ الْكُوفِيُّ، حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، عَنْ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأطعمة ۲۵ (۳۳۰۱)، (تحفة الأشراف : ۷۸۲۱),1880,,The Book on Drinks
1881,حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، عَنْ سَعِيدٍ، عَنْ قَتَادَة,Ahmad Muhammad Shakir: Sahih Lighairihi; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۳۱۷۷),1881,,The Book on Drinks
1882,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا هُشَيْمٌ، حَدَّثَنَا عَاصِمٌ الْأَحْوَلُ، وَمُغِيرَةُ،,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الحج ۷۶ (۱۶۳۷)، والأشربة ۶ (۵۶۱۷)، صحیح مسلم/الأشربة ۱۵ (۲۰۲۷)، سنن النسائی/الحج ۶۵ (۲۹۶۷)، و ۶۶ (۲۹۶۸)، سنن ابن ماجہ/الأشربة ۲۱ (۳۴۲۲)، والمؤلف في الشمائل ۳۱ (۱۹۷، ۱۹۸، ۱۹۹)، (تحفة الأشراف : ۵۷۶۷)، و مسند احمد (۱/۲۱۴، ۲۲۰، ۳۴۲),1882,,The Book on Drinks
1883,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، عَنْ حُسَيْنٍ الْمُعَلِّمِ، عَنْ عَمْرِو,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۸۶۸۹),1883,,The Book on Drinks
1884,حَدَّثَنَا قُتَيْبَةُ، وَيُوسُفُ بْنُ حَمَّادٍ، قَالَا:‏‏‏‏ حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيد,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأشربة ۱۶ (۲۰۲۸/۱۲۳)، سنن ابی داود/ الأشربة ۱۹ (۳۷۲۷) (تحفة الأشراف : ۱۷۲۳)، و مسند احمد (۳/۱۱۹، ۱۸۵، ۲۱۱),1884,,The Book on Drinks
1885,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا وَكِيعٌ، عَنْ يَزِيدَ بْنِ سِنَانٍ الْجَزَرِيِّ، عَنْ ابْنٍ لِ,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۵۹۷۱),1885,,The Book on Drinks
1886,حَدَّثَنَا عَلِيُّ بْنُ خَشْرَمٍ، حَدَّثَنَا عِيسَى بْنُ يُونُسَ، عَنْ رِشْدِينَ بْنِ كُرَيْبٍ، عَنْ,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأشربة ۱۸ (۳۴۱۷)، (تحفة الأشراف : ۶۳۴۷),1886,,The Book on Drinks
1887,حَدَّثَنَا عَلِيُّ بْنُ خَشْرَمٍ، أَخْبَرَنَا عِيسَى بْنُ يُونُسَ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ أَ,Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۴۴۳۶),1887,,The Book on Drinks
1888,حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الْكَرِيمِ الْجَزَر,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأشربة ۲۰ (۳۷۲۸)، سنن ابن ماجہ/الأشربة ۲۳ (۳۴۲۸)، (تحفة الأشراف : ۶۱۴۹)، سنن الدارمی/الأشربة ۲۷ (۲۱۸۰),1888,,The Book on Drinks
1889,حَدَّثَنَا إِسْحَاق بْنُ مَنْصُورٍ، حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، حَدَّثَنَا ه,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الوضوء ۱۸ (۱۵۳)، و ۱۹ (۱۵۴)، والأشربة ۲۵ (۵۶۳۰)، صحیح مسلم/الطہارة ۱۸ (۲۶۷)، سنن ابی داود/ الطہارة ۱۸ (۳۱)، (تحفة الأشراف : ۱۲۱۰۵)، و مسند احمد (۵/۲۹۵، ۲۹۶، ۳۰۰، ۳۰۹، ۳۱۰),1889,,The Book on Drinks
1890,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا سُفْيَانُ، عَنْ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ ال,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأشربة ۲۳ (۵۶۲۴)، صحیح مسلم/الأشربة (۲۰۲۳)، سنن ابی داود/ الأشربة ۱۵ (۳۷۲۰)، سنن ابن ماجہ/الأشربة ۱۹ (۳۴۱۸)، (تحفة الأشراف : ۴۱۳۸)، و مسند احمد (۳/۶، ۶۷، ۶۹، ۹۳),1890,,The Book on Drinks
1891,حَدَّثَنَا يَحْيَى بْنُ مُوسَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ عُمَر,Ahmad Muhammad Shakir: Munkar; Al-Albani: Daif; Bashar Awad Maarouf: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأشربة ۱۵ (۳۷۲۱)، (تحفة الأشراف : ۵۱۴۹),1891,,The Book on Drinks
1892,حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنْ يَزِيدَ بْنِ جَابِرٍ، عَنْ عَبْدِ الرَّحْم,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأشربة ۲۱ (۳۴۲۳)، (تحفة الأشراف : ۱۸۰۴۹)، و مسند احمد (۶/۴۳۴),1892,,The Book on Drinks
1893,حَدَّثَنَا الْأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، قَالَ:‏‏‏‏ وحَدَّثَنَا قُتَيْبَةُ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأشربة ۱۴ (۵۶۱۳)، و ۱۸ (۵۷۱۹) والشرب ۱ (۲۳۵۲)، والہبة ۴ (۲۵۷۱)، صحیح مسلم/الأشربة ۱۷ (۲۰۲۹)، سنن ابی داود/ الأشربة ۱۹ (۳۷۲۶)، سنن ابن ماجہ/الأشربة ۲۲ (۳۴۲۵)، (تحفة الأشراف : ۱۵۷۴)، و موطا امام مالک/صفة النبي ﷺ ۹ (۱۷)، و مسند احمد (۳/۱۱۰، ۱۱۳، ۱۹۷)، سنن الدارمی/الأشربة ۱۸ (۲۱۶۲),1893,,The Book on Drinks
1894,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ ثَابِتٍ الْبُنَانِيِّ، عَنْ عَبْدِ اللّ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/المساجد ۵۵ (۶۸۱)، (في سیاق طویل) سنن ابن ماجہ/الأشربة ۲۶ (۳۴۳۴)، (تحفة الأشراف : ۱۲۰۸۶)، و مسند احمد (۵/۳۰۳),1894,,The Book on Drinks
1895,حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ مَعْمَرٍ، عَنْ الزُّهْرِيّ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (أخربہ النسائي في الکبریٰ) (تحفة الأشراف : ۱۶۶۴۸),1895,,The Book on Drinks
1896,حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، أَخْبَرَنَا مَعْمَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۹۳۹۴ و ۱۹۴۱۴),1896,,The Book on Drinks
1926,"حَدَّثَنَا أَبُو زَكَرِيَّا، يَحْيَى بْنُ دُرُسْتَ الْبَصْرِيُّ حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ أَيُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ كُلُّ مُسْكِرٍ خَمْرٌ وَكُلُّ مُسْكِرٍ حَرَامٌ وَمَنْ شَرِبَ الْخَمْرَ فِي الدُّنْيَا فَمَاتَ وَهُوَ يُدْمِنُهَا لَمْ يَشْرَبْهَا فِي الآخِرَةِ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَبِي هُرَيْرَةَ وَأَبِي سَعِيدٍ وَعَبْدِ اللَّهِ بْنِ عَمْرٍو وَابْنِ عَبَّاسٍ وَعُبَادَةَ وَأَبِي مَالِكٍ الأَشْعَرِيِّ ‏.‏ قَالَ أَبُو عِيسَى حَدِيثُ ابْنِ عُمَرَ حَدِيثٌ حَسَنٌ صَحِيحٌ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ عَنْ نَافِعٍ عَنِ ابْنِ عُمَرَ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ وَرَوَاهُ مَالِكُ بْنُ أَنَسٍ عَنْ نَافِعٍ عَنِ ابْنِ عُمَرَ مَوْقُوفًا فَلَمْ يَرْفَعْهُ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۲۸۶۳),,Narrated Ibn 'Umar:,The Book on Drinks
1927,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا جَرِيرُ بْنُ عَبْدِ الْحَمِيدِ، عَنْ عَطَاءِ بْنِ السَّائِبِ، عَنْ عَبْدِ اللَّهِ بْنِ عُبَيْدِ بْنِ عُمَيْرٍ، عَنْ أَبِيهِ، قَالَ قَالَ عَبْدُ اللَّهِ بْنُ عُمَرَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ شَرِبَ الْخَمْرَ لَمْ يَقْبَلِ اللَّهُ لَهُ صَلاَةً أَرْبَعِينَ صَبَاحًا فَإِنْ تَابَ تَابَ اللَّهُ عَلَيْهِ فَإِنْ عَادَ لَمْ يَقْبَلِ اللَّهُ لَهُ صَلاَةً أَرْبَعِينَ صَبَاحًا فَإِنْ تَابَ تَابَ اللَّهُ عَلَيْهِ فَإِنْ عَادَ لَمْ يَقْبَلِ اللَّهُ لَهُ صَلاَةً أَرْبَعِينَ صَبَاحًا فَإِنْ تَابَ تَابَ اللَّهُ عَلَيْهِ فَإِنْ عَادَ الرَّابِعَةَ لَمْ يَقْبَلِ اللَّهُ لَهُ صَلاَةً أَرْبَعِينَ صَبَاحًا فَإِنْ تَابَ لَمْ يَتُبِ اللَّهُ عَلَيْهِ وَسَقَاهُ مِنْ نَهْرِ الْخَبَالِ ‏""""‏ ‏.‏ قِيلَ يَا أَبَا عَبْدِ الرَّحْمَنِ وَمَا نَهْرُ الْخَبَالِ قَالَ نَهْرٌ مِنْ صَدِيدِ أَهْلِ النَّارِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ وَقَدْ رُوِيَ نَحْوُ هَذَا عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو وَابْنِ عَبَّاسٍ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: صحیح مسلم/البر والصلة ۱۰ (۲۵۶۴)، سنن ابن ماجہ/الزہد ۲۳ (۴۲۱۳) (تحفة الأشراف : ۱۲۳۱۹),,Narrated 'Abdullah bin 'Umar:,The Book on Drinks
1928,"حَدَّثَنَا إِسْحَاقُ بْنُ مُوسَى الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنِ ابْنِ شِهَابٍ، عَنْ أَبِي سَلَمَةَ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم سُئِلَ عَنِ الْبِتْعِ فَقَالَ ‏ ‏ كُلُّ شَرَابٍ أَسْكَرَ فَهُوَ حَرَامٌ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الصلاة ۸۸ (۴۸۱)، والمظالم ۵ (۲۴۴۶)، والأدب ۲۶ (۶۰۲۶)، صحیح مسلم/البر والصلة ۱۷ (۲۵۸۵)، سنن النسائی/الزکاة ۶۷ (۲۵۶۱) (تحفة الأشراف : ۹۰۴۰)، و مسند احمد (۴/۳۹۴),,Narrated 'Aishah:,The Book on Drinks
1929,"حَدَّثَنَا عُبَيْدُ بْنُ أَسْبَاطِ بْنِ مُحَمَّدٍ الْقُرَشِيُّ الْكُوفِيُّ، وَأَبُو سَعِيدٍ الأَشَجُّ قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي سَلَمَةَ، عَنِ ابْنِ عُمَرَ، قَالَ سَمِعْتُ النَّبِيَّ صلى الله عليه وسلم يَقُولُ ‏ ‏ كُلُّ مُسْكِرٍ حَرَامٌ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عُمَرَ وَعَلِيٍّ وَابْنِ مَسْعُودٍ وَأَنَسٍ وَأَبِي سَعِيدٍ وَأَبِي مُوسَى وَالأَشَجِّ الْعَصَرِيِّ وَدَيْلَمَ وَمَيْمُونَةَ وَابْنِ عَبَّاسٍ وَقَيْسِ بْنِ سَعْدٍ وَالنُّعْمَانِ بْنِ بَشِيرٍ وَمُعَاوِيَةَ وَوَائِلِ بْنِ حُجْرٍ وَقُرَّةَ الْمُزَنِيِّ وَعَبْدِ اللَّهِ بْنِ مُغَفَّلٍ وَأُمِّ سَلَمَةَ وَبُرَيْدَةَ وَأَبِي هُرَيْرَةَ وَعَائِشَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ ‏.‏ وَقَدْ رُوِيَ عَنْ أَبِي سَلَمَةَ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ وَكِلاَهُمَا صَحِيحٌ رَوَاهُ غَيْرُ وَاحِدٍ عَنْ مُحَمَّدِ بْنِ عَمْرٍو عَنْ أَبِي سَلَمَةَ عَنْ أَبِي هُرَيْرَةَ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ وَعَنْ أَبِي سَلَمَةَ عَنِ ابْنِ عُمَرَ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏""",Ahmad Muhammad Shakir: Very Daif; Al-Albani: Very Daif; Bashar Awad Maarouf: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۴۱۲۱),,Narrated Ibn 'Umar:,The Book on Drinks
1930,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ جَعْفَرٍ، وَحَدَّثَنَا عَلِيُّ بْنُ حُجْرٍ، أَخْبَرَنَا إِسْمَاعِيلُ بْنُ جَعْفَرٍ، عَنْ دَاوُدَ بْنِ بَكْرِ بْنِ أَبِي الْفُرَاتِ، عَنِ ابْنِ الْمُنْكَدِرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَا أَسْكَرَ كَثِيرُهُ فَقَلِيلُهُ حَرَامٌ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ سَعْدٍ وَعَائِشَةَ وَعَبْدِ اللَّهِ بْنِ عَمْرٍو وَابْنِ عُمَرَ وَخَوَّاتِ بْنِ جُبَيْرٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ مِنْ حَدِيثِ جَابِرٍ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم ۱۴۲۵,,Narrated Jabir bin ‘Abdullah :,The Book on Drinks
1931,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا عَبْدُ الأَعْلَى بْنُ عَبْدِ الأَعْلَى، عَنْ هِشَامِ بْنِ حَسَّانَ، عَنْ مَهْدِيِّ بْنِ مَيْمُونٍ، ح وَحَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُعَاوِيَةَ الْجُمَحِيُّ، حَدَّثَنَا مَهْدِيُّ بْنُ مَيْمُونٍ الْمَعْنَى، وَاحِدٌ، عَنْ أَبِي عُثْمَانَ الأَنْصَارِيِّ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ كُلُّ مُسْكِرٍ حَرَامٌ مَا أَسْكَرَ الْفَرَقُ مِنْهُ فَمِلْءُ الْكَفِّ مِنْهُ حَرَامٌ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى قَالَ أَحَدُهُمَا فِي حَدِيثِهِ ‏""‏ الْحُسْوَةُ مِنْهُ حَرَامٌ ‏""‏ ‏.‏ قَالَ هَذَا حَدِيثٌ حَسَنٌ ‏.‏ وَقَدْ رَوَاهُ لَيْثُ بْنُ أَبِي سُلَيْمٍ وَالرَّبِيعُ بْنُ صَبِيحٍ عَنْ أَبِي عُثْمَانَ الأَنْصَارِيِّ نَحْوَ رِوَايَةِ مَهْدِيِّ بْنِ مَيْمُونٍ ‏.‏ وَأَبُو عُثْمَانَ الأَنْصَارِيُّ اسْمُهُ عَمْرُو بْنُ سَالِمٍ وَيُقَالُ عُمَرُ بْنُ سَالِمٍ أَيْضًا ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۰۹۹۵) (وانظر حم: ۶/۴۴۹، ۴۵۰),1931,Narrated 'Aishah:,The Book on Drinks
1932,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا ابْنُ عُلَيَّةَ، وَيَزِيدُ بْنُ هَارُونَ، قَالاَ أَخْبَرَنَا سُلَيْمَانُ التَّيْمِيُّ، عَنْ طَاوُسٍ، أَنَّ رَجُلاً، أَتَى ابْنَ عُمَرَ فَقَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنْ نَبِيذِ الْجَرِّ فَقَالَ نَعَمْ ‏.‏ فَقَالَ طَاوُسٌ وَاللَّهِ إِنِّي سَمِعْتُهُ مِنْهُ ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ أَبِي أَوْفَى وَأَبِي سَعِيدٍ وَسُوَيْدٍ وَعَائِشَةَ وَابْنِ الزُّبَيْرِ وَابْنِ عَبَّاسٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأدب ۶۲ (۶۰۷۷)، والإستئذان ۹ (۶۲۳۷)، صحیح مسلم/البر والصلة ۸ (۲۵۶۰) (تحفة الأشراف : ۳۴۷۹),1932,Narrated Sulaiman At-Taimi:,The Book on Drinks
1933,حَدَّثَنَا أَبُو مُوسَى، مُحَمَّدُ بْنُ الْمُثَنَّى حَدَّثَنَا أَبُو دَاوُدَ الطَّيَالِسِيُّ، حَدَّثَنَا شُعْبَةُ، عَنْ عَمْرِو بْنِ مُرَّةَ، قَالَ سَمِعْتُ زَاذَانَ، يَقُولُ سَأَلْتُ ابْنَ عُمَرَ عَمَّا نَهَى عَنْهُ رَسُولُ اللَّهِ صلى الله عليه وسلم مِنَ الأَوْعِيَةِ أَخْبِرْنَاهُ بِلُغَتِكُمْ وَفَسِّرْهُ لَنَا بِلُغَتِنَا ‏.‏ فَقَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الْحَنْتَمَةِ وَهِيَ الْجَرَّةُ وَنَهَى عَنِ الدُّبَّاءِ وَهِيَ الْقَرْعَةُ وَنَهَى عَنِ النَّقِيرِ وَهُوَ أَصْلُ النَّخْلِ يُنْقَرُ نَقْرًا أَوْ يُنْسَحُ نَسْحًا وَنَهَى عَنِ الْمُزَفَّتِ وَهِيَ الْمُقَيَّرُ وَأَمَرَ أَنْ يُنْبَذَ فِي الأَسْقِيَةِ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عُمَرَ وَعَلِيٍّ وَابْنِ عَبَّاسٍ وَأَبِي سَعِيدٍ وَأَبِي هُرَيْرَةَ وَعَبْدِ الرَّحْمَنِ بْنِ يَعْمُرَ وَسَمُرَةَ وَأَنَسٍ وَعَائِشَةَ وَعِمْرَانَ بْنِ حُصَيْنٍ وَعَائِذِ بْنِ عَمْرٍو وَالْحَكَمِ الْغِفَارِيِّ وَمَيْمُونَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/البیوع ۱ (۲۰۴۹)، والکفالة ۲ (۲۲۹۳)، مناقب الأنصار ۳ (۳۷۸۱)، و ۵۰ (۳۹۳۷)، والنکاح ۶۸ (۵۱۶۷)، والأدب ۶۷ (۶۰۸۲) (تحفة الأشراف : ۵۷۱)، و مسند احمد (۳/۱۹۰، ۲۰۴، ۲۷۱),1933,Narrated Zadhan:,The Book on Drinks
1934,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَالْحَسَنُ بْنُ عَلِيٍّ، وَمَحْمُودُ بْنُ غَيْلاَنَ، قَالُوا حَدَّثَنَا أَبُو عَاصِمٍ، حَدَّثَنَا سُفْيَانُ، عَنْ عَلْقَمَةَ بْنِ مَرْثَدٍ، عَنْ سُلَيْمَانَ بْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنِّي كُنْتُ نَهَيْتُكُمْ عَنِ الظُّرُوفِ وَإِنَّ ظَرْفًا لاَ يُحِلُّ شَيْئًا وَلاَ يُحَرِّمُهُ وَكُلُّ مُسْكِرٍ حَرَامٌ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/البر والصلة ۲۰ (۲۵۸۹)، سنن ابی داود/ الأدب ۴۰ (۴۸۷۴) (تحفة الأشراف : ۱۴۰۵۴)، و مسند احمد (۲/۲۳۰، ۴۵۸)، سنن الدارمی/الرقاق ۶ (۲۷۵۶),,Narrated Sulaiman bin Buraidah:,The Book on Drinks
1935,"حَدَّثَنَا مَحْمُودُ بْنُ غَيْلاَنَ، حَدَّثَنَا أَبُو دَاوُدَ الْحَفَرِيُّ، عَنْ سُفْيَانَ، عَنْ مَنْصُورٍ، عَنْ سَالِمِ بْنِ أَبِي الْجَعْدِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، قَالَ نَهَى رَسُولُ اللَّهِ صلى الله عليه وسلم عَنِ الظُّرُوفِ فَشَكَتْ إِلَيْهِ الأَنْصَارُ فَقَالُوا لَيْسَ لَنَا وِعَاءٌ ‏.‏ قَالَ ‏ ‏ فَلاَ إِذًا ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ مَسْعُودٍ وَأَبِي سَعِيدٍ وَأَبِي هُرَيْرَةَ وَعَبْدِ اللَّهِ بْنِ عَمْرٍو ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأدب ۵۷ (۶۰۶۵)، ۶۲ (۶۰۷۶)، صحیح مسلم/البر والصلة ۷ (۲۵۵۹)، سنن ابی داود/ الأدب ۵۵ (۴۹۱۰) (تحفة الأشراف : ۱۴۸۸)، و مسند احمد (۳/۱۹۹),,Narrated Jabir bin ‘Abdullah :,The Book on Drinks
1936,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، عَنْ يُونُسَ بْنِ عُبَيْدٍ، عَنِ الْحَسَنِ الْبَصْرِيِّ، عَنْ أُمِّهِ، عَنْ عَائِشَةَ، قَالَتْ كُنَّا نَنْبِذُ لِرَسُولِ اللَّهِ صلى الله عليه وسلم فِي سِقَاءٍ يُوكَأُ فِي أَعْلاَهُ لَهُ عَزْلاَءُ نَنْبِذُهُ غُدْوَةً وَيَشْرَبُهُ عِشَاءً وَنَنْبِذُهُ عِشَاءً وَيَشْرَبُهُ غُدْوَةً ‏.‏ قَالَ وَفِي الْبَابِ عَنْ جَابِرٍ وَأَبِي سَعِيدٍ وَابْنِ عَبَّاسٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ لاَ نَعْرِفُهُ مِنْ حَدِيثِ يُونُسَ بْنِ عُبَيْدٍ إِلاَّ مِنْ هَذَا الْوَجْهِ وَقَدْ رُوِيَ هَذَا الْحَدِيثُ مِنْ غَيْرِ هَذَا الْوَجْهِ عَنْ عَائِشَةَ أَيْضًا ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Bukhari And Muslim,takhreej: تخریج دارالدعوہ: صحیح البخاری/التوحید ۴۵ (۷۵۲۹)، صحیح مسلم/ صلاة المسافرین ۴۷ (۸۱۵)، سنن ابن ماجہ/الزہد ۲۲ (۴۲۰۹) (تحفة الأشراف : ۶۸۱۵)، و مسند احمد (۲/۹، ۳۶، ۸۸، ۱۳۳، ۱۵۲),1936,Narrated 'Aishah:,The Book on Drinks
1937,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ، حَدَّثَنَا إِسْرَائِيلُ، حَدَّثَنَا إِبْرَاهِيمُ بْنُ مُهَاجِرٍ، عَنْ عَامِرٍ الشَّعْبِيِّ، عَنِ النُّعْمَانِ بْنِ بَشِيرٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّ مِنَ الْحِنْطَةِ خَمْرًا وَمِنَ الشَّعِيرِ خَمْرًا وَمِنَ التَّمْرِ خَمْرًا وَمِنَ الزَّبِيبِ خَمْرًا وَمِنَ الْعَسَلِ خَمْرًا ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَبِي هُرَيْرَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/المنافقین ۱۶ (۲۸۱۲) (تحفة الأشراف : ۲۳۰۲)، و مسند احمد (۳/۳۱۳، ۳۵۴، ۳۶۶، ۳۸۴),,Narrated An-Nu'man bin Bashir:,The Book on Drinks
1938,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا يَحْيَى بْنُ آدَمَ، عَنْ إِسْرَائِيلَ، نَحْوَهُ ‏.‏ وَرَوَى أَبُو حَيَّانَ التَّيْمِيُّ، هَذَا الْحَدِيثَ عَنِ الشَّعْبِيِّ، عَنِ ابْنِ عُمَرَ، عَنْ عُمَرَ، قَالَ إِنَّ مِنَ الْحِنْطَةِ خَمْرًا فَذَكَرَ هَذَا الْحَدِيثَ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الصلح ۲ (۲۶۹۲)، صحیح مسلم/البر والصلة ۳۷ (۲۶۰۵)، سنن ابی داود/ الأدب ۵۸ (۴۹۲۰) (تحفة الأشراف : ۱۸۳۵۳)، و مسند احمد (۶/۴۰۴),1938,Narrated 'Umar:,The Book on Drinks
1939,حَدَّثَنَا بِذَلِكَ، أَحْمَدُ بْنُ مَنِيعٍ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ أَبِي حَيَّانَ التَّيْمِيِّ، عَنِ الشَّعْبِيِّ، عَنِ ابْنِ عُمَرَ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، إِنَّ مِنَ الْحِنْطَةِ خَمْرًا بِهَذَا ‏.‏ وَهَذَا أَصَحُّ مِنْ حَدِيثِ إِبْرَاهِيمَ بْنِ مُهَاجِرٍ ‏.‏ وَقَالَ عَلِيُّ بْنُ الْمَدِينِيِّ قَالَ يَحْيَى بْنُ سَعِيدٍ لَمْ يَكُنْ إِبْرَاهِيمُ بْنُ مُهَاجِرٍ بِالْقَوِيِّ فِي الْحَدِيثِ ‏.‏ وَقَدْ رُوِيَ مِنْ غَيْرِ وَجْهٍ أَيْضًا عَنِ الشَّعْبِيِّ عَنِ النُّعْمَانِ بْنِ بَشِيرٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۵۷۷۰)، وانظر مسند احمد (۶/۴۵۴، ۴۵۹، ۴۶۰),1939,Narrated 'Umar bin Al-Khattab:,The Book on Drinks
1940,"حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، حَدَّثَنَا الأَوْزَاعِيُّ، وَعِكْرِمَةُ بْنُ عَمَّارٍ، قَالاَ حَدَّثَنَا أَبُو كَثِيرٍ السُّحَيْمِيُّ، قَالَ سَمِعْتُ أَبَا هُرَيْرَةَ، يَقُولُ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الْخَمْرُ مِنْ هَاتَيْنِ الشَّجَرَتَيْنِ النَّخْلَةُ وَالْعِنَبَةُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏ وَأَبُو كَثِيرٍ السُّحَيْمِيُّ هُوَ الْغُبَرِيُّ وَاسْمُهُ يَزِيدُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ غُفَيْلَةَ ‏.‏ وَرَوَى شُعْبَةُ عَنْ عِكْرِمَةَ بْنِ عَمَّارٍ هَذَا الْحَدِيثَ ‏.‏""",Ahmad Muhammad Shakir: Hasan; Al-Albani: Hasan; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأقضیة ۳۱ (۳۶۳۵)، سنن ابن ماجہ/الأحکام ۱۷ (۲۳۴۰) (تحفة الأشراف : ۱۲۰۶۶۳)، و مسند احمد (۳/۴۵۳),,Narrated Abu Kathir As-Suhaimi:,The Book on Drinks
1941,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ عَطَاءِ بْنِ أَبِي رَبَاحٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى أَنْ يُنْبَذَ الْبُسْرُ وَالرُّطَبُ جَمِيعًا ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۶۶۱۹),1941,Narrated Jabir bin ‘Abdullah :,The Book on Drinks
1942,حَدَّثَنَا سُفْيَانُ بْنُ وَكِيعٍ، حَدَّثَنَا جَرِيرٌ، عَنْ سُلَيْمَانَ التَّيْمِيِّ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنِ الْبُسْرِ وَالتَّمْرِ أَنْ يُخْلَطَ بَيْنَهُمَا وَنَهَى عَنِ الزَّبِيبِ وَالتَّمْرِ أَنْ يُخْلَطَ بَيْنَهُمَا وَنَهَى عَنِ الْجِرَارِ أَنْ يُنْبَذَ فِيهَا ‏.‏ قَالَ وَفِي الْبَابِ عَنْ جَابِرٍ وَأَنَسٍ وَأَبِي قَتَادَةَ وَابْنِ عَبَّاسٍ وَأُمِّ سَلَمَةَ وَمَعْبَدِ بْنِ كَعْبٍ عَنْ أُمِّهِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأدب ۲۸ (۶۰۱۴)، صحیح مسلم/البر والصلة ۴۲ (۲۶۲۴)، سنن ابی داود/ الأدب ۱۳۲ (۵۱۵۱)، سنن ابن ماجہ/الأدب ۴ (۲۶۷۳) (تحفة الأشراف : ۱۷۹۴۷)، و مسند احمد (۶/۹۱، ۱۲۵),1942,Narrated Abu Sa'eed:,The Book on Drinks
1943,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنِ الْحَكَمِ، قَالَ سَمِعْتُ ابْنَ أَبِي لَيْلَى، يُحَدِّثُ أَنَّ حُذَيْفَةَ، اسْتَسْقَى فَأَتَاهُ إِنْسَانٌ بِإِنَاءٍ مِنْ فِضَّةٍ فَرَمَاهُ بِهِ وَقَالَ إِنِّي كُنْتُ قَدْ نَهَيْتُهُ فَأَبَى أَنْ يَنْتَهِيَ إِنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى عَنِ الشُّرْبِ فِي آنِيَةِ الْفِضَّةِ وَالذَّهَبِ وَلُبْسِ الْحَرِيرِ وَالدِّيبَاجِ وَقَالَ ‏ ‏ هِيَ لَهُمْ فِي الدُّنْيَا وَلَكُمْ فِي الآخِرَةِ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أُمِّ سَلَمَةَ وَالْبَرَاءِ وَعَائِشَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأدب ۱۳۲ (۵۱۵۲) (تحفة الأشراف : ۸۹۱۹),,Narrated Shu'bah bin Al-Hakam:,The Book on Drinks
1944,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنْ سَعِيدِ بْنِ أَبِي عَرُوبَةَ، عَنْ قَتَادَةَ، عَنْ أَنَسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى أَنْ يَشْرَبَ الرَّجُلُ قَائِمًا ‏.‏ فَقِيلَ الأَكْلُ قَالَ ذَاكَ أَشَدُّ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۸۸۶۵)، وانظر مسند احمد (۲/۱۶۸),1944,Narrated Qatadah:,The Book on Drinks
1945,حَدَّثَنَا أَبُو السَّائِبِ، سَلْمُ بْنُ جُنَادَةَ الْكُوفِيُّ حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ كُنَّا نَأْكُلُ عَلَى عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم وَنَحْنُ نَمْشِي وَنَشْرَبُ وَنَحْنُ قِيَامٌ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ صَحِيحٌ غَرِيبٌ مِنْ حَدِيثِ عُبَيْدِ اللَّهِ بْنِ عُمَرَ عَنْ نَافِعٍ عَنِ ابْنِ عُمَرَ ‏.‏ وَرَوَى عِمْرَانُ بْنُ حُدَيْرٍ هَذَا الْحَدِيثَ عَنْ أَبِي الْبَزَرِيِّ عَنِ ابْنِ عُمَرَ ‏.‏ وَأَبُو الْبُزَرِيُّ اسْمُهُ يَزِيدُ بْنُ عُطَارِدٍ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الإیمان ۲۲ (۳۰)، والتعق ۱۵ (۲۵۴۵)، والأدب ۴۴ (۶۰۵۰)، صحیح مسلم/الأیمان والنذور ۱۰ (۱۶۶۱)، سنن ابن ماجہ/الأدب ۱۰ (۳۶۹۰) (تحفة الأشراف : ۱۱۹۸۰)، و مسند احمد (۵/۱۵۸، ۱۷۳),1945,Narrated Ibn 'Umar:,The Book on Drinks
1946,"حَدَّثَنَا حُمَيْدُ بْنُ مَسْعَدَةَ، حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، عَنْ سَعِيدٍ، عَنْ قَتَادَةَ، عَنْ أَبِي مُسْلِمٍ الْجَذْمِيِّ، عَنِ الْجَارُودِ بْنِ الْمُعَلَّى، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنِ الشُّرْبِ قَائِمًا ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أَبِي سَعِيدٍ وَأَبِي هُرَيْرَةَ وَأَنَسٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ حَسَنٌ ‏.‏ وَهَكَذَا رَوَى غَيْرُ وَاحِدٍ هَذَا الْحَدِيثَ عَنْ سَعِيدٍ عَنْ قَتَادَةَ عَنْ أَبِي مُسْلِمٍ عَنِ الْجَارُودِ عَنِ النَّبِيِّ صلى الله عليه وسلم ‏.‏ وَرُوِيَ عَنْ قَتَادَةَ عَنْ يَزِيدَ بْنِ عَبْدِ اللَّهِ بْنِ الشِّخِّيرِ عَنْ أَبِي مُسْلِمٍ عَنِ الْجَارُودِ أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ ضَالَّةُ الْمُسْلِمِ حَرْقُ النَّارِ ‏""""‏ ‏.‏ وَالْجَارُودُ هُوَ ابْنُ الْمُعَلَّى الْعَبْدِيُّ صَاحِبُ النَّبِيِّ صلى الله عليه وسلم وَيُقَالُ الْجَارُودُ بْنُ الْعَلاَءِ أَيْضًا وَالصَّحِيحُ ابْنُ الْمُعَلَّى ‏.‏""",Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: سنن ابن ماجہ/الأدب ۱۰ (۳۶۹۱) (تحفة الأشراف : ۶۶۱۸),,Narrated Al-Jarud bin Al-'Ala':,The Book on Drinks
1947,حَدَّثَنَا أَحْمَدُ بْنُ مَنِيعٍ، حَدَّثَنَا هُشَيْمٌ، حَدَّثَنَا عَاصِمٌ الأَحْوَلُ، وَمُغِيرَةُ، عَنِ الشَّعْبِيِّ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم شَرِبَ مِنْ زَمْزَمَ وَهُوَ قَائِمٌ ‏.‏ قَالَ وَفِي الْبَابِ عَنْ عَلِيٍّ وَسَعْدٍ وَعَبْدِ اللَّهِ بْنِ عَمْرٍو وَعَائِشَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الحدود ۴۵ (۶۸۵۸)، صحیح مسلم/الأیمان والنذور ۹ (۱۶۶۰)، سنن ابی داود/ الأدب ۱۳۳ (۵۱۶۵) (تحفة الأشراف : ۱۳۶۲۴)، و مسند احمد (۲/۴۳۱),1947,Narrated Ibn 'Abbas:,The Book on Drinks
1948,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، عَنْ حُسَيْنٍ الْمُعَلِّمِ، عَنْ عَمْرِو بْنِ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ رَأَيْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَشْرَبُ قَائِمًا وَقَاعِدًا ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تخریج دارالدعوہ: صحیح مسلم/الأیمان والنذور ۸ (۱۶۵۹)، سنن ابی داود/ الأدب ۱۳۳ (۵۱۵۹) (تحفة الأشراف : ۱۰۰۰۹),1948,Narrated 'Amr bin Shu'aib:,The Book on Drinks
1949,"حَدَّثَنَا قُتَيْبَةُ، وَيُوسُفُ بْنُ حَمَّادٍ، قَالاَ حَدَّثَنَا عَبْدُ الْوَارِثِ بْنُ سَعِيدٍ، عَنْ أَبِي عِصَامٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ يَتَنَفَّسُ فِي الإِنَاءِ ثَلاَثًا وَيَقُولُ ‏ ‏ هُوَ أَمْرَأُ وَأَرْوَى ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ غَرِيبٌ ‏.‏ وَرَوَاهُ هِشَامٌ الدَّسْتَوَائِيُّ عَنْ أَبِي عِصَامٍ عَنْ أَنَسٍ ‏.‏ وَرَوَى عَزْرَةُ بْنُ ثَابِتٍ، عَنْ ثُمَامَةَ، عَنْ أَنَسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ يَتَنَفَّسُ فِي الإِنَاءِ ثَلاَثًا ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأدب ۱۳۳ (۵۱۶۴) (تحفة الأشراف : ۷۱۱۷، ۸۸۳۶)، و مسند احمد (۲/۹۰، ۱۱۱),,Narrated Anas bin Malik:,The Book on Drinks
1950,حَدَّثَنَا بِذَلِكَ مُحَمَّدُ بْنُ بَشَّارٍ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ حَدَّثَنَا عَزْرَةُ بْنُ ثَابِتٍ الأَنْصَارِيُّ عَنْ ثُمَامَةَ عَنْ أَنَسِ بْنِ مَالِكٍ أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ يَتَنَفَّسُ فِي الإِنَاءِ ثَلاَثًا ‏.‏ قَالَ هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Bashar Awad Maarouf: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۴۲۶۳),1950,Narrated 'Azrah bin Thabit:,The Book on Drinks
1951,"حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا وَكِيعٌ، عَنْ يَزِيدَ بْنِ سِنَانٍ الْجَزَرِيِّ، عَنِ ابْنٍ لِعَطَاءِ بْنِ أَبِي رَبَاحٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ تَشْرَبُوا وَاحِدًا كَشُرْبِ الْبَعِيرِ وَلَكِنِ اشْرَبُوا مَثْنَى وَثُلاَثَ وَسَمُّوا إِذَا أَنْتُمْ شَرِبْتُمْ وَاحْمَدُوا إِذَا أَنْتُمْ رَفَعْتُمْ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ ‏.‏ وَيَزِيدُ بْنُ سِنَانٍ الْجَزَرِيُّ هُوَ أَبُو فَرْوَةَ الرُّهَاوِيُّ ‏.‏""",Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۲۱۹۵),,Narrated Ibn 'Abbas:,The Book on Drinks
1952,حَدَّثَنَا عَلِيُّ بْنُ خَشْرَمٍ، حَدَّثَنَا عِيسَى بْنُ يُونُسَ، عَنْ رِشْدِينَ بْنِ كُرَيْبٍ، عَنْ أَبِيهِ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم كَانَ إِذَا شَرِبَ تَنَفَّسَ مَرَّتَيْنِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ غَرِيبٌ لاَ نَعْرِفُهُ إِلاَّ مِنْ حَدِيثِ رِشْدِينَ بْنِ كُرَيْبٍ ‏.‏ قَالَ وَسَأَلْتُ أَبَا مُحَمَّدٍ عَبْدَ اللَّهِ بْنَ عَبْدِ الرَّحْمَنِ عَنْ رِشْدِينَ بْنِ كُرَيْبٍ قُلْتُ هُوَ أَقْوَى أَوْ مُحَمَّدُ بْنُ كُرَيْبٍ فَقَالَ مَا أَقْرَبَهُمَا وَرِشْدِينُ بْنُ كُرَيْبٍ أَرْجَحُهُمَا عِنْدِي ‏.‏ قَالَ وَسَأَلْتُ مُحَمَّدَ بْنَ إِسْمَاعِيلَ عَنْ هَذَا فَقَالَ مُحَمَّدُ بْنُ كُرَيْبٍ أَرْجَحُ مِنْ رِشْدِينَ بْنِ كُرَيْبٍ ‏.‏ وَالْقَوْلُ عِنْدِي مَا قَالَ أَبُو مُحَمَّدٍ عَبْدُ اللَّهِ بْنُ عَبْدِ الرَّحْمَنِ رِشْدِينُ بْنُ كُرَيْبٍ أَرْجَحُ وَأَكْبَرُ وَقَدْ أَدْرَكَ ابْنَ عَبَّاسٍ وَرَآهُ وَهُمَا أَخَوَانِ وَعِنْدَهُمَا مَنَاكِيرُ ‏.‏,Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۴۴۷۳),1952,Narrated Ibn 'Abbas:,The Book on Drinks
1953,"حَدَّثَنَا عَلِيُّ بْنُ خَشْرَمٍ، أَخْبَرَنَا عِيسَى بْنُ يُونُسَ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ أَيُّوبَ، وَهُوَ ابْنُ حَبِيبٍ أَنَّهُ سَمِعَ أَبَا الْمُثَنَّى الْجُهَنِيَّ، يَذْكُرُ عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى عَنِ النَّفْخِ فِي الشُّرْبِ ‏.‏ فَقَالَ رَجُلٌ الْقَذَاةُ أَرَاهَا فِي الإِنَاءِ قَالَ ‏""‏ أَهْرِقْهَا ‏""‏ ‏.‏ قَالَ فَإِنِّي لاَ أَرْوَى مِنْ نَفَسٍ وَاحِدٍ قَالَ ‏""‏ فَأَبِنِ الْقَدَحَ إِذًا عَنْ فِيكَ ‏""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تخریج دارالدعوہ: صحیح البخاری/الہبة ۱۱ (۲۵۸۵)، سنن ابی داود/ البیوع ۸۲ (۳۵۳۷) (تحفة الأشراف : ۱۷۱۳۳),1953,Narrated Abu Sa’id Al Khudri :,The Book on Drinks
1954,حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَبْدِ الْكَرِيمِ الْجَزَرِيِّ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَهَى أَنْ يُتَنَفَّسَ فِي الإِنَاءِ أَوْ يُنْفَخَ فِيهِ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأدب ۱۲ (۴۸۱۱) (تحفة الأشراف : ۱۴۳۶۸)، و مسند احمد (۲/۲۹۵، ۳۰۳، ۴۶۱),1954,Narrated Ibn 'Abbas:,The Book on Drinks
1955,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ، حَدَّثَنَا هِشَامٌ الدَّسْتَوَائِيُّ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ عَبْدِ اللَّهِ بْنِ أَبِي قَتَادَةَ، عَنْ أَبِيهِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا شَرِبَ أَحَدُكُمْ فَلاَ يَتَنَفَّسْ فِي الإِنَاءِ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih Lighairihi; Al-Albani: Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۴۲۳۵),,Narrated 'Abdullah bin Abi Qatadah:,The Book on Drinks
1956,حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا سُفْيَانُ، عَنِ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، رِوَايَةً أَنَّهُ نَهَى عَنِ اخْتِنَاثِ الأَسْقِيَةِ، ‏.‏ قَالَ وَفِي الْبَابِ عَنْ جَابِرٍ، وَابْنِ، عَبَّاسٍ وَأَبِي هُرَيْرَةَ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۱۹۷۵),1956,"'Ubaidullah bin 'Abdullah narrated a report (of the Messenger of Allah (ﷺ) from Abu Sa'eed, that he prohibited bending the mouths of the water-skins.\n\n\nHe said:",The Book on Drinks
1957,حَدَّثَنَا يَحْيَى بْنُ مُوسَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ عُمَرَ، عَنْ عِيسَى بْنِ عَبْدِ اللَّهِ بْنِ أُنَيْسٍ، عَنْ أَبِيهِ، قَالَ رَأَيْتُ النَّبِيَّ صلى الله عليه وسلم قَامَ إِلَى قِرْبَةٍ مُعَلَّقَةٍ فَخَنَثَهَا ثُمَّ شَرِبَ مِنْ فِيهَا ‏.‏ قَالَ وَفِي الْبَابِ عَنْ أُمِّ سُلَيْمٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ لَيْسَ إِسْنَادُهُ بِصَحِيحٍ ‏.‏ وَعَبْدُ اللَّهِ بْنُ عُمَرَ الْعُمَرِيُّ يُضَعَّفُ فِي الْحَدِيثِ وَلاَ أَدْرِي سَمِعَ مِنْ عِيسَى أَمْ لاَ,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۸۸۷)، وانظر مسند احمد (۴/۲۹۶، ۳۰۰),1957,Narrated 'Eisa bin 'Abdullah bin Unais:,The Book on Drinks
1958,حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ، عَنْ يَزِيدَ بْنِ يَزِيدَ بْنِ جَابِرٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي عَمْرَةَ، عَنْ جَدَّتِهِ، كَبْشَةَ قَالَتْ دَخَلَ عَلَىَّ رَسُولُ اللَّهِ صلى الله عليه وسلم فَشَرِبَ مِنْ فِي قِرْبَةٍ مُعَلَّقَةٍ قَائِمًا فَقُمْتُ إِلَى فِيهَا فَقَطَعْتُهُ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ غَرِيبٌ ‏.‏ وَيَزِيدُ بْنُ يَزِيدَ بْنِ جَابِرٍ هُوَ أَخُو عَبْدِ الرَّحْمَنِ بْنِ يَزِيدَ بْنِ جَابِرٍ وَهُوَ أَقْدَمُ مِنْهُ مَوْتًا ‏.‏,Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: تخریج دارالدعوہ: صحیح البخاری/الأذان ۳۲ (۶۵۲) والمظالم ۲۸ (۲۴۷۲)، صحیح مسلم/الإمارة ۵۱ (۱۹۱۴/۱۶۴)، والبر والصلة (۱۹۱۴/۱۲۷) (تحفة الأشراف : ۱۲۵۷۵),1958,Narrated 'Abdur-Rahman bin Abi 'Amrah:,The Book on Drinks
1959,"حَدَّثَنَا الأَنْصَارِيُّ، حَدَّثَنَا مَعْنٌ، حَدَّثَنَا مَالِكٌ، قَالَ وَحَدَّثَنَا قُتَيْبَةُ، عَنْ مَالِكٍ، عَنِ ابْنِ شِهَابٍ، عَنْ أَنَسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم أُتِيَ بِلَبَنٍ قَدْ شِيبَ بِمَاءٍ وَعَنْ يَمِينِهِ أَعْرَابِيٌّ وَعَنْ يَسَارِهِ أَبُو بَكْرٍ فَشَرِبَ ثُمَّ أَعْطَى الأَعْرَابِيَّ وَقَالَ ‏ ‏ الأَيْمَنَ فَالأَيْمَنَ ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ عَبَّاسٍ وَسَهْلِ بْنِ سَعْدٍ وَابْنِ عُمَرَ وَعَبْدِ اللَّهِ بْنِ بُسْرٍ ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Hasan; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/ الأدب ۱۳۷ (۴۸۶۸) (تحفة الأشراف : ۲۳۸۴)، و مسند احمد (۳/۳۸۰),,Narrated Anas bin Malik:,The Book on Drinks
1960,"حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ ثَابِتٍ الْبُنَانِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ رَبَاحٍ، عَنْ أَبِي قَتَادَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ سَاقِي الْقَوْمِ آخِرُهُمْ شُرْبًا ‏""""‏ ‏.‏ قَالَ وَفِي الْبَابِ عَنِ ابْنِ أَبِي أَوْفَى ‏.‏ قَالَ أَبُو عِيسَى هَذَا حَدِيثٌ حَسَنٌ صَحِيحٌ ‏.‏""",Ahmad Muhammad Shakir: Sahih; Al-Albani: Sahih; Bashar Awad Maarouf: Hasan Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الزکاة ۲۱ (۱۴۳۳)، و۲۲ (۱۴۳۴)، والہبة ۱۵ (۲۵۹۰)، صحیح مسلم/الزکاة ۲۸ (۱۰۲۹)، سنن ابی داود/ الزکاة ۴۶ (۱۶۹۹)، سنن النسائی/الزکاة ۶۲ (۲۵۵۲) (تحفة الأشراف : ۱۵۷۱۸)، و مسند احمد (۶/۳۴۴),,Narrated Abu Qatadah:,The Book on Drinks
1961,حَدَّثَنَا ابْنُ أَبِي عُمَرَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ مَعْمَرٍ، عَنِ الزُّهْرِيِّ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، قَالَتْ كَانَ أَحَبَّ الشَّرَابِ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم الْحُلْوُ الْبَارِدُ ‏.‏ قَالَ أَبُو عِيسَى هَكَذَا رَوَى غَيْرُ وَاحِدٍ عَنِ ابْنِ عُيَيْنَةَ مِثْلَ هَذَا عَنْ مَعْمَرٍ عَنِ الزُّهْرِيِّ عَنْ عُرْوَةَ عَنْ عَائِشَةَ وَالصَّحِيحُ مَا رُوِيَ عَنِ الزُّهْرِيِّ عَنِ النَّبِيِّ صلى الله عليه وسلم مُرْسَلاً ‏.‏,Ahmad Muhammad Shakir: Very Daif; Al-Albani: Very Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۱۳۹۷۳),1961,Narrated 'Aishah:,The Book on Drinks
1962,"حَدَّثَنَا أَحْمَدُ بْنُ مُحَمَّدٍ، أَخْبَرَنَا عَبْدُ اللَّهِ بْنُ الْمُبَارَكِ، أَخْبَرَنَا مَعْمَرٌ، وَيُونُسُ، عَنِ الزُّهْرِيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم سُئِلَ أَىُّ الشَّرَابِ أَطْيَبُ قَالَ ‏ ‏ الْحُلْوُ الْبَارِدُ ‏""""‏ ‏.‏ قَالَ أَبُو عِيسَى وَهَكَذَا رَوَى عَبْدُ الرَّزَّاقِ عَنْ مَعْمَرٍ عَنِ الزُّهْرِيِّ عَنِ النَّبِيِّ صلى الله عليه وسلم مُرْسَلاً وَهَذَا أَصَحُّ مِنْ حَدِيثِ ابْنِ عُيَيْنَةَ رَحِمَهُ اللَّهُ ‏.‏""",Ahmad Muhammad Shakir: Daif; Al-Albani: Daif; Zubair Ali Zai: Daif,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (تحفة الأشراف : ۴۱۱۰),,Narrated Az-Zuhri:,The Book on Drinks
