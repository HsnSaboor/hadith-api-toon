hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
167,[167] وَحَدَّثَنِی عَنْ مَالِکٍ عَنْ أَبِی نُعَیْمٍ وَہْبِ بْنِ کَیْسَانَ عَنْ جَابِرِ بْنِ عَبْدِ,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 0, Hadith 1",167,,
684,[684] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ عَبْدِ اللّٰہِ بْنِ دِینَارٍ، عَنْ سُلَیْمَانَ بْنِ یَس,"{'name': 'Salim al-Hilali', 'grade': 'Maqtu Daif'}","Book 0, Hadith 1",684,,
927,[927] حَدَّثَنِی عَنْ مَالِکٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ، عَنْ أَبِیہِ، عَنْ عَائِشَۃ,"{'name': 'Salim al-Hilali', 'grade': 'Sahih'}","Book 0, Hadith 1",927,,
951,[951] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ بِمِثْلِ ذَلِکَ۔,"{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}","Book 0, Hadith 1",951,,
958,[958] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنْ سَالِمِ بْنِ عَبْدِ اللّٰہِ، عَنْ عَبْدِ ا,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Sahih'}","Book 0, Hadith 1",958,,
1013,[1013] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ : أَنَّ سَعِیدَ بْنَ الْمُسَیَّبِ وَأَبَا سَل,"{'name': 'Salim al-Hilali', 'grade': 'Maqtu Daif'}","Book 0, Hadith 1",1013,,
1040,[1040] وَحَدَّثَنِی عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ : أَنَّ سَعِیدَ بْنَ الْمُسَیَّبِ کَانَ یَکْرَ,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}","Book 0, Hadith 1",1040,,
1090,[1090] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنِ الْمِسْوَرِ بْنِ رِفَاعَۃَ الْقُرَظِیِّ، عَنِ الزُّبَی,"{'name': 'Salim al-Hilali', 'grade': 'Daif'}","Book 0, Hadith 1",1090,,
1171,[1171] حَدَّثَنِی یَحْیَی،وعَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ، أَنَّ عُرْوَۃَ بْنَ الزُّبَیْرِ کَانَ,"{'name': 'Salim al-Hilali', 'grade': 'Daif'}","Book 0, Hadith 1",1171,,
1176,[1176] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنِ ابْنِ شِہَابٍ، عَنْ طَلْحَۃَ بْنِ عَبْدِ اللّٰہِ بْنِ,"{'name': 'Salim al-Hilali', 'grade': 'Hasan'}","Book 0, Hadith 1",1176,,
1191,[1191] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ طَلَّقَ ام,"{'name': 'Salim al-Hilali', 'grade': 'Maqtu Daif'}","Book 0, Hadith 1",1191,,
1203,[1203] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ نَافِعٍ : أَنَّ عَبْدَ اللّٰہِ بْنَ عُمَرَ طَلَّقَ امْرَأَۃ,"{'name': 'Salim al-Hilali', 'grade': 'Maqtu Daif'}","Book 0, Hadith 1",1203,,
1338,[1338] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنْ أبِی الزِّنَادِ، أَنَّہُ سَمِعَ سَعِیدَ بْنَ الْمُسَیَّبِ ی,"{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}","Book 0, Hadith 1",1338,,
1492,[1492] حَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ، أَ نَّہُ بَلَغَہُ، أَنَّ عُرْوَۃَ بْنَ الزُّبَیْرِ کَانَ,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}","Book 0, Hadith 1",1492,,
1519,[1519] وَحَدَّثَنِی یَحْیَی، عَنْ مَالِکٍ : أَ نَّہُ بَلَغَہُ : أَنَّ سَعِیدَ بْنَ الْمُسَیَّبِ، و,"{'name': 'Salim al-Hilali', 'grade': 'Mauquf Daif'}","Book 0, Hadith 1",1519,,
1528,[1528] وَحَدَّثَنِی مَالِکٌ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ عَمْرِو بْنِ شُعَیْبٍ : أَنَّ رَجُلاً,"{'name': 'Salim al-Hilali', 'grade': 'Maqtu Daif'}","Book 0, Hadith 1",1528,,
1583,[1583] وَحَدَّثَنِی عَنْ مَالِکٍ، عَنِ الثِّقَۃِ عِنْدَہُ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللّٰہِ بْنِ ال,"{'name': 'Salim al-Hilali', 'grade': 'Maqtu Sahih'}","Book 0, Hadith 1",1583,,
1748,[1748] عَنْ عَائِشَۃَ زَوْجِ النَّبِیِّ  ﷺ ، أَ نَّہُ بَلَغَہَا : أَنَّ أَہْلَ بَیْتٍ فِی دَارِہَ,"{'name': 'Salim al-Hilali', 'grade': 'Sahih'}","Book 0, Hadith 1",1748,,