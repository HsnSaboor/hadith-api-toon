hadiths[3]{hadithnumber,text}:
22860,أوذوزأثىأؼثزتههۄأثىأدذطأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأڬۄأتۏڬأوشحثۄأۄوأهًڲأظذىأوضدزأوۏڽأتضأدڲۄأثۏټہەأۄًةەأحہەأدۄتڽأدىتصەأشڬہەأدتحەأحہەأ؏أۄوتشەأزشوۏتىأىثۏأ﷽أثہۏأحطشۏلألشوتأحہەأ؏أتضۏأزًشتىأىثۏأ﷽أىەأإضوتىأڬۏأغشلأىڲتۄۏڽأتټہتأڬشأزۏڬہتأ؏أځہشأتځىۏأىػشۏڽأدہڬتأهۏڽأتًشأتځىتأۄتحہأتځىۏأځۏطتىۏأځشأشڬہأڬشأزًأوشحثۄأضثذتىأتههۄأڬۄتأتًشألشوتۏتأڬحىۏأضرحأثتحأتحشۏأۄەأآأۄوأتۏڬأزىأشتحأرتوًطأشۄەأهۏڬىأۄوۏڽأرۏشأڬەأؼهتًۄأڬډہأزڬہتةۏأىۄأزۏتأ؏أتڲهەأزىأوۏڽأىەأىثۏأ﷽أضەأځًډہتأڬۄأًۄأضرحأثتحأڬۏتأۄەأدًأتحشۏأۄەأآأىثۏأ﷽أىەألشوتۏتأتضأڬتأحؼهمأمشعأضەأۄەأ؏أتضأستحأڬۏأمضوأدضأڬەأزضحأمزشحأوۏڽأوذوزأ﷽أڬۏأدتىأۄەأ؏أتڲشأڬًةۏأإزوۏأتههۄأڬەأشتضحەأوۏڽأطۄۏزأۄًأدتةەأ؏أځہشأتضەأصىزڲۏأوهەأتًشأًۄأزًثتشۄأطۄۏزأۄًأدتةەأ؏أځہشأصىزڲۏأوهەأتًشأًۄأطۄۏزأۄًأدتةەأ؏أتًشأځہشأصىزڲۏأوهأدتةەأتًشأتضأځشأمشعأۄًأحًأتضأڬۏأتزتةۏڲۏأحڬأًۄأدىحأوۏڽأزترهأىۄأۄًأڲتأۗ
22861,أوذوزأثىأدذطأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأىثۏأ﷽أذعشحأوؼوشأشعۏأتههۄأؼىۄأڬەأځتضأضەأڲسشەأدًأظذىأوضدزأوۏڽأزًىًڽأټتىڲۏڽأڬہڔۏأڬشأڬەأتضأغشذأثۏټہەأۄًةەأحہەأڬۄأتىأڬۏأشتىأڬۏأتۏڬأدتىثأضەأڬځڔتأۄټأڲۏتأحہتأ؏أىثۏأ﷽أىەأتىأضەألشوتۏتأتەأوؼوشأ$أتځىۏأشتىأڬًأڋہتىځًأڬۏًىڬۄأشتىأطشوڲتۄأۄەأۗأ
22862,أوذوزأثىأدذطأشعۏأتههۄأؼىۄأضەأوشًۏأۄەأڬۄأتۏڬأوشحثۄأىثۏأ﷽أذعشحأوؼوشأشعۏأتههۄأؼىۄأڬەأځتضأضەأڲسشەأ؏أوۏڽأثہۏأىثۏأ﷽أڬەأۄوشتۄأحہتأ؏أتىأڬۏأشتىًڽأضەأڬځڔتأۄټأڲۏتأحہتأ؏أىثۏأ﷽أىەأتىأضەألشوتۏتأتەأوؼوشأ$أتځىۏأشتىأڬًأڋہتىځًأڬۏًىڬۄأشتىأطشوڲتۄأۄەأۗ
