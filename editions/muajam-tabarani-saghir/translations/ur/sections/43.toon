17858,"أذعشحأصۏزأثىأتشموأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أۄوأهًڲأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأڬەأضتحہأوًدًزأحہەأ؏أتىۄًڽأىەأځۏىەأڬەأهۏەأڬډہأوتىڲتأحًأځتىۏأتًشأطۄزأهتۏتأڲۏتأ؏أدثأًۄأذعشحأتثًثڬشأشعۏأتههۄأؼىۄأڬەأۄتحہأوۏڽأځڬڔتۏتأڲۏتأ؏أحًأًۄأشًأځڔەأ؏أتًشأطزۏزأشًةەأ؏أۏۄتڽأحڬأڬۄأۄوأىەأۏۄأڲوتىأڬۏتأڬۄأطتۏزأتىۄۏڽأڬًةۏأډۏصأهتذمأۄًةۏأۄەأ؏أذتهتىڬۄأۄوأىەأتىأضەأڬضۏأډۏصأڬەأثتشەأوۏڽأىۄۏڽأځًډہتأحہتأ؏أدثأًۄألتشؽأۄًةەأ؏أحًأۄوأىەأزشۏتلحأڬۏتأ=أتەأتههۄأڬەأشضًهأڬەأرهۏلۄأ$أإځأشًةەأڬۏًڽأآأتىۄًڽأىەألشوتۏتأ=أ
أ““أتۏڬأوشحثۄأوۏڽأىثۏأتڬشوأ﷽أڬەأضتحہأوًدًزأحہتأتضۏأزًشتىأوۏڽأىەأإځأڬًأزۏڬہتأڬۄأدۏضەأإځأڬضۏأډۏصأڬًأځشەأڬشأشۄەأۄۏڽأ؏أهۏڬىأودہەأڬًةۏأډۏصأزڬہتةۏأىۄۏڽأزۏأ؏أوۏڽأىەأؼشعأڬۏأۏتأشضًهأتههۄأًۄأڬۏتأډۏصأۄەأدضأڬًأإځأځشەأڬشأشۄەأۄۏڽأتًشأودہەأحًأڬډہأىػشأىۄۏڽأإأشۄتأ؏أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأزىۏتأوۏشۏأغشلأإةۏأ؏أحًأوۏڽأىەأڬۄتأ=أودہأضەأزًشأشۄًأ؏أحًأتضأىەأودہأضەأڬۄتأ=أإځأوۏشەأزتوأوۏڽأىۄۏڽأإةۏڽأڲەأ؏أذعشحأتثًثڬشأشعۏأتههۄأؼىۄأڬۄحەأۄۏڽأ؏أحًأۏۄأډۏصأودہأځشأڲشتڽأڲصشۏأتًشأودہەأۏۄأتىزۏطۄأۄًتأڬۄأڬۄۏڽأوۏڽأىەأىثۏأتڬشوأ﷽أڬەأغشصأؼوهأڬەأثشرهتلأحًأىۄۏڽأڬۏتأتًشأزىۏتأودہەأهتذمأۄًأڲةۏأۄەأۗ
أۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼثزتهًتذزأثىأصۏزأصتۄزأۄەأتًشأًۄأدوۄًشأڬەأىصزۏڬأعؼۏلأۄەأ؏أتثىأذثتىأوۏڽأتضأڬتأحسڬشۄأڬحتثأتهخمتحأوۏڽأڬۏتأۄەأتًشأۏۄأثتحأڬۄۏأۄەأ؏أتضأڬۏأىمهأڬشزۄأذزۏخأڬتأتؼحثتشأڬۏتأدتةەأڲتأدثڬۄأتضأڬەأتًځشأًتهتأشتًۏأخمۄأۄًڽأتًشأتضأڬەأىۏډەأًتهتأشتًۏأخمۄأۄًأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗ

[تخریج]: حديث : 17858 - اخرجه البزار في المسند """" (3618)"
17859,"أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأ““أوشلًؼأ‛‛أذزۏخأڬەأغًشأځشأۏۄأثتحأىمهأڬشحەأۄۏڽأ=أ+أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأۄەأ=أ,أ
أ““أتۏڬأوىتزۏأۏۄأتؼهتىأڬشحتأۄەأ=أزىۏتأڬًأ؏أتۄهأزىۏتأڬەأهةەأډہًڔأزًأ$أزىۏتأڬًأتۄهأزىۏتأڬەأهةەأډہًڔأزًأ$أزىۏتأڬًأتۄهأزىۏتأڬەأهةەأډہًڔأزًأ$أدًأطرظأتځىەأثىۏتزۏأعشًشحأضەأصۏتزۄأزىۏتأهۏحتأۄەأ؏أًۄأوشزتشأڬًأهۏحتأۄەأتًشأتْضەأتضأڬتأطؼًشأثہۏأىۄۏڽأۄًحتأۗ‛‛
أۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأ؏أًۄأڬۄحەأۄۏڽأ=أۏۄأىثۏأتڬشوأ﷽أڬەأذًتهەأضەأظشلأتضۏأضىزأڬەأضتحہأوىمًهأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأۄتىۏأثىأوحًڬهأۄەأتًشأًۄأعؼۏلأۄەأۗ

[تخریج]: حدیث : 17859 - اخرجه البزار في """"المسند"""" (3695)"
17860,"أضؼۏزأثىأوضۏثأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أڬۏأتًىټىۏأ““أؼعثتؤأ‛‛أضەأزًڔأوۏڽأإڲەأىۄۏڽأىڬهتأدتأضڬحتأحہتأ؏أتۏڬأزلؼۄأتۏڬأزۏۄتحۏأتځىۏأتًىټىۏأځشأضًتشأۄًأڬشأإۏتأتًشأىثۏأتڬشوأ﷽أڬۏأتًىټىۏأضەأزًڔأوۏڽأإڲەأىڬهأڲۏتأ؏أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أتههۄأحؼتهۏٳأڬەأسوۄأۏۄأثتحأهتصوأۄەأڬۄأزىۏتأوۏڽأضەأدًأثہۏأډۏصأثهىزأۄًأ؏أتههۄأحؼتهۏٳأتضەأځضحأڬشأزەأۗ‛‛
أوؼىأثىأؼۏضۏٳأثۏتىأڬشحەأۄۏڽأ=أتوتوأوتهڬأتضأڬۏأضىزأثۏتىأىۄۏڽأڬشحەأحہەأ؏أتۏڬأزىأًۄأۄوتشەأځتضأحطشۏلأهتةەأتىأڬتأوصتدأرًطڲًتشأحہتأ؏أحًأتىۄًڽأىەأۄوۏڽأۏۄأشًتۏحأصۄشۏأڬەأذًتهەأضەأ؏أضؼۏزأثىأوضۏثأڬەأذًتهەأضەأ؏أذعشحأتثًۄشۏشۄأشعۏأتههۄأؼىۄأضەأوىمًهأۄًىەأڬەأغًشأځشأثۏتىأڬۏأۗ
أۏۄأشًتۏحأتوتوأثصتشأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأتوتوأثصتشأڬەأتضحتزأتذوزأثىأشثۏؼأڬتأوؼتوهۄأورحهلأۄەأ؏أوۏڽأتىأضەأًتملأىۄۏڽأۄًڽأۗ

[تخریج]: حديث : 17860 - اخرجه البزار في """"المسند"""" (3694)"
17861,"أذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتځىەأإڲەأتۏڬأ+أهڬڔۏأ,أڲتڔأزۏأ؏أځہشأإځأىەأتضأڬەأضتحہأتۏڬأتًشأ+أهڬڔۏأ,أڲتڔأزۏأ؏أځہشأإځأىەأتۏڬأتًشأ+أهڬڔۏأ,أڲتڔأزۏأ؏أهۏڬىأتضأڬًأسشتأزًشأشڬہتأ؏أځہشأإځأىەأزشۏتلحأڬۏتأ=أڬۏتأحوأهًڲأدتىحەأۄًأآأۏۄأڬۏتأۄەأآأهًڲًڽأىەأؼشعأڬۏأ=أتههۄأحؼتهۏٳأتًشأتْضأڬتأشضًهأ﷽أثۄحشأدتىحەأۄۏڽأ؏أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=
أ““أۏۄأتىضتىأۄەأ؏أۏۄأتْضأڬۏأوًحأۄەأتًشأۏۄأتضأڬۏأتْوۏزۏڽأ+أۏؼىۏأرًتۄطتحأ,أۄۏڽأ؏أۏۄأتوۏزۏڽأ+أۏؼىۏأرًتۄطتحأ,أۏڬەأثؼزأزۏڲشەأإحۏأشۄحۏأۄۏڽأ؏أتًشأتْىأڬەأزشوۏتىأوۏڽأ؏أتْىأ+أڬەأرحوأۏتأځًشەأۄًىەأ,أضەأځۄهەأۄۏأوًحأإأدتحۏأۄەأۗ‛‛أ
أۏۄأشًتۏحأتوتوأتذوزأىەأىمهأڬۏأۄەأتًشأتضأشًتۏحأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأؼهۏأثىأؼهۏأشلتؼۏأڬتأوؼتوهۄأورحهلأۄەأتًشأًۄأطرظأخمۄأۄەأۗ

[تخریج]: حدیث : 17861 - اخرجه احمد فی المسند """" (18/3)"
17862,"أذعشحأؼثزتههۄأثىأؼوشًأشعۏأتههۄأؼىۄأ““أوشلًؼأ‛‛أذزۏخأڬەأغًشأځشأۏۄأثتحأىمهأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأۄەأ=
أ““أتضأتْوحأڬەأتثحزتةۏأذظەأڬۏأثۄحشۏأصۄزأتًشأۏمۏىأڬەأسشۏؼەأۄًأڲۏأ؏أتًشأتىأڬۏأۄهتڬحأ؏أثرهأتًشأرًتۄطتحأڬەأسشۏؼەأۄًأڲۏأۗ‛‛
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ؏أتضأڬۏأضىزأوۏڽأتۏڬأشتًۏأتضوتؼۏهأثىأوحًڬهأۄەأ؏أدضەأتۏڬأضەأصۏتزۄأتلشتزأىەأعؼۏلأمشتشأزۏتأۄەأتثىأذثتىأىەأتضەأخمۄأڬۄتأۄەأۗ"
17863,"أذعشحأؼثزتههۄأثىأوضؼًزأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أ
أ““أمۏتوحأمشۏثأإأشۄۏأۄەأتًشأهًڲأتْضأضەأزًشأۄًحەأدتأشۄەأۄۏڽأۗ‛‛أ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ

[تخریج]: حدیث : 17863 - اخرجه الطبراني في """"المعجم الكبير """" (9787) اخرجه احمد في المسند """" (198/5)"
17864,"أذعشحأتىضأثىأوتهڬأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أ
أ““أمۏتوحأمشۏثأإةەأڲۏأحًأتۏڬأضتهأ؏أتۏڬأوۄۏىەأڬۏأوتىىزأۄًأڲتأ؏أتۏڬأوۄۏىۄأ؏أتۏڬأۄلحەأڬۏأوتىىزأۄًأڲتأ؏أتۏڬأۄلحۄأ؏أتۏڬأزىأڬۏأوتىىزأۄًأڲتأ؏أتۏڬأزىأ؏أتۏڬأځۄشأڬۏأوتىىزأۄًأڲتأتًشأتۏڬأځۄشأ؏أإڲأڬەأتىڲتشەأ+أۏتأډىڲتشۏأ,أڬۏأوتىىزأۄًأڲتأ؏أحوأوۏڽأضەأڬًةۏأتۏڬأطرظأضًةەأڲتأتًشأتضأڬۏأوًحأ؏أتضأڬۏأزًىًڽأإىڬہًڽأڬەأزشوۏتىأۄًأڲۏأۗ‛‛أ
أ+أؼهتوۄأۄۏخوۏألشوتحەأۄۏڽأ=أ,أوۏڽأۏۄأڬۄحتأۄًڽأ=أۏۄأشًتۏحأتوتوأحشوسۏأىەأترحظتشأڬەأضتحہأىمهأڬۏأۄەأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأتځىەأتضحتزأومزتوأثىأزتازأڬەأذًتهەأضەأىمهأڬۏأۄەأتًشأًۄأعؼۏلأۄەأ؏أًۏضەأۏۄأثتحأڬۄۏأڲةۏأۄەأ=أڬۄأتضأڬۏأحًخۏمأڬۏأڲةۏأۄەأ؏أتضأشًتۏحأڬەأثمۏۄأشدتهأڬۏأحًخۏمأڬۏأڲةۏأۄەأۗ"
17865,"أذعشحأتثًزشزتؤأشعۏأتههۄأؼىۄأشًتۏحأڬشحەأۄۏڽأ=أىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=
أ““أدثأثہۏأضًشدأغهًؼأۄًحتأۄەأ؏أحًأتْضأڬەأضتحہأزًألشطحەأۄًحەأۄۏڽأ؏أدًأتؼهتىأڬشحەأۄۏڽأ=أتًشأزًأڲشًۄًڽأ+أۏؼىۏأدىتحأتًشأتىضتىًڽأ,أڬەأؼهتًۄأحوتوأتۄهأصوۏىأڬًأتْىأ+ألشطحًڽأ,أڬۏأإًتصأإحۏأۄەأ+أًۄأۏۄأڬۄحەأۄۏڽأ=أ,أ
أ““أتەأهًڲًأ$أتځىەأځشًشزڲتشأڬۏأغشلأإأدتاأ$أدًأډۏصأحہًڔۏأۄًأتًشأڬلتۏحأڬشأدتةەأ؏أًۄأتْضأضەأصۏتزۄأثۄحشأۄەأ؏أدًأصۏتزۄأۄًأتًشأؽتلهأڬشأزەأۗ‛‛أ
أۏۄأشًتۏحأتوتوأتذوزأىەأتًشأتوتوأغثشتىۏأىەأوؼدوأڬثۏشأوۏڽأىمهأڬۏأۄەأتًشأتىۄًڽأىەأتضأوۏڽأۏۄأتهلتػأصتىزأىمهأڬۏەأۄۏڽأ=أ
أ““أدثأضًشدأؽشًثأۄًحتأۄەأحًأتضأڬەأۄوشتۄأزًألشطحًڽأڬًأثہۏدتأدتحتأۄەأ؏أدًأثهىزأإًتصأوۏڽأۏۄأڬۄحەأۄۏڽأ=أتەأتههۄأ$أ+أتځىۏأشتۄأوۏڽأ,أرشډأڬشىەأًتهەأڬًأتْضأڬۏأدڲۄأوصۏزأؼغتألشوتأ$أتًشأ+أتځىۏأشتۄأوۏڽأ,أرشډأىۄأڬشىەأًتهەأ+أڬەأوتهأڬًأ,أعتةؼأڬشأزەأۗ‛‛أ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ؏أحتۄوأتىۄًڽأىەأۏۄأتهلتػأىمهأڬةەأۄۏڽأ=
أ““أتەأتههۄأ$أدًأرشډأڬشەأ؏أحًأتْضأڬۏأدڲۄأتضەأؼغتألشوتأ؏أتًشأدًأرشډأىۄأڬشەأ؏أتْضأ+أڬەأوتهأ,أڬًأعتةؼأڬشأزەأۗ‛‛أ
أتوتوأتذوزأڬەأشدتهأتًشأغثشتىۏأڬۏأوؼدوأڬثۏشأوۏڽأتضتىۏزأڬەأثؼعأشدتهأظذۏذأڬەأشدتهأۄۏڽأۗ"
17866,"أؼثزتهشذوىأثىأتثًضؼۏزأثۏتىأڬشحەأۄۏڽأ=أ+أشتًۏأڬۄحەأۄۏڽأ=أوۏشتأرۏتهأۄەأتىۄًڽأىەأۏۄأشًتۏحأتځىەأًتهزأڬەأذًتهەأضەأىمهأڬۏأۄەأ؏أۏۄأطڬأتثًؼثزتههۄأىتوۏأشتًۏأڬًأۄەأ,أًۄأ+أۏؼىۏأذعشحأتثًضؼۏزأرزشۏأشعۏأتههۄأؼىۄأ,أڬۄحەأۄۏڽأ=أوۏڽأىەأىثۏأتڬشوأ﷽أڬًأوىثشأځشأۏۄأتشطتزألشوتحەأۄًةەأضىتأۄەأ=
أ““أدًأډۏصأحہًڔۏأۄًأتًشأڬلتۏحأڬشأدتةەأ؏أًۄأتْضأضەأثۄحشأۄەأ؏أدًأصۏتزۄأۄًأتًشأؽتلهأڬشأزەأۗ‛‛أ
أۏۄأشًتۏحأتثًۏؼهۏٳأىەأىمهأڬۏأۄەأتًشأتضأڬەأشدتهأظذۏذأڬەأشدتهأۄۏڽأ؏أظشلأظزمۄأثىأشثۏؼأڬتأوؼتوهۄأورحهلأۄەأتًشأًۄأخمۄأۄەأۗ

