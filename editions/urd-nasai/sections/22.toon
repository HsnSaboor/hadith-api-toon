hadiths[345]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
2090,"قرہ رضی الله عنہ کہتے ہیں:  نبی اکرم صلی اللہ علیہ وسلم جب بیٹھتے تو آپ کے صحابہ کی ایک جماعت بھی آپ",,,,,2090
2091,ابوہریرہ رضی الله عنہ کہتے ہیں  موت کا فرشتہ موسیٰ علیہ السلام کے پاس بھیجا گیا، جب وہ ان کے پاس آیا,,,,,2091
2092,طلحہ بن عبیداللہ رضی الله عنہ سے روایت ہے کہ  ایک اعرابی رسول اللہ صلی اللہ علیہ وسلم کے پاس پراگندہ,,,,,2092
2093,"انس رضی الله عنہ کہتے ہیں:  ہمیں قرآن کریم میں نبی اکرم صلی اللہ علیہ وسلم سے لایعنی بات پوچھنے سے م",,,,,2093
2094,"انس بن مالک رضی الله عنہ کہتے ہیں:  ہم مسجد میں بیٹھے تھے کہ اسی دوران ایک شخص اونٹ پر آیا، اسے مسجد",,,,,2094
2095,انس بن مالک رضی الله عنہ کہتے ہیں  ہم رسول اللہ صلی اللہ علیہ وسلم کے پاس مسجد میں بیٹھے تھے کہ اسی ,,,,,2095
2096,ابوہریرہ رضی الله عنہ کہتے ہیں  نبی اکرم صلی اللہ علیہ وسلم اپنے صحابہ کے ساتھ تھے کہ اسی دوران دیہا,,,,,2096
2097,عبداللہ بن عباس رضی الله عنہما کہتے تھے  رسول اللہ صلی اللہ علیہ وسلم لوگوں میں سب سے زیادہ سخی آدمی,,,,,2097
2098,ام المؤمنین عائشہ رضی الله عنہا کہتی ہیں  رسول اللہ صلی اللہ علیہ وسلم نے کوئی لعنت ایسی نہیں کی جسے,,,,,2098
2099,"ابوہریرہ رضی الله عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا: ”جب رمضان کا مہینہ آتا",,,,,2099
