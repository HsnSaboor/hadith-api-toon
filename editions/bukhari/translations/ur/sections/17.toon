{"hadithnumber": "1067", "text": "ہم سے محمد بن بشار نے بیان کیا، کہا کہ ہم سے غندر محمد بن جعفر نے بیان کیا کہا کہ ہم سے شعبہ نے بیان"}
{"hadithnumber": "1068", "text": "ہم سے محمد بن یوسف فریابی نے بیان کیا، انہوں نے کہا کہ ہم سے سفیان ثوری نے بیان کیا، انہوں نے سعد بن"}
{"hadithnumber": "1069", "text": "ہم سے سلیمان بن حرب اور ابوالنعمان بن فضل نے بیان کیا، ان دونوں نے کہا کہ ہم سے حماد بن زید نے بیان"}
{"hadithnumber": "1070", "text": "ہم سے حفص بن عمر نے بیان کیا، کہا کہ ہم سے شعبہ نے، ابواسحاق سے بیان کیا، ان سے اسود نے، ان سے عبدال"}
{"hadithnumber": "1071", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے عبدالوارث نے بیان کیا، کہا ہم سے ایوب سختیانی نے بیان"}
{"hadithnumber": "1072", "text": "ہم سے سلیمان بن داؤد ابوالربیع نے بیان کیا، انہوں نے کہا کہ ہم سے اسماعیل بن جعفر نے بیان کیا، کہا ک"}
{"hadithnumber": "1073", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا کہ ہم سے ابن ابی ذئب نے بیان کیا، کہا کہ ہم سے یزید بن عبدالل"}
{"hadithnumber": "1074", "text": "ہم سے مسلم بن ابراہیم اور معاذ بن فضالہ نے بیان کیا، انہوں نے کہا کہ ہم سے ہشام بن ابی عبداللہ دستوا"}
{"hadithnumber": "1075", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے یحییٰ بن سعید قطان نے بیان کیا، کہا کہ ہم سے عبیداللہ"}
{"hadithnumber": "1076", "text": "ہم سے بشر بن آدم نے بیان کیا، کہا کہ ہم سے علی بن مسہر نے بیان کیا، کہا کہ ہمیں عبیداللہ عمری نے خبر"}
{"hadithnumber": "1077", "text": "ہم سے ابراہیم بن موسیٰ نے بیان کیا، انہوں نے کہا کہ ہمیں ہشام بن یوسف نے خبر دی اور انہیں ابن جریج ن"}
{"hadithnumber": "1078", "text": "ہم سے مسدد بن مسرہد نے بیان کیا، کہا کہ ہم سے معتمر بن سلیمان نے بیان کیا، کہا کہ میں نے اپنے باپ سے"}
{"hadithnumber": "1079", "text": "ہم سے صدقہ بن فضل نے بیان کیا، ان سے یحییٰ بن سعیدقطان نے بیان کیا، ان سے عبیداللہ نے، ان سے نافع نے"}
