أۏۄأشًتۏحأتوتوأثصتشأىەأتًشأتوتوأغثشتىۏأىەأوؼدوأتًضغأوۏڽأىمهأڬۏأۄەأ؏أتوتوأغثشتىۏأڬۏأضىزأوۏڽأتۏڬأشتًۏأؼوشأثىأشتطزأۄەأ؏أدضەأؼدهۏأىەأخمۄأمشتشأزۏتأۄەأ؏أتًشأدوۄًشأتةوۄأىەأتضەأعؼۏلأڬۄتأۄەأۗأتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأ؏أتوتوأثصتشأڬتأغشۏمأعؼۏلأۄەأۗ

[تخریج]: حديث : 12830 - اخرجه البزار في """"المسند"""" (1986)"
12831,"أذعشحأۏؼۏطأؽلتشۏأشعۏأتههۄأؼىۄأثۏتىأڬشحەأۄۏڽأ=أتۏڬأزىأىثۏأتڬشوأ﷽أىەأتًىټىۏأوىڲًتةۏأ؏أإځأىەأزشۏتلحأڬۏتأ=أڬًىأتضأڬتأزًزہأزًۄأهەأڲتأآأتۏڬأظتذثأىەأؼشعأڬۏأ=أوۏڽأۗأىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أحوۄتشتأىتوأڬۏتأۄەأآأتضأىەأؼشعأڬۏأ=أوشۄأ+أۏؼىۏأڬڔًتأ,أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوأثۏټہأدتاأۗأځہشأتۏڬأتًشأظتذثأڬہڔەأۄًةەأۗأىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أحوۄتشتأڬۏتأىتوأۄەأآأتضأىەأڬۄتأ=أوشۄأۗأىثۏأتڬشوأ﷽أىەأتشطتزألشوتۏتأ=أحوأثۏټہأدتاأۗأځہشأتۏڬأتًشأظتذثأڬہڔەأۄًةەأ؏أىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أحوۄتشتأىتوأڬۏتأۄەأآأتضأىەأدًتثأزۏتأ=أدوشۄأ+أۏؼىۏأتىڲتشۄأ,أىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوأثۏټہأدتاأۗأځہشأذعشحأۏؼۏطأشعۏأتههۄأؼىۄأڬہڔەأۄًةەأ؏أىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أحوۄتشتأىتوأڬۏتأۄەأآأتىۄًڽأىەأدًتثأزۏتأ=أۏؼۏطأۗأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوأتضأڬتأزًزہأزًۄأهًأۗأ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأىمهأڬۏأۄەأ؏أتًشأتضأڬۏأضىزأذضىأۄەأۗ

[تخریج]: حديث : 12831 - اخرجه الطبراني في """"المعجم الكبير """" (277/22)"
12832,"أذعشحأتثًذززشزأشعۏأتههۄأؼىۄأىثۏأتڬشوأ﷽أڬتأۏۄألشوتىأىمهأڬشحەأۄۏڽأ=أ
أ““أڬًىأۄوتشەأتىأتًىټًڽأڬًأۄتىڬأڬشأهەأدتةەأڲتأ+أشتًۏأڬًأطڬأۄەأطتۏزأۏۄأتهلتػأۄۏڽأ=أ,أڬًىأۄوتشەأتًىټًڽأڬًأ+أوىصهأومظًزأحڬأ,أځۄىډتةەأڲتأ؏أحًأتۏڬأظتذثأڬہڔەأۄًةەأ؏أىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أحوۄتشتأىتوأڬۏتأۄەأآأتىۄًڽأىەأدًتثأزۏتأ=ألهتڽأۗأځہشأتۏڬأتًشأظتذثأڬہڔەأۄًةەأتىۄًڽأىەأؼشعأڬۏأ=أوۏڽأتۏضتأڬشأزًڽأڲتأۗأىثۏأتڬشوأ﷽أىەأزشۏتلحأڬۏتأ=أحوۄتشتأىتوأڬۏتأۄەأآأتىۄًڽأىەأدًتثأزۏتأ=أىتدۏۄأۗأىثۏأتڬشوأ﷽أىەألشوتۏتأ=أحوأۏۄأڬتوأڬشًأڲەأ؏أحوأتىۄۏڽأهەأدتاأۗ
أۏۄأشًتۏحأتوتوأغثشتىۏأىەأتذوزأثىأثطۏشأڬەأذًتهەأضەأتضأڬەأډډتأضەأىمهأڬۏأۄەأ؏أتًشأوۏڽأىەأتىأزًىًڽأڬەأثتشەأوۏڽأڬًةۏأدشذأۏتأڬًةۏأحؼزۏهأىۄۏڽأځتةۏأۄەأۗأتضأشًتۏحأڬەأثمۏۄأشدتهأخمۄأۄۏڽأۗ

