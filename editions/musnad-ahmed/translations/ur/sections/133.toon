hadiths[1]{hadithnumber,text}:
15740,"أضؼۏزأثىأتثۏأشتطزأشذوۆأتههۄأؼهۏۄأڬۄحەأۄۏڽأڬۄأتۏڬأوشحثۄأذوظأوۏڽأوۏشۏأوهتمتحأحىًرۏأضەأۄًةۏأدًأىثۏأ﷽أڬەأځتضأۄشمهأڬەأتۏهډۏأثىأڬشأإةەأحہەأ؏أًۄأوۏشەأځڔًضۏأحہەأ؏أتىحۄتةۏأثًڔہەأۄًأډڬەأحہەأتًشأضټہۏتأدتىەأڬۏأؼوشأحڬأځۄىډأډڬەأحہەأ؏أوۏڽأىەأتىأضەأڬۄتأڬۄأإځأودہەأىثۏأ﷽أڬەأىتوأۄشمهأڬەأرغأتًشأۄشمهأڬەأىتوأىثۏأ﷽أڬەأرغأڬەأثتشەأڬډہأثحتحەأڬۏًڽأىۄۏڽأآأتىۄًڽأىەأڬۄتأڬۏًڽأىۄۏڽأ؏أىثۏأ﷽أحثًڬأوۏڽأحطشۏلأهتةەأۄًةەأحہەأ؏أإځأ﷽أىەأذعشحأزذۏۄأڬهثۏأشعۏأتههۄأؼىۄأڬًأۄشمهأڬەأځتضأثہۏدتأ؏أدثأۄشمهأڬەأځتضأىثۏأ﷽أڬتأوثتشڬأرغأځۄىډتأحًأتضأىەأشًوۏأځتزشۏًڽأتًشأضشزتشًڽأڬًأدوؼأڬۏتأتًشأڬوشەأڬتأزشًتصۄأثىزأڬشأهۏتأ؏أتًشأتىأضەأڬۄىەأهڲتأڬۄأۏۄأإزوۏأوۏشەأځتضأإۏتأۄەأدۏضتأڬۄأحوأىەأزۏڬہأۄۏأهۏتأۄەأ؏أودہەأدًأرغأثہۏدتأڲۏتأۄەأ؏أتضأوۏڽأودہەأحۏىأوۏڽأضەأڬضۏأتۏڬأظًشحأڬًأمثًهأڬشىەأڬۏأزؼًحأزۏأڲةۏأۄەأ؏أۏتأحًأوۏڽأتىأڬەأزۏىأڬۏأځۏشًۏأڬشأهًڽأ؏أۏتأتىۄۏڽأصوۏىأځشأوتهأڬۏأظًشحأوۏڽأټۏڬضأزًڽأتًشأصوۏىأۄوتشەأځتضأۄۏأشۄەأ؏أۏتأځہشأتىأضەأدىڲأڬشًڽأ؏أتههۄأڬۏأمضوأ$أإځأهًڲأدًأڬحتثۏڽأځڔہحەأۄًأ؏أتىأڬۏأشًطىۏأوۏڽأإځأدتىحەأۄًأڬۄأًۄأوۏشەأتىأمزوًڽأڬەأىۏډەأڬۏأدڲۄأثہۏأذتظهأڬشأهۏڽأڲەأ؏أحًأڬۏًڽأىۄأۄوأتىأڬۏأزۏىأڬۏأځۏشًۏأڬشأهۏڽأۏتأتځىۏأصوۏىأڬتأوتهأڬۏأظًشحأوۏڽأټۏڬضأزەأزۏتأڬشۏڽأۗأأۏۄأضىأڬشأتىأضثأڬەأىشرشًڽأضەأتۏڬأدۏضۏأإًتصأىڬهىەأهڲۏأ؏أذحۏأڬۄأتىۄًڽأىەأتځىۏأټًځۏتڽأتحتشأزۏڽأتًشأڬۄىەأهڲەأڬۄأڬۏتأإځأۄوۏڽأؼۏضتةۏحأډہًڔىەأڬۏأزؼًحأزەأشۄەأۄۏڽأ؏أۏتأۏۄأڬۄأۄوأڬضۏأزۏۄتحۏأڬەأ““أدًأذدتصأضەأإۏتأۄەأ‛‛أؽهتوأثىأدتةۏڽأ؏أدثأۄشمهأىەأزۏڬہتأڬۄأتڲشأۏۄأهًڲأتضأڬەأځتضأضەأتضۏأذتهأوۏڽأډهەأڲةەأحًأًۄأځًشەأشًوأوۏڽأتضأڬەأرهتلألضتزأثشځتأڬشأزۏڽأڲەأحًأتضأىەألًشتَأځۏىحشتأثزهأڬشأڬۄتأڬۄأوۏڽأىەأحًأۏۄأثتحأوذعأتضأهةەأڬۄۏأحہۏأڬۄأتځىەأزۏىأځشأحوۄتشتأدوتاأتًشأوعثًغۏأزۏڬہأضڬًڽأۗأأځہشأتضأىەأ““أؼشثأحدۏثأ‛‛أڬەأتۏڬأإزوۏأڬًأ““أدًأىظتشۏأؼشثأځشأتوۏشأومششأحہتأ‛‛أثهتۏتأتًشأڬۄتأڬۄأوۏشەأځتضأتۏضەأإزوۏأڬًأثهتأڬشأهتاأدًأذتلػۄأڬتأمًۏأۄًأتًشأؼشثۏأصثتىأدتىحتأۄًأ؏أحتڬۄأوۏڽأتضەأتضأطرظأڬۏأغشلأتضأڬەأرغأڬتأدًتثأزەأڬشأثہۏدًڽأ؏أًۄأودہەأثهتأهتۏتأ؏أۄشمهأىەأتځىتأرغأوۏشەأذًتهەأڬشأزۏتأتًشأڬۄىەأهڲتأڬۄأوۏشتأۏۄأرغأتضأطرظأڬەأځتضأهەأدتاأ؏أتڲشأتضأڬۏأضتشۏأثتحۏڽأحوأۏتزأىۄأشڬہأضڬًأحًأڬوأتصأڬوأحۏىأډۏصۏڽأعشًشأۏتزأشڬہأهۏىتأ؏أۏۄأزۏڬہىتأڬۄأًۄأوۏشۏأغشلأثہۏدەأۄًةەأتځىەأرغأڬتأڬًةۏأسڬشأڬشحەأۄۏڽأۏتأىۄۏڽأآأۏۄأزۏڬہىتأڬۄأدثأًۄأوۏشتأرغأځڔہحەأۄۏڽأحًشتحأڬتأسڬشأڬشحەأۄۏڽأۏتأىۄۏڽأآأتًشأتىأڬۏأځطحأځشأزۏڬہىتأ؏أحوۄۏڽأڬًةۏأؼدۏثأډۏصأزڬہتةۏأزۏحۏأۄەأۏتأىۄۏڽأآأوۏڽأۄشمهأڬتأرغأهەأڬشأشًتىۄأۄًتأتًشأحثًڬأځۄىډتأ؏أىثۏأ﷽أتځىەأظذتثۄأشعۏأتههۄأؼىۄوأڬەأزشوۏتىأځتىۏأڬەأمشۏثۏأؼهتمەأوۏڽأتځىۏأټتىڲًڽأڬەأڲشزأۄتحہًڽأضەأذهمۄأثىتأڬشأثۏټہەأۄًةەأحہەأ؏أوۏڽأىەأهًڲًڽأضەأځًډہتأڬۄأحوۄتشەأ““أضتحہۏأ‛‛أڬۄتڽأۄۏڽأآأتىۄًڽأىەأودہەأتطتشۄأضەأثحتأزۏتأ؏أوۏڽأډهحتأۄًتأإۏتأتًشأىثۏأ﷽أڬەأضتوىەأثۏټہأڲۏتأ؏أتىۄۏڽأرغأځڬڔتۏتأدضەأتىۄًڽأىەأتځىۏأڲًزأوۏڽأشڬہأهۏتأتًشأودہأضەأځًډہتأڬۄأحوۄتشتأحؼهمأڬۄتڽأضەأۄەأآأوۏڽأىەأڬۄتأڬۄأوۏڽأتۏڬأحىًرۏأإزوۏأۄًڽأ؏أىثۏأ﷽أىەأځًډہتأڬۄأحوۄۏڽأوهحأذىۏلۏۄأتضهتوأ““أدًأحوۄتشەأثتځأتثشتۄۏوأؼهۏۄأتهضهتوأڬۏأوهحأۄەأ‛‛أوۏڽأڬًةۏأشؽثحأوذضًضأۄًحۏأۄەأآأوۏڽأىەأڬۄتأڬۄأتۏڬأمًوأڬتأمتظزأۄًڽأتًشأتۏڬأمًوأڬەأزۏىأځشأۄًڽأ؏أوۏڽأدثأحڬأتىأڬۄأځتضأهًټأىۄأدتاڽأ؏أتضأزۏىأضەأثشڲطحۄأىۄۏڽأۄًأضڬحتأ؏أتضأځشأىثۏأ﷽أوضڬشتأڬشأۏۄأإۏحأځڔہىەأهڲەأڬۄأ““أدضەأإځأډتۄۏڽأتضەأۄزتۏحأىۄۏڽأزەأضڬحەأ؏أتهثحۄأتههۄأدضەأډتۄحتأۄەأ؏أۄزتۏحأزەأزۏحتأۄەأ؏أتًشأًۄأۄزتۏحأۏتلحۄأهًڲًڽأڬًأصۏتزۄأدتىحتأۄەأۗ‛‛أتەأحىًرۏأثہتةۏأ$أوۏڽأىەأتۏڬأرغأڬضشۏأڬۏأغشلأهڬہتأحہتأ؏أتضأىەأتضەأټڬڔەأټڬشەأڬشأزۏتأ؏أتههۄأتضەأتًشأتضأڬۏأذڬًوحأڬًأثہۏأټڬڔەأټڬشەأڬشأزەأڲتأ؏أوۏڽأىەأىدتطۏأڬۏأغشلأثہۏأرغأهڬہتأحہتأ؏أتضأىەأتضەأځہتڔأزۏتأ؏أتههۄأتضەأتًشأتضأڬۏأذڬًوحأڬًأحًشأځہًڔأزەأڲتأ؏أوۏڽأىەأحوۄتشەأثتزطتۄأڬًأثہۏأرغأهڬہتأهۏڬىأتضأىەأتضەأوذلًػأڬشأهۏتأ؏أهۄستأدثأحڬأصىزڲۏأوۏڽأڬًةۏأرۏشأشۄەأڲۏأ؏أهًڲًڽأځشأتضأڬتأشؼثأًأزثزثۄأثتمۏأشۄەأڲتأ؏أوۏڽأىەأتځىەأزهأوۏڽأضًډتأڬۄأۏۄأحۏىأوۏڽأضەأځۄهۏأثتحأۄەأدضأڬۏأودہەأثتزطتۄأىەأًظۏحأڬۏأحہۏأ؏أډىتىډۄأوۏڽأىەأتځىەأحشڬطأضەأتۏڬأحۏشأىڬتهتأتًشأتضأضەأتځىۏأحهًتشأڬۏأدهزأځشأۏۄأثتحأهڬہأهۏأۗأأځہشأىثۏأ﷽أىەأًۄأرغأتځىۏأثتةۏڽأدتىثأثۏټہەأۄًةەأتۏڬأإزوۏأڬًأزەأزۏتأ؏أوۏڽأىەأهًڲًڽأضەأځًډہتأڬۄأۏۄأرغأځڔہىەأًتهەأظتذثأڬًىأۄۏڽأآأهًڲًڽأىەأثحتۏتأڬۄأذعشحأتوۏشأوؼتًۏۄأشعۏأتههۄأؼىۄأۄۏڽأ؏أثۄشذتهأ$أۄوتشەأثتزطتۄأڬەأرغأوۏڽأهڬہتأۄًتأحہتأڬۄأإځأودہەأتضأدىحأڬۏأزؼًحأزۏحەأۄۏڽأدضأڬۏأډًڔتةۏأصوۏىأًأإضوتىأڬەأثشتثشأۄەأتًشأدًأوحمۏًڽأڬەأهةەأحۏتشأڬۏأڲةۏأۄەأ؏أحًأدۄىوأڬۄتڽأۄەأآأىثۏأ﷽أىەألشوتۏتأضثذتىأتههۄأ$أدثأزىأإحتأۄەأحًأشتحأڬۄتڽأدتحۏأۄەأآأوۏڽأىەأتځىەأحشڬطأضەأحۏشأىڬتهأڬشأتځىۏأحهًتشأڬۏأدهزأځشأۏۄأثتحأثہۏأهڬہأهۏأۗأأىثۏأ﷽أدثأرغأځڔہأڬشألتشؽأۄًةەأحًألشوتۏتأڬۄأحوۄتشتأۄوأځشأذمأثىحتأۄەأڬۏًىڬۄأحوأمتظزأۄًأ؏أتڲشأۄوتشەأځتضأڬًةۏأتىؼتوأۄًحتأحًأحوۄۏڽأعشًشأزۏحەأهۏڬىأتثہۏأۄوأضلشأوۏڽأځشتڲىزۄأۄۏڽأ؏أۏۄأضىأڬشأهًڲًڽأوۏڽأضەأتۏڬأإزوۏأىەأځڬتشأڬشأڬۄتأڬۄأوۏڽأتضەأتىؼتوأزًڽأڲتأ؏أډىتىډۄأتضأىەأتځىتأرۏوۄأڬہًهتأتًشأتۏڬأظلًشۏأذهۄأهەأإۏتأتًشأهتأڬشأوۏشۏأڲًزأوۏڽأڋتهأزۏتأ؏أوۏڽأىەأهًڲًڽأضەأځًډہتأڬۄأۏۄأتىؼتوأزۏىەأًتهەأظتذثأڬًىأۄۏڽأآأهًڲًڽأىەأثحتۏتأڬۄأۏۄأذعشحأؼخوتىأؽىۏأشعۏأتههۄأؼىۄأۄۏڽأۗأأځہشأىثۏأ﷽أىەألشوتۏتأڬەأحوأوۏڽأضەأڬًىأطرظأتضەأتځىتأوۄوتىأثىتةەأڲتأآأتضأځشأتۏڬأتىظتشۏأىًدًتىأىەأڬۄتأڬۄأوۏڽأثىتاڽأڲتأ؏أځہشأًۄأتىظتشۏأڬہڔتأۄًتأتًشأوۏڽأثہۏأڬہڔتأۄًأڲۏتأ؏أدثأوۏڽأودهضأضەأىڬهأڲۏتأحًأىثۏأ﷽أىەأودہەأځڬتشأڬشألشوتۏتأتەأحىًرۏأثہتةۏأ$أتزہشأإاأوۏڽأزًڔحتأۄًتأڲۏتأتًشأتضۏأدڲۄأځشأدتأڬشأڬہڔتأۄًأڲۏتأدۄتڽأوۏڽأځۄهەأثۏټہتأحہتأ؏أىثۏأ﷽أىەأتځىۏأځطحأضەأڬځڔتأۄټتۏتأتًشألشوتۏتأۏۄتڽأزۏڬہًأ؏أتًشأحوۄۏڽأدًأذڬوأزۏتأڲۏتأۄەأتضەأځًشتأڬشًأ؏أډىتىډۄأوۏڽأڲہًوأڬشأىثۏأ﷽أڬۏأځطحأوثتشڬأڬۏأغشلأإۏتأ؏أوۏڽأىەأڬىزہًڽأڬەأزشوۏتىأوۄشأىثًحأزۏڬہۏأدًأځہًهەأۄًةەأؽزًزأڬۏأوتىىزأحہۏأۗ"
