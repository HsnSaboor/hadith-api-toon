metadata:
  section_id: 4
  section_name: وضو کو واجب کرنے والے احدا?? کے ابواب کا مجموعہ
  hadith_first: 25
  hadith_last: 25

hadiths[1]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
25,"سیدنا عبدالله بن زید رضی اللہ عنہ بیان کرتے ہیں کہ میں نے رسول الله  صلی اللہ علیہ وسلم   سے اس آدمی کے متعلق پوچھا جو نماز کے دوران کچھ محسوس کرتا ہے۔ آپ  صلی اللہ علیہ وسلم   نے فرمایا: ”وہ (نماز توڑ کر) نہ پھرے حتیٰ کہ (ہوا خارج ہونے) کی آواز سن لے یا بو محسوس کر لے۔“",,,25,,وضو کو واجب کرنے والے احدا?? کے ابواب کا مجموعہ
