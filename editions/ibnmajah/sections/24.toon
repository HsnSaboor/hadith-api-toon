hadiths[count]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
2489,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ فُضَيْلٍ، عَنْ عُمَارَةَ بْنِ الْقَعْقَاعِ، عَنْ أَبِي زُرْعَةَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ أَعَدَّ اللَّهُ لِمَنْ خَرَجَ فِي سَبِيلِهِ لاَ يُخْرِجُهُ إِلاَّ جِهَادٌ فِي سَبِيلِي وَإِيمَانٌ بِي وَتَصْدِيقٌ بِرُسُلِي فَهُوَ عَلَىَّ ضَامِنٌ أَنْ أُدْخِلَهُ الْجَنَّةَ أَوْ أَرْجِعَهُ إِلَى مَسْكَنِهِ الَّذِي خَرَجَ مِنْهُ نَائِلاً مَا نَالَ مِنْ أَجْرٍ أَوْ غَنِيمَةٍ ‏""‏ ‏.‏ ثُمَّ قَالَ ‏""‏ وَالَّذِي نَفْسِي بِيَدِهِ لَوْلاَ أَنْ أَشُقَّ عَلَى الْمُسْلِمِينَ مَا قَعَدْتُ خِلاَفَ سَرِيَّةٍ تَخْرُجُ فِي سَبِيلِ اللَّهِ أَبَدًا وَلَكِنْ لاَ أَجِدُ سَعَةً فَأَحْمِلَهُمْ وَلاَ يَجِدُونَ سَعَةً فَيَتَّبِعُونِي وَلاَ تَطِيبُ أَنْفُسُهُمْ فَيَتَخَلَّفُونَ بَعْدِي وَالَّذِي نَفْسُ مُحَمَّدٍ بِيَدِهِ لَوَدِدْتُ أَنْ أَغْزُوَ فِي سَبِيلِ اللَّهِ فَأُقْتَلَ ثُمَّ أَغْزُوَ فَأُقْتَلَ ثُمَّ أَغْزُوَ فَأُقْتَلَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۶۶۵، ومصباح الزجاجة:۸۷۹),2489,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2490,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَأَبُو كُرَيْبٍ قَالاَ حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، عَنْ شَيْبَانَ، عَنْ فِرَاسٍ، عَنْ عَطِيَّةَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ الْمُجَاهِدُ فِي سَبِيلِ اللَّهِ مَضْمُونٌ عَلَى اللَّهِ إِمَّا أَنْ يَكْفِتَهُ إِلَى مَغْفِرَتِهِ وَرَحْمَتِهِ وَإِمَّا أَنْ يَرْجِعَهُ بِأَجْرٍ وَغَنِيمَةٍ وَمَثَلُ الْمُجَاهِدِ فِي سَبِيلِ اللَّهِ كَمَثَلِ الصَّائِمِ الْقَائِمِ الَّذِي لاَ يَفْتُرُ حَتَّى يَرْجِعَ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۴۵۳، ومصباح الزجاجة:۸۸)، وقد أخرجہ: مسند احمد (۳/۴۶۷،۴/۳۰۷)، سنن الدارمی/البیوع ۸۱ (۲۶۶۷),,It was\nnarrated from Abu Sa’eed Al-Khudri that the Prophet (ﷺ)\nsaid:,The Chapters on Jihad
2491,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَبْدُ اللَّهِ بْنُ سَعِيدٍ، قَالاَ حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ، عَنِ ابْنِ عَجْلاَنَ، عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ غَدْوَةٌ أَوْ رَوْحَةٌ فِي سَبِيلِ اللَّهِ خَيْرٌ مِنَ الدُّنْيَا وَمَا فِيهَا ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۳۹۴، ومصباح الزجاجة:۸۸۲),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2492,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا زَكَرِيَّا بْنُ مَنْظُورٍ، حَدَّثَنَا أَبُو حَازِمٍ، عَنْ سَهْلِ بْنِ سَعْدٍ السَّاعِدِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ غَدْوَةٌ أَوْ رَوْحَةٌ فِي سَبِيلِ اللَّهِ خَيْرٌ مِنَ الدُّنْيَا وَمَا فِيهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/البیوع ۷۸ (۴۶۵۰)،(تحفة الأشراف:۲۷۶۵)، وقد أخرجہ: صحیح مسلم/المساقاة ۲۸ (۱۶۰۸)، سنن ابی داود/البیوع ۷۵ (۳۵۱۳)، مسند احمد (۳/۳۱۲،۳۱۶،۳۵۷),,It was\nnarrated from Sahl bin Sa’d As-Sa’idi that the Messenger of\nAllah\n(ﷺ) said:,The Chapters on Jihad
2493,"حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، وَمُحَمَّدُ بْنُ الْمُثَنَّى، قَالاَ حَدَّثَنَا عَبْدُ الْوَهَّابِ الثَّقَفِيُّ، حَدَّثَنَا حُمَيْدٌ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لَغَدْوَةٌ أَوْ رَوْحَةٌ فِي سَبِيلِ اللَّهِ خَيْرٌ مِنَ الدُّنْيَا وَمَا فِيهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۱۳۱، ومصباح الزجاجة:۸۸۳),,It was\nnarrated from Anas bin Malik that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2494,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، حَدَّثَنَا لَيْثُ بْنُ سَعْدٍ، عَنْ يَزِيدَ بْنِ عَبْدِ اللَّهِ بْنِ الْهَادِ، عَنِ الْوَلِيدِ بْنِ أَبِي الْوَلِيدِ، عَنْ عُثْمَانَ بْنِ عَبْدِ اللَّهِ بْنِ سُرَاقَةَ، عَنْ عُمَرَ بْنِ الْخَطَّابِ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ مَنْ جَهَّزَ غَازِيًا فِي سَبِيلِ اللَّهِ حَتَّى يَسْتَقِلَّ كَانَ لَهُ مِثْلُ أَجْرِهِ حَتَّى يَمُوتَ أَوْ يَرْجِعَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/البیوع ۷۵ (۳۵۱۸)، سنن الترمذی/الأحکام ۳۲ (۱۳۶۹)،(تحفة الأشراف:۲۴۳۴)، وقد أخرجہ: سنن الدارمی/البیوع ۸۳ (۲۶۶۹),,It was\nnarrated that ‘Umar bin Khattab said:,The Chapters on Jihad
2495,"حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ عَبْدِ الْمَلِكِ بْنِ أَبِي سُلَيْمَانَ، عَنْ عَطَاءٍ، عَنْ زَيْدِ بْنِ خَالِدٍ الْجُهَنِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ جَهَّزَ غَازِيًا فِي سَبِيلِ اللَّهِ كَانَ لَهُ مِثْلُ أَجْرِهِ مِنْ غَيْرِ أَنْ يَنْقُصَ مِنْ أَجْرِ الْغَازِي شَيْئًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الشفعة ۲ (۲۲۵۸)، الحیل ۱۴ (۶۹۷۷)،۱۵ (۶۹۸۱،۶۹۷۸)، سنن ابی داود/البیوع ۷۵ (۳۵۱۶)، سنن النسائی/البیوع ۱۰۷ (۴۷۰۶)،(تحفة الأشراف:۱۲۰۲۷)، وقد أخرجہ: مسند احمد (۴/۳۸۹،۳۹۰،۶/۱۰،۳۹۰),,It was\nnarrated from Zaid bin Khalid Al-Juhani that the Messenger of\nAllah\n(ﷺ) said:,The Chapters on Jihad
2496,"حَدَّثَنَا عِمْرَانُ بْنُ مُوسَى اللَّيْثِيُّ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، حَدَّثَنَا أَيُّوبُ، عَنْ أَبِي قِلاَبَةَ، عَنْ أَبِي أَسْمَاءَ، عَنْ ثَوْبَانَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ أَفْضَلُ دِينَارٍ يُنْفِقُهُ الرَّجُلُ دِينَارٌ يُنْفِقُهُ عَلَى عِيَالِهِ وَدِينَارٌ يُنْفِقُهُ عَلَى فَرَسٍ فِي سَبِيلِ اللَّهِ وَدِينَارٌ يُنْفِقُهُ الرَّجُلُ عَلَى أَصْحَابِهِ فِي سَبِيلِ اللَّهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/البیوع ۱۰۷ (۴۷۰۷)،(تحفة الأشراف:۴۸۴۰),,It was\nnarrated from Thawban that the Messenger of Allah (ﷺ) said:,The Chapters on Jihad
2497,"حَدَّثَنَا هَارُونُ بْنُ عَبْدِ اللَّهِ الْحَمَّالُ، حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ، عَنِ الْخَلِيلِ بْنِ عَبْدِ اللَّهِ، عَنِ الْحَسَنِ، عَنْ عَلِيِّ بْنِ أَبِي طَالِبٍ، وَأَبِي الدَّرْدَاءِ، وَأَبِي، هُرَيْرَةَ وَأَبِي أُمَامَةَ الْبَاهِلِيِّ وَعَبْدِ اللَّهِ بْنِ عُمَرَ وَعَبْدِ اللَّهِ بْنِ عَمْرٍو وَجَابِرِ بْنِ عَبْدِ اللَّهِ وَعِمْرَانَ بْنِ الْحُصَيْنِ كُلُّهُمْ يُحَدِّثُ عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ قَالَ ‏""‏ مَنْ أَرْسَلَ بِنَفَقَةٍ فِي سَبِيلِ اللَّهِ وَأَقَامَ فِي بَيْتِهِ فَلَهُ بِكُلِّ دِرْهَمٍ سَبْعُمِائَةِ دِرْهَمٍ وَمَنْ غَزَا بِنَفْسِهِ فِي سَبِيلِ اللَّهِ وَأَنْفَقَ فِي وَجْهِ ذَلِكَ فَلَهُ بِكُلِّ دِرْهَمٍ سَبْعُمِائَةِ أَلْفِ دِرْهَمٍ ‏""‏ ‏.‏ ثُمَّ تَلاَ هَذِهِ الآيَةَ ‏{وَاللَّهُ يُضَاعِفُ لِمَنْ يَشَاءُ}‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۲۴۱،۱۵۲۴۹)، مصباح الزجاجة:۸۸۴)، وقد أخرجہ: سنن ابی داود/البیوع ۷۵ (۳۵۱۵),2497,"It was\nnarrated from ‘Ali bin Abu Talib, Abu Darda’, Abu Hurairah, Abu\nUmamah Al-Bahili, ‘Abdullah bin ‘Umar, ‘Abdullah bin ‘Amr,\nJabir bin\n‘Abdullah and ‘Imran bin Husain, all of them narrating\nthat the\nMessenger of Allah (ﷺ) said:",The Chapters on Jihad
2498,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا يَحْيَى بْنُ الْحَارِثِ الذِّمَارِيُّ، عَنِ الْقَاسِمِ، عَنْ أَبِي أُمَامَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ لَمْ يَغْزُ أَوْ يُجَهِّزْ غَازِيًا أَوْ يَخْلُفْ غَازِيًا فِي أَهْلِهِ بِخَيْرٍ أَصَابَهُ اللَّهُ سُبْحَانَهُ بِقَارِعَةٍ قَبْلَ يَوْمِ الْقِيَامَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «انظرحدیث رقم:(۲۴۹۵),,It was\nnarrated from Abu Umamah that the Prophet (ﷺ) said:,The Chapters on Jihad
2499,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْوَلِيدُ، حَدَّثَنَا أَبُو رَافِعٍ، - هُوَ إِسْمَاعِيلُ بْنُ رَافِعٍ - عَنْ سُمَىٍّ، - مَوْلَى أَبِي بَكْرٍ - عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ لَقِيَ اللَّهَ وَلَيْسَ لَهُ أَثَرٌ فِي سَبِيلِ اللَّهِ لَقِيَ اللَّهَ وَفِيهِ ثُلْمَةٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/البیوع ۹۶ (۲۲۱۳)،۹۷ (۲۲۱۴)، الشفعة ۲ (۲۲۵۷)، الحیل ۱۴ (۷۶ ۶۹)، الشرکة ۸ (۹۵ ۲۴)، سنن ابی داود/البیوع ۷۵ (۳۵۱۴)، سنن الترمذی/الأحکام ۳۳ (۱۳۷۰)،(تحفة الأشراف:۳۱۵۳)، وقد أخرجہ: سنن النسائی/البیوع ۱۰۷ (۴۷۰۸)، موطا امام مالک/الشفعة ۱ (۱)، مسند احمد (۳/۳۷۲،۳۹۹)، سنن الدارمی/البیوع ۸۳ (۲۶۷۰),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2500,"حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنْ حُمَيْدٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ لَمَّا رَجَعَ رَسُولُ اللَّهِ صلى الله عليه وسلم مِنْ غَزْوَةِ تَبُوكَ فَدَنَا مِنَ الْمَدِينَةِ قَالَ ‏""‏ إِنَّ بِالْمَدِينَةِ لَقَوْمًا مَا سِرْتُمْ مِنْ مَسِيرٍ وَلاَ قَطَعْتُمْ وَادِيًا إِلاَّ كَانُوا مَعَكُمْ فِيهِ ‏""‏ ‏.‏ قَالُوا يَا رَسُولَ اللَّهِ وَهُمْ بِالْمَدِينَةِ قَالَ ‏""‏ وَهُمْ بِالْمَدِينَةِ حَبَسَهُمُ الْعُذْرُ ‏""‏ ‏.‏",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۲۹۲، ومصباح الزجاجة:۸۸۶),2500,It was\nnarrated that Anas bin Malik said:,The Chapters on Jihad
2501,"حَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ أَبِي سُفْيَانَ، عَنْ جَابِرٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّ بِالْمَدِينَةِ رِجَالاً مَا قَطَعْتُمْ وَادِيًا وَلاَ سَلَكْتُمْ طَرِيقًا إِلاَّ شَرِكُوكُمْ فِي الأَجْرِ حَبَسَهُمُ الْعُذْرُ ‏""""‏ ‏.‏ قَالَ أَبُو عَبْدِ اللَّهِ بْنُ مَاجَهْ أَوْ كَمَا قَالَ كَتَبْتُهُ لَفْظًا ‏.‏""",Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۲۹۳، ومصباح الزجاجة:۸۸۷),,It was\nnarrated from Jabir that the Messenger of Allah (ﷺ) said:,The Chapters on Jihad
2502,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ زَيْدِ بْنِ أَسْلَمَ، عَنْ أَبِيهِ، عَنْ مُصْعَبِ بْنِ ثَابِتٍ، عَنْ عَبْدِ اللَّهِ بْنِ الزُّبَيْرِ، قَالَ خَطَبَ عُثْمَانُ بْنُ عَفَّانَ النَّاسَ فَقَالَ يَا أَيُّهَا النَّاسُ إِنِّي سَمِعْتُ حَدِيثًا مِنْ رَسُولِ اللَّهِ صلى الله عليه وسلم لَمْ يَمْنَعْنِي أَنْ أُحَدِّثَكُمْ بِهِ إِلاَّ الضِّنُّ بِكُمْ وَبِصَحَابَتِكُمْ فَلْيَخْتَرْ مُخْتَارٌ لِنَفْسِهِ أَوْ لِيَدَعْ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ مَنْ رَابَطَ لَيْلَةً فِي سَبِيلِ اللَّهِ سُبْحَانَهُ كَانَتْ كَأَلْفِ لَيْلَةٍ صِيَامِهَا وَقِيَامِهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۳۵۱، ومصباح الزجاجة:۸۸۸)، وقد أخرجہ: مسند احمد (۴/۲۵),,It was\nnarrated that ‘Abdullah bin Zubair said:,The Chapters on Jihad
2503,"حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الأَعْلَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي اللَّيْثُ، عَنْ زُهْرَةَ بْنِ مَعْبَدٍ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ مَاتَ مُرَابِطًا فِي سَبِيلِ اللَّهِ أَجْرَى عَلَيْهِ أَجْرَ عَمَلِهِ الصَّالِحِ الَّذِي كَانَ يَعْمَلُ وَأَجْرَى عَلَيْهِ رِزْقَهُ وَأَمِنَ مِنَ الْفَتَّانِ وَبَعَثَهُ اللَّهُ يَوْمَ الْقِيَامَةِ آمِنًا مِنَ الْفَزَعِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/اللقطة ۱ (۱۷۲۰)،(تحفة الأشراف:۳۲۳۳)، وقد أخرجہ: مسند احمد (۴/۳۶۰،۳۶۲),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2504,"حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ بْنِ سَمُرَةَ، حَدَّثَنَا مُحَمَّدُ بْنُ يَعْلَى السُّلَمِيُّ، حَدَّثَنَا عُمَرُ بْنُ صُبْحٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَمْرٍو، عَنْ مَكْحُولٍ، عَنْ أُبَىِّ بْنِ كَعْبٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لَرِبَاطُ يَوْمٍ فِي سَبِيلِ اللَّهِ مِنْ وَرَاءِ عَوْرَةِ الْمُسْلِمِينَ مُحْتَسِبًا مِنْ غَيْرِ شَهْرِ رَمَضَانَ أَعْظَمُ أَجْرًا مِنْ عِبَادَةِ مِائَةِ سَنَةٍ صِيَامِهَا وَقِيَامِهَا وَرِبَاطُ يَوْمٍ فِي سَبِيلِ اللَّهِ مِنْ وَرَاءِ عَوْرَةِ الْمُسْلِمِينَ مُحْتَسِبًا مِنْ شَهْرِ رَمَضَانَ أَفْضَلُ عِنْدَ اللَّهِ وَأَعْظَمُ أَجْرًا - أُرَاهُ قَالَ - مِنْ عِبَادَةِ أَلْفِ سَنَةٍ صِيَامِهَا وَقِيَامِهَا فَإِنْ رَدَّهُ اللَّهُ إِلَى أَهْلِهِ سَالِمًا لَمْ تُكْتَبْ عَلَيْهِ سَيِّئَةٌ أَلْفَ سَنَةٍ وَتُكْتَبُ لَهُ الْحَسَنَاتُ وَيُجْرَى لَهُ أَجْرُ الرِّبَاطِ إِلَى يَوْمِ الْقِيَامَةَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/اللقطة ۱ (۲۴۲۶)، صحیح مسلم/اللقطة ۱ (۱۷۲۲)، سنن ابی داود/اللقطة ۱ (۱۷۰۴،۱۷۰۵)، سنن الترمذی/الاحکام ۳۵ (۱۳۷۲)،(تحفة الأشراف:۳۷۶۳)، وقد أخرجہ: موطا امام مالک/الأقضیة ۳۸ (۴۶،۴۷)، مسند احمد (۴/۱۱۵،۱۱۶،۱۱۷),,It was\nnarrated that Ubayy bin Ka’b said:,The Chapters on Jihad
2505,"حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، عَنْ صَالِحِ بْنِ مُحَمَّدِ بْنِ زَائِدَةَ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِيزِ، عَنْ عُقْبَةَ بْنِ عَامِرٍ الْجُهَنِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ رَحِمَ اللَّهُ حَارِسَ الْحَرَسِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/اللقطة ۱ (۱۷۰۹)،(تحفة الأشراف:۱۱۰۱۳)، وقد أخرجہ: مسند احمد (۴/۱۶۲،۲۶۶),,It was\nnarrated from ‘Uqbah bin ‘Amir Al-Juhani that the Messenger of\nAllah (ﷺ) said:,The Chapters on Jihad
2506,"حَدَّثَنَا عِيسَى بْنُ يُونُسَ الرَّمْلِيُّ، حَدَّثَنَا مُحَمَّدُ بْنُ شُعَيْبِ بْنِ شَابُورَ، عَنْ سَعِيدِ بْنِ خَالِدِ بْنِ أَبِي الطَّوِيلِ، قَالَ سَمِعْتُ أَنَسَ بْنَ مَالِكٍ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ حَرْسُ لَيْلَةٍ فِي سَبِيلِ اللَّهِ أَفْضَلُ مِنْ صِيَامِ رَجُلٍ وَقِيَامِهِ فِي أَهْلِهِ أَلْفَ سَنَةٍ السَّنَةُ ثَلاَثُمِائَةٍ وَسِتُّونَ يَوْمًا وَالْيَوْمُ كَأَلْفِ سَنَةٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/اللقطة ۱ (۲۴۲۶)، صحیح مسلم/اللقطة ۱ (۱۷۲۳)، سنن ابی داود/اللقطة ۱ (۱۷۰۱،۱۷۰۲)، سنن الترمذی/الأحکام ۳۵ (۱۳۷۴)،(تحفة الأشراف:۲۸)، وقد أخرجہ: مسند احمد (۵/۱۲۶،۱۲۷),,It was\nnarrated that Sa’eed bin Khalid bin Abu Tuwail said:,The Chapters on Jihad
2507,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ أُسَامَةَ بْنِ زَيْدٍ، عَنْ سَعِيدٍ الْمَقْبُرِيِّ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ لِرَجُلٍ ‏ ‏ أُوصِيكَ بِتَقْوَى اللَّهِ وَالتَّكْبِيرِ عَلَى كُلِّ شَرَفٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/اللقطة ۱ (۱۷۲۲)، سنن ابی داود/اللقطة ۱ (۱۷۰۶)، سنن الترمذی/الأحکام ۳۵ (۱۳۷۲،۱۳۷۳)،(تحفة الأشراف:۳۷۴۸)، وقد أخرجہ: مسند احمد (۴/۱۱۶،۵/۱۹۳),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid to\na man:,The Chapters on Jihad
2508,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، أَنْبَأَنَا حَمَّادُ بْنُ زَيْدٍ، عَنْ ثَابِتٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ ذُكِرَ النَّبِيُّ صلى الله عليه وسلم فَقَالَ كَانَ أَحْسَنَ النَّاسِ وَكَانَ أَجْوَدَ النَّاسِ وَكَانَ أَشْجَعَ النَّاسِ وَلَقَدْ فَزِعَ أَهْلُ الْمَدِينَةِ لَيْلَةً فَانْطَلَقُوا قِبَلَ الصَّوْتِ فَتَلَقَّاهُمْ رَسُولُ اللَّهِ صلى الله عليه وسلم وَقَدْ سَبَقَهُمْ إِلَى الصَّوْتِ وَهُوَ عَلَى فَرَسٍ لأَبِي طَلْحَةَ عُرْىٍ مَا عَلَيْهِ سَرْجٌ فِي عُنُقِهِ السَّيْفُ وَهُوَ يَقُولُ ‏""‏ يَا أَيُّهَا النَّاسُ لَنْ تُرَاعُوا ‏""‏ ‏.‏ يَرُدُّهُمْ ثُمَّ قَالَ لِلْفَرَسِ ‏""‏ وَجَدْنَاهُ بَحْرًا ‏""‏ ‏.‏ أَوْ ‏""‏ إِنَّهُ لَبَحْرٌ ‏""‏ ‏.‏ قَالَ حَمَّادٌ وَحَدَّثَنِي ثَابِتٌ أَوْ غَيْرُهُ قَالَ كَانَ فَرَسًا لأَبِي طَلْحَةَ يُبَطَّأُ فَمَا سُبِقَ بَعْدَ ذَلِكَ الْيَوْمِ ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الخراج ۴۰ (۳۰۸۷)،(تحفة الأشراف:۱۱۵۵۰),2508,"It was\nnarrated from Hammad bin Zaid from Thabit, that the Prophet\n(ﷺ) was\nmentioned before Anas bin Malik and he said:",The Chapters on Jihad
2509,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ بَكَّارِ بْنِ عَبْدِ الْمَلِكِ بْنِ الْوَلِيدِ بْنِ بُسْرِ بْنِ أَبِي أَرْطَاةَ، حَدَّثَنَا الْوَلِيدُ، حَدَّثَنِي شَيْبَانُ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنِ ابْنِ عَبَّاسٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏ ‏ إِذَا اسْتُنْفِرْتُمْ فَانْفِرُوا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحدود ۱۱ (۱۷۱۰)، سنن ابی داود/الخراج ۴۰ (۳۰۸۵)، سنن الترمذی/الأحکام ۳۷ (۱۳۷۷)، سنن النسائی/الزکاة ۲۸ (۲۴۹۷)،(تحفة الأشراف:۱۳۱۲۸،۱۵۱۴۷)، وقد أخرجہ: صحیح البخاری/الزکاة ۶۶ (۱۴۹۹)، المساقاة ۳ (۲۳۵۵)، الدیات ۲۸ (۶۹۱۲)،۲۹ (۶۹۱۳)، موطا امام مالک/ العقول ۱۸ (۱۲)، مسند احمد (۲/۲۲۸،۲۲۹،۲۵۴،۲۷۴،۲۸۵،۳۱۹،۳۸۲،۳۸۶،۴۰۶،۴۱۱،۴۱۴،۴۵۴،۴۵۶،۴۶۷،۴۷۵،۴۸۲،۴۸۲،۴۹۵،۴۹۹،۵۰۱،۵۰۷)، سنن الدارمی/الزکاة ۳۰ (۱۷۱۰)، الدیات ۹ (۲۴۲۲),,It was\nnarrated from Ibn ‘Abbas that the Prophet (ﷺ) said:,The Chapters on Jihad
2510,"حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ، - مَوْلَى آلِ طَلْحَةَ - عَنْ عِيسَى بْنِ طَلْحَةَ، عَنْ أَبِي هُرَيْرَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ لاَ يَجْتَمِعُ غُبَارٌ فِي سَبِيلِ اللَّهِ وَدُخَانُ جَهَنَّمَ فِي جَوْفِ عَبْدٍ مُسْلِمٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۱۲۹، ومصباح الزجاجة:۸۸۹)، وقد أخرجہ: مسند احمد (۱/۳۱۴،۳/۱۸۰),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,The Chapters on Jihad
2511,"حَدَّثَنَا مُحَمَّدُ بْنُ سَعِيدِ بْنِ يَزِيدَ بْنِ إِبْرَاهِيمَ التُّسْتَرِيُّ، حَدَّثَنَا أَبُو عَاصِمٍ، عَنْ شَبِيبٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ رَاحَ رَوْحَةً فِي سَبِيلِ اللَّهِ كَانَ لَهُ بِمِثْلِ مَا أَصَابَهُ مِنَ الْغُبَارِ مِسْكًا يَوْمَ الْقِيَامَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۲۹۶)، وقد أخرجہ: صحیح البخاری/الأنبیاء ۵۴ (۳۴۷۲)، صحیح مسلم/الأقضیة ۱۱ (۱۷۲۱)، مسند احمد (۲/۳۱۶),,It was\nnarrated from Anas bin Malik that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2512,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنِ ابْنِ حَبَّانَ، - هُوَ مُحَمَّدُ بْنُ يَحْيَى بْنِ حَبَّانَ - عَنْ أَنَسِ بْنِ مَالِكٍ، عَنْ خَالَتِهِ أُمِّ حَرَامٍ بِنْتِ مِلْحَانَ، أَنَّهَا قَالَتْ نَامَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَوْمًا قَرِيبًا مِنِّي ثُمَّ اسْتَيْقَظَ يَبْتَسِمُ فَقُلْتُ يَا رَسُولَ اللَّهِ مَا أَضْحَكَكَ قَالَ ‏""‏ نَاسٌ مِنْ أُمَّتِي عُرِضُوا عَلَىَّ يَرْكَبُونَ ظَهْرَ هَذَا الْبَحْرِ كَالْمُلُوكِ عَلَى الأَسِرَّةِ ‏""‏ ‏.‏ قَالَتْ فَادْعُ اللَّهَ أَنْ يَجْعَلَنِي مِنْهُمْ ‏.‏ قَالَ فَدَعَا لَهَا ثُمَّ نَامَ الثَّانِيَةَ فَفَعَلَ مِثْلَهَا ثُمَّ قَالَتْ مِثْلَ قَوْلِهَا فَأَجَابَهَا مِثْلَ جَوَابِهِ الأَوَّلِ ‏.‏ قَالَتْ فَادْعُ اللَّهَ أَنْ يَجْعَلَنِي مِنْهُمْ قَالَ ‏""‏ أَنْتِ مِنَ الأَوَّلِينَ ‏""‏ ‏.‏ قَالَ فَخَرَجَتْ مَعَ زَوْجِهَا عُبَادَةَ بْنِ الصَّامِتِ غَازِيَةً أَوَّلَ مَا رَكِبَ الْمُسْلِمُونَ الْبَحْرَ مَعَ مُعَاوِيَةَ بْنِ أَبِي سُفْيَانَ فَلَمَّا انْصَرَفُوا مِنْ غَزَاتِهِمْ قَافِلِينَ فَنَزَلُوا الشَّامَ فَقُرِّبَتْ إِلَيْهَا دَابَّةٌ لِتَرْكَبَ فَصَرَعَتْهَا فَمَاتَتْ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/البیوع ۵۹ (۲۱۴۱)،۱۱۰ (۲۲۳۰)، الإاستقراض ۱۶ (۲۴۰۳)، الخصومات ۳ (۲۴۱۵)، العقتق ۹ (۲۵۳۴)، کفارات الأیمان ۷ (۶۷۱۶)، الإکراہ ۴ (۶۹۴۷)، الأحکام ۳۲ (۷۱۸۶)، سنن ابی داود/العتق ۹ (۳۹۵۵)، سنن النسائی/البیوع ۸۳ (۴۶۵۸)،(تحفة الأشراف:۲۴۱۶)، وقد أخرجہ: صحیح مسلم/الزکاة ۱۳ (۹۹۷)، سنن الترمذی/البیوع ۱۱ (۱۲۱۹)، مسند احمد (۳/۳۰۱،۳۰۸،۳۶۵،۳۹۰)، سنن الدارمی/البیوع ۳۷ (۲۶۱۵),2512,It was\nnarrated from Anas bin Malik that his maternal aunt Umm Harim\nbint\nMilhan said:,The Chapters on Jihad
2513,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا بَقِيَّةُ، عَنْ مُعَاوِيَةَ بْنِ يَحْيَى، عَنْ لَيْثِ بْنِ أَبِي سُلَيْمٍ، عَنْ يَحْيَى بْنِ عَبَّادٍ، عَنْ أُمِّ الدَّرْدَاءِ، عَنْ أَبِي الدَّرْدَاءِ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ غَزْوَةٌ فِي الْبَحْرِ مِثْلُ عَشْرِ غَزَوَاتٍ فِي الْبَرِّ وَالَّذِي يَسْدَرُ فِي الْبَحْرِ كَالْمُتَشَحِّطِ فِي دَمِهِ فِي سَبِيلِ اللَّهِ سُبْحَانَهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih Hadith; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/البیوع ۱۱۰ (۲۲۳۱)، صحیح مسلم/الزکاة ۱۳ (۹۹۷)، سنن الترمذی/البیوع ۱۱ (۱۲۱۹)،(تحفة الأشراف:۲۵۲۶)، وقد أخرجہ: مسند احمد (۳/۳۰۸),,It was\nnarrated from Abu Darda’ that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2514,"حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ يُوسُفَ الْجُبَيْرِيُّ، حَدَّثَنَا قَيْسُ بْنُ مُحَمَّدٍ الْكِنْدِيُّ، حَدَّثَنَا عُفَيْرُ بْنُ مَعْدَانَ الشَّامِيُّ، عَنْ سُلَيْمِ بْنِ عَامِرٍ، قَالَ سَمِعْتُ أَبَا أُمَامَةَ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ شَهِيدُ الْبَحْرِ مِثْلُ شَهِيدَىِ الْبَرِّ وَالْمَائِدُ فِي الْبَحْرِ كَالْمُتَشَحِّطِ فِي دَمِهِ فِي الْبَرِّ وَمَا بَيْنَ الْمَوْجَتَيْنِ كَقَاطِعِ الدُّنْيَا فِي طَاعَةِ اللَّهِ وَإِنَّ اللَّهَ عَزَّ وَجَلَّ وَكَلَ مَلَكَ الْمَوْتِ بِقَبْضِ الأَرْوَاحِ إِلاَّ شَهِيدَ الْبَحْرِ فَإِنَّهُ يَتَوَلَّى قَبْضَ أَرْوَاحِهِمْ وَيَغْفِرُ لِشَهِيدِ الْبَرِّ الذُّنُوبَ كُلَّهَا إِلاَّ الدَّيْنَ وَلِشَهِيدِ الْبَحْرِ الذُّنُوبَ وَالدَّيْنَ ‏""""‏ ‏.‏""",Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۰۶۵، ومصباح الزجاجة:۸۹۰),,It was\nnarrated that Sulaim bin ‘Amr said:,The Chapters on Jihad
2515,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا أَبُو دَاوُدَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ الْوَاسِطِيُّ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ح وَحَدَّثَنَا عَلِيُّ بْنُ الْمُنْذِرِ، حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ، كُلُّهُمْ عَنْ قَيْسٍ، عَنْ أَبِي حُصَيْنٍ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لَوْ لَمْ يَبْقَ مِنَ الدُّنْيَا إِلاَّ يَوْمٌ لَطَوَّلَهُ اللَّهُ عَزَّ وَجَلَّ حَتَّى يَمْلِكَ رَجُلٌ مِنْ أَهْلِ بَيْتِي يَمْلِكُ جَبَلَ الدَّيْلَمِ وَالْقُسْطَنْطِينِيَّةَ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۰۲۳، ومصباح الزجاجة:۸۹۱)، وقد أخرجہ: مسند احمد (۱/۳۰۳،۳۱۷،۳۲۰)، سنن الدارمی/البیوع ۳۸ (۲۶۱۶),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2516,"حَدَّثَنَا إِسْمَاعِيلُ بْنُ أَسَدٍ، حَدَّثَنَا دَاوُدُ بْنُ الْمُحَبَّرِ، أَنْبَأَنَا الرَّبِيعُ بْنُ صَبِيحٍ، عَنْ يَزِيدَ بْنِ أَبَانَ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ سَتُفْتَحُ عَلَيْكُمُ الآفَاقُ وَسَتُفْتَحُ عَلَيْكُمْ مَدِينَةٌ يُقَالُ لَهَا قَزْوِينُ مَنْ رَابَطَ فِيهَا أَرْبَعِينَ يَوْمًا أَوْ أَرْبَعِينَ لَيْلَةً كَانَ لَهُ فِي الْجَنَّةِ عَمُودٌ مِنْ ذَهَبٍ عَلَيْهِ زَبَرْجَدَةٌ خَضْرَاءُ عَلَيْهَا قُبَّةٌ مِنْ يَاقُوتَةٍ حَمْرَاءَ لَهَا سَبْعُونَ أَلْفَ مِصْرَاعٍ مِنْ ذَهَبٍ عَلَى كُلِّ مِصْرَاعٍ زَوْجَةٌ مِنَ الْحُورِ الْعِينِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۰۲۴، ومصباح الزجاجة:۸۹۴),,It was\nnarrated from Anas bin Malik that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2517,"حَدَّثَنَا أَبُو يُوسُفَ، مُحَمَّدُ بْنُ أَحْمَدَ الرَّقِّيُّ حَدَّثَنَا مُحَمَّدُ بْنُ سَلَمَةَ الْحَرَّانِيُّ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ مُحَمَّدِ بْنِ طَلْحَةَ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِي بَكْرٍ الصِّدِّيقِ، عَنْ مُعَاوِيَةَ بْنِ جَاهِمَةَ السُّلَمِيِّ، قَالَ أَتَيْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم فَقُلْتُ يَا رَسُولَ اللَّهِ إِنِّي كُنْتُ أَرَدْتُ الْجِهَادَ مَعَكَ أَبْتَغِي بِذَلِكَ وَجْهَ اللَّهِ وَالدَّارَ الآخِرَةَ ‏.‏ قَالَ ‏""‏ وَيْحَكَ أَحَيَّةٌ أُمُّكَ ‏""‏ ‏.‏ قُلْتُ نَعَمْ ‏.‏ قَالَ ‏""‏ ارْجِعْ فَبَرَّهَا ‏""‏ ‏.‏ ثُمَّ أَتَيْتُهُ مِنَ الْجَانِبِ الآخَرِ فَقُلْتُ يَا رَسُولَ اللَّهِ إِنِّي كُنْتُ أَرَدْتُ الْجِهَادَ مَعَكَ أَبْتَغِي بِذَلِكَ وَجْهَ اللَّهِ وَالدَّارَ الآخِرَةَ ‏.‏ قَالَ ‏""‏ وَيْحَكَ أَحَيَّةٌ أُمُّكَ ‏""‏ ‏.‏ قُلْتُ نَعَمْ يَا رَسُولَ اللَّهِ قَالَ ‏""‏ فَارْجِعْ إِلَيْهَا فَبَرَّهَا ‏""‏ ‏.‏ ثُمَّ أَتَيْتُهُ مِنْ أَمَامِهِ فَقُلْتُ يَا رَسُولَ اللَّهِ إِنِّي كُنْتُ أَرَدْتُ الْجِهَادَ مَعَكَ أَبْتَغِي بِذَلِكَ وَجْهَ اللَّهِ وَالدَّارَ الآخِرَةَ ‏.‏ قَالَ ‏""‏ وَيْحَكَ أَحَيَّةٌ أُمُّكَ ‏""‏ ‏.‏ قُلْتُ نَعَمْ يَا رَسُولَ اللَّهِ ‏.‏ قَالَ ‏""‏ وَيْحَكَ الْزَمْ رِجْلَهَا فَثَمَّ الْجَنَّةُ ‏""‏ ‏.‏ حَدَّثَنَا هَارُونُ بْنُ عَبْدِ اللَّهِ الْحَمَّالُ، حَدَّثَنَا حَجَّاجُ بْنُ مُحَمَّدٍ، حَدَّثَنَا ابْنُ جُرَيْجٍ، أَخْبَرَنِي مُحَمَّدُ بْنُ طَلْحَةَ بْنِ عَبْدِ اللَّهِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبِي بَكْرٍ الصِّدِّيقِ، عَنْ أَبِيهِ، طَلْحَةَ عَنْ مُعَاوِيَةَ بْنِ جَاهِمَةَ السُّلَمِيِّ، أَنَّ جَاهِمَةَ، أَتَى النَّبِيَّ صلى الله عليه وسلم فَذَكَرَ نَحْوَهُ ‏. ‏قَالَ أَبُو عَبْدِ اللَّهِ بْنُ مَاجَهْ هَذَا جَاهِمَةُ بْنُ عَبَّاسِ بْنِ مِرْدَاسٍ السُّلَمِيُّ الَّذِي عَاتَبَ النَّبِيَّ صلى الله عليه وسلم يَوْمَ حُنَيْنٍ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۸۳۵، ومصباح الزجاجة:۸۹۳)، وقد أخرجہ: سنن ابی داود/العتق ۸ (۳۹۵۴)، مسند احمد (۳/۳۲۱),,It was\nnarrated that Mu’awiyah bin Jahimah As-Sulaimi said:,The Chapters on Jihad
2518,"حَدَّثَنَا أَبُو كُرَيْبٍ، مُحَمَّدُ بْنُ الْعَلاَءِ حَدَّثَنَا الْمُحَارِبِيُّ، عَنْ عَطَاءِ بْنِ السَّائِبِ، عَنْ أَبِيهِ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ أَتَى رَجُلٌ رَسُولَ اللَّهِ صلى الله عليه وسلم فَقَالَ يَا رَسُولَ اللَّهِ إِنِّي جِئْتُ أُرِيدُ الْجِهَادَ مَعَكَ أَبْتَغِي وَجْهَ اللَّهِ وَالدَّارَ الآخِرَةَ وَلَقَدْ أَتَيْتُ وَإِنَّ وَالِدَىَّ لَيَبْكِيَانِ ‏.‏ قَالَ ‏ ‏ فَارْجِعْ إِلَيْهِمَا فَأَضْحِكْهُمَا كَمَا أَبْكَيْتَهُمَا ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/فضائل الجہاد۲۰ (۱۶۵۵)، سنن النسائی/الجہاد ۱۳ (۳۱۲۳)، النکاح ۵ (۳۲۲۰)،(تحفة الأشراف:۱۳۰۳۹)، وقد أخرجہ: مسند احمد (۲/۲۵۱،۴۳۷),,It was\nnarrated that ‘Abdullah bin ‘Amr said:,The Chapters on Jihad
2519,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ شَقِيقٍ، عَنْ أَبِي مُوسَى، قَالَ سُئِلَ النَّبِيُّ صلى الله عليه وسلم عَنِ الرَّجُلِ يُقَاتِلُ شَجَاعَةً وَيُقَاتِلُ حَمِيَّةً وَيُقَاتِلُ رِيَاءً فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ قَاتَلَ لِتَكُونَ كَلِمَةُ اللَّهِ هِيَ الْعُلْيَا فَهُوَ فِي سَبِيلِ اللَّهِ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۶۷۳، ومصباح الزجاجة:۸۹۴)، وقد أخرجہ: سنن ابی داود/العتق ۱ (۳۹۲۷)، سنن الترمذی/البیوع ۳۵ (۱۲۶۰),,It was\nnarrated that Abu Musa said:,The Chapters on Jihad
2520,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا حُسَيْنُ بْنُ مُحَمَّدٍ، حَدَّثَنَا جَرِيرُ بْنُ حَازِمٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ دَاوُدَ بْنِ الْحُصَيْنِ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِي عُقْبَةَ، عَنْ أَبِي عُقْبَةَ، - وَكَانَ مَوْلًى لأَهْلِ فَارِسَ - قَالَ شَهِدْتُ مَعَ النَّبِيِّ صلى الله عليه وسلم يَوْمَ أُحُدٍ فَضَرَبْتُ رَجُلاً مِنَ الْمُشْرِكِينَ فَقُلْتُ خُذْهَا مِنِّي وَأَنَا الْغُلاَمُ الْفَارِسِيُّ ‏.‏ فَبَلَغَتِ النَّبِيَّ صلى الله عليه وسلم فَقَالَ ‏ ‏ أَلاَ قُلْتَ خُذْهَا مِنِّي وَأَنَا الْغُلاَمُ الأَنْصَارِيُّ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/العتق ۱ (۳۹۲۸)، سنن الترمذی/البیوع ۳۵ (۱۲۶۱)،(تحفة الأشراف:۱۸۲۲۱)، وقد أخرجہ: مسند احمد (۶/۲۸۹),,"It was\nnarrated that Abu ‘Uqbah, who was the freed slave of some\nPersian\npeople, said:",The Chapters on Jihad
2521,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ يَزِيدَ، حَدَّثَنَا حَيْوَةُ، أَخْبَرَنِي أَبُو هَانِئٍ، أَنَّهُ سَمِعَ أَبَا عَبْدِ الرَّحْمَنِ الْحُبُلِيَّ، يَقُولُ إِنَّهُ سَمِعَ عَبْدَ اللَّهِ بْنَ عَمْرٍو، يَقُولُ سَمِعْتُ النَّبِيَّ صلى الله عليه وسلم يَقُولُ ‏ ‏ مَا مِنْ غَازِيَةٍ تَغْزُو فِي سَبِيلِ اللَّهِ فَيُصِيبُوا غَنِيمَةً إِلاَّ تَعَجَّلُوا ثُلُثَىْ أَجْرِهِمْ فَإِنْ لَمْ يُصِيبُوا غَنِيمَةً تَمَّ لَهُمْ أَجْرُهُمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح البخاری/المکاتب ۳ (۲۵۶۳)، صحیح مسلم/العتق ۲ (۱۵۰۴)،(تحفة الأشراف:۱۷۲۶۳)، وقد أخرجہ: سنن ابی داود/الطلاق ۱۹ (۲۲۳۳)، سنن الترمذی/البیوع ۳۳ (۱۲۵۶)، سنن النسائی/الطلاق ۳۱ (۳۴۸۳)، موطا امام مالک/الطلاق ۱۰ (۲۵)، مسند احمد (۶/۴۶،۱۱۵،۱۲۳،۱۷۲،۱۹۱،۲۰۷)، سنن الدارمی/الطلاق ۱۵ (۲۳۳۵),,‘Abdullah bin ‘Amr said:,The Chapters on Jihad
2522,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ شَبِيبِ بْنِ غَرْقَدَةَ، عَنْ عُرْوَةَ الْبَارِقِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الْخَيْرُ مَعْقُودٌ بِنَوَاصِي الْخَيْلِ إِلَى يَوْمِ الْقِيَامَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/العتق ۱۴ (۳۹۶۷)، سنن النسائی/الجہاد ۲۶ (۳۱۴۶)،(تحفة الأشراف:۱۱۱۶۳)، وقد أخرجہ: سنن الترمذی/فضائل الجہاد ۹ (۱۶۳۴)، مسند احمد (۴/۲۳۵،۲۳۶),,It was\nnarrated from ‘Urwah Al-Bariqi that the Messenger of Allah\n(ﷺ)\nsaid:,The Chapters on Jihad
2523,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ نَافِعٍ، عَنْ عَبْدِ اللَّهِ بْنِ عُمَرَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ قَالَ ‏ ‏ الْخَيْلُ فِي نَوَاصِيهَا الْخَيْرُ إِلَى يَوْمِ الْقِيَامَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العتق ۲ (۲۵۱۸)، صحیح مسلم/الإیمان ۳۵ (۸۴)، سنن النسائی/الجہاد ۱۷ (۳۱۳۱)،(تحفة الأشراف:۱۲۰۰۴),,It was\nnarrated from ‘Abdullah bin ‘Umar that the Messenger of Allah\n(ﷺ) said:,The Chapters on Jihad
2524,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ الْمُخْتَارِ، حَدَّثَنَا سُهَيْلٌ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ الْخَيْلُ فِي نَوَاصِيهَا الْخَيْرُ - أَوْ قَالَ الْخَيْلُ مَعْقُودٌ فِي نَوَاصِيهَا قَالَ سُهَيْلٌ أَنَا أَشُكُّ الْخَيْرُ - إِلَى يَوْمِ الْقِيَامَةِ الْخَيْلُ ثَلاَثَةٌ فَهِيَ لِرَجُلٍ أَجْرٌ وَلِرَجُلٍ سِتْرٌ وَعَلَى رَجُلٍ وِزْرٌ فَأَمَّا الَّذِي هِيَ لَهُ أَجْرٌ فَالرَّجُلُ يَتَّخِذُهَا فِي سَبِيلِ اللَّهِ وَيُعِدُّهَا لَهُ فَلاَ تُغَيِّبُ شَيْئًا فِي بُطُونِهَا إِلاَّ كُتِبَ لَهُ أَجْرٌ وَلَوْ رَعَاهَا فِي مَرْجٍ مَا أَكَلَتْ شَيْئًا إِلاَّ كُتِبَ لَهُ بِهَا أَجْرٌ وَلَوْ سَقَاهَا مِنْ نَهَرٍ جَارٍ كَانَ لَهُ بِكُلِّ قَطْرَةٍ تُغَيِّبُهَا فِي بُطُونِهَا أَجْرٌ - حَتَّى ذَكَرَ الأَجْرَ فِي أَبْوَالِهَا وَأَرْوَاثِهَا - وَلَوِ اسْتَنَّتْ شَرَفًا أَوْ شَرَفَيْنِ كُتِبَ لَهُ بِكُلِّ خَطْوَةٍ تَخْطُوهَا أَجْرٌ ‏.‏ وَأَمَّا الَّذِي هِيَ لَهُ سِتْرٌ فَالرَّجُلُ يَتَّخِذُهَا تَكَرُّمًا وَتَجَمُّلاً وَلاَ يَنْسَى حَقَّ ظُهُورِهَا وَبُطُونِهَا فِي عُسْرِهَا وَيُسْرِهَا ‏.‏ وَأَمَّا الَّذِي هِيَ عَلَيْهِ وِزْرٌ فَالَّذِي يَتَّخِذُهَا أَشَرًا وَبَطَرًا وَبَذَخًا وَرِياءً لِلنَّاسِ فَذَلِكَ الَّذِي هِيَ عَلَيْهِ وِزْرٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/العتق ۷ (۳۹۴۹)، سنن الترمذی/الأحکام ۲۸ (۱۳۶۵)،(تحفة الأشراف:۴۵۸۰،۴۵۸۵)، وقد أخرجہ: مسند احمد (۵/۱۵،۱۸،۲۰),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2525,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، حَدَّثَنَا أَبِي قَالَ، سَمِعْتُ يَحْيَى بْنَ أَيُّوبَ، يُحَدِّثُ عَنْ يَزِيدَ بْنِ أَبِي حَبِيبٍ، عَنْ عُلَىِّ بْنِ رَبَاحٍ، عَنْ أَبِي قَتَادَةَ الأَنْصَارِيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ خَيْرُ الْخَيْلِ الأَدْهَمُ الأَقْرَحُ الْمُحَجَّلُ الأَرْثَمُ طَلْقُ الْيَدِ الْيُمْنَى فَإِنْ لَمْ يَكُنْ أَدْهَمَ فَكُمَيْتٌ عَلَى هَذِهِ الشِّيَةِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۱۵۷، ومصباح الزجاجة:۸۹۵)، سنن الترمذی/الأحکام ۲۸ (۱۳۶۵ تعلیقاً),,It was\nnarrated from Abu Qatadah Al-Ansari that the Messenger of\nAllah (ﷺ)\nsaid:,The Chapters on Jihad
2526,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ سَلْمِ بْنِ عَبْدِ الرَّحْمَنِ النَّخَعِيِّ، عَنْ أَبِي زُرْعَةَ بْنِ عَمْرِو بْنِ جَرِيرٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ كَانَ النَّبِيُّ صلى الله عليه وسلم يَكْرَهُ الشِّكَالَ مِنَ الْخَيْلِ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,,2526,It was\nnarrated that Abu Hurairah said:,The Chapters on Jihad
2527,"حَدَّثَنَا أَبُو عُمَيْرٍ، عِيسَى بْنُ مُحَمَّدٍ الرَّمْلِيُّ حَدَّثَنَا أَحْمَدُ بْنُ يَزِيدَ بْنِ رَوْحٍ الدَّارِيُّ، عَنْ مُحَمَّدِ بْنِ عُقْبَةَ الْقَاضِي، عَنْ أَبِيهِ، عَنْ جَدِّهِ، عَنْ تَمِيمٍ الدَّارِيِّ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ مَنِ ارْتَبَطَ فَرَسًا فِي سَبِيلِ اللَّهِ ثُمَّ عَالَجَ عَلَفَهُ بِيَدِهِ كَانَ لَهُ بِكُلِّ حَبَّةٍ حَسَنَةٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/ الشرکة ۵ (۲۴۹۲)،۱۴ (۲۵۰۴)، العتق ۵ (۲۵۲۶،۲۵۲۷)، صحیح مسلم/العتق ۱ (۱۵۰۳)، سنن ابی داود/العتق ۳ (۳۹۳۴)، سنن الترمذی/الأحکام ۱۴ (۱۳۴۸)،(تحفة الأشراف:۱۲۲۱۱)، وقد أخرجہ: مسند احمد (۲/۲۵۵،۳۴۷،۴۲۶،۴۶۸،۴۷۲،۵۳۱),,It was\nnarrated that Tamim Ad-Dari said:,The Chapters on Jihad
2528,"حَدَّثَنَا بِشْرُ بْنُ آدَمَ، حَدَّثَنَا الضَّحَّاكُ بْنُ مَخْلَدٍ، حَدَّثَنَا ابْنُ جُرَيْجٍ، حَدَّثَنَا سُلَيْمَانُ بْنُ مُوسَى، حَدَّثَنَا مَالِكُ بْنُ يُخَامِرَ، حَدَّثَنَا مُعَاذُ بْنُ جَبَلٍ، أَنَّهُ سَمِعَ النَّبِيَّ صلى الله عليه وسلم يَقُولُ ‏ ‏ مَنْ قَاتَلَ فِي سَبِيلِ اللَّهِ عَزَّ وَجَلَّ مِنْ رَجُلٍ مُسْلِمٍ فُوَاقَ نَاقَةٍ وَجَبَتْ لَهُ الْجَنَّةُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العتق ۴ (۲۵۲۲)، الشرکة ۵ (۲۴۹۱)،۱۴ (۲۵۰۳)، صحیح مسلم/العتق ۱ (۱۵۰۱)، الأإیمان ۱۲ (۱۵۰۱)، سنن ابی داود/العتق ۶ (۳۹۴۰)،(تحفة الأشراف:۷۶۰۴)، وقد أخرجہ: سنن الترمذی/الأحکام ۱۴ (۱۳۴۶)، سنن النسائی/ البیوع ۱۰۴ (۴۷۰۳)، موطا امام مالک/العتق ۱ (۱)، مسند احمد (۲/۲،۱۵،۳۴،۷۷،۱۰۵،۱۱۲،۱۴۲،۱۵۶),,Mu’adh\nbin Jabal narrated that he heard the Prophet (ﷺ) say:,The Chapters on Jihad
2529,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَفَّانُ، حَدَّثَنَا دَيْلَمُ بْنُ غَزْوَانَ، حَدَّثَنَا ثَابِتٌ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ حَضَرْتُ حَرْبًا فَقَالَ عَبْدُ اللَّهِ بْنُ رَوَاحَةَ يَا نَفْسِ أَلاَ أَرَاكِ تَكْرَهِينَ الْجَنَّهْ أَحْلِفُ بِاللَّهِ لَتَنْزِلِنَّهْ طَائِعَةً أَوْ لَتُكْرَهِنَّهْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/العتق ۱۱ (۳۹۶۲)،(تحفة الأشراف:۷۶۰۴)، وقد أخرجہ: صحیح البخاری/المساقاة ۱۷ (۲۳۷۹)، صحیح مسلم/البیوع ۱۵ (۱۵۴۳)، سنن الترمذی/البیوع ۲۵ (۱۲۴۴),2529,It was\nnarrated that Anas bin Malik said:,The Chapters on Jihad
2530,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَعْلَى بْنُ عُبَيْدٍ، حَدَّثَنَا حَجَّاجُ بْنُ دِينَارٍ، عَنْ مُحَمَّدِ بْنِ ذَكْوَانَ، عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ عَمْرِو بْنِ عَبَسَةَ، قَالَ أَتَيْتُ النَّبِيَّ صلى الله عليه وسلم فَقُلْتُ يَا رَسُولَ اللَّهِ أَىُّ الْجِهَادِ أَفْضَلُ قَالَ ‏ ‏ مَنْ أُهْرِيقَ دَمُهُ وَعُقِرَ جَوَادُهُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۴۹۳، ومصباح الزجاجة:۸۹۶),,It was\nnarrated that ‘Amr bin ‘Abasah said:,The Chapters on Jihad
2531,"حَدَّثَنَا بِشْرُ بْنُ آدَمَ، وَأَحْمَدُ بْنُ ثَابِتٍ الْجَحْدَرِيُّ، قَالاَ حَدَّثَنَا صَفْوَانُ بْنُ عِيسَى، حَدَّثَنَا مُحَمَّدُ بْنُ عَجْلاَنَ، عَنِ الْقَعْقَاعِ بْنِ حَكِيمٍ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَا مِنْ مَجْرُوحٍ يُجْرَحُ فِي سَبِيلِ اللَّهِ - وَاللَّهُ أَعْلَمُ بِمَنْ يُجْرَحُ فِي سَبِيلِهِ - إِلاَّ جَاءَ يَوْمَ الْقِيَامَةِ وَجُرْحُهُ كَهَيْئَتِهِ يَوْمَ جُرِحَ وَاللَّوْنُ لَوْنُ دَمٍ وَالرِّيحُ رِيحُ مِسْكٍ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۸۰۸۸، ومصباح الزجاجة:۸۹۸)، وقد أخرجہ: مسند احمد (۶/۴۶۳)،,,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2532,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا يَعْلَى بْنُ عُبَيْدٍ، حَدَّثَنِي إِسْمَاعِيلُ بْنُ أَبِي خَالِدٍ، سَمِعْتُ عَبْدَ اللَّهِ بْنَ أَبِي أَوْفَى، يَقُولُ دَعَا رَسُولُ اللَّهِ صلى الله عليه وسلم عَلَى الأَحْزَابِ فَقَالَ ‏ ‏ اللَّهُمَّ مُنْزِلَ الْكِتَابِ سَرِيعَ الْحِسَابِ اهْزِمِ الأَحْزَابَ اللَّهُمَّ اهْزِمْهُمْ وَزَلْزِلْهُمْ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الطلاق ۲ (۲۲۳۷)، سنن النسائی/الطلاق ۲۸ (۳۴۷۶)،(تحفة الأشراف:۱۷۵۳۴),,Isma’il\nbin Abu Khalid said:,The Chapters on Jihad
2533,"حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، وَأَحْمَدُ بْنُ عِيسَى الْمِصْرِيَّانِ، قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، حَدَّثَنِي أَبُو شُرَيْحٍ عَبْدُ الرَّحْمَنِ بْنُ شُرَيْحٍ، أَنَّ سَهْلَ بْنَ أَبِي أُمَامَةَ بْنِ سَهْلِ بْنِ حُنَيْفٍ، حَدَّثَهُ عَنْ أَبِيهِ، عَنْ جَدِّهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ مَنْ سَأَلَ اللَّهَ الشَّهَادَةَ بِصِدْقٍ مِنْ قَلْبِهِ بَلَّغَهُ اللَّهُ مَنَازِلَ الشُّهَدَاءِ وَإِنْ مَاتَ عَلَى فِرَاشِهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الدیات ۳ (۴۵۰۲)، سنن الترمذی/الفتن ۱ (۲۱۵۸)، سنن النسائی/المحاربة (تحریم الدم)۶ (۴۰۲۴)،(تحفة الأشراف:۹۷۸۲)، وقد أخرجہ: مسند احمد (۱/۶۱،۶۲،۶۵،۷۰)، سنن الدارمی/الحدود ۱ (۲۳۴۳),,"Sahl bin\nAbu Umamah bin Sahl bin Hunaif narrated from his father,\nfrom his\ngrandfather that the Prophet (ﷺ) said:",The Chapters on Jihad
2534,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنِ ابْنِ عَوْنٍ، عَنْ هِلاَلِ بْنِ أَبِي زَيْنَبَ، عَنْ شَهْرِ بْنِ حَوْشَبٍ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ذُكِرَ الشُّهَدَاءُ عِنْدَ النَّبِيِّ صلى الله عليه وسلم فَقَالَ ‏ ‏ لاَ تَجِفُّ الأَرْضُ مِنْ دَمِ الشَّهِيدِ حَتَّى تَبْتَدِرَهُ زَوْجَتَاهُ كَأَنَّهُمَا ظِئْرَانِ أَضَلَّتَا فَصِيلَيْهِمَا فِي بَرَاحٍ مِنَ الأَرْضِ وَفِي يَدِ كُلِّ وَاحِدَةٍ مِنْهُمَا حُلَّةٌ خَيْرٌ مِنَ الدُّنْيَا وَمَا فِيهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الدیات ۶ (۶۸۷۶)، صحیح مسلم/القسامة ۶ (۱۶۷۶)، سنن ابی داود/الحدود ۱ (۴۳۵۲)، سنن الترمذی/الدیات ۱۰ (۱۴۰۲)، سنن النسائی/المحاربة ۵ (۴۰۲۱)،(تحفة الأشراف:۹۵۶۷)، وقد أخرجہ: مسند احمد (۱/۳۸۲،۴۲۸،۴۴۴،۴۶۵)، سنن الدارمی/الحدود ۲ (۲۳۴۴),,It was\nnarrated from Abu Hurairah:,The Chapters on Jihad
2535,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، حَدَّثَنِي بَحِيرُ بْنُ سَعْدٍ، عَنْ خَالِدِ بْنِ مَعْدَانَ، عَنِ الْمِقْدَامِ بْنِ مَعْدِيكَرِبَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لِلشَّهِيدِ عِنْدَ اللَّهِ سِتُّ خِصَالٍ يُغْفَرُ لَهُ فِي أَوَّلِ دَفْعَةٍ مِنْ دَمِهِ وَيُرَى مَقْعَدَهُ مِنَ الْجَنَّةِ وَيُجَارُ مِنْ عَذَابِ الْقَبْرِ وَيَأْمَنُ مِنَ الْفَزَعِ الأَكْبَرِ وَيُحَلَّى حُلَّةَ الإِيمَانِ وَيُزَوَّجُ مِنَ الْحُورِ الْعِينِ وَيُشَفَّعُ فِي سَبْعِينَ إِنْسَانًا مِنْ أَقَارِبِهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: صحیح البخاری/الجہاد ۱۴۹ (۳۰۱۷)، المرتدین ۲ (۶۹۲۲)، سنن ابی داود/الحدود ۱ (۴۳۵۱)، سنن الترمذی/الحدود ۲۵ (۱۴۵۸)، سنن النسائی/الحدود ۱۱ (۴۰۶۴)،(تحفة الأشراف:۵۹۸۷)، وقد أخرجہ: مسند احمد (۱/۲۸۲،۲۸۳،۳۲۳),,It was\nnarrated from Miqdam bin Ma’dikarib that the Messenger of\nAllah\n(ﷺ) said:,The Chapters on Jihad
2536,"حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحَرَامِيُّ، حَدَّثَنَا مُوسَى بْنُ إِبْرَاهِيمَ الْحَرَامِيُّ الأَنْصَارِيُّ، سَمِعْتُ طَلْحَةَ بْنَ خِرَاشٍ، سَمِعْتُ جَابِرَ بْنَ عَبْدِ اللَّهِ، يَقُولُ لَمَّا قُتِلَ عَبْدُ اللَّهِ بْنُ عَمْرِو بْنِ حَرَامٍ يَوْمَ أُحُدٍ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ يَا جَابِرُ أَلاَ أُخْبِرُكَ مَا قَالَ اللَّهُ عَزَّ وَجَلَّ لأَبِيكَ ‏""‏ ‏.‏ قُلْتُ بَلَى ‏.‏ قَالَ ‏""‏ مَا كَلَّمَ اللَّهُ أَحَدًا إِلاَّ مِنْ وَرَاءِ حِجَابٍ وَكَلَّمَ أَبَاكَ كِفَاحًا ‏.‏ فَقَالَ يَا عَبْدِي تَمَنَّ عَلَىَّ أُعْطِكَ ‏.‏ قَالَ يَا رَبِّ تُحْيِينِي فَأُقْتَلُ فِيكَ ثَانِيَةً ‏.‏ قَالَ إِنَّهُ سَبَقَ مِنِّي أَنَّهُمْ إِلَيْهَا لاَ يُرْجَعُونَ ‏.‏ قَالَ يَا رَبِّ فَأَبْلِغْ مَنْ وَرَائِي ‏.‏ فَأَنْزَلَ اللَّهُ عَزَّ وَجَلَّ هَذِهِ الآيَةَ ‏{وَلاَ تَحْسَبَنَّ الَّذِينَ قُتِلُوا فِي سَبِيلِ اللَّهِ أَمْوَاتًا‏}‏ ‏""‏ ‏.‏ الآيَةَ كُلَّهَا ‏.‏",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن النسائی/الزکاة ۱ (۲۴۳۸)،۷۳ (۲۵۶۹)،(تحفة الأشراف:۱۱۳۸۸)، وقد أخرجہ: مسند احمد (۵/۵),2536,It was\nnarrated from Jabir bin ‘Abdullah:,The Chapters on Jihad
2537,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنَا الأَعْمَشُ، عَنْ عَبْدِ اللَّهِ بْنِ مُرَّةَ، عَنْ مَسْرُوقٍ، عَنْ عَبْدِ اللَّهِ، فِي قَوْلِهِ ‏{وَلاَ تَحْسَبَنَّ الَّذِينَ قُتِلُوا فِي سَبِيلِ اللَّهِ أَمْوَاتًا بَلْ أَحْيَاءٌ عِنْدَ رَبِّهِمْ يُرْزَقُونَ‏}‏ قَالَ أَمَا إِنَّا سَأَلْنَا عَنْ ذَلِكَ فَقَالَ ‏""‏ أَرْوَاحُهُمْ كَطَيْرٍ خُضْرٍ تَسْرَحُ فِي الْجَنَّةِ فِي أَيِّهَا شَاءَتْ ثُمَّ تَأْوِي إِلَى قَنَادِيلَ مُعَلَّقَةٍ بِالْعَرْشِ فَبَيْنَمَا هُمْ كَذَلِكَ إِذِ اطَّلَعَ عَلَيْهِمْ رَبُّكَ اطِّلاَعَةً فَيَقُولُ سَلُونِي مَا شِئْتُمْ ‏.‏ قَالُوا رَبَّنَا وَمَاذَا نَسْأَلُكَ وَنَحْنُ نَسْرَحُ فِي الْجَنَّةِ فِي أَيِّهَا شِئْنَا فَلَمَّا رَأَوْا أَنَّهُمْ لاَ يُتْرَكُونَ مِنْ أَنْ يَسْأَلُوا قَالُوا نَسْأَلُكَ أَنْ تَرُدَّ أَرْوَاحَنَا فِي أَجْسَادِنَا إِلَى الدُّنْيَا حَتَّى نُقْتَلَ فِي سَبِيلِكَ ‏.‏ فَلَمَّا رَأَى أَنَّهُمْ لاَ يَسْأَلُونَ إِلاَّ ذَلِكَ تُرِكُوا ‏""‏ ‏.‏",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۳۸۱، ومصباح الزجاجة:۸۹۹),2537,It was\nnarrated from ‘Abdullah concerning the Verse:,The Chapters on Jihad
2538,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَأَحْمَدُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ، وَبِشْرُ بْنُ آدَمَ، قَالُوا حَدَّثَنَا صَفْوَانُ بْنُ عِيسَى، أَنْبَأَنَا مُحَمَّدُ بْنُ عَجْلاَنَ، عَنِ الْقَعْقَاعِ بْنِ حَكِيمٍ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَا يَجِدُ الشَّهِيدُ مَسَّ الْقَتْلِ إِلاَّ كَمَا يَجِدُ أَحَدُكُمْ مَسَّ الْقَرْصَةِ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: سنن النسائی/قطع السارق ۷ (۴۹۱۹،۴۹۲۰ موقوفاً)،(تحفة الأشراف:۱۴۸۸۸)، وقد أخرجہ: مسند احمد (۲/۳۶۲،۴۰۲),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2539,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ أَبِي الْعُمَيْسِ، عَنْ عَبْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ بْنِ جَابِرِ بْنِ عَتِيكٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، أَنَّهُ مَرِضَ فَأَتَاهُ النَّبِيُّ صلى الله عليه وسلم يَعُودُهُ فَقَالَ قَائِلٌ مِنْ أَهْلِهِ إِنْ كُنَّا لَنَرْجُو أَنْ تَكُونَ وَفَاتُهُ قَتْلَ شَهَادَةٍ فِي سَبِيلِ اللَّهِ ‏.‏ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّ شُهَدَاءَ أُمَّتِي إِذًا لَقَلِيلٌ الْقَتْلُ فِي سَبِيلِ اللَّهِ شَهَادَةٌ وَالْمَطْعُونُ شَهَادَةٌ وَالْمَرْأَةُ تَمُوتُ بِجُمْعٍ شَهَادَةٌ - يَعْنِي الْحَامِلَ - وَالْغَرِقُ وَالْحَرِقُ وَالْمَجْنُوبُ - يَعْنِي ذَاتَ الْجَنْبِ - شَهَادَةٌ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۰۴۲، ومصباح الزجاجة:۹۰۰),,"It was\nnarrated from ‘Abdullah bin ‘Abdullah bin Jabir bin ‘Atik, from\nhis father, that his grandfather fell sick and the Prophet (ﷺ) came\nto visit him. One of his family members said:",The Chapters on Jihad
2540,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ الْمُخْتَارِ، حَدَّثَنَا سُهَيْلٌ، عَنْ أَبِيهِ، عَنْ أَبِي هُرَيْرَةَ، عَنِ النَّبِيِّ صلى الله عليه وسلم أَنَّهُ قَالَ ‏""‏ مَا تَقُولُونَ فِي الشَّهِيدِ فِيكُمْ ‏""‏ ‏.‏ قَالُوا الْقَتْلُ فِي سَبِيلِ اللَّهِ ‏.‏ قَالَ ‏""‏ إِنَّ شُهَدَاءَ أُمَّتِي إِذًا لَقَلِيلٌ مَنْ قُتِلَ فِي سَبِيلِ اللَّهِ فَهُوَ شَهِيدٌ وَمَنْ مَاتَ فِي سَبِيلِ اللَّهِ فَهُوَ شَهِيدٌ وَالْمَبْطُونُ شَهِيدٌ وَالْمَطْعُونُ شَهِيدٌ ‏""‏ ‏.‏ قَالَ سُهَيْلٌ وَأَخْبَرَنِي عُبَيْدُ اللَّهِ بْنُ مِقْسَمٍ، عَنْ أَبِي صَالِحٍ، وَزَادَ، فِيهِ ‏""""‏ وَالْغَرِقُ شَهِيدٌ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۰۸۷، ومصباح الزجاجة:۹۰۱)، وقد أخرجہ: مسند احمد (۵/۳۳۰),,It was\nnarrated from Abu Hurairah that the Prophet (ﷺ) said:,The Chapters on Jihad
2541,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، وَسُوَيْدُ بْنُ سَعِيدٍ، قَالاَ حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، حَدَّثَنِي الزُّهْرِيُّ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم دَخَلَ مَكَّةَ يَوْمَ الْفَتْحِ وَعَلَى رَأْسِهِ الْمِغْفَرُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: سنن ابی داود/الحدود ۱۷ (۴۴۰۴)، سنن الترمذی/السیر ۲۹ (۱۵۸۴)، سنن النسائی/الطلاق ۲۰ (۳۴۶۰)، القطع ۱۴ (۴۹۸۴)،(تحفة الأشراف:۹۹۰۴)، وقد أخرجہ: مسند احمد (۴/۳۱۰،۳۸۳،۵/۳۱۲،۳۸۳),2541,,The Chapters on Jihad
2542,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ يَزِيدَ بْنِ خُصَيْفَةَ، عَنِ السَّائِبِ بْنِ يَزِيدَ، إِنْ شَاءَ اللَّهُ تَعَالَى ‏.‏ أَنَّ النَّبِيَّ صلى الله عليه وسلم يَوْمَ أُحُدٍ أَخَذَ دِرْعَيْنِ كَأَنَّهُ ظَاهَرَ بَيْنَهُمَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «انظر ما قبلہ,2542,,The Chapters on Jihad
2543,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا الأَوْزَاعِيُّ، حَدَّثَنِي سُلَيْمَانُ بْنُ حَبِيبٍ، قَالَ دَخَلْنَا عَلَى أَبِي أُمَامَةَ فَرَأَى فِي سُيُوفِنَا شَيْئًا مِنْ حِلْيَةِ فِضَّةٍ فَغَضِبَ وَقَالَ لَقَدْ فَتَحَ الْفُتُوحَ قَوْمٌ مَا كَانَ حِلْيَةُ سُيُوفِهِمْ مِنَ الذَّهَبِ وَالْفِضَّةِ وَلَكِنِ الآنُكُ وَالْحَدِيدُ وَالْعَلاَبِيُّ ‏.‏ قَالَ أَبُو الْحَسَنِ الْقَطَّانُ الْعَلاَبِيُّ الْعَصَبُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: حدیث أبي أسامة أخرجہ: صحیح البخاری/الشہادات ۱۸ (۲۶۶۴)، المغازي ۲۹ (۴۰۹۷)،(تحفة الأشراف:۷۸۳۳)، وقد أخرجہ: وحدیث عبد اللہ بن نمیر صحیح مسلم/الإمارہ ۲۳ (۱۸۶۴)،(تحفة الأشراف:۷۹۵۵)، مسند احمد (۲/۱۷)، وحدیث أبي معاویہ تفردبہ ابن ماجہ، تحفة الأشراف:۸۱۱۵)، سنن ابی داود/الخراج ۱۶ (۲۹۵۷)، الحدود ۱۷ (۴۴۰۶)، سنن الترمذی/الأحکام ۲۴ (۱۳۱۶)، الجہاد ۳۱ (۱۷۱۱)، سنن النسائی/الطلا ق۲۰ (۳۴۳۱)، مسند احمد (۲/۱۷),2543,Sulaiman\nbin Habib said:,The Chapters on Jihad
2544,حَدَّثَنَا أَبُو كُرَيْبٍ، حَدَّثَنَا ابْنُ الصَّلْتِ، عَنِ ابْنِ أَبِي الزِّنَادِ، عَنْ أَبِيهِ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم تَنَفَّلَ سَيْفَهُ ذَا الْفِقَارِ يَوْمَ بَدْرٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۴۹)، وقد أخرجہ: صحیح مسلم/الذکر ۱۱ (۲۶۹۹)، سنن ابی داود/الأدب ۶۸ (۴۹۴۶)، سنن الترمذی/الحدود ۳ (۱۴۲۵)، مسند احمد (۲/۲۵۲،۳۲۵،۵۰۰،۵۲۲)، سنن الدارمی/المقدمة ۳۲ (۳۶۰),2544,,The Chapters on Jihad
2545,"حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ بْنِ سَمُرَةَ، أَنْبَأَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ أَبِي إِسْحَاقَ، عَنْ أَبِي الْخَلِيلِ، عَنْ عَلِيِّ بْنِ أَبِي طَالِبٍ، قَالَ كَانَ الْمُغِيرَةُ بْنُ شُعْبَةَ إِذَا غَزَا مَعَ النَّبِيِّ صلى الله عليه وسلم حَمَلَ مَعَهُ رُمْحًا فَإِذَا رَجَعَ طَرَحَ رُمْحَهُ حَتَّى يُحْمَلَ لَهُ ‏.‏ فَقَالَ لَهُ عَلِيٌّ لأَذْكُرَنَّ ذَلِكَ لِرَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏ فَقَالَ ‏ ‏ لاَ تَفْعَلْ فَإِنَّكَ إِنْ فَعَلْتَ لَمْ تُرْفَعْ ضَالَّةٌ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۹۴۵، ومصباح الزجاجة:۹۰۲),,It was\nnarrated that ‘Ali bin Abi Talib said:,The Chapters on Jihad
2546,"حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ بْنِ سَمُرَةَ، أَنْبَأَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، عَنْ أَشْعَثَ بْنِ سَعِيدٍ، عَنْ عَبْدِ اللَّهِ بْنِ بُسْرٍ، عَنْ أَبِي رَاشِدٍ، عَنْ عَلِيٍّ، قَالَ كَانَتْ بِيَدِ رَسُولِ اللَّهِ صلى الله عليه وسلم قَوْسٌ عَرَبِيَّةٌ فَرَأَى رَجُلاً بِيَدِهِ قَوْسٌ فَارِسِيَّةٌ فَقَالَ ‏ ‏ مَا هَذِهِ أَلْقِهَا وَعَلَيْكُمْ بِهَذِهِ وَأَشْبَاهِهَا وَرِمَاحِ الْقَنَا فَإِنَّهُمَا يَزِيدُ اللَّهُ بِهِمَا فِي الدِّينِ وَيُمَكِّنُ لَكُمْ فِي الْبِلاَدِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۰۴۳، ومصباح الزجاجة:۹۰۳),,It was\nnarrated that ‘Ali said:,The Chapters on Jihad
2547,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا هِشَامٌ الدَّسْتَوَائِيُّ، عَنْ يَحْيَى بْنِ أَبِي كَثِيرٍ، عَنْ أَبِي سَلاَّمٍ، عَنْ عَبْدِ اللَّهِ بْنِ الأَزْرَقِ، عَنْ عُقْبَةَ بْنِ عَامِرٍ الْجُهَنِيِّ، عَنِ النَّبِيِّ صلى الله عليه وسلم قَالَ ‏""‏ إِنَّ اللَّهَ لَيُدْخِلُ بِالسَّهْمِ الْوَاحِدِ الثَّلاَثَةَ الْجَنَّةَ صَانِعَهُ يَحْتَسِبُ فِي صَنْعَتِهِ الْخَيْرَ وَالرَّامِيَ بِهِ وَالْمُمِدَّ بِهِ ‏""‏ ‏.‏ وَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ ارْمُوا وَارْكَبُوا وَأَنْ تَرْمُوا أَحَبُّ إِلَىَّ مِنْ أَنْ تَرْكَبُوا وَكُلُّ مَا يَلْهُو بِهِ الْمَرْءُ الْمُسْلِمُ بَاطِلٌ إِلاَّ رَمْيَهُ بِقَوْسِهِ وَتَأْدِيبَهُ فَرَسَهُ وَمُلاَعَبَتَهُ امْرَأَتَهُ فَإِنَّهُنَّ مِنَ الْحَقِّ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: صحیح البخاری/الشبہات ۸ (۲۶۴۸)، الأنبیاء ۵۴ (۳۴۷۵)، فضائل الصحابة ۱۸ (۳۷۳۲)، المغازي ۵۲ (۴۳۰۴)، الحدود ۱۱ (۶۷۸۷)،۱۲ (۶۷۸۸)،۱۴ (۶۸۰۰)، صحیح مسلم/الحدود ۲ (۱۶۸۸)، سنن ابی داود/الحدود ۴ (۴۳۷۳)، سنن الترمذی/الحدود ۶ (۱۴۳۰)، سنن النسائی/قطع السارق ۵ (۴۹۰۳)،(تحفة الأشراف:۱۶۵۷۸)، وقد أخرجہ: مسند احمد (۶/۱۶۲)، سنن الدارمی/الحدود ۵ ۲۳۴۸),2547,It was\nnarrated from ‘Uqbah bin ‘Amir Al-Juhani that the Prophet\n(ﷺ)\nsaid:,The Chapters on Jihad
2548,"حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الأَعْلَى، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي عَمْرُو بْنُ الْحَارِثِ، عَنْ سُلَيْمَانَ بْنِ عَبْدِ الرَّحْمَنِ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ، عَنْ عَمْرِو بْنِ عَبَسَةَ، قَالَ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ مَنْ رَمَى الْعَدُوَّ بِسَهْمٍ فَبَلَغَ سَهْمُهُ الْعَدُوَّ أَصَابَ أَوْ أَخْطَأَ فَيَعْدِلُ رَقَبَةً ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۲۶۳، ومصباح الزجاجة:۹۰۴)، وقد أخرجہ: مسند احمد (۶/۴۰۹),,It was\nnarrated that ‘Amr bin ‘Abasah said:,The Chapters on Jihad
2549,"حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الأَعْلَى، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي عَمْرُو بْنُ الْحَارِثِ، عَنْ أَبِي عَلِيٍّ الْهَمْدَانِيِّ، أَنَّهُ سَمِعَ عُقْبَةَ بْنَ عَامِرٍ الْجُهَنِيَّ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقْرَأُ عَلَى الْمِنْبَرِ ‏""‏ ‏{وَأَعِدُّوا لَهُمْ مَا اسْتَطَعْتُمْ مِنْ قُوَّةٍ}‏ أَلاَ وَإِنَّ الْقُوَّةَ الرَّمْىُ ‏""‏ ثَلاَثَ مَرَّاتٍ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الوکالة ۱۳ (۲۳۱۴،۲۳۱۵مختصراً) الصلح ۵ (۲۶۹۵،۲۶۹۶)، الشروط ۹ (۲۷۲۴،۲۷۲۵)، الإیمان ۳ (۶۶۳۳،۶۶۳۴)، الحدود ۲۰ (۶۸۳۵،۶۸۳۶)،۱۶ (۶۸۲۷،۶۸۲۸)،۳۳ (۶۸۵۹،۶۸۶۰)، الأحکام ۳ (۷۱۹۳۴،۷۱۹۴)، الآحاد ۱ (۷۲۵۸،۷۲۶۰)، صحیح مسلم/الحدود ۵ (۱۶۹۷،۱۶۹۸)، سنن ابی داود/الحدود ۲۵ (۴۴۴۵)، سنن الترمذی/الحدود ۸ (۱۴۳۳)، سنن النسائی/آداب القضاة ۲۱ (۴۵۱۲)،(تحفة الأشراف:۳۷۵۵)، وقد أخرجہ: موطا امام مالک/الحدود ۱ (۶)، مسند احمد (۴/۱۱۵،۱۱۶)، سنن الدارمی/الحدود ۱۲ (۲۳۶۳),2549,It was\nnarrated that ‘Uqbah bin ‘Amir Al-Juhani said:,The Chapters on Jihad
2550,"حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى الْمِصْرِيُّ، أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، أَخْبَرَنِي ابْنُ لَهِيعَةَ، عَنْ عُثْمَانَ بْنِ نُعَيْمٍ الرُّعَيْنِيِّ، عَنِ الْمُغِيرَةِ بْنِ نَهِيكٍ، أَنَّهُ سَمِعَ عُقْبَةَ بْنَ عَامِرٍ الْجُهَنِيَّ، يَقُولُ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ مَنْ تَعَلَّمَ الرَّمْىَ ثُمَّ تَرَكَهُ فَقَدْ عَصَانِي ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: صحیح مسلم/الحدود ۳ (۱۶۹۰)، سنن ابی داود/الحدود ۲۳ (۴۴۱۵،۴۴۱۶)، سنن الترمذی/الحدود ۸ (۱۴۳۴)،(تحفة الأشراف:۵۰۸۳)، وقد أخرجہ: حم (۳/۴۷۵،۵/۳۱۳،۳۱۷،۳۱۸،۳۲۰)، سنن الدارمی/الحدود ۱۹ (۲۳۷۲),,It was\nnarrated that ‘Uqbah bin ‘Amir Al-Juhani said:,The Chapters on Jihad
2551,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا عَبْدُ الرَّزَّاقِ، أَنْبَأَنَا سُفْيَانُ، عَنِ الأَعْمَشِ، عَنْ زِيَادِ بْنِ الْحُصَيْنِ، عَنْ أَبِي الْعَالِيَةِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ مَرَّ النَّبِيُّ صلى الله عليه وسلم بِنَفَرٍ يَرْمُونَ فَقَالَ ‏ ‏ رَمْيًا بَنِي إِسْمَاعِيلَ فَإِنَّ أَبَاكُمْ كَانَ رَامِيًا ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الحدود ۲۸ (۴۴۵۸،۴۴۵۹)، سنن الترمذی/الحدود ۲۱ (۱۴۵۱)، سنن النسائی/النکاح ۷۰ (۳۳۶۲)،(تحفة الأشراف:۱۱۶۱۳)، وقد أخرجہ: مسند احمد (۶/۲۷۲،۲۷۶،۲۷۷)، سنن الدارمی/الحدود ۲۰ (۲۳۷۴),,It was\nnarrated that Ibn ‘Abbas said:,The Chapters on Jihad
2552,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، عَنْ عَاصِمٍ، عَنِ الْحَارِثِ بْنِ حَسَّانَ، قَالَ قَدِمْتُ الْمَدِينَةَ فَرَأَيْتُ النَّبِيَّ صلى الله عليه وسلم قَائِمًا عَلَى الْمِنْبَرِ وَبِلاَلٌ قَائِمٌ بَيْنَ يَدَيْهِ مُتَقَلِّدٌ سَيْفًا وَإِذَا رَايَةٌ سَوْدَاءُ فَقُلْتُ مَنْ هَذَا قَالُوا هَذَا عَمْرُو بْنُ الْعَاصِ قَدِمَ مِنْ غَزَاةٍ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/الحدود ۲۸ (۴۴۶۰،۴۴۶۱)، سنن النسائی/النکاح ۷۰ (۳۳۶۵)،(تحفة الأشراف:۴۵۵۹)، وقد أخرجہ: مسند احمد (۳/۴۷۶،۵/۶),2552,It was\nnarrated that Harith bin Hassan said:,The Chapters on Jihad
2553,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، وَعَبْدَةُ بْنُ عَبْدِ اللَّهِ، قَالَ حَدَّثَنَا يَحْيَى بْنُ آدَمَ، حَدَّثَنَا شَرِيكٌ، عَنْ عَمَّارٍ الدُّهْنِيِّ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرِ بْنِ عَبْدِ اللَّهِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم دَخَلَ مَكَّةَ يَوْمَ الْفَتْحِ وَلِوَاؤُهُ أَبْيَضُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحدود ۳۰ (۶۸۲۹،۶۸۳۰)، صحیح مسلم/الحدود ۴ (۱۶۹۱)، سنن ابی داود/الحدود ۲۳ (۴۴۱۸)، سنن الترمذی/الحدود ۷ (۱۴۳۱،۱۴۳۲)،(تحفة الأشراف:۱۰۵۰۸)، وقد أخرجہ: موطا امام مالک/الحدود ۱ (۱)، مسند احمد (۱/ ۲۳،۴۰،۴۷،۵۵)، سنن الدارمی/الحدود ۱۶ (۲۳۶۸),2553,,The Chapters on Jihad
2554,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِسْحَاقَ الْوَاسِطِيُّ النَّاقِدُ، حَدَّثَنَا يَحْيَى بْنُ إِسْحَاقَ، عَنْ يَزِيدَ بْنِ حَيَّانَ، سَمِعْتُ أَبَا مِجْلَزٍ، يُحَدِّثُ عَنِ ابْنِ عَبَّاسٍ، أَنَّ رَايَةَ، رَسُولِ اللَّهِ صلى الله عليه وسلم كَانَتْ سَوْدَاءَ وَلِوَاؤُهُ أَبْيَضُ ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۰۳۴)، وقد أخرجہ: صحیح البخاری/الطلاق ۱۱ (۵۲۷۰)، صحیح مسلم/الحدود ۵ (۱۶۹۴)، سنن ابی داود/الحدود ۲۴ (۴۴۱۹)، سنن الترمذی/الحدود ۵ (۱۴۲۸),2554,,The Chapters on Jihad
2555,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ حَجَّاجٍ، عَنْ أَبِي عُمَرَ، - مَوْلَى أَسْمَاءَ - عَنْ أَسْمَاءَ بِنْتِ أَبِي بَكْرٍ، أَنَّهَا أَخْرَجَتْ جُبَّةً مُزَرَّرَةً بِالدِّيبَاجِ فَقَالَتْ كَانَ النَّبِيُّ صلى الله عليه وسلم يَلْبَسُ هَذِهِ إِذَا لَقِيَ الْعَدُوَّ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۸۷۹)، وقد أخرجہ: صحیح مسلم/الحدود ۵ (۱۶۹۶)، سنن ابی داود/الحدود ۲۵ (۴۴۴۰)، سنن الترمذی/الحدود ۹ (۱۴۳۵)، سنن النسائی/الجنائز ۶۴ (۱۹۵۹)، مسند احمد (۴/۴۲۰،۴۳۳،۴۳۷)، سنن الدارمی/الحدود ۱۷ (۲۳۷۰),2555,"It was\nnarrated from Abu ‘Umar, the freed slave of Asma’, from Asma’\nbint Abi Bakr, that she brought out a cloak edged with brocade and\nsaid:",The Chapters on Jihad
2556,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، عَنْ عَاصِمٍ الأَحْوَلِ، عَنْ أَبِي عُثْمَانَ، عَنْ عُمَرَ، أَنَّهُ كَانَ يَنْهَى عَنِ الْحَرِيرِ، وَالدِّيبَاجِ، إِلاَّ مَا كَانَ هَكَذَا ثُمَّ أَشَارَ بِإِصْبَعِهِ ثُمَّ الثَّانِيَةِ ثُمَّ الثَّالِثَةِ ثُمَّ الرَّابِعَةِ وَقَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم يَنْهَانَا عَنْهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۰۱۴)، وقد أخرجہ: صحیح البخاری/الحدود ۲۴ (۶۱۴۸)، صحیح مسلم/الحدود ۶ (۱۶۹۹)، سنن ابی داود/الحدود ۲۶ (۴۴۴۶)، سنن الترمذی/االحدود ۱۰ (۱۴۳۶)، موطا امام مالک/الحدود ۱ (۱)، وقد أخرجہ: مسند احمد (۲/۷،۶۳،۷۶)، سنن الدارمی/الحدود ۱۵ (۲۳۶۷),2556,"It was\nnarrated from ‘Umar that he used to forbid silk and brocade\nexcept\nthat which was like that, then he gestured with his finger,\nthen his\nsecond finger, then his third, then his fourth,* and said:",The Chapters on Jihad
2557,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ مُسَاوِرٍ، حَدَّثَنِي جَعْفَرُ بْنُ عَمْرِو بْنِ حُرَيْثٍ، عَنْ أَبِيهِ، قَالَ كَأَنِّي أَنْظُرُ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم وَعَلَيْهِ عِمَامَةٌ سَوْدَاءُ قَدْ أَرْخَى طَرَفَيْهَا بَيْنَ كَتِفَيْهِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الحدود ۱۰ (۱۴۳۷)،(تحفة الأشراف:۲۱۷۵)، وقد أخرجہ:(حم (۵/۹۱،۹۴،۹۶،۹۷،۱۰۴),2557,Ja’far\nbin ‘Amr bin Huraith narrated that his father said:,The Chapters on Jihad
2558,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا حَمَّادُ بْنُ سَلَمَةَ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم دَخَلَ مَكَّةَ وَعَلَيْهِ عِمَامَةٌ سَوْدَاءُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الحدود ۶ (۱۷۰۰)، سنن ابی داود/الحدود ۲۶ (۴۴۴۷)،(تحفة الأشراف:۱۷۷۱)، وقد أخرجہ: مسند احمد (۲۸۶،۲۹۰،۳۰۰),2558,,The Chapters on Jihad
2559,حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عَبْدِ الْكَرِيمِ، حَدَّثَنَا سُنَيْدُ بْنُ دَاوُدَ، عَنْ خَالِدِ بْنِ حَيَّانَ الرَّقِّيِّ، أَنْبَأَنَا عَلِيُّ بْنُ عُرْوَةَ الْبَارِقِيُّ، حَدَّثَنَا يُونُسُ بْنُ يَزِيدَ، عَنْ أَبِي الزِّنَادِ، عَنْ خَارِجَةَ بْنِ زَيْدٍ، قَالَ رَأَيْتُ رَجُلاً سَأَلَ أَبِي عَنِ الرَّجُلِ، يَغْزُو فَيَشْتَرِي وَيَبِيعُ وَيَتَّجِرُ فِي غَزْوِهِ فَقَالَ لَهُ أَبِي كُنَّا مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم بِتَبُوكَ نَشْتَرِي وَنَبِيعُ وَهُوَ يَرَانَا وَلاَ يَنْهَانَا ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۸۷۷، ومصباح الزجاجة:۹۰۵)، وقد أخرجہ: صحیح البخاری/الطلاق ۳۱ (۵۳۱۰)،۳۶ (۵۳۱۶)، الحدود ۴۳ (۶۸۵۶)، صحیح مسلم/اللعان ۱ (۱۴۹۷)، سنن النسائی/الطلاق ۳۶ (۳۴۹۷)، مسند احمد (۱/۳۳۵،۳۵۷،۳۶۵),2559,It was\nnarrated that Kharijah bin Zaid said:,The Chapters on Jihad
2560,"حَدَّثَنَا جَعْفَرُ بْنُ مُسَافِرٍ، حَدَّثَنَا أَبُو الأَسْوَدِ، حَدَّثَنَا ابْنُ لَهِيعَةَ، عَنْ زَبَّانَ بْنِ فَائِدٍ، عَنْ سَهْلِ بْنِ مُعَاذِ بْنِ أَنَسٍ، عَنْ أَبِيهِ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ لأَنْ أُشَيِّعَ مُجَاهِدًا فِي سَبِيلِ اللَّهِ فَأَكُفَّهُ عَلَى رَحْلِهِ غَدْوَةً أَوْ رَوْحَةً أَحَبُّ إِلَىَّ مِنَ الدُّنْيَا وَمَا فِيهَا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحدود ۳۰ (۶۸۵۵)، التمني ۹ (۷۲۳۸)، صحیح مسلم/اللعان (۱۴۹۷)،(تحفة الأشراف:۶۳۲۷)، وقد أخرجہ: مسند احمد (۱/۳۳۵،۳۳۶،۳۵۷،۳۶۵),,"It was\nnarrated from Sahl bin Mu’adh bin Anas, from his father, that\nthe\nMessenger of Allah (ﷺ) said:",The Chapters on Jihad
2561,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا ابْنُ لَهِيعَةَ، عَنِ الْحَسَنِ بْنِ ثَوْبَانَ، عَنْ مُوسَى بْنِ وَرْدَانَ، عَنْ أَبِي هُرَيْرَةَ، قَالَ وَدَّعَنِي رَسُولُ اللَّهِ صلى الله عليه وسلم فَقَالَ ‏ ‏ أَسْتَوْدِعُكَ اللَّهَ الَّذِي لاَ تَضِيعُ وَدَائِعُهُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الحدود ۲۹ (۴۴۶۲)، سنن الترمذی/الحدود ۲۴ (۱۴۵۶)،(تحفة الأشراف:۶۱۷۶)، وقد أخرجہ: مسند احمد (۱/۲۶۹،۳۰۰),,It was\nnarrated that Abu Hurairah said:,The Chapters on Jihad
2562,"حَدَّثَنَا عَبَّادُ بْنُ الْوَلِيدِ، حَدَّثَنَا حَبَّانُ بْنُ هِلاَلٍ، حَدَّثَنَا أَبُو مِحْصَنٍ، عَنِ ابْنِ أَبِي لَيْلَى، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا أَشْخَصَ السَّرَايَا يَقُولُ لِلشَّاخِصِ ‏ ‏ أَسْتَوْدِعُ اللَّهَ دِينَكَ وَأَمَانَتَكَ وَخَوَاتِيمَ عَمَلِكَ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۶۸۶، ومصباح الزجاجة:۹۰۶)، وقد أخرجہ: سنن الترمذی/الحدود ۲۴،(۱۴۵۶ تعلیقاً),,It was\nnarrated that Ibn ‘Umar said:,The Chapters on Jihad
2563,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا عَبْدُ الْمَلِكِ بْنُ مُحَمَّدٍ الصَّنْعَانِيُّ، حَدَّثَنَا أَبُو سَلَمَةَ الْعَامِلِيُّ، عَنِ ابْنِ شِهَابٍ، عَنْ أَنَسِ بْنِ مَالِكٍ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ لأَكْثَمَ بْنِ الْجَوْنِ الْخُزَاعِيِّ ‏ ‏ يَا أَكْثَمُ اغْزُ مَعَ غَيْرِ قَوْمِكَ يَحْسُنْ خُلُقُكَ وَتَكْرُمْ عَلَى رُفَقَائِكَ يَا أَكْثَمُ خَيْرُ الرُّفَقَاءِ أَرْبَعَةٌ وَخَيْرُ السَّرَايَا أَرْبَعُمِائَةٍ وَخَيْرُ الْجُيُوشِ أَرْبَعَةُ آلاَفٍ وَلَنْ يُغْلَبَ اثْنَا عَشَرَ أَلْفًا مِنْ قِلَّةٍ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الحدود ۲۴ (۱۴۵۷)،(تحفة الأشراف:۲۳۶۷)، وقد أخرجہ: مسند احمد (۳/۳۸۲),,It was\nnarrated from Anas bin Malik that the Messenger of Allah (ﷺ)\nsaid\nto Aktham bin Al-Jawn Al-Khuza’i:,The Chapters on Jihad
2564,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا أَبُو عَامِرٍ، حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي إِسْحَاقَ، عَنِ الْبَرَاءِ بْنِ عَازِبٍ، قَالَ كُنَّا نَتَحَدَّثُ أَنَّ أَصْحَابَ، رَسُولِ اللَّهِ صلى الله عليه وسلم كَانُوا يَوْمَ بَدْرٍ ثَلاَثَمِائَةٍ وَبِضْعَةَ عَشَرَ عَلَى عِدَّةِ أَصْحَابِ طَالُوتَ مَنْ جَازَ مَعَهُ النَّهَرَ وَمَا جَازَ مَعَهُ إِلاَّ مُؤْمِنٌ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۰۷۹، ومصباح الزجاجة:۹۰۷)، وقد أخرجہ: سنن الترمذی/الحدود ۲۳ (۱۴۵۵)، مسند احمد (۱/۳۰۰),2564,It was\nnarrated that Bara’ bin ‘Azib said:,The Chapters on Jihad
2565,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا زَيْدُ بْنُ الْحُبَابِ، عَنِ ابْنِ لَهِيعَةَ، أَخْبَرَنِي يَزِيدُ بْنُ أَبِي حَبِيبٍ، عَنْ لَهِيعَةَ بْنِ عُقْبَةَ، قَالَ سَمِعْتُ أَبَا الْوَرْدِ، صَاحِبَ النَّبِيِّ صلى الله عليه وسلم يَقُولُ إِيَّاكُمْ وَالسَّرِيَّةَ الَّتِي إِنْ لَقِيَتْ فَرَّتْ وَإِنْ غَنِمَتْ غَلَّتْ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحدود ۲۲ (۶۸۳۷،۶۸۳۸)، صحیح مسلم/الحدود ۶ (۱۷۰۳)، سنن ابی داود/الحدود ۳۳ (۴۴۶۹)، سنن الترمذی/الحدود ۱۳ (۱۴۳۳)،(تحفة الأشراف:۳۷۵۶،۴۸۱۴،۱۴۱۰۷)، وقد أخرجہ: موطا امام مالک/الحدود ۳ (۱۴)، مسند احمد (۴/۱۱۶،۱۱۷)سنن الدارمی/الحدود ۱۲ (۲۳۷۱),2565,It was\nnarrated that Lahi’ah bin ‘Uqbah said:,The Chapters on Jihad
2566,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ سِمَاكِ بْنِ حَرْبٍ، عَنْ قَبِيصَةَ بْنِ هُلْبٍ، عَنْ أَبِيهِ، قَالَ سَأَلْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم عَنْ طَعَامِ النَّصَارَى فَقَالَ ‏ ‏ لاَ يَخْتَلِجَنَّ فِي صَدْرِكَ طَعَامٌ ضَارَعْتَ فِيهِ نَصْرَانِيَّةً ‏""""‏ ‏.‏""",Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۹۰۹، ومصباح الزجاجة:۹۰۸)، وقد أخرجہ: مسند احمد (۶/۶۵),,It was\nnarrated from Qabisah bin Hulb that his father said:,The Chapters on Jihad
2567,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو أُسَامَةَ، حَدَّثَنِي أَبُو فَرْوَةَ، يَزِيدُ بْنُ سِنَانٍ حَدَّثَنِي عُرْوَةُ بْنُ، رُوَيْمٍ اللَّخْمِيُّ، عَنْ أَبِي ثَعْلَبَةَ الْخُشَنِيِّ، - قَالَ وَلَقِيَهُ وَكَلَّمَهُ - قَالَ أَتَيْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم فَسَأَلْتُهُ فَقُلْتُ يَا رَسُولَ اللَّهِ قُدُورُ الْمُشْرِكِينَ نَطْبُخُ فِيهَا قَالَ ‏""‏ لاَ تَطْبُخُوا فِيهَا ‏""‏ ‏.‏ قُلْتُ فَإِنِ احْتَجْنَا إِلَيْهَا فَلَمْ نَجِدْ مِنْهَا بُدًّا قَالَ ‏""‏ فَارْحَضُوهَا رَحْضًا حَسَنًا ثُمَّ اطْبُخُوا وَكُلُوا ‏""‏ ‏.‏",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: سنن ابی داود/الحدود ۳۵ (۴۴۷۴،۴۴۷۵)، سنن الترمذی/تفسیر القرآن، سورة النور۲۵ (۳۱۸۱)،(تحفة الأشراف:۱۷۸۹۸)، وقد أخرجہ: مسند احمد (۶/۳۵،۶۱),2567,‘Urwah\nbin Ruwaim Al-Lakhmi narrated that Abu Tha’labah Al-Khushani –\nwhom he said he met and spoke with – said:,The Chapters on Jihad
2568,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ عَبْدِ اللَّهِ بْنِ يَزِيدَ، عَنْ نِيَارٍ، عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، عَنْ عَائِشَةَ، قَالَتْ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّا لاَ نَسْتَعِينُ بِمُشْرِكٍ ‏""""‏ ‏.‏ قَالَ عَلِيٌّ فِي حَدِيثِهِ عَبْدُ اللَّهِ بْنُ يَزِيدَ أَوْ زَيْدٍ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۰۷۵، ومصباح الزجاجة:۹۰۹)، وقد أخرجہ: سنن الترمذی/الحدود ۲۹ (۱۴۶۲)، ولم یذکر الشطر الثانی: وَإِذَا قَالَ الرَّجُلُ لِلرَّجُلِ: يَا لُوطِيُّ! ......),,It was\nnarrated from ‘Aishah that the Messenger of Allah (ﷺ) said:,The Chapters on Jihad
2569,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ يَزِيدَ بْنِ رُومَانَ، عَنْ عُرْوَةَ، عَنْ عَائِشَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ الْحَرْبُ خُدْعَةٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحدود ۵ (۶۷۷۸)، صحیح مسلم/الحدود ۸ (۱۷۰۷)، سنن ابی داود/الحدود ۳۷ (۴۴۸۶)،(تحفة الأشراف:۱۰۲۵۴)، وقد أخرجہ: مسند احمد (۱/۱۲۵،۱۳۰),,It was\nnarrated from ‘Aishah that the Prophet (ﷺ) said:,The Chapters on Jihad
2570,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، عَنْ مَطَرِ بْنِ مَيْمُونٍ، عَنْ عِكْرِمَةَ، عَنِ ابْنِ عَبَّاسٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏ ‏ الْحَرْبُ خُدْعَةٌ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۲۶)، وقد أخرجہ: صحیح البخاری/الحدود ۲ (۶۷۷۳)، صحیح مسلم/الحدود ۸ (۱۷۰۶)، سنن ابی داود/الحدود ۳۷ (۴۴۸۷)، سنن الترمذی/الحدود ۱۴ (۱۴۴۳)، مسند احمد (۱/۱۷۶،۲۷۲)، سنن الدارمی/الحدود ۸ (۲۳۵۷),,It was\nnarrated from Ibn ‘Abbas that the Prophet (ﷺ) said:,The Chapters on Jihad
2571,حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، وَحَفْصُ بْنُ عَمْرٍو، قَالاَ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ، أَنْبَأَنَا وَكِيعٌ، قَالاَ حَدَّثَنَا سُفْيَانُ، عَنْ أَبِي هَاشِمٍ الرُّمَّانِيِّ، - قَالَ أَبُو عَبْدِ اللَّهِ هُوَ يَحْيَى بْنُ الأَسْوَدِ - عَنْ أَبِي مِجْلَزٍ، عَنْ قَيْسِ بْنِ عُبَادٍ، قَالَ سَمِعْتُ أَبَا ذَرٍّ، يُقْسِمُ لَنَزَلَتْ هَذِهِ الآيَاتُ فِي هَؤُلاَءِ الرَّهْطِ السِّتَّةِ يَوْمَ بَدْرٍ ‏{‏هَذَانِ خَصْمَانِ اخْتَصَمُوا فِي رَبِّهِمْ‏}‏ إِلَى قَوْلِهِ‏:‏ ‏{‏ إِنَّ اللَّهَ يَفْعَلُ مَا يُرِيدُ‏}‏ فِي حَمْزَةَ بْنِ عَبْدِ الْمُطَّلِبِ وَعَلِيِّ بْنِ أَبِي طَالِبٍ وَعُبَيْدَةَ بْنِ الْحَارِثِ وَعُتْبَةَ بْنِ رَبِيعَةَ وَشَيْبَةَ بْنِ رَبِيعَةَ وَالْوَلِيدِ بْنِ عُتْبَةَ اخْتَصَمُوا فِي الْحُجَجِ يَوْمَ بَدْرٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح البخاری/الحدود ۴ (۶۷۷۳)، صحیح مسلم/الحدود ۸ (۱۷۰۷)، سنن ابی داود/الحدود ۳۶ (۴۴۸۰،۴۴۸۱،۴۴۷۹)،(تحفة الأشراف:۱۰۰۸۰،۱۳۵۲)، وقد أخرجہ: مسند احمد (۱/۸۲،۶۴۰،۱۴۴)، سنن الدارمی/الحدود ۹ (۲۳۵۸),2571,It was\nnarrated that Qais bin ‘Ubaid said:,The Chapters on Jihad
2572,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا أَبُو الْعُمَيْسِ، وَعِكْرِمَةُ بْنُ عَمَّارٍ، عَنْ إِيَاسِ بْنِ سَلَمَةَ بْنِ الأَكْوَعِ، عَنْ أَبِيهِ، قَالَ بَارَزْتُ رَجُلاً فَقَتَلْتُهُ فَنَفَّلَنِي رَسُولُ اللَّهِ صلى الله عليه وسلم سَلَبَهُ ‏.‏,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الحدود ۳۷ (۴۴۸۴)، سنن النسائی/الأشربة ۴۳ (۵۷۶۵)،(تحفة الأشراف:۱۳۹۴۸)، وقد أخرجہ: مسند احمد (۲/۲۸۰،۲۹۱،۵۰۴،۵۱۹),2572,It was\nnarrated from Iyas bin Salamah bin Akwa’ that his father said:,The Chapters on Jihad
2573,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ عُمَرَ بْنِ كَثِيرِ بْنِ أَفْلَحَ، عَنْ أَبِي مُحَمَّدٍ، مَوْلَى أَبِي قَتَادَةَ عَنْ أَبِي قَتَادَةَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَفَّلَهُ سَلَبَ قَتِيلٍ قَتَلَهُ يَوْمَ حُنَيْنٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الحدود ۳۷ (۴۴۸۲)، سنن الترمذی/الحدود ۱۵ (۱۴۴۴)،(تحفة الأشراف:۱۱۴۱۲)، وقد أخرجہ: مسند احمد۴/۹۵،۹۶،۱۰۰),2573,,The Chapters on Jihad
2574,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، حَدَّثَنَا أَبُو مَالِكٍ الأَشْجَعِيُّ، عَنْ نُعَيْمِ بْنِ أَبِي هِنْدٍ، عَنِ ابْنِ سَمُرَةَ بْنِ جُنْدُبٍ، عَنْ أَبِيهِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ قَتَلَ فَلَهُ السَّلَبُ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱ ۴۴۷، ومصباح الزجاجة:۹۱۰)، وقد أخرجہ: سنن ابی داود/الحدود ۳۴ (۴۴۷۲)، مسند احمد (۵/۲۲۲),,It was\nnarrated from the son of Samurah bin Jundub that his father\nsaid:,The Chapters on Jihad
2575,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنِ الزُّهْرِيِّ، عَنْ عُبَيْدِ اللَّهِ بْنِ عَبْدِ اللَّهِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ حَدَّثَنَا الصَّعْبُ بْنُ جَثَّامَةَ، قَالَ سُئِلَ النَّبِيُّ صلى الله عليه وسلم عَنْ أَهْلِ الدَّارِ مِنَ الْمُشْرِكِينَ يُبَيَّتُونَ فَيُصَابُ النِّسَاءُ وَالصِّبْيَانُ قَالَ ‏ ‏ هُمْ مِنْهُمْ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «حدیث یعقوب بن حمید بن کاسب عن عبدالعزیز أخرجہ: صحیح مسلم/الإیمان ۴۳ (۱۰۱)،(تحفة الأشراف:۱۲۶۹۲)، وحدیث یعقوب بن حمید بن کاسب عن المغیرة بن عبدالرحمن تفرد بہ ابن ماجہ، تحفة الأشراف:۱۴۱۴۹)، وحدیث یعقوب بن حمید بن کاسب عن أنس بن عیاض قد تفرد بہ ابن ماجہ، تحفة الأشراف:۱۴۶۰۱،۱۴۶۳۱),,It was\nnarrated that Ibn ‘Abbas said:,The Chapters on Jihad
2576,حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ، أَنْبَأَنَا وَكِيعٌ، عَنْ عِكْرِمَةَ بْنِ عَمَّارٍ، عَنْ إِيَاسِ بْنِ سَلَمَةَ بْنِ الأَكْوَعِ، عَنْ أَبِيهِ، قَالَ غَزَوْنَا مَعَ أَبِي بَكْرٍ هَوَازِنَ عَلَى عَهْدِ النَّبِيِّ صلى الله عليه وسلم فَأَتَيْنَا مَاءً لِبَنِي فَزَارَةَ فَعَرَّسْنَا حَتَّى إِذَا كَانَ عِنْدَ الصُّبْحُ شَنَنَّاهَا عَلَيْهِمْ غَارَةً فَأَتَيْنَا أَهْلَ مَاءٍ فَبَيَّتْنَاهُمْ فَقَتَلْنَاهُمْ تِسْعَةً أَوْ سَبْعَةَ أَبْيَاتٍ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الایمان ۴۲ (۱۰۰)،(تحفة الأشراف:۷۸۳۶)، وقد أخرجہ: صحیح البخاری/الفتن ۷ (۷۰۷۰)، مسند احمد (۲/۳،۳۵،۱۴۲),2576,"It was\nnarrated from Iyas bin Salamah bin Awka’, that his father\nsaid:",The Chapters on Jihad
2577,حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، حَدَّثَنَا عُثْمَانُ بْنُ عُمَرَ، أَنْبَأَنَا مَالِكُ بْنُ أَنَسٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم رَأَى امْرَأَةً مَقْتُولَةً فِي بَعْضِ الطَّرِيقِ فَنَهَى عَنْ قَتْلِ النِّسَاءِ وَالصِّبْيَانِ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الفتن ۷ (۷۰۷۱)، صحیح مسلم/الایمان ۴۲ (۱۰۰)، سنن الترمذی/الحدود ۲۶ (۱۴۵۹)،(تحفة الأشراف:۹۰۴۲),2577,,The Chapters on Jihad
2578,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ أَبِي الزِّنَادِ، عَنِ الْمُرَقَّعِ بْنِ عَبْدِ اللَّهِ بْنِ صَيْفِيٍّ، عَنْ حَنْظَلَةَ الْكَاتِبِ، قَالَ غَزَوْنَا مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم فَمَرَرْنَا عَلَى امْرَأَةٍ مَقْتُولَةٍ قَدِ اجْتَمَعَ عَلَيْهَا النَّاسُ فَأَفْرَجُوا لَهُ فَقَالَ ‏(‏مَا كَانَتْ هَذِهِ تُقَاتِلُ فِيمَنْ يُقَاتِلُ‏)‏ ‏.‏ ثُمَّ قَالَ لِرَجُلٍ ‏(‏انْطَلِقْ إِلَى خَالِدِ بْنِ الْوَلِيدِ فَقُلْ لَهُ إِنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم يَأْمُرُكَ يَقُولُ لاَ تَقْتُلَنَّ ذُرِّيَّةً وَلاَ عَسِيفًا‏)‏‏.‏ حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا قُتَيْبَةُ، حَدَّثَنَا الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَنِ، عَنْ أَبِي الزِّنَادِ، عَنِ الْمُرَقَّعِ، عَنْ جَدِّهِ، رَبَاحِ بْنِ الرَّبِيعِ عَنِ النَّبِيِّ صلى الله عليه وسلم نَحْوَهُ.‏ قَالَ أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ يُخْطِئُ الثَّوْرِيُّ فِيهِ.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۲۸)، وقد أخرجہ: صحیح البخاری/الوضو ۶۷ (۲۲۳)، الزکاة ۶۸ (۱۵۰۱)، الجہاد ۱۵۲ (۳۰۱۸)، المغازي ۳۷ (۱۴۹۲،۱۴۹۳)، الطب ۵ (۵۶۸۵)،۶ (۵۶۸۶)،۲۹ (۵۷۲۷)، الحدود ۱ (۶۸۰۲)،۲ (۶۸۰۳)،۳ (۶۸۰۴)،۴ (۶۸۰۵)، الدیات ۲۲ (۶۸۹۹)، صحیح مسلم/القسامة ۲ (۱۶۷۱)، سنن ابی داود/الحدود ۳ (۴۳۶۴)، سنن الترمذی/الاطعمة ۳۸ (۱۸۴۵)، الطب ۶ (۲۰۴۲)، سنن النسائی/الطہارة ۱۹۱ (۳۰۶)، المحاربة (تحریم الدم)۷ (۴۰۲۹)، مسند احمد (۳/۱۶۱،۱۶۳،۱۷۰،۲۳۳),,It was\nnarrated that Hanzalah Al-Katib said:,The Chapters on Jihad
2579,"حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيلَ بْنِ سَمُرَةَ، حَدَّثَنَا وَكِيعٌ، عَنْ صَالِحِ بْنِ أَبِي الأَخْضَرِ، عَنِ الزُّهْرِيِّ، عَنْ عُرْوَةَ بْنِ الزُّبَيْرِ، عَنْ أُسَامَةَ بْنِ زَيْدٍ، قَالَ بَعَثَنِي رَسُولُ اللَّهِ صلى الله عليه وسلم إِلَى قَرْيَةٍ يُقَالُ لَهَا أُبْنَى فَقَالَ ‏ ‏ ائْتِ أُبْنَى صَبَاحًا ثُمَّ حَرِّقْ ‏""""‏ ‏.‏""",Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/المحاریة (تحریم الدم)۷ (۴۰۴۳)،(تحفة الأشراف:۱۷۰۳۲),,It was\nnarrated that Usamah bin Said said:,The Chapters on Jihad
2580,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم حَرَّقَ نَخْلَ بَنِي النَّضِيرِ وَقَطَعَ ‏.‏ وَهِيَ الْبُوَيْرَةُ فَأَنْزَلَ اللَّهُ عَزَّ وَجَلَّ ‏{مَا قَطَعْتُمْ مِنْ لِينَةٍ أَوْ تَرَكْتُمُوهَا قَائِمَةً }‏ الآيَةَ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: سنن ابی داود/السنة ۳۲ (۴۷۷۲)، سنن الترمذی/الدیات ۲۲ (۱۴۲۱)، سنن النسائی/الدم ۱۸ (۴۰۹۵،۴۰۹۶،۴۰۹۹)،(تحفة الأشراف:۴۴۵۶)، وقد أخرجہ: مسند احمد (۱/۱۸۷،۱۸۸،۱۸۹،۱۹۰),2580,"It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nburned\nthe palm trees of Banu Nadir, and cut down Buwairah (the name\nof\ntheir garden). Then Allah revealed the words:",The Chapters on Jihad
2581,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، حَدَّثَنَا عُقْبَةُ بْنُ خَالِدٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم حَرَّقَ نَخْلَ بَنِي النَّضِيرِ وَقَطَعَ ‏.‏ وَفِيهِ يَقُولُ شَاعِرُهُمْ فَهَانَ عَلَى سَرَاةِ بَنِي لُؤَىٍّ حَرِيقٌ بِالْبُوَيْرَةِ مُسْتَطِيرُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۴۶۸، ومصباح الزجاجة:۹۱۲,2581,"It was\nnarrated from Ibn ‘Umar that the Prophet (ﷺ) burned the palm\ntrees of Banu Nadir and cut them down. Concerning that, their poet\nsaid:",The Chapters on Jihad
2582,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، وَمُحَمَّدُ بْنُ إِسْمَاعِيلَ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ عِكْرِمَةَ بْنِ عَمَّارٍ، عَنْ إِيَاسِ بْنِ سَلَمَةَ بْنِ الأَكْوَعِ، عَنْ أَبِيهِ، قَالَ غَزَوْنَا مَعَ أَبِي بَكْرٍ هَوَازِنَ عَلَى عَهْدِ رَسُولِ اللَّهِ صلى الله عليه وسلم فَنَفَّلَنِي جَارِيَةً مِنْ بَنِي فَزَارَةَ مِنْ أَجْمَلِ الْعَرَبِ عَلَيْهَا قِشْعٌ لَهَا فَمَا كَشَفْتُ لَهَا عَنْ ثَوْبٍ حَتَّى أَتَيْتُ الْمَدِينَةَ فَلَقِيَنِي النَّبِيُّ صلى الله عليه وسلم فِي السُّوقِ فَقَالَ ‏ ‏ لِلَّهِ أَبُوكَ هَبْهَا لِي ‏""""‏ ‏.‏ فَوَهَبْتُهَا لَهُ فَبَعَثَ بِهَا فَفَادَى بِهَا أُسَارَى مِنْ أُسَارَى الْمُسْلِمِينَ كَانُوا بِمَكَّةَ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۶۵۷، ومصباح الزجاجة:۹۱۲)، وقد أخرجہ: مسند احمد (۲/۱۹۴،۳۲۴),,It was\nnarrated from Ayas bin Salamah bin Akwa’ that his father said:,The Chapters on Jihad
2583,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ ذَهَبَتْ فَرَسٌ لَهُ فَأَخَذَهَا الْعَدُوُّ فَظَهَرَ عَلَيْهِمُ الْمُسْلِمُونَ فَرُدَّ عَلَيْهِ فِي زَمَنِ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏ قَالَ وَأَبَقَ عَبْدٌ لَهُ فَلَحِقَ بِالرُّومِ فَظَهَرَ عَلَيْهِمُ الْمُسْلِمُونَ فَرَدَّهُ عَلَيْهِ خَالِدُ بْنُ الْوَلِيدِ بَعْدَ وَفَاةِ رَسُولِ اللَّهِ صلى الله عليه وسلم ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحدود ۲۳ (۱۶۸۷)،(تحفة الأشراف:۱۲۵۱۵)، وقد أخرجہ: مسند احمد (۲/۲۴۳،۳۱۷،۳۷۶،۳۸۶،۳۸۹),2583,It was\nnarrated that Ibn ‘Umar said that a horse of his went out and the\nenemy captured it. Then the Muslims defeated them and it was returned\nto him. (That was) during the time of the Messenger of Allah (ﷺ).\nHe said:,The Chapters on Jihad
2584,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ يَحْيَى بْنِ سَعِيدٍ، عَنْ مُحَمَّدِ بْنِ يَحْيَى بْنِ حَبَّانَ، عَنْ أَبِي عَمْرَةَ، عَنْ زَيْدِ بْنِ خَالِدٍ الْجُهَنِيِّ، قَالَ تُوُفِّيَ رَجُلٌ مِنْ أَشْجَعَ بِخَيْبَرَ فَقَالَ النَّبِيُّ صلى الله عليه وسلم ‏""‏ صَلُّوا عَلَى صَاحِبِكُمْ ‏""‏ ‏.‏ فَأَنْكَرَ النَّاسُ ذَلِكَ وَتَغَيَّرَتْ لَهُ وُجُوهُهُمْ فَلَمَّا رَأَى ذَلِكَ قَالَ ‏""‏ إِنَّ صَاحِبَكُمْ غَلَّ فِي سَبِيلِ اللَّهِ ‏""‏ ‏.‏ قَالَ زَيْدٌ فَالْتَمَسُوا فِي مَتَاعِهِ فَإِذَا خَرَزَاتٌ مِنْ خَرَزِ يَهُودَ مَا تُسَاوِي دِرْهَمَيْنِ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحدود ۱ (۱۶۸۶)، سنن ابی داود/الحدود ۱۱ (۴۳۸۵)، سنن الترمذی/الحدود ۱۶ (۱۴۴۶)، سنن النسائی/قطع السارق ۷ (۴۹۱۲)،(تحفة الأشراف:۸۰۶۷)، وقد أخرجہ: صحیح البخاری/الحدود ۱۴ (۶۷۹۵،۶۷۹۶،۶۷۹۷،۶۷۹۸)، مسند احمد (۶/۱۶۲)، سنن الدارمی/الحدود ۴،۲۴۶),2584,It was\nnarrated that Zaid bin Khalid Al-Juhani said:,The Chapters on Jihad
2585,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، عَنْ عَمْرِو بْنِ دِينَارٍ، عَنْ سَالِمِ بْنِ أَبِي الْجَعْدِ، عَنْ عَبْدِ اللَّهِ بْنِ عَمْرٍو، قَالَ كَانَ عَلَى ثَقَلِ النَّبِيِّ صلى الله عليه وسلم رَجُلٌ يُقَالُ لَهُ كِرْكِرَةُ ‏.‏ فَمَاتَ فَقَالَ النَّبِيُّ صلى الله عليه وسلم ‏ ‏ هُوَ فِي النَّارِ ‏""""‏ ‏.‏ فَذَهَبُوا يَنْظُرُونَ فَوَجَدُوا عَلَيْهِ كِسَاءً أَوْ عَبَاءَةً قَدْ غَلَّهَا ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحدود ۱۴ (۶۷۸۹)، صحیح مسلم/الحدود ۱ (۱۶۸۴)، سنن ابی داود/الحدود ۱۱ (۴۳۸۳)، سنن الترمذی/الحدود ۱۶ (۱۴۴۵)، سنن النسائی/قطع السارق ۷ (۴۹۲۰)،(تحفة الأشراف:۱۷۹۲۰)، و قد أخرجہ: موطا امام مالک/الحدود ۷ (۲۳)، مسند احمد (۶/۳۶،۸۰،۸۱،۱۰۴،۱۶۳،۲۴۹،۲۵۲)، سنن الدارمی/الحدود ۴ (۲۳۴۶),,It was\nnarrated that ‘Abdullah bin ‘Amr said:,The Chapters on Jihad
2586,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو أُسَامَةَ، عَنْ أَبِي سِنَانٍ، عِيسَى بْنِ سِنَانٍ عَنْ يَعْلَى بْنِ شَدَّادٍ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، قَالَ صَلَّى بِنَا رَسُولُ اللَّهِ صلى الله عليه وسلم يَوْمَ حُنَيْنٍ إِلَى جَنْبِ بَعِيرٍ مِنَ الْمَقَاسِمِ ثُمَّ تَنَاوَلَ شَيْئًا مِنَ الْبَعِيرِ فَأَخَذَ مِنْهُ قَرَدَةً - يَعْنِي وَبَرَةً - فَجَعَلَ بَيْنَ إِصْبَعَيْهِ ثُمَّ قَالَ ‏ ‏ يَا أَيُّهَا النَّاسُ إِنَّ هَذَا مِنْ غَنَائِمِكُمْ أَدُّوا الْخَيْطَ وَالْمِخْيَطَ فَمَا فَوْقَ ذَلِكَ فَمَا دُونَ ذَلِكَ فَإِنَّ الْغُلُولَ عَارٌ عَلَى أَهْلِهِ يَوْمَ الْقِيَامَةِ وَشَنَارٌ وَنَارٌ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۸۸۳، ومصباح الزجاجة:۹۱۴)، وقد أخرجہ: مسند احمد (۱/۱۶۹),,It was\nnarrated that ‘Ubadah bin Samit said:,The Chapters on Jihad
2587,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ يَزِيدَ بْنِ يَزِيدَ بْنِ جَابِرٍ، عَنْ مَكْحُولٍ، عَنْ زَيْدِ بْنِ جَارِيَةَ، عَنْ حَبِيبِ بْنِ مَسْلَمَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَفَّلَ الثُّلُثَ بَعْدَ الْخُمُسِ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن ابی داود/الحدود ۲۱،(۴۴۱۱)، سنن الترمذی/الحدود ۱۷ (۱۴۴۷)، سنن النسائی/قطع السارق ۱۵ (۴۹۸۵)،(تحفة الأشراف:۱۱۰۲۹)، وقد أخرجہ: مسند احمد (۶/۱۹),2587,,The Chapters on Jihad
2588,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، عَنْ سُفْيَانَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ الزُّرَقِيِّ، عَنْ سُلَيْمَانَ بْنِ مُوسَى، عَنْ مَكْحُولٍ، عَنْ أَبِي سَلاَّمٍ الأَعْرَجِ، عَنْ أَبِي أُمَامَةَ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَفَّلَ فِي الْبَدْأَةِ الرُّبُعَ وَفِي الرَّجْعَةِ الثُّلُثَ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۰۷۵، ومصباح الزجاجة:۹۱۵),2588,,The Chapters on Jihad
2589,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو الْحُسَيْنِ، أَنْبَأَنَا رَجَاءُ بْنُ أَبِي سَلَمَةَ، حَدَّثَنَا عَمْرُو بْنُ شُعَيْبٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ، قَالَ لاَ نَفَلَ بَعْدَ رَسُولِ اللَّهِ صلى الله عليه وسلم يَرُدُّ الْمُسْلِمُونَ قَوِيُّهُمْ عَلَى ضَعِيفِهِمْ ‏.‏ قَالَ رَجَاءٌ فَسَمِعْتُ سُلَيْمَانَ بْنَ مُوسَى، يَقُولُ لَهُ حَدَّثَنِي مَكْحُولٌ، عَنْ حَبِيبِ بْنِ مَسْلَمَةَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم نَفَّلَ فِي الْبَدْأَةِ الرُّبُعَ وَحِينَ قَفَلَ الثُّلُثَ ‏.‏ فَقَالَ عَمْرٌو أُحَدِّثُكَ عَنْ أَبِي عَنْ جَدِّي وَتُحَدِّثُنِي عَنْ مَكْحُولٍ""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الحدود ۲۲ (۴۴۱۲)، سنن النسائی/قطع السارق ۱۳ (۴۹۸۳)،(تحفة الأشراف:۱۴۹۷۹),,‘Amr\nbin Shu’aib narrated from his father that his grandfather said:,The Chapters on Jihad
2590,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ النَّبِيَّ صلى الله عليه وسلم أَسْهَمَ يَوْمَ خَيْبَرَ لِلْفَارِسِ ثَلاَثَةَ أَسْهُمٍ لِلْفَرَسِ سَهْمَانِ وَلِلرَّجُلِ سَهْمٌ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۵۰۸ (ألف)، ومصباح الزجاجة:۹۱۶),2590,,The Chapters on Jihad
2591,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا هِشَامُ بْنُ سَعْدٍ، عَنْ مُحَمَّدِ بْنِ زَيْدِ بْنِ مُهَاجِرِ بْنِ قُنْفُذٍ، قَالَ سَمِعْتُ عُمَيْرًا، مَوْلَى آبِي اللَّحْمِ - قَالَ وَكِيعٌ كَانَ لاَ يَأْكُلُ اللَّحْمَ - قَالَ غَزَوْتُ مَعَ مَوْلاَىَ يَوْمَ خَيْبَرَ وَأَنَا مَمْلُوكٌ فَلَمْ يَقْسِمْ لِي مِنَ الْغَنِيمَةِ وَأُعْطِيتُ مِنْ خُرْثِيِّ الْمَتَاعِ سَيْفًا فَكُنْتُ أَجُرُّهُ إِذَا تَقَلَّدْتُهُ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحدود ۱۳ (۴۳۹۱،۴۳۹۲)، سنن الترمذی/الحدود ۱۸ (۱۴۴۸)، سنن النسائی/قطع السارق ۱۰ (۴۹۷۵)،(تحفة الأشراف:۲۸۰۰)، وقد أخرجہ: مسند احمد (۳/۳۸۰)، سنن الدارمی/الحدود ۸ (۴۹۸۸),2591,"‘Umair,\nthe freed slave of Aabi Lahm – Waki’ said; - “He used to not\neat meat” – said:",The Chapters on Jihad
2592,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، عَنْ هِشَامٍ، عَنْ حَفْصَةَ بِنْتِ سِيرِينَ، عَنْ أُمِّ عَطِيَّةَ الأَنْصَارِيَّةِ، قَالَتْ غَزَوْتُ مَعَ رَسُولِ اللَّهِ صلى الله عليه وسلم سَبْعَ غَزَوَاتٍ أَخْلُفُهُمْ فِي رِحَالِهِمْ وَأَصْنَعُ لَهُمُ الطَّعَامَ وَأُدَاوِي الْجَرْحَى وَأَقُومُ عَلَى الْمَرْضَى ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۷۱۵، ومصباح الزجاجة:۹۱۷),2592,It was\nnarrated that Umm ‘Atiyyah Al-Ansariyyah said:,The Chapters on Jihad
2593,"حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلاَّلُ، حَدَّثَنَا أَبُو أُسَامَةَ، حَدَّثَنِي عَطِيَّةُ بْنُ الْحَارِثِ أَبُو رَوْقٍ الْهَمْدَانِيُّ، حَدَّثَنِي أَبُو الْغَرِيفِ، عُبَيْدُ اللَّهِ بْنُ خَلِيفَةَ عَنْ صَفْوَانَ بْنِ عَسَّالٍ، قَالَ بَعَثَنَا رَسُولُ اللَّهِ صلى الله عليه وسلم فِي سَرِيَّةٍ فَقَالَ ‏ ‏ سِيرُوا بِاسْمِ اللَّهِ وَفِي سَبِيلِ اللَّهِ قَاتِلُوا مَنْ كَفَرَ بِاللَّهِ وَلاَ تُمَثِّلُوا وَلاَ تَغْدِرُوا وَلاَ تَغُلُّوا وَلاَ تَقْتُلُوا وَلِيدًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/الحدود ۱۹ (۱۴۴۹)، سنن النسائی/قطع السارق ۱۰ (۴۹۶۴)،(تحفة الأشراف:۳۵۸۸)، وقد أخرجہ: سنن ابی داود/الحدود ۱۲ (۴۳۸۸)، موطا امام مالک/الحدود ۱۱ (۳۲)، مسند احمد (۳/۴۶۳،۴۶۴)، سنن الدارمی/الحدود ۷ (۲۳۵۰),,It was\nnarrated that Safwan bin ‘Assil said:,The Chapters on Jihad
2594,"حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ الْفِرْيَابِيُّ، حَدَّثَنَا سُفْيَانُ، عَنْ عَلْقَمَةَ بْنِ مَرْثَدٍ، عَنِ ابْنِ بُرَيْدَةَ، عَنْ أَبِيهِ، قَالَ كَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا أَمَّرَ رَجُلاً عَلَى سَرِيَّةٍ أَوْصَاهُ فِي خَاصَّةِ نَفْسِهِ بِتَقْوَى اللَّهِ وَمَنْ مَعَهُ مِنَ الْمُسْلِمِينَ خَيْرًا فَقَالَ ‏ ‏ اغْزُوا بِاسْمِ اللَّهِ وَفِي سَبِيلِ اللَّهِ قَاتِلُوا مَنْ كَفَرَ بِاللَّهِ اغْزُوا وَلاَ تَغْدِرُوا وَلاَ تَغُلُّوا وَلاَ تُمَثِّلُوا وَلاَ تَقْتُلُوا وَلِيدًا وَإِذَا أَنْتَ لَقِيتَ عَدُوَّكَ مِنَ الْمُشْرِكِينَ فَادْعُهُمْ إِلَى إِحْدَى ثَلاَثِ خِلاَلٍ أَوْ خِصَالٍ فَأَيَّتُهُنَّ أَجَابُوكَ إِلَيْهَا فَاقْبَلْ مِنْهُمْ وَكُفَّ عَنْهُمْ ادْعُهُمْ إِلَى الإِسْلاَمِ فَإِنْ أَجَابُوكَ فَاقْبَلْ مِنْهُمْ وَكُفَّ عَنْهُمْ ثُمَّ ادْعُهُمْ إِلَى التَّحَوُّلِ مِنْ دَارِهِمْ إِلَى دَارِ الْمُهَاجِرِينَ وَأَخْبِرْهُمْ إِنْ هُمْ فَعَلُوا ذَلِكَ أَنَّ لَهُمْ مَا لِلْمُهَاجِرِينَ وَأَنَّ عَلَيْهِمْ مَا عَلَى الْمُهَاجِرِينَ وَإِنْ أَبَوْا فَأَخْبِرْهُمْ أَنَّهُمْ يَكُونُونَ كَأَعْرَابِ الْمُسْلِمِينَ يَجْرِي عَلَيْهِمْ حُكْمُ اللَّهِ الَّذِي يَجْرِي عَلَى الْمُؤْمِنِينَ وَلاَ يَكُونُ لَهُمْ فِي الْفَىْءِ وَالْغَنِيمَةِ شَىْءٌ إِلاَّ أَنْ يُجَاهِدُوا مَعَ الْمُسْلِمِينَ فَإِنْ هُمْ أَبَوْا أَنْ يَدْخُلُوا فِي الإِسْلاَمِ فَسَلْهُمْ إِعْطَاءَ الْجِزْيَةِ فَإِنْ فَعَلُوا فَاقْبَلْ مِنْهُمْ وَكُفَّ عَنْهُمْ فَإِنْ هُمْ أَبَوْا فَاسْتَعِنْ بِاللَّهِ عَلَيْهِمْ وَقَاتِلْهُمْ وَإِنْ حَاصَرْتَ حِصْنًا فَأَرَادُوكَ أَنْ تَجْعَلَ لَهُمْ ذِمَّةَ اللَّهِ وَذِمَّةَ نَبِيِّكَ فَلاَ تَجْعَلْ لَهُمْ ذِمَّةَ اللَّهِ وَلاَ ذِمَّةَ نَبِيِّكَ وَلَكِنِ اجْعَلْ لَهُمْ ذِمَّتَكَ وَذِمَّةَ أَبِيكَ وَذِمَّةَ أَصْحَابِكَ فَإِنَّكُمْ إِنْ تُخْفِرُوا ذِمَّتَكُمْ وَذِمَّةَ آبَائِكُمْ أَهْوَنُ عَلَيْكُمْ مِنْ أَنْ تُخْفِرُوا ذِمَّةَ اللَّهِ وَذِمَّةَ رَسُولِهِ وَإِنْ حَاصَرْتَ حِصْنًا فَأَرَادُوكَ أَنْ يَنْزِلُوا عَلَى حُكْمِ اللَّهِ فَلاَ تُنْزِلْهُمْ عَلَى حُكْمِ اللَّهِ وَلَكِنْ أَنْزِلْهُمْ عَلَى حُكْمِكَ فَإِنَّكَ لاَ تَدْرِي أَتُصِيبُ فِيهِمْ حُكْمَ اللَّهِ أَمْ لاَ ‏""""‏ ‏.‏ قَالَ عَلْقَمَةُ فَحَدَّثْتُ بِهِ، مُقَاتِلَ بْنَ حَيَّانَ فَقَالَ حَدَّثَنِي مُسْلِمُ بْنُ هَيْصَمٍ، عَنِ النُّعْمَانِ بْنِ مُقَرِّنٍ، عَنِ النَّبِيِّ صلى الله عليه وسلم مِثْلَ ذَلِكَ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۹۶۷، ومصباح الزجاجة:۹۱۸),,It was\nnarrated from Ibn Buraidah that his father said:,The Chapters on Jihad
2595,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، قَالاَ حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا الأَعْمَشُ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ أَطَاعَنِي فَقَدْ أَطَاعَ اللَّهَ وَمَنْ عَصَانِي فَقَدْ عَصَى اللَّهَ وَمَنْ أَطَاعَ الإِمَامَ فَقَدْ أَطَاعَنِي وَمَنْ عَصَى الإِمَامَ فَقَدْ عَصَانِي ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الحدود ۱۴ (۴۳۹۴)، سنن النسائی/قطع السارق ۴ (۴۸۸۲ مرسلاً)،(تحفة الأشراف:۴۹۴۳)، وقد أخرجہ: موطا امام مالک/الحدود ۹ (۲۸)، مسند احمد (۳/۴۰۱،۶/۴۶۵،۴۶۶)، سنن الدارمی/الحدود ۳ (۲۳۴۵),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2596,"حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، وَأَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ قَالاَ حَدَّثَنَا يَحْيَى بْنُ سَعِيدٍ، حَدَّثَنَا شُعْبَةُ، حَدَّثَنِي أَبُو التَّيَّاحِ، عَنْ أَنَسِ بْنِ مَالِكٍ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ اسْمَعُوا وَأَطِيعُوا وَإِنِ اسْتُعْمِلَ عَلَيْكُمْ عَبْدٌ حَبَشِيٌّ كَأَنَّ رَأْسَهُ زَبِيبَةٌ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: سنن ابی داود/اللقطة ۱ (۱۷۱۱)، الحدود ۱۲ (۴۳۹۰)،(تحفة الأشراف:۸۸۱۲)، وقد أخرجہ: سنن الترمذی/البیوع ۵۴ (۱۲۸۹)، سنن النسائی/قطع السارق ۱۱ (۴۹۷۲)، مسند احمد (۲/۱۸۶),,It was\nnarrated from Anas bin Malik that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2597,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا وَكِيعُ بْنُ الْجَرَّاحِ، عَنْ شُعْبَةَ، عَنْ يَحْيَى بْنِ الْحُصَيْنِ، عَنْ جَدَّتِهِ أُمِّ الْحُصَيْنِ، قَالَتْ سَمِعْتُ رَسُولَ اللَّهِ صلى الله عليه وسلم يَقُولُ ‏ ‏ إِنْ أُمِّرَ عَلَيْكُمْ عَبْدٌ حَبَشِيٌّ مُجَدَّعٌ فَاسْمَعُوا لَهُ وَأَطِيعُوا مَا قَادَكُمْ بِكِتَابِ اللَّهِ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الحدود ۸ (۴۳۸۰)، سنن النسائی/قطع السارق ۳ (۴۸۸۱)،(تحفة الأشراف:۱۱۸۶۱)، وقد أخرجہ: مسند احمد (۵/۲۹۳)، سنن الدارمی/الحدود ۶ (۲۳۴۹),,It was\nnarrated from Umm Husain that she heard the Messenger of Allah\n(ﷺ)\nsay:,The Chapters on Jihad
2598,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، حَدَّثَنَا شُعْبَةُ، عَنْ أَبِي عِمْرَانَ الْجَوْنِيِّ، عَنْ عَبْدِ اللَّهِ بْنِ الصَّامِتِ، عَنْ أَبِي ذَرٍّ، أَنَّهُ انْتَهَى إِلَى الرَّبَذَةِ وَقَدْ أُقِيمَتِ الصَّلاَةُ فَإِذَا عَبْدٌ يَؤُمُّهُمْ فَقِيلَ هَذَا أَبُو ذَرٍّ ‏.‏ فَذَهَبَ يَتَأَخَّرُ فَقَالَ أَبُو ذَرٍّ أَوْصَانِي خَلِيلِي صلى الله عليه وسلم أَنْ أَسْمَعَ وَأُطِيعَ وَإِنْ كَانَ عَبْدًا حَبَشِيًّا مُجَدَّعَ الأَطْرَافِ ‏.‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: سنن الترمذی/الحدود ۲۲ (۱۴۵۳)،(تحفة الأشراف:۱۱۷۶۰)، وقد أخرجہ: مسند احمد (۴/۳۱۸),2598,"It was\nnarrated from Abu Dharr that he reached Rabadhah when the\nIqamah for\nthe prayer had already been given, and there was a slave\nleading them\nin prayer. It was said:",The Chapters on Jihad
2599,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، حَدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو، عَنْ عُمَرَ بْنِ الْحَكَمِ بْنِ ثَوْبَانَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم بَعَثَ عَلْقَمَةَ بْنَ مُجَزِّزٍ عَلَى بَعْثٍ وَأَنَا فِيهِمْ فَلَمَّا انْتَهَى إِلَى رَأْسِ غَزَاتِهِ أَوْ كَانَ بِبَعْضِ الطَّرِيقِ اسْتَأْذَنَتْهُ طَائِفَةٌ مِنَ الْجَيْشِ فَأَذِنَ لَهُمْ وَأَمَّرَ عَلَيْهِمْ عَبْدَ اللَّهِ بْنَ حُذَافَةَ بْنِ قَيْسٍ السَّهْمِيَّ فَكُنْتُ فِيمَنْ غَزَا مَعَهُ فَلَمَّا كَانَ بِبَعْضِ الطَّرِيقِ أَوْقَدَ الْقَوْمُ نَارًا لِيَصْطَلُوا أَوْ لِيَصْنَعُوا عَلَيْهَا صَنِيعًا فَقَالَ عَبْدُ اللَّهِ - وَكَانَتْ فِيهِ دُعَابَةٌ - أَلَيْسَ لِي عَلَيْكُمُ السَّمْعُ وَالطَّاعَةُ قَالُوا بَلَى ‏.‏ قَالَ فَمَا أَنَا بِآمِرِكُمْ بِشَىْءٍ إِلاَّ صَنَعْتُمُوهُ قَالُوا نَعَمْ ‏.‏ قَالَ فَإِنِّي أَعْزِمُ عَلَيْكُمْ إِلاَّ تَوَاثَبْتُمْ فِي هَذِهِ النَّارِ ‏.‏ فَقَامَ نَاسٌ فَتَحَجَّزُوا فَلَمَّا ظَنَّ أَنَّهُمْ وَاثِبُونَ قَالَ أَمْسِكُوا عَلَى أَنْفُسِكُمْ فَإِنَّمَا كُنْتُ أَمْزَحُ مَعَكُمْ ‏.‏ فَلَمَّا قَدِمْنَا ذَكَرُوا ذَلِكَ لِلنَّبِيِّ صلى الله عليه وسلم فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ أَمَرَكُمْ مِنْهُمْ بِمَعْصِيَةِ اللَّهِ فَلاَ تُطِيعُوهُ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الدیات ۹ (۱۴۰۱)،(تحفة الأشراف:۵۷۴۰)، وقد أخرجہ: سنن الدارمی/الدیات ۶ (۲۴۰۲),,"It was\nnarrated from Abu Sa’eed Al-Khudri that the Messenger of Allah\n(ﷺ) sent ‘Alqamah bin Mujazziz at the head of a detachment, and I\nwas among them. When he reached the battle site, or when he was\npartway there, a group of the army asked permission to take a\ndifferent route, and he gave them permission, and appointed ‘Abdullah\nbin Hudhafah bin Qais As-Sahmi as their leader, and I was one of\nthose\nwho fought alongside with him. When we were partway there, the\npeople\nlit a fire to warm themselves and cook some food. ‘Abdullah,\nwho was a\nman who liked to joke, said:",The Chapters on Jihad
2600,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ عُبَيْدِ اللَّهِ بْنِ عُمَرَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، وَسُوَيْدُ بْنُ سَعِيدٍ، قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ رَجَاءٍ الْمَكِّيُّ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم قَالَ ‏ ‏ عَلَى الْمَرْءِ الْمُسْلِمِ الطَّاعَةُ فِيمَا أَحَبَّ أَوْ كَرِهَ إِلاَّ أَنْ يُؤْمَرَ بِمَعْصِيَةٍ فَمَنْ أُمِرَ بِمَعْصِيَةٍ فَلاَ سَمْعَ وَلاَ طَاعَةَ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۸۰۲، ومصباح الزجاجة:۹۱۹),,It was\nnarrated from Ibn ‘Umar that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2601,"حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، حَدَّثَنَا يَحْيَى بْنُ سُلَيْمٍ، ح وَحَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا إِسْمَاعِيلُ بْنُ عَيَّاشٍ، قَالاَ حَدَّثَنَا عَبْدُ اللَّهِ بْنُ عُثْمَانَ بْنِ خُثَيْمٍ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ، عَنْ أَبِيهِ، عَنْ جَدِّهِ عَبْدِ اللَّهِ بْنِ مَسْعُودٍ، أَنَّ النَّبِيَّ صلى الله عليه وسلم قَالَ ‏""‏ سَيَلِي أُمُورَكُمْ بَعْدِي رِجَالٌ يُطْفِئُونَ السُّنَّةَ وَيَعْمَلُونَ بِالْبِدْعَةِ وَيُؤَخِّرُونَ الصَّلاَةَ عَنْ مَوَاقِيتِهَا ‏""‏ فَقُلْتُ يَا رَسُولَ اللَّهِ إِنْ أَدْرَكْتُهُمْ كَيْفَ أَفْعَلُ قَالَ ‏""‏ تَسْأَلُنِي يَا ابْنَ أُمِّ عَبْدٍ كَيْفَ تَفْعَلُ لاَ طَاعَةَ لِمَنْ عَصَى اللَّهَ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحدود ۴۲ (۶۸۴۸،۶۸۴۹،۶۸۵۰)، صحیح مسلم/الحدود ۹ (۱۷۰۸)، سنن ابی داود/الحدود ۳۹ (۴۴۹۱،۴۴۹۲)، سنن الترمذی/الحدود ۳۰ (۱۴۶۳)، وقد أخرجہ: مسند احمد (۳/۴۶۶،۴/۴۵)،(تحفة الأشراف:۱۱۷۲۰)، سنن الدارمی/الحدود ۱۱ (۲۳۶۰),2601,It was\nnarrated from ‘Abdullah bin Mas’ud that the Prophet (ﷺ)\nsaid:,The Chapters on Jihad
2602,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، وَيَحْيَى بْنِ سَعِيدٍ، وَعُبَيْدِ اللَّهِ بْنِ عُمَرَ، وَابْنِ، عَجْلاَنَ عَنْ عُبَادَةَ بْنِ الْوَلِيدِ بْنِ عُبَادَةَ بْنِ الصَّامِتِ، عَنْ أَبِيهِ، عَنْ عُبَادَةَ بْنِ الصَّامِتِ، قَالَ بَايَعْنَا رَسُولَ اللَّهِ صلى الله عليه وسلم عَلَى السَّمْعِ وَالطَّاعَةِ فِي الْعُسْرِ وَالْيُسْرِ وَالْمَنْشَطِ وَالْمَكْرَهِ وَالأَثَرَةِ عَلَيْنَا وَأَنْ لاَ نُنَازِعَ الأَمْرَ أَهْلَهُ وَأَنْ نَقُولَ الْحَقَّ حَيْثُمَا كُنَّا لاَ نَخَافُ فِي اللَّهِ لَوْمَةَ لاَئِمٍ ‏.‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan Lighairihi; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۳۸۱، ومصباح الزجاجة:۹۲۰),2602,It was\nnarrated that ‘Ubadah bin Samit said:,The Chapters on Jihad
2603,"حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، حَدَّثَنَا سَعِيدُ بْنُ عَبْدِ الْعَزِيزِ التَّنُوخِيُّ، عَنْ رَبِيعَةَ بْنِ يَزِيدَ، عَنْ أَبِي إِدْرِيسَ الْخَوْلاَنِيِّ، عَنْ أَبِي مُسْلِمٍ، قَالَ حَدَّثَنِي الْحَبِيبُ الأَمِينُ، - أَمَّا هُوَ إِلَىَّ فَحَبِيبٌ وَأَمَّا هُوَ عِنْدِي فَأَمِينٌ - عَوْفُ بْنُ مَالِكٍ الأَشْجَعِيُّ قَالَ كُنَّا عِنْدَ النَّبِيِّ صلى الله عليه وسلم سَبْعَةً أَوْ ثَمَانِيَةً أَوْ تِسْعَةً فَقَالَ ‏""‏ أَلاَ تُبَايِعُونَ رَسُولَ اللَّهِ ‏""‏ ‏.‏ فَبَسَطْنَا أَيْدِيَنَا فَقَالَ قَائِلٌ يَا رَسُولَ اللَّهِ إِنَّا قَدْ بَايَعْنَاكَ فَعَلاَمَ نُبَايِعُكَ فَقَالَ ‏""‏ أَنْ تَعْبُدُوا اللَّهَ وَلاَ تُشْرِكُوا بِهِ شَيْئًا وَتُقِيمُوا الصَّلَوَاتِ الْخَمْسَ وَتَسْمَعُوا وَتُطِيعُوا - وَأَسَرَّ كَلِمَةً خُفْيَةً - وَلاَ تَسْأَلُوا النَّاسَ شَيْئًا ‏""‏ ‏.‏ قَالَ فَلَقَدْ رَأَيْتُ بَعْضَ أُولَئِكَ النَّفَرِ يَسْقُطُ سَوْطُهُ فَلاَ يَسْأَلُ أَحَدًا يُنَاوِلُهُ إِيَّاهُ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحدود ۱۰ (۱۷۰۹)،(تحفة الأشراف:۵۰۹۰)، وقد أخرجہ: صحیح البخاری/الایمان ۱۱ (۱۸)، مناقب الانصار۴۳ (۳۸۹۲)، تفسیرسورةالممتحنة ۳ (۴۸۹۴)، الحدود ۸ (۶۷۸۴)،۱۴ (۸۰۱)، الاحکام ۴۹ (۷۲۱۳)، التوحید ۳۱ (۷۴۶)، سنن الترمذی/الحدود ۱۲ (۱۴۳۹)، سنن النسائی/البیعة ۹ (۴۱۶۶)، مسند احمد (۵/۳۱۴،۳۲۱،۳۳۳)، سنن الدارمی/السیر ۱۷ (۲۴۹۷),2603,‘Awf\nbin Malik Al-Ashja’i said:,The Chapters on Jihad
2604,"حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا وَكِيعٌ، حَدَّثَنَا شُعْبَةُ، عَنْ عَتَّابٍ، - مَوْلَى هُرْمُزَ - قَالَ سَمِعْتُ أَنَسَ بْنَ مَالِكٍ، يَقُولُ بَايَعْنَا رَسُولَ اللَّهِ صلى الله عليه وسلم عَلَى السَّمْعِ وَالطَّاعَةِ فَقَالَ ‏ ‏ فِيمَا اسْتَطَعْتُمْ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/الإیمان ۱۱ (۲۶۲۶)،(تحفة الأشراف:۱۰۳۱۳)، وقد أخرجہ: مسند احمد (۱/۹۹،۱۵۹),,"It was\nnarrated that ‘Attab, the freed slave of Hurmuz, said:",The Chapters on Jihad
2605,"حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ أَبِي الزُّبَيْرِ، عَنْ جَابِرٍ، قَالَ جَاءَ عَبْدٌ فَبَايَعَ النَّبِيَّ صلى الله عليه وسلم عَلَى الْهِجْرَةِ وَلَمْ يَشْعُرِ النَّبِيُّ صلى الله عليه وسلم أَنَّهُ عَبْدٌ فَجَاءَ سَيِّدُهُ يُرِيدُهُ فَقَالَ النَّبِيُّ صلى الله عليه وسلم ‏ ‏ بِعْنِيهِ ‏""""‏ ‏.‏ فَاشْتَرَاهُ بِعَبْدَيْنِ أَسْوَدَيْنِ ثُمَّ لَمْ يُبَايِعْ أَحَدًا بَعْدَ ذَلِكَ حَتَّى يَسْأَلَهُ أَعَبْدٌ هُوَ""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/اللعان ۱ (۱۴۹۸)، سنن ابی داود/الدیات ۱۲ (۴۵۳۲)،(تحفة الأشراف:۱۲۶۹۹)، وقد أخرجہ: موطا امام مالک/الأقضیة ۱۹ (۱۷)، الحدود ۱ (۷),,It was\nnarrated that Jabir said:,The Chapters on Jihad
2606,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَعَلِيُّ بْنُ مُحَمَّدٍ، وَأَحْمَدُ بْنُ سِنَانٍ، قَالُوا حَدَّثَنَا أَبُو مُعَاوِيَةَ، عَنِ الأَعْمَشِ، عَنْ أَبِي صَالِحٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ ثَلاَثَةٌ لاَ يُكَلِّمُهُمُ اللَّهُ وَلاَ يَنْظُرُ إِلَيْهِمْ يَوْمَ الْقِيَامَةِ وَلاَ يُزَكِّيهِمْ وَلَهُمْ عَذَابٌ أَلِيمٌ رَجُلٌ عَلَى فَضْلِ مَاءٍ بِالْفَلاَةِ يَمْنَعُهُ مِنِ ابْنِ السَّبِيلِ وَرَجُلٌ بَايَعَ رَجُلاً بِسِلْعَةٍ بَعْدَ الْعَصْرِ فَحَلَفَ بِاللَّهِ لأَخَذَهَا بِكَذَا وَكَذَا فَصَدَّقَهُ وَهُوَ عَلَى غَيْرِ ذَلِكَ وَرَجُلٌ بَايَعَ إِمَامًا لاَ يُبَايِعُهُ إِلاَّ لِدُنْيَا فَإِنْ أَعْطَاهُ مِنْهَا وَفَى لَهُ وَإِنْ لَمْ يُعْطِهِ مِنْهَا لَمْ يَفِ لَهُ ‏""""‏ ‏.‏""",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۵۶۲، ومصباح الزجاجة:۹۲۱),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2607,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، عَنْ حَسَنِ بْنِ فُرَاتٍ، عَنْ أَبِيهِ، عَنْ أَبِي حَازِمٍ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ إِنَّ بَنِي إِسْرَائِيلَ كَانَتْ تَسُوسُهُمْ أَنْبِيَاؤُهُمْ كُلَّمَا ذَهَبَ نَبِيٌّ خَلَفَهُ نَبِيٌّ وَأَنَّهُ لَيْسَ كَائِنٌ بَعْدِي نَبِيٌّ فِيكُمْ ‏""‏ ‏.‏ قَالُوا فَمَا يَكُونُ يَا رَسُولَ اللَّهِ قَالَ ‏""‏ تَكُونُ خُلَفَاءُ فَيَكْثُرُوا ‏""‏ ‏.‏ قَالُوا فَكَيْفَ نَصْنَعُ قَالَ ‏""‏ أَوْفُوا بِبَيْعَةِ الأَوَّلِ فَالأَوَّلِ أَدُّوا الَّذِي عَلَيْكُمْ فَسَيَسْأَلُهُمُ اللَّهُ عَزَّ وَجَلَّ عَنِ الَّذِي عَلَيْهِمْ ‏""‏ ‏.‏",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الحدود ۲۷ (۴۴۵۶،۴۴۵۷)، سنن الترمذی/الاحکام ۲۵ (۱۳۶۲)، سنن النسائی/النکاح ۵۸ (۳۳۳)،(تحفة الأشراف:۱۵۵۳۴)، وقد أخرجہ: مسند احمد (۴/۲۹۰،۲۹۲،۲۹۵،۲۹۷)، سنن الدارمی/النکاح ۴۳ (۲۲۸۵),2607,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2608,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، حَدَّثَنَا أَبُو الْوَلِيدِ، حَدَّثَنَا شُعْبَةُ، ح وَحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، عَنْ شُعْبَةَ، عَنِ الأَعْمَشِ، عَنْ أَبِي وَائِلٍ، عَنْ عَبْدِ اللَّهِ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ يُنْصَبُ لِكُلِّ غَادِرٍ لِوَاءٌ يَوْمَ الْقِيَامَةِ فَيُقَالُ هَذِهِ غَدْرَةُ فُلاَنٍ ‏""""‏ ‏.‏""",Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۰۸۲، ومصباح الزجاجة:۹۲۲),,It was\nnarrated from ‘Abdullah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2609,"حَدَّثَنَا عِمْرَانُ بْنُ مُوسَى اللَّيْثِيُّ، حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، أَنْبَأَنَا عَلِيُّ بْنُ زَيْدِ بْنِ جُدْعَانَ، عَنْ أَبِي نَضْرَةَ، عَنْ أَبِي سَعِيدٍ الْخُدْرِيِّ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ أَلاَ إِنَّهُ يُنْصَبُ لِكُلِّ غَادِرٍ لِوَاءٌ يَوْمَ الْقِيَامَةِ بِقَدْرِ غَدْرَتِهِ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۵۴۰، ومصباح الزجاجة:۹۲۳)، وقد أخرجہ: مسند احمد (۱/۳۰۹،۳۱۷،۳۲۸),,It was\nnarrated from Abu Sa’eed Al-Khudri that the Messenger of Allah\n(ﷺ) said:,The Chapters on Jihad
2610,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، أَنَّهُ سَمِعَ مُحَمَّدَ بْنَ الْمُنْكَدِرِ، قَالَ سَمِعْتُ أُمَيْمَةَ بِنْتَ رُقَيْقَةَ، تَقُولُ جِئْتُ النَّبِيَّ صلى الله عليه وسلم فِي نِسْوَةٍ نُبَايِعُهُ فَقَالَ لَنَا ‏ ‏ فِيمَا اسْتَطَعْتُنَّ وَأَطَقْتُنَّ إِنِّي لاَ أُصَافِحُ النِّسَاءَ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المغازي ۵۶ ۴۳۲۶)، صحیح مسلم/الایمان ۲۷ (۶۳)، سنن ابی داود/الأدب ۱۱۹ (۵۱۱۳)،(تحفة الأشراف:۳۹۰۲)، وقد أخرجہ: مسند احمد (۱/۱۶۹،۱۷۴،۱۷۹،۵/۳۸،۴۶)، سنن الدارمی/السیر ۸۳ (۲۵۷۲)، الفرائض ۲ (۲۹۰۲),,Muhammad\nbin Munkadir said that he heard Umaimah bint Ruqaiqah say:,The Chapters on Jihad
2611,"حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ الْمِصْرِيُّ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، قَالَ أَخْبَرَنِي يُونُسُ، عَنِ ابْنِ شِهَابٍ، أَخْبَرَنِي عُرْوَةُ بْنُ الزُّبَيْرِ، أَنَّ عَائِشَةَ، زَوْجَ النَّبِيِّ صلى الله عليه وسلم قَالَتْ كَانَتِ الْمُؤْمِنَاتُ إِذَا هَاجَرْنَ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم يُمْتَحَنَّ بِقَوْلِ اللَّهِ ‏{يَا أَيُّهَا النَّبِيُّ إِذَا جَاءَكَ الْمُؤْمِنَاتُ يُبَايِعْنَكَ }‏ إِلَى آخِرِ الآيَةِ قَالَتْ عَائِشَةُ فَمَنْ أَقَرَّ بِهَا مِنَ الْمُؤْمِنَاتِ فَقَدْ أَقَرَّ بِالْمِحْنَةِ فَكَانَ رَسُولُ اللَّهِ صلى الله عليه وسلم إِذَا أَقْرَرْنَ بِذَلِكَ مِنْ قَوْلِهِنَّ قَالَ لَهُنَّ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏""‏ انْطَلِقْنَ فَقَدْ بَايَعْتُكُنَّ ‏""‏ ‏.‏ لاَ وَاللَّهِ مَا مَسَّتْ يَدُ رَسُولِ اللَّهِ صلى الله عليه وسلم يَدَ امْرَأَةٍ قَطُّ غَيْرَ أَنَّهُ يُبَايِعُهُنَّ بِالْكَلاَمِ ‏.‏ قَالَتْ عَائِشَةُ وَاللَّهِ مَا أَخَذَ رَسُولُ اللَّهِ صلى الله عليه وسلم عَلَى النِّسَاءِ إِلاَّ مَا أَمَرَهُ اللَّهُ وَلاَ مَسَّتْ كَفُّ رَسُولِ اللَّهِ صلى الله عليه وسلم كَفَّ امْرَأَةٍ قَطُّ وَكَانَ يَقُولُ لَهُنَّ إِذَا أَخَذَ عَلَيْهِنَّ ‏""‏ قَدْ بَايَعْتُكُنَّ ‏""‏ ‏.‏ كَلاَمًا ‏.‏",Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۹۲۲، ومصباح الزجاجة:۹۲۴)، وقد أخرجہ: مسند احمد (۲/۱۷۱،۹۴),2611,‘Aishah\nthe wife of the Prophet (ﷺ) said:,The Chapters on Jihad
2612,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، وَمُحَمَّدُ بْنُ يَحْيَى، قَالاَ حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، أَنْبَأَنَا سُفْيَانُ بْنُ حُسَيْنٍ، عَنِ الزُّهْرِيِّ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ مَنْ أَدْخَلَ فَرَسًا بَيْنَ فَرَسَيْنِ وَهُوَ لاَ يَأْمَنُ أَنْ يَسْبِقَ فَلَيْسَ بِقِمَارٍ وَمَنْ أَدْخَلَ فَرَسًا بَيْنَ فَرَسَيْنِ وَهُوَ يَأْمَنُ أَنْ يَسْبِقَ فَهُوَ قِمَارٌ ‏""""‏ ‏.‏""",Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفربہ ابن ماجہ،(تحفة الأشراف:۱۶۱، ومصباح الزجاجة:۹۲۵)، وقد أخرجہ: مسند احمد (۲/۲۷۴،۵/۲۱۱،۲۱۲),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2613,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، عَنْ عُبَيْدِ اللَّهِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ ضَمَّرَ رَسُولُ اللَّهِ صلى الله عليه وسلم الْخَيْلَ فَكَانَ يُرْسِلُ الَّتِي ضُمِّرَتْ مِنَ الْحَفْيَاءِ إِلَى ثَنِيَّةِ الْوَدَاعِ وَالَّتِي لَمْ تُضَمَّرْ مِنْ ثَنِيَّةِ الْوَدَاعِ إِلَى مَسْجِدِ بَنِي زُرَيْقٍ ‏.‏,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Mawdu; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۹۵۰، ومصباح الزجاجة:۹۲۶),2613,It was\nnarrated that Ibn ‘Umar said:,The Chapters on Jihad
2614,"حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِي الْحَكَمِ، - مَوْلَى بَنِي لَيْثٍ - عَنْ أَبِي هُرَيْرَةَ، قَالَ قَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ لاَ سَبَقَ إِلاَّ فِي خُفٍّ أَوْ حَافِرٍ ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المغازي ۵۶ (۴۳۲۴)، صحیح مسلم/السلام ۱۳ (۲۱۸۰)، سنن ابی داود/الأدب ۶۱ (۴۹۲۹)،(تحفة الأشراف:۱۸۲۶۳)، وقد أخرجہ: مسند احمد (۶/۲۹۰،۳۱۸)(ہذا الحدیث وقد مضی برقم:(۱۹۰۳),,It was\nnarrated from Abu Hurairah that the Messenger of Allah (ﷺ)\nsaid:,The Chapters on Jihad
2615,حَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، وَأَبُو عُمَرَ قَالاَ حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَهْدِيٍّ، عَنْ مَالِكِ بْنِ أَنَسٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّ رَسُولَ اللَّهِ صلى الله عليه وسلم نَهَى أَنْ يُسَافَرَ بِالْقُرْآنِ إِلَى أَرْضِ الْعَدُوِّ مَخَافَةَ أَنْ يَنَالَهُ الْعَدُوُّ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الرقاق ۴۸ (۶۵۳۳)، الدیات ۱ (۶۸۶۴)، صحیح مسلم/القسامة ۸ (۱۶۷۸)، سنن الترمذی/الدیات ۸ (۱۳۹۶،۱۳۹۷)، سنن النسائی/تحریم الدم ۲ (۳۹۹۷)،(تحفة الأشراف:۹۲۴۶)، وقد أخرجہ: مسند احمد (۱/۳۸۸،۴۴۱،۴۴۲),2615,,The Chapters on Jihad
2616,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، عَنْ رَسُولِ اللَّهِ صلى الله عليه وسلم أَنَّهُ كَانَ يَنْهَى أَنْ يُسَافَرَ بِالْقُرْآنِ إِلَى أَرْضِ الْعَدُوِّ مَخَافَةَ أَنْ يَنَالَهُ الْعَدُوُّ ‏.‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الانبیاء ۱ (۳۳۳۵)، الدیات ۲ (۶۸۶۷)، الاعتصام ۱۵ (۷۳۲۱)، صحیح مسلم/القسامة ۷ (۱۶۷۷)، سنن الترمذی/العلم ۱۴ (۲۶۷۳)، سنن النسائی/تحریم الدم ۱ (۳۹۹۰)،(تحفة الأشراف:۹۵۶۸)، وقد أخرجہ: مسند احمد (۱/۳۸۳،۴۳۰،۴۳۳),2616,,The Chapters on Jihad
2617,"حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الأَعْلَى، حَدَّثَنَا أَيُّوبُ بْنُ سُوَيْدٍ، عَنْ يُونُسَ بْنِ يَزِيدَ، عَنِ ابْنِ شِهَابٍ، عَنْ سَعِيدِ بْنِ الْمُسَيَّبِ، أَنَّ جُبَيْرَ بْنَ مُطْعِمٍ، أَخْبَرَهُ أَنَّهُ، جَاءَ هُوَ وَعُثْمَانُ بْنُ عَفَّانَ إِلَى رَسُولِ اللَّهِ صلى الله عليه وسلم يُكَلِّمَانِهِ فِيمَا قَسَمَ مِنْ خُمُسِ خَيْبَرَ لِبَنِي هَاشِمٍ وَبَنِي الْمُطَّلِبِ فَقَالاَ قَسَمْتَ لإِخْوَانِنَا بَنِي هَاشِمٍ وَبَنِي الْمُطَّلِبِ وَقَرَابَتُنَا وَاحِدَةٌ فَقَالَ رَسُولُ اللَّهِ صلى الله عليه وسلم ‏ ‏ إِنَّمَا أَرَى بَنِي هَاشِمٍ وَبَنِي الْمُطَّلِبِ شَيْئًا وَاحِدًا ‏""""‏ ‏.‏""",Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «سنن النسائی/تحریم الدم ۲ (۳۹۹۶)،(تحفة الأشراف:۹۲۷۵)، وقد أخرجہ: صحیح البخاری/الرقاق ۴۸ (۶۵۳۳)، الدیات ا (۶۸۶۴)، صحیح مسلم/القسامة ۸ (۱۶۷۸)، سنن الترمذی/الدیات ۸ (۱۳۹۶،۱۳۹۷)، مسند احمد (۲/۸۷۳),,It was\nnarrated from Sa’eed bin Musayyab that Jubair bin Mut’im told\nhim\nthat he and ‘Uthman bin ‘Affan came to the Messenger of Allah\n(ﷺ) to speak to him about the way in which the one fifth from\nKhaibar had been distributed to Banu Hashim and Banu Muttalib. They\nsaid:,The Chapters on Jihad
2753,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ الْفُضَيْلِ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الإیمان ۲۶ (۳۶ مطولاً)، الجہاد ۲ ۲۷۸۷)، فرض الخمس ۸ (۳۱۲۳)، التوحید ۲۸ (۷۴۵۷)، صحیح مسلم/الإمارة ۲۸ (۱۸۷۶)، سنن النسائی/الجہاد ۱۴ (۳۱۲۴)،(تحفة الأشراف:۱۴۹۰۱)، وقد أخرجہ: موطا امام مالک/الجہاد ۱ (۲)، مسند احمد (۲/۲۳۱،۳۸۴،۳۹۹،۴۲۴،۴۹۴)، سنن الدارمی/الجہاد ۲ (۲۴۳۶),2753,,The Chapters on Jihad
2754,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَأَبُو كُرَيْبٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۲۲۴، ومصباح الزجاجة:۹۷۳),2754,,The Chapters on Jihad
2755,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/فضائل الجہاد ۱۷ (۱۶۴۹)،(تحفة الأشراف:۱۳۴۲۸)، وقد أخرجہ: صحیح البخاری/الجہاد ۵ (۲۷۹۲)، مسند احمد (۲/۵۳۲،۵۳۳),2755,,The Chapters on Jihad
2756,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا زَكَرِيَّا بْنُ مَنْظُورٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۶۷۳)، وقد أخرجہ: صحیح البخاری/الجہاد ۵ (۲۷۹۴)،۷۳ (۲۸۹۲)، الرقاق ۲ (۶۴۱۵)، صحیح مسلم/الإمارة ۳۰ (۱۸۸۱)، سنن الترمذی/فضائل الجہاد ۱۷ (۱۶۴۸)،۲۶ (۱۶۶۴)، سنن النسائی/الجہاد ۱۱ (۳۱۲۰)، مسند احمد (۳/۴۳۳،۵/۳۳۵،۳۳۷،۳۳۹)، سنن الدارمی/الجہاد ۹ (۲۴۴۳),2756,,The Chapters on Jihad
2757,حَدَّثَنَا نَصْرُ بْنُ عَلِيٍّ الْجَهْضَمِيُّ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏قَالَا:‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۲۶)، وقد أخرجہ: صحیح البخاری/الجہاد ۵ (۲۷۹۲)، صحیح مسلم/الإمارة ۳۰ (۱۸۸۰)، سنن الترمذی/فضائل الجہاد ۱۷ (۱۶۵۱),2757,,The Chapters on Jihad
2758,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يُونُسُ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۶۰۵، ومصباح الزجاجة:۹۷۴)، وقد أخرجہ: مسند احمد (۱/۲۰،۵۳),2758,,The Chapters on Jihad
2759,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏عَنْ عَبْد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/فضائل الجہاد ۶ (۱۶۲۹ ۱۶۳۰)،(تحفة الأشراف:۳۷۶۱)، وقد أخرجہ: صحیح البخاری/الجہاد ۳۸ (۲۸۴۳)، صحیح مسلم/الإمارة ۳۸ (۱۸۹۵)، سنن ابی داود/الجہاد ۲۱ (۲۵۰۹)، سنن النسائی/الجہاد ۴۴ (۳۱۸۲)، مسند احمد (۴/۱۱۵،۱۱۶،۱۱۷،۵/۱۹۲،۱۹۳)، سنن الدارمی/الجہاد ۲۷ (۲۴۶۳),2759,,The Chapters on Jihad
2760,حَدَّثَنَا عِمْرَانُ بْنُ مُوسَى اللَّيْثِيُّ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏حَدَّثَن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الزکاة ۱۲ (۹۹۴)، سنن الترمذی/البر والصلة ۴۲ (۱۹۶۶)،(تحفة الأشراف:۲۱۰۱)، وقد أخرجہ: مسند احمد۵/ (۲۷۹،۲۸۴),2760,,The Chapters on Jihad
2761,حَدَّثَنَا هَارُونُ بْنُ عَبْدِ اللَّهِ الْحَمَّالُ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ أَبِي فُدَيْكٍ، ‏‏‏‏‏‏عَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۲۲۷،۸۶۱۷،۱۰۰۶۸،۱۰۷۹۴،۱۰۹۲۹،۱۲۲۶۱، ومصباح الزجاجة:۹۷۵),2761,,The Chapters on Jihad
2762,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الجہاد ۱۸ (۲۵۰۳)،(تحفة الأشراف:۴۸۹۷)، وقد أخرجہ: سنن الدارمی/الجہاد ۲۶ (۲۴۶۲),2762,,The Chapters on Jihad
2763,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو رَافِعٍ هُوَ إ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/فضائل الجہاد ۲۶ (۱۶۶۶)،(تحفة الأشراف:۱۲۵۵۴)، وقد أخرجہ: مسند احمد (۳/۱۶۰،۲۱۴),2763,,The Chapters on Jihad
2764,حَدَّثَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، ‏‏‏‏‏‏عَنْ حُمَيْدٍ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۵۸)، وقد أخرجہ: صحیح البخاری/الجہاد ۳۵ (۲۸۳۹)، صحیح مسلم/الإمارة ۴۸ (۱۹۱۱)، سنن ابی داود/الجہاد ۲۰ (۲۵۰۸),2764,,The Chapters on Jihad
2765,حَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَنِ الْأَعْمَشِ، ‏‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۴۸ (۱۹۱۱)،(تحفة الأشراف:۲۳۰۴)، وقد أخرجہ: مسند احمد (۳/۳۰۰),2765,,The Chapters on Jihad
2766,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ زَيْدِ بْنِ أَسْلَمَ، ‏‏‏,Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۸۱۶، ومصباح الزجاجة:۹۷۶)، وقد أخرجہ: مسند احمد (۱/۶۱،۶۴),2766,,The Chapters on Jihad
2767,حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الْأَعْلَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏أَخْبَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۶۱۷، ومصباح الزجاجة:۹۷۸)، وقد أخرجہ: مسند احمد (۲/۴۰۴),2767,,The Chapters on Jihad
2768,حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيل بْنِ سَمُرَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ يَعْلَى السُّلَ,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۵، ومصباح الزجاجة:۹۷۹),2768,,The Chapters on Jihad
2769,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ الْعَزِيزِ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏عَن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۹۴۵، ومصباح الزجاجة:۹۸۰)، وقد أخرجہ: سنن الدارمی/الجہاد ۱۱ (۲۴۴۵),2769,,The Chapters on Jihad
2770,حَدَّثَنَا عِيسَى بْنُ يُونُسَ الرَّمْلِيُّ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ شُعَيْبِ بْنِ شَابُورَ،,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۶۰، ومصباح الزجاجة:۹۸۱),2770,,The Chapters on Jihad
2771,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ أُسَامَةَ بْنِ زَي,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الدعوات ۴۶ (۳۴۴۵)،(تحفة الأشراف:۱۲۹۴۶)، وقد أخرجہ:۲/۳۲۵،۳۳۱،۴۴۳،۴۷۶),2771,,The Chapters on Jihad
2772,حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، ‏‏‏‏‏‏أَنْبَأَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏عَنْ ثَابِتٍ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/ الجہاد ۴۲ (۲۸۲۰)،۵۴ (۲۸۶۶)،۸۲ (۲۹۰۸)، الأدب ۳۹ (۶۰۳۳)، صحیح مسلم/الفضائل ۱۱ (۲۳۰۷)، سنن الترمذی/الجہاد ۱۴ (۱۶۸۷)،(تحفة الأشراف:۲۸۹)، وقد أخرجہ: مسند احمد۳/۱۴۷،۱۶۳،۱۸۵،۲۷۱),2772,,The Chapters on Jihad
2773,حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ الرَّحْمَنِ بْنِ بَكَّارِ بْنِ عَبْدِ الْمَلِكِ بْنِ الْوَلِيدِ بْنِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۴۱۸، ومصباح الزجاجة:۹۸۲)، وقد أخرجہ: صحیح البخاری/جزاء الصید ۴ (۱۸۳۴)، الجہاد ۱ (۲۷۸۳)،۲۷ (۲۸۲۵)،۱۹۴ (۳۰۷۷)، صحیح مسلم/الإمارة ۲۰ (۱۳۵۳)، سنن الترمذی/السیر ۳۳ (۱۵۹۰)، سنن النسائی/البیعة ۱۵ (۴۱۷۵)، مسند احمد (۱/۲۲۶،۲۶۶،۳۱۶،۳۵۵)، سنن الدارمی/السیر ۶۹ (۲۵۵۴),2773,,The Chapters on Jihad
2774,حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/فضائل الجہاد ۸ (۱۶۳۳)، الزہد ۸ (۲۳۱۱)، سنن النسائی/الجہاد ۸ (۳۱۰۹)،(تحفة الأشراف:۱۴۲۸۵)، وقد أخرجہ: مسند احمد (۲/۵۰۵),2774,,The Chapters on Jihad
2775,حَدَّثَنَا مُحَمَّدُ بْنُ سَعِيدِ بْنِ يَزِيدَ بْنِ إِبْرَاهِيمَ التُّسْتَرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا أَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۰۳، ومصباح الزجاجة:۹۸۳),2775,,The Chapters on Jihad
2776,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ، ‏‏‏‏‏‏عَنْ يَحْيَى بْنِ سَعِيدٍ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجہاد ۳ (۲۷۸۸)،۸ (۲۷۹۹)،۶۳ (۲۸۷۷)،۷۵ (۲۸۹۴)،۹۳ (۲۹۲۴)، الاستئذان ۴۱ (۶۲۸۲)، التعبیر ۱۲ (۷۰۰۱)، صحیح مسلم/الإمارة ۴۹ (۱۹۱۲)، سنن ابی داود/الجہاد ۱۰ (۲۴۹۰،۲۴۹۲)، سنن الترمذی/فضائل الجہاد ۱۵ (۱۶۴۵)، سنن النسائی/الجہاد ۴۰ (۳۱۷۴)،(تحفة الأشراف:۱۸۳۰۷)، وقد أخرجہ: موطا امام مالک/الجہاد ۱۸ (۳۹)، مسند احمد (۳/۲۶۴،۶/۳۶۱،۴۲۳،۴۳۵)، سنن الدارمی/الجہاد ۲۹ (۲۴۶۵),2776,,The Chapters on Jihad
2777,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا بَقِيَّةُ، ‏‏‏‏‏‏عَنْ مُعَاوِيَةَ بْنِ يَحْيَى، ‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Sanad Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۰۰۱، ومصباح الزجاجة:۹۸۴),2777,,The Chapters on Jihad
2778,حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ يُوسُفَ الْجُبَيْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا قَيْسُ بْنُ مُحَمَّدٍ الْك,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۸۷۲، ومصباح الزجاجة:۹۸۵),2778,,The Chapters on Jihad
2779,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا أَبُو دَاوُدَ، ‏‏‏‏‏‏ح وَحَدَّثَنَا مُحَمَّدُ بْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۸۴۱، ومصباح الزجاجة:۹۸۶),2779,,The Chapters on Jihad
2780,حَدَّثَنَا إِسْمَاعِيل بْنُ أَسَدٍ، ‏‏‏‏‏‏حَدَّثَنَا دَاوُدُ بْنُ الْمُحَبَّرِ، ‏‏‏‏‏‏أَنْبَأَنَا ال,Al-Albani: Mawdu; Muhammad Fouad Abd al-Baqi: Mawdu; Shuaib Al Arnaut: Mawdu; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۸۶، ومصباح الزجاجة:۹۸۷),2780,,The Chapters on Jihad
2781,حَدَّثَنَا أَبُو يُوسُفَ مُحَمَّدُ بْنُ أَحْمَدَ الرَّقِّيُّ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ سَلَمَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن النسائی/الجہاد ۶ (۳۱۰۶)،(تحفة الأشراف:۱۱۳۷۵)، وقد أخرجہ: مسند احمد (۳/۴۲۹),2781,,The Chapters on Jihad
2782,حَدَّثَنَا أَبُو كُرَيْبٍ مُحَمَّدُ بْنُ الْعَلَاءِ، ‏‏‏‏‏‏حَدَّثَنَا الْمُحَارِبِيُّ، ‏‏‏‏‏‏عَنْ عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الجہاد ۳۳ (۲۵۲۸)، سنن النسائی/الجہاد ۵ (۳۱۰۵)،(تحفة الأشراف:۸۶۴۰)، وقد أخرجہ: صحیح البخاری/الجہاد ۱۳۸ (۳۰۰۴)، صحیح مسلم/البر ۱ (۲۵۴۹)، سنن الترمذی/الجہاد ۲ (۱۶۷۱)، مسند احمد (۲/۱۶۵،۱۹۴،۱۹۸،۲۰۴),2782,,The Chapters on Jihad
2783,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/العلم ۴۵ (۱۲۳)، الجہاد ۱۵ (۲۸۱۰)، الخمس ۱۰ (۳۱۲۶)، التوحید ۲۸ (۷۴۵۸)، صحیح مسلم/الإمارة ۴۲ (۱۹۰۴)، سنن ابی داود/الجہاد ۲۶ (۲۵۱۷،۲۵۱۸)، سنن الترمذی/فضائل الجہاد ۱۶ (۱۶۴۶)، سنن النسائی/الجہاد ۲۱ (۳۱۳۸)،(تحفة الأشراف:۸۹۹۹)، وقد أخرجہ: مسند احمد (۴/۳۹۲،۳۹۷،۴۰۵،۴۱۷),2783,,The Chapters on Jihad
2784,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا حُسَيْنُ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الأدب ۱۲۱ (۵۱۲۳)،(تحفة الأشراف:۱۲۰۷۰)، وقد أخرجہ: مسند احمد (۵/۲۹۵),2784,,The Chapters on Jihad
2785,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ يَزِيدَ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۴۴ (۱۹۰۶)، سنن ابی داود/الجہاد ۱۳ (۲۴۹۷)، سنن النسائی/الجہاد ۱۵ (۳۱۲۷)،(تحفة الأشراف:۸۸۴۷)، وقد أخرجہ: مسند احمد (۲/۱۶۹),2785,,The Chapters on Jihad
2786,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْأَحْوَصِ، ‏‏‏‏‏‏عَنْ شَبِيبِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «صحیح البخاری/الجہاد ۴۳ (۲۸۵۰)،۴۴ (۲۸۵۲)، الخمس ۸ (۳۱۱۹)، المناقب ۲۸ (۳۶۴۲)، صحیح مسلم/الإمارة ۲۶ (۱۸۷۳)، سنن الترمذی/الجہاد ۱۹ (۱۶۹۴)، سنن النسائی/الخیل ۶ (۳۶۰۴)،(تحفة الأشراف:۹۸۹۷)، وقد أخرجہ: مسند احمد (۴/۳۷۵)، سنن الدارمی/الجہاد ۳۴ (۲۴۷۰),2786,,The Chapters on Jihad
2787,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۲۶ (۱۸۷۱)، سنن النسائی/الخیل ۶ (۳۶۰۳)،(تحفة الأشراف:۸۲۸۷)، وقد أخرجہ: صحیح البخاری/الجہاد ۴۳ (۲۸۴۹)، المناقب ۲۸ (۳۶۴۴)، موطا امام مالک/الجہاد ۱۹ (۴۴)، مسند احمد (۲/۴۹،۵۷،۱۰۱،۱۱۲),2787,,The Chapters on Jihad
2788,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الزکاة ۶ (۹۸۷)،(تحفة الأشراف:۱۲۷۸۵)، وقد أخرجہ: صحیح البخاری/الشرب المساقاة ۱۲ (۲۳۷۱)، الجہاد ۴۸ (۲۸۶۰)، المناقب ۲۸ (۳۶۴۶)، تفسیر سورة الزلزلة ۱ (۴۹۶۲)، الاعتصام ۲۴ (۷۳۵۶)، سنن الترمذی/فضائل الجہاد ۱۰ (۱۶۳۶)، سنن النسائی/الخیل (۳۵۹۲)، موطا امام مالک/الجہاد ۱ (۳)، مسند احمد (۲/۲۶۲،۲۸۳),2788,,The Chapters on Jihad
2789,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا وَهْبُ بْنُ جَرِيرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبِي، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/الجہاد۲۰ (۱۶۹۵)،(تحفة الأشراف:۱۲۱۲۱)، وقد أخرجہ: مسند احمد (۵/۳۰۰)، سنن الدارمی/الجہاد ۳۵ (۲۴۷۲),2789,,The Chapters on Jihad
2790,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۲۷ (۱۸۷۵)، سنن ابی داود/الجہاد ۴۶ (۲۵۴۷)، سنن الترمذی/الجہاد ۲۱ (۱۶۹۸)، سنن النسائی/الخیل ۴ (۳۵۹۷)،(تحفة الأشراف:۱۴۸۹۰)، وقد أخرجہ: مسند احمد (۲/۲۵۰،۴۳۶،۴۶۱،۷۶),2790,,The Chapters on Jihad
2791,حَدَّثَنَا أَبُو عُمَيْرٍ عِيسَى بْنُ مُحَمَّدٍ الرَّمْلِيُّ، ‏‏‏‏‏‏حَدَّثَنَا أَحْمَدُ بْنُ يَزِيدَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۰۵۹، ومصباح الزجاجة:۹۸۸),2791,,The Chapters on Jihad
2792,حَدَّثَنَا بِشْرُ بْنُ آدَمَ، ‏‏‏‏‏‏حَدَّثَنَا الضَّحَّاكُ بْنُ مَخْلَدٍ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ جُر,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الجہاد ۴۲ (۲۵۴۱)، سنن النسائی/الجہاد ۲۵ (۳۱۴۳)، سنن الترمذی/فضائل الجہاد ۱۹ (۱۶۵۴)،۲۱ (۱۹۵۶)،(تحفة الأشراف:۱۱۳۵۹)، وقد أخرجہ: مسند احمد (۵/۲۳۰،۲۳۵،۲۴۳،۲۴۴، سنن الدارمی/الجہاد ۵ (۲۴۳۹),2792,,The Chapters on Jihad
2793,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَفَّانُ، ‏‏‏‏‏‏حَدَّثَنَا دَيْلَمُ بْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۲۵۶، ومصباح الزجاجة:۹۸۹),2793,,The Chapters on Jihad
2794,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَعْلَى بْنُ عُبَيْدٍ، ‏‏‏‏‏‏حَدَّثَنَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۷۵۷، ومصباح الزجاجة:۹۹۰)، وقد أخرحہ: مسند احمد (۴/۱۱۴),2794,,The Chapters on Jihad
2795,حَدَّثَنَا بِشْرُ بْنُ آدَمَ، ‏‏‏‏‏‏ وَأَحْمَدُ بْنُ ثَابِتٍ الْجَحْدَرِيُّ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّ,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۸۷۴، ومصباح الزجاجة:۹۹۱)، وقد أخرجہ: صحیح البخاری/الجہاد ۱۰ (۲۸۰۳)، صحیح مسلم/الإمارة ۲۸ (۱۸۷۶)، سنن الترمذی/فضائل الجہاد ۲۱ (۱۶۵۶)، موطا امام مالک/الجہاد ۱۴ (۲۹)، مسند احمد (۲/۳۹۱،۳۹۸،۳۹۹،۴۰۰،۵۱۲،۵۲،۵۳۱،۵۳۷)، سنن الدارمی/الجہاد ۱۵ (۲۴۵۰),2795,,The Chapters on Jihad
2796,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا يَعْلَى بْنُ عُبَيْدٍ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجہاد ۹۸ (۲۹۳۳)، صحیح مسلم/الجہاد ۷ (۱۷۴۲)، سنن الترمذی/الجہاد ۸ (۱۶۷۸)،(تحفة الأشراف:۵۱۵۴)، وقد أخرجہ: مسند احمد (۴/۳۵۳،۳۵۵،۳۸۱),2796,,The Chapters on Jihad
2797,حَدَّثَنَا حَرْمَلَةُ بْنُ يَحْيَى، ‏‏‏‏‏‏ وَأَحْمَدُ بْنُ عِيسَى الْمِصْرِيَّانِ، ‏‏‏‏‏‏قَالَا:‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۴۶ (۱۹۰۹)، سنن ابی داود/الصلا ة۳۶۱ (۱۵۲۰)، سنن الترمذی/فضائل الجہاد ۱۹ (۱۶۵۳)، سنن النسائی/الجہاد ۳۶ (۳۱۶۴)،(تحفة الأشراف:۴۶۵۵)، سنن الدارمی/الجہاد ۱۶ (۲۴۵۱),2797,,The Chapters on Jihad
2798,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ أَبِي عَدِيٍّ، ‏‏‏‏‏‏عَنْ ابْنِ,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۳۵۰۰، ومصباح الزجاجة:۹۹۲)، وقد أخرجہ: مسند احمد (۲/۲۹۷،۴۲۷),2798,,The Chapters on Jihad
2799,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل بْنُ عَيَّاشٍ، ‏‏‏‏‏‏حَدَّثَنِي بَحِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/فضائل الجہاد ۲۵ (۱۶۶۳)،(تحفة الأشراف:۱۱۵۵۶)، وقد أخرجہ: مسند احمد (۴/۱۳۱),2799,,The Chapters on Jihad
2800,حَدَّثَنَا إِبْرَاهِيمُ بْنُ الْمُنْذِرِ الْحِزَامِيُّ، ‏‏‏‏‏‏حَدَّثَنَا مُوسَى بْنُ إِبْرَاهِيمَ ال,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۲۲۵۷ (ألف)، وقد أخرجہ: سنن الترمذی/تفسیر القرآن (۳۰۱۰)، تقدم برقم:۱۹۰,2800,,The Chapters on Jihad
2801,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏حَدَّثَنَا الْأَعْمَشُ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۳۳ (۱۸۸۷)سنن الترمذی/تفسیر القرآن ۴ (۳۰۱۱)،(تحفة الأشراف:۹۵۷۰)، وقد أخرجہ: سنن الدارمی/الجہاد ۱۹ (۲۴۵۴),2801,,The Chapters on Jihad
2802,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏ وَأَحْمَدُ بْنُ إِبْرَاهِيمَ الدَّوْرَقِيُّ، ‏‏‏‏‏‏ وبشر,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Daif,takhreej: «سنن الترمذی/فضائل الجہاد ۲۶ (۱۶۶۸)، سنن النسائی/الجہاد ۳۵ (۳۱۶۳)،(تحفة الأشراف:۱۲۸۶۱)، وقد أخرجہ: مسند احمد (۲/۲۹۷)، سنن الدارمی/الجہاد ۱۷ (۲۴۵۲),2802,,The Chapters on Jihad
2803,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ أَبِي الْعُمَيْسِ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الجنائز ۱۵ (۳۱۱۱)، سنن النسائی/الجنائز ۱۴ (۱۸۴۷)، الجہاد ۳۹ (۳۱۹۶)،(تحفة الأشراف:۳۱۷۳)، وقد أخرجہ: موطا امام مالک/الجنائز ۱۲ (۳۶)، مسند احمد (۵/۴۴۶),2803,,The Chapters on Jihad
2804,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ الْمَلِكِ بْنِ أَبِي الشَّوَارِبِ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۲۷۳۲)، وقد أخرجہ: صحیح البخاری/الأذان ۳۲ (۶۵۲)، صحیح مسلم/الإمارة ۵۱ (۱۹۱۴),2804,,The Chapters on Jihad
2805,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَسُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا مَالِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/جزاء الصید ۱۸ (۱۸۴۶)، الجہاد۱۶۰ (۳۰۴۴)، المغازي ۴۸ (۴۲۸۶)، اللباس ۱۷ (۵۸۰۸)، صحیح مسلم/الحج ۸۴ (۱۳۵۷)، سنن ابی داود/الجہاد ۱۲۷ (۲۶۸۵)، سنن الترمذی/الجہاد ۱۸ (۱۶۹۳)، الشمائل ۱۶ (۱۰۶)، سنن النسائی/الحج ۱۰۷ (۲۸۷۰،۲۸۷۱)،(تحفة الأشراف:۱۵۲۷)، وقد أخرجہ: موطا امام مالک/الحج ۸۱ (۲۴۷)، مسند احمد (۳/۱۰۹،۱۶۴،۱۸۰،۱۸۶،۲۲۴،۲۳۲،۲۴۰)، سنن الدارمی/المناسک ۸۸ (۱۹۸۱)، السیر ۲۰ (۲۵۰۰),2805,,The Chapters on Jihad
2806,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ يَزِيدَ بْن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۸۰۵، ومصباح الزجاجة:۹۹۳)، وقد أخرجہ: سنن ابی داود/الجہاد ۷۵ (۲۵۹۰)، مسند احمد (۳/۴۴۹),2806,,The Chapters on Jihad
2807,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِبْرَاهِيمَ الدِّمَشْقِيُّ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُس,Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الجہاد ۸۳ (۲۹۰۹)،(تحفة الأشراف:۴۸۷۴),2807,,The Chapters on Jihad
2808,حَدَّثَنَا أَبُو كُرَيْبٍ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ الصَّلْتِ، ‏‏‏‏‏‏عَنْ ابْنِ أَبِي الزِّنَادِ، ‏‏‏‏,Al-Albani: Hasan Isnaad; Muhammad Fouad Abd al-Baqi: Hasan Isnaad; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/السیر ۱۲ (۱۵۱۶)،(تحفة الأشراف:۵۸۲۷)، وقد أخرجہ: مسند احمد (۱/۲۴۶۱،۲۷۱),2808,,The Chapters on Jihad
2809,حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيل بْنِ سَمُرَةَ، ‏‏‏‏‏‏أَنْبَأَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ سُفْيَانَ,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: «تفرد بن ابن ماجہ،(تحفة الأشراف:۱۰۱۸۲، ومصباح الزجاجة:۹۹۴)، وقد أخرجہ: مسند احمد (۱/۱۴۸),2809,,The Chapters on Jihad
2810,حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيل بْنِ سَمُرَةَ، ‏‏‏‏‏‏أَنْبَأَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى،,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۳۲۶، ومصباح الزجاجة:۹۹۵),2810,,The Chapters on Jihad
2811,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏أَنْبَأَن,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/فضائل الجہاد ۱۱ (۱۶۳۷،۱۶۳۸)،(تحفة الأشراف:۹۹۲۹)، وقد أخرجہ: مسند احمد (۴/۱۴۴،۱۴۸، سنن الدارمی/الجہاد ۱۴ (۲۴۴۹),2811,,The Chapters on Jihad
2812,حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الْأَعْلَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏أَخْبَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۷۶۵)، وقد أخرجہ: سنن الترمذی/فضائل الجہاد ۱۱ (۱۶۳۸),2812,,The Chapters on Jihad
2813,حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الْأَعْلَى، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏‏أَخْب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۵۲ (۱۹۱۷)، سنن ابی داود/الجہاد ۲۴ (۲۵۱۴)،(تحفة الأشراف:۹۹۱۱)، وقد أخرجہ: سنن الترمذی/تفسیر القرآن ۹ (۳۰۸۳)، مسند احمد (۴/۱۵۷)، سنن الدارمی/الجہاد ۱۴ (۲۴۴۸),2813,,The Chapters on Jihad
2814,حَدَّثَنَا حَرْمَلَهُ بْنُ يَحْيَى الْمِصْرِيُّ، ‏‏‏‏‏‏أَنْبَأَنَا عَبْدُ اللَّهِ بْنُ وَهْبٍ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۹۷۱)، وقد أخرجہ: سنن ابی داود/الجہاد ۲۴ (۲۵۱۳)، سنن الترمذی/فضائل الجہاد ۱۱ (۱۶۳۷)، سنن النسائی/الجہاد ۲۶ (۳۱۴۸)، الخیل ۸ (۳۶۰۸)، مسند احمد (۴/۱۴۴،۱۴۶،۱۴۸،۱۵۴، سنن الدارمی/الجہاد ۱۴ (۲۴۴۹),2814,,The Chapters on Jihad
2815,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّزَّاقِ، ‏‏‏‏‏‏أَنْبَأَنَا سُفْيَانُ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۴۲۸، ومصباح الزجاجة:۹۹۶)، وقد أخرجہ: مسند احمد (۱/۳۶۴),2815,,The Chapters on Jihad
2816,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو بَكْرِ بْنُ عَيَّاشٍ، ‏‏‏‏‏‏عَنْ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن الترمذی/تفسیر القرآ ن ۵۱ (۲)(۳۲۷۳،۳۲۷۴)،(تحفة الأشراف:۳۲۷۷)، وقد أخرجہ: مسند احمد (۳/۴۸۲),2816,,The Chapters on Jihad
2817,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، ‏‏‏‏‏‏ وَعَبْدَةُ بْنُ عَبْدِ اللَّهِ، ‏‏‏‏‏‏قَالَ:‏‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الجہاد ۷۶ (۲۵۹۲)، سنن الترمذی/الجہاد ۹ (۱۶۷۹)، سنن النسائی/الحج ۱۰۶ (۲۸۶۹)،(تحفة الأشراف:۲۸۸۹),2817,,The Chapters on Jihad
2818,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِسْحَاق الْوَاسِطِيُّ النَّاقِدُ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ إِسْ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن الترمذی/الجہاد ۱۰ (۱۶۸۱)،(تحفة الأشراف:۶۵۴۲),2818,,The Chapters on Jihad
2819,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، ‏‏,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «صحیح مسلم/اللباس و الزینة ۲ (۲۰۶۹)، سنن ابی داود/اللباس ۱۲ (۴۰۵۴)، سنن النسائی/الکبری الزینة (۹۶۱۹)،(تحفة الأشراف:۱۵۷۲۱)، وقد أخرجہ: مسند احمد (۶/۴۷،۳۴۸،۳۵۳)، الأدب المفرد (۳۴۸),2819,,The Chapters on Jihad
2820,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا حَفْصُ بْنُ غِيَاثٍ، ‏‏‏‏‏‏عَنْ عَاصِم,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/اللباس ۲۵ (۵۸۲۸)، صحیح مسلم/اللباس ۲ (۲۰۶۹)، سنن ابی داود/اللباس ۱۰ (۴۰۴۲)، سنن النسائی/الزینة ۳۸ (۵۳۱۴)،(تحفة الأشراف:۱۰۵۹۷)، وقد أخرجہ: مسند احمد (۱/۱۵،۳۶،۴۳),2820,,The Chapters on Jihad
2821,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ مُسَاوِرٍ،,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الحج ۸۴ (۱۳۵۹)،(تحفة الأشراف:۱۰۷۱۶)، وقد أخرجہ: سنن ابی داود/اللباس ۲۴ (۴۰۷۷)، سنن الترمذی/الشمائل ۱۶ (۱۰۸،۱۰۹)، سنن النسائی/الزینة من المجتبیٰ ۵۶ (۵۳۴۸)، مسند احمد (۴/۳۰۷)، سنن الدارمی/المناسک ۸۸ (۱۹۸۲),2821,,The Chapters on Jihad
2822,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الحج ۸۴ (۱۳۵۸)، سنن ابی داود/اللباس ۲۴ (۴۰۷۶)، سنن الترمذی/اللباس ۱۱ (۱۷۳۵)، سنن النسائی/الحج ۱۰۷ (۲۸۷۲)، والزینة من المجتبیٰ ۵۵ (۵۳۴۶،۵۳۴۷)،(تحفة الأشراف:۲۶۸۹)، وقد أخرجہ: مسند احمد (۳/۳۶۳،۳۸۷),2822,,The Chapters on Jihad
2823,حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ عَبْدِ الْكَرِيمِ، ‏‏‏‏‏‏حَدَّثَنَا سُنَيْدُ بْنُ دَاوُدَ، ‏‏‏‏‏‏عَ,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۷۱۳، ومصباح الزجاجة:۹۹۷)، وقد أخرجہ: مسند احمد (۳/۴۴۰),2823,,The Chapters on Jihad
2824,حَدَّثَنَا جَعْفَرُ بْنُ مُسَافِرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْأَسْوَدِ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ لَهِي,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۲۹۶، ومصباح الزجاجة:۹۹۸),2824,,The Chapters on Jihad
2825,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۴۶۲۶، ومصباح الزجاجة:۹۹۹)، وقد أخرجہ: مسند احمد (۲/۳۵۸،۴۰۳),2825,,The Chapters on Jihad
2826,حَدَّثَنَا عَبَّادُ بْنُ الْوَلِيدِ، ‏‏‏‏‏‏حَدَّثَنَا حَبَّانُ بْنُ هِلَالٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۴۲۷، ومصباح الزجاجة:۱۰۰۰)، وقد أخرجہ: سنن ابی داود/الجہاد ۸۰ (۲۶۰۰)، سنن الترمذی/الدعوات ۴۴ (۳۴۳۸),2826,,The Chapters on Jihad
2827,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْمَلِكِ مُحَمَّدٌ الصَّنْعَانِيُّ، ‏‏‏‏‏,Al-Albani: Very Daif; Muhammad Fouad Abd al-Baqi: Very Daif; Shuaib Al Arnaut: Very Daif; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۷۱، ومصباح الزجاجة:۱۰۰۱),2827,,The Chapters on Jihad
2828,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو عَامِرٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/المغازي ۶ (۳۹۵۹)،(تحفة الأشراف:۱۸۵۱)، وقد أخرجہ: سنن الترمذی/السیر ۳۸ (۱۵۹۸),2828,,The Chapters on Jihad
2829,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا زَيْدُ بْنُ الْحُبَاب، ‏‏‏‏‏‏عَنْ ابْن,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Zubair Ali Zai: Daif,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۵۵۱۸، ومصباح الزجاجة:۱۰۰۲),2829,,The Chapters on Jihad
2830,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Zubair Ali Zai: Hasan,takhreej: «سنن ابی داود/الأطعمة ۲۴ (۳۷۸۴)، سنن الترمذی/السیر ۱۶ (۱۵۶۵)،(تحفة الأشراف:۱۱۷۳۴)، وقد مسند احمد (۵/۲۲۶),2830,,The Chapters on Jihad
2831,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏حَدَّثَنِي أَبُو فَرْوَةَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۱۸۶۹، ومصباح الزجاجة:۱۰۰۳),2831,,The Chapters on Jihad
2832,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الجہاد ۵۱ (۱۸۱۷)، سنن ابی داود/الجہاد ۱۵۳ (۲۷۳۲)، سنن الترمذی/السیر ۱۰ (۱۵۵۸)،(تحفة الأشراف:۱۶۳۵۸)، وقد أخرجہ: مسند احمد (۶/۶۷،۱۴۸)، سنن الدارمی/السیر ۵۴ (۲۵۳۸),2832,,The Chapters on Jihad
2833,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، ‏‏‏‏,Al-Albani: Sahih Mutawatir; Muhammad Fouad Abd al-Baqi: Sahih Mutawatir; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۷۳۶۱، ومصباح الزجاجة:۱۰۰۴),2833,,The Chapters on Jihad
2834,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا يُونُسُ بْنُ بُكَيْرٍ، ‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۶۲۱۸، ومصباح الزجاجة:۱۰۰۵),2834,,The Chapters on Jihad
2835,حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، ‏‏‏‏‏‏ وَحَفْصُ بْنُ عَمْرٍو، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا عَبْدُ ا,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/المغازي ۸ (۳۹۶۶،۳۹۶۸)، تفسیر سورة الحج ۳ (۴۷۴۳)، صحیح مسلم/التفسیر ۷ (۳۰۳۳)،(تحفة الأشراف:۱۱۹۷۴),2835,,The Chapters on Jihad
2836,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْعُمَيْسِ وَعِ,Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۵۲۹، ومصباح الزجاجة:۱۰۰۶)وقد أخرجہ: صحیح البخاری/الجہاد ۱۷۳ (۳۰۵۱)، صحیح مسلم/الجہاد ۱۳ (۱۷۵۴)، مسند احمد (۴/۴۵،۴۶)، سنن الدارمی/السیر ۱۵ (۲۴۹۵),2836,,The Chapters on Jihad
2837,حَدَّثَنَا مُحَمَّدُ بْنُ الصَّبَّاحِ، ‏‏‏‏‏‏أَنْبَأَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ يَحْي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/البیوع ۳۷ (۲۱۰۰)، فرض الخمس ۱۸ (۳۱۴۲)، المغازي ۱۸ (۴۳۲۱،۴۳۲۲)، الاحکام ۲۱ (۷۱۷۰)، صحیح مسلم/الجہاد ۱۳ (۱۷۵۱)، سنن ابی داود/الجہاد ۱۴۷ (۲۷۱۷)، سنن الترمذی/السیر ۱۳ (۱۵۶۲)،(تحفة الأشراف:۱۲۱۳۲)، وقد أخرجہ: موطا امام مالک/الجہاد ۱۰ (۱۸)، مسند احمد (۵/۲۹۵،۲۹۶،۳۰۶)، سنن الدارمی/السیر ۴۴ (۲۵۲۸),2837,,The Chapters on Jihad
2838,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مَالِك,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۶۲۲، ومصباح الزجاجة:۱۰۰۷)، وقد أخرجہ: مسند احمد (۵/۱۲),2838,,The Chapters on Jihad
2839,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجہاد ۱۴۶ (۳۰۱۲)، صحیح مسلم/الجہاد ۹ (۱۷۸۵)، سنن الترمذی/السیر ۱۹ (۱۵۷۰)، سنن ابی داود/الجہاد ۱۲۱ (۲۶۷۲)،(تحفة الأشراف:۴۹۳۹)، وقد أخرجہ: مسند احمد (۴/۳۸،۷۱،۷۲،۷۳),2839,,The Chapters on Jihad
2840,حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏أَنْبَأَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ عِكْرِمَةَ بْنِ عَمَّار,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الجہاد ۱۳۴ (۲۵۹۷)،(تحفة الأشراف:۴۵۱۶)، وقد أخرجہ: صحیح مسلم/الجہاد ۱۴ (۱۷۵۵)، مسند احمد (۵/۳۷۷),2840,,The Chapters on Jihad
2841,حَدَّثَنَا يَحْيَى بْنُ حَكِيمٍ، ‏‏‏‏‏‏حَدَّثَنَا عُثْمَانُ بْنُ عُمَرَ، ‏‏‏‏‏‏أَنْبَأَنَا مَالِكُ ب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۴۰۱)، وقد أخرجہ: صحیح البخاری/الجہاد ۱۴۷ (۳۰۱۴)، صحیح مسلم/الجہاد ۸ (۱۷۴۴)، سنن ابی داود/الجہاد ۱۲۱ (۲۶۶۸)، سنن الترمذی/الجہاد ۱۹ (۱۵۶۹)، موطا امام مالک/الجہاد ۳ (۹)، مسند احمد (۲/۱۲۲،۱۲۳)، سنن الدارمی/السیر ۲۵ (۲۵۰۵),2841,,The Chapters on Jihad
2842,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏ع,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۳۴۴۹، ومصباح الزجاجة:۱۰۰۸)، وقد أخرجہ: سنن ابی داود/الجہاد ۱۲۱ (۲۶۶۹)، مسند احمد (۴/۱۷۸),2842,,The Chapters on Jihad
2843,حَدَّثَنَا مُحَمَّدُ بْنُ إِسْمَاعِيل بْنِ سَمُرَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ صَالِحِ بْ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الجہاد ۹۱ (۲۶۱۶)،(تحفة الأشراف:۱۰۷)، وقد أخرجہ: مسند احمد (۵/۲۰۵،۲۰۹),2843,,The Chapters on Jihad
2844,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الحرث والمزارعة ۴ (۲۳۵۶)، الجہاد ۱۵۴ (۳۰۲۰)، المغازي ۱۴ (۴۰۳۱)، صحیح مسلم/الجہاد ۱۰ (۱۷۴۶)، سنن ابی داود/الجہاد ۹۱ (۲۶۱۵)، سنن الترمذی/التفسیر ۵۹ (۳۳۰۲، السیر ۴ (۱۵۵۲)،(تحفة الأشراف:۸۲۶۷)، وقد أخرجہ: مسند احمد (۲/۱۲۳،۱۴۰)، سنن الدارمی/السیر ۲۳ (۲۵۰۳),2844,,The Chapters on Jihad
2845,حَدَّثَنَا عَبْدُ اللَّهِ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا عُقْبَةُ بْنُ خَالِدٍ، ‏‏‏‏‏‏عَنْ عُبَيْدِ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «أنظر ماقبلہ،(تحفة الأشراف:۸۰۶۰),2845,,The Chapters on Jihad
2846,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ إِسْمَاعِيل، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/المغازي ۱۴ (۱۷۵۵)، سنن ابی داود/الجہاد ۱۳۴ (۲۶۹۷)،(تحفة الأشراف:۴۵۱۵)، وقد أخرجہ: مسند احمد (۴/ و ۴۷،۵۱),2846,,The Chapters on Jihad
2847,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏عَنْ عُبَيْد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الجہاد ۱۸۷ (۳۰۶۷ تعلیقاً)، سنن ابی داود/الجہاد ۱۳۵ (۲۶۹۹)،(تحفة الأشراف:۷۹۴۳),2847,,The Chapters on Jihad
2848,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ يَحْيَى بْنِ س,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Isnaad Hasan,takhreej: «سنن ابی داود/الجہاد ۱۴۳ (۲۷۱۰)، سنن النسائی/الجنائز ۶۶ (۱۹۶۱)،(تحفة الأشراف:۳۷۶۷)، وقد أخرجہ: موطا امام مالک/الجہاد۱۳ (۲۳)، مسند احمد (۴/۱۱۴،۵/۱۹۲),2848,,The Chapters on Jihad
2849,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ عَمْرِو بْن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الجہاد ۱۹۰ (۳۰۷۴)،(تحفة الأشراف:۸۶۳۲)، وقد أخرجہ: مسند احمد (۲/۱۶۰),2849,,The Chapters on Jihad
2850,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏عَنْ أَبِي سِنَانٍ عِيسَى,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۵۱۲۱، ومصباح الزجاجة:۱۰۰۹),2850,,The Chapters on Jihad
2851,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الجہاد ۱۵۸ (۲۷۴۸،۲۷۴۹،۲۷۵۰)،(تحفة الأشراف:۳۲۹۳)، وقد أخرجہ: مسند احمد (۴/۱۵۹،۱۶۰)، سنن الدارمی/السیر ۴۳ (۲۵۲۶),2851,,The Chapters on Jihad
2852,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ سُفْيَانَ، ‏‏‏‏‏‏عَنْ عَبْدِ,Al-Albani: Daif Isnaad; Muhammad Fouad Abd al-Baqi: Daif Isnaad; Shuaib Al Arnaut: Daif; Zubair Ali Zai: Sahih,takhreej: «سنن الترمذی/السیر ۱۲ (۱۵۶۱)،(تحفة الأشراف:۵۰۹۱)، وقد أخرجہ: مسند احمد (۵/۳۱۹،۳۲۲،۳۲۳)، سنن الدارمی/السیر ۴۲ (۲۵۲۵),2852,,The Chapters on Jihad
2853,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْحُسَيْنِ، ‏‏‏‏‏‏أَنْبَأَنَا رَجَاءُ بْن,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «حدیث عبد اللہ بن عمرو تفرد بہ ابن ماجہ،(تحفة الأشراف:۸۷۰۵، ومصباح الزجاجة:۱۰۱۰)، وحدیث حبیب بن مسلمة تقدم تخریجہ،(۲۸۵۱),2853,,The Chapters on Jihad
2854,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو مُعَاوِيَةَ، ‏‏‏‏‏‏عَنْ عُبَيْدِ اللَّهِ ب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن ابی داود/الجہاد ۱۵۴ (۲۷۳۳)،(تحفة الأشراف:۸۱۱۱)، وقد أخرجہ: صحیح البخاری/الجہاد ۵۱ (۲۸۶۳)، صحیح مسلم/الجہاد ۱۷ (۱۷۶۲)، سنن الترمذی/السیر ۶ (۱۵۵۴)، مسند احمد (۲/۲،۶۲)، سنن الدارمی/السیر۳۳ (۲۵۱۵),2854,,The Chapters on Jihad
2855,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا هِشَامُ بْنُ سَعْدٍ، ‏,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Sahih,takhreej: «سنن ابی داود/الجہاد ۱۵۲ (۲۷۳۰)، سنن الترمذی/السیر ۹ (۱۵۵۷)،(تحفة الأشراف:۱۰۸۹۸)، وقد أخرجہ: مسند احمد۵/۲۲۳)، سنن الدارمی/السیر ۳۵ (۲۵۱۸),2855,,The Chapters on Jihad
2856,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الرَّحِيمِ بْنُ سُلَيْمَانَ، ‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الجہاد ۴۸ (۱۸۱۲)،(تحفة الأشراف:۱۸۱۳۷)، وقد أخرجہ: صحیح البخاری/الحیض ۲۴ (۳۲۴)، الحج ۸۱ (۱۶۵۲)، سنن الدارمی/الجہاد ۳۰ (۲۴۶۶),2856,,The Chapters on Jihad
2857,حَدَّثَنَا الْحَسَنُ بْنُ عَلِيٍّ الْخَلَّالُ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو أُسَامَةَ، ‏‏‏‏‏‏حَدَّثَنِي عَ,Al-Albani: Hasan Sahih; Muhammad Fouad Abd al-Baqi: Hasan Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۹۵۳، ومصباح الزجاجة:۱۰۱۱)، وقد أخرجہ: مسند احمد (۴/۲۴۰),2857,,The Chapters on Jihad
2858,حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ يُوسُفَ الْفِرْيَابِيُّ، ‏‏‏‏‏‏حَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الجہاد ۲ (۱۷۳۱)، سنن ابی داود/الجہاد ۹۰ (۲۶۱۲،۲۶۱۳)، سنن الترمذی/السیر ۴۸ (۱۶۱۷)،(تحفة الأشراف:۱۹۲۹)، وقد أخرجہ: مسند احمد (۵/۳۵۲،۳۵۸)، سنن الدارمی/السیر ۵ (۲۴۸۳),2858,,The Chapters on Jihad
2859,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «انظر حدیث رقم:(۳)(تحفة الأشراف:۱۲۴۷۷),2859,,The Chapters on Jihad
2860,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏ وَأَبُو بِشْرٍ بَكْرُ بْنُ خَلَفٍ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۶۹۹)، وقد أخرجہ: صحیح البخاری/الأذان ۵۴ (۶۹۳)، مسند احمد (۳/۱۱۴،۱۷۱),2860,,The Chapters on Jihad
2861,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعُ بْنُ الْجَرَّاحِ، ‏‏‏‏‏‏عَنْ ش,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الحج ۵۱ (۱۲۹۸)، الإمارة ۸ (۱۸۳۸)، سنن النسائی/البیعة ۲۶ (۴۱۹۷)،(تحفة الأشراف:۱۸۳۱۱)، وقد أخرجہ: مسند احمد (۴/۶۹،۵/۳۸۱،۶/۴۰۲،۴۰۳),2861,,The Chapters on Jihad
2862,حَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا مُحَمَّدُ بْنُ جَعْفَرٍ، ‏‏‏‏‏‏حَدَّثَنَا شُعْب,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح مسلم/الإمارة ۸ (۱۸۳۷)،(تحفة الأشراف:۱۱۹۵۰)،(یہ حدیث مکرر ہے، دیکھئے:۱۲۵۶),2862,,The Chapters on Jihad
2863,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَزِيدُ بْنُ هَارُونَ، ‏‏‏‏‏‏حَدَّثَنَ,Al-Albani: Hasan; Muhammad Fouad Abd al-Baqi: Hasan; Shuaib Al Arnaut: Hasan; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۲۶۶، ومصباح الزجاجة:۱۰۱۲)، وقد أخرجہ: مسند احمد (۳/۶۷),2863,,The Chapters on Jihad
2864,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ عُبَيْدِ اللَّ,Al-Albani: Sahih Isnaad; Muhammad Fouad Abd al-Baqi: Sahih Isnaad; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «حدیث عبد اللہ بن رجاء المکی تفرد بہ ابن ماجہ،(تحفة الأشراف:۷۹۲۷)، وحدیث اللیث بن سعد أخرجہ: صحیح مسلم/الإمارة ۸ (۱۸۳۹)، سنن الترمذی/الجہاد ۲۹ (۱۷۰۷)،(تحفة الأشراف:۸۰۸۸)وقد أخرجہ: صحیح البخاری/الجہاد ۱۰۸ (۲۹۵۵)، الأحکام ۴ (۷۱۴۴)، سنن ابی داود/الجہاد ۹۶ (۲۶۲۶)، سنن النسائی/البیعة ۳۴ (۴۲۱۱)، مسند احمد (۲/۱۷،۴۲),2864,,The Chapters on Jihad
2865,حَدَّثَنَا سُوَيْدُ بْنُ سَعِيدٍ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ سُلَيْمٍ، ‏‏‏‏‏‏ح وحَدَّثَنَا هِشَام,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۹۳۷۰، ومصباح الزجاجة:۱۰۱۳)، وقد أخرجہ: مسند احمد (۱/۳۹۹،۵/۳۲۵،۳۲۹),2865,,The Chapters on Jihad
2866,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، ‏‏‏‏‏‏عَنْ مُحَمّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الفتن ۲ (۷۰۵۶)، الأحکام ۴۳ (۷۱۹۹،۷۲۰۰)، صحیح مسلم/الإمارة ۸ (۱۷۰۹)، سنن النسائی/البیعة ۱ (۴۱۵۴،۴۱۵۵)،(تحفة الأشراف:۵۱۱۸)، وقد أخرجہ: موطا امام مالک/الجہاد۱ (۵)، مسند احمد (۴/۳۱۴،۳۱۸،۳۱۹،۳۲۱،۳۲۵),2866,,The Chapters on Jihad
2867,حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏حَدَّثَنَا الْوَلِيدُ بْنُ مُسْلِمٍ، ‏‏‏‏‏‏حَدَّثَنَا سَعِيد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الزکاة ۳۵ (۱۰۴۳)، سنن ابی داود/الزکاة ۲۷ (۱۶۴۲)، سنن النسائی/الصلاة ۵ (۴۶۱)،(تحفة الأشراف:۱۰۹۱۹),2867,,The Chapters on Jihad
2868,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏حَدَّثَنَا شُعْبَةُ، ‏‏‏‏‏‏عَنْ ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih Lighairihi; Zubair Ali Zai: Isnaad Hasan,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۱۰۸۷)، وقد أخرجہ: مسند احمد (۳/۱۱۹،۱۷۲،۱۸۵),2868,,The Chapters on Jihad
2869,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ أَبِي الزُّبَي,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/المساقاة ۲۳ (۱۶۰۲)، سنن ابی داود/البیوع ۱۷ (۳۳۵۸مختصرا)، سنن الترمذی/البیوع ۲۲ (۱۲۳۹)، السیر ۳۶ (۱۵۹۶)، سنن النسائی/البیعة ۲۱ (۴۱۸۹)، البیوع ۶۴ (۴۶۲۵)،(تحفة الأشراف:۲۹۰۴)، وقد أخرجہ: مسند احمد (۳/۳۴۹،۳۷۲),2869,,The Chapters on Jihad
2870,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَعَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏ وَأَحْمَدُ بْنُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih,takhreej: «صحیح البخاری/الشہادات ۲۲ (۲۶۷۲)، الأحکام ۴۸ (۷۲۱۲)، صحیح مسلم/الإیمان ۴۶ (۱۰۸)، البیوع ۶۲ (۱۵۶۶)، سنن الترمذی/السیر ۳۵ (۱۵۹۵)، سنن النسائی/البیوع ۶ (۴۴۶۷)،(تحفة الأشراف:۱۲۵۲۲)، وقد أخرجہ: مسند احمد (۲/۲۵۳،۴۸۰)،(یہ حدیث مکرر ہے دیکھئے:۲۲۰۷),2870,,The Chapters on Jihad
2871,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ إِدْرِيسَ، ‏‏‏‏‏‏ع,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/أحادیث الأنبیاء ۵۰ (۳۴۵۵)، صحیح مسلم/الإمارة ۱۰ (۱۸۴۲)،(تحفة الأشراف:۱۳۴۱۷)، وقد أخرجہ: مسند احمد (۲/۲۹۷),2871,,The Chapters on Jihad
2872,حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ نُمَيْرٍ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْوَلِيدِ، ‏‏‏‏‏‏حَد,Al-Albani: Sahih Mutawatir; Muhammad Fouad Abd al-Baqi: Sahih Mutawatir; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجزیة والموادعة ۲۲ (۳۱۸۶)، صحیح مسلم/الجہاد ۴ (۱۷۳۶)،(تحفة الأشراف:۹۲۵۰)، وقد أخرجہ: مسند احمد (۱/۴۱۱،۴۱۷،۴۴۱)، سنن الدارمی/البیوع ۱۱ (۲۵۸۴),2872,,The Chapters on Jihad
2873,حَدَّثَنَا عِمْرَانُ بْنُ مُوسَى اللَّيْثِيُّ، ‏‏‏‏‏‏حَدَّثَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏أَنْبَأَ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «تفرد بہ ابن ماجہ،(تحفة الأشراف:۴۳۶۸، ومصباح الزجاجة:۱۰۱۴)، وقد أخرجہ: صحیح مسلم/الجہاد ۴ (۱۷۳۸)، سنن الترمذی/الفتن ۲۶ (۲۱۹۱),2873,,The Chapters on Jihad
2874,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏أَنَّ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Isnaad Sahih,takhreej: «سنن الترمذی/السیر ۳۷ (۱۰۹۷)، سنن النسائی/البیعة ۱۸ (۴۱۸۶)،(تحفة الأشراف:۱۵۷۸۱)، وقد أخرجہ: موطا امام مالک/البیعة ۱ (۲)مسند احمد (۵/۳۲۳،۶/۳۵۷),2874,,The Chapters on Jihad
2875,حَدَّثَنَا أَحْمَدُ بْنُ عَمْرِو بْنِ السَّرْحِ الْمِصْرِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ و,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الطلاق ۲۰ (۵۲۸۸ تعلیقاً)، صحیح مسلم/الإمارة ۲۱ (۱۸۶۶)، سنن الترمذی/تفسیرالقرآن ۶۰ (۲)(۳۳۰۶)،(تحفة الأشراف:۱۶۶۹۷),2875,,The Chapters on Jihad
2876,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏ وَمُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدّ,Al-Albani: Daif; Muhammad Fouad Abd al-Baqi: Daif; Zubair Ali Zai: Daif,takhreej: «سنن ابی داود/الجہاد ۴۹ (۲۵۷۹)،(تحفة الأشراف:۱۳۱۲۱)، وقد أخرجہ: مسند احمد (۲/۵۰۵),2876,,The Chapters on Jihad
2877,حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ نُمَيْرٍ، ‏‏‏‏‏‏عَنْ عُبَيْد,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۲۵ (۱۸۷۰)،(تحفة الأشراف:۷۹۵۶)، وقد أخرجہ: صحیح البخاری/الصلاة ۴۱ (۱۲۰)، الجہاد ۵۶ (۲۸۶۸)،۵۷ (۲۸۶۹)،۵۸ (۲۸۷۰)، الاعتصام ۱۶ (۷۳۳۶)، سنن ابی داود/الجہاد ۶۷ (۲۵۷۵)، سنن الترمذی/الجہاد ۲۲ (۱۶۹۹)، سنن النسائی/الخیل ۱۲ (۳۶۱۴)، موطا امام مالک/ الجہاد ۱۹ (۴۵)، مسند احمد (۲/۵،۵۵،۵۶)، سنن الدارمی/الجہاد ۳۶ (۲۴۷۳),2877,,The Chapters on Jihad
2878,حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدَةُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏عَنْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih,takhreej: «سنن النسائی/الخیل ۱۳ (۳۶۱۵)،(تحفة الأشراف:۱۴۸۷۷)، وقد أخرجہ: سنن ابی داود/الجہاد ۶۷ (۲۵۷۴)، سنن الترمذی/الجہاد ۲۲ (۱۷۰۰)، مسند احمد (۲/۲۵۶،۳۵۸،۴۲۵،۴۷۴),2878,,The Chapters on Jihad
2879,حَدَّثَنَا أَحْمَدُ بْنُ سِنَانٍ، ‏‏‏‏‏‏ وَأَبُو عُمَرَ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih - Agreed Upon,takhreej: «صحیح البخاری/الجہاد ۱۲۹ (۲۹۹۰)، صحیح مسلم/الإمارة ۲۴ (۱۸۶۹)، سنن ابی داود/الجہاد ۸۸ (۲۶۱۰)،(تحفة الأشراف:۸۳۴۷)، وقد أخرجہ: موطا امام مالک/الجہاد ۲ (۷)، مسند احمد (۲/۶،۷،۱۰،۵۵،۶۳،۷۶،۱۲۸),2879,,The Chapters on Jihad
2880,حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ، ‏‏‏‏‏,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Shuaib Al Arnaut: Sahih; Zubair Ali Zai: Sahih Muslim,takhreej: «صحیح مسلم/الإمارة ۲۴ (۱۸۶۹)،(تحفة الأشراف:۸۲۸۶),2880,,The Chapters on Jihad
2881,حَدَّثَنَا يُونُسُ بْنُ عَبْدِ الْأَعْلَى، ‏‏‏‏‏‏حَدَّثَنَا أَيُّوبُ بْنُ سُوَيْدٍ، ‏‏‏‏‏‏عَنْ يُونُ,Al-Albani: Sahih; Muhammad Fouad Abd al-Baqi: Sahih; Zubair Ali Zai: Sahih Bukhari,takhreej: «صحیح البخاری/الخمس ۱۷ (۳۱۴۰)، المناقب ۲ (۳۵۰۲)، المغازي ۳۹ (۴۲۲۹)، سنن ابی داود/الخراج ۲۰ ۲۹۷۸،۲۹۸۹)، سنن النسائی/قسم الفئی ۱ (۴۱۴۱)،(تحفة الأشراف:۳۱۸۵)، وقد أخرجہ: مسند احمد (۴/۸۱،۸۳،۸۵),2881,,The Chapters on Jihad
