hadiths[39]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
287,"حضرت عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ باجماعت نماز اکیلے شخص ک",,,287,,
288,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ نماز باجماعت ، تم میں سے کسی اکی",,,288,,
289,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ قسم ہے اس ذات کی جس کے ہاتھ میں ",,,289,,
290,"بسر بن سعید رضی اللہ عنہ سے روایت ہے کہ حضرت زید بن ثابت رضی اللہ عنہ نے فرمایا : تمھاری سب سے افضل ",,,290,,
291,"سعید بن مسیّب رحمہ اللہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ ہمارے درمیان اور منافقوں کے درمیان ",,,291,,
292,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ ایک دفعہ کا واقعہ ہے کہ ایک شخص ",,,292,,
293,ابوبکر رحمہ اللہ بن سلیمان بن ابی حثمہ سے روایت ہے کہ حضرت عمر بن خطاب رضی اللہ عنہ نے نماز فجر میں ,,,293,,
294,عبدالرحمن بن ابی عمرہ انصاری رضی اللہ عنہ سے روایت ہے کہ حضرت عثمان بن عفان رضی اللہ عنہ نمازِ عشاء ,,,294,,
295,بُسر بن محجن رحمہ اللہ اپنے باپ مِحْجَن رضی اللہ عنہ سے روایت کرتے ہیں کہ ( ایک دفعہ ) وہ رسول اللہ ,,,295,,
296,نافع رحمہ اللہ سے روایت ہے کہ ایک آدمی نے حضرت عبداللہ بن عمر رضی اللہ عنہما سے سوال کیا کہ ( کبھی ی,,,296,,
297,یحیی بن سعید رحمہ اللہ سے روایت ہے کہ ایک آدمی نے سعید بن مسیب رحمہ اللہ سے سوال کیا ، کہنے لگا کہ ی,,,297,,
298,بنو اسد سے تعلق رکھنے والے ایک شخص نے حضرت ابوایوب انصاری رضی اللہ عنہ سے سوال کیا کہ میں ( بعض اوقا,,,298,,
299,"نافع رحمہ اللہ سے روایت ہے کہ حضرت عبداللہ بن عمر رضی اللہ عنہما کہا کرتے تھے : جس شخص نے نماز ِمغرب",,,299,,
300,"حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ جب تم میں سے کوئی شخص لوگوں کو ن",,,300,,
301,نافع رحمہ اللہ سے روایت ہے کہتے ہیں کہ میں نمازوں میں سے کسی نماز میں حضرت عبداللہ بن عمر رضی اللہ ع,,,301,,
302,یحیی بن سعید رحمہ اللہ سے روایت ہے کہ ایک آدمی ( مدینہ کے ایک مقام ) عقیق میں لوگوں کی امامت کراتا ت,,,302,,
303,حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ ایک گھوڑے پر سوار ہوئے ، پھر آپ ﷺ اس سے گرے,,,303,,
304,سیدہ عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے کہ ( ایک دفعہ ) رسول اللہ ﷺ نے اس حال میں نماز پڑ,,,304,,
305,ہشام بن عُروہ رحمہ اللہ اپنے باپ سے روایت کرتے ہیں کہ رسول اللہ ﷺ اپنے مرض میں تشریف لائے ، آپ ﷺ مسج,,,305,,
306,"حضرت عبداللہ بن عمرو بن عاص رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ تم میں سے کسی کی ب",,,306,,
307,حضرت عبداللہ بن عمرو بن عاص رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ جب ہم ( ہجرت کر کے ) مدینہ آئے تو,,,307,,
308,حضرت حفصہ ام المومنین رضی اللہ عنہا سے روایت ہے ، کہتی ہیں کہ میں نے رسول اللہ ﷺ کو کبھی بھی بیٹھ کر,,,308,,
309,حضرت عائشہ رضی اللہ عنہا زوجہ پیغمبر ﷺ سے روایت ہے ، کہتی ہیں کہ انھوں نے رسول اللہ ﷺ کو کبھی بھی را,,,309,,
310,ام المومنین سیّدہ عائشہ رضی اللہ عنہا ہی سے روایت ہے کہ رسول اللہ ﷺ بیٹھ کر نماز پڑھتے تو آپ ﷺ بیٹھے,,,310,,
311,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ عُروہ بن زُبیر رحمہ اللہ اور سعید بن مسیب رحمہ اللہ نفلی نماز,,,311,,
312,اُم المومنین سیدہ عائشہ رضی اللہ عنہا کے آزاد کردہ غلام ابو یُونس رحمہ اللہ روایت کرتے ہیں کہ سیدہ ع,,,312,,
313,عمرو بن رافع رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں اُمّ المومنین سیدہ حفصہ رضی اللہ عنہا کے لیے مص,,,313,,
314,عبدالرحمن بن سعید بن یربوع مخزومی رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ میں نے حضرت زید بن ثابت رضی ال,,,314,,
315,امام مالک رحمہ اللہ نے فرمایا کہ اُن کو یہ خبر پہنچی کہ حضرت علی بن ابی طالب رضی اللہ عنہ اور حضرت ع,,,315,,
316,حضرت عمر بن ابی سلمہ رضی اللہ عنہ سے روایت ہے کہ انھوں نے رسول اللہ ﷺ کو ایک کپڑے میں نماز پڑھتے ہوئ,,,316,,
317,حضرت ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ ایک سائل نے رسول اللہ ﷺ سے ایک کپڑے میں نماز پڑھنے کے متعل,,,317,,
318,سعید بن مسیَّب رحمہ اللہ سے روایت ہے کہ حضرت ابوہریرہ رضی اللہ عنہ سے سوال کیا گیا کہ کیا آدمی صرف ا,,,318,,
319,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ حضرت جابر بن عبداللہ انصاری رضی اللہ عنہ ایک ہی کپڑے میں نماز,,,319,,
320,ربیعہ بن ابی عبدالرحمن رحمہ اللہ سے روایت ہے کہ محمد بن عمرو بن حزم رحمہ اللہ صرف ایک قمیص میں نماز ,,,320,,
321,"حضرت جابر بن عبداللہ رضی اللہ عنہ سے روایت ہے کہ رسول اللہ ﷺ نے فرمایا :’’ جو شخص دو کپڑے نہ پا سکے ",,,321,,
322,امام مالک رحمہ اللہ کو یہ خبر پہنچی کہ زوجہ پیغمبر ﷺ سیدہ عائشہ رضی اللہ عنہا قمیص اور دوپٹے ہی میں ,,,322,,
323,محمد بن زید بن قُنفُذ رحمہ اللہ اپنی والدہ ( اُمِّ حرام آمنہ رحمہ اللہ ) سے روایت کرتے ہیں کہ انھوں ,,,323,,
324,عبیداللہ بن اَسْوَد خولانی رحمہ اللہ جو زوجہ پیغمبر ﷺ سیدہ میمونہ رضی اللہ عنہا کی گود میں ( پلے بڑھ,,,324,,
325,ہشام بن عروہ رحمہ اللہ اپنے باپ عُروہ رحمہ اللہ سے روایت کرتے ہیں کہ عورت نے اُن سے ( عروہ رحمہ اللہ,,,325,,
