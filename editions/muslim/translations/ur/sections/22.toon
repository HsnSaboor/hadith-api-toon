{"hadithnumber": "3962", "text": "یحییٰ قطان نے ہمیں عبیداللہ سے حدیث بیان کی ،  کہا :  مجھے نافع نے حضرت ابن عمر رضی اللہ عنہ سے خبر"}
{"hadithnumber": "3963", "text": "علی بن مسہر نے ہمیں حدیث بیان کی ،  کہا :  ہمیں عبیداللہ نے نافع سے حدیث بیان کی اور انہوں نے حضرت ا"}
{"hadithnumber": "3964", "text": "عبداللہ بن نمیر نے ہمیں حدیث بیان کی ،  کہا :  ہمیں عبیداللہ نے حدیث بیان کی ،  انہوں نے کہا :  مجھے"}
{"hadithnumber": "3965", "text": "اسامہ بن زید لیثی نے مجھے نافع سے خبر دی ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت کی ،"}
{"hadithnumber": "3966", "text": "محمد بن عبدالرحمٰن نے نافع سے ،  انہوں نے حضرت عبداللہ بن عمر رضی اللہ عنہ سے اور انہوں نے رسول اللہ"}
{"hadithnumber": "3967", "text": "موسیٰ بن عقبہ نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ حضرت عمر بن خطاب رضی"}
{"hadithnumber": "3968", "text": "عطاء نے حضرت جابر رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا"}
{"hadithnumber": "3969", "text": "لیث نے ہمیں ابوزبیر سے خبر دی ،  انہوں نے حضرت جابر رضی اللہ عنہ سے روایت کی کہ نبی صلی اللہ علیہ وس"}
{"hadithnumber": "3970", "text": "محمد بن حاتم اور ابن ابی خلف نے مجھے حدیث بیان کی ،  دونوں نے کہا :  ہمیں رَوح نے حدیث بیان کی ،  ان"}
{"hadithnumber": "3971", "text": "مجھے عمرو بن دینار نے بتایا کہ انہوں نے حضرت جابر بن عبداللہ رضی اللہ عنہ سے سنا ،  کہہ رہے تھے :  ن"}
{"hadithnumber": "3972", "text": "ابوبکر بن ابی شیبہ نے کہا :  ہمیں حفص بن غیاث نے حدیث بیان کی ،  نیز ابوکریب اور اسحاق بن ابراہیم نے"}
{"hadithnumber": "3973", "text": "ابوعوانہ نے قتادہ سے اور انہوں نے حضرت انس رضی اللہ عنہ سے روایت کی ،  انہوں نے کہا :  رسول اللہ صلی"}
{"hadithnumber": "3974", "text": "ابان بن یزید نے ہمیں حدیث بیان کی ،  کہا :  ہمیں قتادہ نے حدیث بیان کی ،  کہا :  ہمیں حضرت انس بن ما"}
{"hadithnumber": "3975", "text": "ابن وہب نے ہمیں ابن جریج سے خبر دی کہ ابوزبیر نے انہیں جابر بن عبداللہ رضی اللہ عنہ سے روایت کی کہ ر"}
{"hadithnumber": "3976", "text": "ابوعاصم نے ابن جریج سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی"}
{"hadithnumber": "3977", "text": "اسماعیل بن جعفر نے حمید سے اور انہوں نے حضرت انس رضی اللہ عنہ سے روایت کی کہ نبی صلی اللہ علیہ وسلم"}
{"hadithnumber": "3978", "text": "امام مالک نے حمید الطویل سے اور انہوں نے حضرت انس بن مالک رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی"}
{"hadithnumber": "3979", "text": "عبدالعزیز بن محمد نے حمید کے واسطے سے حضرت انس رضی اللہ عنہ سے حدیث  بیان کی کہ نبی صلی اللہ علیہ وس"}
{"hadithnumber": "3980", "text": "بشر بن حکم ،  ابراہیم بن دینار اور عبدالجبار بن علاء سے روایت ہے ،  الفاظ بشر کے ہیں ،  سب نے کہا :"}
{"hadithnumber": "3981", "text": "لیث نے ہمیں بکیر سے حدیث بیان کی ،  انہوں نے عیاض بن عبداللہ سے اور انہوں نے حضرت ابوسعید خدری رضی ا"}
{"hadithnumber": "3982", "text": "عمرو بن حارث نے بکیر بن اشج سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی"}
{"hadithnumber": "3983", "text": "عمرہ بنت عبدالرحمان  ( بن عوف )  نے کہا :  میں نے حضرت عائشہ رضی اللہ عنہا کو کہتے ہوئے سنا :  رسول"}
{"hadithnumber": "3984", "text": "عبداللہ بن وہب نے ہمیں خبر دی ،  کہا :  مجھے یونس نے ابن شہاب سے خبر دی ،  کہا :  مجھے عبداللہ بن کع"}
{"hadithnumber": "3985", "text": "عثمان بن عمر نے ہمیں خبر دی ،  انہوں نے کہا :  ہمیں یونس نے زہری سے خبر دی ،  انہوں نے عبداللہ بن کع"}
{"hadithnumber": "3986", "text": "عبدالرحمٰن بن ہُرمز نے عبداللہ بن کعب بن مالک سے اور انہوں نے حضرت کعب بن مالک رضی اللہ عنہ سے روایت"}
{"hadithnumber": "3987", "text": "زہیر بن حرب نے کہا :  ہمیں یحییٰ بن سعید نے حدیث بیان کی ،  کہا :  مجھے ابوبکر بن محمد بن عمرو بن حز"}
{"hadithnumber": "3988", "text": "یحییٰ بن یحییٰ نے ہمیں حدیث بیان کی ،  کہا :  ہمیں ہشیم نے خبر دی ،   ( اسی طرح )  قتیبہ بن سعید اور"}
{"hadithnumber": "3989", "text": "ابن ابی حسین نے مجھے حدیث بیان کی کہ انہیں ابوبکر بن محمد بن عمرو بن حزم نے خبر دی کہ انہیں عمر بن ع"}
{"hadithnumber": "3990", "text": "شعبہ نے ہمیں قتادہ سے حدیث بیان کی ،  انہیں نے نضر بن انس سے ،  انہوں نے بشیر بن نہیک سے ،  انہوں نے"}
{"hadithnumber": "3991", "text": "سعید اور ہشام دونوں نے قتادہ سے اسی سند کے ساتھ اسی کی مانند روایت کی اور کہا :   \" تو وہ  ( دیگر )"}
{"hadithnumber": "3992", "text": "عراک بن مالک نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :"}
{"hadithnumber": "3993", "text": "منصور نے ہمیں ربعی بن حراش سے حدیث بیان کی کہ حضرت حذیفہ  ( بن یمان رضی اللہ عنہ )  نے انہیں حدیث بی"}
{"hadithnumber": "3994", "text": "نُعَیم بن ابی ہند نے ربعی بن حراش سے روایت کی ،  انہوں نے کہا :  حضرت حذیفہ اور حضرت ابومسعود  ( انص"}
{"hadithnumber": "3995", "text": "عبدالملک بن عمیر نے ربعی بن حراش سے ،  انہوں نے حضرت حذیفہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ"}
{"hadithnumber": "3996", "text": "حذیفہ رضی اﷲ عنہ سے روایت ہے اﷲ عزوجل کے پس اس کا ایک بندہ لایا گیا جس کو اس نے مال دیا تھا تو اﷲ تع"}
{"hadithnumber": "3997", "text": "حضرت ابی مسعود رضی اﷲ عنہ سے روایت ہے رسول اﷲ ﷺ نے فرمایا تم سے پہلے ایک شخص کا حساب ہوا تو اس کی کو"}
{"hadithnumber": "3998", "text": "ابوہریرہؓ سے روایت ہے رسول اﷲ ﷺ نے فرمایا ایک شخص لوگوں کو قرض دیا کرتا اور وہ اپنے نوکروں سے کہتا ج"}
{"hadithnumber": "3999", "text": "یونس نے ابن شہاب سے خبر دی کہ انہیں عبیداللہ بن عبداللہ بن عتبہ نے حدیث بیان کی کہ انہوں نے حضرت ابو"}
{"hadithnumber": "4000", "text": "حماد بن زید نے ہمیں ایوب سے حدیث بیان کی ،  انہوں نے یحییٰ بن ابی کثیر سے اور انہوں نے عبداللہ بن اب"}
{"hadithnumber": "4001", "text": "جریر بن حازم نے ایوب سے اسی سند کے ساتھ اسی طرح حدیث بیان کی ۔"}
{"hadithnumber": "4002", "text": "اعرج  ( عبدالرحمٰن بن ہرمز مدنی )  نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ ع"}
{"hadithnumber": "4003", "text": "ہمام بن منبہ نے حضرت ابوہریرہ رضی اللہ عنہ سے اور انہوں نے نبی صلی اللہ علیہ وسلم سے روایت کی  ۔  ۔"}
{"hadithnumber": "4004", "text": ")  وکیع اور یحییٰ بن سعید نے ابن جریج سے حدیث بیان کی ،  انہوں نے ابوزبیر سے اور انہوں نے حضرت جابر"}
{"hadithnumber": "4005", "text": "روح بن عبادہ نے ہمیں خبر دی ،  کہا :  ہمیں ابن جریج نے حدیث بیان کی ،  کہا :  مجھے ابوزبیر نے بتایا"}
{"hadithnumber": "4006", "text": "اعرج نے حضرت ابوہریرہ رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا :   \" زائد"}
{"hadithnumber": "4007", "text": "ابن شہاب سے روایت ہے ،  کہا :  مجھے سعید بن مسیب اور ابوسلمہ بن عبدالرحمٰن نے حدیث بیان کی کہ حضرت ا"}
{"hadithnumber": "4008", "text": "ہلال بن اسامہ نے خبر دی کہ ابوسلمہ بن عبدالرحمٰن نے انہیں بتایا کہ انہوں نے حضرت ابوہریرہ رضی اللہ ع"}
{"hadithnumber": "4009", "text": "امام مالک نے ابن شہاب سے ،  انہوں نے ابوبکر بن عبدالرحمٰن سے اور انہوں نے حضرت ابومسعود انصاری رضی ا"}
{"hadithnumber": "4010", "text": ")  قتیبہ بن سعید اور محمد بن رُمح نے لیث بن سعد سے روایت کی ،  نیز ابوبکر بن ابی شیبہ نے کہا :  ہمیں"}
{"hadithnumber": "4011", "text": "محمد بن یوسف سے روایت ہے ،  انہوں نے کہا :  میں نے سائب بن یزید سے سنا ،  وہ حضرت رافع بن خدیج رضی ا"}
{"hadithnumber": "4012", "text": "اوزاعی نے یحییٰ بن ابی کثیر سے روایت کی ،  کہا :  مجھے ابراہیم بن قارظ نے سائب بن یزید سے حدیث بیان"}
{"hadithnumber": "4013", "text": "معمر نے یحییٰ بن ابی کثیر سے اسی سند کے ساتھ اسی کے مانند حدیث بیان کی ۔"}
{"hadithnumber": "4014", "text": "ہشام نے ہمیں یحییٰ بن ابی کثیر سے حدیث بیان کی ،  کہا :  مجھے ابراہیم نے عبداللہ نے سائب بن یزید سے"}
{"hadithnumber": "4015", "text": "ابوزبیر سے روایت ہے ،  انہوں نے کہا :  میں نے حضرت جابر رضی اللہ عنہ سے کتے اور بلی کی قیمت کے بارے"}
{"hadithnumber": "4016", "text": "امام مالک نے نافع سے اور انہوں نے حضرت ابن عمر رضی اللہ عنہ سے روایت کی کہ رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "4017", "text": "عبیداللہ نے ہمیں نافع کے حوالے سے حضرت ابن عمر رضی اللہ عنہ سے حدیث بیان کی ،  انہوں نے کہا :  رسول"}
