hadiths[68]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
735,"عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  جس شخ",,,,,735
736,"عثمان بن عفان رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  جس ",,,,,736
737,"علی بن ابی طالب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے اللہ تع",,,,,737
738,"جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس شخص نے پرندے",,,,,738
739,"انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قیامت اس وقت قائم ہو ",,,,,739
740,"عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میرا خیال ہے کہ",,,,,740
741,"عمر بن خطاب رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب کسی قوم کے اعمال خ",,,,,741
742,انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  مسجد نبوی کی زمین قبیلہ بنو نجار کی ملکیت تھی، جس میں کھجور کے,,,,,742
743,عثمان رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے انہیں حکم دیا کہ طائف میں مسجد وہیں ,,,,,743
744,عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  ان سے ان باغات میں نماز پڑھنے کے متعلق پوچھا گیا جن می,,,,,744
745,"ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قبرستان اور حمام  (",,,,,745
