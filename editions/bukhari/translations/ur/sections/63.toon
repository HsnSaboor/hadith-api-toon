{"hadithnumber": "3930", "text": "ہم سے عبیداللہ بن سعید نے بیان کیا، کہا ہم سے ابواسامہ نے بیان کیا، ان سے ہشام نے، ان سے ان کے والد"}
{"hadithnumber": "3931", "text": "مجھ سے محمد بن مثنیٰ نے بیان کیا، کہا ہم سے غندر نے بیان کیا، ان سے شعبہ نے بیان کیا، ان سے ہشام نے،"}
{"hadithnumber": "3932", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے عبدالوارث نے بیان کیا (دوسری سند) اور ہم سے اسحاق بن منصور نے بیان"}
{"hadithnumber": "3933", "text": "مجھ سے ابراہیم بن حمزہ نے بیان کیا، کہا ہم سے حاتم بن اسماعیل نے بیان کیا، ان سے عبدالرحمٰن بن حمید"}
{"hadithnumber": "3934", "text": "ہم سے عبداللہ بن مسلمہ قعنبی نے بیان کیا، کہا ہم سے عبدالعزیز بن ابوحازم نے بیان کیا، ان سے ان کے وا"}
{"hadithnumber": "3935", "text": "ہم سے مسدد نے بیان کیا، کہا ہم سے یزید بن زریع نے بیان کیا، کہا ہم سے معمر نے بیان کیا، ان سے زہری ن"}
{"hadithnumber": "3936", "text": "ہم سے یحییٰ بن قزعہ نے بیان کیا، کہا ہم سے ابراہیم بن سعد نے بیان کیا، ان سے زہری نے، ان سے عامر بن"}
{"hadithnumber": "3937", "text": "ہم سے محمد بن یوسف بیکندی نے بیان کیا، ان سے سفیان بن عیینہ نے بیان کیا، ان سے حمید طویل نے اور ان س"}
{"hadithnumber": "3938", "text": "مجھ سے حامد بن عمر نے بیان کیا، کہا ہم سے بشر بن مفضل نے، ان سے حمید طویل نے بیان کیا اور ان سے انس"}
{"hadithnumber": "3940", "text": "ہم سے علی بن عبداللہ المدینی نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے بیان کیا، ان سے عمرو بن دینار"}
{"hadithnumber": "3941", "text": "ہم سے مسلم بن ابراہیم نے بیان کیا، کہا ہم سے قرہ بن خالد نے بیان کیا، ان سے محمد بن سیرین نے اور ان"}
{"hadithnumber": "3942", "text": "مجھ سے احمد یا محمد بن عبیداللہ غدانی نے بیان کیا، کہا ہم سے حماد بن اسامہ نے بیان کیا کہ انہیں ابو"}
{"hadithnumber": "3943", "text": "ہم سے زیاد بن ایوب نے بیان کیا، انہوں نے کہا ہم سے ہشیم نے بیان کیا، انہوں نے کہا ہم سے ابوبشر جعفر"}
{"hadithnumber": "3944", "text": "ہم سے عبدان نے بیان کیا، انہوں نے کہا ہم سے عبداللہ بن مبارک نے بیان کیا، انہوں نے کہا کہ ہم سے یونس"}
{"hadithnumber": "3945", "text": "مجھ سے زیاد بن ایوب نے بیان کیا کہا، ہم سے ہشیم نے بیان کیا کہا، ہم کو ابوبشر (جابر بن ابی وحشیہ) نے"}
{"hadithnumber": "3946", "text": "مجھ سے حسن بن شقیق نے بیان کیا، کہا ہم سے معتمر نے بیان کیا کہ میرے والد سلیمان بن طرخان نے بیان کیا"}
{"hadithnumber": "3947", "text": "ہم سے محمد بن یوسف بیکندی نے بیان کیا کہا، ہم سے ابن عیینہ نے بیان کیا، ان سے عوف اعرابی نے، ان سے ا"}
{"hadithnumber": "3948", "text": "مجھ سے حسن بن مدرک نے بیان کیا، کہا ہم سے یحییٰ بن حماد نے بیان کیا، کہا ہم کو ابوعوانہ نے خبر دی، ا"}
