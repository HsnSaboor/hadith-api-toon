{"hadithnumber": "2495", "text": "اسماعیل بن جعفر نے ابو سہیل ( نافع بن مالک بن ابی عامر )  سے  ، انھوں نے اپنے والد سے ، انھوں نے حضر"}
{"hadithnumber": "2496", "text": "یونس نے ابن شہاب سے خبردی ، انھوں نے ( ابوسہیل نافع )  ابن ابی انس سے روایت کی کہ انھیں ان کےوالد نے"}
{"hadithnumber": "2497", "text": "صالح نے ابن شہاب سے باقی ماندہ سابقہ سند سے روایت کی کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :"}
{"hadithnumber": "2498", "text": "یحییٰ بن یحییٰ نے کہا : میں نے مالک کے سامنے قراءت کی ، انھوں نے نافع سے ، انھوں نے حضرت ابن عمر رضی"}
{"hadithnumber": "2499", "text": "ابواسامہ نے کہا : عبیداللہ نے ہمیں نافع سے حدیث بیان کی ، انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے"}
{"hadithnumber": "2500", "text": "ہم سے ابن نمیر نے حدیث بیان کی  ، کہا : ہمیں میرے والد نے حدیث سنائی ، کہا : ہمیں عبیداللہ نے اسی ("}
{"hadithnumber": "2501", "text": "یحییٰ بن سعید نے عبیداللہ سے اسی سند کے ساتھ حدیث بیان کی اور کہا : رسول اللہ  صلی اللہ علیہ وسلم  ن"}
{"hadithnumber": "2502", "text": "ایوب نے نافع سے ، انھوں نے ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا : رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "2503", "text": "سلمہ بن علقمہ نے نافع سے حدیث بیان کی ، انھوں نے عبداللہ  بن عمر  رضی اللہ تعالیٰ عنہ سےروایت کی  ،"}
{"hadithnumber": "2504", "text": "سالم بن عبداللہ نے حدیث بیان کی کہ حضرت عبداللہ بن عمر  رضی اللہ تعالیٰ عنہ  نے کہا : میں نے رسول ال"}
{"hadithnumber": "2505", "text": "عبداللہ بن دینار سے روایت ہے کہ انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے سنا ، کہا : رسول اللہ"}
{"hadithnumber": "2506", "text": "عمرو بن دینار نے ہمیں حدیث سنائی کہ انھوں نے حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے سنا ، کہہ رہے تھے"}
{"hadithnumber": "2507", "text": "ابو سلمہ نے مجھے بتایا کہ انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے سنا ، وہ کہہ رہے تھے : میں ن"}
{"hadithnumber": "2508", "text": "موسیٰ بن طلحہ نے حضرت عبداللہ بن عمر رضی اللہ تعالیٰ عنہ  سے ، انھوں نے نبی اکرم  صلی اللہ علیہ وسلم"}
{"hadithnumber": "2509", "text": "شعبہ ، جبلۃ حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرما"}
{"hadithnumber": "2510", "text": "شعبہ نے ہمیں عقبہ بن حریث سے حدیث بیان کی ، کہا : میں نے ابن عمر   رضی اللہ تعالیٰ عنہ  سے سنا  ، کہ"}
{"hadithnumber": "2511", "text": "محمد بن المثنی ، ابن بشار  ، محمد جعفر ، شعبہ ، اسود بن قیس ، سعید ابن عمر وبن سعید ، حضرت ابن عمر"}
{"hadithnumber": "2512", "text": "سفیان نے اسود بن قیس سے اسی سندکے ساتھ روایت کی اور دوسرے مہینے کے تیس ( دنوں )  کا ذکر نہیں کیا"}
{"hadithnumber": "2513", "text": "سعد بن عبیدہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے انہوں نے فرمایا کہ حضرت ابن عمر  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2514", "text": "سعید بن مسیب ، حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ انہوں نے فرمایا کہ رسول اللہ  صلی"}
{"hadithnumber": "2515", "text": "۔  ربیع ، ابن مسلم ، عن محمد ، ابن زیاد ، حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ نبی کر"}
{"hadithnumber": "2516", "text": "شعبہ ، محمد بن زیاد ، حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  فرماتے ہیں کہ رسول اللہ  صلی اللہ علیہ وس"}
{"hadithnumber": "2517", "text": "اعرج ، ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  فرماتے ہیں کہ رسول اللہ  رضوان اللہ عنھم اجمعین  نے فرمایا کہ"}
{"hadithnumber": "2518", "text": "علی بن مبارک  ، یحییٰ بن ابن کثیر ، ابی سلمہ ، حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ ا"}
{"hadithnumber": "2519", "text": "۔  معاویہ ، ابن سلام ، ابن مثنی ، ابو  عامر  ، ہشام ، ابن مثنی ، ابن ابی عمر ، عبدالوہاب بن عبدالمجی"}
{"hadithnumber": "2520", "text": "معمر ، حضرت زہری  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ نبی کریم  صلی اللہ علیہ وسلم  نے قسم اٹھائی کہ"}
{"hadithnumber": "2521", "text": "لیث ، ابن زبیر ، حضرت جابر  رضی اللہ تعالیٰ عنہ  سے روایت ہے انہوں نے فرمایا کہ رسول اللہ  صلی اللہ"}
{"hadithnumber": "2522", "text": "ابن جریج ، ابو زبیر ، حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  فرماتے ہیں کہ نبی کریم  صلی اللہ عل"}
{"hadithnumber": "2523", "text": "حجاج بن محمد ، ابن جریج ، یحییٰ بن عبداللہ بن محمد بن صیفی ، عکرمہ بن عبدالرحمٰن بن حارث ، حضرت ام س"}
{"hadithnumber": "2524", "text": "ضحاک ، حضرت ابن جریج سے اس سند کے ساتھ ہی اسی حدیث کی طرح روایت کیا گیا ہے ۔"}
{"hadithnumber": "2525", "text": "محمد بن بشر ، اسماعیل بن ابی خالد ، محمد بن سعید ، حضرت سعد بن ابی وقاص  رضی اللہ تعالیٰ عنہ  سے روا"}
{"hadithnumber": "2526", "text": "زائدہ ، اسماعیل ، حضرت محمد بن سعد اپنے باپ سے روایت کرتے ہوئے فرماتے ہیں کہ نبی کریم  صلی اللہ علیہ"}
{"hadithnumber": "2527", "text": "۔  عبداللہ بن مبارک ، اسماعیل بن ابی خالد اس سند کے ساتھ یہ روایت بھی اس طرح نقل کی گئی ہے ۔"}
{"hadithnumber": "2528", "text": "کریب کو سیدہ ام الفضل بنت حارث رضی اللہ عنہا نے سیدنا معاویہ رضی اللہ عنہ کی طرف بھیجا شام میں، انہو"}
{"hadithnumber": "2529", "text": "۔  حصین ، عمر بن مرہ ، حضرت ابوالبختری  رضی اللہ تعالیٰ عنہ  سے روایت ہے انہوں نے  فرمایا کہ ہم عمرہ"}
{"hadithnumber": "2530", "text": "شعبہ ، عمرو ابن مرہ حضرت ابو البختری فرماتے ہیں کہ ہم نے ذات عرق میں رمضان کا چاندد یکھا  تو ہم نے ح"}
{"hadithnumber": "2531", "text": "یزید بن زریع ، خالد ، حضرت عبدالرحمٰن بن ابی بکرہ  رضی اللہ تعالیٰ عنہ  اپنے باپ سے روایت کرتے ہوئے"}
{"hadithnumber": "2532", "text": "معتمر بن سلیمان ، اسحاق بن سوید ، خالد ، حضرت عبدالرحمٰن بن ابی بکرہ  رضی اللہ تعالیٰ عنہ  اپنے باپ"}
{"hadithnumber": "2533", "text": "حضرت عدی بن حاتم رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ انہوں نے فرمایا کہ جب آیت حَتَّىٰ يَتَبَيَّنَ ل"}
{"hadithnumber": "2534", "text": "فضیل بن سلیمان ، ابو حازم ،  حضرت سہل بن سعد  رضی اللہ تعالیٰ عنہ  بیان کرتے ہیں ۔ جب یہ آیتوَكُلُوا"}
{"hadithnumber": "2535", "text": "ابو غسان ، ابو حازم ، سہل بن سعد  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ جب یہ آیت نازل ہوئی تو بعض آدم"}
{"hadithnumber": "2536", "text": "لیث ، ابن شہاب ، سالم بن عبداللہ ، حضرت عبداللہ  رضی اللہ تعالیٰ عنہ  رسول اللہ  صلی اللہ علیہ وسلم"}
{"hadithnumber": "2537", "text": "یونس ، ابن شہاب ، سالم بن عبداللہ ، حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  نے فرمایا کہ میں نے رسول اللہ"}
{"hadithnumber": "2538", "text": "ابن نمیر ، عبیداللہ بن نافع ، حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  نے فرمایا کہ ر سول اللہ  صلی اللہ ع"}
{"hadithnumber": "2539", "text": "ابن نمیر ، عبیداللہ  ، قاسم ، سید  عائشہ  رضی اللہ تعالیٰ عنہا   نے نبی کریم  صلی اللہ علیہ وسلم  سے"}
{"hadithnumber": "2540", "text": "ابو اسامہ ، عبدہ ، حمادبن مسعدہ ،  سب نے عبیداللہ  سے ( پچھلی دونوں حدیثوں میں مذکوران کی  ) سندوں ک"}
{"hadithnumber": "2541", "text": "اسماعیل بن ابراہیم ، سلیمان تیمی ، ابی عثمان ، حضرت ابن مسعود  رضی اللہ تعالیٰ عنہ  نے کہا کہ رسول ا"}
{"hadithnumber": "2542", "text": "خالداحمر نے ، سلیمان تیمی ، سے اس سند کے ساتھ حضرت سلیمان تیمی سے یہ روایت اسی طرح نقل کی گئی ہے سوا"}
{"hadithnumber": "2543", "text": "ابو بکر ابن ابی شیبہ ، معتمر بن سلیمان ، اسحاق بن ابراہیم ، جریر ، معتمر بن سلیمان ، اس سند کے ساتھ"}
{"hadithnumber": "2544", "text": "عبدالوارث ، عبداللہ بن سوادۃ قشیری ، حضرت سمرہ بن جندب  رضی اللہ تعالیٰ عنہ  فرماتے ہیں کہ میں نے مح"}
{"hadithnumber": "2545", "text": "۔  اسماعیل بن علیۃ ، عبداللہ بن سوادۃ ، حضرت سمرہ بن جندب  رضی اللہ تعالیٰ عنہ  فرماتے ہیں کہ رسول ا"}
{"hadithnumber": "2546", "text": "حماد ، ابن زید ، عبداللہ بن سوادۃ قشیری ، حضرت سمرہ بن جندب  رضی اللہ تعالیٰ عنہ  فرماتے ہیں کہ رسول"}
{"hadithnumber": "2547", "text": "عبیداللہ بن معاذ ، شعبہ ، سوادہ ، حضرت سمرہ بن جندب  رضی اللہ تعالیٰ عنہ  خطبہ دیتے ہوئے بیان کرتے ہ"}
{"hadithnumber": "2548", "text": "ابو داود ( طیالسی )  نے شعبہ سے باقی ماندہ سابقہ سند کے ساتھ روایت کی کہ رسول اللہ  صلی اللہ علیہ وس"}
{"hadithnumber": "2549", "text": "حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا کہ سحری کھایا"}
{"hadithnumber": "2550", "text": "لیث ، موسیٰ بن علی  ، ابی قیس ، مولی عمرو بن عاص ، حضرت عمر بن العاص  رضی اللہ تعالیٰ عنہ  سے روایت"}
{"hadithnumber": "2551", "text": "وکیع اور وہب دونون نے موسیٰ بن علی  رضی اللہ تعالیٰ عنہ  سے اسی طرح ر وایت نقل کی گئی ہے ۔"}
{"hadithnumber": "2552", "text": "ہشام ، قتادہ ، انس ، حضرت زید بن ثابت  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ انہوں نے فرمایا کہ ہم نے"}
{"hadithnumber": "2553", "text": "عمرو ناقد ، یزیدبن ہارون ، ہمام ، ابن مثنی ، سالم بن نوح ، عمربن عامر ، قتادہ اس سند کے ساتھ حضرت قت"}
{"hadithnumber": "2554", "text": "عبدالعزیز بن ابی حازم ، حضرت سہل بن سعد  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ  رسول اللہ  صلی اللہ عل"}
{"hadithnumber": "2555", "text": "قتیبہ ، یعقوب ، زہیر بن حرب ، عبدالرحمٰن ابن مہدی ، سفیان ، حضرت سہل بن سعد   رضی اللہ تعالیٰ عنہ  ن"}
{"hadithnumber": "2556", "text": "یحییٰ بن یحییٰ  ، ابو کریب ، محمد بن علاء ، ابو معاویہ ، اعمش ، عمارہ بن عمیر ، حضرت ابو عطیہ  رضی ا"}
{"hadithnumber": "2557", "text": "ابن ابی زوائد ، اعمش ، عمارہ ، حضرت ابو عطیہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے انہوں نے فرمایا کہ می"}
{"hadithnumber": "2558", "text": "یحییٰ بن یحییٰ  ، ابو کریب ، ابن نمیر ، یحییٰ  ، ابو معاویہ  ، ابن نمیر ، ابو کریب ، اسامہ ،  ہشام ،"}
{"hadithnumber": "2559", "text": "ہشیم ، ابی اسحاق شیبانی ، حضرت عبداللہ بن ابی اوفیٰ سے روایت ہے انہوں نے فرمایا کہ ہم  رسول اللہ  صل"}
{"hadithnumber": "2560", "text": "علی بن مسہر ، عباد بن عوام ، شیبانی ، حضرت ابن ابی اوفیٰ  رضی اللہ تعالیٰ عنہ  سے روایت ہے انہوں نے"}
{"hadithnumber": "2561", "text": "ابوکامل ، عبدالواحد ، سلیمان شیبانی ، حضرت عبداللہ بن اوفیٰ  رضی اللہ تعالیٰ عنہ  فرماتے ہیں کہ تم ر"}
{"hadithnumber": "2562", "text": "ابن ابی عمر  ، سفیان ، اسحاق ، جریر ، شیبانی ، ابن ابی اوفیٰ ، عبیداللہ بن معاذ ، ابن مثنی ، محمد بن"}
{"hadithnumber": "2563", "text": "یحییٰ بن یحییٰ ، نافع ، حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ نبی کریم  صلی اللہ علیہ وس"}
{"hadithnumber": "2564", "text": "ابو بکر بن ابی شیبہ ، عبداللہ بن نمیر ، عبیداللہ  ، نافع ، حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روا"}
{"hadithnumber": "2565", "text": "عبدالوارث بن عبدالصمد ، ایوب ، نافع ، ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی ال"}
{"hadithnumber": "2566", "text": "حرملہ بن یحییٰ  ، ابن وہب ، یونس ، ابن شہاب ، ابو سلمہ بن عبدالرحمٰن  ، حضرت ابوہریرۃ  رضی اللہ تعال"}
{"hadithnumber": "2567", "text": "زہیر بن حرب ، اسحاق ،  زہیر ، جریر ، عمارہ ، ابی زرعہ ، حضرت ابوہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت"}
{"hadithnumber": "2568", "text": "قتیبہ ، مغیرہ ، ابی زناد ، اعرج ، حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  نے رسول اللہ  صلی اللہ علیہ و"}
{"hadithnumber": "2569", "text": "ابن نمیر ، اعمش ، ابی صالح ، حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  نے نبی سے اسی  طرح روایت کیا ہے جس"}
{"hadithnumber": "2570", "text": "زہیر بن حرب ابو نضر ہاشم بن قاسم سلیمان ثابت حضرت انس  رضی اللہ تعالیٰ عنہ  نے فرمایا کہ رسول اللہ"}
{"hadithnumber": "2571", "text": "۔  عاصم بن نضر تیمی  ، خالد ، ابن حارث ، حمید ، ثابت ، حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ"}
{"hadithnumber": "2572", "text": "اسحاق بن ابراہیم ، عثمان بن ابی شیبہ  ، عبدہ بن سلیمان  ، ہشام بن عروہ ، حضرت عائشہ  رضی اللہ تعالیٰ"}
{"hadithnumber": "2573", "text": "علی بن حجر ، سفیان ، ہشام بن عروہ ، سیدہ عائشہ  رضی اللہ تعالیٰ عنہا   فرماتی ہیں کہ  رسول اللہ  صلی"}
{"hadithnumber": "2574", "text": "علی بن حجر ، ابن ابی عمر ، حضرت سفیان  رضی اللہ تعالیٰ عنہ  فرماتے ہیں کہ میں نے عبدالرحمٰن بن قاسم"}
{"hadithnumber": "2575", "text": "۔  ابو بکر بن ابی شیبہ ، علی بن مسہر ، عبیداللہ بن عمر ، قاسم  ، سیدہ عائشہ  رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "2576", "text": "یحییٰ بن یحییٰ  ، ابو بکر بن ابی شیبہ ، ابو کریب ، یحییٰ  ، ابو معاویہ ، اعمش ، ابراہیم ، اسود  ، عل"}
{"hadithnumber": "2577", "text": "علی بن حجر ، زہیر بن حرب ، سفیان ، منصور ، ابراہیم  ، علقمہ ، سید ہ عائشہ  رضی اللہ تعالیٰ عنہا   فر"}
{"hadithnumber": "2578", "text": "محمد بن مثنی ، ابن بشار ، محمد بن جعفر ، شعبہ ، منصور  ، ابراہیم ، علقمہ ، سیدہ عائشہ  رضی اللہ تعال"}
{"hadithnumber": "2579", "text": "محمد بن مثنی ، ابو عاصم ، ابن عون ، ابراہیم ، اسود ، فرماتے ہیں کہ میں اور مسروق حضرت عائشہ   رضی ال"}
{"hadithnumber": "2580", "text": "یعقوب اسماعیل ، ابن عون ، ابراہیم ، اسود ، مسروق اس سند کے ساتھ حضرت ابراہیم  رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "2581", "text": "ابو بکر ابن ابی شیبہ ،  ، حسن بن موسیٰ ، شیبان ، یحییٰ ابن ابی کثیر ، ابی سلمہ ، عمر بن عبدالعزیز ،"}
{"hadithnumber": "2582", "text": "یحییٰ ابن بشر حریری ، معاویہ ، حضرت یحییٰ بن کثیر سے اس سندکے ساتھ اسی طرح روایت نقل کی  گئی ہے ۔"}
{"hadithnumber": "2583", "text": "یحییٰ ابن یحییٰ  ،  قتیبہ بن سعید ،  ابو بکر بن ابی شیبہ ، ابوااحوص ، زیادہ بن علاقہ ، عمرو بن میمون"}
{"hadithnumber": "2584", "text": "محمد بن حاتم ، بھز بن اسد ، ابو بکر نہشلی ، زیاد بن علاقہ ، عمرو بن میمون ، سیدہ  عائشہ صدیقہ  رضی ا"}
{"hadithnumber": "2585", "text": "۔  محمد بن بشار ، عبدالرحمٰن ، سفیان ، ابی زناد ، علی بن حسین ، سیدہ عائشہ صدیقہ  رضی اللہ تعالیٰ عن"}
{"hadithnumber": "2586", "text": "یحییٰ بن یحییٰ  ، ابو بکر بن ابی شیبہ ، ابو کریب  ، یحییٰ ، ابومعاویہ ، اعمش ، مسلم ، شتیر بن شکل ،"}
{"hadithnumber": "2587", "text": "۔  ابو ربیع زہرانی ، ابو عوانہ  ، ابو بکر بن ابی شیبہ ، اسحاق بن ابراہیم ، جریر ، منصور ، مسلم شتیر"}
{"hadithnumber": "2588", "text": "ہارون بن سعید ، ابن وہب ، عمرو ، ابن حارث ، عبدربہ بن سعید ، عبداللہ بن کعب حمیری ، حضرت عمر بن ابی"}
{"hadithnumber": "2589", "text": "محمد بن حاتم ، یحییٰ بن سعید ، ابن جریج ، محمد بن رافع ، عبدالرزاق بن ہمام ، ابن جریج ، عبدالملک بن"}
{"hadithnumber": "2590", "text": "حرملہ بن یحییٰ ، ابن وہب ، یونس ، ابن شہاب ، عروہ بن زبیر ، ابی بکر بن عبدالرحمٰن ، سیدہ عائشہ صدیقہ"}
{"hadithnumber": "2591", "text": "ہارون بن سعید ، ابن وہب ، عمرو ، ابن حارث ، عبدربہ ، حضرت عبداللہ بن کعب حمیری  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2592", "text": "یحییٰ بن یحییٰ ، مالک ، عبدربہ ، بن سعید ، ابی بکر بن عبدالرحمٰن بن حارث بن ہشام ، سیدہ عائشہ صدیقہ"}
{"hadithnumber": "2593", "text": "یحییٰ بن یحییٰ ، ایوب ، قتیبہ ، ابن حجر ، ابن ایوب ، اسماعیل بن جعفر ، عبداللہ بن عبداالرحمٰن ، ابن"}
{"hadithnumber": "2594", "text": "احمد بن عثمان نوفلی ، ابو عاصم ، ابن جریج ، محمد بن یوسف ، حضرت سلیمان بن یسار رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2595", "text": "یحییٰ بن یحییٰ ، ابو بکر بن ابی شیبہ ، زہیر بن حرب ، ابن نمیر ، ابن عینیہ ، سفیان بن عینیہ ، حمید بن"}
{"hadithnumber": "2596", "text": "اسحاق بن ابراہیم ، جریر ، منصور ، حضرت محمد بن مسلم زہری  رضی اللہ تعالیٰ عنہ  سے اس سند کے ساتھ اس"}
{"hadithnumber": "2597", "text": "یحییٰ بن یحییٰ ، محمد بن رمح ، لیث  ، قتیبہ ، ابن شہاب ، حمید بن عبدالرحمٰن  ، بن عوف ، حضرت ابوہریر"}
{"hadithnumber": "2598", "text": "محمد بن  رافع ، اسحا ق بن عیسیٰ ، مالک ، حضرت زہری سے اس سندکے ساتھ روایت ہے کہ ایک آدمی نے رمضان می"}
{"hadithnumber": "2599", "text": "محمد بن رافع ، عبدالرزاق  ، ابن جریج ، ابن شہاب ، حمید بن عبدالرحمان ، حضرت ابو ہریرۃ  رضی اللہ تعال"}
{"hadithnumber": "2600", "text": "معمرنے زہری سےاسی سندکے ساتھ ابن عینیہ کی حدیث کی طرح روایت کی ۔"}
{"hadithnumber": "2601", "text": "محمد بن رمح ، ابن مہاجر ، لیث ، یحییٰ بن سعید ، عبدالرحمان بن قاسم ، محمد بن جعفر ، ابن زبیر ، عباد"}
{"hadithnumber": "2602", "text": "محمد بن مثنیٰ ، عبدالوہاب ثقفی  ، یحییٰ بن سعید ، عبدالرحمان بن قاسم ، محمد بن جعفر بن زبیر ، عبدالل"}
{"hadithnumber": "2603", "text": "ابو طاہر ، ابن وہب ، عمرو بن لیث ، عبدالرحمان بن قاسم ، محمد بن جعفر بن زبیر ، عبادبن عبداللہ بن زبی"}
{"hadithnumber": "2604", "text": "یحییٰ بن یحییٰ ، محمد بن رمح ، لیث  ، قتیبہ ، بن سعید ، ابن شہاب ، عبیداللہ بن عبداللہ بن عتبہ ، حضر"}
{"hadithnumber": "2605", "text": "یحییٰ بن یحیٰ ۔ ابو بکر بن ابی شیبہ ، عمر ، اسحاق بن ابراہیم ، سفیان ، حضرت زہری ، سے اس سند کے ساتھ"}
{"hadithnumber": "2606", "text": "۔  محمد بن رافع ، عبدالرزاق  ، معمر ، حضرت زہری  رضی اللہ تعالیٰ عنہ  سے اس سند کے ساتھ اسی طرح روای"}
{"hadithnumber": "2607", "text": "حرملہ بن یحییٰ ، ابن وہب  ، یونس ، ابن شہاب لیث اس سند کے ساتھ ابن شہاب سےلیث کی حدیث کی طرح روایت ن"}
{"hadithnumber": "2608", "text": "۔  اسحاق بن ابراہیم ، جریر ، منصور ، مجاہد ، طاؤس ، حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت ہے"}
{"hadithnumber": "2609", "text": "ابو کریب ، وکیع ، سفیان ، عبدالکریم ، طاؤس ، حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت ہے انہوں ن"}
{"hadithnumber": "2610", "text": "محمد بن مثنی ، عبدالوہاب ، ابن عبدالمجید ، جعفر ، حضرت جابر بن عبداللہ  رضی اللہ تعالیٰ عنہ  سے روای"}
{"hadithnumber": "2611", "text": "قتیبہ بن سعید ، عبدالعزیز ، حضرت  جعفر سے اس سند کے ساتھ یہ روایت نقل کی گئی ہے اور اس میں یہ زائد ہ"}
{"hadithnumber": "2612", "text": "ابو بکر بن ابی شیبہ ، محمد بن مثنیٰ ، ابن بشار ، محمد بن جعفر ، غندر ، شعبہ ، محمد بن عبدالرحمان  ،"}
{"hadithnumber": "2613", "text": "عبیداللہ بن معاذ ، شعبہ ،  محمد بن عبدالرحمان ، محمد بن عمرو بن حسن ، حضرت جابر بن عبداللہ  رضی اللہ"}
{"hadithnumber": "2614", "text": "احمد بن عثمان نوفلی ، ابو داود ، شعبہ ، یحییٰ ابن ابی کثیر اس طرح ایک اور سند کےساتھ بھی یہ روایت نق"}
{"hadithnumber": "2615", "text": "ہداب بن خالد ، ہمام بن یحییٰ  ، قتادہ ، حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ  سے روایت ہے انہوں ن"}
{"hadithnumber": "2616", "text": "محمد بن ابی بکر مقدمی ، یحییٰ بن سعید تیمی ، محمد بن مثنیٰ ، ابن مہدی  ، شعبہ ، ابو عامر ، ہشام ، سا"}
{"hadithnumber": "2617", "text": "نصر بن علی جہضمی ، بشر ( ابن مفضل )  ابی مسلمہ  ، ابی نضرۃ ، حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2618", "text": "۔  عمرو ناقد ، اسماعیل بن ابراہیم ، جریری ، ابی نضرۃ ، حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ   سے"}
{"hadithnumber": "2619", "text": "سعید بن عمر ، سہل بن عثمان ، سوید بن سعید ، حسین بن حریث ، سعید  ، مروان بن معاویہ  ، عاصم ، ابا نضر"}
{"hadithnumber": "2620", "text": "یحییٰ بن یحییٰ  ، ابو خثيمة ، حضرت حمید سے روایت ہے کہ حضرت انس  رضی اللہ تعالیٰ عنہ  سے سفر   میں ر"}
{"hadithnumber": "2621", "text": "ابو بکر بن ابی شیبہ ، ابو خالد احمر ، حضرت حمید  رضی اللہ تعالیٰ عنہ  سے روایت ہے ۔ فرمایا کہ میں نک"}
{"hadithnumber": "2622", "text": "ابو بکر بن ابی شیبۃ ، ابو معاویہ ، عاصم ، مورق ، حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ ہم رس"}
{"hadithnumber": "2623", "text": "ابو کریب ، حفص ، عاصم ، مورق ، حضرت انس  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علی"}
{"hadithnumber": "2624", "text": "محمد بن حاتم ، عبدالرحمان بن مہدی ، معاویہ بن صالح ، حضرت ربیعہ سے روایت ہے  وہ کہتے ہیں کہ مجھ سے ق"}
{"hadithnumber": "2625", "text": "۔  قتیبہ بن سعید ، لیث ، ہشام بن عروۃ  ، سید عائشہ صدیقہ  رضی اللہ تعالیٰ عنہا   فرماتی ہیں کہ حضرت"}
{"hadithnumber": "2626", "text": "ابوربیع  ، حماد ، ابن زید ، ہشام ، سیدہ عائشہ صدیقہ  رضی اللہ تعالیٰ عنہا   سے روایت ہے کہ حضرت حمزہ"}
{"hadithnumber": "2627", "text": "یحییٰ بن یحییٰ  ، ابو معاویہ ، حضرت ہشام سے اس سند کے ساتھ اسی طرح حدیث نقل کی گئی ہے ۔"}
{"hadithnumber": "2628", "text": "ابو بکر بن ابی شیبہ ابو کریب  ، ابن نمیر ، ابو بکر عبداالرحیم بن سلیمان ، حضرت ہشام سے اس سند کے سات"}
{"hadithnumber": "2629", "text": "ابو طاہر ، ہارون بن سعید ، ہارون ، ابو طاہر ، ابن وہب ، عمرو بن حارث ، ابی اسود  ، عروۃ بن زبیر ، اب"}
{"hadithnumber": "2630", "text": "داود بن رشید  ، ولید بن مسلم ، سعید بن عبدالعزیز ، اسماعیل ، عبیداللہ ، ام درداء ، حضرت ابو درداء  ر"}
{"hadithnumber": "2631", "text": "عبداللہ بن مسلمۃ ، ہشام بن سعید ، عثمان ابن حیان ، دمشقی ، حضرت ام درداء  رضی اللہ تعالیٰ عنہ  سے رو"}
{"hadithnumber": "2632", "text": "یحییٰ بن یحییٰ  ، مالک ، ابی نضر ، عمیر ، مولی ابن عباس ، حضرت ام الفضل بنت حارثہ سے روایت ہے کہ کچھ"}
{"hadithnumber": "2633", "text": "اسحاق بن ابراہیم ، ابن ابی عمر ، سفیان ، حضرت ابی انصر سے اس سند کے ساتھ روایت ہے لیکن اس میں آپ صلی"}
{"hadithnumber": "2634", "text": "زہیر بن حرب ، عبدالرحمان بن مہدی ، سفیان ، حضرت سالم بن ابی النضر  رضی اللہ تعالیٰ عنہ  سے اس سند کے"}
{"hadithnumber": "2635", "text": "ہارون بن سعید ، ابن وہب ، عمرو ، ابی نضر ، مولی ابن عباس ، حضرت ام فضل  رضی اللہ تعالیٰ عنہا   فرمات"}
{"hadithnumber": "2636", "text": "ہارون بن سعید ، ابن وہب ، عمر ، بکیر ، بن اشج ، کریب ، مولی ابن عباس ، حضرت میمونہ  رضی اللہ تعالیٰ"}
{"hadithnumber": "2637", "text": "۔  زہیر بن حرب ، جریر ، ہشام بن عروۃ  ، سیدہ عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت ہے فرماتی ہیں کہ"}
{"hadithnumber": "2638", "text": "ابو بکر بن ابی شیبہ ، ابو کریب ، ابن نمیر ، حضرت ہشام سے اس سند کے ساتھ روایت ہے اور حدیث کے شروع می"}
{"hadithnumber": "2639", "text": "عمرو ناقد ، سفیان ، زہری ، عروۃ ، سیدہ عائشہ صدیقہ  رضی اللہ تعالیٰ عنہا   سے روایت ہے کہ عاشورہ کے"}
{"hadithnumber": "2640", "text": "حرملہ بن یحییٰ ، ابن وہب ، یونس ، ابن شہاب ، عروۃ بن زبیر ، سیدہ عائشہ صدیقہ  رضی اللہ تعالیٰ عنہا"}
{"hadithnumber": "2641", "text": "قتیبہ بن سعید ، محمد بن  رمح ، لیث بن سعید ، یزید بن ابی حبیب ، عروۃ ، عائشہ صدیقہ  رضی اللہ تعالیٰ"}
{"hadithnumber": "2642", "text": "ابو بکر بن ابی شیبہ ، عبداللہ بن نمیر ، ابن نمیر ، عبیداللہ  ، نافع ، حضرت ابن عمر  رضی اللہ تعالیٰ"}
{"hadithnumber": "2643", "text": "محمد بن مثنی ، زہیر بن حرب ، یحییٰ ، ابو بکر بن ابی شیبہ ، ابواسامہ ، حضرت عبیداللہ سے اس سند کے سات"}
{"hadithnumber": "2644", "text": "قتیبہ بن سعید ، لیث ، ابن رمح ، لیث  ، نافع ، حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول"}
{"hadithnumber": "2645", "text": "ابو کریب ، ابو اسامہ ، ولید ، ابن کثیر ، نافع ، حضرت ابن عمر  رضی اللہ تعالیٰ عنہ  بیان کرتے ہیں انہ"}
{"hadithnumber": "2646", "text": "محمد بن احمد بن ابی خلف ، روح ، ابو مالک ، عبیداللہ بن اخنس ، نافع ، حضرت ابن عمر  رضی اللہ تعالیٰ ع"}
{"hadithnumber": "2647", "text": "احمد بن عثمان نوفلی ، ابو عاصم ، عمر بن محمد بن زیدعسقلانی ، سالم بن عبداللہ ، حضرت ابن عمر  رضی الل"}
{"hadithnumber": "2648", "text": "ابو بکر بن ابی شیبہ ، ابو کریب ، ابی معاویہ ، ابو بکر ، ابومعاویہ ، اعمش  ، عمارۃ ، حضرت عبدالرحمان"}
{"hadithnumber": "2649", "text": "زہیر بن حرب ، عثمان بن ابی شیبہ ، جریر ، حضرت اعمش سے اس سند کے ساتھ یہ حدیث اس طرح نقل کی گئی ہے ۔"}
{"hadithnumber": "2650", "text": "ابو بکر بن ابی شیبہ ، وکیع ، یحییٰ بن سعید ، سفیان ، محمد بن حاتم ، زبید یامی ، عمارۃ بن عمیر ، حضرت"}
{"hadithnumber": "2651", "text": "محمد بن حاتم ، اسحاق بن منصور ، اسرائیل ، منصور ، ابراہیم ، علقمہ ، اشعث بن قیس ، علی ابن مسعود ، حض"}
{"hadithnumber": "2652", "text": "ابو بکر ابن ابی شیبہ ، عبیداللہ بن موسیٰ ، شیبان ، اشعث بن ابی شعشاء ، جعفر بن ابی ثور ، حضرت جابر ب"}
{"hadithnumber": "2653", "text": "۔  حرملہ بن یحییٰ ، ابن وہب ، یونس ، ابن شہاب ، حضرت حمید بن عبدالرحمان ،  رضی اللہ تعالیٰ عنہ  خبر"}
{"hadithnumber": "2654", "text": "ابو طاہر عبداللہ ، عبداللہ بن وہب ، مالک بن انس ، حضرت ابن شہاب  رضی اللہ تعالیٰ عنہ  سے اس سند کے س"}
{"hadithnumber": "2655", "text": "ابن ابی عمر ، سفیان بن عینیہ ، حضرت زہری سے اس سند کے ساتھ روایت ہے کہ انہوں نے نبی کریم صلی اللہ عل"}
{"hadithnumber": "2656", "text": "یحییٰ بن یحییٰ ، ہشیم ابی بشر ، سعید بن جبیر ، حضرت ابن عباس  رضی اللہ تعالیٰ عنہ  سے روایت ہے فرمای"}
{"hadithnumber": "2657", "text": "ابن بشار ، ابو بکر بن نافع ، محمد بن جعفر ، شعبہ ، ابی بشراس سندکے ساتھ حضرت ابی بشر  رضی اللہ تعالی"}
{"hadithnumber": "2658", "text": "ابن ابی عمر ، سفیان ، ایوب ، عبداللہ بن سعید بن جبیر ، حضرت ابن عباس رضی اللہ تعالیٰ عنہ  سے روایت ہ"}
{"hadithnumber": "2659", "text": "اسحاق بن ابراہیم ، عبدالرزاق ، معمر ، حضرت ایوب سے اس سند کے ساتھ اسی طرح روایت نقل کی گئی ہے سوائے"}
{"hadithnumber": "2660", "text": "ابو بکر بن ابی شیبہ ، ابن نمیر ، ابو اسامہ ، ابی عمیس ، قیس بن سالم ، طارق بن شہاب ، حضرت ابو موسیٰ"}
{"hadithnumber": "2661", "text": "احمد بن منذر ، حماد بن  اسامہ ، ابو عمیس  ، قیس ، صدقہ بن ابی عمران ، قیس بن سالم ، طارق بن شہاب ، ح"}
{"hadithnumber": "2662", "text": "ابو بکر ابن شیبہ ، عمروناقد ، سفیان ، ابو بکر ، ابن عینیہ ، عبیداللہ ابن ابی یزید ، حضرت ابن عباس  ر"}
{"hadithnumber": "2663", "text": "۔  محمد بن رافع  ، عبدالرزاق ، ابن جریج ، عبیداللہ بن ابی یزید اس سند کے ساتھ اسی طرح کی یہ حدیث نقل"}
{"hadithnumber": "2664", "text": "ابو بکر بن ابی شیبہ ، وکیع بن جراح ، حاجب ابن عمر ، حضرت حکم بن اعرج سے روایت ہے فرماتے ہیں کہ میں ح"}
{"hadithnumber": "2665", "text": "محمد بن حاتم ، یحییٰ بن سعید ، معاویہ بن عمرو ، حضرت حکم بن اعرج کہتے ہیں کہ میں نے حضرت ابن عباس  ر"}
{"hadithnumber": "2666", "text": "حسن بن علی حلوانی ، ابن ابی مریم ، یحییٰ بن ایوب ، اسماعیل بن امیہ ، حضرت ابن عباس  رضی اللہ تعالیٰ"}
{"hadithnumber": "2667", "text": "ابو بکر بن ابی شیبہ ، ابو کریب ، وکیع ، ابن ابی ذئب ، قاسم بن عبداللہ ، عبداللہ بن عمیر ، حضرت ابن ع"}
{"hadithnumber": "2668", "text": "قتیبہ بن سعید ، حاتم یعنی ابن اسماعیل ، یزید بن ابی عبید ، حضرت سلمہ بن اکوع  رضی اللہ تعالیٰ عنہ  س"}
{"hadithnumber": "2669", "text": "ابو بکر بن نافع ، بشر بن مفضل بن لاحق  ، خالد بن ذکوان ، حضرت ربیع بنت معوذبن عفراء  رضی اللہ تعالیٰ"}
{"hadithnumber": "2670", "text": "یحییٰ بن یحییٰ ، ابو معشر ، عطار ، حضرت خالد بن ذکوان کہتے ہیں کہ میں نے ربیع بنت معوذ  رضی اللہ تعا"}
{"hadithnumber": "2671", "text": "یحییٰ بن یحییٰ  ، مالک ابن شہاب ، حضرت ابو عبید مولی بن ازہر سے روایت ہے انہوں نے کہاکہ میں عید کے د"}
{"hadithnumber": "2672", "text": "یحییٰ بن یحییٰ ، مالک ، محمد بن یحییٰ ابن حبان ، اعرج ، حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روای"}
{"hadithnumber": "2673", "text": "قتیبہ بن سعید ، جریر ، عبدالملک ، ابن عمیر ، قزعہ ، حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ  سے روای"}
{"hadithnumber": "2674", "text": "ابو کامل جحدری ، عبدالعزیز بن مختار  ، عمرو بن یحییٰ ، حضرت ابو سعید خدری  رضی اللہ تعالیٰ عنہ  سے ر"}
{"hadithnumber": "2675", "text": "ابوبکر بن ابی شیبہ ، وکیع ابن عون ، حضرت زیاد بن جبیر  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ فرمایا کہ"}
{"hadithnumber": "2676", "text": "حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت ہے ، کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے دو روزوں  ،"}
{"hadithnumber": "2677", "text": "سریج بن یونس ، ہشیم  ، خالد ، ابی ملیح ، حضرت نبیشہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ"}
{"hadithnumber": "2678", "text": "محمد بن عبداللہ ابن نمیر ، اسماعیل ابن علیہ ، خالد ، ابی ملیح ، نبیشہ ، اس سند کے ساتھ بھی نبی کریم"}
{"hadithnumber": "2679", "text": "ابو بکر بن ابی شیبہ ، محمد بن  سابق ، ابراہیم بن طہمان ، ابی زبیر ، حضرت کعب  رضی اللہ تعالیٰ عنہ  ا"}
{"hadithnumber": "2680", "text": "عبد بن حمید  ، ابو عامر ، عبدالملک بن عمرو ، ابراہیم بن طہمان اس سند کے ساتھ بھی اسی طرح روایت نقل ک"}
{"hadithnumber": "2681", "text": "عمرو ناقد ، سفیان بن عینیہ ، عبدالحمید ابن جبیر ، حضرت محمد بن عباد بن جعفر  رضی اللہ تعالیٰ عنہ  کہ"}
{"hadithnumber": "2682", "text": "محمد بن رافع ، عبدالرزاق ، ابن جریج ، عبدالحمید بن جبیر بن شیبہ ، محمد بن عباد جعفر  ، جابر بن عبدال"}
{"hadithnumber": "2683", "text": "ابو بکر بن ابی شیبہ ، حفص ، ابو معاویہ ، اعمش ، یحییٰ بن یحییٰ ، ابو معاویہ ، اعمش ، ابی صالح ، حضرت"}
{"hadithnumber": "2684", "text": "ابو کریب ، حسین یعنی جعفی ، زائدہ ، ہشام ، ابن سیرین ، حضرت ابو ہریرۃ  رضی اللہ تعالیٰ عنہ  سے روایت"}
{"hadithnumber": "2685", "text": "۔  قتیبہ بن سعید ، بکر یعنی ابن مضر ، عمرو بن حارث  ، بکیر  ، یزید مولی سلمہ ، حضرت سلمہ بن اکوع  رض"}
{"hadithnumber": "2686", "text": "عمرو بن سواد عامری ، عبداللہ بن وہب ، عمروبن حارث بکیر بن اشجع ، یزید مولی سلمۃ بن اکوع  ، حضرت سلمہ"}
{"hadithnumber": "2687", "text": "احمد بن عبداللہ بن یونس ، زہیر ، یحییٰ بن سعید ، حضرت ابو سلمہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے فرم"}
{"hadithnumber": "2688", "text": "اسحاق بن ابراہیم ، بشر بن عمر زہرانی ، سلیمان بن بلال ، یحییٰ حضرت یحییٰ بن سعید اس سند کے ساتھ اس ط"}
{"hadithnumber": "2689", "text": "محمد بن رافع ، عبدالرزاق ، ابن جریج ، یحییٰ بن سعید ، نے اس سند کے ساتھ اس طرح بیان کیا کہ میرا خیال"}
{"hadithnumber": "2690", "text": "محمد بن مثنیٰ ، عبدالوہاب ، عمروناقد ، سفیان ، حضرت یحییٰ سے اس سند کے ساتھ روایت ہے اور اس حدیث میں"}
{"hadithnumber": "2691", "text": "محمد بن ابی عمر مکی ، عبدالعزیز بن محمد دراوردی ، یزید بن عبداللہ بن ہاد ، محمد بن ابراہیم ، ابی سلم"}
{"hadithnumber": "2692", "text": "ہارون بن سعید  ، احمد بن عیسیٰ  ، ابن وہب ، عمر وبن حارث ، عبیداللہ بن ابی جعفر ، محمد بن جعفر بن زب"}
{"hadithnumber": "2693", "text": "اسحاق بن ابراہیم ، عیسیٰ بن یونس ، اعمش ، مسلم ، سعید بن جبیر ، حضرت ابن عباس  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2694", "text": "۔  احمد بن عمر وکیعی ، حسین بن علی ، زائدہ ، سلیمان  ، مسلم  ، سعید بن جبیر ، حضرت ابن عباس  رضی الل"}
{"hadithnumber": "2695", "text": "ابو سعید اشج ، ابو خالد ، اعمش ، سلمہ بن کہیل ، حکم بن عتیبہ ، مسلم بن جبیر ، مجاہد ، وعطاء ، ابن عب"}
{"hadithnumber": "2696", "text": "اسحاق بن منصور ، ابن ابی خلف ، عبد بن حمید ، زکریا بن عدی  ، عبیداللہ بن عمرو ، زید بن ابی انیسہ ، ح"}
{"hadithnumber": "2697", "text": "علی بن مسہر ، ابوالحسن نے عبداللہ بن عطاء سے ، انھوں نے عبداللہ بن بریدہ سے اور انھوں نے اپنے والدسے"}
{"hadithnumber": "2698", "text": "عبداللہ بن نمیر نے عبداللہ بن عطاء سے  ، انھوں نے عبداللہ بن بریدہ سے ، انھوں نے اپنے والد سے روایت"}
{"hadithnumber": "2699", "text": "عبدالرزاق نے کہا : ہمیں ( سفیان )  ثوری نے عبداللہ بن عطاء سے خبر دی ، انھوں نے ابن بریدہ سے اورانھو"}
{"hadithnumber": "2700", "text": "عبیداللہ بن موسیٰ نے سفیان ( ثوری )  سے اسی سند کے ساتھ ( سابقہ حدیث کی مانند )  حدیث بیان کی اورانھ"}
{"hadithnumber": "2701", "text": "عبدالملک بن ابی سلیمان نے عبداللہ بن عطاء سے  ، انھوں نے سلیمان بن بریرہ سے اور انھوں نے اپنے والد س"}
{"hadithnumber": "2702", "text": "۔ حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ نبی اکرم  صلی اللہ علیہ وسلم  نےفرمایا :  \" جب"}
{"hadithnumber": "2703", "text": "حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  نے ( نبی کریم سے )  روایت کی ، کہا :  \" جب تم  میں سے کوئی کسی"}
{"hadithnumber": "2704", "text": "ابن شہاب سے روایت ہے  ، کہا : سعید بن مسیب نے مجھے بتایا کہ انھوں نے حضرت ابو ہریرہ  رضی اللہ تعالیٰ"}
{"hadithnumber": "2705", "text": "اعرج نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی  ، کہا : رسول اللہ صلی اللہ علیہ وسلم  نے فر"}
{"hadithnumber": "2706", "text": "عطاء نے ابو صالح الزیا ت سے روایت کی  ، انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے سنا ، کہہ رہ"}
{"hadithnumber": "2707", "text": "اعمش نے ابو صالح سے اور انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہاؒ رسول اللہ  ص"}
{"hadithnumber": "2708", "text": "محمد بن فضیل نے ابو سنان سے ،  انھوں نے ابو صالح سے اور انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2709", "text": "عبد العزیز بن مسلم نے کہا :  ہمیں ضرار بن مرہ  ( ابوسنان  ) نے اسی سند کے ساتھ  ( سابقہ حدیث کے ما ن"}
{"hadithnumber": "2710", "text": "حضرت سہل بن سعد  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہا رسول اللہ  صلی اللہ علیہ وسلم  نے فر ما یا  :"}
{"hadithnumber": "2711", "text": "ابن ہاد نے سہیل بن ابی صالح سے  ، انھوں نے نعمان بن ابی عیاش سے اور انھوں نے حضرت ابو سعید خدری رضی"}
{"hadithnumber": "2712", "text": "عبد العزیز یعنی دراوردی نے سہیل سے اسی سند کے ساتھ  ،  ( سابقہ حدیث کے مانند  ) حدیث بیان کی ،"}
{"hadithnumber": "2713", "text": "ابن جریج نے یحییٰ بن سعید اور سہیل بن ابی صالح سے خبر دی کہ ان دونوں نے نعمان بن عیاش زرقی صالح سے خ"}
{"hadithnumber": "2714", "text": "عبدالواحد بن زیاد نے حدیث بیان کی ،  ( کہا :  ) ہمیں طلحہ بن یحییٰ نے حدیث سنائی ،  ( انھوں نے کہا :"}
{"hadithnumber": "2715", "text": "وکیع نے باقی ماندہ سابقہ سند کے ساتھ ام المومنین حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے روایت کی ، کہ"}
{"hadithnumber": "2716", "text": "حضرت ابو ہریرہ  رضی اللہ تعالیٰ عنہ  سے روایت ہے  ، کہا : رسول اللہ  صلی اللہ علیہ وسلم  نے فرمایا :"}
{"hadithnumber": "2717", "text": "سعید جریری نے عبداللہ بن  شقیق سے روایت کی ، کہا : میں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سےدریاف"}
{"hadithnumber": "2718", "text": "کہمس نے عبداللہ بن شقیق سے حدیث بیان کی  ، کہا : میں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے پوچھا"}
{"hadithnumber": "2719", "text": "حماد نے ایوب اورہشام سے  ، انھوں نے محمد سے ، انھوں نے عبداللہ بن شقیق سے روایت کی ۔ حماد نے کہا : م"}
{"hadithnumber": "2720", "text": "قتیبہ نے ہمیں حدیث سنائی ،  ( کہا :  )   ہمیں حماد نے ایوب سے حدیث سنائی ، انھوں نے عبداللہ بن شقیق"}
{"hadithnumber": "2721", "text": "عمر بن عبیداللہ کے آزاد کردہ غلام ابو نضر نے ابو سلمہ بن عبدالرحمان ( بن عوف )  سے اور انھوں نے ام ا"}
{"hadithnumber": "2722", "text": "ابن ابی لبید نے ابو سلمہ سے روایت کی ، کہا : میں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سے رسول اللہ"}
{"hadithnumber": "2723", "text": "یحییٰ بن ابی کثیر نے ابو سلمہ سے اور انھوں نے حضرت عائشہ  رضی اللہ تعالیٰ عنہا   سےروایت کی ، اور کہ"}
{"hadithnumber": "2724", "text": "ابو عوانہ نے ابو بشر سے  ، انھوں نے سعید بن جبیر سے اور انھوں نے حضرت ابن عباس رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2725", "text": "شعبہ نے اسی سند کے ساتھ ابو بشر سے ( سابقہ حدیث کے مانند )  روایت کی اور (  \" پورا مہینہ کے بجائے )"}
{"hadithnumber": "2726", "text": "عبداللہ بن نمیر نے کہا : ہمیں عثمان بن حکیم نے حدیث سنائی ، کہا : میں نے سعید بن جبیر سے رجب میں روز"}
{"hadithnumber": "2727", "text": "علی بن مسہر اور عیسیٰ بن یونس دونوں نے اسی سند کے ساتھ عثمان بن حکیم سے اسی ( سابقہ حدیث )  کے مانند"}
{"hadithnumber": "2728", "text": "زہیر بن حرب اورابو بکر بن نافع نے  ۔ الفاظ انھی کے ہین ۔ دو الگ الگ سندوں کے ساتھ حماد سے حدیث بیان"}
{"hadithnumber": "2729", "text": "ابن شہاب نے سعید بن مسیب اور ابو سلمہ بن عبدالرحمان سے روایت کی کہ حضرت عبداللہ بن عمرو بن عاص  رضی"}
{"hadithnumber": "2730", "text": "عکرمہ بن عمار نے کہا : ہمیں یحییٰ نے حدیث سنائی کہا : میں اور عبداللہ بن یزید حضرت ابو سلمہ کے پاس ح"}
{"hadithnumber": "2731", "text": "حسین المعلم نے یحییٰ بن ابی کثیر سے اسی سند کے ساتھ  ( سابقہ حدیث کے مانند )  حدیث  سنائی ، اور آپ ص"}
{"hadithnumber": "2732", "text": "شیبان نے یحییٰ سے ، انہوں نے بنو زہرہ کے مولیٰ محمد بن عبدالرحمان سے ، انھوں نے ابو سلمہ سے روایت کی"}
{"hadithnumber": "2733", "text": "اوزاعی نے کہا : مجھے یحییٰ بن ابی کثیر نے  ( عمر )   بن حکم بن ثوبان سے حدیث سنائی ، کہا : مجھے ابو"}
{"hadithnumber": "2734", "text": "عبدالرزاق نے کہا : ہمیں ابن جریج نے خبر دی  ، کہا : میں نے عطاء سے سنا وہ کہتے تھے  کہ ابو عباس نے ا"}
{"hadithnumber": "2735", "text": "محمد بن بکر نے ہم سے حدیث بیان کی ،  ( کہا :  ) ہمیں ابن جریج نے اسی سند سے ( سابقہ حدیث کے مانند )"}
{"hadithnumber": "2736", "text": "شعبہ نے ہمیں حبیب سے حدیث بیا ن کی ، انھوں نے ابو عباس ( سائب بن فروخ )  سے سنا ، انھوں نے عبداللہ ب"}
{"hadithnumber": "2737", "text": "مسعر سے روایت ہے ، کہا :  )  ہمیں حبیب بن ابی ثابت نے اسی سند کےساتھ ( سابقہ حدیث کے مانند )  حدیث س"}
{"hadithnumber": "2738", "text": "سفیان بن عینیہ نے عمر و سے ، انھوں نے ابوعباس سے ، انھوں نے حضرت عبداللہ بن عمر و رضی اللہ تعالیٰ عن"}
{"hadithnumber": "2739", "text": "ہمیں سفیان بن عینیہ نے عمرو بن دینار سے حدیث بیان کی ، انھوں نے عمرو بن اوس سے اور انھوں نے عبداللہ"}
{"hadithnumber": "2740", "text": "ہمیں ابن جریج نے خبر دی ، انھوں نے کہا : مجھے عمرو بن دینار نے خبر دی کہ ان کو عمرو بن اوس نے حضرت ع"}
{"hadithnumber": "2741", "text": "ابو قلابہ ( بن زید بن عامر الجرمی البصری )  نے کہا : مجھے ابوملیح نے خبر دی ، کہا : میں تمھارے والد"}
{"hadithnumber": "2742", "text": "زیاد بن فیاض سے روایت ہے  ، کہا : میں نے ابو عیاض سے سنا ، انھوں نے حضرت عبداللہ بن عمر و  رضی اللہ"}
{"hadithnumber": "2743", "text": "سعید بن میناء نے ہمیں حدیث سنائی ،  کہا :  عبداللہ بن عمرو عاص رضی اللہ تعالیٰ عنہ  نے کہا : رسول ال"}
{"hadithnumber": "2744", "text": "سیدہ معاذہ العدویہ سے روایت ہے کہ انہوں نے ام المؤمنین عائشہ صدیقہ رضی اللہ عنہا سے پوچھا کہ کیا رسو"}
{"hadithnumber": "2745", "text": "حضرت عمران بن حصین  رضی اللہ تعالیٰ عنہ  سے روایت ہے کہ رسول اللہ  صلی اللہ علیہ وسلم  نے ان سے پوچھ"}
{"hadithnumber": "2746", "text": "حماد نے غیلان سے ، انھوں نے عبداللہ بن معبد زمانی سے اورانھوں نے حضرت ابو قتادہ  رضی اللہ تعالیٰ عنہ"}
{"hadithnumber": "2747", "text": "محمد بن جعفر نے کہا : ہمیں شعبہ نے غیلان بن جریر سے حدیث سنائی ، انھوں نے عبداللہ بن معبد زمانی سے س"}
{"hadithnumber": "2748", "text": "معاذ بن معاذ ، شبابہ اورنضر بن شمیل سب نے شعبہ سے اس سند کے ساتھ ( سابق حدیث کے مانند )  روایت کی ۔"}
{"hadithnumber": "2749", "text": "ابان عطار نے کہا : ہمیں غیلان بن جریر نے اسی سند کے ساتھ شعبہ کی حدیث کی مانند حدیث بیا  ن کی ، مگر"}
{"hadithnumber": "2750", "text": "ہمیں مہدی بن میمون نے حدیث سنائی ، انھوں نے غیلان سے باقی ماندہ سابقہ سند کے ساتھ ابو قتادہ انصاری"}
{"hadithnumber": "2751", "text": "ثا بت نے مطر ف سے انھوں نے حضرت عمرا ن حصین  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ"}
{"hadithnumber": "2752", "text": "ابو علا ء نے مطر ف سے اور انھوں نے حضرت حصین  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ نبی اکرم  صلی اللہ"}
{"hadithnumber": "2753", "text": "محمد بن جعفر نے کہا  :  ہمیں شعبہ نے مطرف بن شخیر کے بھتیجے سے حدیث سنا ئی کہا  :  میں نے مطرف کو حض"}
{"hadithnumber": "2754", "text": "نضر نے ہمیں خبر دی  ( کہا  )  ہمیں شعبہ نے خبر دی  ( کہا )  ہمیں مطرف کے بھتیجے عبد اللہ بن ہانی نے"}
{"hadithnumber": "2755", "text": "ابو بشر نے حمید بن عبد الرحمان حمیری سے اور انھوں نے حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت کی"}
{"hadithnumber": "2756", "text": "جریر نے عبد الملک بن عمیر سے انھوں نے محمد بن منتشر سے انھوں نے حمید بن عبد الرحمان سے اور انھوں نے"}
{"hadithnumber": "2757", "text": "زائد ہ نے عبد الملک بن عمیر سے اسی سند کے ساتھ نبی  صلی اللہ علیہ وسلم  سے روزوں کے ذکر میں اس  ( سا"}
{"hadithnumber": "2758", "text": "ہمیں اسما عیل بن جعفر نے حدیث سنا ئی  ،  ( کہا :   ) مجھے سعد بن سعید قیس نے عمر بن ثا بت بن حارث خز"}
{"hadithnumber": "2759", "text": "عبد اللہ بن نمیر نے باقی ماندہ سابقہ سند کے ساتھ حضرت ابو ایوب انصاری رضی اللہ تعالیٰ عنہ  سے خبر دی"}
{"hadithnumber": "2760", "text": "عبد اللہ بن مبا رک نے سعد بن سعید سے روایت کی ،  کہا :  میں نے عمر بن ثا بت سے سنا  ، کہا :  میں نے"}
{"hadithnumber": "2761", "text": "نافع نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی ، کہ آخری سات راتوں میں نبی اکرم صلی اللہ علیہ"}
{"hadithnumber": "2762", "text": "۔ عبد اللہ بن دینار نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے اور انھوں نے نبی  صلی اللہ علیہ وسلم  سے"}
{"hadithnumber": "2763", "text": "سفیان بن عیینہ نے زہری سے انھوں نے سالم سے اور انھوں نے اپنے والد  ( حضرت عبد اللہ بن عمر رضی اللہ ت"}
{"hadithnumber": "2764", "text": "یو نس نے ابن شہاب سے روایت کی  ،  ( کہا  :   )  مجھے سالم بن عبد اللہ بن عمر نے خبرد ی کہ ان کے والد"}
{"hadithnumber": "2765", "text": "عقبہ نے کہا  :  میں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے سنا ،  کہہ رہے تھے رسول اللہ  صلی اللہ ع"}
{"hadithnumber": "2766", "text": "شعبہ نے جبلہ سے روایت کی کہا :  میں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے سنا ،  وہ نبی  صلی اللہ"}
{"hadithnumber": "2767", "text": "شیبانی نے جبلہ اور محارب سے انھوں نے حضرت ابن عمر رضی اللہ تعالیٰ عنہ  سے روایت کی کہا :  رسول اللہ"}
{"hadithnumber": "2768", "text": "ہمیں ابو طاہر اور حرملہ بن یحییٰ نے حدیث بیان کی  ، دونوں نے کہا  :  ہمیں ابن وہب نے خبردی  ( کہا :"}
{"hadithnumber": "2769", "text": "ہمیں بکر نے ابن ہا د سے حدیث سنا ئی  ، انھوں نے محمد بن ابرا ہیم سے  ، انھوں نے ابو سلمہ بن عبد الرح"}
{"hadithnumber": "2770", "text": "عبد العزیز  ، یعنی دراوری نے یزید  ( بن ہاد )  سے انھوں نے محمد بن ابرا ہیم سے انھوں نے ابو سلمہ بن"}
{"hadithnumber": "2771", "text": "ہم سے عمارہ بن غزیہ انصاری نے حدیث بیان کی ،  کہا  :  میں نے محمد بن ابرا ہیم  سے سنا وہ ابو سلمہ سے"}
{"hadithnumber": "2772", "text": "ہشا م نے یحییٰ سے اور انھوں نے ابو سلمہ سے روایت کی ، کہا :  ہم نے آپس میں لیلۃالقدر کے بارے میں بات"}
{"hadithnumber": "2773", "text": "معمر اور اوزاعی دونوں نے یحییٰ بن ابی کثیر سے اسی سند کے ساتھ اس  ( سابقہ حدیث  )  کے ہم معنی روایت"}
{"hadithnumber": "2774", "text": "محمد بن مثنیٰ اورابو بکر بن خلاد نے کہا  :  ہمیں عبد الارلیٰ نے حدیث بیا ن کی  ، انھوں نے کہا :  ہمی"}
{"hadithnumber": "2775", "text": "بسر بن سعید نے حضرت عبد اللہ بن انیس  رضی اللہ تعالیٰ عنہ  سے روایت کی کہ رسول اللہ  صلی اللہ علیہ و"}
{"hadithnumber": "2776", "text": "حضرت عائشہ رضی اللہ تعالیٰ عنہا   سے روایت ہے کہا :  رسول اللہ  صلی اللہ علیہ وسلم نے فرمایا :  \"  ل"}
{"hadithnumber": "2777", "text": "سفیان بن عیینہ نے عبد ہ اور عا صم بن ابی نجود سے روایت کی ،  ان دو نوں نے حضرت زربن حبیش ؒ سے سنا ،"}
{"hadithnumber": "2778", "text": "شعبہ نے کہا  :  میں نے عبد ہ بن ابی لبابہ سے سنا ،  وہ حضرت زر بن حبیشؒ سے حدیث بیان کر رہے تھے  ۔ ا"}
{"hadithnumber": "2779", "text": "حضرت ابو ہریرہ رضی اللہ تعالیٰ عنہ  سے روایت ہے کہا  :  رسول اللہ  صلی اللہ علیہ وسلم  کے سامنے ہم ن"}
