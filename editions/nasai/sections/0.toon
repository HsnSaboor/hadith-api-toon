3906,أَخْبَرَنَا عَمْرُو بْنُ عَلِيٍّ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا يَحْيَى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا ع,Abu Ghuddah: Sahih Lighairihi; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3906,,
3907,أَخْبَرَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏عَنْ يَحْيَى بْنِ حَمْزَةَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا الْ,Abu Ghuddah: Sahih Lighairihi; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الحرث ۱۸ (۲۳۴۰)، الہبة ۳۵ (۲۶۳۲)، صحیح مسلم/البیوع ۱۷ (۱۵۳۶)، سنن ابن ماجہ/الرہون ۷ (۲۴۵۱)، (تحفة الأشراف: ۲۴۲۴)، مسند احمد (۳/۳۵۵) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3907,,
3908,أَخْبَرَنَا عِيسَى بْنُ مُحَمَّدٍ وَهُوَ أَبُو عُمَيْرِ بْنُ النَّحَّاسِ، ‏‏‏‏‏‏وَعِيسَى بْنُ يُونُس,Abu Ghuddah: Sahih Isnaad; Al-Albani: Sahih Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/البیوع ۱۷ (۱۵۳۶)، سنن ابن ماجہ/الرہون ۷ (۲۴۵۴)، (تحفة الأشراف: ۲۴۸۶)، مسند احمد (۳/۳۶۹) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3908,,
3909,أَخْبَرَنِي مُحَمَّدُ بْنُ إِسْمَاعِيل بْنِ إِبْرَاهِيمَ، ‏‏‏‏‏‏عَنْ يُونُسَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّ,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/البیوع ۱۶ (۱۵۳۶)، (تحفة الأشراف: ۲۴۸۷)، مسند احمد (۳/۳۹۵) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3909,,
3910,أَخْبَرَنَا قُتَيْبَةُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا الْمُفَضَّلُ، ‏‏‏‏‏‏عَنِ ابْنِ جُرَيْجٍ، ‏‏‏‏‏‏ع,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/البیوع ۸۳ (۲۱۸۹)، المساقاة ۱۷ (۲۳۸۰)، صحیح مسلم/البیوع ۱۶ (۱۵۳۶)، (تحفة الأشراف: ۲۴۵۲، ۲۸۰۱)، مسند احمد (۳/۳۶۰، ۳۸۱، ۳۹۱، ۳۹۲)، ویأتي عند المؤلف بأرقام: ۴۵۲۷، ۴۵۲۸، ۴۵۵۴) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3910,,
3911,أَخْبَرَنِي زِيَادُ بْنُ أَيُّوبَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ، ‏‏‏‏‏‏قَال,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/البیوع ۳۴ (۳۴۰۵)، سنن الترمذی/البیوع ۵۵ (۱۲۹۰)، (تحفة الأشراف: ۲۴۹۵)، ویأتي عند المؤلف ۴۶۳۷ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3911,,
3912,أَخْبَرَنِي أَحْمَدُ بْنُ يَحْيَى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا أَبُو نُعَيْمٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدّ,Abu Ghuddah: Sahih Isnaad; Al-Albani: Sahih Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/البیوع ۱۷ (۱۵۳۶)، (تحفة الأشراف: ۲۴۹۱)، مسند احمد (۳/۳۶۳) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3912,,
3913,أَخْبَرَنَا مُحَمَّدُ بْنُ إِدْرِيسَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا أَبُو تَوْبَةَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ ح,Abu Ghuddah: Sahih Isnaad; Al-Albani: Sahih Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: صحیح مسلم/البیوع ۱۷(۱۵۳۶)، (تحفة الأشراف: ۳۱۴۵) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3913,,
3914,أَخْبَرَنَا الثِّقَةُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَةَ، ‏‏‏‏‏‏عَنْ هِشَامِ بْنِ,Abu Ghuddah: Sahih Isnaad; Al-Albani: Sahih Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۳۱۶۴) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3914,,
3915,أَخْبَرَنَا عَمْرُو بْنُ عَلِيٍّ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَبْدُ الرَّحْمَنِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ ح,Abu Ghuddah: Shadh; Al-Albani: Daif; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۱۴۹۸۶)، مسند احمد (۲/۴۸۴) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3915,,
3916,أَخْبَرَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ الْمُبَارَكِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا يَحْيَى وَه,Abu Ghuddah: Sahih; Al-Albani: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۴۴۳۱)، مسند احمد (۳/۶۷)، سنن الدارمی/البیوع ۲۳ (۲۵۹۹) (حسن صحیح الإسناد)  (بمطابق الشیخ ناصر الدین البانی)؛,3916,,
3917,أَخْبَرَنَا زَكَرِيَّا بْنُ يَحْيَى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ يَزِيدَ بْنِ إِبْرَا,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۳۵۹۰) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3917,,
3918,أَخْبَرَنَا عَمْرُو بْنُ عَلِيٍّ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا أَبُو عَاصِمٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّث,Abu Ghuddah: Sahih; Al-Albani: Sahih,takhreej: (بمطابق الشیخ ناصر الدین البانی)؛,3918,,
3919,أَخْبَرَنَا عَمْرُو بْنُ عَلِيٍّ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ قَالَ أَبُو عَاصِمٍ، ‏‏‏‏‏‏عَنْ عُثْمَانَ بْنِ مُ,Abu Ghuddah: Sahih Isnaad; Al-Albani: Sahih Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3919,,
3920,أَخْبَرَنَا مُحَمَّدُ بْنُ الْمُثَنَّى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا يَحْيَى، ‏‏‏‏‏‏عَنْ أَبِي جَعْفَ,Abu Ghuddah: Sahih Lighairihi; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/البیوع ۳۲ (۳۳۹۹)، (تحفة الأشراف: ۳۵۵۸) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3920,,
3921,أَخْبَرَنَا قُتَيْبَةُ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا أَبُو الْأَحْوَصِ، ‏‏‏‏‏‏عَنْ طَارِقٍ، ‏‏‏‏‏‏عَن,Abu Ghuddah: Sahih; Al-Albani: Sahih Hadith; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/البیوع ۳۲ (۳۴۰۰)، سنن ابن ماجہ/الرہون ۷ (۲۴۴۹)، (تحفة الأشراف: ۳۵۵۷)، ویأتي عند المؤلف بأرقام: ۳۹۲۲-۳۹۲۴) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3921,,
3922,أَخْبَرَنَا أَحْمَدُ بْنُ سُلَيْمَانَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عُبَيْدُ اللَّهِ بْنُ مُوسَى، ‏‏‏,Abu Ghuddah: Sahih; Al-Albani: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۹۲۱ (حسن الإسناد)  (بمطابق الشیخ ناصر الدین البانی)؛,3922,,
3923,أَخْبَرَنَا مُحَمَّدُ بْنُ عَلِيٍّ وَهُوَ ابْنُ مَيْمُونٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا مُحَمَّدٌ، ‏‏,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۹۲۱ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3923,,
3924,قَالَ الْحَارِثُ بْنُ مِسْكِينٍ قِرَاءَةً عَلَيْهِ وَأَنَا أَسْمَعُ:‏‏‏‏ عَنِ ابْنِ الْقَاسِمِ، ‏‏‏‏,Abu Ghuddah: Sahih Isnaad; Al-Albani: Sahih Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ المؤلف (صحیح) (یہ روایت مرسل ہے، لیکن مرفوع روایات سے تقویت پاکر صحیح ہے)  (بمطابق الشیخ ناصر الدین البانی)؛,3924,,
3925,أَخْبَرَنَا عُبَيْدُ اللَّهِ بْنُ سَعْدِ بْنِ إِبْرَاهِيمَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنِي عَمِّي، ‏‏‏‏,Abu Ghuddah: Sahih Isnaad; Al-Albani: Sahih Isnaad; Takhreej-Group: Hasan,takhreej: تخریج دارالدعوہ: سنن ابی داود/البیوع ۳۱ (۳۳۹۱)، (تحفة الأشراف: ۳۸۶۰)، مسند احمد (۱/۱۷۸، ۱۸۲)، سنن الدارمی/البیوع ۷۵ (۲۶۶۰) (حسن) (شواہد کی بنا پر یہ حدیث حسن ہے، ورنہ اس کے راوی ’’محمد بن عکرمہ‘‘ لین الحدیث، اور ’’محمد بن عبدالرحمن بن لبیبہ‘‘ ضعیف)  (بمطابق الشیخ ناصر الدین البانی)؛,3925,,
3926,أَخْبَرَنِي زِيَادُ بْنُ أَيُّوبَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا ابْنُ عُلَيَّةَ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ أَن,Abu Ghuddah: Shadh; Al-Albani: Shadh; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الحرث ۱۸ (۲۳۴۶)، ۱۹ (۲۳۳۷)، صحیح مسلم/البیوع ۱۸ (۱۵۴۸)، سنن ابی داود/البیوع ۳۲ (۳۳۹۵)، سنن ابن ماجہ/الرہون ۱۲ (۲۴۶۵)، (تحفة الأشراف: ۳۵۵۹، ۱۵۵۷۰)، مسند احمد (۳/۴۶۵، ۴/۱۶۹)، ویأتي عند المؤلف بأرقام: ۳۹۲۷- ۳۹۲۹، ۳۹۴۰، ۳۹۴۱) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3926,,
3927,أَخْبَرَنِي زَكَرِيَّا بْنُ يَحْيَى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا مُحَمَّدُ بْنُ عُبَيْدٍ، ‏‏‏‏‏‏قَال,Abu Ghuddah: Daif; Al-Albani: Daif; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3927,,
3928,أَخْبَرَنَا إِسْمَاعِيل بْنُ مَسْعُودٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا خَالِدُ بْنُ الْحَارِثِ، ‏‏‏‏‏‏ع,Al-Albani: Sahih Isnaad Maqtu; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۹۲۶ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3928,,
3929,أَخْبَرَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ الْمُبَارَكِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا حُجَيْنُ بْ,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۹۲۶ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3929,,
3930,أَخْبَرَنِي الْمُغِيرَةُ بْنُ عَبْدِ الرَّحْمَنِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عِيسَى هُوَ ابْنُ يُون,Abu Ghuddah: Sahih; Al-Albani: Sahih; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: صحیح البخاری/الحرث ۷ (۲۳۲۷)، ۱۲ (۲۳۳۲)، ۱۹(۲۳۴۶)، الشروط ۷ (۲۷۲۲)، صحیح مسلم/البیوع ۱۹ (۱۵۴۷)، سنن ابی داود/البیوع ۳۱ (۳۳۹۲)، سنن ابن ماجہ/الرہون ۹ (۲۴۵۸) (تحفة الأشراف: ۳۵۵۳)، مسند احمد (۳/۴۶۳، ۴/۱۴۰، ۱۴۲)، ویأتي عند المؤلف بأرقام: ۳۹۳۱-۳۹۳۳) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3930,,
3931,أَخْبَرَنَا عَمْرُو بْنُ عَلِيٍّ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا يَحْيَى، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا م,Abu Ghuddah: Sahih Isnaad; Al-Albani: Sahih Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3931,,
3932,أَخْبَرَنَا مُحَمَّدُ بْنُ عَبْدِ اللَّهِ بْنِ الْمُبَارَكِ، ‏‏‏‏‏‏عَنْ وَكِيعٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَ,Abu Ghuddah: Daif Isnaad; Al-Albani: Daif Isnaad; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر أیضا حدیث رقم: ۳۹۳۰ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3932,,
3933,أَخْبَرَنَا يَحْيَى بْنُ حَبِيبِ بْنِ عَرَبِيٍّ فِي حَدِيثِهِ، ‏‏‏‏‏‏عَنْ حَمَّادِ بْنِ زَيْدٍ، ‏‏‏‏,Abu Ghuddah: Sahih Isnaad Mauquf; Al-Albani: Sahih Isnaad Mauquf,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۹۳۰ (صحیح الإسناد)  (بمطابق الشیخ ناصر الدین البانی)؛,3933,,
3934,أَخْبَرَنَا مُحَمَّدُ بْنُ يَحْيَى بْنِ عَبْدِ اللَّهِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عَبْدُ اللَّهِ ب,Abu Ghuddah: Sahih Isnaad Maqtu; Al-Albani: Sahih Isnaad Maqtu; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: سنن ابی داود/البیوع ۳۲ (۳۳۹۴)، (تحفة الأشراف: ۱۵۵۷۱)، مسند احمد (۳/۴۶۵، ۱۴۳)، ویأتي عند المؤلف بأرقام: ۳۹۳۵، ۳۹۳۶، ۳۹۳۹) (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3934,,
3935,أَخْبَرَنَا عَبْدُ الْمَلِكِ بْنُ شُعَيْبِ بْنِ اللَّيْثِ بْنِ سَعْدٍ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا أ,Abu Ghuddah: Sahih Isnaad Maqtu; Al-Albani: Sahih Isnaad Maqtu; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (صحیح)  (بمطابق الشیخ ناصر الدین البانی)؛,3935,,
3936,أَخْبَرَنِي مُحَمَّدُ بْنُ خَالِدِ بْنِ خَلِيٍّ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا بِشْرُ بْنُ شُعَيْبٍ، ‏,Abu Ghuddah: Daif Isnaad Maqtu; Al-Albani: Daif Isnaad Maqtu; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر حدیث رقم: ۳۹۳۴(صحیح) (سند میں انقطاع کی وجہ سے یہ روایت صحیح نہیں ہے، لیکن متابعات سے تقویت پاکر صحیح ہے)  (بمطابق الشیخ ناصر الدین البانی)؛,3936,,
3937,أَخْبَرَنَا أَحْمَدُ بْنُ مُحَمَّدِ بْنِ الْمُغِيرَةِ، ‏‏‏‏‏‏قَالَ:‏‏‏‏ حَدَّثَنَا عُثْمَانُ بْنُ سَ,Abu Ghuddah: Daif; Al-Albani: Daif; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: تفرد بہ النسائي (تحفة الأشراف: ۳۵۸۰) (صحیح) (یہ روایت منقطع ہے، زہری کی رافع رضی الله عنہ سے ملاقات نہیں ہے، لیکن سابقہ متابعات کی وجہ سے صحیح ہے)  (بمطابق الشیخ ناصر الدین البانی)؛,3937,,
3938,قَالَ الْحَارِثُ بْنُ مِسْكِينٍ قِرَاءَةً عَلَيْهِ وَأَنَا أَسْمَعُ:‏‏‏‏ عَنِ ابْنِ وَهْبٍ، ‏‏‏‏‏‏قَ,Abu Ghuddah: Sahih Isnaad Maqtu; Al-Albani: Sahih Isnaad Maqtu; Takhreej-Group: Sahih,takhreej: تخریج دارالدعوہ: انظر ما قبلہ (صحیح) (یہ روایت بھی منقطع ہے، لیکن سابقہ متابعت سے تقویت پاکر صحیح ہے)  (بمطابق الشیخ ناصر الدین البانی)؛,3938,,
