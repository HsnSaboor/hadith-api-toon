{"hadithnumber": "4891", "text": "عقبہ بن عامر رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جو کسی کا کوئی عیب دی"}
{"hadithnumber": "4892", "text": "عقبہ بن عامر رضی اللہ عنہ کے منشی (سکریٹری) دخین کہتے ہیں کہ  ہمارے کچھ پڑوسی شراب پیتے تھے، میں نے"}
{"hadithnumber": "4893", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  مسلمان مسلمان کا"}
{"hadithnumber": "4894", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  باہم گالی گلوچ کرنے والے"}
{"hadithnumber": "4895", "text": "عیاض بن حمار رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ نے مجھ کو وحی ک"}
{"hadithnumber": "4896", "text": "سعید بن مسیب سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم بیٹھے ہوئے تھے اور آپ کے ساتھ آپ کے صحابہ"}
{"hadithnumber": "4897", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  ایک شخص ابوبکر رضی اللہ عنہ کو گالی دے رہا تھا، پھر انہوں نے ا"}
{"hadithnumber": "4898", "text": "ابن عون کہتے ہیں  آیت کریمہ «ولمن انتصر بعد ظلمه فأولئك ما عليهم من سبيل»  اور جو لوگ اپنے مظلوم ہون"}
{"hadithnumber": "4899", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تمہارا ساتھ"}
{"hadithnumber": "4900", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم اپنے مردوں کی"}
{"hadithnumber": "4901", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:  بنی اسرا"}
{"hadithnumber": "4902", "text": "ابوبکرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ظلم و بغاوت اور قطع رحمی"}
{"hadithnumber": "4903", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  تم لوگ حسد سے بچو، اس لیے"}
{"hadithnumber": "4904", "text": "سہل بن ابی امامہ کا بیان ہے کہ  وہ اور ان کے والد عمر بن عبدالعزیز کے زمانے میں جب وہ مدینے کے گورنر"}
{"hadithnumber": "4905", "text": "ام الدرداء رضی اللہ عنہا کہتی ہیں کہ  میں نے ابو الدرداء کو کہتے ہوئے سنا کہ رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "4906", "text": "سمرہ بن جندب رضی اللہ عنہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ کی لعنت یا اللہ کا غضب یا جہ"}
{"hadithnumber": "4907", "text": "ام الدرداء رضی اللہ عنہا کہتی ہیں کہ  میں نے ابوالدرداء کو سنا وہ کہہ رہے تھے کہ میں نے رسول اللہ صل"}
{"hadithnumber": "4908", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  ایک شخص نے ہوا پر لعنت کی  ( مسلم کی روایت میں اس طرح ہے"}
{"hadithnumber": "4909", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  ان کی کوئی چیز چوری ہو گئی، تو وہ اس پر بد دعا کرنے لگی"}
