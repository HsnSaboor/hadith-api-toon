{"hadithnumber": "3275", "text": "اور عثمان بن ہیشم نے بیان کیا، کہا ہم سے عوف نے بیان کیا، ان سے محمد بن سیرین نے اور ان سے ابوہریرہ"}
{"hadithnumber": "3276", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا ہم سے لیث بن سعد نے بیان کیا، ان سے عقیل نے، ان سے ابن شہاب نے"}
{"hadithnumber": "3277", "text": "ہم سے یحییٰ بن بکیر نے بیان کیا، کہا ہم سے لیث نے بیان کیا، ان سے عقیل نے بیان کیا، ان سے ابن شہاب ن"}
{"hadithnumber": "3278", "text": "ہم سے حمیدی نے بیان کیا، کہا ہم سے سفیان بن عیینہ نے، کہا ہم سے عمرو بن دینار نے، کہا کہ  مجھے سعید"}
{"hadithnumber": "3279", "text": "ہم سے عبداللہ بن مسلمہ نے بیان کیا، ان سے امام مالک نے بیان کیا، ان سے عبداللہ بن دینار نے بیان کیا"}
{"hadithnumber": "3280", "text": "ہم سے یحییٰ بن جعفر نے بیان کیا، انہوں نے کہا ہم سے محمد بن عبداللہ انصاری نے بیان کیا، انہوں نے کہا"}
{"hadithnumber": "3281", "text": "ہم سے محمود بن غیلان نے بیان کیا، کہا ہم سے عبدالرزاق نے بیان کیا، کہا ہم کو معمر نے خبر دی، انہیں ز"}
{"hadithnumber": "3282", "text": "ہم سے عبدان نے بیان کیا، ان سے ابوحمزہ نے، ان سے اعمش نے، ان سے عدی بن ثابت نے اور ان سے سلیمان بن ص"}
{"hadithnumber": "3283", "text": "ہم سے آدم بن ابی ایاس نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے منصور نے بیان کیا، ان سے سالم ب"}
{"hadithnumber": "3284", "text": "ہم سے محمود بن غیلان نے بیان کیا، کہا ہم سے شبابہ نے بیان کیا، کہا ہم سے شعبہ نے بیان کیا، ان سے محم"}
{"hadithnumber": "3285", "text": "ہم سے محمد بن یوسف نے بیان کیا، کہا ہم سے اوزاعی نے بیان کیا، ان سے یحییٰ بن ابی کثیر نے، ان سے ابوس"}
