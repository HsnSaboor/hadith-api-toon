{"hadithnumber": "2024", "text": "اس سند سے بھی مالک سے یہی حدیث مروی ہے  اس میں ستونوں کا ذکر نہیں، البتہ اتنا اضافہ ہے  پھر آپ صلی ا"}
{"hadithnumber": "2025", "text": "عبداللہ بن عمر رضی اللہ عنہما نے نبی اکرم صلی اللہ علیہ وسلم سے قعنبی کی حدیث کے ہم مثل روایت کی ہے"}
{"hadithnumber": "2026", "text": "عبدالرحمٰن بن صفوان کہتے ہیں کہ  میں نے عمر بن خطاب رضی اللہ عنہما سے پوچھا: رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "2027", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم جب مکہ آئے تو آپ نے کعبہ"}
{"hadithnumber": "2028", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میری خواہش تھی کہ میں بیت اللہ میں داخل ہو کر اس میں نم"}
{"hadithnumber": "2029", "text": "ام المؤمنین عائشہ رضی اللہ عنہا سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم میرے پاس سے نکلے اور آپ"}
{"hadithnumber": "2030", "text": "اسلمیہ کہتی ہیں کہ  میں نے عثمان رضی اللہ عنہ سے پوچھا ۱؎: جب رسول اللہ صلی اللہ علیہ وسلم نے آپ کو"}
{"hadithnumber": "2031", "text": "شیبہ بن عثمان کہتے ہیں کہ  عمر بن خطاب رضی اللہ عنہ اس جگہ بیٹھے جہاں تم بیٹھے ہو اور کہا: میں باہر"}
{"hadithnumber": "2032", "text": "زبیر رضی اللہ عنہ کہتے ہیں کہ  جب ہم رسول اللہ صلی اللہ علیہ وسلم کے ساتھ لیّۃ ۱؎ سے لوٹے اور بیری ک"}
{"hadithnumber": "2033", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  کجاوے صرف تین ہی مسجدو"}
{"hadithnumber": "2034", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  ہم نے رسول اللہ صلی اللہ علیہ وسلم سے سوائے قرآن کے اور اس کے جو اس صح"}
{"hadithnumber": "2035", "text": "علی رضی اللہ عنہ سے اس قصے میں روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اس  ( یعنی مدینہ"}
{"hadithnumber": "2036", "text": "عدی بن زید رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مدینہ کے ہر جانب ایک ایک برید م"}
{"hadithnumber": "2037", "text": "سلیمان بن ابی عبداللہ کہتے ہیں کہ  میں نے سعد بن ابی وقاص رضی اللہ عنہ کو دیکھا کہ انہوں نے ایک شخص"}
{"hadithnumber": "2038", "text": "سعد رضی اللہ عنہ کے غلام سے روایت ہے کہ  سعد نے مدینہ کے غلاموں میں سے کچھ غلاموں کو مدینہ کے درخت ک"}
{"hadithnumber": "2039", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  رسول اللہ صل"}
{"hadithnumber": "2040", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم مسجد قباء پیدل اور سوار  ( د"}
{"hadithnumber": "2041", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مجھ پر جب بھی کوئی سلام"}
{"hadithnumber": "2042", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اپنے گھروں کو قبرستان نہ"}
{"hadithnumber": "2043", "text": "ربیعہ بن ہدیر کہتے ہیں کہ  میں نے طلحہ بن عبیداللہ رضی اللہ عنہ کو سوائے اس ایک حدیث کے کوئی اور حدی"}
{"hadithnumber": "2044", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے بطحاء میں جو ذی الحلیف"}
{"hadithnumber": "2045", "text": "مالک کہتے ہی  جب کوئی مدینہ واپس لوٹے اور معرس پہنچے تو اس کے لیے مناسب نہیں ہے کہ وہ آگے بڑھے جب تک"}
