{"hadithnumber": "1318", "arabic": "حَدَّثَنَا أَحْمَدُ بْنُ عَبْدَةَ، ‏‏‏‏‏‏أَنْبَأَنَا حَمَّادُ بْنُ زَيْدٍ، ‏‏‏‏‏‏عَنْ أَنَسِ بْنِ سِ", "grades": "{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 5, Hadith 516", "international_number": "1318", "narrator_chain": ""}
{"hadithnumber": "1319", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ رُمْحٍ، ‏‏‏‏‏‏أَنْبَأَنَا اللَّيْثُ بْنُ سَعْدٍ، ‏‏‏‏‏‏عَنْ نَافِعٍ، ‏‏‏‏‏", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 5, Hadith 517", "international_number": "1319", "narrator_chain": ""}
{"hadithnumber": "1320", "arabic": "حَدَّثَنَا سَهْلُ بْنُ أَبِي سَهْلٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ، ‏‏‏‏‏‏عَنْ الزُّهْرِيِّ، ‏‏‏‏‏‏عَنْ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Bukhari'}", "reference": "Book 5, Hadith 518", "international_number": "1320", "narrator_chain": ""}
{"hadithnumber": "1321", "arabic": "حَدَّثَنَا سُفْيَانُ بْنُ وَكِيعٍ، ‏‏‏‏‏‏حَدَّثَنَا عَثَّامُ بْنُ عَلِيٍّ، ‏‏‏‏‏‏عَنْ الْأَعْمَشِ، ‏", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 5, Hadith 519", "international_number": "1321", "narrator_chain": ""}
{"hadithnumber": "1322", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ . ح وحَدَّثَنَا مُحَمَّدُ بْنُ بَشَّارٍ،", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 5, Hadith 520", "international_number": "1322", "narrator_chain": ""}
