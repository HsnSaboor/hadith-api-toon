{"hadithnumber": "325", "text": "طارق رضی اللہ عنہ سے روایت ہے کہ  ایک آدمی جنبی ہو گیا، اس نے نماز نہیں پڑھی، تو وہ نبی اکرم صلی الل"}
{"hadithnumber": "326", "text": "عبداللہ بن عباس رضی اللہ عنہم سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کی ایک بیوی نے غسل جنابت ک"}
{"hadithnumber": "327", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  عرض کیا گیا: اللہ کے رسول! کیا ہم بضاعہ نامی کنویں سے وضو کر"}
{"hadithnumber": "328", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  میں نبی اکرم صلی اللہ علیہ وسلم کے پاس سے گزرا، آپ بئر بضاعہ"}
{"hadithnumber": "329", "text": "عبداللہ بن عمر رضی اللہ عنہم کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے پانی کے بارے میں پوچھا گیا"}
{"hadithnumber": "330", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  ایک دیہاتی مسجد میں پیشاب کرنے لگا، تو کچھ لوگ اس کی طرف بڑھے، رسول"}
{"hadithnumber": "331", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک دیہاتی کھڑا ہوا اور مسجد میں پیشاب کرنے لگا، لوگ اسے پکڑنے کے"}
{"hadithnumber": "332", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  تم میں سے کوئی شخص ٹھہرے"}
{"hadithnumber": "333", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ایک آدمی نے رسول اللہ صلی اللہ علیہ وسلم سے عرض کیا کہ اللہ کے رس"}
{"hadithnumber": "334", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم دعا کرتے تھے: «اللہم اغسل"}
{"hadithnumber": "335", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم دعا کرتے تھے: «‏اللہم اغسلني من خطاي"}
{"hadithnumber": "336", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب تم میں سے کسی کے برتن"}
