{"hadithnumber": "1217", "arabic": "حَدَّثَنَا سُفْيَانُ بْنُ وَكِيعٍ، ‏‏‏‏‏‏حَدَّثَنَا يُونُسُ بْنُ بَكِيرٍ، ‏‏‏‏‏‏حَدَّثَنَا ابْنُ إِس", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 5, Hadith 415", "international_number": "1217", "narrator_chain": ""}
{"hadithnumber": "1218", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ خَلَّادٍ، ‏‏‏‏‏‏حَدَّثَنَا سُفْيَانُ بْنُ عُيَيْنَةَ، ‏‏‏‏‏‏عَنْ مَنْصُ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 5, Hadith 416", "international_number": "1218", "narrator_chain": ""}
{"hadithnumber": "1219", "arabic": "حَدَّثَنَا هِشَامُ بْنُ عَمَّارٍ، ‏‏‏‏‏‏ وَعُثْمَانُ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏قَالَا:‏‏‏‏ حَدَّثَن", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 5, Hadith 417", "international_number": "1219", "narrator_chain": ""}
{"hadithnumber": "1220", "arabic": "حَدَّثَنَا يَعْقُوبُ بْنُ حُمَيْدِ بْنِ كَاسِبٍ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ اللَّهِ بْنُ مُوسَى التَّيْ", "grades": "{'name': 'Al-Albani', 'grade': 'Hasan Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Hasan Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Hasan'},{'name': 'Zubair Ali Zai', 'grade': 'Hasan'}", "reference": "Book 5, Hadith 418", "international_number": "1220", "narrator_chain": ""}
{"hadithnumber": "1221", "arabic": "حَدَّثَنَا مُحَمَّدُ بْنُ يَحْيَى، ‏‏‏‏‏‏حَدَّثَنَا الْهَيْثَمُ بْنُ خَارِجَةَ، ‏‏‏‏‏‏حَدَّثَنَا إِس", "grades": "{'name': 'Al-Albani', 'grade': 'Daif'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Daif'},{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 5, Hadith 419", "international_number": "1221", "narrator_chain": ""}
{"hadithnumber": "1222", "arabic": "حَدَّثَنَا عُمَرُ بْنُ شَبَّةَ بْنِ عَبِيدَةَ بْنِ زَيْدٍ، ‏‏‏‏‏‏حَدَّثَنَا عُمَرُ بْنُ عَلِيٍّ الْم", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 5, Hadith 420", "international_number": "1222", "narrator_chain": ""}
{"hadithnumber": "1223", "arabic": "حَدَّثَنَا عَلِيُّ بْنُ مُحَمَّدٍ، ‏‏‏‏‏‏حَدَّثَنَا وَكِيعٌ، ‏‏‏‏‏‏عَنْ إِبْرَاهِيمَ بْنِ طَهْمَانَ،", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 5, Hadith 421", "international_number": "1223", "narrator_chain": ""}
{"hadithnumber": "1224", "arabic": "حَدَّثَنَا عَبْدُ الْحَمِيدِ بْنُ بَيَانٍ الْوَاسِطِيُّ، ‏‏‏‏‏‏حَدَّثَنَا إِسْحَاق الْأَزْرَقُ، ‏‏‏‏", "grades": "{'name': 'Shuaib Al Arnaut', 'grade': 'Daif'},{'name': 'Zubair Ali Zai', 'grade': 'Daif'}", "reference": "Book 5, Hadith 422", "international_number": "1224", "narrator_chain": ""}
{"hadithnumber": "1225", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا أَبُو الْأَحْوَصِ، ‏‏‏‏‏‏عَنْ أَبِي إِ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 5, Hadith 423", "international_number": "1225", "narrator_chain": ""}
{"hadithnumber": "1226", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا إِسْمَاعِيل ابْنُ عُلَيَّةَ، ‏‏‏‏‏‏عَن", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 5, Hadith 424", "international_number": "1226", "narrator_chain": ""}
{"hadithnumber": "1227", "arabic": "حَدَّثَنَا أَبُو مَرْوَانَ الْعُثْمَانِيُّ، ‏‏‏‏‏‏حَدَّثَنَا عَبْدُ الْعَزِيزِ بْنُ أَبِي حَازِمٍ، ‏", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih - Bukhari And Muslim'}", "reference": "Book 5, Hadith 425", "international_number": "1227", "narrator_chain": ""}
{"hadithnumber": "1228", "arabic": "حَدَّثَنَا أَبُو بَكْرِ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ، ‏‏‏‏‏‏عَنْ حُمَي", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Shuaib Al Arnaut', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih Muslim'}", "reference": "Book 5, Hadith 426", "international_number": "1228", "narrator_chain": ""}
{"hadithnumber": "1229", "arabic": "حَدَّثَنَا عُثْمَانُ بْنُ أَبِي شَيْبَةَ، ‏‏‏‏‏‏حَدَّثَنَا يَحْيَى بْنُ آدَمَ، ‏‏‏‏‏‏حَدَّثَنَا قُطْ", "grades": "{'name': 'Al-Albani', 'grade': 'Sahih'},{'name': 'Muhammad Fouad Abd al-Baqi', 'grade': 'Sahih'},{'name': 'Zubair Ali Zai', 'grade': 'Sahih'}", "reference": "Book 5, Hadith 427", "international_number": "1229", "narrator_chain": ""}
