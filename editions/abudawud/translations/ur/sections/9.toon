{"hadithnumber": "1556", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں  جب رسول اللہ صلی اللہ علیہ وسلم کی وفات ہو گئی، آپ کے بعد ابوبکر رضی"}
{"hadithnumber": "1557", "text": "اس سند سے بھی زہری سے یہی روایت مروی ہے  اس میں ہے ابوبکر رضی اللہ عنہ نے کہا: اس  ( اسلام )  کا حق"}
{"hadithnumber": "1558", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  پانچ اونٹوں سے کم م"}
{"hadithnumber": "1559", "text": "ابو سعید خدری رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  پانچ وسق سے کم می"}
{"hadithnumber": "1560", "text": "ابراہیم کہتے ہیں  ایک وسق ساٹھ صاع کا ہوتا ہے، جس پر حجاجی مہر لگی ہوتی ہے۔"}
{"hadithnumber": "1561", "text": "حبیب مالکی کہتے ہیں کہ  ایک شخص نے عمران بن حصین رضی اللہ عنہما سے کہا: ابونجید! آپ ہم لوگوں سے بعض"}
{"hadithnumber": "1562", "text": "سمرہ بن جندب رضی اللہ عنہ سے روایت ہے  انہوں نے امابعد کہا پھر کہا: رسول اللہ صلی اللہ علیہ وسلم ہم"}
{"hadithnumber": "1563", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  ایک عورت رسول اللہ صلی اللہ علیہ وسلم کی خدمت میں حاض"}
{"hadithnumber": "1564", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں  میں سونے کے اوضاح ۱؎ پہنا کرتی تھی، میں نے عرض کیا: اللہ"}
{"hadithnumber": "1565", "text": "عبداللہ بن شداد بن الہاد رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ ام المؤمنین عائشہ رضی اللہ عنہا کے پاس گئے"}
{"hadithnumber": "1566", "text": "اس سند سے عمر بن یعلیٰ (عمر بن عبداللہ بن یعلیٰ بن مرہ) سے اسی انگوٹھی والی حدیث جیسی حدیث مروی ہے"}
{"hadithnumber": "1567", "text": "حماد کہتے ہیں  میں نے ثمامہ بن عبداللہ بن انس سے ایک کتاب لی، وہ کہتے تھے: یہ ابوبکر رضی اللہ عنہ نے"}
{"hadithnumber": "1568", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  کہ رسول اللہ صلی اللہ علیہ وسلم نے زکاۃ کی کتاب لکھی، لیک"}
{"hadithnumber": "1569", "text": "محمد بن یزید واسطی کہتے ہیں  ہمیں سفیان بن حسین نے اسی سند سے اسی مفہوم کی حدیث کی خبر دی ہے اس میں"}
{"hadithnumber": "1570", "text": "ابن شہاب زہری کہتے ہیں  یہ نقل ہے اس کتاب کی جو رسول اللہ صلی اللہ علیہ وسلم نے زکاۃ کے تعلق سے لکھی"}
{"hadithnumber": "1571", "text": "عبداللہ بن مسلمہ کہتے ہیں کہ  مالک نے کہا: عمر بن خطاب رضی اللہ عنہ کے قول  جدا جدا مال کو اکٹھا نہی"}
{"hadithnumber": "1572", "text": "علی رضی اللہ عنہ سے روایت ہے (   ( زہیر کہتے ہیں: میرا خیال ہے کہ انہوں نے نبی اکرم صلی اللہ علیہ وس"}
{"hadithnumber": "1573", "text": "علی رضی اللہ عنہ اس حدیث کے ابتدائی کچھ حصہ کے ساتھ نبی اکرم صلی اللہ علیہ وسلم سے روایت کرتے ہیں  آ"}
{"hadithnumber": "1574", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں نے گھوڑا، غلام اور لونڈی"}
{"hadithnumber": "1575", "text": "معاویہ بن حیدہ رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  چرنے والے اونٹوں میں"}
{"hadithnumber": "1576", "text": "معاذ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے جب انہیں یمن کی طرف روانہ کیا تو یہ حک"}
{"hadithnumber": "1577", "text": "اس سند سے بھی معاذ رضی اللہ عنہ سے  اسی کے مثل مرفوعاً مروی ہے۔"}
{"hadithnumber": "1578", "text": "معاذ بن جبل رضی اللہ عنہ کہتے ہیں  نبی اکرم صلی اللہ علیہ وسلم نے انہیں یمن بھیجا، پھر انہوں نے اسی"}
{"hadithnumber": "1579", "text": "سوید بن غفلہ رضی اللہ عنہ کہتے ہیں کہ  میں خود گیا، یا یوں کہتے ہیں: جو رسول اللہ صلی اللہ علیہ وسلم"}
{"hadithnumber": "1580", "text": "سوید بن غفلہ رضی اللہ عنہ کہتے ہیں کہ  ہمارے پاس نبی اکرم صلی اللہ علیہ وسلم کا محصل آیا، میں نے اس"}
{"hadithnumber": "1581", "text": "مسلم بن ثفنہ یشکری ۱؎ کہتے ہیں  نافع بن علقمہ نے میرے والد کو اپنی قوم کے کاموں پر عامل مقرر کیا اور"}
{"hadithnumber": "1582", "text": "اس طریق سے بھی زکریا بن اسحاق سے یہی حدیث اسی سند سے مروی ہے  اس میں مسلم بن شعبہ ہے اور اس میں ہے ک"}
{"hadithnumber": "1583", "text": "ابی بن کعب رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے مجھے صدقہ وصول کرنے کے لیے بھیجا"}
{"hadithnumber": "1584", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے معاذ رضی اللہ عنہ کو یمن"}
{"hadithnumber": "1585", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  زکاۃ لینے میں زیادتی"}
{"hadithnumber": "1586", "text": "بشیر بن خصاصیہ رضی اللہ عنہ سے روایت ہے   ( ابن عبید اپنی حدیث میں کہتے ہیں: ان کا نام بشیر نہیں تھا"}
{"hadithnumber": "1587", "text": "اس سند سے بھی ایوب سے اسی مفہوم کی حدیث مروی ہے  مگر اس میں ہے ہم نے کہا: اللہ کے رسول! زکاۃ لینے وا"}
{"hadithnumber": "1588", "text": "جابر بن عتیک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  قریب ہے کہ تم سے زکا"}
{"hadithnumber": "1589", "text": "جریر بن عبداللہ رضی اللہ عنہ کہتے ہیں کہ  کچھ لوگ یعنی کچھ دیہاتی رسول اللہ صلی اللہ علیہ وسلم کے پا"}
{"hadithnumber": "1590", "text": "عبداللہ بن ابی اوفی رضی اللہ عنہ کہتے ہیں کہ  میرے والد  ( ابواوفی )  اصحاب شجرہ ۱؎ میں سے تھے، جب ن"}
{"hadithnumber": "1591", "text": "ابوداؤد کہتے ہیں  میں نے اونٹوں کی عمروں کی یہ تفصیل ریاشی اور ابوحاتم وغیرہ وغیرہ سے سنا ہے، اور نض"}
{"hadithnumber": "1592", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا: نہ «جلب» صحیح"}
{"hadithnumber": "1593", "text": "محمد بن اسحاق سے  آپ صلی اللہ علیہ وسلم کے فرمان: «لا جلب ولا جنب» کی تفسیر میں مروی ہے کہ «لا جلب»"}
{"hadithnumber": "1594", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  عمر بن خطاب رضی اللہ عنہ نے اللہ کی راہ میں ایک گھوڑا"}
{"hadithnumber": "1595", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  گھوڑے اور غلام یا لونڈ"}
{"hadithnumber": "1596", "text": "اعبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کھیت کو آسما"}
{"hadithnumber": "1597", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جسے دریا یا چشم"}
{"hadithnumber": "1598", "text": "وکیع کہتے ہیں  «بعل» سے مراد وہ کھیتی ہے جو آسمان کے پانی سے  ( بارش )  اگتی ہو، ابن اسود کہتے ہیں:"}
{"hadithnumber": "1599", "text": "معاذ بن جبل رضی اللہ عنہ سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے انہیں یمن بھیجا تو فرمایا:"}
{"hadithnumber": "1600", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  بنی متعان کے ایک فرد متعان اپنے شہد کا عشر  ( دسواں حصہ"}
{"hadithnumber": "1601", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  قبیلہ شبابہ جو قبیلہ فہم کی ایک شاخ ہے، پھر راوی نے ا"}
{"hadithnumber": "1602", "text": "اس سند سے بھی عبداللہ بن عمرو رضی اللہ عنہما سے مغیرہ رضی اللہ عنہ کی روایت کے ہم معنی روایت ہے  اس"}
{"hadithnumber": "1603", "text": "عتاب بن اسید رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے انگور کا تخمینہ لگانے کا حکم"}
{"hadithnumber": "1604", "text": "ابن شہاب سے اس سند سے بھی اسی مفہوم کی حدیث مروی ہے  ابوداؤد کہتے ہیں: سعید نے عتاب سے کچھ نہیں سنا"}
{"hadithnumber": "1605", "text": "عبدالرحمٰن بن مسعود رضی اللہ عنہ کہتے ہیں کہ  سہل بن ابی حثمہ رضی اللہ عنہ ہماری مجلس میں تشریف لائے"}
{"hadithnumber": "1606", "text": "ام المؤمنین عائشہ رضی اللہ عنہا خیبر کے معاملہ کا ذکر کرتے ہوئے بیان کرتی ہیں کہ  نبی اکرم صلی اللہ"}
{"hadithnumber": "1607", "text": "سہل رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے «جعرور» اور «لون الحبیق» کو زکاۃ میں ل"}
{"hadithnumber": "1608", "text": "عوف بن مالک رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم ایک بار ہمارے پاس مسجد میں تشریف"}
{"hadithnumber": "1609", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے صدقہ فطر صائم کو لغو اور"}
{"hadithnumber": "1610", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں حکم دیا کہ صدقہ فطر"}
{"hadithnumber": "1611", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے صدقہ فطر کھجور سے ایک"}
{"hadithnumber": "1612", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے صدقہ فطر ایک صاع مقرر کیا"}
{"hadithnumber": "1613", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے صدقہ فطر جو یا کھجور می"}
{"hadithnumber": "1614", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں لوگ صدقہ فطر می"}
{"hadithnumber": "1615", "text": "نافع کہتے ہیں کہ  عبداللہ بن عمر رضی اللہ عنہما نے کہا: اس کے بعد لوگوں نے آدھے صاع گیہوں کو ایک صاع"}
{"hadithnumber": "1616", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم ہمارے درمیان باحیات تھے، ہم"}
{"hadithnumber": "1617", "text": "اس سند سے اسماعیل (اسماعیل ابن علیہ) سے یہی حدیث (نمبر: ۱۶۱۶ کے اخیر میں مذکور سند سے) مروی ہے  اس م"}
{"hadithnumber": "1618", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  میں ہمیشہ ایک ہی صاع نکالوں گا، ہم لوگ رسول اللہ صلی اللہ عل"}
{"hadithnumber": "1619", "text": "عبداللہ بن ابوصعیر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  گیہوں کا ایک ص"}
{"hadithnumber": "1620", "text": "ثعلبہ بن صعیر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم خطبہ کے لیے کھڑے ہوئے تو آپ صلی"}
{"hadithnumber": "1621", "text": "عبدالرزاق کہتے ہیں ابن جریج نے ہمیں خبر دی ہے، وہ کہتے ہیں کہ  ابن شہاب نے اپنی روایت میں عبداللہ بن"}
{"hadithnumber": "1622", "text": "حسن کہتے ہیں کہ  ابن عباس رضی اللہ عنہما نے رمضان کے اخیر میں بصرہ کے منبر پر خطبہ دیا اور کہا:  اپن"}
{"hadithnumber": "1623", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے عمر بن خطاب رضی اللہ عنہ کو زکاۃ و"}
{"hadithnumber": "1624", "text": "علی رضی اللہ عنہ کہتے ہیں کہ  عباس رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے زکاۃ جلدی  ( یعنی"}
{"hadithnumber": "1625", "text": "عطا کہتے ہیں  زیاد یا کسی اور امیر نے عمران بن حصین رضی اللہ عنہما کو زکاۃ کی وصولی کے لیے بھیجا، جب"}
{"hadithnumber": "1626", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو سوال کرے اور"}
{"hadithnumber": "1627", "text": "بنی اسد کے ایک صاحب کہتے ہیں کہ  میں اور میری بیوی بقیع غرقد میں جا کر اترے، میری بیوی نے مجھ سے کہا"}
{"hadithnumber": "1628", "text": "ابوسعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو سوال کرے حالانکہ"}
{"hadithnumber": "1629", "text": "ابوکبشہ سلولی کہتے ہیں ہم سے سہل بن حنظلیہ نے بیان کیا، وہ کہتے ہیں کہ  کہ رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "1630", "text": "زیاد بن حارث صدائی رضی اللہ عنہ کہتے ہیں  میں رسول اللہ صلی اللہ علیہ وسلم کے پاس آیا اور آپ سے بیعت"}
{"hadithnumber": "1631", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  مسکین وہ نہیں ہے جسے ایک"}
{"hadithnumber": "1632", "text": "اس سند سے بھی ابوہریرہ رضی اللہ عنہ سے اسی کے مثل مروی ہے  اس میں ہے: لیکن مسکین سوال کرنے سے بچنے و"}
{"hadithnumber": "1633", "text": "عبیداللہ بن عدی بن خیار رضی اللہ عنہما کہتے ہیں کہ  دو آدمیوں نے مجھے خبر دی ہے کہ وہ حجۃ الوداع میں"}
{"hadithnumber": "1634", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  صدقہ مالدار ک"}
{"hadithnumber": "1635", "text": "عطاء بن یسار سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کسی مالدار کے لیے صدقہ لینا حل"}
{"hadithnumber": "1636", "text": "اس سند سے بھی ابو سعید خدری رضی اللہ عنہ سے اسی مفہوم کی حدیث مرفوعاً مروی ہے  ابوداؤد کہتے ہیں: نیز"}
{"hadithnumber": "1637", "text": "ابوسعید رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کسی مالدار کے لیے صدقہ حل"}
{"hadithnumber": "1638", "text": "بشیر بن یسار کہتے ہیں کہ  انصار کے ایک آدمی نے انہیں خبر دی جس کا نام سہل بن ابی حثمہ تھا کہ نبی اکر"}
{"hadithnumber": "1639", "text": "سمرہ رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  سوال کرنا آدمی کا اپنے چہر"}
{"hadithnumber": "1640", "text": "قبیصہ بن مخارق ہلالی رضی اللہ عنہ کہتے ہیں کہ  میں ایک قرضے کا ضامن ہو گیا، چنانچہ  ( مانگنے کے لے )"}
{"hadithnumber": "1641", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  کہ ایک انصاری نبی اکرم صلی اللہ علیہ وسلم کے پاس مانگنے کے"}
{"hadithnumber": "1642", "text": "ابومسلم خولانی کہتے ہیں کہ  مجھ سے میرے پیارے اور امانت دار دوست عوف بن مالک رضی اللہ عنہ نے حدیث بی"}
{"hadithnumber": "1643", "text": "ثوبان رضی اللہ عنہ جو رسول اللہ صلی اللہ علیہ وسلم کے غلام تھے، کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "1644", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  انصار کے کچھ لوگوں نے رسول اللہ صلی اللہ علیہ وسلم سے مانگا"}
{"hadithnumber": "1645", "text": "ابن مسعود رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جسے فاقہ پہنچے اور وہ"}
{"hadithnumber": "1646", "text": "ابن الفراسی سے روایت ہے کہ  فراسی نے رسول اللہ صلی اللہ علیہ وسلم سے پوچھا! اللہ کے رسول! کیا میں سو"}
{"hadithnumber": "1647", "text": "ابن ساعدی کہتے ہیں کہ  عمر رضی اللہ عنہ نے مجھے صدقے پر عامل مقرر کیا تو جب میں اس کام سے فارغ ہوا ا"}
{"hadithnumber": "1648", "text": "عبداللہ بن عمر رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا اور آپ منبر پر"}
{"hadithnumber": "1649", "text": "مالک بن نضلہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہاتھ تین طرح کے ہیں:"}
{"hadithnumber": "1650", "text": "ابورافع رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے بنی مخزوم کے ایک شخص کو صدقہ وصو"}
{"hadithnumber": "1651", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم کا گزر کسی پڑی ہوئی کھجور پر ہوتا تو آپ"}
{"hadithnumber": "1652", "text": "انس رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے ایک کھجور  ( پڑی )  پائی تو فرمایا:"}
{"hadithnumber": "1653", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  مجھے میرے والد نے نبی اکرم صلی اللہ علیہ وسلم کے پاس اس"}
{"hadithnumber": "1654", "text": "اس سند سے بھی ابن عباس رضی اللہ عنہما سے اسی طرح کی روایت مروی ہے  البتہ اس میں  ( ابوعبیدہ نے )  یہ"}
{"hadithnumber": "1655", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے پاس گوشت لایا گیا، آپ نے پوچھا:  یہ گوش"}
{"hadithnumber": "1656", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  ایک عورت رسول اللہ صلی اللہ علیہ وسلم کے پاس آئی اور کہا: میں نے ایک"}
{"hadithnumber": "1657", "text": "عبداللہ بن مسعود رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم کے زمانے میں ہم ڈول اور دیگچ"}
{"hadithnumber": "1658", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  کہ رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس کے پاس مال ہو وہ ا"}
{"hadithnumber": "1659", "text": "اس سند سے بھی ابوہریرہ رضی اللہ عنہ نے نبی اکرم صلی اللہ علیہ وسلم سے اسی طرح روایت کی ہے  البتہ اس"}
{"hadithnumber": "1660", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے اس طرح کا قصہ سنا تو راوی"}
{"hadithnumber": "1661", "text": "عبید بن عمر کہتے ہیں کہ  ایک شخص نے پوچھا: اللہ کے رسول! اونٹوں کا حق کیا ہے؟ پھر اس نے اوپر جیسی رو"}
{"hadithnumber": "1662", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے حکم دیا کہ جو دس وسق کھجو"}
{"hadithnumber": "1663", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے ساتھ ایک سفر میں تھے،"}
{"hadithnumber": "1664", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  جب آیت کریمہ «والذين يكنزون الذهب والفضة» نازل ہوئی تو م"}
{"hadithnumber": "1665", "text": "حسین بن علی رضی اللہ عنہ کہتے ہیں کہ  حسین بن علی رضی اللہ عنہ کہتے ہیں کہ"}
{"hadithnumber": "1666", "text": "اس سند سے علی رضی اللہ عنہ سے بھی  اسی کے مثل مرفوعاً مروی ہے۔"}
{"hadithnumber": "1667", "text": "ام بجید رضی اللہ عنہا یہ ان لوگوں میں سے تھیں جنہوں نے رسول اللہ صلی اللہ علیہ وسلم سے بیعت کی تھی،"}
{"hadithnumber": "1668", "text": "اسماء رضی اللہ عنہا کہتی ہیں کہ  میرے پاس میری ماں آئیں جو قریش کے دین کی طرف مائل اور اسلام سے بیزا"}
{"hadithnumber": "1669", "text": "بہیسہ اپنے والد (عمیر) کہتی ہیں کہ  میرے والد نے نبی اکرم صلی اللہ علیہ وسلم سے  ( آپ کے پاس آنے کی"}
{"hadithnumber": "1670", "text": "عبدالرحمٰن بن ابی بکر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  کیا تم می"}
{"hadithnumber": "1671", "text": "جابر رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  اللہ کے نام پر سوائے جنت کے"}
{"hadithnumber": "1672", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جو اللہ کے نام پ"}
{"hadithnumber": "1673", "text": "جابر بن عبداللہ انصاری رضی اللہ عنہما کہتے ہیں کہ  ہم لوگ رسول اللہ صلی اللہ علیہ وسلم کے پاس تھے کہ"}
{"hadithnumber": "1674", "text": "اس سند سے بھی ابن اسحاق سے اسی مفہوم کی حدیث اسی طریق سے مروی ہے  البتہ اس میں اتنا اضافہ ہے: «خذ عن"}
{"hadithnumber": "1675", "text": "ابوسعید خدری رضی اللہ عنہ کہتے ہیں کہ  ایک شخص مسجد میں داخل ہوا تو نبی اکرم صلی اللہ علیہ وسلم نے ل"}
{"hadithnumber": "1676", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  بہترین صدقہ وہ ہے جو آدم"}
{"hadithnumber": "1677", "text": "ابوہریرہ رضی اللہ عنہ سے روایت ہے کہ  انہوں نے عرض کیا: اللہ کے رسول! کون سا صدقہ افضل ہے؟ آپ صلی ال"}
{"hadithnumber": "1678", "text": "اسلم کہتے ہیں کہ  میں نے عمر بن خطاب رضی اللہ عنہ کو کہتے سنا کہ ایک دن ہمیں رسول اللہ صلی اللہ علیہ"}
{"hadithnumber": "1679", "text": "سعد بن عبادہ انصاری خزرجی رضی اللہ عنہ سے روایت ہے کہ  انہوں نے نبی اکرم صلی اللہ علیہ وسلم کے پاس آ"}
{"hadithnumber": "1680", "text": "اس سند سے بھی سعد بن عبادہ رضی اللہ عنہ  نبی اکرم صلی اللہ علیہ وسلم سے اسی جیسی حدیث مروی ہے۔"}
{"hadithnumber": "1681", "text": "سعد بن عبادہ رضی اللہ عنہ سے روایت ہے کہ  انہوں نے عرض کیا: اللہ کے رسول! ام سعد  ( میری ماں )  انتق"}
{"hadithnumber": "1682", "text": "ابوسعید خدری رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جس مسلمان نے کسی م"}
{"hadithnumber": "1683", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  چالیس خصلتیں ہی"}
{"hadithnumber": "1684", "text": "ابوموسیٰ رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  امانت دار خازن جو حکم کے مط"}
{"hadithnumber": "1685", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  جب عورت اپنے شو"}
{"hadithnumber": "1686", "text": "سعد رضی اللہ عنہ کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم نے عورتوں سے بیعت کی تو ایک موٹی عورت"}
{"hadithnumber": "1687", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جب عورت اپنے شوہر کی کما"}
{"hadithnumber": "1688", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  ان سے کسی نے پوچھا، عورت بھی اپنے شوہر کے گھر سے صدقہ دے سکتی ہے؟"}
{"hadithnumber": "1689", "text": "انس رضی اللہ عنہ کہتے ہیں  جب «لن تنالوا البر حتى تنفقوا مما تحبون» کی آیت نازل ہوئی تو ابوطلحہ رضی"}
