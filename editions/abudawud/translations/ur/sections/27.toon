{"hadithnumber": "3669", "text": "عمر رضی اللہ عنہ کہتے ہیں کہ  شراب کی حرمت نازل ہوئی تو اس وقت شراب پانچ چیزوں: انگور، کھجور، شہد، گ"}
{"hadithnumber": "3670", "text": "عمر بن خطاب رضی اللہ عنہ کہتے ہیں  جب شراب کی حرمت نازل ہوئی تو انہوں نے دعا کی: اے اللہ! شراب کے سل"}
{"hadithnumber": "3671", "text": "علی بن ابی طالب رضی اللہ عنہ کہتے ہیں کہ  انہیں اور عبدالرحمٰن بن عوف رضی اللہ عنہ کو ایک انصاری نے"}
{"hadithnumber": "3672", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  «يا أيها الذين آمنوا لا تقربوا الصلاة وأنتم سكارى»  ( سو"}
{"hadithnumber": "3673", "text": "انس رضی اللہ عنہ کہتے ہیں کہ  شراب کی حرمت کے وقت میں ابوطلحہ رضی اللہ عنہ کے گھر لوگوں کو شراب پلا"}
{"hadithnumber": "3674", "text": "عبداللہ بن عمر رضی اللہ عنہما کو کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شراب کے پینے"}
{"hadithnumber": "3675", "text": "انس بن مالک رضی اللہ عنہ سے روایت ہے کہ  ابوطلحہ نے رسول اللہ صلی اللہ علیہ وسلم سے ان یتیموں کے سلس"}
{"hadithnumber": "3676", "text": "نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شراب انگور کی بھی"}
{"hadithnumber": "3677", "text": "نعمان بن بشیر رضی اللہ عنہما کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو کہتے ہوئے سنا:  شرا"}
{"hadithnumber": "3678", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  شراب ان دو درختوں کھجور"}
{"hadithnumber": "3679", "text": "عبداللہ بن عمر رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  ہر نشہ آور چیز ش"}
{"hadithnumber": "3680", "text": "عبداللہ بن عباس رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  ہر نشہ آور چی"}
{"hadithnumber": "3681", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  جس چیز کی زیادہ"}
{"hadithnumber": "3682", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم سے شہد کی شراب کا حکم پوچھ"}
{"hadithnumber": "3683", "text": "دیلم حمیری رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے دریافت کیا: اللہ کے رسول"}
{"hadithnumber": "3684", "text": "ابوموسیٰ رضی اللہ عنہ کہتے ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم سے شہد کی شراب کے متعلق پوچھا"}
{"hadithnumber": "3685", "text": "عبداللہ بن عمرو رضی اللہ عنہما سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے شراب، جوا، کوبہ  ( چوس"}
{"hadithnumber": "3686", "text": "ام المؤمنین ام سلمہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے ہر نشہ آور چیز اور ہر"}
{"hadithnumber": "3687", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  میں نے رسول اللہ صلی اللہ علیہ وسلم کو فرماتے ہوئے سنا:"}
{"hadithnumber": "3688", "text": "مالک بن ابی مریم کہتے ہیں کہ  عبدالرحمٰن بن غنم ہمارے پاس آئے تو ہم نے ان سے طلاء ۱؎ کا ذکر کیا، انہ"}
{"hadithnumber": "3689", "text": "حارث بن منصور کہتے ہیں  میں نے سفیان ثوری سے سنا ان سے «داذی» ۱؎ کے متعلق پوچھا گیا تو انہوں نے کہا:"}
{"hadithnumber": "3690", "text": "ابن عمر اور ابن عباس کہتے ہیں کہ  ہم گواہی دیتے ہیں کہ رسول اللہ صلی اللہ علیہ وسلم نے تمبی، سبز رنگ"}
{"hadithnumber": "3691", "text": "سعید بن جبیر کہتے ہیں  میں نے عبداللہ بن عمر رضی اللہ عنہما کو کہتے سنا کہ رسول اللہ صلی اللہ علیہ و"}
{"hadithnumber": "3692", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم کے پاس عبدالقیس کا وفد آیا اور"}
{"hadithnumber": "3693", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے وفد عبدالقیس سے فرمایا:  میں تمہی"}
{"hadithnumber": "3694", "text": "عبداللہ بن عباس رضی اللہ عنہما سے وفد عبدالقیس کے واقعے کے سلسلے میں روایت ہے کہ  وفد کے لوگوں نے پو"}
{"hadithnumber": "3695", "text": "ابوالقموص زید بن علی سے روایت ہے، کہتے ہیں  مجھ سے عبدالقیس کے اس وفد میں سے جو نبی اکرم صلی اللہ عل"}
{"hadithnumber": "3696", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  وفد عبدالقیس نے عرض کیا: اللہ کے رسول! ہم کس برتن میں پیئیں"}
{"hadithnumber": "3697", "text": "علی رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے ہمیں تونبی، سبز رنگ کے برتن، لکڑی کے برتن"}
{"hadithnumber": "3698", "text": "بریدہ رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  میں نے تمہیں تین چیزوں سے ر"}
{"hadithnumber": "3699", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  جب رسول اللہ صلی اللہ علیہ وسلم نے برتنوں کے استعمال سے"}
{"hadithnumber": "3700", "text": "عبداللہ بن عمرو رضی اللہ عنہما کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے دباء، حنتم، مزفت، اور نقیر"}
{"hadithnumber": "3701", "text": "شریک سے اسی سند سے روایت ہے کہ  آپ صلی اللہ علیہ وسلم نے فرمایا:  نشہ آور چیز سے بچو ۔"}
{"hadithnumber": "3702", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم کے لیے چمڑے کے برتن میں نبیذ ت"}
{"hadithnumber": "3703", "text": "جابر بن عبداللہ رضی اللہ عنہما سے روایت ہے کہ  رسول اللہ صلی اللہ علیہ وسلم نے کشمش اور کھجور کو ایک"}
{"hadithnumber": "3704", "text": "ابوقتادہ رضی اللہ عنہ سے روایت ہے کہ  انہوں نے کشمش اور کھجور ملا کر اور پکی اور کچی کھجور ملا کر او"}
{"hadithnumber": "3705", "text": "ایک صحابی رسول رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے کچی کھجور کو پکی ہوئی کھج"}
{"hadithnumber": "3706", "text": "کبشہ بنت ابی مریم کہتی ہیں کہ  میں نے ام المؤمنین ام سلمہ رضی اللہ عنہا سے ان چیزوں کے متعلق پوچھا ج"}
{"hadithnumber": "3707", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں  رسول اللہ صلی اللہ علیہ وسلم کے لیے کشمکش کی نبیذ بنائی جا"}
{"hadithnumber": "3708", "text": "صفیہ بنت عطیہ کہتی ہیں  میں عبدالقیس کی چند عورتوں کے ساتھ ام المؤمنین عائشہ رضی اللہ عنہا کے پاس گئ"}
{"hadithnumber": "3709", "text": "جابر بن زید اور عکرمہ سے روایت ہے کہ  وہ دونوں صرف کچی کھجور کی نبیذ کو مکروہ جانتے تھے، اور اس مذہب"}
{"hadithnumber": "3710", "text": "دیلمی رضی اللہ عنہ کہتے ہیں  ہم رسول اللہ صلی اللہ علیہ وسلم کے پاس آئے اور ہم نے عرض کیا: اللہ کے ر"}
{"hadithnumber": "3711", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں  رسول اللہ صلی اللہ علیہ وسلم کے لیے ایک ایسے چمڑے کے برتن"}
{"hadithnumber": "3712", "text": "ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  وہ نبی اکرم صلی اللہ علیہ وسلم کے لیے صبح کو نبیذ بھگ"}
{"hadithnumber": "3713", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  نبی اکرم صلی اللہ علیہ وسلم کے لیے کشمش کی نبیذ تیار کی جات"}
{"hadithnumber": "3714", "text": "عبید بن عمیر کہتے ہیں  میں نے ام المؤمنین عائشہ رضی اللہ عنہا سے سنا وہ خبر دے رہی تھیں کہ نبی اکرم"}
{"hadithnumber": "3715", "text": "ام المؤمنین عائشہ رضی اللہ عنہا کہتی ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم میٹھی چیزیں اور شہد پسند ک"}
{"hadithnumber": "3716", "text": "ابوہریرہ رضی اللہ عنہ کہتے ہیں  مجھے معلوم تھا کہ رسول اللہ صلی اللہ علیہ وسلم روزے رکھا کرتے ہیں تو"}
{"hadithnumber": "3717", "text": "انس رضی اللہ عنہ کہتے ہیں  رسول صلی اللہ علیہ وسلم نے منع فرمایا ہے کہ آدمی کھڑے ہو کر کچھ پیئے۔"}
{"hadithnumber": "3718", "text": "نزال بن سبرہ رضی اللہ عنہ کہتے ہیں کہ  علی رضی اللہ عنہ نے پانی منگوایا اور اسے کھڑے ہو کر پیا اور ک"}
{"hadithnumber": "3719", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مشکیزے میں منہ لگا کر پی"}
{"hadithnumber": "3720", "text": "ابوسعید خدری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے مشکیزوں کا منہ موڑ کر پینے سے"}
{"hadithnumber": "3721", "text": "عبداللہ انصاری رضی اللہ عنہ کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے احد کے دن ایک مشکیزہ منگوای"}
{"hadithnumber": "3722", "text": "ابو سعید خدری رضی اللہ عنہ کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم نے پیالہ کی ٹوٹی ہوئی جگہ سے پینے،"}
{"hadithnumber": "3723", "text": "ابن ابی لیلیٰ کہتے ہیں کہ  حذیفہ رضی اللہ عنہ مدائن میں تھے، آپ نے پانی طلب کیا تو ایک زمیندار چاندی"}
{"hadithnumber": "3724", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم اور آپ کے اصحاب میں سے ایک ش"}
{"hadithnumber": "3725", "text": "عبداللہ بن ابی اوفی رضی اللہ عنہ کہتے ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  قوم کے ساقی کو"}
{"hadithnumber": "3726", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں  نبی اکرم صلی اللہ علیہ وسلم کے پاس دودھ لایا گیا جس میں پانی ملای"}
{"hadithnumber": "3727", "text": "انس بن مالک رضی اللہ عنہ کہتے ہیں کہ  جب نبی اکرم صلی اللہ علیہ وسلم پیتے تو تین سانس میں پیتے اور ف"}
{"hadithnumber": "3728", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے برتن میں سانس لینے یا پھ"}
{"hadithnumber": "3729", "text": "عبداللہ بن بسر جو بنی سلیم سے تعلق رکھتے ہیں کہتے ہیں  رسول اللہ صلی اللہ علیہ وسلم میرے والد کے پاس"}
{"hadithnumber": "3730", "text": "عبداللہ بن عباس رضی اللہ عنہما کہتے ہیں  میں ام المؤمنین میمونہ رضی اللہ عنہا کے گھر میں تھا کہ اتنے"}
{"hadithnumber": "3731", "text": "جابر رضی اللہ عنہ سے روایت ہے کہ  نبی اکرم صلی اللہ علیہ وسلم نے فرمایا:  اللہ کا نام لے کر اپنے درو"}
{"hadithnumber": "3732", "text": "اس سند سے بھی جابر بن عبداللہ رضی اللہ عنہما نے  نبی اکرم صلی اللہ علیہ وسلم سے یہی حدیث روایت کی ہے"}
{"hadithnumber": "3733", "text": "جابر بن عبداللہ رضی اللہ عنہما کہتے ہیں کہ  رسول اللہ صلی اللہ علیہ وسلم نے فرمایا:  عشاء کے وقت اپن"}
{"hadithnumber": "3734", "text": "جابر رضی اللہ عنہ کہتے ہیں  ہم لوگ نبی اکرم صلی اللہ علیہ وسلم کے ساتھ تھے آپ نے پانی طلب کیا تو قوم"}
{"hadithnumber": "3735", "text": "ام المؤمنین عائشہ رضی اللہ عنہا فرماتی ہیں کہ  نبی اکرم صلی اللہ علیہ وسلم کے لیے سقیا کے گھروں سے م"}
