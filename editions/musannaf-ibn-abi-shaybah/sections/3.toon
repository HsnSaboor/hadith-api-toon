hadiths[2633]{hadithnumber,arabic,grades,reference,international_number,narrator_chain,chapter_intro}:
2393,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ عَبْدِاللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ، عَنِ ابْنِ الْحَنَفِیَّۃِ، عَنْ أَبِیہِ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مِفْتَاحُ الصَّلاَۃِ الطُّہُورُ ، وَتَحْرِیمُہَا التَّکْبِیرُ وَتَحْلِیلُہَا التَّسْلِیمُ۔(دارمی 687)",,,2393
2394,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ، قَالَ: قَالَ عَبْدُاللہِ: تَحْرِیمُ الصَّلاَۃِ التَّکْبِیرُ، وَتَحْلِیلُہَا التَّسْلِیمُ۔",,,2394
2395,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی سُفْیَانَ السَّعْدِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مِفْتَاحُ الصَّلاَۃِ الطَّہُورُ ، وَتَحْرِیمُہَا التَّکْبِیرُ ، وَتَحْلِیلُہَا التَّسْلِیمُ۔",,,2395
2396,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنِ ابْنِ کُرَیْبٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مِفْتَاحُ الصَّلاَۃِ الطَّہُورُ ، وَتَحْرِیمُہَا التَّکْبِیرُ ، وَتَحْلِیلُہَا التَّسْلِیمُ۔",,,2396
2397,"حَدَّثَنَا ابْنُ ہَارُونَ، عَنْ حُسَیْنٍ الْمُعَلِّمِ ، عَنْ بُدَیْلٍ ، عَنْ أَبِی الْجَوْزَائِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَفْتَتِحُ الصَّلاَۃَ بِالتَّکْبِیرِ ، وَکَانَ یَخْتِمُ بِالتَّسْلِیمِ۔ (مسلم 640۔ ابوداؤد 779)",,,2397
2398,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، وَوَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عُثْمَانَ الثَّقَفِیِّ ، عَنْ سَالِمٍ ، قَالَ : قَالَ أَبُو الدَّرْدَائِ : لِکُلِّ شَیْئٍ شِعَارٌ ، وَشِعَارُ الصَّلاَۃِ التَّکْبِیرُ۔",,,2398
2399,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، وَطَاوُوس قَالاَ : التَّشَہُّدُ تَمَامُ الصَّلاَۃِ ، وَالتَّسْلِیمُ إذْنُ قَضَائِہَا۔",,,2399
2400,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ وِقَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لَیْسَ بَعْدَ التَّسْلِیمِ صَلاَۃٌ۔",,,2400
2401,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : إذَا سَلَّمَ الإِمَامُ ، فَقَدِ انصرف مَنْ خَلْفَہُ۔",,,2401
2402,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ أَبِی وَائِلٍ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ الْخَطَّابِ افْتَتَحَ الصَّلاَۃَ فَکَبَّرَ ، ثُمَّ قَالَ : سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک۔",,,2402
2403,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عُمَرُ إذَا افْتَتَحَ الصَّلاَۃَ کَبَّرَ ، فَذَکَرَ مِثْلَ حَدِیثِ حُصَیْنٍ ، وَزَادَ فِیہِ : یَجْہَرُ بِہِنَّ ، قَالَ : وَقَالَ : کَانَ إبْرَاہِیمُ لاَ یَجْہَرُ بِہِنَّ۔",,,2403
2404,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا الأَعْمَش ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : سَمِعْتُ عُمَرَ یَقُولُ حِینَ افْتَتَحَ الصَّلاَۃَ : سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک۔",,,2404
2405,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إبْرَاہِیمَ ، عْن عَلْقَمَۃَ ؛ أَنَّہُ انْطَلَقَ إلَی عُمَرَ ، فَقَالُوا لَہُ : احْفَظْ لَنَا مَا اسْتَطَعْت ، فَلَمَّا قَدِمَ قَالَ : فِیمَا حَفِظْت أَنَّہُ تَوَضَّأَ مَرَّتَیْنِ وَنَثَرَ مَرَّتَیْنِ ، فَلَمَّا کَبَّرَ ، أَوْ فَلَمَّا قَامَ إلَی الصَّلاَۃِ ، قَالَ: سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک۔",,,2405
2406,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ خُصَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ إذَا افْتَتَحَ الصَّلاَۃَ ، قَالَ : سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک۔",,,2406
2407,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ حَکِیمِ بْنِ جَابِرٍ ؛ أَنَّ عُمَرَ کَانَ إذَا افْتَتَحَ الصَّلاَۃَ ، قَالَ : سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک۔",,,2407
2408,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنِ ابْنِ عَجْلاَنَ ، قَالَ : بَلَغَنِی أَنَّ أَبَا بَکْرٍ کَانَ یَقُولُ مِثْلَ ذَلِکَ۔",,,2408
2409,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی وَائِلٍ ، قَالَ : کَانَ عُمَرُ إذَا افْتَتَحَ الصَّلاَۃَ ، قَالَ : سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک ، یُسْمِعُنَا۔",,,2409
2410,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عُمَرَ ؛ أَنَّہُ قَالَ حِینَ اسْتَفْتَحَ الصَّلاَۃَ : سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک۔",,,2410
2411,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبَّادِ بْنِ عَاصِمٍ ، عَنْ نَافِعِ بْنِ جُبَیْرِ بْنِ مُطْعِمٍ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ افْتَتَحَ الصَّلاَۃَ ، قَالَ : اللَّہُ أَکْبَرُ ، ثَلاَثًا ، الْحَمْدُ لِلَّہِ کَثِیرًا ، ثَلاَثًا ، سُبْحَانَ اللہِ بُکْرَۃً وَأَصِیلاً ، ثَلاَثًا ، اللَّہُمَّ إنِّی أَعُوذُ بِکَ مِنَ الشَّیْطَانِ الرجیم ، مِنْ ہَمْزِہِ ، وَنَفْخِہِ، وَنَفْثِہِ۔ (بیہقی 35)",,,2411
2412,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَمَّارِ بْنِ عَاصِمٍ ، عَنِ ابْنِ جُبَیْرِ بْنِ مُطْعِمٍ ، عَنْ أَبِیہِ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الضُّحَی ، فَذَکَرَ مِثْلَ حَدِیثِ ابْنِ إدْرِیسَ۔",,,2412
2413,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ طَلْحَۃَ بْنِ یَزِیدَ الأَنْصَارِیِّ ، عَنْ حُذَیْفَۃَ قَالَ : قَامَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَاتَ لَیْلَۃٍ مِنْ رَمَضَانَ فِی حُجْرَۃٍ مِنْ جَرِیدِ النَّخْلِ ، ثُمَّ صَبَّ علَیْہِ دَلْوًا مِنْ مَائٍ ، ثُمَّ قَالَ : اللَّہُ أَکْبَرُ ذُو الْمَلَکُوتِ ، وَالْجَبَرُوتِ ، وَالْکِبْرِیَائِ ، وَالْعَظَمَۃِ۔\n\n(احمد 5/400۔ نسائی 1378)",,,2413
2414,"حَدَّثَنَا سُوَیْد بْنُ عَمْرٍو الْکَلْبِیُّ ، قَالَ : حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ أَبِی سَلَمَۃَ ، قَالَ : أَخْبَرَنَا الْمَاجِشُونُ عَمِّی، عَنِ الأَعْرَجِ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی رَافِعٍ ، عَنْ عَلِیٍّ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا افْتَتَحَ الصَّلاَۃَ کَبَّرَ ، ثُمَّ قَالَ : وَجَّہْت وَجْہِی لِلَّذِی فَطَرَ السَّمَاوَاتِ وَالأَرْضَ حَنِیفًا ، وَمَا أَنَا مِنَ الْمُشْرِکِینَ ، إنَّ صَلاَتِی وَنُسُکِی وَمَحْیَایَ وَمَمَاتِی لِلَّہِ رَبِّ الْعَالَمِینَ لاَ شَرِیکَ لَہُ ، وَبِذَلِکَ أُمِرْت وَأَنَا أَوَّلُ الْمُسْلِمِینَ ، اللَّہُمَّ أَنْتَ الْمَلِکُ لاَ إلَہَ إِلاَّ أَنْتَ ، أَنْتَ رَبِّی وَأَنَا عَبْدُک ، ظَلَمْت نَفْسِی ، وَاعْتَرَفْت بِذَنْبِی فَاغْفِرْ لِی ذُنُوبِی جَمِیعًا ، إِنَّہُ لاَ یَغْفِرُ الذُّنُوبَ إِلاَّ أَنْتَ ، وَاہْدِنِی لأَحْسَنِ الأَخْلاَقِ لاَ یَہْدِینی لأَحْسَنِہَا إِلاَّ أَنْتَ ، وَاصْرِفْ عَنِّی سَیِّئَہَا لاَ یَصْرِفُ عَنِّی سَیِّئَہَا إِلاَّ أَنْتَ ، لَبَّیْکَ وَسَعْدَیْکَ ، وَالْخَیْرُ کُلُّہُ فِی یَدَیْک ، أَنَا بِکَ وَإِلَیْک ، تَبَارَکْت وَتَعَالَیْت ، أَسْتَغْفِرُک وَأَتُوبُ إلَیْک۔ (مسلم 201۔ ترمذی 3421)",,,2414
2415,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : سَمِعْتُ عَمْرَو بْنَ مَیْمُونٍ ، قَالَ : صَلَّی بِنَا عُمَرُ الصُّبْحَ وَہُوَ مُسَافِرٌ بِذِی الْحُلَیْفَۃِ وَہُوَ یُرِیدُ مَکَّۃَ ، فَقَالَ : اللَّہُ أَکْبَرُ ، سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک۔",,,2415
2416,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنِی جَعْفَرُ بْنُ سُلَیْمَانَ الضُّبَعِیُّ ، عَنْ عَلِیِّ بْنِ عَلِیٍّ الرِّفَاعِیِّ ، عَنْ أَبِی الْمُتَوَکِّلِ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْتَفْتِحُ الصَّلاَۃَ یَقُولُ : سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک۔ (ابن ماجہ 804۔ نسائی 973)",,,2416
2417,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا جُوَیْبِرٌ ، عَنِ الضَّحَّاکِ : فِی قَوْلِہِ : وَسَبِّحْ بِحَمْدِ رَبِّکَ حِینَ تَقُومُ ، قَالَ : حِینَ تَقُومُ إلَی الصَّلاَۃِ تَقُولُ ہَؤُلاَئِ الْکَلِمَاتِ ، سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک۔",,,2417
2418,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنِ الْحَارِثِ بْنِ سُوَیْد، قَالَ: قَالَ ابْنُ مَسْعُودٍ : إنَّ مِنْ أَحَبِّ الْکَلاَمِ إلَی اللہِ أَنْ یَقُولَ الرَّجُلُ : سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک ، رَبِّ إنِّی ظَلَمْت نَفْسِی فَاغْفِرْ لِی ذنوبی ، إِنَّہُ لاَ یَغْفِرُ الذُّنُوبَ إِلاَّ أَنْتَ۔",,,2418
2419,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : کَانَ عُمَرُ إذَا افْتَتَحَ الصَّلاَۃَ رَفَعَ صَوْتَہُ یُسْمِعُنَا یَقُولُ : سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک۔",,,2419
2420,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : حَدَّثَنَا إسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی الْخَلِیلِ ، عَنْ عَلِیٍّ ، قَالَ : سَمِعْتُہُ حِینَ کَبَّرَ فِی الصَّلاَۃِ ، قَالَ : لاَ إلَہَ إِلاَّ أَنْتَ سُبْحَانَک ، إنِّی ظَلَمْت نَفْسِی فَاغْفِرْ لِی ذُنُوبِی ، إِنَّہُ لاَ یَغْفِرُ الذُّنُوبَ إِلاَّ أَنْتَ۔",,,2420
2421,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ وَعَلِیِّ بْنِ صَالِحٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ ابْنِ أَبِی الْخَلِیلِ ، عَنْ عَلِیٍّ ، مِثْلَہُ۔,,,2421
2422,"حَدَّثَنَا وَکِیعُ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الْہَیْثُمِ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ حِینَ یَفْتَتِحُ الصَّلاَۃَ : اللَّہُ أَکْبَرُ کَبِیرًا ، وَسُبْحَانَ اللہِ وَبِحَمْدِہِ بُکْرَۃً وَأَصِیلاً ، اللَّہُمَّ اجْعَلْہُ أَحَبَّ شَیْئٍ إلَیَّ ، وَأَخْشَی شَیْئٍ عِنْدِی۔",,,2422
2423,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنِ ابْنِ مَسْعُودٍ ، نَحْوَہُ۔,,,2423
2424,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا افْتَتَحَ الصَّلاَۃَ رَفَعَ یَدَیْہِ حَتَّی یُحَاذِیَ مَنْکِبَیْہِ۔ (ترمذی 256۔ ابوداؤد 721)",,,2424
2425,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ وَائِلِ بْنِ حُجْرٍ ، قَالَ : قَدِمْتُ الْمَدِینَۃَ ، فَقُلْتُ: لأَنْظُرَنَّ إلَی صَلاَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَکَبَّرَ وَرَفَعَ یَدَیْہِ ، حَتَّی رَأَیْت إبْہَامَیْہِ قَرِیبًا مِنْ أُذُنَیْہِ۔ (ابوداؤ9 728۔ نسائی 1191)",,,2425
2426,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ افْتَتَحَ الصَّلاَۃَ رَفَعَ یَدَیْہِ حَتَّی کَادَتَا تُحَاذِیَانِ أُذُنَیْہِ۔ (احمد 4/202۔ عبدالرزاق 3530)",,,2426
2427,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ نَصْرِ بْنِ عَاصِمٍ ، عَنْ مَالِکِ بْنِ الْحُوَیْرِثِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَفَعَ یَدَیْہِ حَتَّی یُحَاذِیَ بِہِمَا فُرُوعَ أُذُنَیْہِ۔ (مسلم 26۔ ابوداؤد 745)",,,2427
2428,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ؛ أَنَّ عُمَرَ کَانَ یَرْفَعُ یَدَیْہِ فِی الصَّلاَۃِ حَذْوَ مَنْکِبَیْہِ۔,,,2428
2429,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَرْفَعُ یَدَیْہِ حَذْوَ مَنْکِبَیْہِ۔,,,2429
2430,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ تُجَاوِزْ بِالْیَدَیْنِ الأُذُنَیْنِ فِی الصَّلاَۃِ۔",,,2430
2431,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : لاَ یُجَاوِزُ أُذُنَیْہِ بِیَدَیْہِ فِی الإِفْتِتَاحِ۔",,,2431
2432,حَدَّثَنَا عَبَّادُ بْنُ العوام ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ یَرْفَعُ یَدَیْہِ حَذْوَ مَنْکِبَیْہِ۔,,,2432
2433,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، وَعُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی مَیْسَرَۃَ ، قَالَ : کَانَ أَصْحَابُنَا إذَا افْتَتَحُوا الصَّلاَۃَ رَفَعُوا أَیْدِیَہُمْ إلَی آذَانِہِمْ۔",,,2433
2434,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ عَطَائٍ ، قَالَ : لاَ تُجَاوِزْ بِیَدَیْک أُذُنَیْک فِی دُعَائٍ ، أَوْ غَیْرِہِ۔",,,2434
2435,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ مُحَارِبٍ ، قَالَ : لَوْ رَأَیْتَ عَبْدَ اللہِ بْنَ عُمَرَ إذَا قامَ إلَی الصَّلاَۃِ ، قَالَ : ہَکَذَا ، وَرَفَعَ یَدَیْہِ حَذْوَ وَجْہِہِ۔",,,2435
2436,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَرْفَعُ یَدَیْہِ حَذْوَ مَنْکِبَیْہِ۔,,,2436
2437,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ إسْمَاعِیلَ بْنِ مُحَمَّدٍ ، عَنِ الأَعْرَجِ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یَقُولُ : مِنْکُمْ مَنْ یَقُولُ ہَکَذَا ، وَرَفَعَ سُفْیَانُ یَدَیْہِ حَتَّی تَجَاوَزَ بِہِمَا رَأْسَہُ ، وَمِنْکُمْ مَنْ یَقُولُ ہَکَذَا ، وَوَضَعَ یَدَیْہِ عِنْدَ بَطْنِہِ ، وَمِنْکُمْ مَنْ یَقُولُ ہَکَذَا ، یَعْنِی : حَذْوَ مَنْکِبَیْہِ۔",,,2437
2438,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ سَالِمًا إذَا قَامَ یَرْفَعُ یَدَیْہِ حَذْوَ مَنْکِبَیْہِ۔",,,2438
2439,حَدَّثَنَا أَحْمَدُ بْنُ بَشِیرٍ ، عَنْ مِسْعَرٍ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ سَالِمٍ ؛ أَنَّہُ کَانَ یَرْفَعُ یَدَیْہِ حَذْوَ مَنْکِبَیْہِ۔,,,2439
2440,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَرْفَعُ یَدَیْہِ إذَا افْتَتَحَ الصَّلاَۃَ ، وَإِذَا رَکَعَ وَبَعْدَمَا یَرْفَعُ ، وَلاَ یَرْفَعُ یَدَیْہِ بَیْنَ السَّجْدَتَیْنِ۔",,,2440
2441,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ وَائِلِ بْنِ حُجْرٍ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَرْفَعُ یَدَیْہِ کُلَّمَا رَکَعَ وَرَفَعَ۔",,,2441
2442,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قتادۃ ، عَنْ نَصْرِ بْنِ عَاصِمٍ ، عَنْ مَالِکِ بْنِ الْحُوَیْرِثِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُکَبِّرُ إذَا رَکَعَ ، وَإِذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ حَتَّی یُحَاذِیَ بِہِمَا فُرُوعَ أُذُنَیْہِ۔",,,2442
2443,حَدَّثَنَا ہُشَیْمٌ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَرْفَعُ یَدَیْہِ إذَا افْتَتَحَ ، وَإِذَا رَکَعَ ، وَإِذَا رَفَعَ رَأْسَہُ ، وَلاَ یُجَاوِزُ بِہِمَا أُذُنَیْہِ۔,,,2443
2444,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِثْلُ ذَلِکَ۔",,,2444
2445,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا لَیْثٌ ، عَنْ عَطَائٍ ، قَالَ : رَأَیْتُ أَبَا سَعِیدٍ الْخُدْرِیَّ ، وَابْنَ عُمَرَ، وَابْنَ عَبَّاسٍ، وَابْنَ الزُّبَیْرِ ؛ یَرْفَعُونَ أَیْدِیَہُمْ ، نَحْوٌ مِنْ حَدِیثِ الزُّہْرِیِّ۔",,,2445
2446,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو حَمْزَۃَ ، قَالَ : رَأَیْتُ ابْنَ عَبَّاسٍ یَرْفَعُ یَدَیْہِ إذَا افْتَتَحَ الصَّلاَۃَ ، وَإِذَا رَکَعَ ، وَإِذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ۔",,,2446
2447,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی صَلاَتِہِمْ کَأَنَّ أَیْدِیَہُمُ الْمَرَاوِحُ إذَا رَکَعُوا ، وَإِذَا رَفَعُوا رُؤُوسَہُمْ۔",,,2447
2448,حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّہُ کَانَ یَرْفَعُ یَدَیْہِ إذَا دَخَلَ فِی الصَّلاَۃِ ، وَإِذَا رَکَعَ ، وَإِذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ۔,,,2448
2449,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَرْفَعُ یَدَیْہِ فِی الرُّکُوعِ وَالسُّجُودِ۔ (ابن ماجہ 866۔ دارقطنی 11),,,2449
2450,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ أَشْعَثَ ، قَالَ : کَانَ الْحَسَنُ ، یَفْعَلُہُ۔",,,2450
2451,"حَدَّثَنَا مُعَاذٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یَرْفَعُ یَدَیْہِ إذَا دَخَلَ الصَّلاَۃَ ، وَإِذَا رَکَعَ ، وَإِذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ۔",,,2451
2452,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ؛ أَنَّ أَبَا قِلاَبَۃَ کَانَ یَرْفَعُ یَدَیْہِ إذَا رَکَعَ ، وَإِذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ۔,,,2452
2453,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخْبَرَنَا عَبْدُ الْحَمِیدِ بْنُ جَعْفَرٍ الأَنْصَارِیُّ ، عَنْ مُحَمَّدِ بْنِ عَمْرِو بْنِ عَطَائٍ الْقُرَشِیِّ، قَالَ : رَأَیْتُ أَبَا حُمَیْدٍ السَّاعِدِیَّ مَعَ عَشَرَۃِ رَہْطٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : أَلاَ أُحَدِّثُکُمْ عَنْ صَلاَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالُوا : ہَاتِ ، قَالَ : رَأَیْتُہ إذَا کَبَّرَ عِنْدَ فَاتِحَۃِ الصَّلاَۃِ رَفَعَ یَدَیْہِ ، وَإِذَا رَکَعَ رَفَعَ یَدَیْہِ ، وَإِذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ رَفَعَ یَدَیْہِ ، ثُمَّ یَمْکُثُ قَائِمًا حَتَّی یَقَعَ کُلُّ عَظْمٍ فِی مَوْضِعِہِ ، ثُمَّ یَہْبِطُ سَاجِدًا وَیُکَبِّرُ۔ (ترمذی 304۔ ابوداؤد 730)",,,2453
2454,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ مُحَارِبِ بْنِ دِثَارٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : رَأَیْتُہ یَرْفَعُ یَدَیْہِ فِی الرُّکُوعِ وَالسُّجُودِ ، فَقُلْتُ لَہُ : مَا ہَذَا ؟ فَقَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا قَامَ فی الرَّکْعَتَیْنِ کَبَّرَ وَرَفَعَ یَدَیْہِ۔ (بخاری 739۔ ابوداؤد 741)",,,2454
2455,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ وَعِیسَی ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا افْتَتَحَ الصَّلاَۃَ رَفَعَ یَدَیْہِ ، ثُمَّ لاَ یَرْفَعُہُمَا حَتَّی یَفْرُغَ۔\n\n(ابوداؤد 749۔ دارقطنی 22)",,,2455
2456,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ عَبْدِ الرحمن بْنِ الأَسْوَدِ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : أَلاَ أُرِیکُمْ صَلاَۃَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَلَمْ یَرْفَعْ یَدَیْہِ إِلاَّ مَرَّۃً۔\n\n(ترمذی 257۔ ابوداؤ 748)",,,2456
2457,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ اللہِ بْنِ قِطَافٍ النَّہْشَلِیِّ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا کَانَ یَرْفَعُ یَدَیْہِ إذَا افْتَتَحَ الصَّلاَۃَ ، ثُمَّ لاَ یَعُودُ۔,,,2457
2458,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یَرْفَعُ یَدَیْہِ فِی أَوَّلِ مَا یَفْْتَتِحُ ، ثُمَّ لاَ یَرْفَعُہُمَا۔,,,2458
2459,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَانَ یَرْفَعُ یَدَیْہِ فِی أَوَّلِ التَّکْبِیرَۃِ ، ثُمَّ لاَ یَرْفَعُہُمَا۔,,,2459
2460,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ وَمُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَقُولُ : إذَا کَبَّرْتَ فِی فَاتِحَۃِ الصَّلاَۃِ فَارْفَعْ یَدَیْک ، ثُمَّ لاَ تَرْفَعْہُمَا فِیمَا بَقِیَ۔",,,2460
2461,"حَدَّثَنَا وَکِیعٌ ، وَأَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ ، وَأَصْحَابُ عَلِیٍّ ، لاَ یَرْفَعُونَ أَیْدِیَہُمْ إِلاَّ فِی افْتِتَاحِ الصَّلاَۃِ ، قَالَ وَکِیعٌ : ثُمَّ لاَ یَعُودُونَ۔",,,2461
2462,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ حُصَیْنٍ وَمُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ تَرْفَعْ یَدَیْک فِی شَیْئٍ مِنَ الصَّلاَۃِ إِلاَّ فِی الافْتِتَاحَۃِ الأُولَی۔",,,2462
2463,"حَدَّثَنَا أَبُو بَکْرٍ ، عَنِ الْحَجَّاجِ ، عَنْ طَلْحَۃَ ، عَنْ خَیْثَمَۃَ وَإِبْرَاہِیمَ ، قَالَ : کَانَا لاَ یَرْفَعَانِ أَیْدِیَہُمَا إِلاَّ فِی بَدْئِ الصَّلاَۃِ۔",,,2463
2464,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ إسْمَاعِیلَ ، قَالَ : کَانَ قَیْسٌ یَرْفَعُ یَدَیْہِ أَوَّلَ مَا یَدْخُلُ فِی الصَّلاَۃِ ، ثُمَّ لاَ یَرْفَعُہُمَا۔",,,2464
2465,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : تُرْفَعُ الأَیْدِی فِی سَبْعَۃِ مَوَاطِنَ : إذَا قَامَ إلَی الصَّلاَۃِ ، وَإِذَا رَأَی الْبَیْتَ ، وَعَلَی الصَّفَا وَالْمَرْوَۃِ ، وَفِی عَرَفَاتٍ ، وَفِی جَمْعٍ ، وَعِنْدَ الْجِمَارِ۔",,,2465
2466,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہُشَیْمٍ ، عَنْ سُفْیَانَ ، عَنْ مُسْلِمٍ الْجُہَنِیِّ ، قَالَ : کَانَ ابْنُ أَبِی لَیْلَی یَرْفَعُ یَدَیْہِ أَوَّلَ شَیْئٍ إذَا کَبَّرَ۔",,,2466
2467,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، قَالَ : مَا رَأَیْت ابْنَ عُمَرَ یَرْفَعُ یَدَیْہِ إِلاَّ فِی أَوَّلِ مَا یَفْتَتِحُ۔",,,2467
2468,حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنْ جَابِرٍ ، عَنِ الأَسْوَدِ وَعَلْقَمَۃَ ؛ أَنَّہُمَا کَانَا یَرْفَعَانِ أَیْدِیَہُمَا إذَا افْتَتَحَا ، ثُمَّ لاَ یَعُودَانِ۔,,,2468
2469,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ، عَنْ حَسَنِ بْنِ عَیَّاشٍ، عَنْ عَبْدِالْمَلِکِ بْنِ أَبْجَرَ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ، عَنْ إبْرَاہِیمَ، عَنِ الأَسْوَدِ ، قَالَ : صَلَّیْت مَعَ عُمَرَ فَلَمْ یَرْفَعْ یَدَیْہِ فِی شَیْئٍ مِنْ صَلاَتِہِ إِلاَّ حِینَ افْتَتَحَ الصَّلاَۃَ ، قَالَ عَبْدُ الْمَلِکِ : وَرَأَیْت الشَّعْبِیَّ ، وَإِبْرَاہِیمَ ، وَأَبَا إِسْحَاقَ ، لاَ یَرْفَعُونَ أَیْدِیَہُمْ إِلاَّ حِینَ یَفْتَتِحُونَ الصَّلاَۃَ۔",,,2469
2470,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : افْتَتَحَ عُمَرُ الصَّلاَۃَ ، ثُمَّ کَبَّرَ ، ثُمَّ قَالَ : سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، وَتَبَارَکَ اسْمُک وَتَعَالَی جَدُّک، وَلاَ إلَہَ غَیْرُک ، أَعُوذُ بِاللَّہِ مِنَ الشَّیْطَانِ الرَّجِیمِ، الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ۔",,,2470
2471,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ سُفْیَانَ ، عَنِ الأَسْوَدِ ، قَالَ : سَمِعْتُ عُمَرَ افْتَتَحَ الصَّلاَۃَ وَکَبَّرَ ، فَقَالَ : سُبْحَانَک اللَّہُمَّ وَبِحَمْدِکَ ، تَبَارَکَ اسْمُک وَتَعَالَی جَدُّک ، وَلاَ إلَہَ غَیْرُک ، ثُمَّ یَتَعَوَّذُ۔",,,2471
2472,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ کَانَ یَتَعَوَّذُ یَقُولُ : أَعُوذُ بِاللَّہِ مِنَ الشَّیْطَانِ الرَّجِیمِ ، أَوْ أَعُوذُ بِاللَّہِ السَّمِیعِ الْعَلِیمِ مِنَ الشَّیْطَانِ الرَّجِیمِ۔",,,2472
2473,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ، عَنْ کَہْمَسٍ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمِ بْنِ یَسَارٍ، قَالَ: سَمِعَنِی أَبِی وَأَنَا أَسْتَعِیذُ بِالسَّمِیعِ الْعَلِیمِ ، فَقَالَ: مَا ہَذَا ؟ قُلْ : أَعُوذُ بِاللَّہِ مِنَ الشَّیْطَانِ الرَّجِیمِ ، إنَّ اللَّہَ ہُوَ السَّمِیعُ الْعَلِیمُ۔",,,2473
2474,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ یَتَعَوَّذُ قَبْلَ قِرَائَۃِ فَاتِحَۃِ الْکِتَابِ وَبَعْدَہَا، وَیَقُولُ فِی تَعَوُّذِہِ : أَعُوذُ بِاَللَّہِ السَّمِیعِ الْعَلِیمِ مِنْ ہَمَزَاتِ الشَّیَاطِینِ ، وَأَعُوذُ بِاللَّہِ أَنْ یَحْضُرُونِ۔",,,2474
2475,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ حُصَیْنٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ عَبَّادِ بْنِ عَاصِمٍ ، عَنْ نَافِعِ بْنِ جُبَیْرِ بْنِ مُطْعِمٍ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ افْتَتَحَ الصَّلاَۃَ ، قَالَ : اللَّہُمَّ إنِّی أَعُوذُ بِکَ مِنَ الشَّیْطَانِ الرَّجِیمِ ، مِنْ ہَمْزِہِ ، وَنَفْخِہِ ، وَنَفْثِہِ۔",,,2475
2476,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا سَبَّحَ ، أَوْ کَبَّرَ ، أَوْ ہَلَّلَ أَجْزَأَہُ فِی الإِفْتِتَاحِ، وَیَسْجُدُ سَجْدَتَیِ السَّہْوِ۔",,,2476
2477,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی لَیْلَی، عَنِ الْحَکَمِ ، قَالَ: إذَا سَبَّحَ، أَوْ ہَلَّلَ فِی افْتِتَاحِ الصَّلاَۃِ، أَجْزَأَہُ مِنَ التَّکْبِیرِ۔",,,2477
2478,"حَدَّثَنَا وَکِیعٌ ، عَنْ زِیَادِ بْنِ أَبِی مُسْلِمٍ ، قَالَ : سَمِعْتُ أَبَا الْعَالِیَۃِ سُئِلَ ، بِأَیِّ شَیْئٍ کَانَ الأَنْبِیَائُ یَسْتَفْتِحُونَ الصَّلاَۃَ ؟ قَالَ : بِالتَّوْحِیدِ ، وَالتَّسْبِیحِ ، وَالتَّہْلِیلِ۔",,,2478
2479,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ رَجُلٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : بِأَیِّ أَسْمَائِ اللہِ افْتَتَحْت الصَّلاَۃَ أَجْزَأَک۔",,,2479
2480,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا نَسِیَ تَکْبِیرَۃَ الافْتِتَاحِ اسْتَأْنَفَ۔",,,2480
2481,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَنْسَی تَکْبِیرَۃَ الافْتِتَاحِ ، قَالَ : تُجْزِئُہُ تَکْبِیرَۃُ الرُّکُوعِ۔",,,2481
2482,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّہُ قَالَ ؛ فِی الرَّجُلِ إذَا نَسِیَ أَنْ یُکَبِّر حِینَ یَفْتَتِحُ الصَّلاَۃَ ، فَإِنَّہُ یُکَبِّرُ إذَا ذَکَرَ ، فَإِن لَمْ یَذْکُرْ حَتَّی یُصَلِّیَ مَضَتْ صَلاَتُہُ ، وَتُجْزِئُ ہُ تَکْبِیرَۃُ الرُّکُوعِ۔,,,2482
2483,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنْ حَمَّادٍ ، قَالَ : إذَا نَسِیَ الإِمَامُ التَّکْبِیرَۃَ الأُولَی الَّتِی یَفْتَتِحُ بِہَا الصَّلاَۃَ أَعَادَہ ، قَالَ الْحَکَمُ : یُجْزِئُ ہُ تَکْبِیرَۃُ الرُّکُوعِ۔",,,2483
2484,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ، قَالَ : یُکَبِّرُ إذَا ذَکَرَ۔",,,2484
2485,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ رَبِّہِ بْنِ زَیْتُونَ ، قَالَ : رَأَیْتُ أُمَّ الدَّرْدَائِ تَرْفَعُ یَدَیْہَا حَذْوَ مَنْکِبَیْہَا حِینَ تَفْتَتِحُ الصَّلاَۃَ ، وَإذَا قَالَ الإِمَامُ سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، رَفَعَتْ یَدَیْہَا فِی الصَّلاَۃِ ، وَقَالَتَ : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ۔",,,2485
2486,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا شَیْخٌ لَنَا ، قَالَ : سَمِعْتُ عَطَائً ؛ سُئِلَ عَنِ الْمَرْأَۃِ کَیْفَ تَرْفَعُ یَدَیْہَا فِی الصَّلاَۃِ ؟ قَالَ : حَذْوَ ثَدْیَیْہَا۔",,,2486
2487,"حَدَّثَنَا رَوَّادُ بْنُ جَرَّاحٍ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الزُّہْرِیِّ ، قَالَ : تَرْفَعُ یَدَیْہَا حَذْوَ مَنْکِبَیْہَا۔",,,2487
2488,حَدَّثَنَا خَالِدُ بْنُ حَیَّانَ ، عَنْ عِیسَی بْنِ کَثِیرٍ ، عَنْ حَمَّادٍ ؛ أَنَّہُ کَانَ یَقُولُ فِی الْمَرْأَۃِ إذَا اسْتَفْتَحَتِ الصَّلاَۃَ ، تَرْفَعُ یَدَیْہَا إلَی ثَدْیَیْہَا۔,,,2488
2489,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : تُشِیرُ الْمَرْأَۃُ بِیَدَیْہَا بِالتَّکْبِیرِ کَالرَّجُلِ ؟ قَالَ : لاَ تَرْفَعُ بِذَلِکَ یَدَیْہَا کَالرَّجُلِ ، وَأَشَارَ فَخَفَضَ یَدَیْہِ جِدًّا ، وَجَمَعَہُمَا إلَیْہِ جِدًّا ، وَقَالَ : إنَّ لِلْمَرْأَۃِ ہَیْئَۃً لَیْسَتْ لِلرَّجُلِ ، وَإِنْ تَرَکَتْ ذَلِکَ فَلاَ حَرَجَ۔",,,2489
2490,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ : حدَّثَنِی یَحْیَی بْنُ مَیْمُونٍ ، قَالَ : حَدَّثَنِی عَاصِمٌ الأَحْوَلُ ، قَالَ : رَأَیْتُ حَفْصَۃَ بِنْتَ سِیرِینَ کَبَّرَتْ فِی الصَّلاَۃِ ، وَأَوْمَأَتْ حَذْوَ ثَدْیَیْہَا ، وَوَصَفَ یَحْیَی فَرَفَعَ یَدَیْہِ جَمیعًا۔",,,2490
2491,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ عَلْقَمَۃَ وَالأَسْوَدِ ، عَنْ عَبْدِ اللہِ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُکَبِّرُ فِی کُلِّ رَفْعٍ ، وَوَضْعٍ ، وَقِیَامٍ ، وَقُعُودٍ ، وَأَبُو بَکْرٍ ، وَعُمَرُ۔ (ترمذی 253۔ احمد 443)",,,2491
2492,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الرَّحْمَنِ الأَصَمِّ ، عَنْ أَنَسٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، وَأَبُو بَکْرٍ ، وَعُمَرُ ، وَعُثْمَانَ لاَ یُنْقِصُونَ التَّکْبِیرَ۔ (احمد 3/125۔ عبدالرزاق 250)",,,2492
2493,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ الْحَکَمِ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ؛ أَنَّ عُمَرَ کَانَ یُتِمُّ التَّکْبِیرَ۔,,,2493
2494,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ نُعَیْمِ بْنِ حَکِیمٍ ، عَنْ أَبِی مَرْیَمَ ، قَالَ : قَالَ عَمَّارٌ : لَوْ لَمْ یُدْرِکْ عَلِیٌّ مِنَ الْفَضْلِ إِلاَّ إحْیَائَ ہَاتَیْنِ التَّکْبِیرَتَیْنِ ، یَعْنِی : إذَا رَکَعَ ، وَإِذَا سَجَدَ۔",,,2494
2495,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : أَوْصَانِی قَیْسُ بْنُ عُبَادٍ أَنْ أُکَبِّرَ کُلَّمَا سَجَدْت وَکُلَّمَا رَفَعْت۔",,,2495
2496,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ وَہْبِ بْنِ کَیْسَانَ ، قَالَ : کَانَ جَابِرُ بْنُ عَبْدِ اللہِ یُعَلِّمُنَا التَّکْبِیْرَ فِی الصَّلاَۃِ ، نُکَبِّرَ إذَا خَفَضْنَا ، وَإِذَا رَفَعْنَا۔",,,2496
2497,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ؛ أَنَّ مَرْوَانَ کَانَ یَسْتَخْلِفُ أَبَا ہُرَیْرَۃَ ، فَکَانَ یُتِمُّ التَّکْبِیرَ وَکَانَ ابْنُ عُمَرَ یُتِمُّ التَّکْبِیرَ۔,,,2497
2498,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، عَنْ عَوْنِ بْنِ عَبْدِاللہِ، قَالَ: کَانَ ابْنُ مَسْعُودٍ یُتِمُّ التَّکْبِیرَ۔",,,2498
2499,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی رَزِینٍ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یُکَبِّرُ کُلَّمَا سَجَدَ ، وَکُلَّمَا رَفَعَ ، وَکُلَّمَا نَہَضَ۔,,,2499
2500,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی رَزِینٍ ، قَالَ : صَلَّیْت خَلْفَ عَلِیٍّ ، وَابْنِ مَسْعُودٍ فَکَانَا یُتِمَّانِ التَّکْبِیرَ۔",,,2500
2501,حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ کَانَ یُکَبِّرُ إذَا سَجَدَ ، وَإِذَا نَہَضَ بَیْنَ الرَّکْعَتَیْنِ۔,,,2501
2502,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنْ أَبِی عُثْمَانَ ؛ أَنَّہُ کَانَ یُکَبِّرُ إذَا سَجَدَ ، وَإِذَا نَہَضَ بَیْنَ الرَّکْعَتَیْنِ۔,,,2502
2503,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُتِمُّ التَّکْبِیرَ۔,,,2503
2504,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ؛ أَنَّ ابْنَ الزُّبَیْرِ کَانَ یُکَبِّرُ لِنَہْضَتِہِ۔,,,2504
2505,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ شَہْرِ بْنِ حَوْشَبٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ غَنْمٍ ، عَنْ أَبِی مَالِکٍ الأَشْعَرِیِّ ؛ أَنَّہُ قَالَ لِقَوْمِہِ : قُومُوا حَتَّی أُصَلِّیَ بِکُمْ صَلاَۃَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَصَفَّنَا خَلْفَہُ، فَکَبَّرَ ، ثُمَّ قَرَأَ ، ثُمَّ کَبَّرَ ، ثُمَّ رکع ، ثُمَّ رَفَعَ رَأْسَہُ فَکَبَّرَ ، فَصَنَعَ ذَلِکَ فِی صَلاَتِہِ کُلِّہَا۔\n\n(احمد 342۔ طبرانی 3411)",,,2505
2506,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ بُرَید بْنِ أَبِی مَرْیَمَ ، عْن أَبِی مُوسَی ، قَالَ : صَلَّی بِنَا عَلِیٌّ یَوْمَ الْجَمَلِ صَلاَۃً ، ذَکَّرَنَا بِہَا صَلاَۃَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَإِمَّا أَنْ نَکُونَ نَسِینَاہَا ، وَإِمَّا أَنْ نَکُونَ تَرَکْنَاہَا عَمْدًا ، یُکَبِّرُ فِی کُلِّ رَفْعٍ وَخَفْضٍ ، وَقِیَامٍ وَقُعُودٍ ، وَیُسَلِّمُ عَنْ یَمِینِہِ وَیَسَارِہِ۔\n\n(ابن ماجہ 917۔ احمد 4/392)",,,2506
2507,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، قَالَ : حَدَّثَنَا الْوَلِیدُ ، عَنْ غَیْلاَنَ بْنِ جَرِیرٍ ، عَنْ مُطَرِّفِ بْنِ عَبْدِ اللہِ بْنِ الشِّخِّیرِ ، قَالَ : صَلَّیْتُ أَنَا وَعِمْرَانُ بْنُ حُصَیْنٍ مَعَ عَلِیٍّ فَجَعَلَ یُکَبِّرُ إذَا سَجَدَ ، وَإِذَا رَفَعَ رَأْسَہُ ، فَلَمَّا انْفَتَلَ مِنْ صَلاَتِہِ ، قَالَ عِمْرَانُ : صَلَّی بِنَا ہَذَا مِثْل صَلاَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔\n\n(بخاری 826۔ مسلم 33)",,,2507
2508,"حَدَّثَنَا حَفْصٌ ، عَنْ عَبْدِ الْمَلِکِ ، قَالَ : کَانَ سَعِیدُ بْنُ جُبَیْرٍ یُکَبِّرُ کُلَّمَا رَفَعَ وَکُلَّمَا رَکَعَ ، قَالَ : فَذُکِرَ ذَلِکَ لأَبِی جَعْفَرٍ ، فَقَالَ : قَدْ عَلِمَ أَنَّہَا صَلاَۃُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ سَعِیدٌ : إنَّمَا ہُوَ شَیْئٌ یُزَیِّنُ بِہِ الرَّجُلُ صَلاَتَہُ۔",,,2508
2509,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، قَالَ : أَخْبَرَنِی عَلِیُّ بْنُ حُسَیْنٍ ، قَالَ : إِنَّہَا کَانَتْ صَلاَۃَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَذُکرَ لَہُ أَنَّ أَبَا ہُرَیْرَۃَ کَانَ یُکَبِّرُ فِی کُلِّ خَفْضٍ وَرَفْعٍ۔ (عبدالرزاق 2497)",,,2509
2510,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : رَأَیْتُ یَعْلَی یُصَلِّی عِنْدَ الْمَقَامِ یُکَبِّرُ فِی کُلِّ وَضْعٍ وَرَفْعٍ ، قَالَ : فَأَتَیْتُ ابْنَ عَبَّاسٍ فَأَخْبَرْتُہُ بِذَلِکَ ، فَقَالَ لِی ابْنُ عَبَّاسٍ : أَوَلَیْسَ تِلْکَ صَلاَۃُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ أُمَّ لِعِکْرِمَۃَ۔ (بخاری 787۔ ابن خزیمہ 577)",,,2510
2511,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّہُ کَانَ إذَا صَلَّی لَنَا کَبَّرَ کُلَّمَا رَفَعَ وَوَضَعَ ، وَإِذَا انْصَرَفَ ، قَالَ : أَنَا أَشْبَہُکُمْ صَلاَۃً بِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ۔ (بخاری 785۔ مسلم 293)",,,2511
2512,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنِ الْحَسَنِ بْنِ عِمْرَانَ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، عَنْ أَبِیہِ ، قَالَ : صَلَّیْت خَلْفَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَکَانَ لاَ یُتِمُّ التَّکْبِیرَ۔ (احمد 3/407)",,,2512
2513,حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ شُعْبَۃَ ، عَنِ الْحَسَنِ بْنِ عِمْرَانَ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَانَ لاَ یُتِمُّ التَّکْبِیرَ۔,,,2513
2514,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، قَالَ : صَلَّیْت خَلْفَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَکَانَ لاَ یُتِمُّ التَّکْبِیرَ۔",,,2514
2515,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : أَوَّلُ مَنْ نَقَصَ التَّکْبِیرَ زِیَادٌ۔",,,2515
2516,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَدِ اللہِ بْنِ عُمَرَ ، قَالَ : صَلَّیْت خَلْفَ الْقَاسِمِ وَسَالِمٍ فَکَانَا لاَ یُتِمَّانِ التَّکْبِیرَ۔",,,2516
2517,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ الْقَاسِمِ وَسَالِمٍ ؛ مِثْلَہُ۔,,,2517
2518,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : صَلَّیْت مَعَ سَعِیدِ بْنِ جُبَیْرٍ ، فَکَانَ لاَ یُتِمُّ التَّکْبِیرَ۔",,,2518
2519,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ مِسْعَرٍ ، عَنْ یَزِیدَ الْفَقِیرِ ، قَالَ : کَانَ ابْنُ عُمَرَ یَنْقُصُ التَّکْبِیرَ فِی الصَّلاَۃِ، قَالَ مِسْعَرٌ : إذَا انْحَطَّ بَعْدَ الرُّکُوعِ لِلسُّجُودِ لَمْ یُکَبِّرْ ، فَإِذَا أَرَادَ أَنْ یَسْجُدَ الثَّانِیَۃَ لَمْ یُکَبِّرْ۔",,,2519
2520,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ وَزَیْدِ بْنِ ثَابِتٍ قَالاَ : إذَا أَدْرَکَ الرَّجُلُ الْقَوْمَ رُکُوعًا ، فَإِنَّہُ یُجْزِئُہُ تَکْبِیرَۃٌ وَاحِدَۃٌ۔",,,2520
2521,حَدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ إسْمَاعِیلَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ وَزَیْدِ بْنِ ثَابِتٍ ؛ أَنَّہُمَا کَانَا یَجِیئَانِ وَالإِمَامُ رَاکِعٌ فَیُکَبِّرَانِ تَکْبِیرَۃَ الافْتِتَاحِ لِلصَّلاَۃِ وَلِلرَّکْعَۃِ۔,,,2521
2522,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : وَاحِدَۃٌ تُجْزِئُک۔",,,2522
2523,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، قَالَ : قُلْتُ لابْنِ أَبِی نَجِیحٍ : الرَّجُلُ یَنْتَہِی إلَی الْقَوْمِ وَہُمْ رُکُوعٌ فَیُکَبِّرُ تَکْبِیرَۃً وَیَرْکَعُ ؟ قَالَ : کَانَ مُجَاہِدٌ یَقُولُ : تُجْزِئہُ۔",,,2523
2524,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : تُجْزِئہُ التَّکْبِیرَۃُ ، وَإِنْ زَادَ فَہُوَ أَفْضَلُ۔",,,2524
2525,"حَدَّثَنَا غُنْدَرٌ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ : تُجْزِئہُ التَّکْبِیرَۃُ۔",,,2525
2526,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ أَبِی عُمَارَۃَ ، عَنْ بَکْرٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : کَبِّرْ تَکْبِیرَۃً۔",,,2526
2527,حَدَّثَنَا خَالِدُ بْنُ حَیَّانَ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ؛ تُجْزِئہُ تَکْبِیرَۃٌ۔,,,2527
2528,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَسْتَحِبُّ أَنْ یُکَبِّرَ تَکْبِیرَتَیْنِ ، فَإِنْ عَجَّلَ ، أَوْ نَسِیَ فَکَبَّرَ تَکْبِیرَۃً أَجْزَأَہُ۔,,,2528
2529,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، فَقَالَ : تُجْزِئُہُ تَکْبِیرَۃٌ۔",,,2529
2530,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَمْرِو بْنِ مُہَاجِرِ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : یُکَبِّرُ تَکْبِیرَتَیْنِ۔",,,2530
2531,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ رَبِیعٍ ، عَنْ إبْرَاہِیمَ الْحَنَفِیِّ ، قَالَ : سَأَلْتُ ابْنَ سِیرِینَ عَنِ الرَّجُلِ یَجِیئُ إلَی الإِمَامِ وَہُوَ رَاکِعٌ ؟ قَالَ : لِیَفْتَتِح الصَّلاَۃَ بِتَکْبِیرَۃٍ ، وَیُکَبِّرُ لِلرُّکُوعِ ، فَإِنْ لَمْ یَفْعَلْ فَلا یُجْزِئُہُ۔",,,2531
2532,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : یُکَبِّرُ تَکْبِیرَۃً لِلإِفْتِتَاحِ وَیُکَبِّرُ لِلرُّکُوعِ۔",,,2532
2533,"حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ، عَنْ عَطَائِ بْنِ السَّائِبِ، عَنِ أَبی عَبْدِالرَّحْمَنِ، قَالَ: یُکَبِّرُ تَکْبِیرَتَیْنِ۔",,,2533
2534,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إذَا جِئْت وَالإِمَامُ رَاکِعٌ فَوَضَعْتَ یَدَیْک عَلَی رُکْبَتَیْک قَبْلَ أَنْ یَرْفَعَ رَأْسَہُ ، فَقَدْ أَدْرَکْت۔",,,2534
2535,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : مَنْ أَدْرَکَ الإِمَامَ قَبْلَ أَنْ یَرْفَعَ رَأْسَہُ ، فَقَدْ أَدْرَکَ السَّجْدَۃَ۔",,,2535
2536,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : قُلْتُ : الرَّجُلُ یَنْتَہِی إلَی الْقَوْمِ وَہُمْ رُکُوعٌ وَقَدْ رَفَعَ الإِمَامُ رَأْسَہُ ؟ قَالَ : بَعْضُکُمْ أَئِمَّۃُ بَعْضٍ۔",,,2536
2537,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : إذَا دَخَلْت الْمَسْجِدَ وَالْقَوْمُ رُکُوعٌ ، فَکَبَّرْتَ ثُمَّ رَکَعْتَ قَبْلَ أَنْ یَرْفَعُوا رُؤُوسَہُمْ ، فَقَدْ أَدْرَکْت الرَّکْعَۃَ۔",,,2537
2538,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَالِمِ الْبَرَّاد ، قَالَ : أَتَیْنَا أَبَا مَسْعُودٍ فَقُلْنَا : أَرِنَا صَلاَۃَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَکَبَّرَ ثُمَّ رَکَعَ ، فَوَضَعَ یَدَیْہِ عَلَی رُکْبَتَیْہِ ، ثُمَّ قَالَ : ہَکَذَا صَلَّی بِنَا۔\n\n(ابوداؤد 859۔ احمد 4/119)",,,2538
2539,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ وَائِلِ بْنِ حُجْرٍ ، قَالَ : کُنْتُ فِیمَنْ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقُلْتُ : لأَنْظُرَنَّ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا أَرَادَ أَنْ یَرْکَعَ رَفَعَ یَدَیْہِ ، ثُمَّ رَکَعَ فَوَضَعَ یَدَیْہِ عَلَی رُکْبَتَیْہِ۔",,,2539
2540,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ عَلِیِّ بْنِ یَحْیَی بْنِ خَلاَّدٍ ، عَنْ رِفَاعَۃَ بْنِ رَافِعٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لِرَجُلٍ : إذَا اسْتَقْبَلْتَ الْقِبْلَۃَ فَکَبِّرْ وَاقْرَأْ بِمَا شِئْت ، فَإِذَا أَرَدْت أَنْ تَرْکَعَ فَاجْعَلْ رَاحَتَیْک عَلَی رُکْبَتَیْک ، وَمَکِّنْ لِرُکُوعِک۔ (ترمذی 302۔ احمد 340)",,,2540
2541,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَارِثَۃَ ، عَنْ عَمْرَۃَ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ رَکَعَ فَوَضَعَ یَدَیْہِ عَلَی رُکْبَتَیْہِ۔ (ابن ماجہ 874),,,2541
2542,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ، قَالَ : رَأَیْتُ عُمَرَ رَاکِعًا وَقَدْ وَضَعَ یَدَیْہِ عَلَی رُکْبَتَیْہِ۔",,,2542
2543,حَدَّثَنَا ابْنُ فُضَیْلٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن أَبِی مَعْمَرٍ ، عَنْ عُمَرَ ؛ أَنَّہُ کَانَ إذَا رَکَعَ وَضَعَ یَدَیْہِ عَلَی رُکْبَتَیْہِ۔,,,2543
2544,"حَدَّثَنَا عَبْدَۃُ ، وَوَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ مُصْعَبِ بْنِ سعْدٍ ، قَالَ : رَکَعْت إلَی جَنْبِ أَبِی ، فَجَعَلْتُ یَدَیَّ بَیْنَ رُکْبَتَیَّ ، فَضَرَبَ سَعْدٌ یَدِی ، ثُمَّ قَالَ : کُنَّا نَفْعَلُ ہَذَا ، ثُمَّ أُمِرْنَا بِالرُّکَبِ۔\n\n(بخاری 790۔ مسلم 31)",,,2544
2545,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ خَیْثَمَۃَ ، قَالَ : کَانَ ابْنُ عُمَرَ إذَا رَکَعَ وَضَعَ یَدَیْہِ عَلَی رُکْبَتَیْہِ۔",,,2545
2546,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ، قَالَ : قَامَ فِینَا رَجُلٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنَ الأَنْصَارِ یَوْمَ الْقَادِسِیَّۃِ ، فَقَالَ : إذَا رَکَعَ فَلْیَضَعْ یَدَیْہِ عَلَی رُکْبَتَیْہِ ، وَلْیُمَکِّنْ حَتَّی یَعْلُوَ عَجْبُ ذَنَبِہِ۔",,,2546
2547,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ کَعْبٍ ، قَالَ : إذَا رَکَعْتَ فَانْصِبْ وَجْہَک للقِبلَۃ، وَضَعْ یَدَیْک عَلَی رُکْبَتَیْک ، وَلاَ تُدَبِّحْ کَمَا یُدَبِّحُ الْحِمَارُ۔",,,2547
2548,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُبَیْدِ اللہِ ، عَنْ أَبِی جَعْفَرٍ ، عَنْ عَلِیٍّ ، قَالَ : إذَا رَکَعْت فَضَعْ کَفَّیْک عَلَی رُکْبَتَیْک ، وَابْسُطْ ظَہْرَک ، وَلاَ تُقَنِّعْ رَأْسَک ، وَلاَ تُصَوِّبْہُ ، وَلاَ تَمْتَدَّ ، وَلاَ تَقْبِضْ۔",,,2548
2549,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : کَانَ أَبِی إذَا رَکَعَ وَضَعَ یَدَیْہِ عَلَی رُکْبَتَیْہِ۔",,,2549
2550,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : رَأَیْتُ إبْرَاہِیمَ یَضَعُ یَدَیْہِ عَلَی رُکْبَتَیْہِ۔",,,2550
2551,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ نَافِعٍ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ إذَا رَکَعَ وَضَعَ یَدَیْہِ عَلَی رُکْبَتَیْہِ۔",,,2551
2552,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : قَالَ عُمَرُ : سُنَّتْ لَکُمُ الرُّکَبُ ، فَأَمْسِکُوا بِالرُّکَبِ۔ (نسائی 623)",,,2552
2553,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا فِطْرٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : إذَا رَکَعْتَ، فَإِنْ شِئْتَ قُلْتَ ہَکَذَا ، وَإِنْ شِئْتَ وَضَعْت یَدَیْکَ عَلَی رُکْبَتَیْکَ ، وَإِنْ شِئْتَ قُلْتَ ہَکَذَا، یَعْنِی: طَبَّقْتَ۔",,,2553
2554,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : دَخَلَ الأَسْوَدُ وَعَلْقَمَۃُ عَلَی عَبْدِ اللہِ ، فَقَالَ عَبْدُ اللہِ : صَلَّی ہَؤُلاَئِ بَعْدُ ؟ قَالاَ : لاَ ، قَالَ : فَقُومُوا فَصَلُّوا ، وَلَمْ یَأْمُرْ بِأَذَانٍ ، وَلاَ إقَامَۃٍ ، وَتَقَدَّمَ ہو فَصَلَّی بِنَا ، فَذَہَبْنَا نَتَأَخَّرُ فَأَخَذَ بِأَیْدِینَا فَأَقَامَنَا مَعَہُ ، فَلَمَّا رَکَعْنَا وَضَعَ الأَسْوَدُ یَدَیْہِ عَلَی رُکْبَتَیْہِ ، فَنَظَرَ عَبْدُ اللہِ فَأَبْصَرَہُ فَضَرَبَ یَدَہُ ، فَنَظَرَ الأَسْوَدُ فَإِذَا یَدَا عَبْدِ اللہِ بَیْنَ رُکْبَتَیْہِ وَقَدْ خَالَفَ بین أَصَابِعِہِ ، فَلَمَّا قَضَی الصَّلاَۃَ ، قَالَ : إذَا کُنْتُمْ ثَلاَثَۃً فَلْیَؤُمَّکُمْ أَحَدُکُمْ ، وَإِذَا رَکَعْتَ فَأَفْرِشْ ذِرَاعَیْک فَخِذَیْک ، فَکَأَنِّی أَنْظُرُ إلَی اخْتِلاَفِ أَصَابِعِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ رَاکِعٌ ، ثُمَّ قَالَ : إِنَّہُ سَیَکُونُ أُمَرَائُ یُمِیتُونَ الصَّلاَۃَ شَرَقَ الْمَوْتَی ، وَأَنَّہَا صَلاَۃُ مَنْ ہُوَ شَرٌّ مِنْ حِمَارٍ ، وَصَلاَۃُ مَنْ لاَ یَجِدُ بُدًّا ، فَمَنْ أَدْرَکَ ذَلِکَ مِنْکُمْ فَلْیُصَلِّ الصَّلاَۃَ لِمِیقَاتِہَا ، وَلْتَکُنْ صَلاَتُکُمْ مَعَہُمْ سُبْحَۃً ، فَقُلْتُ لإِبْرَاہِیمَ : کَانَ عَلْقَمَۃُ وَالأَسْوَدُ یَفْعَلاَنِ ذَلِکَ ؟ قَالَ : نَعَمْ ، قُلْتُ لإِبْرَاہِیمَ : تَفْعَلُ أَنْتَ ذَلِکَ ؟ قَالَ : نَعَمْ ، قُلْتُ : إنَّ النَّاسَ یَضَعُونَ أَیْدِیَہُمْ عَلَی رُکَبِہِمْ ؟ فَقَالَ إبْرَاہِیمُ : سَمِعْت أَبَا مَعْمَرٍ یَقُولُ : رَأَیْت عُمَرَ یَضَعُ یَدَیْہِ عَلَی رُکْبَتَیْہِ۔",,,2554
2555,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : عَلَّمَنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الصَّلاَۃَ فَکَبَّرَ وَرَفَعَ یَدَیْہِ ، ثُمَّ رَکَعَ فَطَبَّقَ یَدَیْہِ بَیْنَ رُکْبَتَیْہِ۔ \n\n(نسائی 620۔ ابن خزیمہ 595)",,,2555
2556,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : أَکَانَ عَبْدُ اللہِ یُطَبِّقُ بِإِحْدَی یَدَیْہِ عَلَی الأُخْرَی فَیجعلہما بَیْنَ رِجْلَیْہِ وَیُفْرِشُ ذِرَاعَیْہِ فَخْذَیْہِ إذَا رَکَعَ ؟ قَالَ : نَعَمْ ، قُلْتُ : أَلاَ أَفْعَلُ ذَلِکَ ؟ قَالَ : إنَّ عُمَرَ کَانَ یُطَبِّقُ بِکَفَّیْہِ عَلَی رُکْبَتَیْہِ۔",,,2556
2557,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُثْمَانَ بْنُ أَبِی ہِنْدٍ ، قَالَ : رَأَیْتُ أَبَا عُبَیْدَۃَ إذَا رَکَعَ طَبَّقَ۔",,,2557
2558,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ عَوْنٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَعَلَہُ ، یَعْنِی : یُطَبِّقُ یَدَیْہِ فِی الرُّکُوعِ ۔ قَالَ ابْنُ عَوْنٍ : فَذَکَرْتُہُ لابْنِ سِیرِینَ ، قَالَ : لَعَلَّہُ فَعَلَہُ مَرَّۃً۔",,,2558
2559,"حَدَّثَنَا ہُشَیْمٌ ، أَخْبَرَنَا ہِشَام ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، رضی اللہ عنہما ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ ، قَالَ : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ مِلْئَ السَّمَاوَاتِ وَمِلْئَ الأَرْضِ وَمِلْئَ مَا شِئْت مِنْ شَیْئٍ بَعْدُ ، أَہْلَ الثَّنَائِ وَالْمَجْدِ ، لاَ مَانِعَ لِمَا أَعْطَیْت ، وَلاَ مُعْطِیَ لِمَا مَنَعْت ، وَلاَ یَنْفَعُ ذَا الْجَدِّ مِنْک الْجَدُّ۔ (مسلم 347۔ نسائی 654)",,,2559
2560,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عُبَیْدِ بْنِ الْحَسَنِ ، عَنِ ابْنِ أَبِی أَوْفَی ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ ، قَالَ : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ مِلْئَ السَّمَاوَاتِ ، وَمِلْئَ الأَرْضِ ، وَمِلْئَ مَا شِئْتَ مِنْ شَیْئٍ بَعْدُ۔ (مسلم 202۔ ابوداؤد 842)",,,2560
2561,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ أَبِی زِیَادٍ ، قَالَ : حَدَّثَنَا أَبُو جُحَیْفَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یَقُولُ، إذَا رَفَعَ الإِمَامُ رَأْسَہُ مِنَ الرُّکُوعِ ، اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ ، مِلْئَ السَّمَاوَاتِ ، وَمِلْئَ الأَرْضِ ، وَمِلْئَ مَا شِئْت مِنْ شَیْئٍ بَعْدُ۔",,,2561
2562,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، قَالَ : کَانَ عَلِیٌّ إذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ ، قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ ، بِحَوْلِکَ وَقُوَّتِکَ أَقُومُ وَأَقْعُدُ۔",,,2562
2563,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ أَبِی عُبَیْدَۃَ بْنِ عَبْدِ اللہِ ، قَالَ : حَدَّثَنَا قَزَعَۃُ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ ، قَالَ : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ مِلْئَ السَّمَائِ وَمِلْئَ الأَرْضِ ، وَمِلْئَ مَا شِئْت مِنْ شَیْئٍ بَعْدُ ، لاَ مَانِعَ لِمَا أَعْطَیْت ، وَلاَ مُعْطِیَ لِمَا مَنَعْت ، وَلاَ یَنْفَعُ ذَا الْجَدِّ مِنْک الْجَدُّ۔ (ابوداؤد 843۔ نسائی 655)",,,2563
2564,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، عَنْ شَرِیکٍ ، عَنْ أَبِی عُمَرَ ، عَنْ أَبِی جُحَیْفَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَامَ فِی الصَّلاَۃِ ، فَلَمَّا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ ، قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ مِلْئَ السَّمَائِ وَمِلْئَ الأَرْضِ ، وَمِلْئَ مَا شِئْت مِنْ شَیْئٍ بَعْدُ ، لاَ مَانِعَ لِمَا أَعْطَیْت ، وَلاَ مُعْطِیَ لِمَا مَنَعْت ، وَلاَ یَنْفَعُ ذَا الْجَدِّ مِنْک الْجَدُّ ، یَمُدُّ بِہَا صَوْتَہُ۔ (ابن ماجہ 879۔ ابو یعلی 882)",,,2564
2565,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّہُ کَانَ إذَا رَفَعَ رَأْسَہُ ، قَالَ : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ۔",,,2565
2566,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ بُرْدٍ ؛ أَنَّ مَکْحُولاً کَانَ یَقُولُ إذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ مِلْئَ السَّمَائِ وَمِلْئَ الأَرْضِ ، وَمِلْئَ مَا شِئْت مِنْ شَیْئٍ بَعْدُ ، أَہْلَ الثَّنَائِ وَالْحمدِ ، وَخَیْرُ مَا قَالَ الْعَبْدُ ، وَکُلُّنَا لَکَ عَبْدٌ ، لاَ مَانِعَ لِمَا أَعْطَیْت ، وَلاَ مُعْطِیَ لِمَا مَنَعْت ، وَلاَ یَنْفَعُ ذَا الْجَدِّ مِنْک الْجَدُّ۔",,,2566
2567,"حَدَّثَنَا سُوَیْد بْنُ عَمْرٍو الْکَلْبِیُّ ، قَالَ : حدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ أَبِی سَلَمَۃَ ، قَالَ : أَخْبَرَنَا الْمَاجِشُونُ عَمِّی، عَنِ الأَعْرَجِ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی رَافِعٍ ، عَنْ عَلِیٍّ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ ، قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، اللَّہُمَّ رَبَّنَا وَلَک الْحَمْدُ ، مِلْئَ السَّمَاوَاتِ وَمِلْئَ الأَرْضِ ، وَمِلْئَ مَا شِئْت مِنْ شَیْئٍ بَعْدُ۔",,,2567
2568,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنِ الْمُسْتَوْرِدِ بْنِ الأَحْنَفِ ، عَنْ صِلَۃَ بْنِ زُفَرَ ، عَنْ حُذَیْفَۃَ ، قَالَ : صَلَّیْت مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَکَانَ رُکُوعُہُ نَحْوًا مِنْ قِیَامِہِ ، ثُمَّ قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، ثُمَّ قَامَ طَوِیلاً۔ (ترمذی 262۔ ابوداؤد 867)",,,2568
2569,"حَدَّثَنَا یَعْلَی ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : کَانَ عُمَرُ إذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ ، قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، قَبْلَ أَنْ یُقِیمَ ظَہْرَہُ۔",,,2569
2570,"حَدَّثَنَا مُعْتَمِرٌ، عَنْ أَیُّوبَ، عَنِ الأَعْرَجِ، قَالَ: سَمِعْتُ أَبَا ہُرَیْرَۃَ یَرْفَعُ صَوْتَہُ بِـ : اللَّہُمَّ رَبَّنَا وَلَک الْحَمْدُ۔",,,2570
2571,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، عَنْ صِلَۃَ ، عَنْ حُذَیْفَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ فِی رُکُوعِہِ : سُبْحَانَ رَبِّی الْعَظِیمِ ، وَفِی سُجُودِہِ : سُبْحَانَ رَبِّی ألأَعْلَی ، قُلْتُ أَنَا لحفص : وَبِحَمْدِہِ ؟ قَالَ : نَعَمْ إِنْ شَائَ اللَّہُ ثَلاَثًا۔ (ابن خزیمۃ 668۔ دار قطنی 341)",,,2571
2572,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنِ الْمُسْتَوْرِدِ بْنِ الأَحْنَفِ ، عَنْ صِلَۃَ بْنِ زُفَرَ ، عَنْ حُذَیْفَۃَ ، قَالَ : صَلَّیْت مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا رَکَعَ جَعَلَ یَقُولُ : سُبْحَانَ رَبِّی الْعَظِیمِ ، ثُمَّ سَجَدَ ، فَقَالَ : سُبْحَانَ رَبِّی الأَعْلَی۔",,,2572
2573,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ سُلَیْمَانَ بْنِ سُحَیْمٍ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ اللہِ بْنِ مَعْبَدٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَمَّا الرُّکُوعُ فَعَظِّمُوا فِیہِ الرَّبَّ ، وَأَمَّا السُّجُودُ فَاجْتَہِدُوا فِی الدُّعَائِ، فَقَمِنٌ أَنْ یُسْتَجَابَ لَکُمْ۔ (مسلم 208۔ ابوداؤد 872)",,,2573
2574,"حَدَّثَنَا ابْنُ مُسْہِرٍ ، وَابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنِ النُّعْمَانِ بْنِ سَعْدٍ ، عَنْ عَلِیٍّ ، قَالَ: قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : نُہِیت أَنْ أَقْرَأَ الْقُرْآنَ فِی الرُّکُوعِ وَالسُّجُودِ ، فَإِذَا رَکَعْتُمْ فَعَظِّمُوا اللَّہَ ، وَإِذَا سَجَدْتُمْ فَاجْتَہِدُوا فِی الْمَسْأَلَۃِ ، فَقَمِنٌ أَنْ یُسْتَجَابَ لَکُمْ۔ (ابو یعلی 297)",,,2574
2575,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ عَوْنٍ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : ثَلاَثُ تَسْبِیحَاتٍ فِی الرُّکُوعِ وَالسُّجُودِ۔",,,2575
2576,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، قَالَ : بَلَغَنِی أَنَّ عُمَرَ کَانَ یَقُولُ فِی الرُّکُوعِ وَالسُّجُودِ قَدْرَ خَمْسِ تَسْبِیحَاتٍ ، سُبْحَانَ اللہِ وَبِحَمْدِہِ۔",,,2576
2577,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمِ بْنِ ضَمْرَۃَ ، قَالَ : قَالَ : عَلِیٌّ : إذَا رَکَعَ أَحَدُکُمْ فَلْیَقُلَ : اللَّہُمَّ لَکَ رَکَعْتُ ، وَلَک خَشَعْت ، وَبِکَ آمَنْت ، وَعَلَیْک تَوَکَّلْت ، سُبْحَانَ رَبِّی الْعَظِیمِ ، ثَلاَثًا ، وَإِذَا سَجَدَ ، قَالَ : سُبْحَانَ رَبِّی الأَعْلَی ، ثَلاَثًا ، فَإِنْ عَجَّلَ بِہِ أَمْرٌ ، فَقَالَ : سُبْحَانَ رَبِّی الْعَظِیمِ ، وَتَرَکَ ذَلِکَ أَجْزَأَہُ۔ (مسلم 201)",,,2577
2578,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حرب ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللہِ بْنِ أَبِی فَرْوَۃَ ، عَنْ إسْمَاعِیلَ بْنِ عُبَیْدِ اللہِ ؛ أَنَّہُ سَأَلَ أَبَا ہُرَیْرَۃَ ، فَقَالَ : إنِّی رَجُلٌ أَعْوَرُ ، فَمَا نَقُولُ فِی التَّسْبِیحِ فِی السُّجُودِ ؟ قَالَ : ثَلاَثُ تَسْبِیحَاتٍ۔",,,2578
2579,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : صَلَّیْت خَلْفَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فَعَدَدْت لَہُ فِی الرُّکُوعِ أَرْبَعَ ، أَوْ خَمْسَ تَسْبِیحَاتٍ ، وَفِی السُّجُودِ خَمْسَ ، أَوْ سِتَّ تَسْبِیحَاتٍ۔",,,2579
2580,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : جَائَتِ الْحَطَّابَۃُ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَقَالُوا : یَا رَسُولَ اللہِ ، إنَّا لاَ نَزَالُ سَفْرًا أَبَدًا ، فَکَیْفَ نَصْنَعُ بِالصَّلاَۃِ ؟ قَالَ : سَبِّحُوا ثَلاَثَ تَسْبِیحَاتٍ رُکُوعًا ، وَثَلاَثَ تَسْبِیحَاتٍ سُجُودًا۔ (عبدالرزاق 2894)",,,2580
2581,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : مَنْ لَمْ یُسَبِّحْ فِِی رُکُوعِہِ وَسُجُودِہِ ، فَإِنَّمَا صَلاَتُہُ نَقْرٌ۔",,,2581
2582,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُس ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : وَسَطًا مِنَ الرُّکُوعِ وَالسُّجُودِ أَنْ یَقُولَ الرَّجُلُ فِی رُکُوعِہِ وَسُجُودِہِ ، سُبْحَانَ اللہِ وَبِحَمْدِہِ ، ثَلاَثًا۔",,,2582
2583,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : التَّامُّ مِنَ السُّجُودِ ، قَدْرُ سَبْعِ تَسْبِیحَاتٍ ، وَالْمُجْزِیئُ ثَلاَثٌ۔",,,2583
2584,"حَدَّثَنَا ابْن نُمَیْرٍ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ مُحَمَّدِ بْنِ کَعْبٍ ؛ أَنَّہُ سَمِعَہُ یَقُولُ : أَدْنَی السُّجُودِ إذَا وَضَعْت رَأْسَک فِی الأَرْضَ أَنْ تَقُولَ : سُبْحَانَ رَبِّی الأَعْلَی ، ثَلاَثًا۔",,,2584
2585,"حَدَّثَنَا وَکِیعٌ، عَنْ عَبْدِ اللہِ بْنِ أَجْلَح، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ، قَالَ: سَأَلَ الْمُسَیَّبُِ بْنُ رَافِعٍ إبْرَاہِیمَ، فَقَالَ : کَمْ یُجْزِیئُ الرَّجُلَ إذَا وَضَعَ رَأْسَہُ فِی السُّجُودِ مِنْ تَسْبِیحَۃٍ ؟ فَقَالَ إبْرَاہِیمُ : ثَلاَثُ تَسْبِیحَاتٍ۔",,,2585
2586,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : سَأَلْتُ مَیْمُونًا عَنْ مِقْدَارِ الرُّکُوعِ وَالسُّجُودِ ؟ فَقَالَ : لاَ أَرَی أَنْ یَکُونَ أَقَلَّ مِنْ ثَلاَثِ تَسْبِیحَاتٍ ۔ قَالَ جَعْفَرٌ : فَسَأَلْت الزُّہْرِیَّ ، فَقَالَ : إذَا وَقَعَتِ الْعِظَامُ وَاسْتَقَرَّتْ ، فَقُلْتُ لَہُ : إنَّ مَیْمُونًا یَقُولُ : ثَلاَثَ تَسْبِیحَاتٍ ، فَقَالَ : ہُوَ الَّذِی أَقُولُ لَکَ نَحْوٌ مِنْ ذَلِکَ۔",,,2586
2587,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زِیَادٍ الْمُصَفِّرِ ، عَنِ الْحَسَنِ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : ثَلاَثُ تَسْبِیحَاتٍ فِی الرُّکُوعِ ، وَالسُّجُودِ وَسَطٌ۔",,,2587
2588,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی الضُّحَی ، قَالَ : کَانَ عَلِیٌّ یَقُولُ فِی رُکُوعِہِ : سُبْحَانَ رَبِّی الْعَظِیمِ ، ثَلاَثًا ، وَفِی سُجُودِہِ : سُبْحَانَ رَبِّی الأَعْلَی ، ثَلاَثًا۔",,,2588
2589,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنْ مُطَرِّفِ بْنِ عَبْدِ اللہِ بْنِ الشِّخِّیرِ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ فِی رُکُوعِہِ وَسُجُودِہِ : سُبُّوحٌ قُدُّوسٌ ، رَبُّ الْمَلاَئِکَۃِ وَالرُّوحِ۔ (مسلم 224۔ ابوداؤد 868)",,,2589
2590,"حَدَّثَنَا وَکِیعٌ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ إِسْحَاقَ بْنِ یَزِیدَ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ ، عَنِ ابْنِ مَسْعُودٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا رَکَعَ أَحَدُکُمْ فَلْیَقُلْ : سُبْحَانَ رَبِّی الْعَظِیمِ ، ثَلاَثًا ، وَإِذَا سَجَدَ فَلْیَقُلْ : سُبْحَانَ رَبِّی الأَعْلَی ، ثَلاَثًا ، فَإِنَّہُ إذَا فَعَلَ ذَلِکَ فَقَدْ تَمَّ رُکُوعُہُ وَسُجُودُہُ ، وَذَلِکَ أَدْنَاہُ۔ (ترمذی 261۔ ابوداؤد 882)",,,2590
2591,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ؛ أَنَّ ابْنَ مَسْعُودٍ ، قَالَ فِی رُکُوعِہِ : رَبِّ اغْفِرْ لِی۔",,,2591
2592,"حَدَّثَنَا حَفْصٌ ، عَنِ الْجَعْدِ ، رَجُلٍ مِنْ أَہْلِ الْمَدِینَۃِ ، عَنِ ابْنَۃٍ لِسَعْدٍ ؛ أَنَّہَا کَانَتْ تُفْرِطُ فِی الرُّکُوع تُطَأْطؤًا مُنکَرًا ، فَقَالَ لَہَا سَعْدٌ : إنَّمَا یَکْفِیک إذَا وَضَعْت یَدَیْک عَلَی رُکْبَتَیْک۔",,,2592
2593,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ جَرِیرٍ ، عَنِ الضَّحَّاکِ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : إذَا أَمْکَنَ الرَّجُلُ یَدَیْہِ مِنْ رُکْبَتَیْہِ ، وَالأَرْضَ مِنْ جَبْہَتِہِ ، فَقَدْ أَجْزَأَہُ۔",,,2593
2594,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَمَّنْ سَمِعَ مُحَمَّدَ بْنَ عَلِیٍّ یَقُولُ : یُجْزِئُہُ مِنَ الرُّکُوعِ إذَا وَضَعَ یَدَیْہِ عَلَی رُکْبَتَیْہِ ، وَمِنَ السُّجُودِ إذَا وَضَعَ جَبْہَتَہُ عَلَی الأَرْضِ۔",,,2594
2595,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ أَبِی مَالِکٍ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنِ ابن عُمَرَ ، قَالَ : إذَا وَضَعَ الرَّجُلُ جَبْہَتَہُ بِالأَرْضِ أَجْزَأَہُ۔",,,2595
2596,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : یُجْزِیئُ مِنَ الرُّکُوعِ إذَا أَمْکَنَ یَدَیْہِ مِنْ رُکْبَتَیْہِ، وَمِنَ السُّجُودِ إذَا أَمْکَنَ جَبْہَتَہُ مِنَ الأَرْضِ۔",,,2596
2597,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ابْن أَبِی عَرُوبَۃَ ، عَنْ یَعْلَی بْنِ حَکِیمٍ ، قَالَ : قَالَ طَاوُوس وَعِکْرِمَۃُ ، وَأَظُنُّ عَطَائً ثَالِثَہُمْ : إذَا أَمْکَنَ جَبْہَتَہُ مِنَ الأَرْضِ ، فَقَدْ قَضَی مَا عَلَیْہِ۔",,,2597
2598,"حَدَّثَنَا حَفْصٌ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، قَالَ : إذَا وَضَعَ جَبْہَتَہُ علی الأَرْضِ، فَقَدْ أَجْزَأَہُ۔",,,2598
2599,"حَدَّثَنَا حَفْصٌ ، عَنْ مَعْقِلِ بْنِ عُبَیْدِ اللہِ ، قَالَ : سَأَلْتُ عَطَائً عَنْ أَدْنَی مَا یَجُوزُ مِنَ الرُّکُوعِ وَالسُّجُودِ؟ فَقَالَ : إذَا وَضَعَ جَبْہَتَہُ عَلَی الأَرْضِ ، وَوَضَعَ یَدَیْہِ عَلَی رُکْبَتَیْہِ۔",,,2599
2600,"حُدِّثْت ، عَنِ ابْنِ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا وَضَعَ یَدَیْہِ عَلَی رُکْبَتَیْہِ أَجْزَأَہُ۔",,,2600
2601,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ حُسَیْنِ الْمُکْتِبِ ، عَنْ بُدَیْلٍ ، عَنْ أَبِی الْجَوْزَائِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا رَکَعَ لَمْ یُشْخِصْ رَأْسَہُ ، وَلَمْ یُصَوِّبْہُ ، کَانَ بَیْنَ ذَلِکَ۔",,,2601
2602,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، عَنْ رَجُلٍ مِنْ ثَقِیفٍ ، قَالَ : سَأَلْتُ أَبَا ہُرَیْرَۃَ ، فَقَالَ : اتَّقِ الْحَنْوَۃَ فِی الرُّکُوعِ ، وَالْحَدْبَۃَ۔",,,2602
2603,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ کَعْبٍ ، قَالَ : إذَا رَکَعْت فَانْصَبْ وَجْہَک لِلْقِبْلَۃِ ، وَضَعْ یَدَیْک عَلَی رُکْبَتَیْک ، وَلاَ تُدَبِّح کَمَا یُدَبِّحُ الْحِمَارُ۔",,,2603
2604,حَدَّثَنَا ہُشَیْمٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَرْفَعَ الرجل رَأْسَہُ إذَا کَانَ رَاکِعًا، أَوْ یُصَوِّبَہُ۔,,,2604
2605,حَدَّثَنَا ابْنُ إدْرِیسُ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَکْرَہُ التَّحَادُبَ فِی الرُّکُوعِ۔,,,2605
2606,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ حَبِیبِ بْنِ الشَّہِیدِ ، قَالَ : سَمِعْتُ مُحَمَّدَ بْنَ سیرین یَقُولُ : الرُّکُوعُ ہَکَذَا ، وَوَصَفَ مُعَاذٌ أَنَّہُ یُسَوِّی ظَہْرَہُ ، لاَ یُصَوِّبُ رَأْسَہُ ، وَلاَ یَرْفَعُہُ ، قَالَ : سَمِعْتُ الْحَسَنَ یَقُولُ مِثْلَ ذَلِکَ ، غَیْرَ أَنَّ الْحَسَنَ تَکَلَّمَ بِہِ کَلاَمًا۔",,,2606
2607,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَبِی فَرْوَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا رَکَعَ لَوْ صَبَبْتَ عَلَی کَتِفَیْہِ مَائً لاَسْتَقَرَّ۔ (طبرانی 12755۔ عبدالرزاق 2872)",,,2607
2608,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا قَالَ الإِمَامُ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، فَقُولُوا : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ۔",,,2608
2609,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخبرنا عُمَرُ بْنُ أَبِی سَلَمَۃَ ، عَنْ أَبِیہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، رَفَعَہُ ، قَالَ : وَإذَا قَالَ الإِمَامُ: سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، فَقُولُوا : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ۔ (بخاری 722۔ مسلم 309)",,,2609
2610,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ یُونُسَ بْنِ جُبَیْرٍ ، عَنْ حِطَّانَ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی مُوسَی ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا قَالَ الإِمَامُ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، فَقُولُوا : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ ۔ یَسْمَعُ اللَّہُ لَکُمْ۔ (مسلم 403۔ احمد 4/409)",,,2610
2611,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّمَا جُعِلَ الإِمَامُ لِیُؤْتَمَّ بِہِ ، فَإِذَا رَکَعَ فَارْکَعُوا ، وَإذَا قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، فَقُولُوا : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ۔ (مسلم 306۔ ابوداؤد 604)",,,2611
2612,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا قَالَ الإِمَامُ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، قَالَ مَنْ خَلْفَہُ : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ۔",,,2612
2613,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ یَقُل الْقَوْمُ خَلْفَ الإِمَامِ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، وَلَکِنْ لِیَقُولُوا : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ۔",,,2613
2614,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکْیر ، قَالَ : حدَّثَنَا زُہَیْرُ بْنُ مُحَمَّدٍ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، أَنَّہُ سَمِعَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إذَا قَالَ إمَامُکُمْ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، فَقُولُوا : اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ۔ (احمد 3/3)",,,2614
2615,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یَقُولُ إذَا قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، قَالَ مَنْ خَلْفَہُ: سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، اللَّہُمَّ رَبَّنَا لَکَ الْحَمْدُ۔",,,2615
2616,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ رَجُلٍ مِنْ أَہْلِ الْمَدِینَۃِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ سَمِعَ خَفْقَ نَعْلِی وَہُوَ سَاجِدٌ ، فَلَمَّا فَرَغَ مِنْ صَلاَتِہِ ، قَالَ : مَنْ ہَذَا الَّذِی سَمِعْتُ خَفْقَ نَعْلِہِ ؟ قَالَ : أَنَا یَا رَسُولَ اللہِ ، قَالَ : فَمَا صَنَعْت ؟ قَالَ : وَجَدْتُّک سَاجِدًا فَسَجَدْت ، فَقَالَ : ہَکَذَا فَاصْنَعُوا ، وَلاَ تَعْتَدُّوا بِہَا ، مَنْ وَجَدَنِی رَاکِعًا ، أَوْ سَاجِدًا ، أَوْ قَائِمًا ، فَلْیَکُنْ مَعِی عَلَی حَالِی الَّتِی أَنَا عَلَیْہَا۔\n\n(عبدالرزاق 3373۔ بیہقی 89)",,,2616
2617,حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ رَجُلٍ مِنَ الأَنْصَارِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ بِمِثْلِہِ۔,,,2617
2618,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ وَزَیْدِ بْنِ ثَابِتٍ ، قَالاَ : إِنْ وَجَدَہُمْ وَقَدْ رَفَعُوا رُؤُوسَہُمْ مِنَ الرُّکُوعِ کَبَّرَ وَسَجَدَ ، وَلَمْ یَعْتَدَّ بِہَا۔",,,2618
2619,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ (ح) ، وَمُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَنْتَہِی إلَی الإِمَامِ وَہُوَ سَاجِدٌ ، قَالاَ : یَتْبَعُہُ وَیَسْجُدُ مَعَہُ ، وَلاَ یُخَالِفُہُ ، وَلاَ یَعْتَدُّ بِالسُّجُودِ إِلاَّ أَنْ یُدْرِکَ الرُّکُوعَ۔",,,2619
2620,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : عَلَی أَیِّ حَالٍ أَدْرَکْتَ الإِمَامَ فَلاَ تُخَالِفْہُ۔",,,2620
2621,"حدَّثَنَا مُعْتَمِرٌ ، عَنْ سَلْمِ بْنِ أَبِی الذَّیَّالِ ، عَنْ قَتَادَۃَ ، قَالَ : إذَا أَدْرَکْتَہُمْ وَہُمْ سُجُودٌ ، فَاسْجُدْ مَعَہُمْ ، وَلاَ تَعْتَدَّ بِتِلْکَ الرَّکْعَۃِ۔",,,2621
2622,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا وَجَدْتہمْ سُجُودًا فَاسْجُدْ مَعَہُمْ ، وَلاَ تَعْتَدَّ بِہَا ، وَقَالَ أَبُو الْعَالِیَۃِ : اُسْجُدْ مَعَہُمْ وَاعْتَدَّ بِہَا۔",,,2622
2623,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : عَلَی أَیِّ حَالٍ وَجَدْتَ الإِمَامَ ، فَاصْنَعْ کَمَا یَصْنَعُ۔",,,2623
2624,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إبْرَاہِیمَ ، قَالَ : عَلَی أَیِّ حَالٍ وَجَدْت الإِمَامَ ، فَاصْنَعْ کَمَا یَصْنَعُ۔",,,2624
2625,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ یَسْتَحِبُّ أَنْ لاَ یُدْرِکَ الْقَوْمَ عَلَی حَالٍ فِی الصَّلاَۃِ ، إِلاَّ دَخَلَ مَعَہُمْ فِیہَا۔",,,2625
2626,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ دَاوُدَ، عَنِ الشَّعْبِیِّ؛ فِی الرَّجُلِ یَنْتَہِی إلَی الْقَوْمِ وَہُمْ سُجُودٌ، قَالَ: یَسْجُدُ مَعَہُمْ۔",,,2626
2627,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَام ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ قَالاَ : لاَ یَقُومُ الرَّجُلُ قَائِمًا مُنْتَصِبًا ، وَالْقَوْمُ قَدْ وَضَعُوا رُؤُوسَہُمْ۔",,,2627
2628,حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَکْرَہُ لِلرَّجُلِ إذَا جَائَ وَالإِمَامُ سَاجِدٌ ، أَنْ یَتَمَثَّلَ قَائِمًا حَتَّی یَتْبَعَہُ۔,,,2628
2629,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی الْمَوَالِی ، عَنْ عُمَرَ بْنِ أَبِی مُسْلِمٍ ، قَالَ : کانَ عُرْوَۃُ بْنُ الزُّبَیْرِ یَقُولُ : إذَا جَائَ أَحَدُکُمْ وَالإِمَامُ سَاجِدٌ ، فَلْیَسْجُدْ مَعَ النَّاسِ ، وَلاَ یَعْتَدَّ بِہَا۔",,,2629
2630,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ ہُبَیْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : لاَ یَعْتَدُّ بِالسُّجُودِ إذَا لَمْ یُدْرِکِ الرُّکُوعَ۔",,,2630
2631,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ وَہُبَیْرَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا لَمْ تُدْرِکِ الرُّکُوعَ فَلاَ تَعْتَدُّ بِالسُّجُودِ۔",,,2631
2632,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ عَبْدُ اللہِ بْنُ یَزِیدَ الْخَطْمِیِّ إذَا رَفَعَ رَأْسَہُ مِنَ الرَّکْعَۃِ ہَوَی بِالتَّکْبِیرَۃِ ، فَکَأَنَّہُ فِی أُرْجُوحَۃٍ حَتَّی یَسْجُدَ۔",,,2632
2633,"حَدَّثَنَا یَعْلَی ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : کَانَ عُمَرُ إذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ ، قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، قَبْلَ أَنْ یُقِیمَ ظَہْرَہُ ، وَإِذْا کَبَّرَ کَبَّرَ وَہُوَ مُنْحَطٌّ۔",,,2633
2634,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَبِّرْ وَأَنْتَ تَہْوِی ، وَأَنْتَ تَرْکَعُ۔",,,2634
2635,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : أَخْبَرَنَا شَرِیکٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عُمَرَ ؛ أَنَّہُ کَانَ یَہْوِی بِالتَّکْبِیرِ۔",,,2635
2636,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَر ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ عُمَرُ إذَا قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ، انْحَدَرَ مُکَبِّرًا۔",,,2636
2637,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مَنْصُورٍ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، قَالَ : خَرَجْت مَعَ عَبْدِ اللہِ مِنْ دَارِہِ إلَی الْمَسْجِدِ ، فَلَمَّا تَوَسَّطْنَا الْمَسْجِدَ رَکَعَ الإِمَامُ فَکَبَّرَ عَبْدُ اللہِ ، ثُمَّ رَکَعَ وَرَکَعْت مَعَہُ ، ثُمَّ مَشَیْنَا رَاکِعَیْنَ حَتَّی انْتَہَیْنَا إلَی الصَّفِّ ، حَتَّی رَفَعَ الْقَوْمُ رُؤُوسَہُمْ ۔ قَالَ : فَلَمَّا قَضَی الإِمَامُ الصَّلاَۃَ قُمْت أَنَا أَرَی أَنی لَمْ أُدْرِکْ ، فَأَخَذَ بِیَدِی عَبْدُ اللہِ فَأَجْلَسَنِی ، وَقَالَ : إنَّک قَدْ أَدْرَکْتَ۔",,,2637
2638,حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ أَبَا عُبَیْدَۃَ جَائَ وَالْقَوْمُ رُکُوعٌ فَرَکَعَ دُونَ الصَّفِّ ، ثُمَّ مَشَی حَتَّی دَخَلَ فِی الصَّفِّ ، ثُمَّ حَدَّثَ ، عَنْ أَبِیہِ ، بِمِثْلِ ذَلِکَ۔,,,2638
2639,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی أُمَامَۃَ ؛ أَنَّ زَیْدَ بْنَ ثَابِتٍ رَکَعَ قَبْلَ أَنْ یَصِلَ إلَی الصَّفِّ ، ثُمَّ مَشَی رَاکِعًا۔,,,2639
2640,حَدَّثَنَا وَکِیعٌ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ مَوْہَبٍ ، عَنْ کَثِیرِ بْنِ أَفْلَحَ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ؛ أَنَّہُ دَخَلَ وَالْقَوْمُ رُکُوعٌ ، فَرَکَعَ دُونَ الصَّفِّ ، ثُمَّ دَخَلَ فِی الصَّفِّ۔,,,2640
2641,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، قَالَ : رَأَیْتُ ابْنَ جُبَیْرٍ ، فَعَلَہُ۔",,,2641
2642,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ قَالَ : کَانَ أَبِی یَدْخُلُ وَالإِمَامُ رَاکِعٌ ، فَیَرْکَعُ دُونَ الصَّفِّ ، ثُمَّ یَدْخُلُ فِی الصَّفِّ۔",,,2642
2643,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ وِقَائٍ قَالَ: دَخَلْتُ أَنَا وَسَعِیدُ بْنُ جُبَیْرٍ وَہُمْ رُکُوعٌ ، فَرَکَعْت أَنَا وَہُوَ مِنَ الْبَابِ، ثُمَّ جِئْنَا حَتَّی دَخَلْنَا فِی الصَّفِّ۔",,,2643
2644,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقْرِیئُ ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ ، قَالَ : حدَّثَنِی یَزِیدُ بْنُ أَبِی حَبِیبٍ ؛ أَنَّہُ رَأَی أَبَا سَلَمَۃَ دَخَلَ الْمَسْجِدَ وَالْقَوْمُ رُکُوعٌ فَرَکَعَ ، ثُمَّ دَبَّ رَاکِعًا۔",,,2644
2645,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی مَنْ دَخَلَ الْمَسْجِدَ وَالإِمَامُ رَاکِعٌ ، قَالَ : إذَا جَاوَزَ النِّسَائَ کَبَّرَ وَرَکَعَ ، ثُمَّ مَضَی حَتَّی یَدْخُلَ فِی الصَّفِّ ، فَإِنْ أَدْرَکَہُ السُّجُودُ قَبْلَ ذَلِکَ سَجَدَ حَیْثُ أَدْرَکَ۔",,,2645
2646,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، قَالَ : دَخَلْت أَنَا ، وَعَمْرُو بْنُ تَمِیمٍ الْمَسْجِدَ فَرَکَعَ الإِمَامُ ، فَرَکَعْت أَنَا وَہُوَ ، وَمَشَیْنَا رَاکِعَیْنِ حَتَّی دَخَلْنَا الصَّفَّ ، فَلَمَّا قضینا الصلاۃ ، قَالَ لِی عَمْرٌو : اَلَّذِی صَنَعْتَ آنِفًا مِمَّنْ سَمِعْتَہ ؟ قُلْتُ : مِنْ مُجَاہِدٍ ، قَالَ : قَدْ رَأَیْت ابْنَ الزُّبَیْرِ ، فَعَلَہُ۔",,,2646
2647,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ ، عَنِ الْقَاسِمِ (ح) وَعَنْ ہِشَامٍ ، عَنِ الْحَسَنِ قَالاَ : ؛ فِی الرَّجُلِ یَدْخُلُ الْمَسْجِدَ وَالْقَوْمُ قَدْ رَکَعُوا قَالاَ : إِنْ کَانَ یَظُنُّ أَنَّہُ یُدْرِکُ الْقَوْمَ قَبْلَ أَنْ یَرْفَعُوا رُؤُوسَہُمْ فَلْیَرْکَعْ ، وَلِیَمْشِ حَتَّی یَدْخُلَ الصَّفَّ۔",,,2647
2648,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنِ الأَعْرَجِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : لاَ تُکَبِّرْ حَتَّی تَأْخُذَ مَقَامَک مِنَ الصَّفِّ۔",,,2648
2649,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِی الْمُعَلَّی ، قَالَ : سُئِلَ الْحَسَنُ عَنِ الرَّجُلِ یَرْکَعُ قَبْلَ أَنْ یَصِلَ إلَی الصَّفِّ ؟ فَقَالَ: لاَ یَرْکَعُ۔",,,2649
2650,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : إذَا دَخَلْتُ الْمَسْجِدَ وَالإِمَامُ رَاکِعٌ ، أَأَرْکَعُ قَبْلَ أَنْ أَنْتَہِیَ إلَی الصَّفِّ ؟ قَالَ : أَنْتَ لاَ تَفْعَلْ ذَلِکَ۔",,,2650
2651,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنِ الأَعْرَجِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إذَا دَخَلْتَ وَالإِمَامُ رَاکِعٌ فَلاَ تَرْکَعْ حَتَّی تَأْخُذَ مَقَامَک مِنَ الصَّفِّ ۔ قَالَ أَبُو بَکْرٍ : إذَا کَانَ ہُوَ وَآخَرُ ، رَکَعَ دُونَ الصَّفِّ ، وَإِذَا کَانَ وَحْدَہُ فَلاَ یَرْکَعُ۔",,,2651
2652,"حَدَّثَنَا حَفْصٌ، عَنْ لَیْثٍ، قَالَ: کَانَ مُجَاہِدٌ إذَا رَکَعَ یَضَعُ یَدَیْہِ عَلَی رُکْبَتَیْہِ، قَالَ وَکَانَ عَطَائٌ وَطَاوُوس وَنَافِعٌ یفرِّجُونَ۔",,,2652
2653,"حَدَّثَنَا أَبُو بَکْرٍ ، عَنْ حَفْصٍ ، عَنْ لَیْثٍ، قَالَ: صَلَّی رَجُلٌ إلَی جَنْبِ عَطَائٍ ، فَلَمَّا رَکَعَ ثَنَی رُکْبَتَیْہِ ، قَالَ فَضَرَبَ یَدَہُ ، وَقَالَ : اُبْسُطْہُمَا۔",,,2653
2654,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَالِمٍ الْبَرَّادِ ، قَالَ : أَتَیْنَا أَبَا مَسْعُودٍ فِی بَیْتِہِ ، فَقُلْنَا لَہُ: عَلِّمْنَا صَلاَۃَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَصَلَّی ، فَلَمَّا سَجَدَ جَافَی بِمِرْفَقَیْہِ۔ (ابوداؤد 859۔ نسائی 624)",,,2654
2655,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ یَزِیدَ بْنِ الأَصَمِّ ، عَنْ مَیْمُونَۃَ ، قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا سَجَدَ رَأَی مَنْ خَلْفَہُ بَیَاضَ إبِطَیْہِ۔ (مسلم 357۔ ابوداؤد 894)",,,2655
2656,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبَّادِ بْنِ رَاشِدٍ ، عَنِ الْحَسَنِ ، قَالَ : حدَّثَنِی أَحْمَرُ صَاحِبُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إِنْ کُنَّا لَنَأْوِی لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِمَّا یُجَافِی عَنْ جَنْبَیْہِ إذَا سَجَدَ۔\n\n(ابوداؤد 896۔ ابن ماجہ 886)",,,2656
2657,"حَدَّثَنَا وَکِیعٌ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ أَقْرَمَ الْخُزَاعِیِّ) ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ مَعَ أَبِی بِالْقَاعِ مِنْ نَمِرَۃَ ، فَمَرَّ بِنَا رَکْبٌ فَأَنَاخُوا بِنَاحِیَۃِ الطَّرِیقِ ، فَقَالَ : أَیْ بُنَیَّ ، کُنْ فِی بَہْمِکَ حَتَّی آتِیَ ہَؤُلاَئِ الْقَوْمَ ، فَخَرَجَ وَخَرَجْتُ مَعَہُ ، یَعْنِی دَنَا وَدَنَوْت ، فَإِذَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَصَلَّی وَصَلَّیْت مَعَہُ ، فَکُنْت أَنْظُرُ إلَی عُفْرَۃِ إبْطَیْہِ۔ (ابن ماجہ 881۔ احمد 4/35)",,,2657
2658,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ شُعْبَۃَ مَوْلَی ابْنِ عَبَّاسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُرَی بَیَاضُ إبْطَیْہِ إذَا سَجَدَ۔ (ابوداؤد 895۔ احمد 1/267)",,,2658
2659,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حُمَیْدٍ ، قَالَ : کَانَ أَنَسٌ إذَا سَجَدَ جَافَی۔",,,2659
2660,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَرَی مَنْ خَلْفَہُ بَیَاضَ إبْطَیْہِ إذَا سَجَدَ۔,,,2660
2661,"حَدَّثَنَا ہَاشِمُ بْنُ الْقَاسِمِ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ، قَالَ: حدَّثَنِی عَاصِمُ بْنُ شُمَیْخٍ الْغَیْلاَنِیُّ أَحَدُ بَنِی تَمِیمٍ، قَالَ : دَخَلْتُ عَلَی أَبِی سَعِیدٍ فَرَأَیْتُہُ وَہُوَ سَاجِدٌ یُجَافِی بِمِرْفَقَیْہِ عَنْ جَنْبَیْہِ ، حَتَّی أَرَی بَیَاضَ إبْطَیْہِ۔",,,2661
2662,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : الرَّجُلُ یَتَجَافَی۔",,,2662
2663,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا سَجَدَ الرَّجُلُ فَلْیُخَوِّ۔",,,2663
2664,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا سَجَدَ الرَّجُلُ فَلْیُفَرِّجْ بَیْنَ فَخِذَیْہِ۔",,,2664
2665,"حَدَّثَنَا أَسْوَدُ بْنُ عَامِرٍ ، عَنْ شَرِیکٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : وَصَفَ لَنَا الْبَرَائُ فَاعْتَمَدَ عَلَی کَفَّیْہِ وَرَفَعَ عَجِیزَتَہُ ، فَقَالَ : ہَکَذَا کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْجُدُ۔ (ابوداؤد 892۔ احمد 4/303)",,,2665
2666,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، وَأَبُو مُعَاوِیَۃَ ، وَأَبُو خَالِدٍ الأَحْمَرِِِ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ، عَنْ جَابِرٍ، قَالَ: قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا سَجَدَ أَحَدُکُمْ فَلْیَعْتَدِلْ ، وَلاَ یَفْتَرِشْ ذِرَاعَیْہِ افْتِرَاشَ الْکَلْبِ۔\n\n(ترمذی 275۔ احمد 3/305)",,,2666
2667,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ تَمِیمِ بْنِ مَحْمُودٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ شِبْلٍ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ افْتِرَاشِ السَّبُعِ۔ (ابوداؤد 858۔ دارمی 1323)",,,2667
2668,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا سَجَدَ أَحَدُکُمْ فَلْیَعْتَدِلْ ، وَلاَ یَفْتَرِشْ ذِرَاعَیْہِ افْتِرَاشَ الْکَلْبِ۔",,,2668
2669,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُسَیْنٍ الْمُکْتِبِ ، عَنْ بُدَیْلٍ ، عَنْ أَبِی الْجَوْزَائِ ، عَنْ عَائِشَۃَ ، قَالَتْ : نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَفْتَرِشَ أَحَدُنَا ذِرَاعَیْہِ افْتِرَاشَ السَّبُعِ۔",,,2669
2670,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : اعْتَدِلُوا فِی سُجُودِکُمْ ، وَلاَ یَتَبَسَّطْ أَحَدُکُمْ ذِرَاعَیْہِ انْبسَاطَ الْکَلْبِ۔ (بخاری 822۔ ابوداؤد 893)",,,2670
2671,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ عَمْرٍوَ قَالَ: حدَّثَنَا زَائِدَۃُ ، عَنِ الأَعْمَشِ ، عَنْ صَالِحِ بْنِ خَبَّابٍ ، عَنْ حُصَیْنِ بْنِ عُقْبَۃَ، عَنْ عُمَرَ (ح) وَعَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا سَجَدَ أَحَدُکُمْ فَلْیَعْتَدِلْ ، وَلاَ یَفْتَرِشْ ذِرَاعَیْہِ افْتِرَاشَ الْکَلْبِ۔",,,2671
2672,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ الْحَذَّائِ ، عَنِ الْحَکَمِ بْنِ الأَعْرَجِ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی أَبَا ذَرٍّ مُسَوَّدًا مَا بَیْنَ رُسْغِہِ إلَی مِرْفَقَیْہِ۔",,,2672
2673,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ عَامِرِ بْنِ عَبْدَۃَ ، قَالَ : قَالَ عَبْدُ اللہِ : ہُیِّئَتْ عِظَامُ ابْنِ آدَمَ لِسجُودِہِ ، اسْجُدُوا حَتَّی بِالْمَرَافِقِ۔",,,2673
2674,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ، قَالَ: قُلْتُ لِمُحَمَّدٍ: الرَّجُلُ یَسْجُدُ یَعْتَمِدُ بِمِرْفَقَیْہِ عَلَی رُکْبَتَیْہِ؟ قَالَ : مَا أَعْلَمُ بِہِ بَأْسًا۔",,,2674
2675,"حَدَّثَنَا عَاصِمٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یَضُمُّ یَدَیْہِ إلَی جَنْبَیْہِ إذَا سَجَدَ۔",,,2675
2676,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِیہِ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ قَیْسِ بْنِ سَکَن ، قَالَ : کُلَّ ذَلِکَ قَدْ کَانُوا یَفْعَلُونَ ، یَنْضَمُّونَ وَیَتَجَافَوْنَ ، کَانَ بَعْضُہُمْ یَنْضَمُّ وَبَعْضُہُمْ یُجَافِی۔",,,2676
2677,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ سُمَیٍّ ، عَنِ النُّعْمَانِ بْنِ أَبِی عَیَّاشٍ ، قَالَ : شَکَوْا إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الإِدِّعَامَ وَالإِعْتِمَادَ فِی الصَّلاَۃِ ، فَرَخَّصَ لَہُمْ أَنْ یَسْتَعِینَ الرَّجُلُ بِمِرْفَقَیْہِ عَلَی رُکْبَتَیْہِ ، أَوْ فَخِذَیْہِ۔\n\n(عبدالرزاق 2928)",,,2677
2678,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ حَبِیبٍ ، قَالَ : سَأَلَ رَجُلٌ ابْنَ عُمَرَ : أَضَعُ مِرْفَقَیَّ عَلَی فَخْذِی إذَا سَجَدْت ؟ فَقَالَ : اُسْجُدْ کَیْفَ تَیَسَّرَ عَلَیْک۔",,,2678
2679,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنْ أَبِی الأَحْوَصِ ، قَالَ : قَالَ عَبْدُ اللہِ : إذَا سَجَدْتُمْ فَاسْجُدُوا حَتَّی بِالْمَرَافِقِ ، یَعْنِی یَسْتَعِینُ بِمِرْفَقَیْہِ۔",,,2679
2680,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَجَّاجِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ ، قَالَ : سُئِلَ : أَیْنَ کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَضَعُ وَجْہَہُ ؟ قَالَ : کَانَ یَضَعُہُ بَیْنَ کَفَّیْہِ ، أَوَ قَالَ : یَدَیْہِ ، یَعْنِی فِی السُّجُودِ۔",,,2680
2681,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ وَائِلِ بْنِ حُجْرٍ ، قَالَ : قُلْتُ : لأَنْظُرَنَّ إلَی صَلاَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَسَجَدَ ، فَرَأَیْتُ رَأْسَہُ مِنْ یَدَیْہِ عَلَی مِثْلِ مِقْدَارِہِ حَیْثُ اسْتَفْتَحَ ۔ یَقُولُ : قَرِیبًا مِنْ أُذُنَیْہِ۔",,,2681
2682,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ وَائِلِ بْنِ حُجْرٍ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ سَجَدَ وَیَدَیْہِ قَرِیبًا مِنْ أُذُنَیْہِ۔ (احمد 4/316۔ ابن حبان 1860)",,,2682
2683,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَالِمٍ الْبَرَّادِ ، قَالَ : أَتَیْنَا أَبَا مَسْعُودٍ الأَنْصَارِیَّ فِی بَیْتِہِ ، فَقُلْنَا : عَلِّمْنَا صَلاَۃَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَصَلَّی ، فَلَمَّا سَجَدَ وَضَعَ کَفَّیْہِ قَرِیبًا مِنْ رَأْسِہِ۔",,,2683
2684,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ سُئِلَ عَنِ الرَّجُلِ إذَا سَجَدَ کَیْفَ یَضَعُ یَدَیْہِ ؟ قَالَ : یَضَعُہُمَا حَیْثُ تَیَسَّرا ، أَوْ کَیْفَمَا جَائَتَا۔",,,2684
2685,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ أَبِی حَازِمٍ ، قَالَ : قُلْتُ لابْنِ عُمَرَ : أَکُونُ فِی الصَّفِّ وَفِیہِ ضِیقٌ ، کَیْفَ أَضَعُ یَدَیَّ ؟ قَالَ : ضَعْہُمَا حَیْثُ تَیَسَّرَ۔",,,2685
2686,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانُوا یَسْتَحِبُّونَ إذَا سَجَدَ الرَّجُلُ أَنْ یَقُولَ بِیَدَیْہِ ہَکَذَا، وَضَمَّ أَزْہَرُ أَصَابِعَہُ۔",,,2686
2687,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِیہِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا سَجَدْت فَلاَ تَضُمَّ کَفَّیْک ، وَابْسُطْ أَصَابِعَک۔",,,2687
2688,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، قَالَ : صَلَّیْت إلَی جَنْبِ حَفْصِ بْنِ عَاصِمٍ ، فَلَمَّا سَجَدْت فَرَّجْت بَیْنَ أَصَابِعِی وَأَمَلْت کَفِّی عَنِ الْقِبْلَۃِ ، فَلَمَّا سَلَّمْت ، قَالَ : یَا ابْنَ أخِی ، إذَا سَجَدْت فَاضْمُمْ أَصَابِعَک ، وَوَجِّہْ یَدَیْک قِبَلَ الْقِبْلَۃِ ، فَإِنَّ الْیَدَیْنِ تَسْجُدَانِ مَعَ الْوَجْہِ۔",,,2688
2689,"حَدَّثَنَا وَکِیعٌ ، قَالَ سُفْیَانُ : یُفَرِّجُ بَیْنَ أَصَابِعِہِ فِی الرُّکُوعِ ، وَیَضُمُّ فِی السُّجُودِ۔",,,2689
2690,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَان ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ ، قَالَ : السُّجُودُ عَلَی أَلْیَۃِ الْکَفِّ۔\n\n(ابن خزیمۃ 639۔ ابن حبان 1915)",,,2690
2691,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : سَمِعْتُ الْبَرَائَ بْنَ عَازِبٍ یَقُولُ : السُّجُودُ عَلَی أَلْیَۃِ الْکَفَّیْنِ۔",,,2691
2692,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، وَأَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَن عَامِرِ بْنِ سَعْدٍ ، قَالَ : أَمَرَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِوَضْعِ الْکَفَّیْنِ وَنَصْبِ الْقَدَمَیْنِ فِی السُّجُودِ۔\n\n(ترمذی 272۔ ابوداؤد 888)",,,2692
2693,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : أَعْظَمُ السُّجُودِ عَلَی الرَّاحَتَیْنِ وَالرُّکْبَتَیْنِ وَصَدْرِ الْقَدَمَیْنِ۔",,,2693
2694,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ طَلْقِ بْنِ حَبِیبٍ ؛ فِی قَوْلِہِ : {وَعَنَتِ الْوُجُوہُ لِلْحَیِّ الْقَیُّومِ} قَالَ : السُّجُودُ عَلَی الْجَبْہَۃِ ، وَالرَّاحَتَیْنِ ، وَالرُّکْبَتَیْنِ ، وَالْقَدَمَیْنِ۔",,,2694
2695,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، عَنْ عُمَرَ ، قَالَ : وُجِّہَ ابْنُ آدَمَ لِلسُّجُودِ عَلَی سَبْعَۃِ أَعْضَائٍ ؛ الْجَبْہَۃِ ، وَالرَّاحَتَیْنِ ، وَالرُّکْبَتَیْنِ ، وَالْقَدَمَیْنِ۔",,,2695
2696,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخْبَرَنَا أَبُو بِشْرٍ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : السُّجُودُ عَلَی سَبْعَۃِ أَعْضَائٍ؛ الْجَبْہَۃِ ، وَالرَّاحَتَیْنِ ، وَالرُّکْبَتَیْنِ ، وَالْقَدَمَیْنِ۔",,,2696
2697,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أُمِرْت أَنْ أَسْجُدَ عَلَی سَبْعَۃِ أَعْظُمٍ ، لاَ أَکُفَّ شَعْرًا ، وَلاَ ثَوْبًا۔ (بخاری 812۔ مسلم 231)",,,2697
2698,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ السُّجُودَ عَلَی سَبْعَۃِ أَعْظُمٍ ؛ عَلَی الْیَدَیْنِ ، وَالرُّکْبَتَیْنِ ، وَالْقَدَمَیْنِ ، وَالْجَبْہَۃِ۔",,,2698
2699,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائٍ ، عَنْ سَعِیدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یَسْجُدُ عَلَی سَبْعَۃٍ أَعْظُمٍ ؛ یَدَیْہِ ، وَرِجْلَیْہِ ، وَجَبْہَتِہِ ، وَرُکْبَتَیْہِ۔",,,2699
2700,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَسْجُدَ وَأَصَابِعُ رِجْلَیْہِ ہَکَذَا ؛ وَوَصَفَ أَنَّہُ یُثْنِیہَا إلَی بَطْنِ رِجْلِہِ ، وَقَالَ : اُبْسُطْہَا۔",,,2700
2701,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی الْعَنْبَسِ ، عَنْ أَبِی الْبَخْتَرِیِّ ، قَالَ : إذَا سَجَدْت فَانْصِبْ قَدَمَیْک۔",,,2701
2702,"حَدَّثَنَا ہُشَیْمٌ وَحَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الْجَبَّارِ بْنِ وَائِلٍ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْجُدُ عَلَی جَبْہَتِہِ وَأَنْفِہِ۔",,,2702
2703,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ کَانَ یَقُولُ : إذَا سَجَدَ أَحَدُکُمْ فَلْیَلْزَقْ أَنْفَہُ بِالْحَضِیضِ ، فَإِنَّ اللَّہَ قَدِ ابْتَغَی ذَلِکَ مِنْکُمْ۔",,,2703
2704,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْمُغِیرَۃِ ، عَنْ إبْرَاہِیمَ ، قَالَ : السُّجُودُ عَلَی الْجَبْہَۃِ وَالأَنْفِ۔",,,2704
2705,"حَدَّثَنَا مُطَّلِبُ بْنُ زِیَادٍ ، عَنْ عَبْدِ اللہِ بْنِ عِیسَی ، قَالَ : مَرَّ عَلَیَّ عَبْدُ الرَّحْمَنِ بْنُ أَبِی لَیْلَی وَأَنَا سَاجِدٌ ، فَقَالَ : یَا ابْنَ عِیسَی ، ضَعْ أَنْفَک لِلَّہِ۔",,,2705
2706,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ وِقَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : مَا تَمَّتْ صَلاَۃُ رَجُلٍ حَتَّی یَلْزَقَ أَنْفَہُ کَمَا یَلْزَقُ جَبْہَتَہُ۔",,,2706
2707,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : نُبِّئْت أَنَّ طَاوُوسًا سُئِلَ عَنِ السُّجُودِ عَلَی الأَنْفِ ؟ قَالَ : أَوَلَیْسَ أَکْرَمَ الْوَجْہِ۔",,,2707
2708,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، قَالَ : کَانَ ابْنُ سِیرِینَ إذَا سَجَدَ عَلَی مَکَان لاَ یَمَسُّ أَنْفُہُ الأَرْضَ ، تَحَوَّلَ إلَی مَکَان آخَرَ۔",,,2708
2709,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ ثَابِتِ بْنِ قَیْسٍ ، قَالَ : رَأَیْتُ نَافِعَ بْنَ جُبَیْرٍ یُمِسّ أَنْفُہُ الأَرْضَ۔",,,2709
2710,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : مَرَّ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی إنْسَانٍ سَاجِدٍ ، لاَ یَضَعُ أَنْفَہُ فِی الأَرْضِ ، فَقَالَ : مَنْ صَلَّی صَلاَۃً لاَ یُصِیبُ الأَنْفُ مَا یُصِیبُ الْجَبِینُ لَمْ تُقْبَلْ صَلاَتُہُ۔ (دارقطنی 348۔ بیہقی 3)",,,2710
2711,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إذَا سَجَدَ وَضَعَ أَنْفَہُ مَعَ جَبْہَتِہِ۔,,,2711
2712,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُبَیْدِ اللہِ ، قَالَ : قُلْتُ لِوَہْبِ بْنِ کَیْسَانَ : یَا أَبَا نُعَیْمٍ ، مَا لَکَ لاَ تُمَکِّنُ جَبْہَتَکَ وَأَنْفَک مِنَ الأَرْضِ ؟ قَالَ : ذَلِکَ أَنِّی سَمِعْت جَابِرَ بْنَ عَبْدِ اللہِ یَقُولُ : رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْجُدُ فِی أَعْلَی جَبْہَتِہِ عَلَی قُصَاصِ الشَّعَرِ۔ (دارقطنی 349۔ طبرانی 435)",,,2712
2713,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَسَنِ ، قَالَ : إِنْ شِئْتَ فَاسْجُدْ عَلَی أَنْفِکَ ، وَإِنْ شِئْتَ فَلاَ تَفْعَلْ۔",,,2713
2714,"حَدَّثَنَا مَعْنٌ ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ الْقَاسِمَ وَسَالِمًا یَسْجُدَانِ عَلَی جِبَاہِہِمَا ، وَلاَ تَمَسُّ الأَرْضَ أُنُوفُہُمَا۔",,,2714
2715,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ فِی رَجُلٍ لَمْ یَسْجُدْ عَلَی أَنْفِہِ ، قَالَ : یُجْزئُہُ۔",,,2715
2716,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ یَضُرُّہُ۔",,,2716
2717,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَنْ جَدِّہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، یَرْفَعُہُ ، أَنَّہُ قَالَ : إذَا سَجَدَ أَحَدُکُمْ فَلْیَبْتَدِئْ بِرُکْبَتَیْہِ قَبْلَ یَدَیْہِ ، وَلاَ یَبْرُکْ بُرُوکَ الْفَحْلِ۔ (ابوداؤد 834۔ طحاوی 255۔ بیہقی 100 )",,,2717
2718,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّ عُمَرَ کَانَ یَضَعُ رُکْبَتَیْہِ قَبْلَ یَدَیْہِ۔,,,2718
2719,حَدَّثَنَا یَعْلَی ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ؛ أَنَّ عُمَرَ کَانَ یَقَعُ عَلَی رُکْبَتَیْہِ۔,,,2719
2720,حَدَّثَنَا یَعْقُوبُ بْنُ إبْرَاہِیمَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَضَعُ رُکْبَتَیْہِ إذَا سَجَدَ قَبْلَ یَدَیْہِ ، وَیَرْفَعُ یَدَیْہِ إذَا رَفَعَ قَبْلَ رُکْبَتَیْہِ۔,,,2720
2721,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ کَہْمَسٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمِ بْنِ یَسَارٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ إذَا سَجَدَ تَقَعُ رُکْبَتَاہُ، ثُمَّ یَدَاہُ ، ثُمَّ رَأْسُہُ۔,,,2721
2722,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ سُئِلَ عَنِ الرَّجُلِ یَضَعُ یَدَیْہِ قَبْلَ رُکْبَتَیْہِ ؟ فَکَرِہَ ذَلِکَ ، وَقَالَ : ہَلْ یَفْعَلُہُ إِلاَّ مَجْنُونٌ ؟!۔",,,2722
2723,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ خَالِدٍ ، قَالَ : رَأَیْتُ أَبَا قِلاَبَۃَ إذَا سَجَدَ بَدَأَ فَوَضَعَ رُکْبَتَیْہِ ، وَإِذَا قَامَ اعْتَمَدَ عَلَی یَدَیْہِ وَرَأَیْتُ الْحَسَنَ یَخِرُّ فَیَبْدَأُ بِیَدَیْہِ ، وَیَعْتَمِدُ إذَا قَامَ۔",,,2723
2724,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَہْدِیِّ بْنِ مَیْمُونٍ ، قَالَ : رَأَیْتُ ابْنَ سِیرِینَ یَضَعُ رُکْبَتَیْہِ قَبْل یَدَیْہِ۔",,,2724
2725,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ مَعْمَرٍ ، قَالَ : سُئِلَ قَتَادَۃُ عَنِ الرَّجُلِ إذَا انْصَبَّ مِنَ الرُّکُوعِ یَبْدَأُ بِیَدَیْہِ ؟ فَقَالَ : یَصْنعُ أَہْوَنَ ذَلِکَ عَلَیْہِ۔",,,2725
2726,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ إذَا انْحَطُّوا لِلسُّجُودِ وَقَعَتْ رُکَبُہُمْ قَبْلَ أَیْدِیہِمْ۔",,,2726
2727,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ حَارِثَۃَ ، عَنْ عَمْرَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا سَجَدَ وَضَعَ یَدَیْہِ وِجَاہَ الْقِبْلَۃِ۔",,,2727
2728,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمان ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ یَقُولُ : إذَا سَجَدَ أَحَدُکُمْ فَلْیَسْتَقْبِلِ الْقِبْلَۃَ بِیَدَیْہِ ، فَإِنَّہُمَا یَسْجُدَانِ مَعَ الْوَجْہِ۔",,,2728
2729,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَانَا یَسْتَحِبَّانِ إذَا سَجَدَا أَنْ یَسْتَقْبِلاَ بِأَکُفِّہِمَا إلَی الْقِبْلَۃِ۔,,,2729
2730,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْمَسْعُودِیِّ ، عَنْ عُثْمَانَ الثَّقَفِیِّ ؛ أَنَّ عَائِشَۃَ رَأَتْ رَجُلاً مَائِلاً بِکَفَّیْہِ عَنِ الْقِبْلَۃِ ، فَقَالَتِ : اعْدِلْہُمَا إلَی الْقِبْلَۃِ۔",,,2730
2731,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ حَفْصِ بْنِ عَاصِمٍ ، قَالَ : مِنَ السُّنَّۃِ فِی الصَّلاَۃِ أَنْ یَبْسُطَ کَفَّیْہِ ، وَیَضُمَّ أَصَابِعَہُ وَیُوَجِّہَہُمَا مَعَ وَجْہِہِ إلَی الْقِبْلَۃِ۔",,,2731
2732,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ سَالِمًا ، وَالْقَاسِمَ إذَا سَجَدَا اسْتَقْبَلاَ بِأَکُفِّہِمَا إلَی الْقِبْلَۃِ۔",,,2732
2733,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عُثْمَانَ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ : أَنَّہُ کَرِہَ أَنْ یَعْدِلَ بِکَفَّیْہِ عَنِ الْقِبْلَۃِ۔",,,2733
2734,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مِسْعَرٌ ، عَنْ عُثْمَانَ ، عَنْ سَالِمٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، مِثْلَ حَدِیثِ وَکِیعٍ۔",,,2734
2735,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُجَالِدٌ ، عَنِ الشَّعْبِیِّ ، عَنْ سَعِیدِ بْنِ ذِی لَعْوَۃَ ، قَالَ : قَالَ عُمَرُ : إذَا لَمْ یَقْدِرْ أَحَدُکُمْ عَلَی السُّجُودِ یَوْمَ الْجُمُعَۃِ ، فَلْیَسْجُدْ عَلَی ظَہْرِ أَخِیہِ۔",,,2735
2736,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَقُولُ ذَلِکَ۔",,,2736
2737,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُحِبُّ أَنْ یَمْثُلَ قَائِمًا حَتَّی یَرْفَعُوا رُؤُوسَہُمْ، ثُمَّ یَسْجُدَ۔",,,2737
2738,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ طَاوُوسٍ ، قَالَ : إذَا لَمْ یَسْتَطِعْ یَوْمَ الْجُمُعَۃِ أَنْ یَسْجُدَ عَلَی الأَرْضِ فَأَہْوَی بِرَأْسِہِ ، فَلْیَسْجُدْ عَلَی ظَہْرِ أَخِیہِ۔",,,2738
2739,"حَدَّثَنَا شَرِیکٌ ، عَنِ الْعَلاَئِ بْنِ عَبْدِ الْکَرِیمِ ، قَالَ : قَالَ : مُجَاہِدٌ : أَسْجُدُ عَلَی ظَہْرِ رَجُلٍ ؟ قَالَ : نَعَمْ۔",,,2739
2740,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ ، عَنْ عَنْبَسَۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ: إذَا رَفَعَ الَّذِی بَیْنَ یَدَیْہِ رَأْسَہُ سَجَدَ۔",,,2740
2741,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنْ عُمَرَ ، قَالَ : إذَا لَمْ یَسْتَطِعِ الرَّجُلُ أَنْ یَسْجُدَ یَوْمَ الْجُمُعَۃِ ، فَلْیَسْجُدْ عَلَی ظَہْرِ أَخِیہِ۔",,,2741
2742,"حَدَّثَنَا جَرِیرٌ، عَنْ مَنْصُورٍ، عَنْ فُضَیْلٍ، عَنْ إبْرَاہِیمَ ، قَالَ: قَالَ عُمَرُ ، ثُمَّ ذَکَرَ مِثْلَ حَدِیثِ أَبِی مُعَاوِیَۃَ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ۔",,,2742
2743,"حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِیُّ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی حَبِیبَۃَ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ، قَالَ : جَائَنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَصَلَّی بِنَا فِی مَسْجِدِ بَنِی عَبْدِ الأَشْہَلِ ، فَرَأَیْتُہُ وَاضِعًا یَدَیْہِ فِی ثَوْبِہِ إذَا سَجَدَ۔ (ابن ماجہ 1031۔ احمد 4/335)",,,2743
2744,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، أَوْ وَبَرَۃَ، قَالَ: کَانَ ابْنُ عُمَرَ یَلْتَحِفُ بِالْمِلْحَفَۃِ، ثُمَّ یَسْجُدُ فِیہَا۔",,,2744
2745,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، قَالَ : رَأَیْتُ شُرَیْحًا یَسْجُدُ فِی بُرْنُسِہِ۔",,,2745
2746,حَدَّثَنَا عَلِیُّ بْنُ مِسْہِرٍ ، عَنْ أَبِی إِسْحَاقَ الشَّیْبَانِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَسْجُدُ فِی بُرْنُسٍ ، وَلاَ یُخْرِجُ یَدَیْہِ مِنْہُ۔,,,2746
2747,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَسَنِ بْنُ عُبَیْدِ اللہِ ، قَالَ : رَأَیْتُ الأَسْوَدَ یُصَلِّی فِی بُرْنُسِ طَیَالِسِہِ ، یَسْجُدُ فِیہِ ، وَرَأَیْت عَبْدَ الرَّحْمَنِ ، یَعْنِی ابْنَ یَزِیدَ ، یُصَلِّی فِی بُرْنُسٍ شَامِیٍّ یَسْجُدُ فِیہِ۔",,,2747
2748,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَسْجُدُ فِی طَیْلَسَانِہِ۔,,,2748
2749,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، قَالَ : رَأَیْتُ یَحْیَی بْنَ وَثَّابٍ یُصَلِّی فِی مُسْتُقَۃٍ بَیْنَ أُسْطُوَانَتَیْنِ یَؤُمُّ الْقَوْمَ ، وَیَدَاہُ فِی جَوْفِہَا۔",,,2749
2750,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، قَالَ : رَأَیْتُ الْحَسَنَ یَلْبَسُ أَنْبِجَانِیًّا فِی الشِّتَائِ ، یُصَلِّی فِیْہِ ، وَلاَ یُخْرِجُ یَدَیْہِ مِنْہُ۔",,,2750
2751,حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ نَافِعٍ ؛ رَأَیْت سَعِیدَ بْنَ جُبَیْرٍ یُصَلِّی فِی بُرْنُسٍ ، وَلاَ یُخْرِجُ یَدَیْہِ مِنْہُ۔,,,2751
2752,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : کَانَ عَلْقَمَۃُ ، وَمَسْرُوقٌ یُصَلُّونَ فِی بَرَانِسِہِمْ وَمُسْتُقَاتِہِمْ ، وَلاَ یُخْرِجُونَ أَیْدِیَہُمْ۔",,,2752
2753,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحِلٍّ ، قَالَ : رَأَیْتُ إبْرَاہِیمَ لاَ یُخْرِجُ یَدَیْہِ مِنَ الْمُسْتُقَۃِ۔",,,2753
2754,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إِنَّ أَصْحَابَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْجُدُونَ وَأَیْدِیہِمْ فِی ثِیَابِہِمْ ، وَیَسْجُدُ الرَّجُلُ مِنْہُمْ عَلَی عِمَامَتِہِ۔",,,2754
2755,حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ؛ أَنَّ أَبَا قِلاَبَۃَ کَانَ إذَا سَجَدَ أَخَرَجَ یَدَیْہِ مِنْ ثَوْبِہِ۔,,,2755
2756,"حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ مُحَمَّدٍ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، قَالَ : رَأَیْتُ سَالِمًا إذَا سَجَدَ أَخْرَجَ یَدَیْہِ مِنْ بُرْنُسِہِ، حَتَّی یَضَعَہُمَا عَلَی الأَرْضِ۔",,,2756
2757,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْن عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یُبَاشِرُ بِکَفَّیْہِ الأَرْضَ إذَا سَجَدَ۔",,,2757
2758,"حَدَّثَنَا وَکِیعٌ ، عَنْ الْحَسَنِ بْنِ صَالِحٍ ، عَنْ مُوسَی بْنِ أَبِی عَائِشَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی عَاصِمٍ ، عَنْ أَبِی ہِنْدٍ الشَّامِیِّ ، قَالَ : قَالَ عُمَرُ : إذَا سَجَدَ أَحَدُکُمْ فَلْیُبَاشِرْ بِکَفَّیْہِ الأَرْضَ ، لَعَلَّ اللَّہَ یَصْرِفُ عَنْہُ الْغَالَّ، إِنْ غُلَّ یَوْمَ الْقِیَامَۃِ۔",,,2758
2759,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنِ ابْنِ أَبِی الْہُذَیْلِ ؛ أَنَّہُ کَانَ إذَا أَرَادَ أَنْ یَسْجُدَ أَخْرَجَ یَدَیْہِ مِنَ الطَّیْلَسَانِ۔,,,2759
2760,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ؛ أَنَّ ابْنَ عُمَرَ کَانَ یُخْرِجُ یَدَیْہِ إذَا سَجَدَ ، وَإِنَّہُمَا لَیَقْطُرَانِ دَمًا۔,,,2760
2761,"حَدَّثَنَا مَالِکُ بْنُ إسْمَاعِیلَ ، قَالَ : حدَّثَنَا عَبْدُ الْوَارِثِ ، قَالَ : أَخْبَرَنَا إِسْحَاقُ بْنُ سُوَیْد ، قَالَ : رَأَیْتُ أَبَا قَتَادَۃَ الْعَدَوِیَّ إذَا سَجَدَ یُخْرِجُ یَدَیْہِ ، یُمِسَّہُمَا الأَرْض۔",,,2761
2762,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ؛ أَنَّہُ کَانَ یَسْجُدُ عَلَی کَوْرِ الْعِمَامَۃِ۔,,,2762
2763,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ ؛أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا بِالسُّجُودِ عَلَی کَوْرِ الْعِمَامَۃِ۔,,,2763
2764,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَسْجُدُ عَلَی کَوْرِ الْعِمَامَۃِ۔,,,2764
2765,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ؛ أَنَّہُ کَانَ یَسْجُدُ وَہُوَ مُعْتَمٌّ۔,,,2765
2766,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ مُحَمَّدِ بْنِ رَاشِدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ کَانَ یَسْجُدُ عَلَی کَوْرِ الْعِمَامَۃِ ، فَقُلْتُ لَہُ ؟ فَقَالَ : إنِّی أَخَافُ عَلَی بَصَرِی مِنْ بَرْدِ الْحَصَی۔",,,2766
2767,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ بَأْسَ بِالسُّجُودِ عَلَی کَوْرِ الْعِمَامَۃِ۔",,,2767
2768,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ أَبِی وَرْقَائَ ، قَالَ : رَأَیْتُ ابْنَ أَبِی أَوْفَی یَسْجُدُ علَی کَوْرِ عِمَامَتِہِ۔",,,2768
2769,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، قَالَ : رَأَیْتُ عَبْدَ الرَّحْمَنِ بْنَ یَزِیدَ یَسْجُدُ عَلَی عِمَامَتِہِ غَلِیظَۃِ الأَکْوَارِ ، قَدْ حَالَتْ بَیْنَ جَبْہَتِہِ وَبَیْنَ الأَرْضِ۔",,,2769
2770,حَدَّثَنَا وَکِیعٌ ، عَنْ سَکَنِ بْنِ أَبِی کَرِیمَۃَ ، عَنْ مُحَمَّدِ بْنِ عُبَادَۃَ ، عَنْ مَحْمُودِ بْنِ رَبِیعٍ ، عَنْ عُبَادَۃَ بْنِ الصَّامِتِ ؛ أَنَّہُ کَانَ إذَا قَامَ إلَی الصَّلاَۃِ حَسِرَ الْعِمَامَۃَ عَنْ جَبْہَتِہِ۔,,,2770
2771,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی الثَّعْلَبِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ، عَنْ عَلِیٍّ ، قَالَ: إذَا صَلَّی أَحَدُکُمْ فَلْیَحْسِرِ الْعِمَامَۃَ عَنْ جَبْہَتِہِ۔",,,2771
2772,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ لاَ یَسْجُدُ عَلَی کَوْرِ الْعِمَامَۃِ۔",,,2772
2773,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، قَالَ : أَصَابَتْنِی شَجَّۃٌ فَعَصَبْت عَلَیْہَا عِصَابَۃً ، فَسَأَلْت عَبِیْدَۃَ: أَسْجُدُ عَلَیْہَا ؟ قَالَ : لاَ۔ (عبدالرزاق 1569)",,,2773
2774,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنْ عِیَاضِ بْنِ عَبْدِ اللہِ الْقُرَشِیِّ ؛ قَالَ : رَأَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً یَسْجُدُ عَلَی کَوْرِ الْعِمَامَۃِ ، فَأَوْمَأَ بِیَدِہِ أَنِ ارْفَعْ عِمَامَتَکَ فَأَوْمَأَ إلَی جَبْہَتِہِ۔",,,2774
2775,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُحِبُّ لِلْمُعْتَمِّ أَنْ یُنَحِّیَ کَوْرَ الْعِمَامَۃِ عَنْ جَبْہَتِہِ۔,,,2775
2776,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إبْرَاہِیمَ ، قَالَ : أُبْرِزُ جَبِینِی أَحَبُّ إلَیَّ۔",,,2776
2777,حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ؛ أَنَّہُ کَرِہَ السُّجُودَ عَلَی کَوْرِ الْعِمَامَۃِ۔,,,2777
2778,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَعْفَر بْنِ بُرْقَانِ ، عَنْ مَیْمُونٍ ، قَالَ : أُبْرِزُ جَبِینِی أَحَبُّ إلَیَّ۔",,,2778
2779,حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَرِہَ السُّجُودَ عَلَی کَوْرِ الْعِمَامَۃِ۔,,,2779
2780,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ فِی الْمُعْتَمِّ ، قَالَ : یُمَکِّنُ جَبْہَتَہُ مِنَ الأَرْضِ۔",,,2780
2781,"حَدَّثَنَا وَکِیعٌ، عَنِ ابْنِ عُلاَثَۃَ، أَنَّ عُمَرَ بْنَ عَبْدِالْعَزِیزِ، قَالَ لِرَجُلٍ: لَعَلَّک فِیمَنْ یَسْجُدُ عَلَی کَوْرِ الْعِمَامَۃِ؟!",,,2781
2782,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ جَعْدَۃَ بْنِ ہُبَیْرَۃَ ؛ أَنَّہُ رَأَی رَجُلاً یَسْجُدُ وَعَلَیْہِ مِغْفَرَۃٌ وَعِمَامَۃٌ ، قَدْ غَطَّی بِہِمَا وَجْہَہُ ، فَأَخَذَ بِمِغْفَرِہِ وَعِمَامَتِہِ فَأَلْقَاہ مِنْ خَلْفِہِ۔,,,2782
2783,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : صَلَّی عُمَرُ ذَاتَ یَوْمٍ بِالنَّاسِ الْجُمُعَۃَ ، فِی یَوْمٍ شَدِیدِ الْحَرِّ ، فَطَرَحَ طَرَفَ ثَوْبِہِ بِالأَرْضِ ، فَجَعَلَ یَسْجُدُ عَلَیْہِ ، ثُمَّ قَالَ : یَا أَیُّہَا النَّاسُ ، إذَا وَجَدَ أَحَدُکُمُ الْحَرَّ فَلْیَسْجُدْ عَلَی طَرَفِ ثَوْبِہِ۔",,,2783
2784,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنْ عُمَرَ ، قَالَ : إذَا لَمْ یَسْتَطِعْ أَحَدُکُمْ أَنْ یَسْجُدَ عَلَی الأَرْضِ مِنَ الْحَرِّ وَالْبَرْدِ ، فَلْیَسْجُدْ عَلَی ثَوْبِہِ۔",,,2784
2785,"حَدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ ، عَنْ غَالِبٍ ، عَنْ بَکْرٍ ، عَنْ أَنَسٍ ، قَالَ : کُنَّا نُصَلِّی مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی شِدَّۃِ الْحَرِّ ، فَإِذَا لَمْ یَسْتَطِعْ أَحَدُنَا أَنْ یُمَکِّنَ وَجْہَہُ مِنَ الأَرْضِ بَسَطَ ثَوْبَہُ فَسَجَدَ عَلَیْہِ۔\n\n(مسلم 191۔ ابوداؤد 660)",,,2785
2786,حَدَّثَنَا شَرِیکٌ ، عَنْ حُسَیْنٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی ثَوْبٍ وَاحِدٍ ، یَتَّقِی بِفُضُولِہِ حَرَّ الأَرْضِ ، وَبَرْدَہَا۔ (احمد 1/354۔ عبدالرزاق 1369),,,2786
2787,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عُمَرُ : إذَا وَجَدَ أَحَدُکُمْ حَرَّ الأَرْضِ ، فَلْیَضَعْ ثَوْبَہُ بَیْنَہُ وَبَیْنَ الأَرْضِ ، ثُمَّ لْیَسْجُدْ عَلَیْہِ۔",,,2787
2788,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ قَالَ : إذَا کَانَ حَرٌّ ، أَوْ بَرْدٌ فَلْیَسْجُدْ عَلَی ثَوْبِہِ۔",,,2788
2789,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، قَالَ : رَأَیْتُ مُجَاہِدًا فِی الْمَسْجِدِ الْحَرَامِ فِی یَوْمٍ حَارٍّ ، بَسَطَ ثَوْبَہُ فَسَجَدَ عَلَیْہِ۔",,,2789
2790,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ ہِشَامِ بْنِ سَعِیدٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، قَالَ : قُلْتُ لِعَطَائِ بْنِ یَسَارٍ : أَسْجُدُ عَلَی ثَوْبِی ؟ قَالَ : ثِیَابِی مِنِّی۔",,,2790
2791,حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَسْجُدَ الرَّجُلُ عَلَی الثَّوْبِ۔,,,2791
2792,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : أَسْجُدُ عَلَی ثَوْبِی إذَا آذَانِی الْحَرُّ ، فَأَمَّا عَلَی ظَہْرِ رَجُلٍ فَلاَ۔",,,2792
2793,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا سَجَدَتِ الْمَرْأَۃُ فَلْتَحْتَفِز ، وَلْتَضُمَّ فَخِذَیْہَا۔",,,2793
2794,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقْرِیء ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ بُکَیْرِ بْنِ عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ سُئِلَ عَنْ صَلاَۃِ الْمَرْأَۃِ ؟ فَقَالَ : تَجْتَمِعُ وَتَحْتَفِزُ۔",,,2794
2795,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا سَجَدَتِ الْمَرْأَۃُ فَلْتَضُمَّ فَخِذَیْہَا ، وَلْتَضَعْ بَطْنَہَا عَلَیْہِمَا۔",,,2795
2796,حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَضَعَ الرَّجُلُ بَطْنَہُ عَلَی فَخِذَیْہِ إذَا سَجَدَ کَمَا تَصْنَعُ الْمَرْأَۃُ۔,,,2796
2797,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : الْمَرْأَۃُ تَضْطَمُّ فِی السُّجُودِ۔",,,2797
2798,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا سَجَدَتِ الْمَرْأَۃُ فَلْتَلْزَقْ بَطْنَہَا بِفَخِذَیْہَا ، وَلاَ تَرْفَعْ عَجِیزَتَہَا ، وَلاَ تُجَافِی کَمَا یُجَافِی الرَّجُلُ۔",,,2798
2799,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ زُرْعَۃَ بْنِ إِبْرَاہِیمَ ، عَن خَالِدِ بْنِ اللَّجْلاَجِ ، قَالَ : کُنَّ النِّسَائُ یُؤْمَرْنَ أَنْ یَتَرَبَّعْنَ إذَا جَلَسْنَ فِی الصَّلاَۃِ ، وَلاَ یَجْلِسْنَ جُلُوسَ الرِّجَالِ عَلَی أَوْرَاکِہِنَّ ، یُتَّقی ذَلِکَ عَلَی الْمَرْأَۃِ ، مَخَافَۃَ أَنْ یَکُونَ مِنْہَا الشَّیئُ۔",,,2799
2800,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ نَافِعٍ ؛ أَنَّ صَفِیَّۃَ کَانَتْ تُصَلِّی وَہِیَ مُتَرَبِّعَۃٌ۔,,,2800
2801,حَدَّثَنَا وَکِیعٌ ، عَنْ ثَوْرٍ ، عَنْ مَکْحُولٍ ؛ أَنَّ أُمَّ الدَّرْدَائِ کَانَتْ تَجْلِسُ فِی الصَّلاَۃِ کَجِلْسَۃِ الرَّجُلِ۔,,,2801
2802,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، قَالَ : تَرَبَّعُ۔",,,2802
2803,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ سَلْمٍ ، عَنْ قَتَادَۃَ ، قَالَ : تَجْلِسُ کَمَا تَرَی أَنَّہُ أَیْسَرُ۔",,,2803
2804,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : تَقْعُدُ الْمَرْأَۃُ فِی الصَّلاَۃِ کَمَا یَقْعُدُ الرَّجُلُ۔",,,2804
2805,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، قَالَ : کُنَّ نِسَائُ ابْنِ عُمَرَ یَتَرَبَّعْنَ فِی الصَّلاَۃِ۔",,,2805
2806,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا عَنْ قُعُودِ الْمَرْأَۃِ فِی الصَّلاَۃِ ؟ قَالَ : تَقْعُدُ کَیْفَ شَائَتْ۔",,,2806
2807,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : أَتَجْلِسُ الْمَرْأَۃُ فِی مَثْنَی عَلَی شِقِّہَا الأَیْسَرِ ؟ قَالَ : نَعَمْ ، قُلْتُ : ہُوَ أَحَبُّ إلَیْک مِنَ الأَیْمَنِ ؟ قَالَ : نَعَمْ ، تَجْتَمِعُ جَالِسَۃً مَا اسْتَطَاعَتْ ، قُلْتُ : تَجْلِسُ جُلُوسَ الرَّجُلِ فِی مَثْنَی ، أَوْ تُخْرِجُ رِجْلَہَا الْیُسْرَی مِنْ تَحْتِ أَلْیَتِہَا ؟ قَالَ : لاَ یَضُرُّہَا أَیُّ ذَلِکَ جَلَسَتْ إذَا اجْتَمَعَتْ۔",,,2807
2808,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : تَجْلِسُ الْمَرْأَۃُ مِنْ جَانِبٍ فِی الصَّلاَۃِ۔",,,2808
2809,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، وَإسْرَائِیلُ، عَنْ جَابِرٍ، عَنْ عَامِرٍ، قَالَ: تَجْلِسُ الْمَرْأَۃُ فِی الصَّلاَۃِ کَمَا تَیَسَّرُ۔",,,2809
2810,"حَدَّثَنَا ابْن عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یَرْفَعُ یَدَیْہِ بَیْنَ السَّجْدَتَیْنِ۔ (بخاری 738۔ ابوداؤد 721)",,,2810
2811,حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ یَحْیَی بْنِ أَبِی إِسْحَاقَ ، عَنْ أَنَسٍ ؛ أَنَّہُ کَانَ یَرْفَعُ یَدَیْہِ بَیْنَ السَّجْدَتَیْنِ۔,,,2811
2812,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَرْفَعُ یَدَیْہِ إذَا رَفَعَ رَأْسَہُ مِنَ السَّجْدَۃِ الأُولَی۔,,,2812
2813,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : رَأَیْتُ نَافِعًا وَطَاوُوسا یَرْفَعَانِ أَیْدِیَہُمَا بَیْنَ السَّجْدَتَیْنِ۔",,,2813
2814,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ أَنَّہُمَا کَانَا یَرْفَعَانِ أَیْدِیَہُمَا بَیْنَ السَّجْدَتَیْنِ۔,,,2814
2815,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : رَأَیْتُہُ یَفْعَلُہُ۔",,,2815
2816,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی فَزَارَۃَ ، قَالَ : قَالَ ابْنُ عَبَّاسٍ : یَسْجُدُ الْمَرِیضُ عَلَی الْمِرْفَقَۃِ وَالثَّوْبِ الطَّیِّبِ۔",,,2816
2817,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : حدَّثَتْنِی أُمُّ الْحَسَنِ ؛ أَنَّہَا رَأَتْ أُمَّ سَلَمَۃَ رَمِدَتْ عَیْنُہَا ، فَثَنَیْتُ لَہَا وِسَادَۃً مِنْ أَدَمٍ ، فَجَعَلَتْ تَسْجُدُ عَلَیْہَا۔",,,2817
2818,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ الْحَسَنِ ، عَنْ أُمِّ سَلَمَۃَ ، مِثْلَہُ۔,,,2818
2819,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ عَاصِمٍ ، عَنِ الْحَسَنِ ، عَنْ أُمِّہِ ، عَنْ أُمِّ سَلَمَۃَ ، مِثْلَہُ ، إِلاَّ أَنَّہُ قَالَ : اشْتَکَتْ عَیْنَہَا۔",,,2819
2820,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَنَسٍ ؛ أَنَّہُ سَجَدَ عَلَی مِرْفَقَۃٍ۔,,,2820
2821,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ أَبِی خَلْدَۃَ ، قَالَ : کَانَ أَبُو الْعَالِیَۃِ مَرِیضًا ، وَکَانَتِ الْمِرْفَقَۃُ تُثْنَی لَہُ فَیَسْجُدُ عَلَیْہَا۔",,,2821
2822,حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَسْجُدَ الرَّجُلُ عَلَی الْمِرْفَقَۃِ وَالْوِسَادَۃِ فِی السَّفِینَۃِ۔,,,2822
2823,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ؛ عَادَ ابْنُ عُمَرَ صَفْوَانَ ، فَوَجَدَہُ یَسْجُدُ عَلَی وِسَادَۃٍ فَنَہَاہُ ، وَقَالَ : أَوْمِیئْ إیمَائً۔",,,2823
2824,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، قَالَ : السُّجُودُ عَلَی الْوِسَادَۃِ مُحْدَثٌ۔",,,2824
2825,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ أَبِی حَرْبِ بْنِ أَبِی الأَسْوَدِ ، قَالَ : اشْتَکَی أَبُو الأَسْوَدِ الْفَالِجَ ، فَکَانَ لاَ یَسْجُدُ إِلاَّ مَا رَفَعْنَاہُ لَہُ ، مِرْفَقَۃً یَسْجُدُ عَلَیْہَا ، فَسَأَلْنَا عَنْ ذَلِکَ ، وَأَرْسَلَ إلَی ابْنِ عُمَرَ ، فَقَالَ: إنِ اسْتَطَاعَ أَنْ یَسْجُدَ عَلَی الأَرْضِ ، وَإِلاَّ فَیُومِیئُ إیمَائً۔",,,2825
2826,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ کَانَ یُصَلِّی عَلَی فِرَاشِہِ۔,,,2826
2827,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ أَنَّہُ کَانَ یُصَلِّی عَلَی الْفِرَاشِ الَّذِی مَرِضَ عَلَیْہِ۔,,,2827
2828,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنِ الْحَسَنِ بْنِ عُبَیْدِاللہِ، عَنْ إبْرَاہِیمَ، قَالَ: رَأَیْتُ الأَسْوَدَ یُومِیئُ فِی مَرَضِہِ۔",,,2828
2829,حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حَرْمَلَۃَ ؛ أَنَّہُ رَأَی سَعِیدَ بْنَ الْمُسَیَّبِ إذَا کَانَ مَرِیضًا لاَ یَسْتَطِیعُ الْجُلُوسَ أَوْمَأَ إیمَائً ، وَلَمْ یَرْفَعْ إلَی رَأْسِہِ شَیْئًا۔,,,2829
2830,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ یُونُسَ ، عَنِ الْحَسَنِ ، أَنَّہُمَا قَالاَ : یُصَلِّی الْمَرِیضُ عَلَی الْحَالَۃِ الَّتِی ہُوَ عَلَیْہَا۔",,,2830
2831,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أبی إسحاق عن تَمِیمَۃَ مَوْلاَۃِ وَادعَۃَ ، قَالَتْ : دَخَلَ شُرَیْحٌ عَلَی أَبِی مَیْسَرَۃَ یَعُودُہُ ، فَقَالَ لَہُ : کَیْفَ تُصَلِّی ؟ قَالَ : قَاعِدًا ، قَالَ : فَقَالَ لَہُ شُرَیْحٌ : أَنْتَ أَعْلَمُ مِنَّا۔",,,2831
2832,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، أَنَّہُ کَانَ یَقُولُ : الْمَرِیضُ إذَا لَمْ یَسْتَطِعِ السُّجُودَ أَوْمَأَ إیمَائً۔",,,2832
2833,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، قَالَ : سَأَلْتُ عَامِرًا عَنْ صَلاَۃِ الْمَرِیضِ ؟ فَقَالَ : إذَا لَمْ یَسْتَطِعْ أَنْ یَضَعَ جَبْہَتَہُ عَلَی الأَرْضِ فَلْیُومِیئْ إیمَائً ، وَلْیَجْعَلِ السُّجُودَ أَخْفَضَ مِنَ الرُّکُوعِ۔",,,2833
2834,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَبَلَۃَ بْنِ سُحَیْمٍ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ عَنْ صَلاَۃِ الْمَرِیضِ عَلَی الْعُودِ؟ فَقَالَ: لاَ آمُرُکُمْ أَنْ تَتَّخِذُوا مِنْ دُونِ اللہِ أَوْثَانًا ، إنِ اسْتَطَعْت أَنْ تُصَلِّیَ قَائِمًا ، وَإِلاَّ فَقَاعِدًا ، وَإِلاَّ فَمُضْطَجِعًا۔",,,2834
2835,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الْہَیْثُمِ ، قَالَ : دَخَلْنَا عَلَی إبْرَاہِیمَ وَہُوَ مَرِیضٌ ، وَہُوَ یُصَلِّی عَلَی شِقِّہِ الأَیْمَنِ یُومِیئُ إیمَائً۔",,,2835
2836,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ عَنْ أَبِی خَلْدَۃَ قَالَ : رَأَیْتُ أَبَا الْعَالِیَۃَ وَہُوَ مَرِیضٌ یُومِیئُ۔",,,2836
2837,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : یُصَلِّی قَاعِدًا ، فَإِنْ لَمْ یَسْتَطِعْ فَلْیُومِیء ، وَلاَ یَمَسُّ عُودًا۔",,,2837
2838,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ رَبَاحِ بْنِ أَبِی مَعْرُوفٍ ، عَنْ عَطَائٍ ؛ فِی الْمَرِیضِ إذَا لَمْ یَسْتَطِعْ أَنْ یُصَلِّیَ ، قَالَ : یُومِیئُ إیمَائً۔",,,2838
2839,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حَدَّثَنَا أَبُو عَوَانَۃَ ، عَنِ الْمُغِیرَۃِ ، عَنِ الْحَارِثِ ، قَالَ: یُصَلِّی الْمَرِیضُ إذَا لَمْ یَقْدِرْ عَلَی الْجُلُوسِ مُسْتَلْقِیًا، وَیَجْعَلُ رِجْلَیْہِ مِمَّا یَلِی الْقِبْلَۃَ، وَیَسْتَقْبِلُ بِوَجْہِہِ الْقِبْلَۃَ، یُومِیئُ إیمَائً بِرَأْسِہِ۔",,,2839
2840,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنِ الْمُخْتَارِ بْنِ فُلْفُلٍ ، قَالَ : سَأَلْتُ أَنَسًا عَنْ صَلاَۃِ الْمَرِیضِ ، کَیْفَ یُصَلِّی ؟ قَالَ : یُصَلِّی جَالِسًا ، وَیَسْجُدُ عَلَی الأَرْضِ۔",,,2840
2841,"حَدَّثَنَا حَمَّادُ بْنُ خَالِدٍ ، عَنْ عَبْدِ الْوَاحِدِ مَوْلَی عُرْوَۃَ ، عَنْ عُرْوَۃَ ، قَالَ : الْمَرِیضُ یُومِیئُ ، وَلاَ یَرْفَعُ إلَی وَجْہِہِ شَیْئًا۔",,,2841
2842,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی خُشَیْنَۃَ حَاجِبِ ابْنِ عُمَرَ ، قَالَ : دَخَلْت مَعَ الْحَکَمِ بْنِ الأَعْرَجِ عَلَی بَکْرٍ الْمُزَنِیّ وَہُوَ مَرِیضٌ ، فَقَالَ : أَصَلَّیْتُمُ الْعَصْرَ ؟ قَالُوا : نَعَمْ ، فَقَامَ فَصَلَّی صَلاَۃً فَأَخَفَّہَا لِمَرَضِہِ۔",,,2842
2843,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ زَیْدٍ ، قَالَ : حَدَّثَنَا أَبُو عَبْدِ اللہِ الشَّقَرِیُّ ، عَنْ إسْمَاعِیلَ بْنِ رَجَائِ بْنِ رَبِیعَۃَ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا عِنْدَ أَبِی سَعِیدٍ الْخُدْرِیِّ فِی مَرَضِہِ الَّذِی تُوُفِّیَ فِیہِ ، قَالَ : فَأُغْمِیَ عَلَیْہِ ، فَلَمَّا أَفَاقَ ، قَالَ : قُلْنَا لَہُ : الصَّلاَۃُ یَا أَبَا سَعِیدٍ ، قَالَ : کَفَانٍ۔\n\n قَالَ أَبُو بَکْرٍ : یُرِیدُ کَفَانٍ ، یَعْنِی أَوْمَأَ۔",,,2843
2844,"حَدَّثَنَا عَفَّانُ ، قَالَ: حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : أَخْبَرَنَا عَاصِمٌ ، قَالَ: دَخَلَ عَلَیَّ أَبُو وَائِلٍ وَأَنَا مَرِیضٌ، فَقُلْتُ لَہُ : أُصَلِّی یَا أَبَا وَائِلٍ وَأَنَا دَنِفٌ ؟ قَالَ : نَعَمْ۔",,,2844
2845,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ الْمُزَنِیّ ، قَالَ : کَانَ عُمَرَ یَکْرَہُ أَنْ یَسْجُدَ الرَّجُلُ عَلَی الْعُودِ۔",,,2845
2846,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : دَخَلَ عَبْدُ اللہِ عَلَی أَخِیہِ عُتْبَۃَ یَعُودُہُ ، فَوَجَدَہُ عَلَی عُودٍ یُصَلِّی ، فَطَرَحَہُ وَقَالَ : إنَّ ہَذَا شَیْئٌ عَرَّضَ بِہِ الشَّیْطَانُ ، ضَعْ وَجْہَک عَلَی الأَرْضِ، فَإِنْ لَمْ تَسْتَطِعْ فَأَوْمِیئْ إیمَائً۔",,,2846
2847,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : سُئِلَ عَنِ الصَّلاَۃِ عَلَی الْعُودِ فَکَرِہَہُ۔",,,2847
2848,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، قَالَ : دَخَلَ ابْنُ مَسْعُودٍ عَلَی أَخِیہِ عُتْبَۃَ وَہُوَ مَرِیضٌ ، وَہُوَ یَسْجُدُ عَلَی سِوَاکٍ ، فَرَمَی بِہِ وَقَالَ : أَوْمِیئْ إیمَائً۔",,,2848
2849,حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِید بْنِ إبْرَاہِیمَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَرِہَ الصَّلاَۃَ عَلَی الْعُودِ۔,,,2849
2850,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ إسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ مَالِکِ بْنِ عُمَیْرٍ ، قَالَ : حدَّثَنِی مَنْ رَأَی حُذَیْفَۃَ مَرِضَ ، فَکَانَ یُصَلِّی وَقَدْ جُعِلَ لَہُ وِسَادَۃٌ ، وَجُعِلَ لَہُ لَوْحٌ یَسْجُدُ عَلَیْہِ۔",,,2850
2851,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ رَزِینٍ مَوْلَی آلِ عَبَّاسٍ ، قَالَ : أَرْسَلَ إلَیَّ عَلِیُّ بْنُ عَبْدِ اللہِ بْنِ عَبَّاسٍ ، أَنْ أَرْسِلْ إلَیَّ بِلَوْحٍ مِنَ الْمَرْوَۃِ ، أَسْجُدُ عَلَیْہِ۔",,,2851
2852,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ، قَالَ : دَخَلَ عَبْدُ اللہِ عَلَی أَخِیہِ ، فَرَآہُ یُصَلِّی عَلَی عُودٍ فَانْتَزَعَہُ وَرَمَی بِہِ ، وَقَالَ : أَوْمِیئْ إیمَائً حَیْثُ مَا یَبْلُغُ رَأْسُک۔",,,2852
2853,"حَدَّثَنَا أَزْہَرُ السَّمَّانُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ؛ فِی الْمَرِیضِ إذَا لَمْ یَقْدِرْ عَلَی السُّجُودِ ، قَالَ : یُومِیئُ حَیْثُ مَا یَبْلُغُ رَأْسُہُ۔",,,2853
2854,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لِرَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ثَلاَثُ سَکَتَاتٍ: سَکْتَۃً إذَا افْتَتَحَ التَّکْبِیرَ حَتَّی یَقْرَأَ الْحَمْدَ ، وَإِذَا فَرَغَ مِنَ الْحَمْدِ حَتَّی یَقْرَأَ السُّورَۃَ ، وَإِذَا فَرَغَ مِنَ السُّورَۃِ حَتَّی یَرْکَعَ۔ (ترمذی 251۔ ابوداؤد 776)",,,2854
2855,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عُمَارَۃَ بْنِ الْقَعْقَاعِ ، عَنْ أَبِی زُرْعَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا کَبَّرَ سَکَتَ بَیْنَ التَّکْبِیرَۃِ وَالْقِرَائَۃِ۔ (بخاری 744۔ ابوداؤد 777)",,,2855
2856,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَمْرِو بْنِ مُہَاجِرٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، قَالَ : کَانَتْ لَہُ وَقْفَتَانِ : وَقْفَۃٌ إذَا کَبَّرَ ، وَوَقْفَۃٌ إذَا فَرَغَ مِنْ أُمِّ الْکِتَابِ۔",,,2856
2857,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ حُمَیْدٍ ، عَنِ الْحَسَنِ ، عَنْ سَمُرَۃََ بْنِ جُنْدُبٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَسْکُتُ سَکْتَتَیْنِ : إذَا دَخَلَ فِی الصَّلاَۃِ ، وَإِذَا فَرَغَ مِنَ الْقِرَائَۃِ ، فَأَنْکَرَ ذَلِکَ عِمْرَانُ بْنُ حُصَیْنٍ ، فَکَتَبُوا إلَی أُبَیِّ بْنِ کَعْبٍ فَکَتَبَ إلَیْہِمْ أَنْ صَدَقَ سَمُرَۃُ۔(ابوداؤد 773۔ احمد 5/23)",,,2857
2858,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ إذَا کَبَّرَ سَکَتَ ہُنَیْہَۃً ، وَإذَا قَالَ : {غَیْرِ الْمَغْضُوبِ عَلَیْہِمْ وَلاَ الضَّالِّینَ} سَکَتَ ہُنَیْہَۃً ، وَإِذَا نَہَضَ فِی الرَّکْعَۃِ الثَّانِیَۃِ لَمْ یَسْکُتْ ، وَقَالَ : {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ}۔",,,2858
2859,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : سَکَتَ الإِمَامُ سَکْتَتَیْنِ : سَکْتَۃً إذَا کَبَّرَ قَبْلَ أَنْ یَقْرَأَ ، وَسَکْتَۃً إذَا فَرَغَ مِنَ السُّورَۃِ قَبْلَ أَنْ یَرْکَعَ۔",,,2859
2860,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ الأَنْصَارِیِّ ، قَالَ: سَمِعْتُ عَبْدَ الرَّحْمَنِ الأَعْرَجَ، قَالَ : صَلَّیْت مَعَ أَبِی ہُرَیْرَۃَ ، فَلَمَّا کَبَّرَ سَکَتَ سَاعَۃً ، ثُمَّ قَالَ : {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ}۔",,,2860
2861,"حَدَّثَنَا أَبُو الأَحْوَصِِ سَلاَّمُ بْنُ سُلَیْمٍ ، عَنْ سِمَاکِ ، عَنْ مُوسَی بْنِ طَلْحَۃَ ، عَنْ أَبِیہِ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا وَضَعَ أَحَدُکُمْ وَہُوَ یُرِیدُ أَنْ یُصَلِّیَ مِثْلَ مُؤْخِرَۃِ الرَّحْلِ فَلْیُصَلِّ ، وَلاَ یُبَالِ مَنْ مَرَّ وَرَائَ ذَلِکَ۔ (ابوداؤد 685۔ ابن ماجہ 940)",,,2861
2862,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَنْ عَبْدِ اللہِ بْنِ الصَّامِتِ ، عَنْ أَبِی ذَرٍّ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا قَامَ أَحَدُکُمْ یُصَلِّی ، فَإِنَّہُ یَسْتُرُہُ إذَا کَانَ بَیْنَ یَدَیْہِ ، مِثْلُ آخِرَۃِ الرَّحْلِ۔\n\n(ابوداؤد 702۔ احمد 160۔ ابن خزیمۃ 806)",,,2862
2863,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُرَکِّزُ الْحَرْبَۃَ یَوْمَ الْعِیدِ یُصَلِّی إلَیْہَا۔ (بخاری 973۔ مسلم 246),,,2863
2864,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی إلَی عَنَزَۃٍ ، أَوْ شِبْہِہَا ، وَالطَّرِیقُ مِنْ وَرَائِہَا۔ (بخاری 499۔ ابوداؤد 688),,,2864
2865,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ مَکْحُولٍ ، قَالَ : إنَّمَا کَانَتِ الْحَرْبَۃُ تُحْمَلُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِیُصَلِّیَ إلَیْہَا۔",,,2865
2866,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : رَأَیْتُ عُمَرَ رَکَزَ عَنَزَۃً ، ثُمَّ صَلَّی إلَیْہَا ، وَالظُّعُنُ تَمُرُّ بَیْنَ یَدَیْہِ۔",,,2866
2867,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ الْوَلِیدِ بْنِ أَبِی مَالِکٍ ، عَنْ أَبِی عُبَیْدِ اللہِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : یَسْتُرُ الْمُصَلِّی فِی صَلاَتِہِ مِثْلُ مُؤْخِرَۃِ الرَّحْلِ فِی جُلَّۃِ السَّوْطِ۔",,,2867
2868,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْمُہَلَّبِ بْنِ أَبِی صُفْرَۃَ ، عَنْ رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا کَانَ بَیْنَکَ وَبَیْنَ مَنْ یَمُرُّ بَیْنَ یَدَیْک مِثْلُ مُؤْخِرَۃِ الرَّحْلِ ، فَقَدْ سَتَرَک۔",,,2868
2869,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ الْوَلِیدِ بْنِ أَبِی مَالِکٍ ، عَنْ أَبِی عُبَیْدِ اللہِ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَتْ تُرَکَّزُ لَہُ الْحَرْبَۃُ فِی الْعِیدِ ، فَیُصَلِّی إلَیْہَا۔,,,2869
2870,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : رَأَیْتُ أَنَسَ بْنَ مَالِکٍ فِی الْمَسْجِدِ الْحَرَامِ قَدْ نَصَبَ عَصًا یُصَلِّی إلَیْہَا۔",,,2870
2871,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : کَانَ الرَّبِیعُ بْنُ خُثَیْمِ إذَا اشْتَدَّ عَلَیْہِ الْحَرَّ ، رَکَزَ رُمْحَہُ فِی دَارِہِ ، ثُمَّ صَلَّی إلَیْہِ۔",,,2871
2872,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ شُعَیْبِ بْنِ الْحَبْحابِ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : یَسْتُرُ الْمُصَلِّی مَا وَرَائَ حَرْفِ الْعَلَمِ۔",,,2872
2873,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ مِسْعَرٍ ، عَنْ مَعْدَانَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إذَا صَلَّیْت فِی فَضَائٍ مِنَ الأَرْضِ ، فَأَلْقِ بسَوْطِک حَتَّی تُصَلِّیَ إلَیْہِ۔",,,2873
2874,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ ثَابِتِ بْنِ قَیْسٍ الغفاری أَبِی الْغُصْنِ ، قَالَ : رَأَیْتُ نَافِعَ بْنَ جُبَیْرٍ یُصَلِّی إلَی السَّوْطِ فِی السَّفَرِ ، وَإِلَی الْعَصَا۔",,,2874
2875,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ قَالَ : یَسْتُرُ الرَّجُلُ فِی صَلاَتِہِ مِثْلُ آخِرَۃِ الرَّحْلِ۔",,,2875
2876,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ سَلْمٍ ، عَنِ الْحَسَنِ وَقَتَادَۃَ قَالاَ : تَسْتُرُہُ مِثْلُ آخِرَۃِ الرَّحْلِ إذَا کَانَ قُدَّامَ الْمُصَلِّی۔",,,2876
2877,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : النَّہْرُ سُتْرَۃٌ۔",,,2877
2878,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ إذَا صَلَّوْا فِی فَضَائٍ أَنْ یَکُونَ بَیْنَ أَیْدِیہِمْ مَا یَسْتُرُہُمْ۔",,,2878
2879,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : أَخْبَرَنَا عَبْدُ الْمَلِکِ بْنُ الرَّبِیعِ بْنِ سَبْرَۃَ بْنِ مَعْبِدٍ الْجُہَنِیِّ ، قَالَ : أَخْبَرَنِی أَبِی ، عَنْ أَبِیہِ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِیَسْتَتِرْ أَحَدُکُمْ فِی صَلاَتِہِ وَلَوْ بِسَہْمٍ۔\n\n(احمد 3/404۔ ابن خزیمۃ 810)",,,2879
2880,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ یَزِیدَ بْنِ أَبِی عُبَیْدٍ ، عَنْ سَلَمَۃَ ، قَالَ : رَأَیْتُہ یَنْصِبُ أَحْجَارًا فِی الْبَرِّیَّۃِ ، فَإِذَا أَرَادَ أَنْ یُصَلِّیَ صَلَّی إلَیْہَا۔",,,2880
2881,حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنِ الْحَسَنِ بْنِ صَالِحٍ ، عَنْ عِیسَی بْنِ أَبِی عَزَّۃَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَانَ یُلْقِی سَوْطَہُ ، ثُمَّ یُصَلِّی إلَیْہَا۔,,,2881
2882,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جِئْتُ أَنَا وَالْفَضْلُ عَلَی أَتَانٍ ، وَالنَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی بِالنَّاسِ ، فَمَرَرْنَا عَلَی بَعْضِ الصَّفِّ ، فَنَزَلْنَا وَتَرَکْنَاہَا تَرْتَعُ ، فَلَمْ یَقُلْ لَنَا شَیْئًا۔ (مسلم 362۔ ابوداؤد 715)",,,2882
2883,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، عَنِ الْحَکَمِ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی فَضَائٍ لَیْسَ بَیْنَ یَدَیْہِ شَیْئٌ۔",,,2883
2884,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ عَطَائً عَنِ الرَّجُلِ یُصَلِّی فِی الْفَضَائِ لَیْسَ بَیْنَ یَدَیْہِ شَیْئٌ؟ قَالَ: لاَ بَأْسَ بِہِ۔",,,2884
2885,"حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ ابن مُغَفَّل یُصَلِّی وَبَیْنَہُ وَبَیْنَ الْقِبْلَۃِ فَجْوَۃٌ۔",,,2885
2886,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ الْقَاسِمَ وَسَالِمًا یُصَلِّیَانِ فِی السَّفَرِ فِی الصَّحْرَائِ إلَی غَیْرِ سُتْرَۃٍ۔",,,2886
2887,"عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، قَالَ : کَانَ أَبِی یُصَلِّی إلَی غَیْرِ سُتْرَۃٍ۔",,,2887
2888,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، قَالَ : رَأَیْتُ أَبَا جَعْفَرٍ وَعَامِرًا یُصَلِّیَانِ إلَی غَیْرِ أُسْطُوَانَۃٍ۔",,,2888
2889,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَہْدِیِّ بْنِ مَیْمُونٍ ، قَالَ : رَأَیْتُ الْحَسَنَ یُصَلِّی فِی الْجَبَّانَۃِ ، إلَی غَیْرِ سُتْرَۃٍ۔",,,2889
2890,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : رَأَیْتُ مُحَمَّدَ بْنَ الْحَنَفِیَّۃِ یُصَلِّی فِی مَسْجِدِ مِنًی وَالنَّاسُ یُصَلُّونَ بَیْنَ یَدَیْہِ ، فَجَائَ فَتًی مِنْ أَہْلِہِ فَجَلَسَ بَیْنَ یَدَیْہِ۔",,,2890
2891,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ صَفْوَانَ بْنِ سُلَیْمٍ ، عَنْ نَافِعِ بْنِ جُبَیْرٍ ، عَنْ سَہْلِ بْنِ أَبِی حَثْمۃَ ، یَبْلُغُ بِہِ ، قَالَ : إذَا صَلَّی أَحَدُکُمْ إلَی سُتْرَۃٍ فَلْیَدْنُ مِنْہَا ، لاَ یَقْطَعُ الشَّیْطَانُ عَلَیْہِ صَلاَتَہُ۔",,,2891
2892,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَبْدِ الرَّحْمَنِ بْنِ أَبِی سَعِیدٍ الْخُدْرِیِّ ، عَنْ أَبِیہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا صَلَّی أَحَدُکُمْ فَلْیُصَلِّ إلَی سُتْرَۃٍ وَلْیَدْنُ مِنْہَا ، وَلاَ یَدَعْ أَحَدًا یَمُرُّ بَیْنَہُ وَبَیْنَہَا ، فَإِنْ جَائَ أَحَدٌ یَمُرُّ فَلْیُقَاتِلْہُ ، فَإِنَّہُ شَیْطَانٌ۔\n\n(ابوداؤد 698۔ ابن حبان 2375)",,,2892
2893,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنِ الْمُغِیرَۃِ ، عَنْ أَبِی عُبَیْدَۃَ بْنِ عَبْدِ اللہِ ، عَنْ أَبِیہِ ، قَالَ : لاَ تُصَلِّیَنَّ وَبَیْنَکَ وَبَیْنَ الْقِبْلَۃِ فَجْوَۃٌ ، تَقَدَّمْ إلَی الْقِبْلَۃِ ، أَوِ اسْتَتِرْ بِسَارِیَۃٍ۔",,,2893
2894,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، عَنْ مُسْلِمِ بْنِ أَبِی مَرْیَمَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إذَا صَلَّی أَحَدُکُمْ فَلْیُصَلِّ إلَی سُتْرَۃٍ ، وَلْیَدْنُ مِنْہَا ، کَیْ لاَ یَمُرَّ الشَّیْطَانُ أَمَامَہُ۔",,,2894
2895,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ الْغَازِ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ إذَا لَمْ یَجِدْ سَبِیلاً إلَی سَارِیَۃٍ مِنْ سَوَارِی الْمَسْجِدِ ، قَالَ لِی : وَلِّنِی ظَہْرَک۔",,,2895
2896,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ سَلْمٍ ، عَنْ قَتَادَۃَ ، قَالَ یَسْتُرُ الرَّجُلُ الرَّجُلَ إذَا کَانَ جَالِسًا وَہُوَ یُصَلِّی۔,,,2896
2897,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : الرَّجُلُ یَسْتُرُ الْمُصَلِّیَ فِی الصَّلاَۃِ ، وَقَالَ ابْنُ سِیرِینَ : لاَ یَسْتُرُ الرَّجُلُ الْمُصَلِّی۔",,,2897
2898,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ کَانَ یُقْعِدُ رَجُلاً ، فَیُصَلِّی خَلْفَہُ وَالنَّاسُ یَمُرُّونَ بَیْنَ یَدَیْ ذَلِکَ الرَّجُلِ۔,,,2898
2899,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، قَالَ : حَدَّثَنَا حَمَّادٌ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ أَیَسْتُرُ النَّائِمُ ؟ قَالَ : لاَ ، قُلْتُ : فَالْقَاعِدُ ؟ قَالَ : نَعَمْ۔",,,2899
2900,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُجَالِدٍ ، عَنْ أَبِی الْوَدَّاکِ ، عَنْ أَبِی سَعِیدٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ یَقْطَعُ الصَّلاَۃَ شَیْئٌ ، وَادْرَؤُوا مَا اسْتَطَعْتُمْ ، فَإِنَّہُ شَیْطَانٌ۔ (ابوداؤد 719۔ دارقطنی 368)",,,2900
2901,"حَدَّثَنَا عَبْدَۃُ ووَکِیعٌ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، عَنْ عَلِیٍّ وَعُثْمَانَ قَالاَ : لاَ یَقْطَعُ الصَّلاَۃَ شَیْئٌ ، وَادْرَؤُوہُمْ عَنْکُمْ مَا اسْتَطَعْتُمْ۔",,,2901
2902,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ؛ أَنَّ ابْنَ عُمَرَ قِیلَ لَہُ : إنَّ عَبْدَ اللہِ بْنَ عَیَّاشٍ بْنِ أَبِی رَبِیعَۃَ یَقُولُ : یَقْطَعُ الصَّلاَۃَ الْحِمَارُ وَالْکَلْبُ ، فَقَالَ : لاَ یَقْطَعُ صَلاَۃَ الْمُسْلِمِ شَیْئٌ۔",,,2902
2903,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ قَالَ : لاَ یَقْطَعُ الصَّلاَۃَ شَیْئٌ ، وَذُبُّوا عَنْ أَنْفُسِکُمْ۔",,,2903
2904,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : جِئْت أَنَا وَالْفَضْلُ عَلَی أَتَانٍ وَالنَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی بِالنَّاسِ بِعَرَفَۃَ ، فَمَرَرْنَا عَلَی بَعْضِ الصَّفِّ فَنَزَلْنَا وَتَرَکْنَاہَا تَرْتَعُ ، فَلَمْ یَقُلْ لَنَا شَیْئًا۔",,,2904
2905,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ عَبْدِالْکَرِیمِ، قَالَ: سَأَلْتُ سَعِیدَ بْنَ الْمُسَیَّبِ؟ فَقَالَ: لاَ یَقْطَعُ الصَّلاَۃَ إِلاَّ الْحَدَثَ۔",,,2905
2906,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنِ الزِّبْرِقَانِ ، عَنْ کَعْبِ بْنِ عَبْدِ اللہِ ، عَنْ حُذَیْفَۃَ ، قَالَ : لاَ یَقْطَعُ الصَّلاَۃَ شَیْئٌ ، وَادْرَأ مَا اسْتَطَعْتَ۔",,,2906
2907,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ خَیْثَمَۃَ ، قَالَ : سَمِعْتُہُ یُحَدِّثُ عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ ، أَنَّہَا قَالَتْ : لاَ یَقْطَعُ الصَّلاَۃَ شَیْئٌ إِلاَّ الْکَلْبُ الأَسْوَدُ۔",,,2907
2908,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ یَقُولُ : لاَ یَقْطَعُ الصَّلاَۃَ شَیْئٌ إِلاَّ الْکُفْرُ۔",,,2908
2909,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حَنْظَلَۃَ ، عَنِ الْقَاسِمِ ، قَالَ : لاَ یَقْطَعُ الصَّلاَۃَ شَیْئٌ ، اللَّہُ أَقْرَبُ کُلِّ شَیْئٍ۔",,,2909
2910,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی مِنَ اللَّیْلِ وَأَنَا مُعْتَرِضَۃٌ بَیْنَہُ وَبَیْنَ الْقِبْلَۃِ ، کَاعْتِرَاضِ الْجِنَازَۃِ۔ (مسلم 267۔ ابن ماجہ 956),,,2910
2911,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : اعْزِلُوا صَلاَتَکُمْ مَا اسْتَطَعْتُمْ ، وَأَشَدُّ مَا یَتَّقِی عَلَیْہَا مَرَابِضُ الْکِلاَبِ۔",,,2911
2912,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ یَقْطَعُ الصَّلاَۃَ شَیْئٌ وَلَکِنِ ادْرَؤُوا عَنْہَا مَا اسْتَطَعْتُمْ۔",,,2912
2913,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، عَنْ عَبْدِ اللہِ بْنِ الصَّامِتِ ، عَنْ أَبِی ذَرٍّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا لَمْ یَکُنْ بَیْنَ یَدَیْہِ مِثْلَ آخِرَۃِ الرَّحْلِ ، فَإِنَّہُ یَقْطَعُ صَلاَتَہُ : الْمَرْأَۃُ وَالْحِمَارُ وَالْکَلْبُ الأَسْوَدُ ، قَالَ : قُلْتُ : یَا أَبَا ذَرٍّ ، فمَا بَالُ الْکَلْبِ الأَسْوَدِ مِنَ الْکَلْبِ الأَحْمَرِ مِنَ الْکَلْبِ الأَصْفَرِ ؟ فَقَالَ : یَا ابْنَ أَخِی ، إنِّی سَأَلْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَمَا سَأَلْتنِی ، فَقَالَ : الْکَلْبُ الأَسْوَدُ شَیْطَانٌ۔",,,2913
2914,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ مُجَاہِدٍ ، قَالَ : الْکَلْبُ الأَسْوَدُ الْبَہِیمُ شَیْطَانٌ ، وَہُوَ یَقْطَعُ الصَّلاَۃَ۔",,,2914
2915,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ مُعَاذٍ ؛ مِثْلَہُ۔,,,2915
2916,"حَدَّثَنَا أَبُو دَاوُدَ ، وَغُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی بَکْرٍ ، قَالَ : سَمِعْتُ أَنَسًا یَقُولُ : یَقْطَعُ الصَّلاَۃَ الْمَرْأَۃُ وَالْحِمَارُ وَالْکَلْبُ۔",,,2916
2917,حَدَّثَنَا أَبُو دَاوُدَ ، وَغُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ زِیَادِ بْنِ فَیَّاضٍ ، عَنْ أَبِی الأَحْوَصِ ؛ مِثْلَہُ۔,,,2917
2918,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : یَقْطَعُ صَلاَۃَ الرَّجُلِ الْمَرْأَۃُ وَالْحِمَارُ وَالْکَلْبُ۔",,,2918
2919,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ سَلْمٍ ، عَنْ قَتَادَۃَ ، قَالَ : قَالَ ابْنُ عَبَّاسٍ : یَقْطَعُ الصَّلاَۃَ الْکَلْبُ الأَسْوَدُ، وَالْمَرْأَۃُ الْحَائِضُ۔ (نسائی 827)",,,2919
2920,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ سَلْمٍ ، عَنِ الْحَسَنِ ، قَالَ : یَقْطَعُ الصَّلاَۃَ الْکَلْبُ ، وَالْمَرْأَۃُ ، وَالْحِمَارُ۔",,,2920
2921,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ ہِشَامٍ ، عَنْ یَحْیَی ، عَنْ عِکْرِمَۃَ ، قَالَ : یَقْطَعُ الصَّلاَۃَ الْکَلْبُ ، وَالْمَرْأَۃُ ، وَالْخِنْزِیرُ ، وَالْحِمَارُ ، وَالْیَہُودِیُّ ، وَالنَّصْرَانِیُّ ، وَالْمَجُوسِیُّ۔ (ابوداؤد 704)",,,2921
2922,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ زَمْعَۃَ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ، قَالَ : یَقْطَعُ الصَّلاَۃَ الْکَلْبُ ، قِیلَ لَہُ : فَالْمَرْأَۃُ؟ قَالَ : لاَ ، إنَّمَا ہُنَّ شَقَائِقُکُمْ ، أَخَوَاتُکُمْ وَأُمَّہَاتُکُمْ۔",,,2922
2923,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ ، عَنْ بَکْرٍ ؛ أَنَّ ابْنَ عُمَرَ أَعَادَ رَکْعَۃً مِنْ جِرْوٍ مَرَّ بَیْنَ یَدَیْہِ فِی الصَّلاَۃِ۔,,,2923
2924,"حَدَّثَنَا شَبَابَۃُ ، عَنْ ہِشَامِ بْنِ الْغَازِ ، قَالَ : سَمِعْتُ عَطَائً یَقُولُ : لاَ یَقْطَعُ الصَّلاَۃَ إِلاَّ الْکَلْبُ الأَسْوَدُ ، وَالْمَرْأَۃُ الْحَائِضُ۔",,,2924
2925,"مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، قَالَ : کَانَ ابْنُ مَسْعُودٍ إذَا مَرَّ أَحَدٌ بَیْنَ یَدَیْہِ وَہُوَ یُصَلِّی الْتَزَمَہُ حَتَّی یَرُدَّہُ ، وَیَقُولُ : إِنَّہُ لَیَقْطَعُ نِصْفَ صَلاَۃِ الْمَرْئِ مُرُورُ الْمَرْئِ بَیْنَ یَدَیْہِ۔",,,2925
2926,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، وَابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إِنْ مَرَّ بَیْنَ یَدَیْک فَلاَ تَرُدَّہُ۔",,,2926
2927,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ سُفْیَانَ ، عَنْ سَالِمٍ أَبِی النَّضْرِ ، عَنْ بُسْر بْنِ سَعِیدٍ ، عَنْ عَبْدِ اللہِ أَبِی جُہَیمٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ یَعْلَمُ أَحَدُکُمْ مَا لَہُ فِی الْمَمَرِّ بَیْنَ یَدَیْ أَخِیہِ وَہُوَ یُصَلِّی ۔ یعنی : مِنَ الإِثْمِ ، لَوَقَفَ أَرْبَعِینَ۔ (بخاری 510۔ ابوداؤد 701)",,,2927
2928,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، قَالَ : سَمِعْتُ عَبْدَ الْحَمِیدِ بْنَ عَبْدِ الرَّحْمَنِ عَامِلَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، وَمَرَّ رَجُلٌ بَیْنَ یَدَیْہِ وَہُوَ یُصَلِّی ، فَجَبَذَہُ حَتَّی کَادَ یَخْرِقَ ثِیَابَہُ ، فَلَمَّا انْصَرَفَ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ یَعْلَمُ الْمَارُّ بَیْنَ یَدَیِ الْمُصَلِّی ، لَأَحَبَّ أَنْ یَنْکَسِرَ فَخْذُہُ ، وَلاَ یَمُرُّ بَیْنَ یَدَیْہِ۔",,,2928
2929,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ کَہْمَسٍ ، عَنْ عَبْدِ اللہِ بْنِ بُرَیْدَۃَ ، قَالَ : رَأَی أَبِی نَاسًا یَمُرُّ بَعْضُہُمْ بَیْنَ یَدَیْ بَعْضٍ فِی الصَّلاَۃِ ، فَقَالَ : تَرَی أَبْنَائَ ہَؤُلاَئِ إذَا أَدْرَکُوا یَقُولُونَ : إنَّا وَجَدْنَا آبَائَنَا کَذَلِکَ یَفْعَلُونَ۔",,,2929
2930,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، حَدَّثَنَا عَاصِمٌ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ أَبُو سَعِیدٍ الْخُدْرِیُّ قَائِمًا یُصَلِّی ، فَجَائَ عَبْدُ الرَّحْمَنِ بْنُ الْحَارِثِ بْنِ ہِشَامٍ یَمُرُّ بَیْنَ یَدَیْہِ فَدفَعَہُ وَأَبَی إِلاَّ أَنْ یَمْضِیَ ، فَدَفَعَہُ أَبُو سَعِیدٍ فَطَرَحَہُ ، فَقِیلَ لَہُ: تَصْنَعُ ہَذَا بِعَبْدِ الرَّحْمَنِ ؟ فَقَالَ : وَاللَّہِ لَوْ أَبَی إِلاَّ أَنْ آخُذَہُ بِشَعْرِہِ ،لأَخَذْتُ۔",,,2930
2931,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَبْدِ الرَّحْمَنِ بْنِ أَبِی سَعِیدٍ الْخُدْرِیِّ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إِنْ جَائَ أَحَدٌ یَمُرُّ بَیْنَ یَدَیْہِ فَلْیُقَاتِلْہُ ، فَإِنَّمَا ہُوَ شَیْطَانٌ۔",,,2931
2932,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنِ الأَسْوَدِ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنِ اسْتَطَاعَ مِنْکُمْ أَنْ لاَ یَمُرَّ بَیْنَ یَدَیْہِ وَہُوَ یُصَلِّی فَلْیَفْعَلْ ، فَإِنَّ الْمَارَّ بَیْنَ یَدَیِ الْمُصَلِّی أَنْقَصُ مِنَ الْمُمَرِّ عَلَیْہِ۔",,,2932
2933,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : قُلْتُ لِسَعِیدِ بْنِ جُبَیْرٍ : أَدَعُ أَحَدًا یَمُرُّ بَیْنَ یَدَیَّ ؟ قَالَ : لاَ ، قُلْتُ: فَإِنْ أَبَی ، قَالَ : فَمَا تَصْنَعُ ؟ قُلْتُ : بَلَغَنِی أَنَّ ابْنَ عُمَرَ کَانَ لاَ یَدَعُ أَحَدًا یَمُرُّ بَیْنَ یَدَیْہِ ، قَالَ : إِنْ ذَہَبْتَ تَصْنَعُ صَنِیعَ ابْنِ عُمَرَ دُقَّ أَنْفُکَ۔",,,2933
2934,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی فَجَعَلَ جَدْیٌ یُرِیدُ أَنْ یَمُرَّ بَیْنَ یَدَیِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَجَعَلَ یَتَقَدَّمُ حَتَّی نَزَا الْجَدْیُ۔ (ابوداؤد 709۔ احمد 1/291),,,2934
2935,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ أُمِّہِ ، عَنْ أُمِّ سَلَمَۃَ ، قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی فَمَرَّ بَیْنَ یَدَیْہِ عَبْدُ اللہِ ، أَوْ عُمَرُ بْنُ أَبِی سَلَمَۃَ ، فَقَالَ : بِیَدِہِ ، فَرَجَعَ ، فَمَرَّتْ زَیْنَبُ ابْنَۃُ أُمِّ سَلَمَۃَ ، فَقَالَ : بِیَدِہِ ہَکَذَا ، فَمَضَتْ ، فَلَمَّا صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : ہُنَّ أَغْلَبُ۔ (احمد 6/294)",,,2935
2936,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ سُلَیْمَانُ بْنِ حَیَّانَ ، عَنْ سُلَیْمَانَ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : بَادَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِہِرٍّ ، أَوْ ہِرَّۃٍ أَنْ تَمُرَّ بَیْنَ یَدَیْہِ۔ (طبرانی 4965)",,,2936
2937,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ عَبْدِ الْعَزِیزِ التَّنُوخِیُّ ، عَنْ مَوْلًی لِیَزِیدَ بْنِ نِمْرَانَ ، عَنْ یَزِیدَ بْنِ نِمْرَانَ ، قَالَ : رَأَیْتُ رَجُلاً مُقْعَدًا ، فَقَالَ : مَرَرْتُ بَیْنَ یَدَیِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَنَا عَلَی حِمَارٍ وَہُوَ یُصَلِّی ، فَقَالَ : اللَّہُمَّ اقْطَعْ أَثَرَہُ ، فَمَا مَشَیْتُ عَلَیْہَا۔ (ابوداؤد 706۔ احمد 4/377)",,,2937
2938,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ فِطْرٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : مَرَرْت بَیْنَ یَدَیِ ابْنِ عُمَرَ وَہُوَ فِی الصَّلاَۃِ ، فَارْتَفَعَ مِنْ قُعُودِہِ ، ثُمَّ دَفَعَ فِی صَدْرِی۔",,,2938
2939,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا ہُرَیْمٌ ، عَنْ بَیَانٍ ، عَنْ وَبَرَۃَ ، قَالَ : مَا رَأَیْت أَحَدًا أَشَدَّ عَلَیْہِ أَنْ یُمَرَّ بَیْنَ یَدَیْہِ فِی صَلاَۃٍ مِنْ إبْرَاہِیمَ النَّخَعِیِّ ، وَعَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ۔",,,2939
2940,حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ وَائِلِ بْنِ حُجْرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَلَسَ ، فَثَنَی الْیُسْرَی وَنَصَبَ الْیُمْنَی ، یَعْنِی فِی الصَّلاَۃِ۔,,,2940
2941,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُسَیْنٍ الْمُعَلِّمِ ، عَنْ بُدَیْلٍ ، عَنْ أَبِی الْجَوْزَائِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا سَجَدَ فَرَفَعَ رَأْسَہُ لَمْ یَسْجُدْ حَتَّی یَسْتَوِیَ جَالِسًا ، وَکَانَ یَفْرِشُ رِجْلَہُ الْیُسْرَی، وَیَنْصِبُ رِجْلَہُ الْیُمْنَی۔",,,2941
2942,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا جَلَسَ فِی الصَّلاَۃِ افْتَرَشَ رِجْلَہُ الْیُسْرَی حَتَّی اسْوَدَّ ظَہْرُ قَدَمَیْہِ۔ (ابوداؤد 45۔ عبدالرزاق 3037)",,,2942
2943,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ سَعْدٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ قُسَیْطٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَفْتَرِشُ الْیُسْرَی ، وَیَنْصِبُ الْیُمْنَی۔",,,2943
2944,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، وَأَبُو أُسَامَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ اللہِ ، عَنِ ابْنِ عُمَرَ قَالَ : إنَّ مِنْ سُنَّۃِ الصَّلاَۃِ أَنْ تَفترِشَ الْیُسْرَی ، وَأَنْ تَنْصِبَ الْیُمْنَی۔ (بخاری 827۔ ابوداؤد 45)",,,2944
2945,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیرِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ کَعْبٍ ، قَالَ : إذَا قَعَدْتَ فَافْترِشْ رِجْلَک الْیُسْرَی ، فَإِنَّہُ أَقْوَمُ لِصَلاَتِکَ وَلِصُلْبِک۔",,,2945
2946,حَدَّثَنَا وَکِیعٌ وَالْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یَنْصِبُ الْیُمْنَی ، وَیَفْترِشُ الْیُسْرَی۔,,,2946
2947,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ رُبَّمَا أَضْجَعَ رِجْلَیْہِ جَمِیعًا ، وَرُبَّمَا أَضْجَعَ الْیُمْنَی وَنَصَبَ الْیُسْرَی ۔ وَکَانَ مُحَمَّدٌ إذَا جَلَسَ نَصَبَ الْیُمْنَی وَأَضْجَعَ الْیُسْرَی۔",,,2947
2948,حَدَّثَنَا وَکِیعٌ ، عَنْ مُحِلٍّ ، عَنْ إبْرَاہِیمَ ؛ مِثْلُ قَوْلِ مُحَمَّدٍ۔,,,2948
2949,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : نَہَانِی خَلِیلِی أَنْ أُقْعِیَ کَإِقْعَائِ الْقِرْدِ۔ (بخاری 1981۔ مسلم 85)",,,2949
2950,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَرِہَ الإِقْعَائَ فِی الصَّلاَۃِ ، وَقَالَ : عُقْبَۃُ الشَّیْطَانِ۔",,,2950
2951,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَرِہَ الإِقْعَائَ فِی الصَّلاَۃِ۔,,,2951
2952,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ سَعِیدٍ الْمَقْبُرِیِّ ، قَالَ : صَلَّیْت إلَی جَنْبِ أَبِی ہُرَیْرَۃَ ، فَانْتَصَبْتُ عَلَی صُدُورِ قَدَمِی ، فَجَذَبَنِی حَتَّی اطْمَأْنَنْت۔",,,2952
2953,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ الإِقْعَائَ ، وَالتَّوَرُّکَ۔,,,2953
2954,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ وَمُحَمَّدٍ ؛ کَرِہَا الإِقْعَائَ فِی الصَّلاَۃِ۔,,,2954
2955,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ أَنَّہُ کَرِہَ الإِقْعَائَ بَیْنَ السَّجْدَتَیْنِ۔,,,2955
2956,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حُسَیْنٍ الْمُعَلِّمِ ، عَنْ بُدَیْلٍ ، عَنْ أَبِی الْجَوْزَائِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَی عَنْ عُقْبَۃِ الشَّیْطَانِ۔",,,2956
2957,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ، عَنْ طَاوُوسٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: مِنَ السُّنَّۃِ أَنْ تَضَعَ أَلْیَتَیْک عَلَی عَقِبَیْک فِی الصَّلاَۃِ۔ (ترمذی 283۔ ابوداؤد 841)",,,2957
2958,حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، عَنْ جَابِرٍ، وَأَبِی سَعِیدٍ؛ أَنَّہُمَا کَانَا یُقْعِیَانِ بَیْنَ السَّجْدَتَیْنِ۔,,,2958
2959,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ یُقْعِی بَیْنَ السَّجْدَتَیْنِ۔",,,2959
2960,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَطِیَّۃَ ، قَالَ : رَأَیْتُ الْعَبَادَلَۃَ یُقْعُونَ فِی الصَّلاَۃِ بَیْنَ السَّجْدَتَیْنِ ، یَعْنِی عَبْدَ اللہِ بْنَ الزُّبَیْرِ ، وَابْنَ عُمَرَ ، وَابْنَ عَبَّاسٍ۔",,,2960
2961,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، قَالَ : رَأَیْتُ عَطِیَّۃَ یُقْعِی بَیْنَ السَّجْدَتَیْنِ ، فَقُلْتُ لَہُ ، فَقَالَ : رَأَیْت ابْنَ عُمَرَ ، وَابْنَ عَبَّاسٍ ، وَابْنَ الزُّبَیْرِ ، یُقْعُونَ بَیْنَ السَّجْدَتَیْنِ۔",,,2961
2962,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ سُقَیفِ بْنِ بِشْرٍ الْعِجْلِیّ ، قَالَ : رَأَیْتُ طَاوُوسًا یُقْعِی بَیْنَ أَرْبَعِ رَکَعَاتٍ حِینَ یَجْلِسُ۔",,,2962
2963,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ مُوسَی الطَّحَّانِ ، قَالَ : رَأَیْتُ مُجَاہِدًا یُقْعِی بَیْنَ السَّجْدَتَیْنِ۔۔",,,2963
2964,حَدَّثَنَا عُبَیْدُ اللہِ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ أَبِی جَعْفَرٍ؛ أَنَّہُ کَانَ یَجْلِسُ عَلَی عَقِبَیْہِ بَیْنَ السَّجْدَتَیْنِ۔,,,2964
2965,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إذَا جَلَسَ ثَنَی قَدَمَیْہِ۔,,,2965
2966,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ؛ أَنَّہُ کَانَ یُصَلِّی وَالْمَرْأَۃُ تَمُرُّ بِہِ یَمِینًا وَشِمَالاً ، فَلاَ یَرَی بِذَلِکَ بَأْسًا ، قَالَ : وَکَانَ ابْنُ سِیرِینَ إذَا قَامَتْ بِحِذَائِہِ ، سَبَّحَ بِہَا۔",,,2966
2967,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخبرنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ تَمُرَّ الْمَرْأَۃُ ، عَلی یَمِینِ الرَّجُلِ ، وَعَنْ یَسَارِہِ ، وَہُوَ یُصَلِّی۔",,,2967
2968,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ عَطَائً عَنْہُ ؟ فَلَمْ یَرَ بِہِ بَأْسًا ، قَالَ: وَحَدَّثَنِی مَنْ سَأَلَ إبْرَاہِیمَ، فَکَرِہَہُ۔",,,2968
2969,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ، قَالَ : حدَّثَتْنِی مَیْمُونَۃُ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی وَأَنَا بِحِذَائِہِ ، فَرُبَّمَا أَصَابَنِی ثَوْبُہُ إذَا سَجَدَ ،وَکَانَ یُصَلِّی عَلَی الْخُمْرَۃِ۔",,,2969
2970,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ زُہَیْرٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : حدَّثَنِی مُصْعَبُ بْنُ سَعْدٍ ، قَالَ : کَانَ حِذَائَ قِبْلَۃِ سَعْدٍ تَابُوتٌ ، وَکَانَتِ الْخَادِمُ تَجِیئُ فَتَأْخُذُ حَاجَتَہَا عَنْ یَمِینِہِ ، وَعَنْ شِمَالِہِ لاَ تَقْطَعُ صَلاَتَہُ۔",,,2970
2971,"حَدَّثَنَا غُنْدَرٌ ، عَنْ عُثْمَانَ بْنِ غِیَاثٍ ، قَالَ : سَأَلْتُ الْحَسَنَ عَنِ الْمَرْأَۃِ تَمُرُّ بِجَنْبِ الرَّجُلِ وَہُوَ یُصَلِّی ؟ فَقَالَ : لاَ بَأْسَ إِلاَّ أَنْ تَعِنَّ بَیْنَ یَدَیْہِ۔",,,2971
2972,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانَ یُکْرَہُ أَنْ تُصَلِّیَ الْمَرْأَۃُ بِحِذَائِ الرَّجُلِ إذَا کَانَ یُصَلِّی۔",,,2972
2973,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ أَبِی مَعْمَرٍ ، عَنْ أَبِی مَسْعُودٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تُجْزِیء صَلاَۃٌ لاَ یُقِیمُ الرَّجُلُ فِیہَا صُلْبَہُ فِی الرُّکُوعِ وَالسُّجُودِ۔ \n\n(ابوداؤد 581۔ احمد 4/122)",,,2973
2974,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرِو ، عَنْ عَبْدِ اللہِ بْنِ بَدْرٍ ، قَالَ : حدَّثَنِی عَبْدُ الرَّحْمَنِ بْنُ عَلِیِّ بْنِ شَیْبَانَ ، عَنْ أَبِیہِ عَلِیِّ بْنِ شَیْبَانَ ، وَکَانَ مِنَ الْوَفْدِ ، قَالَ : خَرَجْنَا حَتَّی قَدِمْنَا عَلَی نَبِیِّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَبَایَعْنَاہُ ، وَصَلَّیْنَا مَعَہُ ، فَلَمَحَ بِمُؤْخَرِ عَیْنِہِ إلَی رَجُلٍ لاَ یُقِیمُ صُلْبَہُ فِی الرُّکُوعِ وَالسُّجُودِ ، فَلَمَّا قَضَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الصَّلاَۃَ ، قَالَ : یَا مَعْشَرَ الْمُسْلِمِینَ ، لاَ صَلاَۃَ لمن لاَ یُقِیمُ صُلْبَہُ فِی الرُّکُوعِ وَالسُّجُودِ۔\n\n(احمد 4/23۔ ابن حبان 2202)",,,2974
2975,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ عَلِیِّ بْنِ یَحْیَی بْنِ خَلاَّدٍ ، عَنْ أَبِیہِ ، عَنْ عَمِّہِ ، وَکَانَ بَدْرِیًّا ، قَالَ : کُنَّا جُلُوسًا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَدَخَلَ رَجُلٌ فَصَلَّی صَلاَۃً خَفِیفَۃً لاَ یُتِمُّ رُکُوعًا ، وَلاَ سُجُودًا ، وَرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَرْمُقُہُ وَنَحْنُ لاَ نَشْعُرُ ، قَالَ : فَصَلَّی ، ثُمَّ جَائَ فَسَلَّمَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَرَدَّ عَلَیْہِ فَقَالَ : أَعِدْ فَإِنَّک لَمْ تُصَلِّ ، قَالَ : فَفَعَلَ ذَلِکَ ، ثَلاَثًا ، کُلَّ ذَلِکَ یَقُولُ لَہُ : أَعِدْ فَإِنَّک لَمْ تُصَلِّ ، فَلَمَّا کَانَ فِی الرَّابِعَۃِ ، قَالَ : یَا رَسُولَ اللہِ ، عَلِّمْنِی ، فَقَدْ وَاللَّہِ اجْتَہَدْتُ ، فَقَالَ : إذَا قُمْتَ إلَی الصَّلاَۃِ فَاسْتَقْبِلِ الْقِبْلَۃَ ، ثُمَّ کَبِّرْ ، ثُمَّ اقْرَأْ ، ثُمَّ ارْکَعْ ، حَتَّی تَطْمَئِنَّ رَاکِعًا ، ثُمَّ ارْفَعْ حَتَّی تَطْمَئِنَّ قَائِمًا ، ثُمَّ اسْجُدْ حَتَّی تَطْمَئِنَّ ساجدًا ، ثُمَّ اجْلِسْ حَتَّی تَطْمَئِنَّ جَالِسًا ، ثُمَّ قُمْ ، فَإِذَا فَعَلْتَ ذَلِکَ فَقَدْ تَمَّتْ صَلاَتُک ، وَمَا نَقَصْتَ مِنْ ذَلِکَ ، نَقَصْتَ مِنْ صَلاَتِک۔\n\n(ابوداؤد 856۔ احمد 4/340)",,,2975
2976,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ رَجُلاً دَخَلَ الْمَسْجِدَ فَصَلَّی ، وَرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی نَاحِیَۃِ الْمَسْجِدِ ،فَجَائَ فَسَلَّمَ عَلَیْہِ ، وَقَالَ لَہُ : وَعَلَیْک ، ارْجِعْ فَصَلِّ فَإِنَّک لَمْ تُصَلِّ بَعْدُ ، فَرَجَعَ ، فَسَلَّمَ عَلَیْہِ ، فَقَالَ : ارْجِعْ فَإِنَّک لَمْ تُصَلِّ بَعْدُ ، فَقَالَ لَہُ الرَّجُلُ فِی الثَّالِثَۃِ : فَعَلِّمْنِی یَا رَسُولَ اللہِ ، قَالَ : إذَا قُمْتَ إلَی الصَّلاَۃِ فَأسْبِغِ الْوُضُوئَ ، ثُمَّ اسْتَقْبِلِ الْقِبْلَۃَ فَکَبِّرْ، ثُمَّ اقْرَأْ بِمَا تَیَسَّرَ مَعَک مِنَ الْقُرْآنِ ، ثُمَّ ارْکَعْ حَتَّی تَطْمَئِنَّ رَاکِعًا ، ثُمَّ ارْفَعْ حَتَّی تَعْتَدِلَ قَائِمًا، ثُمَّ اسْجُدْ حَتَّی تَطْمَئِنَّ سَاجِدًا ، ثُمَّ ارْفَعْ حَتَّی تَسْتَوِیَ قَائِمًا ، أَو قَالَ : قَاعِدًا ، ثُمَّ افْعَلْ ذَلِکَ فِی صَلاَتِکَ کُلِّہَا۔ (بخاری 6667۔ مسلم 298)",,,2976
2977,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : أَخْبَرَنَا عَلِیُّ بْنُ زَیْدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّ أَسْوَأَ النَّاسِ سَرِقَۃً الَّذِی یَسْرِقُ صَلاَتَہُ ، قَالُوا : یَا رَسُولَ اللہِ ، کَیْفَ یَسْرِقُہَا ؟ قَالَ : لاَ یُتِمُّ رُکُوعَہَا ، وَلاَ سُجُودَہَا۔ (احمد 3/56۔ ابویعلی 1306)",,,2977
2978,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا سُلَیْمَانُ بْنُ الْمُغِیرَۃِ ، قَالَ : حَدَّثَنَا ثَابِتٌ ، عَنْ أَنَسٍ ، قَالَ : وَصَفَ لَنَا أَنَسٌ صَلاَۃَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ قَامَ یُصَلِّی ، فَرَکَعَ فَرَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ ، فَاسْتَوَی قَائِمًا حَتَّی رَأَی بَعْضُنَا أَنَّہُ قَدْ نَسِیَ ، قَالَ : ثُمَّ سجد فَاسْتَوَی قَاعِداً حَتَّی رَأَی بَعْضُنَا أَنَّہُ قَدْ نَسِیَ۔\n\n(بخاری 821۔ مسلم 195)",,,2978
2979,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ سَالِمٍ الْبَرَّادِ ، قَالَ : أَتَیْنَا أَبَا مَسْعُودٍ الأَنْصَارِیَّ فِی بَیْتِہِ فَقُلْنَا لَہُ : حَدِّثْنَا عَنْ صَلاَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَامَ یُصَلِّی بَیْنَ أَیْدِینَا ، فَلَمَّا رَکَعَ وَضَعَ کَفَّیْہِ عَلَی رُکْبَتَیْہِ ، وَجَعَلَ أَصَابِعَہُ أَسْفَلَ مِنْ ذَلِکَ ، وَجَافَی بِمِرْفَقَیْہِ حَتَّی اسْتَوَی کُلُّ شَیْئٍ مِنْہُ ، ثُمَّ رَفَعَ رَأْسَہُ، ثُمَّ قَالَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، فَقَامَ حَتَّی اسْتَوَی کُلُّ شَیْئٍ مِنْہُ ، ثُمَّ سَجَدَ فَفَعَلَ مِثْلَ ذَلِکَ ، فَصَلَّی رَکْعَتَیْنِ، فَلَمَّا قَضَاہا قَالَ : ہَکَذَا رَأَیْنا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی۔",,,2979
2980,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إنَّ الرَّجُلَ لَیُصَلِّی سِتِّینَ سَنَۃً مَا تُقْبَلُ لَہُ صَلاَۃٌ ، لَعَلَّہُ یُتِمُّ الرُّکُوعَ ، وَلاَ یُتِمُّ السُّجُودَ ، وَیُتِمُّ السُّجُودَ ، وَلاَ یُتِمُّ الرُّکُوعَ۔",,,2980
2981,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ الأَنْصَارِیِّ ، عَنْ مُحَمَّدِ بْنِ عَمْرِو بْنِ عَطَائٍ ، قَالَ : رَأَیْتُ أَبَا حُمَیْدٍ السَّاعِدِیَّ مَعَ عَشَرَۃِ رَہْطٍ مِنْ أَصْحَابِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَقَالَ لَہُم : أَلاَ أُحَدِّثُکُمْ عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالُوا : ہَاتِ ، قَالَ : رَأَیْتُہُ إذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ مَکَثَ قَائِمًا حَتَّی یَقَعَ کُلُّ عَظْمٍ مَوْضِعَہُ ، ثُمَّ یَنْحَطُّ سَاجِدًا وَیُکَبِّرُ۔",,,2981
2982,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، وَیَزِیدُ بْنُ ہَارُونَ ، عَنْ حُسَیْنٍ الْمُعَلِّمِ ، عَنْ بُدَیْلٍ ، عَنْ أَبِی الْجَوْزَائِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا رَکَعَ لَمْ یَشْخَصْ رَأْسَہُ ، وَلَمْ یُصَوِّبْہُ وَلَکِنْ بَیْنَ ذَلِکَ ، فَإِذَا رَفَعَ رَأْسَہُ مِنَ الرُّکُوعِ لَمْ یَسْجُدْ حَتَّی یَسْتَوِیَ قَائِمًا ، وَإِذَا سَجَدَ فَرَفَعَ رَأْسَہُ لَمْ یَسْجُدْ حَتَّی یَسْتَوِیَ جَالِسًا ، وَکَانَ یَقُولُ بَیْنَ کُلِّ رَکْعَتَیْنِ التَّحِیَّۃُ۔",,,2982
2983,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنْ حُذَیْفَۃَ ؛ أَنَّہُ دَخَلَ الْمَسْجِدَ فَإِذَا رَجُلٌ یُصَلِّی نَاحِیَۃً مِنْ أَبْوَابِ کِنْدَۃَ ، فَجَعَلَ لاَ یُتِمُّ الرُّکُوعَ وَالسُّجُودَ ، فَلَمَّا انْصَرَفَ ، قَالَ لَہُ حذَیْفَۃُ : مُذْ کَمْ ہَذِہِ صَلاَتُک ؟ قَالَ : مُذْ أَرْبَعِینَ سَنَۃً ، فَقَالَ حُذَیْفَۃُ : مَا صَلَّیْتَ مُذْ أَرْبَعِینَ سَنَۃً ، وَلَوْ مِتَّ وَہَذِہِ صَلاَتُک مِتَّ عَلَی غَیْرِ الْفِطْرَۃِ الَّتِی فُطِرَ عَلَیْہَا مُحَمَّدٌ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ أَقْبَلَ عَلَیْہِ یُعَلِّمُہُ ، فَقَالَ : إنَّ الرَّجُلَ لَیُخَفِّفُ الصَّلاَۃَ وَیُتِمُّ الرُّکُوعَ وَالسُّجُودَ۔ (بخاری 891۔ احمد5/384)",,,2983
2984,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخبرنَا یُونُسُ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ أَسْوَأَ النَّاسِ سَرِقَۃً الَّذِی یَسْرِقُ صَلاَتَہُ ، قَالُوا : یَا رَسُولَ اللہِ ، وَکَیْفَ یَسْرِقُ صَلاَتَہُ ؟ قَالَ : لاَ یُتِمُّ رُکُوعَہَا ، وَلاَ سُجُودَہَا۔",,,2984
2985,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی النَّضْرِ مُسْلِمٍ ، قَالَ : سَمِعْتُ حَمْلَۃَ بْنَ عَبْدِ الرَّحْمَنِ ، قَالَ : رَأَی عُبَادَۃُ رَجُلاً لاَ یُتِمُّ الرُّکُوعَ ، وَلاَ السُّجُودَ ، فَأَخَذَ بِیَدِہِ ، فَفَزِعَ الرَّجُلُ ، فَقَالَ عُبَادَۃُ : لاَ تَشَبَّہُوا بِہَذَا ، وَلاَ بِأَمْثَالِہِ ، إِنَّہُ لاَ تُجْزِیٔ صَلاَۃٌ إِلاَّ بِأُمِّ الْکِتَابِ۔",,,2985
2986,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنِ الْقَاسِمِ بْنِ عَمْرٍو ، عَنْ أَبِی جَعْفَرٍ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَأَی رَجُلاً یَنْکُتُ بِرَأْسِہِ فِی سُجُودِہِ، فَقَالَ: لَوْ مَاتَ ہَذَا، وَہَذِہِ صَلاَتُہُ ، مَاتَ عَلَی غَیْرِ دِینِی۔ (بخاری 2690۔ ابن خزیمۃ 665)",,,2986
2987,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ أَبِی یَحْیَی ، عَنْ أَبِیہِ ؛ أَنَّ أَبَا ہُرَیْرَۃَ رَأَی امْرَأَۃً تُصَلِّی وَہِیَ تَنْقُرُ، فَقَالَ : کَذَبْتِ۔",,,2987
2988,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ قُرَّۃَ ، عَنِ الْحَسَنِ ، قَالَ : رَأَی سَعِیدُ بْنُ الْمُسَیَّبِ رَجُلاً یُصَلِّی ، وَلاَ یُتِمُّ رُکُوعَہُ ، وَلاَ سُجُودَہُ ، فَحَصَبَہُ ، وَقَالَ : أَغْلَقْتَ صَلاَتَک۔",,,2988
2989,"حَدَّثَنَا وَکِیعٌ ، قَالَ : سَمِعْتُ الأَعْمَش یَقُولُ : رَأَیْت أَنَسَ بْنَ مَالِکٍ بِمَکَّۃَ قَائِمًا یُصَلِّی عِنْدَ الْکَعْبَۃِ ، فَمَا عَرَضْتُ لَہُ ، قَالَ : فَکَانَ قَائِمًا یُصَلِّی مُعْتَدِلاً فِی صَلاَتِہِ ، فَإِذَا رَفَعَ رَأْسَہُ انْتَصَبَ قَائِمًا ، حَتَّی تَسْتَوِیَ غُضُونُ بَطْنِہِ۔",,,2989
2990,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ أَبِی فَرْوَۃَ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : دَخَلَ الْمَسْجِدَ رَجُلٌ فَصَلَّی صَلاَۃً لاَ یُتِمُّ رُکُوعَہَا ، وَلاَ سُجُودَہَا ، قَالَ : فَذَکَرْت ذَلِکَ لِعَبْدِ اللہِ بْنِ یَزِیدَ ، فَقَالَ : ہِیَ عَلَی مَا فِیہَا خَیْرٌ مِنْ تَرْکِہَا۔",,,2990
2991,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنِ الْمِسْوَرِ بْنِ مَخْرَمَۃَ ؛ أَنَّہُ رَأَی رَجُلاً لاَ یُتِمُّ رُکُوعَہُ ، وَلاَ سُجُودَہُ ، فَقَالَ لَہُ : أَعِدْ ، فَأَبَی ، فَلَمْ یَدَعْہُ حَتَّی أَعَادَ۔",,,2991
2992,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ مُوسَی بْنِ مُسْلِمٍ ، قَالَ : جَائَ رَجُلٌ یُصَلِّی وَطَاوُوس جَالِسٌ فَجَعَلَ لاَ یُتِمُّ الرُّکُوعَ ، وَلاَ السُّجُودَ ، فَقَالَ بَعْضُ الْقَوْمِ : مَا لِہَذَا صَلاَۃٌ ، فَقَالَ طَاوُوس : مَہْ ،یُکْتَبُ لَہُ مِنْہَا بِقَدْرِ مَا أَدَّی۔",,,2992
2993,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُطَرِّفٍ ، عَنْ یَحْیَی بْنِ عُبَیْدٍ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ لاَ یُتِمُّ الرُّکُوعَ ، وَلاَ السُّجُودَ ؟ فَقَالَ : ہِیَ خَیْرٌ مِنْ لاَ شَیْئَ۔",,,2993
2994,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَمْرٍو الْمُلاَئِیِّ ، عَنْ أَبِی قَیْسٍ ، عَنْ مَسْرُوقٍ ؛ أَنَّہُ رَأَی رَجُلاً یُصَلِّی ، فَأَبْصَرَہُ رَافِعًا رِجْلَیْہِ وَہُوَ سَاجِدٌ ، فَقَالَ : مَا تَمَّتْ صَلاَۃُ ہَذَا۔",,,2994
2995,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ؛ أَنَّہُ رَأَی رَجُلاً سَاجِدًا قَدْ رَفَعَ إحْدَی رِجْلَیْہِ ، فَقَالَ : جَعَلَہَا اللَّہُ سِتًّا ، وَجَعَلْتَہَا خَمْسًا۔",,,2995
2996,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنْ سَلْمَانَ الْفَارِسِیِّ، قَالَ: الصَّلاَۃُ مِکْیَالٌ ، فَمَنْ أَوْفَی أَوْفَی اللَّہُ لَہُ ، وَقَدْ عَلِمْتُمْ مَا قَالَ اللَّہُ فِی الْکَیْلِ : {وَیْلٌ لِلْمُطَفِّفِینَ}۔",,,2996
2997,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ: حَدَّثَنَا سُفْیَانُ ، عَنْ حَجَّاجِ بْنِ فُرَافِصَۃَ ، عَمَّنْ ذَکَرَہُ ، عَنْ أَبِی الدَّرْدَائِ؛ أَنَّہُ مَرَّ بِرَجُلٍ لاَ یُتِمُّ الرُّکُوعَ ، وَلاَ السُّجُودَ ، فَقِیلَ لَہُ ، فَقَالَ أَبُو الدَّرْدَائِ : شَیْئٌ خَیْرٌ مِنْ لاَ شَیْئَ۔",,,2997
2998,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ مُفَضَّلِ بْنِ مُہَلْہَلٍ ، عَنْ بَیَانٍ ، عَنْ قَیْسٍ ؛ أَنَّ بِلاَلاً رَأَی رَجُلاً لاَ یُتِمُّ الرُّکُوعَ ، وَلاَ السُّجُودَ ، فَقَالَ : لَوْ مَاتَ ہَذَا مَاتَ عَلَی غَیْرِ مِلَّۃِ عِیسَی ابْنِ مَرْیَمَ۔",,,2998
2999,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنِ الْحَسَنِ بْنِ الْحُرِّ ، عَنِ الْقَاسِمِ بْنِ مُخَیْمِرَۃَ ، قَالَ : أَخَذَ عَلْقَمَۃُ بِیَدِی ، فَقَالَ : أَخَذَ عَبْدُ اللہِ بِیَدِی ، فَقَالَ : أَخَذَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِیَدِی فَعَلِّمنِی التَّشَہُّدَ : التَّحِیَّاتُ لِلَّہِ ، وَالصَّلَوَاتُ ، وَالطَّیِّبَاتُ ، السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ۔\n\n(احمد 1/450۔ ابن حبان 1963)",,,2999
3000,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَاالأَعْمَش ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : کُنَّا نُصَلِّی خَلْفَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَنَقُولُ : السَّلاَمُ عَلَی اللہِ قَبْلَ عِبَادِہِ ، السَّلاَمُ عَلَی جِبْرِیلَ ، السَّلاَمُ عَلَی مِیکَائِیلَ ، السَّلاَمُ عَلَی فُلاَنٍ وَفُلاَنٍ ، فَلَمَّا قَضَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ: إنَّ اللَّہَ ہُوَ السَّلاَمُ ، فَإِذَا جَلَسَ أَحَدُکُمْ فِی صَلاَتِہِ فَلْیَقُلِ : التَّحِیَّاتُ لِلَّہِ وَالصَّلَوَاتُ وَالطَّیِّبَاتُ ، السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ، ثُمَّ یَتَخَیَّرُ۔ (بخاری 6230۔ مسلم 302)",,,3000
3001,حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَبْدِ اللہِ ؛ مِثْلَ حَدِیثِ أَبِی وَائِلٍ، عَنْ عَبْدِاللہِ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی التَّشَہُّدِ۔ (احمد 1/413۔ طبرانی 9931),,,3001
3002,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنُ بْنُ عَبْدِ الرَّحْمَنِ ، وَمُغِیرَۃُ ، وَالأَعْمَش ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : کُنَّا إذَا جَلَسْنَا خَلْفَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الصَّلاَۃِ نَقُولُ : السَّلاَمُ عَلَی اللہِ ، السَّلاَمُ عَلَی جبریلَ ، السَّلاَمُ عَلَی مِیکَائِیلَ ، السَّلاَمُ عَلَی فُلاَنٍ وَفُلاَنٍ ، قَالَ : فَالْتَفَتَ إلَیْنَا النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إنَّ اللَّہَ ہُوَ السَّلاَمُ ، فَقُولُوا : التَّحِیَّاتُ لِلَّہِ وَالصَّلَوَاتُ وَالطَّیِّبَاتُ ، السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ، فَإِنَّکُمْ إذَا فَعَلْتُمْ ذَلِکَ ، فَقَدْ سَلَّمْتُمْ عَلَی کُلِّ عَبْدٍ صَالِحٍ فِی السَّموَاتِ وَالأَرْضِ۔\n\n(بخاری 7381۔ مسلم 302)",,,3002
3003,"حَدَّثَنَا أَبُو نُعَیْمٍ ، قَالَ : حدَّثَنَا سَیْفُ بْنُ أَبِی سُلَیْمَانَ ، قَالَ : سَمِعْتُ مُجَاہِدًا یَقُولُ : حَدَّثَنِی عَبْدُ اللہِ بْنُ سَخْبَرَۃَ ، قَالَ : سَمِعْتُ ابْنَ مَسْعُودٍ یَقُولُ : عَلَّمَنِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ التَّشَہُّدَ ، کَفِّی بَیْنَ کَفَّیْہِ، کَمَا یُعَلِّمُنِی السُّورَۃَ مِنَ الْقُرْآنِ : التَّحِیَّاتُ لِلَّہِ ، وَالصَّلَوَاتُ وَالطَّیِّبَاتُ ، السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ، وَہُوَ بَیْنَ ظَہْرَانَیْنَا ، فَلَمَّا قُبِضَ قُلْنَا : السَّلاَمُ عَلَی النَّبِیِّ۔ (بخاری 6265۔ مسلم 59)",,,3003
3004,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ، قَالَ: عَلَّمَنِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ التَّشَہُّدَ : التَّحِیَّاتُ لِلَّہِ ، وَالصَّلَوَاتُ وَالطَّیِّبَاتُ ، السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ۔\n\n(احمد 1/376)",,,3004
3005,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، قَالَ : حدَّثَنِی قَتَادَۃُ ، عَنْ یُونُسَ بْنِ جُبَیْرٍ ، عَنْ حِطَّانَ بْنِ عَبْدِ اللہِ ، عَنْ أَبِی مُوسَی ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا کَانَ عِنْدَ الْقَعْدَۃِ فَلْیَکُنْ مِنْ قَوْلِ أَحَدِکُمْ : التَّحِیَّاتُ الطَّیِّبَاتُ الصَّلَوَاتُ لِلَّہِ ، السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ۔",,,3005
3006,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ أَیْمَنَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ : بِسْمِ اللہِ ، وَبِاللَّہِ ، التَّحِیَّاتُ لِلَّہِ ، وَالصَّلَوَاتُ لِلَّہِ ، السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ، أَسْأَلُ اللَّہَ الْجَنَّۃَ ، وَأَعُوذُ بِاللَّہِ مِنَ النَّارِ۔ (احمد 5/363۔ ابن ماجہ 902)",,,3006
3007,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُفْیَانَ ، عَنْ زَیْدٍ الْعَمِّیِّ ، عَنْ أَبِی الصِّدِّیقِ النَّاجِی ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ أَبَا بَکْرٍ کَانَ یُعَلِّمُہُمُ التَّشَہُّدَ عَلَی الْمِنْبَرِ ، کَمَا یُعَلِّمُ الصِّبْیَانَ فِی الْکُتَّابِ : التَّحِیَّاتُ لِلَّہِ وَالصَّلَوَاتُ وَالطَّیِّبَاتُ ، السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ۔ (طحاوی 264)",,,3007
3008,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی الْمُتَوَکِّلِ ، قَالَ : سَأَلْنَا أَبَا سَعِیدٍ ، عَنِ التَّشَہُّدِ ؟ فَقَالَ : التَّحِیَّاتُ الصَّلَوَاتُ الطَّیِّبَاتُ لِلَّہِ ، السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ۔ فَقَالَ أَبُو سَعِیدٍ : کُنَّا لاَ نَکْتُبُ شَیْئًا إِلاَّ الْقُرْآنَ وَالتَّشَہُّدَ۔ (ابوداؤد 240)",,,3008
3009,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدٍ الْقَارِی ، قَالَ : شَہِدْت عُمَرَ بْنَ الْخَطَّابِ یُعَلِّمُ النَّاسَ التَّشَہُّدَ عَلَی الْمِنْبَرِ : التَّحِیَّاتُ لِلَّہِ ، الزَّاکِیَاتُ لِلَّہِ ، الطَّیِّبَاتُ ، الصَّلَوَاتُ لِلَّہِ ، السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ۔ (مالک 53)",,,3009
3010,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الْقَاسِمِ بْنِ مُحَمَّدٍ ، قَالَ : رَأَیْتُ عَائِشَۃَ تُعِدُّ بِیَدِہَا تَقُولُ : التَّحِیَّاتُ الطَّیِّبَاتُ ، الصَّلَوَاتُ الزَّاکِیَاتُ لِلَّہِ ، السَّلاَمُ عَلَی النَّبِیِّ وَرَحْمَۃُ اللہِ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ ، قَالَ : ثُمَّ یَدْعُو لِنَفْسِہِ بِمَا بَدَا لَہُ۔",,,3010
3011,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ حَبِیبِ بْنِ الشَّہِیدِ ، قَالَ : سُئِلَ مُحَمَّدٌ عَنِ التَّشَہُّدِ ؟ فَقَالَ : التَّحِیَّاتُ الصَّلَوَاتُ الطَّیِّبَاتُ ، قَالَ : ثُمَّ قَالَ : کَانَ ابْنُ عَبَّاسٍ یَزِیدُ فِیہَا ، الْبَرَکَاتُ۔",,,3011
3012,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إبْرَاہِیمَ ؛ کَانَ عَلْقَمَۃُ یُعَلِّمُ أَعْرَابِیًّا التَّشَہُّدَ ، فَیَقُولُ عَلْقَمَۃُ : السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ وَمَغْفِرَتُہُ ، فَیُعِیدُ الأَعْرَابِیُّ ، فَقَالَ عَلْقَمَۃُ : ہَکَذَا عُلِّمْنَا۔",,,3012
3013,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سُمِعَ إبْرَاہِیمُ یُعَلِّمُ التَّشَہُّدَ ، التَّحِیَّاتُ لِلَّہِ وَالطَّیِّبَاتُ وَالصَّلَوَاتُ ، السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ ، أَشْہَدُ أَنْ لاَ إلَہَ إِلاَّ اللَّہُ ، وَأَشْہَدُ أَنَّ مُحَمَّدًا عَبْدُہُ وَرَسُولُہُ۔",,,3013
3014,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَقُولُ فِی الرَّکْعَتَیْنِ: السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ ، السَّلاَمُ عَلَیْنَا وَعَلَی عِبَادِ اللہِ الصَّالِحِینَ۔",,,3014
3015,"حَدَّثَنَا ہُشَیْمٌ بْنُ بَشِیرٍ ، قَالَ : حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ إِسْحَاقَ ، عَنْ أَبِی بُرْدَۃَ ، عَنْ أَبِی مُوسَی ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أُعْطِیتُ فَوَاتِحَ الْکَلِمِ ، وَخَوَاتِمَہُ ، وَجَوَامِعَہُ ، قَالَ : فَقُلْنَا : عَلِّمْنَا مِمَّا عَلَّمَک اللَّہُ ، قَالَ : فَعَلَّمَنَا التَّشَہُّدَ۔",,,3015
3016,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَبْدُ الرَّحْمَنِ بْنُ إِسْحَاقَ ، عَنْ مُحَارِبٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُعَلِّمُنَا التَّشَہُّدَ فِی الصَّلاَۃِ ، کَمَا یُعَلِّمُ الْمُکَتِّبُ الْوِلْدَانَ۔ (ابویعلی 5605)",,,3016
3017,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ السُّلَمِیِّ ، قَالَ : کُنَّا نَتَعَلَّمُ التَّشَہُّدَ کَمَا نَتَعَلَّمُ السُّورَۃَ مِنَ الْقُرْآنِ۔",,,3017
3018,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ، قَالَ : رَأَیْتُ عَلْقَمَۃَ یَتَعَلَّمُ التَّشَہُّدَ مِنْ عَبْدِ اللہ ، کَمَا یَتَعَلَّمُ السُّورَۃَ مِنَ الْقُرْآنِ۔",,,3018
3019,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ حُمَیْدٍ ، قَالَ : حَدَّثَنِی أَبُو الزُّبَیْرِ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُعَلِّمُنَا التَّشَہُّدَ ، کَمَا یُعَلِّمُنَا السُّورَۃَ مِنَ الْقُرْآنِ۔ (مسلم 303۔ احمد 1/315)",,,3019
3020,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَتَحَفَّظُونَ ہَذَا التَّشَہُّدَ ، تَشَہُّدَ عَبْدِ اللہِ ، وَیَتَّبِعُونَ حُرُوفَہُ حَرْفًا حَرْفًا۔",,,3020
3021,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ شَرِیکٍ ، عَنْ جَامِعِ بْنِ أَبِی رَاشِدٍ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُعَلِّمُنَا التَّشَہُّدَ کَمَا یُعَلِّمُنَا السُّورَۃَ مِنَ الْقُرْآنِ۔(ابوداؤد 961۔ احمد 394)q",,,3021
3022,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ عُمَیْرِ بْنِ سَعْیدٍ النَّخَعِیِّ ، قَالَ : أَتَیْتُ ابْنَ مَسْعُودٍ مَعَ أَبِی ، فَعَلَّمَنَا ہَذَا التَّشَہُّدَ ، یَعْنِی تَشَہُّدَ عَبْدِ اللہِ۔",,,3022
3023,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا جُوَیْبِرٌ ، عَنِ الضَّحَّاکِ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : مَا کُنَّا نَکْتُبُ فِی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنَ الأَحَادِیثِ إِلاَّ الاسْتِخَارَۃَ وَالتَّشَہُّدَ۔",,,3023
3024,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : کَانَ عَبْدُ اللہِ یُعَلِّمُنَا التَّشَہُّدَ فِی الصَّلاَۃِ ، کَمَا یُعَلِّمُنَا السُّورَۃَ مِنَ الْقُرْآنِ ، یَأْخُذُ عَلَیْنَا الأَلِفَ وَالْوَاوَ۔",,,3024
3025,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : سَمِعَ ابْنُ عَبَّاسٍ رَجُلاً یُصَلِّی ، فَلَمَّا قَعَدَ یَتَشَہَّدُ ، قَالَ : الْحَمْدُ لِلَّہِ ، التَّحِیَّاتُ لِلَّہِ ، قَالَ : فَقَالَ ابْنُ عَبَّاسٍ : وَہُوَ یَنْتَہِرُہُ ، الْحَمْدُ لِلَّہِ ، إذَا قَعَدْت فَابْدَأْ بِالتَّشَہُّدِ ، بِـ : التَّحِیَّاتِ لِلَّہِ۔",,,3025
3026,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یَأْخُذُ عَلَیْنَا الْوَاوَ فِی التَّشَہُّدِ ، الصَّلَوَاتُ وَالطَّیِّبَاتُ۔",,,3026
3027,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَتَعَلَّمُونَ التَّشَہُّدَ ، کَمَا یَتَعَلَّمُونَ السُّورَۃَ مِنَ الْقُرْآنِ۔",,,3027
3028,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ أَیْمَنَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ فِی التَّشَہُّدِ : بِسْمِ اللہِ۔",,,3028
3029,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ عُمَرَ قَالَ فِی التَّشَہُّدِ : بِسْمِ اللہِ۔",,,3029
3030,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یَقُولُ إذَا تَشَہَّدَ : بِسْمِ اللہِ ، خَیْرُ الأَسْمَائِ اسْمُ اللہِ۔",,,3030
3031,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِسْحَاقَ بْنِ یَحْیَی ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، قَالَ : سَمِعَ ابْنُ مَسْعُودٍ رَجُلاً یَقُولُ فِی التَّشَہُّدِ : بِسْمِ اللہِ ، فَقَالَ : إنَّمَا یُقَالُ ہَذَا عَلَی الطَّعَامِ۔",,,3031
3032,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یَقُولُ فِی التَّشَہُّدِ : بِسْمِ اللہِ۔",,,3032
3033,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِی عُبَیْدَۃَ ، عَنْ أَبِیہِ عَبْدِ اللہِ بْنِ مَسْعُودٍ ؛أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا قَعَدَ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ کَأَنَّہُ عَلَی الرَّضْفِ ، قُلْتُ : حتَّی یَقُومَ ؟ قَالَ : حَتَّی یَقُومَ۔ (ابوداؤد 987۔ احمد 1/386)",,,3033
3034,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ تَمِیمِ بْنِ سَلَمَۃَ ، قَالَ : کَانَ أَبُو بَکْرٍ إذَا جَلَسَ فِی الرَّکْعَتَیْنِ کَأَنَّہُ عَلَی الرَّضْفِ ، یَعْنِی حَتَّی یَقُومَ۔",,,3034
3035,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إِبْرَاہِیمَ ، عَن رَجُلٍ صَلَّی خَلْفَ أَبِی بَکْرٍ ؛ فَکَانَ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ ، کَأَنَّہُ عَلَی الْجَمْرِ حَتَّی یَقُومَ۔,,,3035
3036,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخبرنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَجْلِسُ فِی التَّشَہُّدِ فِی الرَّکْعَتَیْنِ قَدْرَ التَّشَہُّدِ مُتَرَسِّلاً ، ثُمَّ یَقُومُ۔",,,3036
3037,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عِیَاضِ بْنِ مُسْلِمٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَقُولُ : مَا جُعِلَتِ الرَّاحَۃُ فِی الرَّکْعَتَیْنِ إِلاَّ لِلتَّشَہُّدِ۔",,,3037
3038,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : لاَ یَزِیدُ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ عَلَی التَّشَہُّدِ۔",,,3038
3039,"حَدَّثَنَا جَرِیرٌ ، عَنْ نُعَیْمٍ الْقَارِیء ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : مَنْ زَادَ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ عَلَی التَّشَہُّدِ فَعَلَیْہِ سَجْدَتَا السَّہْوَ۔",,,3039
3040,"حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ بُدَیْلٍ ، عَنْ أَبِی الْجَوْزَائِ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ فِی الرَّکْعَتَیْنِ : التَّحِیَّاتُ۔ (ابوداؤد 772)",,,3040
3041,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ زِیَادِ بْنِ فَیَّاضٍ ، قَالَ : سَمِعْتُ مُصْعَبَ بْنَ سَعْدٍ یُحَدِّثُ عَنْ سَعْدٍ ؛ أَنَّہُ کَانَ إذَا تَشَہَّدَ فَقَالَ : سُبْحَانَ اللہِ مِلْئَ السَّمَاوَاتِ وَمِلْئَ الأَرْضِ ، وَمَا بَیْنَہُنَّ ، وَمَا تَحْتَ الثَّرَی ، وَالْحَمْدُ لِلَّہِ مِلْئَ السَّمَاوَاتِ وَمِلْئَ الأَرْضِ ، وَمَا بَیْنَہُنَّ ، وَمَا تَحْتَ الثَّرَی ، وَاللَّہُ أَکْبَرُ مِلْئَ السَّمَاوَاتِ وَمِلْئَ الأَرْضِ ، وَمَا بَیْنَہُنَّ ، وَمَا تَحْتَ الثَّرَی ، قَالَ شُعْبَۃُ : لاَ أَدْرِی اللَّہُ أَکْبَرُ قَبْلُ ، أَوِ الْحَمْدُ لِلَّہِ ، وَالْحَمْدُ لِلَّہِ حَمْدًا طَیِّبًا مُبَارَکًا فِیہِ ، لاَ إلَہَ إِلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ ، وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ ، اللَّہُمَّ إنِّی أَسْأَلُک مِنَ الْخَیْرِ کُلِّہِ ، ثُمَّ یُسَلِّمُ۔",,,3041
3042,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ عُمَیْرِ بْنِ سَعِیدٍ ، قَالَ : کَانَ عَبْدُ اللہِ یُعَلِّمُنَا التَّشَہُّدَ فِی الصَّلاَۃِ، ثُمَّ یَقُولُ : إذَا فَرَغَ أَحَدُکُمْ مِنَ التَّشَہُّدِ فِی الصَّلاَۃِ فَلْیَقُلِ : اللَّہُمَّ إنِّی أَسْأَلُک مِنَ الْخَیْرِ کُلِّہِ ، مَا عَلِمْت مِنْہُ ، وَمَا لَمْ أَعْلَمْ ، وَأَعُوذُ بِکَ مِنَ الشَّرِّ کُلِّہِ ، مَا عَلِمْت مِنْہُ ، وَمَا لَمْ أَعْلَمْ ، اللَّہُمَّ إنِّی أَسْأَلُک مِنْ خَیْرِ مَا سَأَلَک مِنْہُ عِبَادُک الصَّالِحُونَ ، وَأَعُوذُ بِکَ مِنْ شَرِّ مَا عَاذَ مِنْہُ عِبَادُک الصَّالِحُونَ ، رَبَّنَا آتِنَا فِی الدُّنْیَا حَسَنَۃً وَفِی الآخِرَۃِ حَسَنَۃً وَقِنَا عَذَابَ النَّارِ ، رَبَّنَا إنَّنَا آمَنَّا فَاغْفِرْ لَنَا ذُنُوبَنَا ، وَکَفِّرْ عَنَّا سَیِّئَاتِنَا ، وَتَوَفَّنَا مَعَ الأَبْرَارِ ، رَبَّنَا وَآتِنَا مَا وَعَدْتنَا عَلَی رُسُلِکَ ، وَلاَ تُخْزِنَا یَوْمَ الْقِیَامَۃِ ، إنَّک لاَ تُخْلِفُ الْمِیعَادَ۔",,,3042
3043,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، وَأَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : یَتَشَہَّدُ الرَّجُلُ ، ثُمَّ یُصَلِّی عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ یَدْعُو لِنَفْسِہِ۔",,,3043
3044,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا فَرَغْت مِنَ التَّشَہُّدِ فَادْعُ لِاٰخِرَتِکَ وَدُنْیَاک مَا بَدَا لَک۔",,,3044
3045,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ (ح) وَعَنِ الشَّیْبَانِیِّ عَنِ الشَّعْبِیِّ أَنَّہُمَا قَالاَ : اُدْعُ فِی صَلاَتِکَ بِمَا بَدَا لَک۔",,,3045
3046,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، قَالَ : قُلْتُ لِمُجَاہِدٍ : أَدْعُو لِنَفْسِی فِی الْمَکْتُوبَۃِ ؟ قَالَ : لاَ تَدْعُ لِنَفْسِکَ حَتَّی تَتَشَہَّدَ ۔ قَالَ : وَسَأَلْت عَطَائً ، فَقَالَ : تَحْتَاطُ بِالإسْتِغْفَارِ۔",,,3046
3047,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یُحِبُّونَ أَنْ یَدْعُوَ الإِمَامُ بَعْدَ التَّشَہُّدِ بِخَمْسِ کَلِمَاتٍ جَوَامِعَ : اللَّہُمَّ إنَّا نَسْأَلُک مِنَ الْخَیْرِ کُلِّہِ ، مَا عَلِمْنَا مِنْہُ ، وَمَا لَمْ نَعْلَمْ ، وَنَعُوذُ بِکَ مِنَ الشَّرِّ کُلِّہِ ، مَا عَلِمْنَا مِنْہُ ، وَمَا لَمْ نَعْلَمْ ، قَالَ : فَمَہْمَا عَجِلَ بِہِ الإِمَامُ فَلاَ یَعْجَلْ عَنْ ہَؤُلاَئِ الْکَلِمَاتِ۔",,,3047
3048,"حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ عَوْنٍ ، قَالَ : قَالَ عَبْدُ اللہِ : اُدْعُوا فِی صَلاَتِکُمْ بِأَہَمِّ حَوَائِجِکُمْ إلَیْکُمْ۔",,,3048
3049,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ عَوْنٍ ، قَالَ : اجْعَلُوا حَوَائِجَکُمُ الَّتِی تَہُمُّکُمْ فِی الصَّلاَۃِ الْمَکْتُوبَۃِ، فَإِنَّ فَضْلَ الدُّعَائِ فِیہَا کَفَضْلِ النَّافِلَۃِ۔",,,3049
3050,"حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ ، عَنْ أَبِی بُرْدَۃَ ، قَالَ : کَانَ أَبُو مُوسَی إذَا فَرَغَ مِنْ صَلاَتِہِ ، قَالَ : اللَّہُمَّ اغْفِرْ لِی ذَنْبِی ، وَیَسِّرْ لِی أَمْرِی ، وَبَارِکْ لِی فِی رِزْقِی۔",,,3050
3051,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یَسْتَحِبُّ أَنْ یَدْعُوَ فِی الْمَکْتُوبَۃِ بِدُعَائِ الْقُرْآنِ۔",,,3051
3052,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ صَدَقَۃَ بْنِ یَسَارٍ ، قَالَ : سَمِعْتُ طَاوُوسًا یَقُولُ : اُدْعُوا فِی الْفَرِیضَۃِ بِمَا فِی الْقُرْآنِ۔",,,3052
3053,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، مِثْلَ حَدِیثِ طَاوُوس۔,,,3053
3054,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ صَدَقَۃَ بْنِ یَسَارٍ ، عَنْ طَاوُوسٍ ، قَالَ : اُدْعُوا فِی الْفَرِیضَۃِ بِمَا فِی الْقُرْآنِ ، أَوَ قَالَ : فِی الْمَکْتُوبَۃِ۔",,,3054
3055,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، قَالَ : سَمِعْتُ مُحَمَّدًا ، وَسُئِلَ عَنِ الدُّعَائِ فِی الصَّلاَۃِ ؟ فَقَالَ : کَانَ أَحَبُّ دُعَائِہِمْ مَا وَافَقَ الْقُرْآنَ۔",,,3055
3056,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ یَکْرَہُ أَنْ یَدْعُوَ فِی الصَّلاَۃِ بِشَیْئٍ مِنْ أَمْرِ الدُّنْیَا۔",,,3056
3057,حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُعْجِبُہُ أَنْ یَدْعُوَ فِی الْمَکْتُوبَۃِ بِمَا فِی الْقُرْآنِ۔,,,3057
3058,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ الْعَبْدِیُّ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنْ مُصْعَبِ بْنِ ثَابِتٍ ، عَنْ إسْمَاعِیلَ بْنِ مُحَمَّدٍ ، عَنْ عَامِرِ بْنِ سَعْدٍ ، عَنْ سَعْدٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُسَلِّمُ عَنْ یَمِینِہِ ، وَعَنْ یَسَارِہِ ، حَتَّی یُرَی بَیَاضُ خَدِّہِ۔ (مسلم 119۔ احمد 1/173)",,,3058
3059,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : سَمِعْتُ أَبَا الْبَخْتَرِیِّ یُحَدِّثُ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْیَحْصُبِیِّ ، عَنْ وَائِلٍ الْحَضْرَمِیِّ ؛ أَنَّہُ صَلَّی مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَکَانَ یُکَبِّرُ إذَا خَفَضَ ، وَإِذَا رَفَعَ ، وَیَرْفَعُ یَدَیْہِ عِنْدَ التَّکْبِیرِ ، وَیُسَلِّمُ عَنْ یَمِینِہِ وَعَنْ یَسَارِہِ۔\n\n قَالَ شُعْبَۃُ : قَالَ لِی أَبَانُ بْنُ تَغْلِبَ : إنَّ فِی الْحَدِیثِ : حَتَّی یَبْدُوَ وَضَحُ وَجْہِہِ ، فَقُلْتُ لِعَمْرٍو : فِی الْحَدِیثِ : حَتَّی یَبْدُوَ وَضَحُ وَجْہِہِ ، فَقَالَ : أَوْ نَحْوُ ذَلِکَ۔ (احمد 4/316۔ طیالسی 1021)",,,3059
3060,"حَدَّثَنَا عُمَرُ بْنُ عُبَیْدٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُسَلِّمُ عَنْ یَمِینِہِ حَتَّی یَبْدُوَ بَیَاضُ خَدِّہِ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ ، وَعَنْ یَسَارِہِ مِثْلَ ذَلِکَ۔ (احمد 1/448۔ ابوداؤد 988)",,,3060
3061,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُسَلِّمُ فِی الصَّلاَۃِ عَنْ یَمِینِہِ ، وَعَنْ شِمَالِہِ حَتَّی یُرَی بَیَاضُ وَجْہِہِ وَیَقُولُ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ ، مِنْ کِلاَ الْجَانِبَیْنِ۔",,,3061
3062,"حَدَّثَنَا وَکِیعٌ ، عَنْ حُرَیْثٍ ، عَنِ الشَّعْبِیِّ ، عَنِ الْبَرَائِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُسَلِّمُ عَنْ یَمِینِہِ وَعَنْ شِمَالِہِ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ ، حَتَّی یُرَی بَیَاضُ خَدِّہِ۔ (طحاوی 269۔ دارقطنی 357)",,,3062
3063,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ عَلْقَمَۃَ، وَالأَسْوَدِ ، عَنْ عَبْدِ اللہِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُسَلِّمُ عَنْ یَمِینِہِ وَعَنْ یَسَارِہِ ، وَأَبُوبَکْرٍ، وَعُمَرُ۔ (نسائی 1242۔ طیالسی 279)",,,3063
3064,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الْعَلاَئِ بْنِ صَالِحٍ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ حُجْرِ بْنِ عَنْبَسٍ، عَنْ وَائِلِ بْنِ حُجْرٍ؛ أَنَّہُ صَلَّی خَلْفَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا قَرَأَ فَاتِحَۃَ الْکِتَابِ جَہَرَ بِآمِینَ ، قَالَ : وَسَلَّمَ عَنْ یَمِینِہِ وَعَنْ یَسَارِہِ ، حَتَّی رَأَیْت بَیَاضَ خَدَّیْہِ۔",,,3064
3065,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، قَالَ : ذُکِرَ التَّسْلِیمُ عِنْدَ شَقِیقٍ ، فَقَالَ : قَدْ صَلَّیْت خَلْفَ عُمَرَ ، وَعَبْدِ اللہِ فَکِلاَہُمَا یُسَلِّمُ یَقُولُ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ ، السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ۔",,,3065
3066,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ حَارِثَۃَ بْنِ مُضَرِّبٍ ، قَالَ : صَلَّیْت خَلْفَ عَمَّارٍ فَسَلَّمَ عَنْ یَمِینِہِ وَعَنْ شِمَالِہِ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ۔",,,3066
3067,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ فُضَیْلٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، قَالَ : کَأَنِّی أَنْظُرُ إلَی بَیَاضِ خَدِّ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَلَّمَ حِینَ سَلَّمَ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ ، السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ۔ (احمد 465)",,,3067
3068,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ شَقِیقِ بْنِ سَلَمَۃَ ، قَالَ : صَلَّیْت خَلْفَ عَلِیٍّ ، فَسَلَّمَ عَنْ یَمِینِہِ وَعَنْ شِمَالِہِ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ ، السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ۔",,,3068
3069,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إِسْمَاعِیلَ بْنِ سُمَیْعٍ ، قَالَ : سَمِعْتُ أَبَا رَزِینٍ یَقُولُ : سَمِعْت عَلِیًّا یُسَلِّمُ فِی الصَّلاَۃِ عَنْ یَمِینِہِ وَعَنْ شِمَالِہِ ، وَالَّتِی عَنْ شِمَالِہِ أَخْفَضُ۔",,,3069
3070,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنْ إبْرَاہِیمَ بْنِ سُوَیْد ، قَالَ : کَانَ عَلْقَمَۃُ یُسَلِّمُ عَنْ یَمِینِہِ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ ، وَعَنْ یَسَارِہِ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ ، قَالَ : وَکَانَ الأَسْوَدُ یَقُولُ عَنْ یَمِینِہِ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ ، وَعَنْ یَسَارِہِ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ۔",,,3070
3071,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ خَیْثَمَۃَ ، أَنَّہُ قَالَ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ، السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ۔",,,3071
3072,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُسَلِّمُ فِی الصَّلاَۃِ یَقُولُ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ ، السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ۔",,,3072
3073,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ کَانَ یُسَلِّمُ عَنْ یَمِینِہِ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ ، وَعَنْ یَسَارِہِ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ۔",,,3073
3074,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُسَلِّمُ عَنْ یَمِینِہِ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ ، یَرْفَعُ بِہَا صَوْتَہُ ، وَعَنْ یَسَارِہِ : السَّلاَمُ عَلَیْکُمْ وَرَحْمَۃُ اللہِ ، أَخْفَضَ مِنَ الأَوَّلِ۔",,,3074
3075,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ سَعِیدًا وَعَمَّارًا سَلَّمَا تَسْلِیمَتَیْنِ۔,,,3075
3076,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ إبْرَاہِیمَ بْنِ مُحَمَّدِ بْنِ الْمُنْتَشِرِ ، عَنْ أَبِیہِ ؛ أَنَّ إمَامَ مَسْجِدِ مَسْرُوقٍ کَانَ یُسَلِّمُ تَسْلِیمَتَیْنِ ، فَقُلْنَا لِمَسْرُوقٍ ؟ فَقَالَ : أَنَا أَمَرْتُہُ بِذَلِکَ۔",,,3076
3077,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، وَوَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنِ ابْنِ أَبِی لَیْلَی ؛ أَنَّہُ کَانَ یُسَلِّمُ عَنْ یَمِینِہِ وَعَنْ یَسَارِہِ : السَّلاَمُ عَلَیْکُمْ ، السَّلاَمُ عَلَیْکُمْ۔",,,3077
3078,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، عَنْ أَبِی مَعْمَرٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ قِیلَ لَہُ : إنَّ رَجُلاً مِنْ أَہْلِ مَکَّۃَ یُسَلِّمُ تَسْلِیمَتَیْنِ ، فَقَالَ عَبْدُ اللہِ : أَنَّی عَلِقَہَا ؟ ! (مسلم 117)",,,3078
3079,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ ثَابِتِ بْنِ یَزِیدَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ؛ أَنَّہُ کَانَ یُسَلِّمُ تَسْلِیمَتَیْنِ۔,,,3079
3080,حَدَّثَنَا مَخْلَدُ بْنُ یَزِیدَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ یُسَلِّمُ تَسْلِیمَتَیْنِ۔,,,3080
3081,حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَبَا بَکْرٍ ، وَعُمَرَ ، کَانُوا یُسَلِّمُونَ تَسْلِیمَۃً وَاحِدَۃً۔ (ابن ماجہ 920۔ بیہقی 179),,,3081
3082,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ حُمَیْدٍ ، قَالَ : کَانَ أَنَسٌ یُسَلِّمُ وَاحِدَۃً۔",,,3082
3083,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ سَعِیدِ بْنِ مَرْزُبَانَ ، قَالَ : صَلَّیْت خَلْفَ ابْنِ أَبِی لَیْلَی فَسَلَّمَ وَاحِدَۃً ، ثُمَّ صَلَّیْتُ خَلْفَ عَلِیٍّ فَسَلَّمَ وَاحِدَۃً۔",,,3083
3084,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ الزِّبْرِقَانِ ؛ أَنَّ أَبَا وَائِلٍ کَانَ یُسَلِّمُ تَسْلِیمَۃً۔,,,3084
3085,حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ یَحْیَی بْنِ وَثَّابٍ ؛ أَنَّہُ کَانَ یُسَلِّمُ تَسْلِیمَۃً۔,,,3085
3086,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، قَالَ : صَلَّیْت خَلْفَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، فَسَلَّمَ وَاحِدَۃً۔",,,3086
3087,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ؛ أَنَّہُمَا کَانَا یُسَلِّمَانِ تَسْلِیمَۃً عَنْ أَیْمَانِہِمَا ، وَصَلَّیْت خَلْفَ الْقَاسِمِ فَلاَ أَعْلَمُہُ خَالَفَہُمَا۔,,,3087
3088,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ خَالِدٍ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُسَلِّمُ تَسْلِیمَۃً۔,,,3088
3089,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ : حدَّثَنَا جَابِرُ بْنُ حَازِمٍ ، عَنْ أَیُّوبَ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَلَّمَ تَسْلِیمَۃً۔",,,3089
3090,حَدَّثَنَا أَبُو بَکْرٍ ، بَلَغَنِی عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنِ الْقَاسِمِ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ تُسَلِّمُ تَسْلِیمَۃً۔ (ابن خزیمۃ 732۔ بیہقی 179),,,3090
3091,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ دِرْہَمٍ ، قَالَ : رَأَیْتُ أَنَسًا ، وَالْحَسَنَ ، وَأَبَا الْعَالِیَۃِ ، وَأَبَا رَجَائٍ یُسَلِّمُونَ تَسْلِیمَۃً۔",,,3091
3092,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُلَیْمَانَ بْنِ زَیْدٍ ، قَالَ : رَأَیْتُ ابْنَ أَبِی أَوْفَی یُسَلِّمُ تَسْلِیمَۃً۔",,,3092
3093,حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ دِینَارٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُسَلِّمُ تَسْلِیمَۃً۔,,,3093
3094,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ وِقَائٍ ؛ أَنَّ سَعِیدَ بْنَ جُبَیْرٍ کَانَ یُسَلِّمُ تَسْلِیمَۃً۔,,,3094
3095,"حَدَّثَنَا مُصْعَبُ بْنُ الْمِقْدَامِ ، قَالَ : حدَّثَنَا إسْرَائِیلُ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ سُوَیْد ؛ أَنَّہُ کَانَ یُسَلِّمُ تَسْلِیمَۃً وَاحِدَۃً۔",,,3095
3096,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ إسْمَاعِیلَ ، عَنْ قَیْسٍ ، أَنَّہُ کَانَ یُسَلِّمُ تَسْلِیمَۃً۔,,,3096
3097,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، قَالَ : کَانَ عَبْدُ اللہِ إذَا قَضَی الصَّلاَۃَ انْفَتَلَ سَرِیعًا ، فَإِمَّا أَنْ یَقُومَ ، وَإِمَّا أَنْ یَنْحَرِفَ۔",,,3097
3098,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، وَخَالِدٍ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ الإِمَامُ إذَا سَلَّمَ قَامَ ، وَقَالَ خَالِدٌ : انْحَرَفَ۔",,,3098
3099,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی رَزِینٍ ، قَالَ : صَلَّیْت خَلْفَ عَلِیٍّ فَسَلَّمَ عَنْ یَمِینِہِ وَعَنْ یَسَارِہِ ، ثُمَّ وَثَبَ کَمَا ہُوَ۔",,,3099
3100,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : قَالَ عُمَرُ : جُلُوسُ الإِمَامِ بَعْدَ التَّسْلِیمِ بِدْعَۃٌ۔",,,3100
3101,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ أَبِی حَصِینٍ ، قَالَ : کَانَ أَبُو عُبَیْدَۃَ بْنُ الْجَرَّاحِ إذَا سَلَّمَ کَأَنَّہُ عَلَی الرَّضْفِ ، حَتَّی یَقُومَ۔",,,3101
3102,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا سَلَّمَ لَمْ یَقْعُدْ إِلاَّ مِقْدَارَ مَا یَقُولُ : اللَّہُمَّ أَنْتَ السَّلاَمُ وَمِنْک السَّلاَمُ تَبَارَکْتَ یَا ذَا الْجَلاَلِ وَالإِکْرَامِ۔ (مسلم 136۔ ترمذی 299)",,,3102
3103,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ عَوْسَجَۃَ بْنِ الرَّمَّاحِ ، عَنِ ابْنِ أَبِی الْہُذَیْلِ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا سَلَّمَ لَمْ یَجْلِسْ إِلاَّ مِقْدَارَ مَا یَقُولُ اللَّہُمَّ أَنْتَ السَّلاَمُ ، وَإِلَیْکَ السَّلاَمُ ، تَبَارَکْتَ یَا ذَا الْجَلاَلِ وَالإِکْرَامِ۔ (ابن حبان 2002۔ ابن خزیمۃ 736)",,,3103
3104,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی سِنَان ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : کَانَ لَنَا إمَامٌ ، ذکر مِنْ فَضْلِہِ ، إذَا سَلَّمَ تَقَدَّمَ۔",,,3104
3105,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ: کُلُّ صَلاَۃٍ بَعْدَہَا تَطَوُّعٌ فَتَحَوَّلْ، إِلاَّ الْعَصْرَ وَالْفَجْرَ۔",,,3105
3106,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : أَمَّا الْمَغْرِبُ فَلاَ تَدَعْ أَنْ تَحَوَّلَ۔",,,3106
3107,حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ إذَا سَلَّمَ انْحَرَفَ ، أَوْ قَامَ سَرِیعًا۔,,,3107
3108,حَدَّثَنَا أَبُو دَاوُدَ، عَنْ زَمْعَۃَ، عَنِ ابْنِ طَاوُوس، عَنْ أَبِیہِ، أَنَّہُ کَانَ إذَا سَلَّمَ قَامَ فَذَہَبَ کَمَا ہُوَ، وَلَمْ یَجْلِسْ۔,,,3108
3109,حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ إذَا سَلَّمَ انْحَرَفَ ، وَاسْتَقْبَلَ الْقَوْمَ۔,,,3109
3110,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یَعْلَی بْنُ عَطَائٍ ، عَنْ جَابِرِ بْنِ یَزِیدَ بْنِ الأَسْوَدِ الْعَامِرِیِّ ، عَنْ أَبِیہِ ، قَالَ : صَلَّیْت مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْفَجْرَ ، فَلَمَّا سَلَّمَ انْحَرَفَ۔ (ترمذی 219۔ احمد 161)",,,3110
3111,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی عَاصِمٍ الثَّقَفِیِّ ، عَنْ قَیْسِ بْنِ مُسْلِمٍ ، عَنْ طَارِقِ بْنِ شِہَابٍ ؛ أَنَّ عَلِیًّا لَمَّا انْصَرَفَ اسْتَقْبَلَ الْقَوْمَ بِوَجْہِہِ۔,,,3111
3112,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : حَدَّثَنِی شَیْخٌ ، عَنْ صِلَۃَ بْنِ زُفَرَ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ فِی دُبُرِ الصَّلاَۃِ : اللَّہُمَّ أَنْتَ السَّلاَمُ ، وَمِنْک السَّلاَمُ ، تَبَارَکْت یَا ذَا الْجَلاَلِ وَالإِکْرَامِ ۔ ثُمَّ صَلَّیْتُ إلَی جَنْبِ عَبْدِ اللہِ بْنِ عَمْرٍو ، فَسَمِعْتُہُ یَقُولُہُنَّ ، قَالَ : فَقُلْتُ لَہُ : إنِّی سَمِعْت ابْنَ عُمَرَ یَقُولُ مِثْلَ الَّذِی تَقُولُ ، فَقَالَ عَبْدُ اللہِ بْنُ عَمْرٍو : إنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُہُنَّ۔ (طبرانی 650)",,,3112
3113,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، عَنْ وَرَّادٍ مَوْلَی الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، قَالَ : کَتَبَ مُعَاوِیَۃُ إلَی الْمُغِیرَۃِ بْنِ شُعْبَۃَ : أَیُّ شَیْئٍ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ ، إذَا سَلَّمَ مِنَ الصَّلاَۃِ ؟ قَالَ : فَأَمْلاَہَا عَلَی الْمُغِیرَۃِ بْنِ شُعْبَۃَ ، فَکَتَبَ بِہَا إلَی مُعَاوِیَۃَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ إذَا سَلَّمَ : لاَ إلَہَ إِلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ ، وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ ، اللَّہُمَّ لاَ مَانِعَ لِمَا أَعْطَیْت ، وَلاَ مُعْطِیَ لِمَا مَنَعْت ، وَلاَ یَنْفَعُ ذَا الْجَدِّ مِنْک الْجَدُّ۔ \n\n(مسلم 415۔ ابوداؤد 1500)",,,3113
3114,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی ہَارُونَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ غَیْرَ مَرَّۃٍ یَقُولُ فِی آخِرِ صَلاَتِہِ عِنْدَ انْصِرَافِہِ : سُبْحَانَ رَبِّکَ رَبِّ الْعِزَّۃِ عَمَّا یَصِفُونَ وَسَلاَمٌ عَلَی الْمُرْسَلِینَ وَالْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ۔ (طیالسی 2198۔ ابو یعلی 1118)",,,3114
3115,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ أَبِی الْیَقْظَانِ ، عَنْ حُصَیْنِ بْنِ یَزِیدَ الثَّعْلَبِیِّ ، عَنْ عَبْدِ اللہِ بْنِ مَسْعُودٍ ؛ أَنَّہُ کَانَ یَقُولُ إذَا فَرَغَ مِنَ الصَّلاَۃِ : اللَّہُمَّ إنِّی أَسْأَلُک مِنْ مُوجِبَاتِ رَحْمَتِکَ ، وَعَزَائِمَ مَغْفِرَتِکَ ، وَأَسْأَلُک الْغَنِیمَۃَ مِنْ کُلِّ بِرٍّ ، وَالسَّلاَمَۃَ مِنْ کُلِّ إِثْمَ ، اللَّہُمَّ إنِّی أَسْأَلُک الْفَوْزَ بِالْجَنَّۃِ وَالْجَوَازَ مِنَ النَّارِ ، اللَّہُمَّ لاَ تَدَعْ لَنَا ذَنْبًا إِلاَّ غَفَرْتَہُ ، وَلاَ ہَمًّا إِلاَّ فَرَّجْتَہُ ، وَلاَ حَاجَۃً إِلاَّ قَضَیْتَہَا۔",,,3115
3116,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ السَّلاَمِ بْنِ شَدَّادٍ الْجُرَیْرِیِّ ، عَنْ غَزْوَانَ بْنِ جَرِیرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ، أَنَّہُ قَالَ حِینَ سَلَّمَ : لاَ إلَہَ إِلاَّ اللَّہُ ، وَلاَ نَعْبُدُ إِلاَّ اللَّہَ۔",,,3116
3117,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ عَوْسَجَۃَ ، عَنِ ابْنِ أَبِی الْہُذَیْلِ ، عَنْ عَبْدِ اللہِ ، وَعَنْ عَاصِمٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ إِذَا سَلَّمَ : اللَّہُمَّ أَنْتَ السَّلاَمُ وَمِنْک السَّلاَمُ ۔ إِلاَّ أَنَّ فِی حَدِیثِ عَبْدِ اللہِ : وَإِلَیْک السَّلاَمُ ، تَبَارَکْت یَا ذَا الْجَلاَلِ وَالإِکْرَامِ۔",,,3117
3118,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، قَالَ : کَانَ إبْرَاہِیمُ إذَا سَلَّمَ أَقْبَلَ عَلَیْنَا بِوَجْہِہِ وَہُوَ یَقُولُ : لاَ إلَہَ إِلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ۔",,,3118
3119,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی الْبَخْتَرِیِّ ، قَالَ : مَرَرْت أَنَا وَعُبَیْدَۃُ فِی الْمَسْجِدِ ، وَمُصْعَبٌ یُصَلِّی بِالنَّاسِ ، فَلَمَّا انْصَرَفَ ، فَقَالَ : لاَ إلَہَ إِلاَّ اللَّہُ وَاللَّہُ أَکْبَرُ ، رَفَعَ بِہَا صَوْتَہُ ، فَقَالَ عبیدَۃُ : قَاتَلَہُ اللَّہُ تَعَالَی ، نَعَّارٌ بِالْبِدَعِ۔",,,3119
3120,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی سِنَانٍ ، عَنِ ابْنِ أَبِی الْہُذَیْلِ ، قَالَ : کَانُوا یَقُولُونَ إذَا انْصَرَفُوا مِنَ الصَّلاَۃِ : اللَّہُمَّ أَنْتَ السَّلاَمُ وَمِنْک السَّلاَمُ ، تَبَارَکْت یَا ذَا الْجَلاَلِ وَالإِکْرَامِ۔",,,3120
3121,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : ذَکَرْت لِلْقَاسِمِ أَنَّ رَجُلاً مِنْ أَہْلِ الْیَمَنِ ذَکَرَ لِی : أَنَّ النَّاسَ کَانُوا إذَا سَلَّمَ الإِمَامُ مِنْ صَلاَۃِ الْمَکْتُوبَۃِ کَبَّرُوا ثَلاَثَ تَکْبِیرَاتٍ ، أَوْ تَہْلِیلاَتٍ ، فَقَالَ الْقَاسِمُ : وَاللَّہِ إِنْ کَانَ ابْنُ الزُّبَیْرِ لِیَصْنَع ذَلِکَ۔",,,3121
3122,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الأَعْمَشِ ، قَالَ : سُئِلَ إبْرَاہِیمُ عَنِ الإِمَامِ إذَا سَلَّمَ فَیَقُولُ : صَلَّی اللَّہُ عَلَی مُحَمَّدٍ ، وَلاَ إلَہَ إِلاَّ اللَّہُ ؟ فَقَالَ : مَا کَانَ مَنْ قَبْلَہُمْ یَصْنَعُ ہَکَذَا۔",,,3122
3123,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الأَعْمَشِ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی الْبَخْتَرِیِّ ، قَالَ : ہَذِہِ بِدْعَۃٌ۔",,,3123
3124,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، قَالَ : أَخْبَرَنِی مُعَاوِیَۃُ بْنُ صَالِحٍ ، قَالَ : حَدَّثَنِی مَالِکُ بْنُ زِیَادٍ الأَشْجَعِیُّ ، قَالَ: سَمِعْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَقُولُ : مِنْ تَمَامِ الصَّلاَۃِ أَنْ تَقُولَ إذَا فَرَغْتَ : لاَ إلَہَ إِلاَّ اللَّہُ وَحْدَہُ لاَ شَرِیکَ لَہُ، لَہُ الْمُلْکُ وَلَہُ الْحَمْدُ ، وَہُوَ عَلَی کُلِّ شَیْئٍ قَدِیرٌ ، ثَلاَثَ مَرَّاتٍ۔",,,3124
3125,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنِ الأَسْوَدِ ، قَالَ : قَالَ عَبْدُ اللہِ : لاَ یَجْعَلَنَّ أَحَدُکُمْ لِلشَّیْطَانِ مِنْ نَفْسِہِ جُزْئً ا ، لاَ یَرَی إِلاَّ أَنَّ حَقًّا عَلَیْہِ أَِنْ لاَ یَنْصَرِفَ إِلاَّ عَنْ یَمِینِہِ ، أَکْثَرُ مَا رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْصَرِفُ عَنْ شِمَالِہِ۔ (بخاری 852۔ ابوداؤد 1035)",,,3125
3126,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سِمَاکِ بْنِ حَرْبٍ ، قَالَ : سَمِعْتُ قَبِیصَۃَ بْنِ ہُلْبٍ یُحَدِّثُ ، عَنْ أَبِیہِ ؛ أَنَّہُ صَلَّی مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَرَآہُ یَنْصَرِفُ عَنْ شِقَّیْہِ۔ (احمد 227۔ طیالسی 1087)",,,3126
3127,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ السُّدِّیّ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَنْصَرِفُ عَنْ یَمِینِہِ۔ (مسلم 61۔ احمد 280),,,3127
3128,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا قُضِیَتِ الصَّلاَۃُ وَأَنْتَ تُرِیدُ حَاجَۃً ، فَکَانَتْ حَاجَتُک عَنْ یَمِینِکَ ، أَوْ عَنْ یَسَارِکَ فَخُذْ نَحْوَ حَاجَتِک۔",,,3128
3129,حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ السَّلاَمِ بْنِ شَدَّادٍ ، عَنْ غَزْوَانَ بْنِ جَرِیرٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا کَانَ إذَا سَلَّمَ لاَ یُبَالِی انْصَرَفَ عَلَی یَمِینِہِ ، أَوْ عَلَی شِمَالِہِ۔,,,3129
3130,حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَسْتَدِیرَ الرَّجُلُ فِی صَلاَتِہِ ، کَمَا یَسْتَدِیرُ الْحِمَارُ۔,,,3130
3131,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ نَاجِیَۃَ ؛ أَنَّ أَبَا عُبَیْدَۃَ رَأَی رَجُلاً انْصَرَفَ عَنْ یَسَارِہِ ، فَقَالَ : أَمَّا ہَذَا فَقَدْ أَصَابَ السُّنَّۃَ۔",,,3131
3132,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَسْتَحِبُّ أَنْ یَنْصَرِفَ الرَّجُلُ مِنْ صَلاَتِہِ عَنْ یَمِینِہِ۔",,,3132
3133,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، عَنْ عَمِّہِ وَاسِعِ بْنِ حَبَّانَ ، قَالَ : کُنْتُ أُصَلِّی ، وَابْنُ عُمَرَ مُُسْنِدٌ ظَہْرَہُ إلَی جِدَارِ الْقِبْلَۃِ ، فَانْصَرَفْت عَنْ یَسَارِی ، فَقَالَ : مَا یَمْنَعُک أَنْ تَنْصَرِفَ عَنْ یَمِینِکَ ؟ قُلْتُ : لاَ ، إِلاَّ أَنِّی رَأَیْتُکَ فَانْصَرَفْت إلَیْک ، فَقَالَ : أَصَبْتَ ، إنَّ نَاسًا یَقُولُونَ : تَنْصَرِفُ عَنْ یَمِینِکَ ، فَإِذَا کُنْت تُصَلِّی فَانْصَرِفْ إِنْ أَحْبَبْت عَنْ یَمِینِکَ ، أَوْ عَنْ یَسَارِک۔",,,3133
3134,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : انْصَرِفْ عَلَی أَیِّ شِقَّیْک شِئْت۔",,,3134
3135,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْوَلِیدِ الْبَجَلِیِّ ، قَالَ : قَالَ عَبْدُ اللہِ : عَلَیْکُمْ بِحَدِّ الصَّلاَۃِ ؛ التَّکْبِیرَۃِ الأَولَی۔",,,3135
3136,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عِمْرَانَ بْن مُسْلِمٍ ، عَنْ خَیْثَمَۃَ ، قَالَ : بِکْرُ الصَّلاَۃِ التَّکْبِیرَۃُ الأَولَی۔",,,3136
3137,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی فَرْوَۃَ یَزِیدَ بْنِ سِنَانٍ ، قَالَ : حدَّثَنَا أَبُو عُبَیْدٍ الْحَاجِبُ ، قَالَ : سَمِعْتُ شَیْخًا فِی الْمَسْجِدِ الْحَرَامِ یَقُولُ : قَالَ أَبُو الدَّرْدَائِ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ لِکُلِّ شَیْئٍ أُنْفَۃً ، وَإِنَّ أُنْفَۃَ الصَّلاَۃِ التَّکْبِیرَۃُ الأَولَی ، فَحَافِظُوا عَلَیْہَا ۔ قَالَ أَبُو عُبَیْدٍ : فَحَدَّثْت بِہِ رَجَائَ بْنَ حَیْوَۃَ ، فَقَالَ : حَدَّثَتْنِیہِ أُمُّ الدَّرْدَائِ ، عَنْ أَبِی الدَّرْدَائِ۔ (مسندہ 46)",,,3137
3138,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنِ الْجَرِیرِیِّ ، عَنِ الرَّیَّانِ الرَّاسِبیِّ ، عَنْ أَشْیَاخِ بَنِی رَاسِبٍ ؛ أَنَّ طَلْحَۃَ وَالزُّبَیْرَ صَلَّیَا فِی بَعْضِ مَسَاجِدِہِمْ ، وَلَمْ یَکُنِ الإِمَامُ ثَمَّ ، فَقُلْنَا لَہُمَا : لِیَتَقَدَّمْ أَحَدُکُمَا ، فَإِنَّکُمَا مِنْ صَحَابَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَأَبَیَا وَقَالاَ : أَیْنَ الإِمَامُ ، أَیْنَ الإِمَامُ ؟ فَجَائَ الإِمَامُ وَصَلَّی بِہِمْ ، قَالاَ : کُلُّ صَلاَتِکُمْ کَانَتْ مُقَارِبَۃً إِلاَّ شَیْئًا رَأَیْتُہُ تَصْنَعُونَہُ ، لَیْسَ بِحَسَنٍ فِی صَلاَتِکُمْ ، فَقُلْنَا : مَا ہُوَ ؟ قَالاَ : إذَا سَلَّمَ الإِمَامُ فَلاَ یَقُومَنَّ رَجُلٌ مِنْ خَلْفِہِ حَتَّی یَنْفَتِلَ الإِمَامُ بِوَجْہِہِ ، أَوْ یَنْہَضَ مِنْ مَکَانِہِ۔",,,3138
3139,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، وَمُغِیرَۃَ ، عَنْ إبْرَاہِیمَ أَنَّہُمَا قَالاَ : لاَ یَقْضِی حَتَّی یَنْحَرِفَ الإِمَامُ۔",,,3139
3140,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، وَخَالِدٌ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، قَالَ : قُلْتُ لابْنِ عُمَرَ : أُسْبَقُ بِبَعْضِ الصَّلاَۃِ فَیُسَلِّمُ الإِمَامُ ، فَأَقُومُ فَأَقْضِی مَا سُبِقْتُ بِہِ ، أَوْ أَنْتَظِرُ أَنْ یَنْحَرِفَ ؟ فَقَالَ ابْنُ عُمَرَ : کَانَ الإِمَامُ إذَا سَلَّمَ قَامَ ، وَقَالَ خَالِدٌ : کَانَ الإِمَامُ إذَا سَلَّمَ انْکَفَأَ ، کَانَ الانکِفَائُ مَعَ التَّسْلِیمِ۔",,,3140
3141,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ فِی رَجُلٍ سُبِقَ بِرَکْعَۃٍ ، أَوْ رَکْعَتَیْنِ ؟ قَالَ : لاَ یَقُومُ إذَا سَلَّمَ الإِمَامُ حَتَّی یَنْحَرِفَ ، أَوْ یَقُومَ۔",,,3141
3142,"حَدَّثَنَا حَفْصٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ سُئِلَ عَنِ الإِمَامِ إذَا سَلَّمَ ، ثُمَّ لاَ یَنْحَرِفُ ؟ قَالَ : دَعْہُ حَتَّی یَفْرُغَ مِنْ بِدْعَتِہِ ، وَکَانَ یَکْرَہُ أَنْ یَقُومَ فَیَقْضِیَ۔",,,3142
3143,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا سَلَّمَ الإِمَامُ فَقُمْ وَاصْنَعْ مَا شِئْت یَقُولُ : لاَ تَنْظُرْ قِیَامَہُ ، وَلاَ تُحَوِّلْہُ مِنْ مَجْلِسِہِ۔",,,3143
3144,"حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَقْضِی ، وَلاَ یَنْتَظِرُ الإِمَامَ ، قَالَ : وَکَانَ الْقَاسِمُ ، وَسَالِمٌ ، وَنَافِعٌ یَفْعَلُونَ ذَلِکَ۔",,,3144
3145,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو ہَارُونَ ، قَالَ : صَلَّیْت بِالْمَدِینَۃِ فَسُبِقْتُ بِبَعْضِ الصَّلاَۃِ ، فَلَمَّا سَلَّمَ الإِمَامُ قُمْتُ لأَقْضِیَ مَا سُبِقْتُ بِہ ، فَجَبَذَنِی رَجُلٌ کَانَ إلَی جَنْبِی ، ثُمَّ قَالَ : کَانَ یَنْبَغِی لَکَ أَنْ لاَ تَقُومَ حَتَّی یَنْحَرِف ، قَالَ : فَلَقِیتُ أَبَا سَعِیدٍ فَذَکَرْت لَہ ذَلِکَ ، فَکَأَنَّہُ لَمْ یَکْرَہْ مَا صَنَعْتُ ، أَوْ کَلِمَۃً نَحْوَہَا۔",,,3145
3146,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ، قَالَ : یَا بُنَیَّ ، إذَا سَلَّمْتُ فَإِنِّی أَجْلِسُ فَأُسَبِّحُ وَأُکَبِّرُ ، فَمَنْ بَقِیَ عَلَیْہِ شَیْئٌ مِنْ صَلاَتِہِ ، فَلْیَقُمْ فَلْیَقْضِ۔",,,3146
3147,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یَنْتَظِرُہُ قَلِیلاً ، فَإِنْ جَلَسَ فَقُمْ وَدَعْہُ۔",,,3147
3148,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَرُدُّ السَّلاَمَ عَلَی الإِمَامِ۔,,,3148
3149,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا سَلَّمَ الإِمَامُ فَرُدَّ عَلَیْہِ۔",,,3149
3150,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَالِمٍ ، قَالَ : إذَا سَلَّمَ الإِمَامُ فَرُدَّ عَلَیْہِ۔",,,3150
3151,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : إنَّ ذَرًّا إذَا سَلَّمَ الإِمَامُ رَدَّ عَلَیْہِ ، قَالَ : یُجْزِئہ أَنْ یُسَلِّمَ عَنْ یَمِینِہِ ، وَعَنْ یَسَارِہِ۔",,,3151
3152,"حَدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ، قَالَ : إذَا سَلَّمَ الإِمَامُ فَلْیَرُدَّ عَلَیْہِ مَنْ خَلْفَہُ۔",,,3152
3153,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقْرِیئُ ، عَنْ سَعِیدِ بْنِ أَبِی أَیُّوبَ ، قَالَ : حدَّثَنِی أَبُو عَقِیلٍ ؛ أَنَّہُ رَأَی سَعِیدَ بْنَ الْمُسَیَّبِ یُسَلِّمُ عَنْ یَمِینِہِ ، وَعَنْ یَسَارِہِ ، ثُمَّ یَرُدُّ عَلَی الإِمَامِ۔",,,3153
3154,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ أَبِیہِ ، قَالَ : کُنْتُ قَاعِدًا عِنْدَ ابْنِ عُمَرَ ، فَرَأَی رَجُلاً قَدْ أَثَّرَ السُّجُودُ فِی وَجْہِہِ ، فَقَالَ : إنَّ صُورَۃَ الرَّجُلِ وَجْہُہُ ، فَلاَ یَشِینُ أَحَدُکُمْ صُورَتَہُ۔",,,3154
3155,"حَدَّثَنَا وَکِیعٌ ، عَنْ ثَوْرٍ ، عَنْ أَبِی عَوْنٍ الأَعْوَرِ ، عَنْ أَبِی الدَّرْدَائِ ؛ أَنَّہُ رَأَی امْرَأَۃً بَیْنَ عَیْنَیْہَا مِثْلُ ثَفِنَۃِ الشَّاۃِ ، فَقَالَ : أَمَا إنَّ ہَذَا لَوْ لَمْ یَکُنْ بَیْنَ عَیْنَیْک کَانَ خَیْرًا لَک۔",,,3155
3156,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ یَزِیدَ بْنِ الأَصَمِّ ، قَالَ : قلت لِمَیْمُونَۃَ : أَلَمْ تَرَیْ إلَی فُلاَنٍ یَنْقُرُ جَبْہَتَہُ بِالأَرْضِ یُرِیدُ أَنْ یُؤَثِّرَ بِہَا أَثَرَ السُّجُودِ ، فَقَالَتْ : دَعْہُ لَعَلَّہُ یَلِجُ۔",,,3156
3157,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حُرَیْثٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَرِہَ الأَثَرَ فِی الْوَجْہِ۔,,,3157
3158,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مُسَافِرٍ الْجَصَّاصِ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، قَالَ : شَکَوْت إلَی مُجَاہِدٍ الأَثَرَ بَیْنَ عَیْنَیَّ ، فَقَالَ لِی : إذَا سَجَدْت فَتَجَافَ۔",,,3158
3159,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ أَصْحَابَ عَلِیٍّ وَأَصْحَابَ عَبْدِ اللہِ وَأَثَارُ السُّجُودِ فِی جِبَاہِہِمْ وَأُنُوفِہِمْ۔",,,3159
3160,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ، عَنْ أَبِی إِسْحَاقَ، قَالَ: مَا رَأَیْت سَجْدَۃً أَعْظَمَ مِنْہَا، یَعْنِی سَجْدَۃَ ابْنِ الزُّبَیْرِ۔",,,3160
3161,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : رَأَیْتُ مَا یَلِی الأَرْضَ مِنْ عَامِرِ بَنِی عَبْدِ قَیْسٍ مِثْلَ ثَفِنِ الْبَعِیرِ۔",,,3161
3162,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ الْحَسَنِ ، قَالُوا : لَمَّا بُنِیَ الْمَسْجِدُ قَالُوا : یَا رَسُولَ اللہِ ، کَیْفَ نَبْنِیہ ؟ قَالَ : عَرْشٌ کَعَرْشِ مُوسَی۔",,,3162
3163,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : حدَّثَنِی رَجُلٌ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : کَانَ یُقَالُ : لَیَأْتِیَنَّ عَلَی النَّاسِ زَمَانٌ یَبْنُونَ الْمَسَاجِدَ یَتَبَاہَوْنَ بِہَا ، وَلاَ یَعْمُرُونَہَا إِلاَّ قَلِیلاً۔ (ابوداؤد 450۔ نسائی 768)",,,3163
3164,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی فَزَارَۃَ ، عَنْ یَزِیدَ بْن الأَصَمِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا أُمِرْتُ بِتَشْیِیدِ الْمَسَاجِدِ۔ (عبدالرزاق 5127)",,,3164
3165,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی فَزَارَۃَ ، عَنْ یَزِیدَ بْن الأَصَمِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَتُزَخْرِفُنَّہَا کَمَا زَخْرَفَتِ الْیَہُودُ وَالنَّصَارَی۔",,,3165
3166,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ، قَالَ : قَالَ أَبِی : إذَا زَوَّقْتُمْ مَسَاجِدَکُمْ ، وَحَلَّیْتُمْ مَصَاحِفَکُمْ ، فَالدُّبَارُ عَلَیْکُمْ۔",,,3166
3167,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی فَزَارَۃَ ، عَنْ مُسْلِمٍ الْبَطِینِ ، قَالَ : مَرَّ عَلَی مَسْجِدٍ قَدْ شُرِّف ، فَقَالَ: ہَذِہِ بَیْعَۃُ بَنِی فُلاَنٍ۔",,,3167
3168,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجَرِیرِیِّ ، قَالَ : قَالَ عَبْدُ اللہِ بْنُ شَقِیقٍ : إنَّمَا کَانَتِ الْمَسَاجِدُ جُمًّا ، وَإِنَّ مَا شَرَّفَ النَّاسُ حَدِیثٌ مِنَ الدَّہْرِ۔",,,3168
3169,"حَدَّثَنَا خَلَفُ بْنُ خَلِیفَۃَ ، عَنْ مُوسَی ، عَنْ رَجُلٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أُمِرْنَا أَنْ نَبْنِیَ الْمَسَاجِدَ جُمًّا ، وَالْمَدَائِنَ شُرَفًا۔",,,3169
3170,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ یَزِیدَ بْنِ الأَصَمِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لَتُزَخْرِفُنَّ مَسَاجِدَکُمْ ، کَمَا زَخْرَفَتِ الْیَہُودُ وَالنَّصَارَی مَسَاجِدَہُمْ۔",,,3170
3171,"حَدَّثَنَا مَالِکُ بْنُ إسْمَاعِیلَ ، قَالَ : حدَّثَنَا ہُرَیْمٌ ، عَنْ لَیْثٍ ، عَنْ أَیُّوبَ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ابْنُوا الْمَسَاجِدَ وَاتَّخِذُوہَا جُمًّا۔",,,3171
3172,"حَدَّثَنَا مَالِکٌ ، قَالَ : حدَّثَنَا ہُرَیْمٌ ، قَالَ : حَدَّثَنَا لَیْثٌ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : نُہِینَا ، أَوْ نَہَانَا ، أَنْ نُصَلِّیَ فِی مَسْجِدٍ مُشَرَّفٍ۔ (طبرانی 13499۔ بیہقی 439)",,,3172
3173,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، عَنْ أَبِی ذَرٍّ ، قَالَ : مَنْ بَنَی لِلَّہِ مَسْجِدًا وَلَوْ مِثْلَ مَفْحَصِ قَطَاۃٍ ، بُنِیَ لَہُ بَیْتٌ فِی الْجَنَّۃِ۔",,,3173
3174,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ عَبْدِ الْعَزِیزِ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، عَنْ أَبِی ذَرٍّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ بَنَی لِلَّہِ مَسْجِدًا وَلَوْ مَفْحَصَ قَطَاۃٍ ، بَنَی اللَّہُ لَہُ بَیْتًا فِی الْجَنَّۃِ۔ (ابن حبان 1611۔ طبرانی 1105)",,,3174
3175,"حَدَّثَنَا یُونُسُ بْنُ مُحَمَّدٍ ، قَالَ : حدَّثَنَا لَیْثُ بْنُ سَعْدٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ أُسَامَۃَ ، عَنِ الْوَلِیدِ بْنِ أَبِی الْوَلِیدِ ، عَنْ عُثْمَانَ بْنِ عَبْدِ اللہِ بْنِ سُرَاقَۃَ ، عَنْ عُمَرَ بْنِ الْخَطَّابِ ، أَنَّہُ ، قَالَ : سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَنْ بَنَی مَسْجِدًا یُذْکَرُ فِیہِ اسْمُ اللہِ ، بَنَی اللَّہُ لَہُ بَیْتًا فِی الْجَنَّۃِ۔ \n\n(ابن ماجہ 2758۔ ابن حبان 1608)",,,3175
3176,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ جَابِرٍ ، عَنْ عَمَّارٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنْ بَنَی مَسْجِدًا مَفْحَصَ قَطَاۃٍ ، بَنَی اللَّہُ لَہُ بَیْتًا فِی الْجَنَّۃِ۔\n\n(احمد 241۔ طیالسی 2617)",,,3176
3177,"قَالَ أَبو بَکر : وَجَدْتُ فِی کِتَابِ أَبِی : عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ مَحْمُودِ بْنِ لَبِیدٍ ، عَنْ عُثْمَانَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : مَنْ بَنَی مَسْجِدًا وَلَوْ مَفْحَصَ قَطَاۃٍ ، بَنَی اللَّہُ لَہُ بَیْتًا فِی الْجَنَّۃِ۔",,,3177
3178,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا کَثِیرُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ بَنَی مَسْجِدًا بَنَی اللَّہُ لَہُ بَیْتًا ، قِیلَ : وَہَذِہِ الْمَسَاجِدُ الَّتِی فِی طَرِیقِ مَکَّۃَ ؟ قَالَتْ : وَہَذِہِ الْمَسَاجِدُ الَّتِی فِی طَرِیقِ مَکَّۃَ۔",,,3178
3179,"حَدَّثَنَا سُفیان بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : أَتَی رَجُلٌ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إنَّ أَحَدَنَا یُصَلِّی فِی ثوْبٍ وَاحِدٍ ، فَقَالَ : أَوَلِکُلِّکُمْ ثَوْبَانِ ؟ قَالَ أَبُو ہُرَیْرَۃَ لِلَّذِی سَأَلَہُ : أَتَعْرِفُ أَبَا ہُرَیْرَۃَ ، فَإِنَّہُ یُصَلِّی فِی ثَوْبٍ۔ (ابن حبان 2296۔ احمد 2/239)",,,3179
3180,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی ثَوْبٍ وَاحِدٍ مُتَوَشِّحًا بِہِ۔ (مسلم 285۔ احمد 3/10),,,3180
3181,حَدَّثَنَا شَرِیکٌ ، عَنْ حُسَیْنِ بْنِ عَبْدِ اللہِ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی ثَوْبٍ وَاحِدٍ ، یَتَّقِی بِفُضُولِہِ حَرَّ الأَرْضِ وَبَرْدَہَا۔,,,3181
3182,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : سُئِلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الصَّلاَۃِ فِی الثَّوْبِ ؟ فَقَالَ : أَوَلِکُلِّکُمْ ثَوْبَانِ ؟۔ (بخاری 365۔ مسلم 368)",,,3182
3183,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللہِ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ اللہِ بْنِ حُنَیْنٍ ، عنِ ابْنِ عَبَّاسٍ ، عَنْ عَلِیِّ بْنِ أَبِی طَالِبٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا کَانَ إزَارُک وَاسِعًا فَتَوَشَّحْ بِہِ، وَإِنْ کَانَ ضَیِّقًا فَاتَّزِرْ۔ (ابن سعد 30)",,,3183
3184,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرٍو ، عَنْ عَبْدِ اللہِ بْنِ بَدْرٍ ، عَنْ قَیْسِ بْنِ طَلْقِ بْنِ عَلِیٍّ ، عَنْ أَبِیہِ ، قَالَ : جَائَ رَجُلٌ فَقَالَ : یَا نَبِیَّ اللہِ ، مَا تَرَی فِی الصَّلاَۃِ فِی ثَوْبٍ وَاحِدٍ ؟ قَالَ : فَأَطْلَقَ النَبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إزَارَہُ فَطَارَقَ بِہِ رِدَائَہُ ، ثُمَّ اشْتَمَلَ بِہِمَا ثُمَّ صَلَّی بِنَا ، فَلَمَّا قَضَی الصَّلاَۃَ ، قَالَ : أَکُلُّکُمْ یَجِدُ ثَوْبَیْنِ ؟۔",,,3184
3185,حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَطَائٍ ، عَنْ مُعَاوِیَۃَ بْنِ أَبِی سُفْیَانَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی فِی ثَوْبٍ وَاحِدٍ۔,,,3185
3186,"حَدَّثَنَا عَبْدُ اللہِ بْنُ أَجْلَح ، عَنْ عَاصِمٍ ، عَنْ أَنَسٍ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی ثَوْبٍ وَاحِدٍ خَالَفَ بَیْنَ طَرَفَیْہِ۔ (نسائی 860۔ احمد 3/243)",,,3186
3187,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ طَارِقٍ ، عَنْ قَیْسِ بْنِ أَبِی حَازِمٍ ، قَالَ : کَانَ خَالِدُ بْنُ الْوَلِیدِ یَخْرُجُ فَیُصَلِّی بِالنَّاسِ فِی ثَوْبٍ وَاحِدٍ۔",,,3187
3188,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی فَرْوَۃَ ، عَنْ أَبِی الضُّحَی ، قَالَ : سُئِلَ ابْنُ عَبَّاسٍ عَنِ الرَّجُلِ یُصَلِّی فِی الثَّوْبِ الْوَاحِدِ ؟ فَقَالَ : نَعَمْ ، یُخَالِفُ بَیْنَ طَرَفَیْہِ۔",,,3188
3189,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : جَائَ رَجُلٌ إلَی عَائِشَۃَ ، فَقَالَ : أُصَلِّی فِی ثَوْبٍ وَاحِدٍ ؟ قَالَتْ : نَعَمْ ، وَخَالِفْ بَیْنَ طَرَفَیْہِ۔",,,3189
3190,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ قَیْسِ بْنِ أَبِی حَازِمٍ ، قَالَ : صَلَّی بِنَا خَالِدُ بْنُ الْوَلِیدِ فِی ثَوْبٍ وَاحِدٍ فِی الْوُفُودِ ، وَقَدْ خَالَفَ بَیْنَ طَرَفَیْہِ ، وَخَلْفَہُ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,3190
3191,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، قَالَ : سُئِلَ أَنَسٌ عَنِ الصَّلاَۃِ فِی الثَّوْبِ ؟ فَقَالَ : یَتَوَشَّحُ بِہِ۔",,,3191
3192,"حَدَّثَنَا حَفْصٌ ، عَنْ حَلاَّمٍ ، عَنْ مَسْعُودٍ ، یَعْنِی ابْنَ حِرَاشٍ ، قَالَ : صَلَّی بِنَا عُمَرُ فِی ثَوْبٍ لَیْسَ عَلَیْہِ غَیْرُہُ ، قَالَ : وَأَمَّنَا مَسْعُودٌ ، یَعْنِی ابْنَ حِرَاشٍ ، فِی بَتٍّ۔",,,3192
3193,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ صَلَّی فِی ثَوْبٍ وَاحِدٍ خَالَفَ بَیْنَ طَرَفَیْہِ۔,,,3193
3194,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عَوْفٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ یُصَلِّیَ الرَّجُلُ فِی ثَوْبٍ۔",,,3194
3195,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ اللہِ بْنِ حُنَیْنٍ ، عَنْ أَبِی مُرَّۃَ مَوْلَی عَقِیلِ بْنِ أَبِی طَالِبٍ ، عَنْ أُمِّ ہَانِیئٍ ابْنَۃِ أَبِی طَالِبٍ ، قَالَتْ : أَتَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَوُضِعَ لَہُ مَائٌ فَاغْتَسَلَ ، ثُمَّ الْتَحَفَ وَخَالَفَ بَیْنَ طَرَفَیْہِ عَلَی عَاتِقَیْہِ ، ثُمَّ صَلَّی الضُّحَی ، ثَمَانِیَ رَکَعَاتٍ۔\n\n قَالَ مُحَمَّدٌ : وَقَدْ رَأَیْت أَبَا مُرَّۃَ۔(احمد 6/342۔ ابن حبان 2537)",,,3195
3196,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیرِیِّ ، عَنْ أَبِی نَضْرَۃَ ، قَالَ : قَالَ أُبَیّ : الصَّلاَۃُ فِی ثَوْبٍ وَاحِدٍ حَسَنٌ ، قَدْ فَعَلْنَاہُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔",,,3196
3197,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ دَاوُدَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : سَأَلْتُہ عَنِ الصَّلاَۃِ فِی الثَّوْبِ ، أَوْ سُئِلَ ؟ فَقَالَ : یُخَالِفُ بَیْنَ طَرَفَیْہِ۔",,,3197
3198,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، قَالَ : سَأَلْتُ أَبَا سَلَمَۃَ بْنَ عَبْدِ الرَّحْمَنِ عَنِ الصَّلاَۃِ فِی الثَّوْبِ الْوَاحِدِ ؟ فَقَالَ : إنِّی لأُصَلِّی فِی الثَّوْبِ الْوَاحِدِ وَإِلَی جَنْبِی ثِیَابٌ ، لَوْ أَشَائُ أَنْ آخُذَ مِنْہَا لأَخَذْت۔",,,3198
3199,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سُفْیَانَ ، عَنْ عُثْمَانَ بْنِ الْمُغِیرَۃِ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ؛ أَنَّ عَلِیًّا ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃِ فِی ثَوْبٍ وَاحِدٍ ، أَوْ صَلَّی فِی ثَوْبٍ وَاحِدٍ۔",,,3199
3200,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یُصَلِّی فِی ثَوْبٍ وَاحِدٍ ، قَالَ : حسَنٌ ، إذَا خَالَفَ بَیْنَ طَرَفَیْہِ۔",,,3200
3201,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی فِی ثَوْبٍ وَاحِدٍ مُتَوَشِّحًا بِہِ۔(مسلم 283۔ احمد 3/356)",,,3201
3202,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبَانُ بْنُ صَمْعَۃَ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ بَأْسَ فِی الصَّلاَۃِ فِی الثَّوْبِ الْوَاحِدِ۔",,,3202
3203,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ؛ أَنَّہُ کَانَ یَقُولُ : یُصَلِّی فِی ثَوْبٍ وَاحِدٍ یَتَّزِرُ بِبَعْضِہِ ، وَیَرْتَدِی بِبَعْضِہِ۔",,,3203
3204,"حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ یَزِیدَ مَوْلَی سَلَمَۃَ بْنِ الأَکْوَعِ ، قَالَ : کَانَ سَلَمَۃُ یُصَلِّی فِی ثَوْبٍ۔",,,3204
3205,"حَدَّثَنَا أَحْمَدُ بْنُ عَبْدِ اللہِ بْنِ یُونُسَ ، قَالَ : حدَّثَنَا یَعْلَی بْنُ الْحَارِثِ الْمُحَارِبِیُّ ، قَالَ : سَمِعْتُ غَیْلاَنَ بْنَ جَامِعٍ ، قَالَ : حَدَّثَنِی إیَاسُ بْنُ سَلَمَۃَ ، عَنِ ابْنٍ لِعَمَّارِ بْنِ یَاسِرٍ ، قَالَ : قَالَ أَبِی : أَمَّنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی ثَوْبٍ وَاحِدٍ مُتَوَشِّحًا بِہِ۔ (ابو یعلی 1635)",,,3205
3206,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا عَمْرُو بْنُ کَثِیرٍ ، قَالَ : حَدَّثَنِی ابْنُ کَیْسَانَ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الظُّہْرَ وَالْعَصْرَ فِی ثَوْبٍ وَاحِدٍ، مُتَلَبِّباً بِہِ۔ (ابن ماجہ 1051۔ احمد 3/417)",,,3206
3207,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا دَاوُد بْنُ أَبِی ہِنْدٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ: اخْتَلَفَ أُبَیُّ بْنُ کَعْبٍ ، وَابْنُ مَسْعُودٍ فِی الصَّلاَۃِ فِی الثَّوْبِ الْوَاحِدِ ، فَقَالَ أُبَیٌّ : ثَوْبٌ ، وَقَالَ : ابْنُ مَسْعُودٍ: ثَوْبَانِ ، فَخَرَجَ عَلَیْہِمَا عُمَرُ فَلاَمَہُمَا ، وَقَالَ : إِنَّہُ لَیَسُوؤُنِی أَنْ یَخْتَلِفَ اثْنَانِ مِنْ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الشَّیْئِ الْوَاحِدِ ، فَعَنْ أَیِّ فُتْیَاکُمَا یَصْدُر النَّاسُ ؟ أَمَّا ابْنُ مَسْعُودٍ فَلَمْ یَأْلُ ، وَالْقَوْلُ مَا قَالَ أُبَیٌّ۔ (بیہقی 238)",,,3207
3208,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : یُصَلِّی فِی الثَّوْبِ الْوَاحِدِ مُتَوَشِّحًا بِہِ ، وَقَالَ ابْنُ عُمَرَ : لاَ یَضُرُّہُ لَوِ الْتَحَفَ حَتَّی یُخْرِجَ إحْدَی یَدَیْہِ۔",,,3208
3209,"حَدَّثَنَا یَحْیَی بْنُ إِسْحَاقَ ، قَالَ : أَخْبَرَنَا یَحْیَی بْنُ أَیُّوبَ ، قَالَ : أَخْبَرَنَا یَحْیَی الأَمَوِیُّ ، قَالَ : دَخَلْت أَنَا وَعُزْرَۃُ بْنُ أَبِی قَیْسٍ عَلَی عَبْدِ اللہِ بْن الْحَارِثِ بْنِ جَزْئٍ الزُّبَیْدِیِّ ، وَکَانَتْ لَہُ صُحْبَۃٌ ، فَتَوَضَّأَ ثُمَّ صَلَّی فِی ثَوْبٍ وَاحِدٍ قَدْ خَالَفَ بَیْنَ طَرَفَیْہِ۔",,,3209
3210,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عُمَرَ بْنِ أَبِی سَلَمَۃَ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی فِی بَیْتِ أُمِّ سَلَمَۃَ فِی ثَوْبٍ ، وَاضِعًا طَرَفَیْہِ عَلَی عَاتِقَیْہِ۔ (ترمذی 339۔ ابوداؤد 628)",,,3210
3211,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا فُضَیْلُ بْنُ غَزْوَانَ ، عَنْ أَبِی حَازِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : رَأَیْتُ سَبْعِینَ مِنْ أَہْلِ الصُّفَّۃِ یُصلَّون فِی ثَوْبٍ ثَوْبٍ ، فَمِنْہُمْ مَنْ یَبْلُغُ رُکْبَتَیْہِ ، وَمِنْہُمْ مَا ہُوَ أَسْفَلَ مِنْ ذَلِکَ ، فَإِذَا رَکَعَ قَبَضَ عَلَیْہِ مَخَافَۃَ أَنْ تَبْدُوَ عَوْرَتُہُ۔",,,3211
3212,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا سُفْیَانُ ، عَنْ عُثْمَانَ بْنِ مُغِیرَۃَ الثَّقَفِیِّ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، عَنْ مُحَمَّدِ بْنِ الْحَنَفِیَّۃِ ، قَالَ : قَالَ عَلِیٌّ : إذَا صَلَّی الرَّجُلُ فِی الثَّوْبِ الْوَاحِدِ فَلْیَتَوَشَّحْ بِہِ۔",,,3212
3213,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : أَمَّنَا جَابِرُ بْنُ عَبْدِ اللہِ فِی ثَوْبٍ وَاحِدٍ مُتَوَشِّحًا بِہِ۔",,,3213
3214,"حَدَّثَنَا مُحَمَّدُ بْنُ عُمَرَ الأَسْلَمِیُّ ، قَالَ : أَخْبَرَنَا الضَّحَّاکُ بْنُ عُثْمَانَ ، عَنْ حَبِیبٍ مَوْلَی عُرْوَۃَ ، قَالَ : سَمِعْتُ أَسْمَائَ بِنْتَ أَبِی بَکْرٍ تَقُولُ : رَأَیْت أَبِی یُصَلِّی فِی ثَوْبٍ وَاحِدٍ ، فَقُلت : یَا أَبۃِ أَتُصلِّی فِی ثَوْبٍ وَاحِدٍ وَثِیَابُکَ مَوْضُوعَۃٌ ؟ فَقَالَ : یَا بُنَیَّۃُ ، إنَّ آخِرَ صَلاَۃٍ صَلاَّہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَلْفِی فِی ثَوْبٍ وَاحِدٍ۔ (ابویعلی 51)",,,3214
3215,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ رَأَی رَجُلاً یُصَلِّی مُلْتَحِفًا ، فَقَالَ : لاَ تَشَبَّہُوا بِالْیَہُودِ ، مَنْ لَمْ یَجِدْ مِنْکُمْ إِلاَّ ثَوْبًا وَاحِدًا فَلْیَتَّزِرْ بِہِ۔",,,3215
3216,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ جَابِرٍ ، قَالَ : رَأَیْتُہُ یُصَلِّی فِی ثَوْبٍ مُؤْتَزِرًا بِہِ۔",,,3216
3217,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ إبْرَاہِیمَ بْنِ أَبِی عَطَائٍ ، قَالَ : سَمِعْتُ عَبْدَ الرَّحْمَنِ بْنَ أَبِی نُعْمٍ یَقُولُ : إنَّ أَبَا سَعِیدٍ سُئِلَ عَنِ الصَّلاَۃِ فِی الثَّوْبِ الْوَاحِدِ ؟ فَقَالَ : یَتَّزِرُ بِہِ کَمَا یَتَّزِرُ لِلصِّراع۔",,,3217
3218,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَمِعْتُ حَیَّانَ الْبَارِقِیَّ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ : لَوْ لَمْ أَجِدْ إِلاَّ ثَوْبًا وَاحِدًا کُنْتُ أَتَّزِرُ بِہِ أَحَبُّ إلَیَّ مِنْ أَنْ أَتَوَشَّحَ بِہِ تَوَشُّحَ الْیَہُودِ۔",,,3218
3219,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : إذَا أَرَادَ الرَّجُلُ أَنْ یُصَلِّیَ فَلَمْ یَکُنْ لَہُ إِلاَّ ثَوْبٌ وَاحِدٌ اتَّزَرَ بِہِ۔",,,3219
3220,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ نَافِعٍ بْنِ عُمَرَ ، قَالَ : صَلَّی بِنَا عَبْدُ اللہِ بْنُ أَبِی مُلَیْکَۃَ فِی ثَوْبٍ وَاحِدٍ قَدْ رَفَعَہُ إلَی صَدْرِہِ۔",,,3220
3221,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا نَافِعٌ بْنِ عُمَرَ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی بِالْعَرَجِ فِی ثَوْبٍ وَاحِدٍ رَفَعَہُ إلَی صَدْرِہِ۔",,,3221
3222,"حَدَّثَنَا وَکِیعٌ ، عَنْ فُضَیْلِ بْنِ غَزْوَانَ ، عَنْ عَبْدِ اللہِ بْنِ وَاقِدٍ ، قَالَ : صَلَّیْت إلَی جَنْبِ عَبْدِ اللہِ بْنِ عُمَرَ وَأَنَا مُتَوَشِّحٌ فَأَمَرَنِی بِالإِزْرَۃِ۔",,,3222
3223,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ تُصَلِّ فِی ثَوْبٍ وَاحِدٍ ، إِلاَّ أَنْ لاَ تَجِدَ غَیْرَہُ۔",,,3223
3224,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُلَیْمَانُ بْنُ قَرْمٍ ، عَنْ أَبِی فَزَارَۃَ ، عَنْ أَبِی زَیْدٍ ، عَنِ ابْنِ مَسْعُودٍ، قَالَ : لاَ تُصَلِّیَنَّ فِی ثَوْبٍ ، وَإِنْ کَانَ أَوْسَعَ مَا بَیْنَ السَّمَائِ وَالأَرْضِ۔",,,3224
3225,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، قَالَ : رَأَیْتُ أَبَا قِلاَبَۃَ وَعَلَیْہِ جُبَّۃٌ وَمِلْحَفَۃٌ غَسِیلَۃٌ وَہُوَ یُصَلِّی مُضْطَبِعًا قَدْ أَخْرَجَ یَدَہُ الْیُمْنَی۔",,,3225
3226,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قیلَ لِلْحَسَنِ : إنَّہُمْ یَقُولُونَ یُکْرَہُ أَنْ یُصَلِّیَ الرَّجُلُ وَقَدْ أَخْرَجَ یَدَہُ مِنْ تَحْتِ نَحْرِہِ ، فَقَالَ الْحَسَنُ : لَوْ وَکَّلَ اللَّہُ دِینَہُ إلَی ہَؤُلاَئِ ، لَضَیَّقُوا عَلَی عِبَادِہِ۔",,,3226
3227,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیرِیِّ ، عَنْ حَیَّانَ بْنِ عُمَیْرٍ ، قَالَ : کُنْتُ مَعَ قَیْسِ بْنِ عُبَادٍ ، فَرَأَی رَجُلاً یُصَلِّی قَدْ أَخْرَجَ یَدَہُ مِنْ عِنْدِ نَحْرِہِ ، فَقَالَ : اذْہَبْ إلَی صَاحِبِکَ فَقُلْ لَہُ : فَلْیَضَعْ یَدَہُ مِنْ مَکَانِ یَدِ الْمَغْلُولِ ، فَأَتَیْتُہُ ، فَقُلْتُ لَہُ : إنَّ قَیْسًا یَقُولُ : ضَعْ یَدَک مِنْ مَکَانِ یَدِ الْمَغْلُولِ ، قَالَ : فَوَضَعَہَا۔",,,3227
3228,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ مُسْلِمٍ ، عَنْ إبْرَاہِیمَ بْنِ مَیْسَرَۃَ ، عَنْ طَاوُوسٍ ، قَالَ : لَقَدْ رَأَیْتُہُ یُصَلِّی ضَابِعًا بِرِدَائِہِ مِنْ تَحْتِ عَضُدِہِ۔",,,3228
3229,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الْوَلِیدِ بْنِ الْعَیْزَارِ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، عَنْ عَبْدِ اللہِ بْنِ مَسْعُودٍ ، قَالَ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَیُّ الْعَمَلِ أَفْضَلُ ؟ قَالَ : الصَّلاَۃُ لِوَقْتِہَا۔ (بخار ی527۔ ترمذی 1898)",,,3229
3230,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حَجَّاجٍ ، عَنِ الْحَسَنِ بْنِ سَعْدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ اللہِ ، عَنِ ابْنِ مَسْعُودٍ ؛ {الَّذِینَ ہُمْ عَلَی صَلاَتِہِمْ دَائِمُونَ} قَالَ : عَلَی مَوَاقِیتِہَا۔",,,3230
3231,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، قَالَ : نُبِّئْتُ أَنَّ أَبَا بَکْرٍ وَعُمَرَ کَانَا یُعَلِّمَانِ النَّاسَ : تَعْبُدُ اللَّہَ، وَلاَ تُشْرِکُ بِہِ شَیْئًا ، وَتُقِیمُ الصَّلاَۃَ الَّتِی افْتَرَضَ اللَّہُ لِمَوَاقِیتِہَا ، فَإِنَّ فِی تَفْرِیطِہَا الْہَلَکَۃَ۔",,,3231
3232,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : الْحِفَاظُ عَلَی الصَّلاَۃِ ، الصَّلاَۃُ لِوَقْتِہَا۔",,,3232
3233,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، قَالَ : مَا کَانَ الأَسْوَدُ إِلاَّ رَاہِبًا ، یَتَخَلَّفُ یُرَی أَنَّہُ یُصَلِّی ، فَإِذَا جَائَ وَقْتُ الصَّلاَۃِ أَنَاخَ وَلَوْ عَلَی الْحِجَارَۃِ۔",,,3233
3234,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : کَتَبَ إلَیْنَا عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : أَمَّا بَعْدُ ، فَإِنَّ عُری الدِّینِ وَقِوَامَ الإِسْلاَمِ الإِیمَانُ بِاللَّہِ ، وَإِقَامُ الصَّلاَۃِ ، وَإِیتَائُ الزَّکَاۃِ ، فَصَلِّ الصَّلاَۃَ لِوَقْتِہَا ، وَحَافِظْ عَلَیْہَا۔",,,3234
3235,حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُعْجِبُہُ إذَا کَانَ فِی سَفَرٍ ، أَنْ یُصَلِّیَ الصَّلاَۃَ لِوَقْتِہَا۔,,,3235
3236,"حَدَّثَنَا وَکِیعٌ، عَنْ عُمَرَ بْنِ مُوسَی، عَنْ أَبِی جَعْفَرٍ، قَالَ: قُلْتُ لَہُ: أَیُّ الصَّلاَۃِ أَفْضَلُ؟ قَالَ: فِی أَوَّلِ وَقْتٍ۔",,,3236
3237,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمِ بْنِ أَبِی النَّجُودِ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ، عَنْ سَعْدٍ ، قَالَ : السَّہْوُ: التَّرْکُ عَنِ الْوَقْتِ۔",,,3237
3238,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَی الْعُمَرِیُّ ، عَنْ القَاسِمِ بْنِ غَنَّامٍ ، عَنْ بَعْضِ أُمَّہَاتِہِ ، عَنْ أُمِّ فَرْوَۃَ ؛ أَنَّہَا سَأَلَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَیُّ الْعَمَلِ ، أَوْ أَیُّ الصَّلاَۃِ ، أَفْضَلُ ؟ فَقَالَ : الصَّلاَۃُ فِی أَوَّلِ وَقْتِہَا۔",,,3238
3239,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ عَیَّاشِ بْنِ أَبِی رَبِیعَۃَ ، عَنْ حَکِیمِ بْنِ حَکِیمِ بْنِ عَبَّادِ بْنِ حُنَیْفٍ ، عَنْ نَافِعِ بْنِ جُبَیْرِ بْنِ مُطْعِمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَمَّنِی جِبْرِیلُ عِنْدَ الْبَیْتِ مَرَّتَیْنِ ، فَصَلَّی بِی الظُّہْرَ حِینَ زَالَتِ الشَّمْسُ وَکَانَتْ بِقَدْرِ الشِّرَاکِ ، وَصَلَّی بِی الْعَصْرَ حِینَ کَانَ ظِلَّ کُلِّ شَیْئٍ مِثْلَہُ ، وَصَلَّی بِی الْمَغْرِبَ حِینَ أَفْطَرَ الصَّائِمُ ، وَصَلَّی بِی الْعِشَائَ حِینَ غَابَ الشَّفَقُ ، وَصَلَّی بِی الْفَجْرَ حِینَ حَرُمَ الطَّعَامُ وَالشَّرَابُ عَلَی الصَّائِمِ ، وَصَلَّی بِی الْغدَ الظُّہْرَ حِینَ کَانَ ظِلَّ کُلِّ شَیْئٍ مِثْلَہُ ، وَصَلَّی بِی الْعَصْرَ حِینَ کَانَ ظِلَّ کُلِّ شَیْئٍ مِثْلَیْہِ ، وَصَلَّی بِی الْمَغْرِبَ حِینَ أَفْطَرَ الصَّائِمُ ، وَصَلَّی بِی الْعِشَائَ ثُلُثَ اللَّیْلِ ، وَصَلَّی بِی الْفَجْرَ فَأَسْفَرَ ، ثُمَّ الْتَفَتَ إلَیَّ ، فَقَالَ : یَا مُحَمَّدُ ، ہَذَا الْوَقْتُ وَقْتُ النَّبِیِّینَ قَبْلَک ، الْوَقْتُ مَا بَیْنَ ہَذَیْنِ الْوَقْتَیْنِ۔\n\n(ترمذی 149۔ ابوداؤد 396)",,,3239
3240,"حَدَّثَنَا وَکِیعٌ ، عَنْ بَدْرِ بْنِ عُثْمَانَ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی مُوسَی سَمِعَہُ مِنْہُ ، عَنْ أَبِیہِ ؛ أَنَّ سَائِلاً أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَسَأَلَہُ عَنْ مَوَاقِیتِ الصَّلاَۃِ فَلَمْ یَرُدَّ شَیْئًا ، قَالَ : ثُمَّ أَمَرَ بِلاَلاً فَأَقَامَ حِینَ انْشَقَّ الْفَجْرُ فَصَلَّی ، ثُمَّ أَمَرَہُ فَأَقَامَ الصَّلاَۃَ وَالْقَائِلُ یَقُولُ : قَدْ زَالَتِ الشَّمْسُ ، أَوْ لَمْ تَزُلْ ، وَہُوَ کَانَ أَعْلَمَ مِنْہُمْ، ثُمَّ أَمَرَہُ فَأَقَامَ الْعَصْرَ وَالشَّمْسُ مُرْتَفِعَۃٌ ، وَأَمَرَہُ فَأَقَامَ الْمَغْرِبَ حِینَ وَقَعَتِ الشَّمْسُ ، وَأَمَرَہُ فَأَقَامَ الْعِشَائَ عِنْدَ سُقُوطِ الشَّفَقِ ، ثُمَّ صَلَّی الْفَجْرَ مِنَ الْغَدِ وَالْقَائِلُ یَقُولُ : قَدْ طَلَعَتِ الشَّمْسُ ، أَوْ لَمْ تَطْلُعْ ، وَہُوَ کَانَ أَعْلَمَ مِنْہُمْ ، وَصَلَّی الظُّہْرَ قَرِیبًا مِنْ وَقْتِ الْعَصْرِ بِالأَمْسِ ، وَصَلَّی الْعَصْرَ وَالْقَائِلُ یَقُولُ : قَدِ احْمَرَّتِ الشَّمْسُ ، وَصَلَّی الْمَغْرِبَ قَبْلَ أَنْ یَغِیبَ الشَّفَقُ ، وَصَلَّی الْعِشَائَ ثُلُثَ اللَّیْلِ الأَوَّلَ ، ثُمَّ قَالَ : أَیْنَ السَّائِلُ عَنِ الْوَقْتِ ؟ مَا بَیْنَ ہَذَیْنِ الْوَقْتَیْنِ وَقْتٌ۔ (مسلم 178۔ ابوداؤد 398)",,,3240
3241,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ لِلصَّلاَۃِ أَوَّلاً وَآخِرًا ، وَإِنَّ أَوَّلَ وَقْتِ الظُّہْرِ حِینَ تَزُولُ الشَّمْسُ ، وَإِنَّ آخِرَ وَقْتِہَا حِینَ یَدْخُلُ وَقْتُ الْعَصْرِ ، وَإِنَّ أَوَّلَ وَقْتِ الْعَصْرِ حِینَ یَدْخُلُ وَقْتُ الْعَصْرِ ، وَإِنَّ آخِرَ وَقْتِہَا حِینَ تَصْفَارُّ الشَّمْسُ ، وَإِنَّ أَوَّلَ وَقْتِ الْمَغْرِبِ حِینَ تَغْرُبُ الشَّمْسُ ، وَإِنَّ آخِرَ وَقْتِہَا حِینَ یَغِیبُ الأَفُقُ ، وَإِنَّ أَوَّلَ وَقْتِ الْعِشَائِ الآخِرَۃِ حِینَ یَغِیبُ الأَفُقُ ، وَإِنَّ آخِرَ وَقْتِہَا حِینَ یَنْتَصِفُ اللَّیْلُ ، وَإِنَّ أَوَّلَ وَقْتِ الْفَجْرِ حِینَ یَطْلُعُ الْفَجْرُ ، وَإِنَّ آخِرَ وَقْتِہَا حِینَ تَطْلُعُ الشَّمْسُ۔ (ترمذی 151۔ احمد 2/232)",,,3241
3242,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَوْفٍ ، عَنْ أَبِی الْمِنْہَالِ ، عَنْ أَبِی بَرْزَۃَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی الْہَجِیرَ الَّتِی تَدْعُونَہَا الأَولَی حِین تَدْحُضُ الشَّمْسُ ، وَیُصَلِّی الْعَصْرَ ، ثُمَّ یَرْجِعُ أَحَدُنَا إلَی رَحْلِہِ فِی أَقْصَی الْمَدِینَۃِ وَالشَّمْسُ حَیَّۃٌ ، قَالَ : وَنَسِیت مَا قَالَ فِی الْمَغْرِبِ ، قَالَ : وَکَانَ یَسْتَحِبُّ أَنْ یُؤَخِّرَ مِنَ الْعِشَائِ الَّتِی تَدْعُونَہَا الْعَتَمَۃَ ، وَکَانَ یَنْفَتِلُ مِنْ صَلاَۃِ الْغَدَاۃِ حِینَ یَعْرِفُ الرَّجُلُ جَلِیسَہُ ، وَکَانَ یَقْرَأُ بِالسِّتِّینَ إلَی الْمِئَۃِ۔ (مسلم 237۔ ابوداؤد 401)",,,3242
3243,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن مُحَمَّدِ بْنِ عَمْرِو بْنِ حسن، عَنْ جَابِرِ بْن عَبْدِاللہِ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی الظُّہْرَ بِالْہَاجِرَۃِ ،وَالْعَصْرَ وَالشَّمْسُ نَقِیَّۃٌ ، وَالْمَغْرِبَ إذَا وَجَبَتْ ، وَالْعِشَائَ أَحْیَانًا یُؤَخِّرُہَا وَأَحْیَانًا یُعَجِّلُ ، إذَا رَآہُمْ قَدِ اجْتَمَعُوا عَجَّلَ ، وَإِذَا رَآہُمْ قَدْ أَبْطَؤوا أَخَّرَ ، وَالصُّبْحَ ، قَالَ : کَانُوا ، أَوْ قَالَ : وَکَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّیہَا بِغَلَسٍ۔ \n\n(بخاری 560۔ مسلم 233)",,,3243
3244,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سُئِلَ عَنْ صَلاَۃِ الْفَجْرِ ؟ فَأَمَرَ بِلاَلاً فَأَذَّنَ حِینَ طَلَعَ الْفَجْرُ ، ثُمَّ مِنَ الْغَدِ حِینَ أَسْفَرَ ، ثُمَّ قَالَ : أَیْنَ السَّائِلُ ؟ مَا بَیْنَ ذَیْنِ وَقْتٌ۔",,,3244
3245,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنِی خَارِجَۃُ بْنُ عَبْدِ اللہِ بْنِ سُلَیْمَانَ بْنِ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : حَدَّثَنِی حُسَیْنُ بْنُ بَشِیر بْنِ سَلْمَانَ ، عَنْ أَبِیہِ ، قَالَ : دَخَلْت أَنَا وَمُحَمَّدُ بْنُ عَلِیٍّ ، أَوْ رَجُلٌ مِنْ آلِ عَلِیٍّ ، عَلَی جَابِرِ بْنِ عَبْدِ اللہِ فَقُلْنَا لَہُ : حَدِّثْنَا کَیْفَ کَانَتِ الصَّلاَۃُ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَقَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الظُّہْرَ حِینَ کَانَ الظِّلُّ مِثْلَ الشِّرَاکِ ، ثُمَّ صَلَّی بِنَا الْعَصْرَ حِینَ کَانَ الظِّلُّ مِثْلَہُ وَمِثْلَ الشِّرَاکِ ، ثُمَّ صَلَّی بِنَا الْمَغْرِبَ حِینَ غَابَتِ الشَّمْسُ ، ثُمَّ صَلَّی بِنَا الْعِشَائَ حِینَ غَابَ الشَّفَقُ ، ثُمَّ صَلَّی بِنَا الْفَجْرَ حِینَ طَلَعَ الْفَجْرُ ، ثُمَّ صَلَّی بِنَا مِنَ الْغَدِ الظُّہْرَ حِینَ کَانَ ظِلُّ کُلِّ شَیْئٍ مِثْلَہُ ، ثُمَّ صَلَّی بِنَا الْعَصْرَ حِینَ کَانَ ظِلُّ کُلِّ شَیْئٍ مِثْلَیْہِ قَدْرَ مَا یَسِیرُ الرَّاکِبُ إلَی ذِی الْحُلَیْفَۃِ الْعَنَقِ ، ثُمَّ صَلَّی بِنَا الْمَغْرِبَ حِینَ غَابَتِ الشَّمْسُ ، ثُمَّ صَلَّی بِنَا الْعِشَائَ حِینَ ذَہَبَ ثُلُثُ اللَّیْلِ ، ثُمَّ صَلَّی بِنَا الْفَجْرَ فَأَسْفَرَ ۔ فَقُلْنَا لَہُ : کَیْفَ نُصَلِّی مَعَ الْحَجَّاجِ وَہُوَ یُؤَخِّرُ ؟ فَقَالَ : مَا صَلَّی لِلْوَقْتِ فَصَلُّوا مَعَہُ ، فَإِذَا أَخَّرَ فَصَلُّوہَا لِوَقْتِہَا ، وَاجْعَلُوہَا مَعَہُ نَافِلَۃً ، وَحَدِیثِی ہَذَا عِنْدَکُمْ أَمَانَۃٌ فَإِذَا مِتُّ ، فَإِنِ اسْتَطَاعَ الْحَجَّاجُ أَنْ یَنْبُشَنِی فَلْیَنْبُشْنِی۔ (نسائی 524)",,,3245
3246,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، قَالَ : أَخْبَرَنِی بَشِیرُ بْنُ أَبِی مَسْعُودٍ ، عَنْ أَبِیہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : نَزَلَ جِبْرِیلُ فَأَمَّنِی ، حَتَّی عَدَّ خَمْسَ صَلَوَاتٍ۔ (بخاری 521۔ مسلم 425)",,,3246
3247,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، قَالَ : سَمِعْتُ أَبَا أَیُّوبَ یُحَدِّثُ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ: وَقْتُ الظُّہْرِ مَا لَمْ یَحْضُرْ وَقْتُ الْعَصْرِ ، وَوَقْتُ الْعَصْرِ مَا لَمْ تَصْفَرَّ الشَّمْسُ ،وَوَقْتُ الْمَغْرِبِ مَا لَمْ یَسْقُطْ ثَوْر الشَّفَقِ ، وَوَقْتُ الْعِشَائِ إلَی نِصْفِ اللَّیْلِ ، وَوَقْتُ الصُّبْحِ مَا لَمْ تَطْلُعِ الشَّمْسُ۔",,,3247
3248,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ قَتَادَۃَ ، عَنْ أَبِی أَیُّوبَ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ: لَمْ یَرْفَعْہُ مَرَّتَیْنِ ، ثُمَّ رَفَعَہُ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ ثُمَّ ذَکَرَ مِثْلَ حَدِیثِ غُنْدَرٍ۔\n\n(مسلم 427۔ احمد 2/213)",,,3248
3249,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْمُغِیرَۃِ بْنِ النُّعْمَانِ ، عَنْ عَلِیِّ بْنِ عَمْرٍو قَالَ : أَتَانَا کِتَابُ عُمَرَ : أَنْ صَلُّوا الْفَجْرَ وَالنُّجُومُ مُشْتَبِکَۃٌ نَیِّرَۃٌ ، وَصَلُّوا الظُّہْرَ إذَا زَالَتِ الشَّمْسُ عَنْ بَطْنِ السَّمَائِ ، وَصَلُّوا الْعَصْرَ وَالشَّمْسُ بَیْضَائُ نَقِیَّۃٌ ، وَصَلُّوا الْمَغْرِبَ حِینَ تَغْرُبُ الشَّمْسُ ، وَرَخَّصَ فِی الْعِشَائِ۔",,,3249
3250,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ نَافِعِ بْنِ جُبَیْرٍ ، قَالَ : کَتَبَ عُمَرُ إلَی أَبِی مُوسَی : أَنْ صَلِّ الظُّہْرَ إذَا زَالَتِ الشَّمْسُ ، وَصَلِّ الْعَصْرَ وَالشَّمْسُ بَیْضَائُ حَیَّۃٌ ، وَصَلِّ الْمَغْرِبَ إذَا اخْتَلَطَ اللَّیْلُ وَالنَّہَارُ ، وَصَلِّ الْعِشَائَ أَیَّ اللَّیْلِ شِئْتَ ، وَصَلِّ الْفَجْرَ إذَا نَوَّرَ النُّورُ۔",,,3250
3251,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ جَابِرٍ ، قَالَ : الظُّہْرُ کَاسْمِہَا ، وَالْعَصْرُ وَالشَّمْسُ بَیْضَائُ حَیَّۃٌ، وَالْمَغْرِبُ کَاسْمِہَا، کُنَّا نُصَلِّی مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَغْرِبَ، ثُمَّ نَأْتِی مَنَازِلَنَا عَلَی قَدْرِ مِیلٍ فَنَرَی مَوَاقِعَ النَّبْلِ ، وَکَانَ یُعَجِّلُ بِالْعِشَائِ ، وَیُؤَخِّرُ ، وَالْفَجْرُ کَاسْمِہَا ، وَکَانَ یُغَلِّسُ بِہَا۔ (احمد 3/303۔ عبدالرزاق 2091)",,,3251
3252,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : کُنَّ نِسَائُ الْمُؤْمِنَاتِ یُصَلِّینَ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃَ الصُّبْحِ ، ثُمَّ یَرْجِعْنَ إلَی أَہْلِہِنَّ فَلاَ یَعْرِفُہُنَّ أَحَدٌ۔\n\n(بخاری 578۔ مسلم 231)",,,3252
3253,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی الْفَجْرَ ، ثُمَّ یَخْرُجْنَ نِسَائُ الْمُؤْمِنِینَ مُتَلَفِّعات فِی مُرُوطِہِنَّ مَا یُعْرَفْنَ مِنَ الْغَلَسِ۔",,,3253
3254,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : أَخْبَرَنِی الْمُہَاجِرُ ، قَالَ : قَرَأْتُ کِتَابَ عُمَرَ إلَی أَبِی مُوسَی فِیہِ مَوَاقِیتُ الصَّلاَۃِ ، فَلَمَّا انْتَہَی إلَی الْفَجْرِ ، أَوَ قَالَ : إلَی الْغَدَاۃِ ، قَالَ : قُمْ فِیہَا بِسَوَادٍ ، أَوْ بِغَلَسٍ، وَأَطِلِ الْقِرَائَۃَ۔",,,3254
3255,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مَنْصُورُ بْنُ حَیَّانَ ، قَالَ : سَمِعْتُ عَمْرَو بْنَ مَیْمُونٍ الأَوْدِیَّ یَقُولُ: إِنْ کُنْتُ لأصَلِّی خَلْفَ عُمَرَ بْنِ الْخَطَّابِ الْفَجْرَ ، وَلَوْ أَنَّ ابْنِی مِنِّی ثَلاَثَۃَ أَذْرُعٍ ، مَا عَرَفْتُہُ حَتَّی یَتَکَلَّمَ۔",,,3255
3256,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مَنْصُورِ بْنِ حَیَّانَ ، قَالَ : کَتَبَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ إلَی عَبْدِ الْحَمِیدِ : أَنْ غَلِّسْ بِالْفَجْرِ۔",,,3256
3257,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی سَلْمَانَ ، قَالَ : خَدَمْتُ الرَّکْبَ فِی زَمَانِ عُثْمَانَ ، فَکَانَ النَّاسُ یُغَلِّسُونَ بِالْفَجْرِ۔",,,3257
3258,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ حَبِیبِ بْنِ شِہَابٍ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَا مُوسَی صَلَّی الْفَجْرَ بِسَوَادٍ۔,,,3258
3259,حَدَّثَنَا وَکِیعٌ ، عَنْ نَافِعِ بْنِ عُمَرَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ؛ أَنَّہُ صَلَّی مَعَ ابْنِ الزُّبَیْرِ ، فَکَانَ یُغَلِّسُ بِالْفَجْرِ ، فَیَنْصَرِفُ وَلاَ یَعْرِفُ بَعْضُنَا بَعْضًا۔,,,3259
3260,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : أَخْبَرَنِی عَبْدُ اللہِ بْنُ إیَاسٍ الْحَنَفِیُّ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا نُصَلِّی مَعَ عُثْمَانَ الْفَجْرَ ، فَنَنْصَرِفُ ، وَمَا یَعْرِفُ بَعْضُنَا وُجُوہَ بَعْضٍ۔",,,3260
3261,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ عَاصِمِ بْنِ عُمَرَ بْنِ قَتَادَۃَ ، عَنْ مَحْمُودِ بْنِ لَبِیدٍ ، عَنْ رَافِعِ بْنِ خَدِیجٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَسْفِرُوا بِالْفَجْرِ ، فَإِنَّہُ أَعْظَمُ لِلأَجْرِ۔\n\n(ابوداؤد 427۔ احمد 3/140)",,,3261
3262,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا نُصَلِّی الْفَجْرَ فَیَقْرَأُ إمَامُنَا بِالسُّورَۃِ مِنَ الْمِئِیْنَ وَعَلَیْنَا ثِیَابُنَا ، ثُمَّ نَأْتِی ابْنَ مَسْعُودٍ فَنَجِدُہُ فِی الصَّلاَۃِ۔",,,3262
3263,"حَدَّثَنَا شَرِیکٌ ، عَنْ سَعِیدِ بْنِ عُبَیْدٍ ، عَنْ عَلِیِّ بْنِ رَبِیعَۃَ ؛ أَنَّ عَلِیًّا ، قَالَ : یَا ابْنَ النَّبَّاحِ ، أَسْفِرْ بِالْفَجْرِ۔",,,3263
3264,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ؛ أَنَّ ابْنَ مَسْعُودٍ کَانَ یُنَوِّرُ بِالْفَجْرِ۔,,,3264
3265,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ أَبِی رَوْقٍ، عَنْ زِیَادِ بْنِ الْمُقَطِّعِ، قَالَ: رَأَیْتُ الْحُسَیْنَ بْنَ عَلِیٍّ أَسْفَرَ بِالْفَجْرِ جِدًّا۔",,,3265
3266,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، عَنْ أَبِی الزَّاہِرِیَّۃِ ، عَنْ جُبَیْرِ بْنِ نُفَیْرٍ ، قَالَ : صَلَّی بِنَا مُعَاوِیَۃُ بِغَلَسٍ ، فَقَالَ أَبُو الدَّرْدَائِ : أَسْفِرُوا بِہَذِہِ الصَّلاَۃِ ، فَإِنَّہُ أَفْقَہُ لَکُمْ۔",,,3266
3267,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ رَضِیِّ بْنِ أَبِی عَقِیلٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ رَبِیعُ بْنُ جُبَیْرٍ یَقُولُ لَہُ ، وَکَانَ مُؤَذِّنُہُ : یَا أَبَا عَقِیلٍ ، نَوِّرْ ، نَوِّرْ۔",,,3267
3268,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : کَانَ ابْنُ مَسْعُودٍ یُنَوِّرُ بِالْفَجْرِ۔",,,3268
3269,حَدَّثَنَا وَکِیعٌ ، عَنْ عُثْمَانَ بْنِ أَبِی ہِنْدٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ کَانَ یُسْفِرُ بِالْفَجْرِ۔,,,3269
3270,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یُسْفِرُونَ بِالْفَجْرِ۔",,,3270
3271,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُبَیْدٍ الْمُکْتِبِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُنَوِّرُ بِالْفَجْرِ۔,,,3271
3272,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ سَعْدٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَسْفِرُوا بِالْفَجْرِ ، فَإِنَّکُمْ کُلَّمَا أَسْفَرْتُمْ کَانَ أَعْظَمَ لِلأَجْرِ۔ (طحاوی 179)",,,3272
3273,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانُوا یُحِبُّونَ أَنْ یَنْصَرِفُوا مِنْ صَلاَۃِ الصُّبْحِ ، وَأَحَدُہُمْ یَرَی مَوْضِعَ نَبْلِہِ۔",,,3273
3274,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ بِشْرِ بْنِ عُرْوَۃَ ، قَالَ : سَافَرْت مَعَ عَلْقَمَۃَ ، فَکَانَ یُنَوِّرُ بِالصُّبْحِ۔",,,3274
3275,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : مَا أَجْمَعَ أَصْحَابُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَلَی شَیْئٍ مَا أَجْمَعُوا عَلَی التَّنْوِیرِ بِالْفَجْرِ۔",,,3275
3276,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ نَفَاعَۃَ بْنِ مُسْلِمٍ ، قَالَ : کَانَ سُوَیْد بْنُ غَفَلَۃَ یُسْفِرُ بِالْفَجْرِ۔",,,3276
3277,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ وِقَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یُنَوِّرُ بِالْفَجْرِ۔,,,3277
3278,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ رَجُلٍ ؛ أَنَّ أُنَاسًا مِنْ أَصْحَابِ عَبْدِ اللہِ کَانُوا یُسْفِرُونَ بِصَلاَۃِ الْفَجْرِ۔,,,3278
3279,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ أَبِی حَصِینٍ ، عَنْ خَرَشَۃَ ، قَالَ : صَلَّی عُمر بِالنَّاسِ الْفَجْر فَغَلَّسَ وَنَوَّرَ ، وَصَلَّی بِہِمْ فِیمَا بَیْنَ ذَلِکَ۔",,,3279
3280,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ عُمَیْرٍ ، قَالَ : صَلَّی الْمُغِیرَۃُ بْنُ شُعْبَۃَ الصُّبْحَ فَغَلَّسَ وَنَوَّرَ ، حَتَّی قُلْتُ : قَدْ طَلَعَتِ الشَّمْسُ ، أَوْ لَمْ تَطْلُعْ ، وَصَلَّی فِیمَا بَیْنَ ذَلِکَ ، وَکَانَ مُؤَذِّنُہُ ابْنَ النَّبَّاحِ ، وَلَمْ یَکُنْ لَہُ مُؤَذِّنٌ غَیْرُہُ۔",,,3280
3281,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ سَدُوسٍ ، رَجُلٍ مِنَ الْحَیِّ ؛ أَنَّ الرَّبِیعَ ، قَالَ : نَوِّرْ ، نَوِّرْ۔",,,3281
3282,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الرُّکَیْنِ الضَّبِّیِّ ، قَالَ : سَمِعْتُ تَمِیمَ بْنَ حَذْلَمَ ، وَکَانَ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، یَقُولُ : نَوِّرْ ، نَوِّرْ بِالصَّلاَۃِ۔",,,3282
3283,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَکِیمِ بْنِ جُبَیْرٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عَائِشَۃَ قَالَتْ : مَا رَأَیْتُ أَحَدًا کَانَ أَشَدَّ تَعْجِیلاً لِلظُّہْرِ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَلاَ أَبًو بَکْرٍ ، وَلاَ عُمَرَ۔\n\n(ترمذی 155۔ احمد 6/135)",,,3283
3284,"حَدَّثَنَا جَرِیرٌ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : کَانَ عُمَرُ یُصَلِّی الظُّہْرَ حِینَ تَزُولُ الشَّمْسُ۔",,,3284
3285,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ عَبْدِ اللہِ بْنِ مُرَّۃَ ، عَنْ مَسْرُوقٍ ، قَالَ : صَلَّی بِنَا عَبْدُ اللہِ بْنُ مَسْعُودٍ الظُّہْرَ حِینَ زَالَتِ الشَّمْسُ ، ثُمَّ قَالَ : ہَذَا ، وَالَّذِی لاَ إلَہَ غَیْرُہُ ، وَقْتُ ہَذِہِ الصَّلاَۃِ۔",,,3285
3286,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ عَنْ مَسْرُوقٍ ، قَالَ : لَمَّا زَالَتِ الشَّمْسُ جَائَ أَبُو مُوسَی ، فَقَالَ : أَیْنَ صَاحِبُکُمْ ؟ ہَذَا وَقْتُ ہَذِہِ الصَّلاَۃِ ، فَلَمْ یَلْبَثْ أَنْ جَائَ عَبْدُ اللہِ مُسْرِعًا ، فَصَلَّی الظُّہْرَ۔",,,3286
3287,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَوْفٍ ، قَالَ : حدَّثَنِی أَبُو الْمِنْہَالِ ، قَالَ : انْتَہَیْت مَعَ أَبِی إلَی أَبِی بَرْزۃَ ، فَقَالَ : حَدِّثْنَا کَیْفَ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی الْمَکْتُوبَۃَ ؟ فَقَالَ : کَانَ یُصَلِّی الْہَجِیرَ الَّتِی تَدْعُونَہَا الأُولَی حِینَ تَدْحَضُ الشَّمْسُ۔",,,3287
3288,"حَدَّثَنَا إسْمَاعِیلُ بْنُ إبْرَاہِیمَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، قَالَتْ أُمُّ سَلَمَۃَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَشَدَّ تَعْجِیلاً لِلظُّہْرِ مِنْکُمْ ، وَأَنْتُمْ أَشَدُّ تَأْخِیرًا لِلْعَصْرِ مِنْہُ۔ \n\n(ترمذی 163۔ احمد 6/310)",,,3288
3289,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ حَبِیبِ بْنِ شِہَابٍ ، عَنْ أَبِیہِ ، قَالَ : سَأَلْتُ أَبَا ہُرَیْرَۃَ عَنْ وَقْتِ الظُّہْرِ ؟ فَقَالَ : إذَا زَالَتِ الشَّمْسُ عَنْ نِصْفِ النَّہَارِ ، وَکَانَ الظِّلُّ قِیسَ الشِّرَاکِ فَقَدْ قَامَتِ الظُّہْرُ۔",,,3289
3290,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، قَالَ : حدَّثَنِی مَیْمُونُ بْنُ مِہْرَانَ ؛ أَنَّ سُوَیْد بْنَ غَفَلَۃَ کَانَ یُصَلِّی الظُّہْرَ حِینَ تَزُولُ الشَّمْسُ فَأَرْسَلَ إلَیْہِ الْحَجَّاجُ لاَ تَسْبِقْنَا بِصَلاَتِنَا ، فَقَالَ سُوَیْد : قَدْ صَلَّیْتہَا مَعَ أَبِی بَکْرٍ وَعُمَرَ ہَکَذَا ، وَالْمَوْتُ أَقْرَبُ إلَیَّ مِنْ أَنْ أَدَعَہَا۔",,,3290
3291,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إسْمَاعِیلَ بْنِ سُمَیْعٍ ، عَنْ مُسْلِمٍ الْبَطِینِ ، عَنْ أَبِی الْبَخْتَرِیِّ ، قَالَ : کَانَ عُمر یَنْصَرِفُ مِنَ الْہَجْر فِی الْحَرِّ ، ثُمَّ یَنْطَلِقُ الْمُنْطَلِقُ إلَی قُبَائَ فَیَجِدُہُمْ یُصَلُّونَ۔",,,3291
3292,"حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : کَانَ بِلاَلٌ یُؤَذِّنُ إذَا دَحَضَتِ الشَّمْسُ۔ (مسلم 188۔ ابوداؤد 406)",,,3292
3293,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ وَہْبٍ ، عَنْ خبّاب ، قَالَ : شَکَوْنَا إلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الصَّلاَۃَ فِی الرَّمْضَائِ ، فَلَمْ یُشْکِنَا۔ (مسلم 189۔ احمد 5/108)",,,3293
3294,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ سَعِیدِ بْنِ الْحَارِثِ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : کُنْتُ أُصَلِّی مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الظُّہْرَ ، فَآخُذُ قَبْضَۃً مِنَ الْحَصَی فَأَجْعَلُہَا فِی کَفِّی ، ثُمَّ أُحَوِّلُہَا إلَی الْکَفِّ الأُخْرَی حَتَّی تَبْرُدَ ، ثُمَّ أَضَعُہَا لِجَبِینِی حِینَ أَسْجُدُ ، مِنْ شِدَّۃِ الْحَرِّ۔\n\n(ابوداؤد 402۔ احمد 3/327)",,,3294
3295,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : کُنَّا نُصَلِّی مَعَہُ الظُّہْرَ أَحْیَانًا نَجِدُ ظِلاًّ نَجْلِسُ فِیہِ ، وَأَحْیَانًا لاَ نَجِدُ ظِلاًّ نَجْلِسُ فِیہِ۔",,,3295
3296,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زَیْدِ بْنِ جُبَیْرٍ ، عَنْ خِشْفِ بْنِ مَالِکٍ ، قَالَ : صَلَّی بِنَا عَبْدُ اللہِ وَإِنَّ الْجَنَادِبَ لَتَنْقُِزُ مِنْ شِدَّۃِ الرَّمْضَائِ۔",,,3296
3297,"حَدَّثَنَا حَفْصٌ ، عَنِ أَبِی الَعَنْبَسِ ، قَالَ : سَأَلْتُ أَبِی ، قُلْتُ : صَلَّیْتَ مَعَ عَلِیٍّ ، فَأَخْبِرْنِی کَیْفَ کَانَ یُصَلِّی الظُّہْرَ ؟ فَقَالَ : إذَا زَالَتِ الشَّمْسُ۔",,,3297
3298,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، قَالَ : سَأَلْتُ جَعْفَرًا عَنْ وَقْتِ الظُّہْرِ ؟ فَقَالَ : إذَا زَالَتِ الشَّمْسُ ، ثُمَّ قَالَ : تسْمَعْ ، لأَنْ یُؤَخِّرَہَا رَجُلٌ حَتَّی یُصَلِّیَ الْعَصْرَ خَیْرٌ لَہُ مِنْ أَنْ یُصَلِّیَہَا قَبْلَ أَنْ تَزُولَ الشَّمْسُ۔",,,3298
3299,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَبْرِدُوا بِالصَّلاَۃِ ، یَعْنِی الظُّہْرَ ، فَإِنَّ شِدَّۃَ الْحَرِّ مِنْ فَیْحِ جَہَنَّمَ۔\n\n(بخاری 3259۔ احمد 3/59)",,,3299
3300,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَبْرِدُوا بِالصَّلاَۃِ ، فَإِنَّ حَرَّ الظَّہِیرَۃِ مِنْ فَیْحِ جَہَنَّمَ۔ (بخاری 536۔ مسلم 430)",,,3300
3301,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، عَنْ شُعْبَۃَ ، قَالَ : حدَّثَنَا الْمُہَاجِرُ أَبُو الْحَسَنِ ، قَالَ : سَمِعْتُ زَیْدَ بْنَ وَہْبٍ یُحَدِّثُ ، عَنْ أَبِی ذَرٍّ ، قَالَ : کُنَّا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مَسِیرٍ فَأَرَادَ بِلاَلٌ أَنْ یُؤَذِّنَ ، فَقَالَ لَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَبْرِدْ ، ثُمَّ أَرَادَ أَنْ یُؤَذِّنَ ، فَقَالَ : أَبْرِدْ ، حَتَّی رَأَیْنَا فَیْئَ التُّلُولِ ، ثُمَّ أَذَّنَ فَصَلَّی الظُّہْرَ ، ثُمَّ قَالَ : إنَّ شِدَّۃَ الْحَرِّ مِنْ فَیْحِ جَہَنَّمَ ، فَإِذَا اشْتَدَّ الْحَرُّ فَأَبْرِدُوا بِالصَّلاَۃِ۔\n\n(بخاری 535۔ مسلم 431)",,,3301
3302,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی مُوسَی ، عَنْ أَبِی مُوسَی ، أَنَّہُ کَانَ یَقُولُ : أَبْرِدُوا بِالصَّلاَۃِ۔",,,3302
3303,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ الرَّحْمَنِ بْنِ سَابِطٍ ، قَالَ : أَذَّنَ أَبُو مَحْذُورَۃَ بِصَلاَۃِ الظُّہْرِ بِمَکَّۃَ ، فَقَالَ لَہُ عُمَرُ : أَصَوْتُک یَا أَبَا مَحْذُورَۃَ الَّذِی سَمِعْتُ ؟ قَالَ : نَعَمْ ، ذَخَرْتُہُ لَکَ یَا أَمِیرَ الْمُؤْمِنِینَ لأَسْمِعَکَہُ ، فَقَالَ عُمَرُ : یَا أَبَا مَحْذُورَۃَ ، إنَّک بِأَرْضٍ شَدِیدَۃِ الْحَرِّ ، فَأَبْرِدْ بِالصَّلاَۃِ ، ثُمَّ أَبْرَدَ بِہَا۔",,,3303
3304,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : الْحَرُّ ، أَوْ شِدَّۃُ الْحَرِّ مِنْ فَیْحِ جَہَنَّمَ ، فَأَبْرِدُوا بِالظُّہْرِ۔",,,3304
3305,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، قَالَ : حدَّثَنَا بَشِیر بْن سَلْمَانَ ، عَنِ الْقَاسِمِ بْنِ صَفْوَانَ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : أَبْرِدُوا بِصَلاَۃِ الظُّہْرِ ، فَإِنَّ شِدَّۃَ الْحَرِّ مِنْ فَیْحِ جَہَنَّمَ۔\n\n(بخاری 2923۔ احمد 4/262)",,,3305
3306,"حَدَّثَنَا وَکِیعٌ ، قَالَ : إسْمَاعِیلُ ، عَنْ قَیْسٍ ، قَالَ : کَانَ یُقَالُ : أَبْرِدُوا بِالظُّہْرِ فَإِنَّ أَبْوَابَ جَہَنَّمَ تُفْتَحُ۔",,,3306
3307,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ مُنْذِرٍ ، قَالَ : قَالَ عُمَرُ : أَبْرِدُوا بِالظُّہْرِ ، فَإِنَّ شِدَّۃَ الْحَرِّ مِنْ فَیْحِ جَہَنَّمَ۔",,,3307
3308,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أَبِی مَالِکٍ الأَشْجَعِیِّ ، عَنْ کَثِیرِ بْنِ مُدْرِکٍ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، قَالَ : قَالَ عَبْدُ اللہِ : إنَّ أَوَّلَ وَقْتِ الظُّہْرِ أَنْ تَنْظُرَ إلَی قَدَمَیْک فَتَقِیسَ ثَلاَثَۃَ أَقْدَامٍ إلَی خَمْسَۃِ أَقْدَامٍ ، وَإِنَّ أَوَّلَ الْوَقْتِ الأَخِرِ خَمْسَۃُ أَقْدَامٍ إلَی سَبْعَۃِ أَقْدَامٍ ، أَظُنُّہُ قَالَ : فِی الشِّتَائِ۔",,,3308
3309,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، قَالَ : کَانُوا یُصَلُّونَ الظُّہْرَ وَالظِّلُّ قَامَۃٌ۔",,,3309
3310,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُصَلَّی الظُّہْرُ إذَا کَانَ الظِّلُّ ثَلاَثَۃَ أَذْرُعٍ ، وَإِنْ عَجَّلَتْ بِرَجُلٍ حَاجَۃٌ صَلَّی قَبْلَ ذَلِکَ ، وَإِنْ شَغَلَہُ شَیْئٌ صَلَّی بَعْدَ ذَلِکَ ، قَالَ زَائِدَۃُ : قُلْتُ لِمَنْصُورٍ : أَلَیْسَ إِنَّمَا یَعْنِی ذَلِکَ فِی الصَّیْفِ ؟ قَالَ : بَلَی۔",,,3310
3311,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُقَالُ : إذَا کَانَ ظِلُّ الرَّجُلِ ثَلاَثَۃَ أَذْرُعٍ فَہُوَ وَقْتُ صَلاَۃِ الظُّہْرِ۔",,,3311
3312,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : صَلَّیْت مَعَ ابْنِ عُمَرَ فَأَرَدْت أَنْ أَقِیسَ صَلاَتَہُ ، فَفَطِنْتُ لِظِلِّی فَقِسْتُہُ ، فَوَجَدْتُہُ ثَلاَثَۃَ أَذْرُعٍ۔",,,3312
3313,"حَدَّثَنَا فَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا حُرَیْثُ بْنُ السَّائِبِ ، قَالَ : سَأَلْتُ مُحَمَّدَ بْنَ سِیرِینَ عَنْ وَقْتِ صَلاَۃِ الظُّہْرِ ؟ فَقَالَ : إذَا کَانَ ظِلُّہُ ثَلاَثَۃَ أَذْرُعٍ فَذَاکَ حِینَ تُصَلَّی الظُّہْرُ۔",,,3313
3314,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، قَالَ : حدَّثَنَا حُرَیْثُ بْنُ السَّائِبِ ، قَالَ : سَأَلْتُ الْحَسَنَ عَنْ وَقْتِ الظُّہْرِ ؟ فَقَالَ : إذَا زَالَ الْفَیْئُ عَنْ طُولِ الشَّیْئِ فَذَاکَ حِینَ تُصَلَّی الظُّہْرُ۔",,,3314
3315,"حَدَّثَنَا وَکِیعٌ ، وَمُعَاذٌ ، کِلاَہُمَا عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : لَیْسَ الْوَقْتُ مَمْدُودًا کَالشِّرَاکِ ، مَنْ أَخْطَأَہُ ہَلَکَ۔",,,3315
3316,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُرْوَۃَ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی الْعَصْرَ وَالشَّمْسُ طَالِعَۃٌ فِی حُجْرَتِی ، لَمْ یَظْہَرِ الْفَیئُ بَعْدُ۔ (بخاری 522۔ ابوداؤد 410)",,,3316
3317,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ رِبْعِیِّ بْنِ حِرَاشٍ ، عَنْ أَبِی الأَبْیَضِ ، عَنْ أَنَسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی الْعَصْرَ وَالشَّمْسُ بَیْضَائُ مُحَلِّقَۃٌ ، ثُمَّ آتِی عَشِیرَتِی فِی جَانِبِ الْمَدِینَۃِ لَمْ یُصَلُّوا فَأَقُولُ : مَا یُجْلِسُکُمْ ؟ صَلُّوا ، فَقَدْ صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔\n\n(احمد 3/232۔ دارقطنی 10)",,,3317
3318,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ عَبْدَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ غَنْمٍ ، قَالَ : کَتَبْتُ إلَی عُمَرَ أَسْأَلُہُ عَنْ وَقْتِ الْعَصْرِ ؟ فَکَتَبَ إلَیَّ أَنْ صَلِّ الْعَصْرَ إذَا کَانَتِ الشَّمْسُ بَیْنَ الشِّقَّیْنِ۔",,,3318
3319,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یُصَلِّی الْعَصْرَ وَالشَّمْسُ بَیْضَائُ نَقِیَّۃٌ ، یُعَجِّلُہَا مَرَّۃً ، وَیُؤَخِّرُہَا أُخْرَی۔",,,3319
3320,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ خَیْثَمَۃَ ، قَالَ : تُصَلَّی الْعَصْرُ وَالشَّمْسُ بَیْضَائُ حَیَّۃٌ ، وَحَیَاتُہَا أَنْ تَجِدَ حَرَّہَا۔",,,3320
3321,"حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ ، عَنِ الأَوْزَاعِیِّ ، عَنْ أَبِی النَّجَاشِیِّ ، عَنْ رَافِعِ بْنِ خَدِیجٍ ، قَالَ : کُنَّا نُصَلِّی مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ نَنْحَرُ الْجَزُورَ ، فَنَقْسِمُ عَشَرَۃَ أَجْزَائٍ ، ثُمَّ نَطْبُخُ ، وَنَأْکُلُ لَحْمًا نَضِیجًا قَبْلَ أَنْ نُصَلِّیَ الْمَغْرِبَ۔ (بخاری 2480۔ مسلم 435)",,,3321
3322,"حَدَّثَنَا حَفْصٌ ، عَنْ أَبِی الَعَنْبَسِ ، قَالَ : سَأَلْتُ أَبِی ، قُلْتُ : صَلَّیْتَ مَعَ عَلِیٍّ ، فَأَخْبِرْنِی کَیْفَ کَانَ یُصَلِّی الْعَصْرَ ؟ فَقَالَ : کَانَ یُصَلِّی الْعَصْرَ وَالشَّمْسُ مُرْتَفِعَۃٌ۔",,,3322
3323,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ ہِشَامٍ، عَنْ أَبِیہِ ، قَالَ: قدِمَ رَجُلٌ عَلَی الْمُغِیرَۃِ بْنِ شُعْبَۃَ وَہُوَ عَلَی الْکُوفَۃِ، فَرَآہُ یُؤَخِّرُ الْعَصْرَ، فَقَالَ لَہُ: لِمَ تُؤَخِّرُ الْعَصْرَ ؟ فَقَدْ کُنْتُ أُصَلِّیہَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ أَرْجِعُ إلَی أَہْلِی إلَی بَنِی عَمْرِو بْنِ عَوْفٍ وَالشَّمْسُ مُرْتَفِعَۃٌ۔",,,3323
3324,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا لَیْثُ بْنُ سَعْدٍ ، عَنِ ابْنِ شِہَابٍ ، عَنْ أَنَسٍ ، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی الْعَصْرَ وَالشَّمْسُ مُرْتَفِعَۃٌ حَیَّۃٌ ، فَیَذْہَبُ الذَّاہِبُ فَیَأْتِی الْعَوَالِیَ وَالشَّمْسُ مُرْتَفِعَۃٌ۔\n\n(مسلم 192۔ ابوداؤد 407)",,,3324
3325,"حَدَّثَنِی أَحْمَدُ بْنُ إِسْحَاقَ ، عَنْ وُہَیْبٍ ، عَنْ أَبِی وَاقِدٍ ، عَنْ أَبِی أَرْوَی ، قَالَ : کُنْتُ أُصَلِّی مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْعَصْرَ، ثُمَّ آتِی الشَّجَرَۃَ، یَعْنِی ذَا الْحُلَیْفَۃِ قَبْلَ أَنْ تَغِیبَ الشَّمْسُ۔(طحاوی 191)",,,3325
3326,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الْعَصْرَ ، ثُمَّ أَخْرَجَ مَالاً یَقْسِمُہُ یُبَادِرُ بِہِ اللَّیْلَ۔,,,3326
3327,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ أَبِی عَاصِمٍ ، عَنْ أَبِی عَوْنٍ ؛ أَنَّ عَلِیًّا کَانَ یُؤَخِّرُ الْعَصْرَ حَتَّی تَرْتَفِعَ الشَّمْسُ عَلَی الْحِیطَانِ۔,,,3327
3328,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ مُنَبِّہٍ ، عَنْ سَوَّارِ بْنِ شَبِیبٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّہُ کَانَ یُؤَخِّرُ الْعَصْرَ حَتَّی أَقُولَ : قدِ اصْفَرَّتِ الشَّمْسُ۔",,,3328
3329,حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ صَالِحٍ ، وَإِسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یُؤَخِّرُ الْعَصْرَ۔,,,3329
3330,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ ابْنُ أَخِی الأَسْوَدِ مُؤَذِّنَہُمْ ، فَکَانَ یُعَجِّلُ الْعَصْرَ ، فَقَالَ لَہُ الأَسْوَدُ : لَتُطِیعُنَا فِی أَذَانِنَا ، أَوْ لَتَعْتَزِلَنَّ مُؤَذِّنِینَا۔",,,3330
3331,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ مَنْ قَبْلَکُمْ أَشَدَّ تَأْخِیرًا لِلْعَصْرِ مِنْکُمْ۔",,,3331
3332,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ وَکِیعٍ ، قَالَ : قَالَ لِی إبْرَاہِیمُ : لاَ تُقِمِ الْعَصْرَ حَتَّی لاَ تَسْمَعَ حَوْلَک مُؤَذِّنًا۔",,,3332
3333,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : أَتَیْتُ عَبْدَ الرَّحْمَنِ بْنَ الأَسْوَدِ وَہُوَ یَتَوَضَّأُ ، فَقَالَ : غَلَبَنَا الْحَوَّاکُونَ عَلَی صَلاَتِنَا یُعَجِّلُونَہَا ، یَعْنِی الْعَصْرَ۔",,,3333
3334,"حَدَّثَنَا جَرِیرٌ عن أبی سنان ، عَنِ ابْنِ أَبِی الْہُذَیْلِ ، قَالَ: تُصَلَّی العصر قَدْرَ مَا تَسِیرُ الْعِیرُ فَرْسَخًا إلَی غُرُوبِ الشَّمْسِ۔",,,3334
3335,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ مَرْدَانُبَۃَ ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ ، قَالَ : سَأَلْتُ أَنَسًا عَنْ وَقْتِ الْعَصْرِ ؟ فَقَالَ : وَقْتُہَا أَنْ تَسِیرَ سِتَّۃَ أَمْیَالٍ إلَی أَنْ تَغْرُبَ الشَّمْسُ۔",,,3335
3336,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ حَرِیشٍ ، عَنْ طَلْحَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : تُصَلَّی الْعَصْرُ إذَا کَانَ الظِّلُّ وَاحِدًا وَعِشْرِینَ قَدَمًا فِی الشِّتَاء وَالصَّیْفِ۔",,,3336
3337,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : إنَّمَا سُمِّیَتِ الْعَصْرَ لِتَعْتَصِرَ۔",,,3337
3338,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عن حمید ، عَنْ أَنَسٍ ، قَالَ : کُنَّا نُصَلِّی الْمَغْرِبَ فِی مَسْجِدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ نَأْتِی بَنِی سَلِمَۃَ ، وَأَحَدُنَا یَرَی مَوْقِعَ نَبْلِہ۔ (ابوداؤد 419۔ ابن خزیمۃ 338)",,,3338
3339,"حَدَّثَنَا عَلِیُّ بْنُ إِسْحَاقَ ، عَنِ ابْنِ مُبَارَکٍ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : حدَّثَنَا أَبُو النَّجَاشِیِّ ، قَالَ : حَدَّثَنَا رَافِعُ بْنُ خَدِیجٍ ، قَالَ : کُنَّا نُصَلِّی الْمَغْرِبَ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَیَنْصَرِفُ أَحَدُنَا ، وَإِنَّہُ لَیَنْظُرُ إلَی مَوَاقِعِ نَبْلِہِ۔ (بخاری 559۔ مسلم 441)",,,3339
3340,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : قَالَ عُمَرُ : صَلُّوا ہَذِہِ الصَّلاَۃَ وَالْفِجَاجُ مُسْفِرَۃٌ ، یَعْنِی الْمَغْرِبَ۔",,,3340
3341,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ طَارِقٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : کَانَ عُمَرُ یَکْتُبُ إلَی أُمَرَائِ الأَمْصَارِ أَنْ لاَ تَنْتَظِرُوا بِصَلاَتِکُمَ اشْتِبَاکَ النُّجُومِ۔",,,3341
3342,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ، قَالَ : کَانَ عَبْدُ اللہِ یُصَلِّی الْمَغْرِبَ حِینَ تَغْرُبُ الشَّمْسُ وَیَقُولُ : ہَذَا ، وَالَّذِی لاَ إِلٰہَ إِلاَّ ہُوَ ، وَقْتُ ہَذِہِ الصَّلاَۃِ۔",,,3342
3343,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُجَالِدٍ ، عَنْ مُحَمَّدِ بْنِ بِشْرٍ ، قَالَ : کَانَ ابْنُ الْحَنَفِیَّۃِ یَأْمُرُ مُؤَذِّنَہُ فَیُؤَذِّنُ الْمَغْرِبَ حِینَ تَغْرُبُ الشَّمْسُ سَوَائً۔",,,3343
3344,حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ إسْمَاعِیلَ بْنِ أبی خَالِدٍ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ؛ أَنَّ سُوَیْد بْنَ غَفَلَۃَ کَانَ یَأْمُرُ مُؤَذِّنَہُ أَنْ یُؤَذِّنَ الْمَغْرِبَ إذَا غَرَبَتِ الشَّمْسُ۔,,,3344
3345,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، عَنْ حَجَّاجٍ الصَّوَّافِ ، عَنْ عَبْدِ اللہِ الدَّانَاجِ ، قَالَ : کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَنَاضَلُونَ بَعْدَ الْمَغْرِبِ۔",,,3345
3346,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ حَاجِبِ بْنِ عُمَرَ ، قَالَ : کُنْتُ أَسْمَعُ عَمِّی الْحَکَمَ بْنَ الأَعْرَجِ یَسْأَلُ دِرْہَمًا أَبَا ہِنْدٍ عَنْ ہَذَا الْحَدِیثِ ؟ فَیَقُولُ دِرْہَمٌ : کُنْتُ أُقْبِلُ مِنَ السُّوقِ فَیَتَلَقَّانِی النَّاسُ مُنْصَرِفِینَ ، قَدْ صَلَّی بِہِمْ مَعْقِلُ بْنُ یَسَارٍ ، فَأَتَمَارَی غَرُبَتِ الشَّمْسُ ، أَوْ لَمْ تَغْرُبْ۔",,,3346
3347,"حَدَّثَنَا حَفْصٌ ، عَنْ أَبِی الَعَنْبَسِ عَمْرِو بْنِ مَرْوَانَ ، قَالَ : سَأَلْتُ أَبِی ، قُلْتُ : قَدْ صَلَّیْتَ مَعَ عَلِیٍّ ، فَأَخْبِرْنِی کَیْفَ کَانَ یُصَلِّی الْمَغْرِبَ ؟ فَقَالَ : کَانَ یُصَلِّی إذَا سَقَطَ الْقُرْصُ۔",,,3347
3348,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنِ الزُّہْرِیِّ ، عَنْ رَجُلٍ أَظُنُّہُ قَالَ : مِنْ أَبْنَائِ النُّقَبَائِ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا نُصَلِّی الْمَغْرِبَ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، ثُمَّ نَرْجِعُ إلَی رِحَالِنَا وَأَحَدُنَا یُبْصِرُ مَوَاقِعَ النَّبْلِ ، قَالَ : قُلْتُ لِلزُّہْرِیِّ : وَکَمْ کَانَتْ مَنَازِلُہُمْ مِنَ الْمَدِینَۃِ ، قَالَ : ثُلُثَیْ مِیلٍ۔ (طبرانی 117)",,,3348
3349,"حَدَّثَنَا شَبَابَۃُ ، قَالَ: حَدَّثَنَا ابْنُ أَبِی ذِئْبٍ، عَنْ صَالِحٍ مَوْلَی التَّوْأَمَۃِ ، عَنْ زَیْدِ بْنِ خَالِدٍ ، قَالَ : کُنَّا نُصَلِّی مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَغْرِبَ ، ثُمَّ نَنْصَرِفُ إلَی السُّوقِ ، وَلَوْ رُمِیَ بِنَبْلٍ أَبْصَرْتُ مَوَاقِعَہَا۔\n\n(احمد 4/115۔ طبرانی 5260)",,,3349
3350,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنِ السُّدِیِّ ، عَنْ أَبِی مَالِکٍ ، عَنْ مَسْرُوقٍ ، قَالَ : صَلَّیْت مَعَ عَبْدِ اللہِ الْمَغْرِبَ ، مِقْدَارَ مَا إذَا رَمَی رَجُلٌ بِسَہْمٍ رَأَی مَوْضِعَہُ۔",,,3350
3351,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا ابْنُ أَبِی ذِئْبٍ ، عَنْ أَبِی حَبِیبَۃَ ، أَنَّہُ بَلَغَہُ عَنْ أَبِی أَیُّوبَ الأَنْصَارِیِّ، أَنَّہُ سَمِعَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : صَلُّوا الْمَغْرِبَ حِینَ فِطْرِ الصَّائِمِ ، مُبَادَرَۃَ طُلُوعِ النُّجُومِ۔ (طبرانی4083)",,,3351
3352,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُؤَخِّرُ الْعِشَائَ الآخِرَۃَ۔ (مسلم 226۔ احمد 5/89)",,,3352
3353,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ حَبِیبِ بْنِ سَالِمٍ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ، قَالَ : أَنَا مِنْ أَعْلَمِ النَّاسِ ، أَوْ کَأَعْلَمِ النَّاسِ بِوَقْتِ صَلاَۃِ ) رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْعِشَائَ ، کَانَ یُصَلِّیہَا بَعْدَ سُقُوطِ الْقَمَرِ لَیْلَۃَ الثَّانِیَۃِ مِنْ أَوَّلِ الشَّہْرِ۔ (ترمذی 165۔ احمد 4/270)",,,3353
3354,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَوْفٍ ، عَنْ أَبِی الْمِنْہَالِ ، عَنْ أَبِی بَرْزَۃَ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْتَحِبُّ أَنْ یُؤَخِّرَ مِنَ الْعِشَائِ الَّتِی یَدْعُونَہَا النَّاسُ الْعَتَمَۃَ۔",,,3354
3355,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ جَابِرٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُعَجِّلُ الْعِشَائَ وَیُؤَخِّرُ۔",,,3355
3356,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، قَالَ : حدَّثَنَا ابْنُ شِہَابٍ ، عَنْ عُرْوَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کان یُصَلِّی الْعِشَائَ حِینَ یَسْوَدُّ الأَفُقُ ، وَرُبَّمَا أَخَّرَہَا حَتَّی یَجْتَمِعَ النَّاسُ۔ \n\n(ابوداؤد 397۔ ابن خزیمۃ 352)",,,3356
3357,"حَدَّثَنَا ابْنُ الْمُبَارَکِ ، عَنْ مَعْمَرٍ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ ، عَنِ ابْنِ لَبِیبَۃَ ، قَالَ : قَالَ لِی أَبُو ہُرَیْرَۃَ : صَلِّ الْعِشَائَ إذَا ذَہَبَ الشَّفَقُ وَادْلاَمَّ اللَّیْلُ مَا بَیْنَکَ وَبَیْنَ ثُلُثِ اللَّیْلِ ، وَمَا عَجَّلْتَ بَعْدَ ذَہَابِ بَیَاضِ الأُفُقِ فَہُوَ أَفْضَلُ۔",,,3357
3358,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ عُمَرَ کَتَبَ إلَی أَبِی مُوسَی أَنْ صَلِّ الْعِشَائَ إلَی ثُلُثِ اللَّیْلِ ، فَإِنْ أَخَّرْت فَإِلَی الشَّطْرِ ، وَلاَ تَکُنْ مِنَ الْغَافِلِینَ۔,,,3358
3359,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : کَانَ ابْنُ مَسْعُودٍ یُؤَخِّرُ الْعِشَائَ۔",,,3359
3360,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : وَقْتُ الْعِشَائِ الآخِرَۃِ رُبْعُ اللَّیْلِ۔",,,3360
3361,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرِو بْنِ مَرْوَانَ ، قَالَ : سَأَلْتُ أَبِی ، قُلْتُ : صَلَّیْتَ مَعَ عَلِیٍّ ، فَأَخْبِرْنِی کَیْفَ کَانَ یُصَلِّی الْعِشَائَ ؟ قَالَ : إذَا غَابَ الشَّفَقُ۔",,,3361
3362,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : وَقْتُ الْعِشَائِ إلَی ثُلُثِ اللَّیْلِ ، وَلاَ نَوْمَ ، وَلاَ غَفلَۃَ۔",,,3362
3363,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : انْتَظَرْنَا لَیْلَۃً رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لِصَلاَۃِ الْعِشَائِ الآخِرَۃِ ، حَتَّی کَانَ ثُلُثُ اللَّیْلِ ، أَوْ بَعْدُ ، ثُمَّ خَرَجَ إلَیْنَا ، فَلاَ أَدْرِی أَشَیْئٌ شَغَلَہُ أَوْ حَاجَۃٌ کَانَتْ لَہُ فِی أَہْلِہِ ، فَقَالَ : مَا أَعْلَمُ أَہْلَ دِینٍ یَنْتَظِرُونَ ہَذِہِ الصَّلاَۃَ غَیْرَکُمْ ، وَلَوْلاَ أَنْ أَشُقَّ عَلَی أُمَّتِی لَصَلَّیْتُ بِہِمْ ہَذِہِ الصَّلاَۃَ ہَذِہِ السَّاعَۃَ۔ (بخاری 570۔ ابوداؤد 423)",,,3363
3364,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْلاَ أَنْ أَشُقَّ عَلَی أُمَّتِی لأَخَّرْتُ صَلاَۃَ الْعِشَائِ إلَی ثُلُثِ اللَّیْلِ ، أَوْ نِصْفِ اللَّیْلِ۔ (ابن ماجہ 691)",,,3364
3365,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حَرِیزٌ ، قَالَ : حَدَّثَنَا رَاشِدُ بْنُ سَعْدٍ ، عَنْ عَاصِمِ بْنِ حُمَیْدِ السَّکُونِیِّ ، وَکَانَ مِنْ أَصْحَابِ مُعَاذٍ ، عَنْ مُعَاذِ بْنِ جَبَلٍ ، قَالَ : بَقَیْنَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی صَلاَۃِ الْعِشَائِ حَتَّی أَبْطَأَ ، حَتَّی قَالَ الْقَائِلُ : قَدْ صَلَّی وَلَمْ یَخْرُجْ ، فَخَرَجَ عَلَیْنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالْقَائِلُ یَقُولُ : یَا رَسُولَ اللہِ ، ظَنَنَّا أَنَّک صَلَّیْت وَلَمْ تَخْرُجْ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَعْتِمُوا بِہَذِہِ الصَّلاَۃِ ، فَقَدْ فُضِّلْتُمْ بِہَا عَلَی سَائِرِ الأُمَمِ ، وَلَمْ تُصَلِّہَا أُمَّۃٌ قَبْلَکُمْ۔\n\n(ابوداؤد 424۔ احمد 5/237)",,,3365
3366,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، عَنْ مُحَمَّدِ بْنِ مُسْلِمٍ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : أَخَّرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃَ الْعِشَائِ ذَاتَ لَیْلَۃٍ ، فَخَرَجَ وَرَأْسُہُ یَقْطُرُ فَقَالَ : لَوْلاَ أَنْ أَشُقَّ عَلَی أُمَّتِی لَجَعَلْتُ وَقْتَ ہَذِہِ الصَّلاَۃِ ہَذَا الْحِینَ۔ (دارمی 1215۔ ابن حبان 1533)",,,3366
3367,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ عَمْرٍو قَالَ : حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ عَمْرِو بْنِ ضَمْرَۃَ ، عَنْ رَجُلٍ مِنْ جُہَیْنَۃَ ، قَالَ : قَالَ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَتَی أُصَلِّی الْعِشَائَ ؟ قَالَ : إذَا مَلأَ اللَّیْلُ بَطْنَ کُلِّ وَادٍ۔ (احمد 5/365)",,,3367
3368,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عُبَیْدٍ ، عَنْ أَبِیہِ ، قَالَ : کُنَّا نُصَلِّی مَعَ النُّعْمَانِ ، یَعْنِی ابْنَ بَشِیرٍ ، الْمَغْرِبَ فَمَا یَخْرُجُ آخرُنَا حَتَّی یَبْدَأَ بِالْعِشَائِ۔",,,3368
3369,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : قَالَ عُمَرُ: عَجِّلُوا الْعِشَائَ قَبْلَ أَنْ یَکْسَلَ الْعَامِلُ ، وَیَنَامَ الْمَرِیضُ۔",,,3369
3370,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ أَثْقَلَ الصَّلاَۃِ عَلَی الْمُنَافِقِینَ صَلاَۃُ الْعِشَائِ وَصَلاَۃُ الْفَجْرِ ، وَلَوْ یَعْلَمُونَ مَا فِیہِمَا لأَتَوْہُمَا وَلَوْ حَبْوًا ، وَلَقَدْ ہَمَمْت أَنْ آمُرَ بِالصَّلاَۃِ ، فَتُقَامَ ، ثُمَّ آمُرَ رَجُلاً ، فَیُصَلِّیَ بِالنَّاسِ ، ثُمَّ أَنْطَلِقَ مَعِی بِرِجَالٍ ، مَعَہُمْ حُزَمٌ مِنْ حَطَبٍ إلَی قَوْمٍ لاَ یَشْہَدُونَ الصَّلاَۃَ ، فَأُحَرِّقَ عَلَیْہِمْ بُیُوتَہُمْ بِالنَّارِ۔\n\n(بخاری 657۔ ابوداؤد 549)",,,3370
3371,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْعَیْزَارِ بْنِ حُرَیْثٍ ، عَنْ أَبِی بَصِیرٍ ، قَالَ : قَالَ أُبَیّ بْنُ کَعْبٍ : صَلَّی بِنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَلَمَّا قَضَی الصَّلاَۃَ ، رَأَی مِنْ أَہْلِ الْمَسْجِدِ قِلَّۃً ، قَالَ : شَاہِدٌ فُلاَنٌ ؟ قُلْنَا : نَعَمْ ، حَتَّی عَدَّ ثَلاَثَۃَ نَفَرٍ ، فَقَالَ : إِنَّہُ لَیْسَ مِنْ صَلاَۃٍ أَثْقَلُ عَلَی الْمُنَافِقِینَ مِنْ صَلاَۃِ الْعِشَائِ الآخِرَۃِ ، وَمِنْ صَلاَۃِ الْفَجْرِ ، وَلَوْ یَعْلَمُونَ مَا فِیہِمَا لأَتَوْہُمَا وَلَوْ حَبْوًا۔(ابوداؤد 555۔ احمد 5/140)",,,3371
3372,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ یَحْیَی بْنق سَعِیدٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کُنَّا إذَا فَقَدْنَا الرَّجُلَ فِی صَلاَۃِ الْعِشَائِ وَصَلاَۃِ الْفَجْرِ ، أَسَأْنَا بِہِ الظَّنَّ۔",,,3372
3373,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ أَبِی بِشْرٍ ، عَنْ أَبِی عُمَیْرِ بْنِ أَنَسٍ ، قَالَ : حَدَّثَنِی عمُومَتِی مِنَ الأَنْصَارِ قَالُوا : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا یَشْہَدُہُمَا مُنَافِقٌ ، یَعْنِی الْعِشَائَ وَالْفَجْرَ۔\n\n(احمد 5/57۔ عبدالرزاق 2023)",,,3373
3374,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : سَمِعْتُ ابْنَ أَبِی لَیْلَی ، عَنْ أَبِی الدَّرْدَائِ ؛ أَنَّہُ قَالَ فِی مَرَضِہِ الَّذِی مَاتَ فِیہِ : أَلاَ احْمِلُونِی ، قَالَ : فَحَمَلُوہُ فَأَخْرَجُوہُ ، فَقَالَ : اسْمَعُوا ، وَبَلِّغُوا مَنْ خَلْفَکُمْ : حَافِظُوا عَلَی ہَاتَیْنِ الصَّلاَتَیْنِ ؛ الْعِشَائِ وَالصُّبْحِ ، وَلَوْ تَعْلَمُونَ مَا فِیہِمَا ) لأَتَیْتُمُوہُمَا وَلَوْ حَبْوًا عَلَی مَرَافِقِکُمْ وَرُکَبِکُمْ۔",,,3374
3375,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، قَالَ : أَخْبَرَنَا شَیْبَانُ ، عَنْ یَحْیَی ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَن یُحَنَّسَ ، أَنَّ عَائِشَۃَ أَخْبَرَتْہُ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالَ : لَوْ أَنَّ النَّاسَ یَعْلَمُونَ مَا فِی فَضْلِ صَلاَۃِ الْعِشَائِ وَصَلاَۃِ الصُّبْحِ لأَتَوْہُمَا وَلَوْ حَبْوًا۔ (احمد 6/80۔ نسائی 386)",,,3375
3376,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ التَّیْمِیِّ ، عَنِ ابْنِ أَبِی عَمْرَۃَ الأَنْصَارِیِّ ، قَالَ : جِئْت وَعُثْمَانُ جَالِسٌ فِی الْمَسْجِدِ صَلاَۃَ الْعِشَائِ الآخِرَۃِ ، فَجَلَسْتُ إلَیْہِ ، فَقَالَ عُثْمَانُ : شُہُودُ صَلاَۃِ الصُّبْحِ کَقِیَامِ لَیْلَۃٍ ، وَصَلاَۃُ الْعِشَائِ کَقِیَامِ نِصْفِ لَیْلَۃٍ۔",,,3376
3377,"حَدَّثَنَا شَبَابَۃُ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عُمَرَ ، قَالَ : لأَنْ أُصَلِّیَہُمَا فِی جَمَاعَۃٍ أَحَبُّ إلَیَّ مِنْ أَنْ أُحْیِیَ مَا بَیْنَہُمَا۔",,,3377
3378,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ \n\n(ح) وَشُعْبَۃُ ، عَنْ نَاجِیَۃَ بْنِ حَسَّانَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عُمَرَ ، قَالَ : لأَنْ أَشْہَدَ الْعِشَائَ وَالْفَجْرَ فِی جَمَاعَۃٍ أَحَبُّ إلَیَّ مِنْ أَنْ أُحْیِیَ مَا بَیْنَہُمَا۔",,,3378
3379,"حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ یَحْیَی بْنِ عَبْدِ الرَّحْمَنِ بْنِ حَاطِبٍ ، قَالَ : کَانَ عُمَرُ إذَا ہَبَطَ من السُّوقِ مَرَّ عَلَی الشِّفَائِ ابْنَۃِ عَبْدِ اللہِ ، فَمَرَّ عَلَیْہَا یَوْمًا مِنْ رَمَضَانَ ، فَقَالَ : أَیْنَ سُلَیْمَانُ ؟ ابْنُہَا ، قَالَتْ : نَائِمٌ ، قَالَ : وَمَا شَہِدَ صَلاَۃَ الصُّبْحِ ؟ قَالَتْ : لاَ ، قَامَ بِالنَّاسِ اللَّیْلَۃَ ، ثُمَّ جَائَ فَضَرَبَ بِرَأْسِہِ ، فَقَالَ عُمَرُ : شُہُودُ صَلاَۃِ الصُّبْحِ أَحَبُّ إلَیَّ مِنْ قِیَامِ لَیْلَۃٍ حَتَّی الصُّبْحِ۔",,,3379
3380,"حَدَّثَنَا یَزِیدُ عن ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لأَنْ أَشْہَدَ الْعِشَائَ وَالْفَجْرَ فِی جَمَاعَۃٍ أَحَبُّ إلَیَّ مِنْ أَنْ أُحْیِیَ مَا بَیْنَہُمَا۔",,,3380
3381,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : الشَّفَقُ الْحُمْرَۃُ۔",,,3381
3382,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَوَکِیعٌ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، قَالَ : کَانَ عُبَادَۃُ بْنُ الصَّامِتِ وَشَدَّادُ بْنُ أَوْسٍ یُصَلِّیَانِ الْعِشَائَ الآخِرَۃَ إذَا غَابَتِ الْحُمْرَۃُ۔",,,3382
3383,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الْعَوَّامِ بْنِ حَوْشَبٍ ، قَالَ : قُلْتُ لِمُجَاہِدٍ : الشَّفَقُ ، قَالَ : لاَ تَقُلِ الشَّفَقُ ، إنَّ الشَّفَقَ مِنَ الشَّمْسِ ، وَلَکِنْ قُلْ حُمْرَۃَ الأُفُقِ۔",,,3383
3384,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : أَخْبَرَنَا فُضَیْلُ بْنُ مَرْزُوقٍ ، قَالَ : سَأَلْتُ جَابِرًا الْجُعْفِیَّ عَنْ ہَذِہِ الآیَۃِ: {حَتَّی یَتَبَیَّنَ لَکُمُ الْخَیْطُ الأَبْیَضُ مِنَ الْخَیْطِ الأَسْوَدِ مِنَ الْفَجْرِ}؟ فَقَالَ : قَالَ سَعِیدُ بْنُ جُبَیْرٍ : فَہُوَ حُمْرَۃُ الأُفُقِ۔",,,3384
3385,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : بَیْنَ کُلِّ صَلاَتَیْنِ وَقْتٌ۔",,,3385
3386,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : مَا بَیْنَ الصَّلاَۃِ إلَی الصَّلاَۃِ وَقْتٌ۔",,,3386
3387,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُنْذِرٍ ، قَالَ : سَأَلْتُ مُرَّۃَ أَبَا رَزِینٍ مَتَی تَفُوتُنِی صَلاَۃٌ ؟ فَقَالَ : لاَ تَفُوتُک صَلاَۃٌ حَتَّی یَدْخُلَ وَقْتُ الأُخْرَی ، وَلَکِنْ بَیْنَ ذَلِکَ إفْرَاطٌ وَإِضَاعَۃٌ۔",,,3387
3388,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی الأَصْبَغِ ، قَالَ : سَمِعْتُ کَثِیرَ ابْنَ عَبَّاسٍ یَقُولُ : لاَ تَفُوتُ صَلاَۃٌ حَتَّی یُنَادَی بِالأُخْرَی۔",,,3388
3389,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُثْمَانَ بْنِ مَوْہَبٍ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یُسْأَل مَا التَّفْرِیطُ فِی الصَّلاَۃِ ؟ قَالَ : أَنْ تُؤَخِّرَہَا حَتَّی یَدْخُلَ وَقْتُ الَّتِی بَعْدَہَا۔",,,3389
3390,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : صَلَّیْت مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی بَیْتِ الْمَقْدِسِ ، سِتَّۃَ عَشَرَ شَہْرًا حَتَّی نَزَلَتِ الآیَۃُ الَّتِی فِی الْبَقَرَۃِ : {وَحَیْثُ مَا کُنْتُمْ فَوَلُّوا وُجُوہَکُمْ شَطْرَہُ} فَنَزَلَتْ بَعْدَ مَا صَلَّی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَانْطَلَقَ رَجُلٌ مِنَ الْقَوْمِ ، فَمَرَّ بِنَاسٍ مِنَ الأَنْصَارِ وَہُمْ یُصَلُّونَ ، فَحَدَّثَہُمْ بِالْحَدِیثِ فَوَلَّوْا وُجُوہَہُمْ قِبَلَ الْبَیْتِ۔ (مسلم 11۔ ترمذی 2962)",,,3390
3391,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ جَمِیلِ بْنِ عُبَیْدٍ الطَّائِیِّ ، عَنْ ثُمَامَۃَ ، عَنْ جَدِّہِ أَنَسِ بْنِ مَالِکٍ ، قَالَ : جَائَ مُنَادِی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : إنَّ الْقِبْلَۃَ قَدْ حُوِّلَتْ إلَی بَیْتِ اللہِ الْحَرَامِ ، وَقَدْ صَلَّی الإِمَامُ رَکْعَتَیْنِ ، فَاسْتَدَارُوا ، فَصَلَّوُا الرَّکْعَتَیْنِ الْبَاقِیَتَیْنِ نَحْوَ الْکَعْبَۃِ۔ (مسلم 375)",,,3391
3392,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَصْحَابُہُ إلَی بَیْتِ الْمَقْدِسِ سِتَّۃَ عَشَرَ شَہْرًا ، ثُمَّ جُعِلَتِ الْقِبْلَۃُ بَعْدُ۔ (احمد 1/250)",,,3392
3393,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا قَیْسٌ ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ ، عَنْ عُمَارَۃَ بْنِ أَوْسٍ ، قَالَ : کُنَّا نُصَلِّی إلَی بَیْتِ الْمَقْدِسِ إذْ أَتَانَا آتٍ وَإِمَامُنَا رَاکِعٌ ، وَنَحْنُ رُکُوعٌ ، فَقَالَ : إنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَدْ أُنْزِلَ عَلَیْہِ قُرْآنٌ ، وَقَدْ أُمِرَ أَنْ یَسْتَقْبِلَ الْکَعْبَۃَ أَلاَ فَاسْتَقْبِلُوہَا ، قَالَ : فَانْحَرَفَ إمَامُنَا وَہُوَ رَاکِعٌ ، وَانْحَرَفَ الْقَوْمُ حَتَّی اسْتَقْبَلُوا الْکَعْبَۃَ ، فَصَلَّیْنَا بَعْضَ تِلْکَ الصَّلاَۃِ إلَی بَیْتِ الْمَقْدِسِ ، وَبَعْضَہَا إلَی الْکَعْبَۃِ۔\n\n(ابو یعلی 1509۔ ابن سعد 243)",,,3393
3394,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا لَیْثُ بْنُ سَعْدٍ ، عَنْ عَقِیلٍ ، عَنِ ابْنِ شِہَابٍ ؛ أَنَّہُ سُئِلَ عَنْ قَوْمٍ صَلَّوْا فِی یَوْمِ غَیْمٍ إلَی غَیْرِ الْقِبْلَۃِ ، ثُمَّ اسْتَبَانَتْ لَہُم الْقِبْلَۃُ وَہُمْ فِی الصَّلاَۃِ ؟ فَقَالَ : یَسْتَقْبِلُونَ الْقِبْلَۃَ ، وَیَعْتَدُّونَ مَا صَلَّوْا، وَقَدْ فَعَلَ ذَلِکَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ أُمِرُوا أَنْ یَسْتَقْبِلُوا الْکَعْبَۃَ ، وَہُمْ فِی الصَّلاَۃِ یُصَلُّونَ إلَی بَیْتِ الْمَقْدِسِ فَاسْتَقْبَلُوا الْکَعْبَۃَ ، فَصَلَّوْا بَعْضَ تِلْکَ الصَّلاَۃِ إلَی بَیْتِ الْمَقْدِسِ ، وَبَعْضَہَا إلَی الْکَعْبَۃِ۔",,,3394
3395,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانُوا رُکُوعًا فِی صَلاَۃِ الصُّبْحِ ، فَانْحَرَفُوا وَہُمْ رُکُوعٌ۔",,,3395
3396,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا النَّضْرُ بْنُ عَرَبِیٍّ، قَالَ: سَمِعْتُ مُجَاہِدًا یَقُولُ: {فَأَیْنَمَا تُوَلُّوا فَثَمَّ وَجْہُ اللہِ} قَالَ: قِبْلَۃُ اللہِ، فَأَیْنَمَا کُنْتُمْ مِنْ شَرْقٍ أَوْ غَرْبٍ فَاسْتَقْبِلُوہَا۔",,,3396
3397,"حَدَّثَنَا وَکِیعٌ، عَنْ سَعِیدِ بْنِ سِنَانٍ أَبُو سِنَانٍ، قَالَ: سَمِعْتُ الضَّحَّاکَ بْنَ مُزَاحِمٍ یَقُولُ: (وَلِکُلٍّ وِجْہَۃٌ ہُوَ مُوَلِّیہَا) یَقُولُ: لِکُلٍّ قِبْلَۃٌ ہُوَ مُوَلِّیہَا۔",,,3397
3398,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا مِسْعَرٌ، عَنْ سِمَاکٍ الْحَنَفِیِّ، قَالَ: سَمِعْتُ ابْنَ عَبَّاسٍ یَقُولُ: لاَ تَجْعَلْ شَیْئًا مِنَ الْبَیْتِ خَلْفًا، وَأتَمَّ بِہِ جَمِیعًا۔",,,3398
3399,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ دَاوُدَ، عَنْ أَبِی الْعَالِیَۃِ، قَالَ: {شَطْرَہُ} : تِلْقَائَہُ۔",,,3399
3400,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ حُصَیْنٍ، عَنْ عَامِرٍ ؛ فِی الرَّجُلِ یُصَلِّی فِی یَوْمِ الْغَیْمِ لِغَیْرِ الْقِبْلَۃِ، قَالَ: یُجْزِئُہُ۔",,,3400
3401,"حَدَّثَنَا حَفْصٌ، عَنْ حَجَّاجٍ، قَالَ: سَأَلْتُ عَطَائً عَنِ الرَّجُلِ صَلَّی فِی یَوْمِ غَیْمٍ فَإِذَا ہُوَ قَدْ صَلَّی إلَی غَیْرِ الْقِبْلَۃِ ؟ قَالَ: یُجْزِئُہُ، قَالَ وَحَدَّثَنِی مَنْ سَأَلَ إبْرَاہِیمَ وَالشَّعْبِیَّ فَقَالاَ: یُجْزِئُہُ۔",,,3401
3402,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنِ الْقَعْقَاعِ بْنِ یَزِیدَ، قَالَ: صَلَّیْت وَأَنَا أَعْمَی لِغَیْرِ الْقِبْلَۃِ، فَسَأَلْت إبْرَاہِیمَ ؟ فَقَالَ: یُجْزِئُکَ۔",,,3402
3403,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، قَالَ: سَأَلْتُ عَطَائً عَنِ الرَّجُل یُصَلِّی لِغَیْرِ الْقِبْلَۃِ ؟ فَقَالَ: یُجْزِئُہُ۔",,,3403
3404,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یُصَلِّی إِلَی غَیْرِ الْقِبْلَۃِ ، قَالَ یُجْزِئُہُ۔",,,3404
3405,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا مِسْعَرٌ، عَنْ حَمَّادٍ، عَنْ إبْرَاہِیمَ، قَالَ: یُجْزِئُہُ۔",,,3405
3406,"حَدَّثَنَا وَکِیعٌ، حدَّثَنَا ابْنُ أَبِی عَرُوبَۃَ، عَنْ قَتَادَۃَ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، قَالَ: لاَ إعَادَۃَ عَلَیْہِ۔",,,3406
3407,"حَدَّثَنَا جَرِیرٌ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ، قَالَ: إذَا صَلَّی الرَّجُل فِی یَوْمِ غَیْمٍ لِغَیْرِ الْقِبْلَۃِ، ثُمَّ تَکَشَّفَ السَّحَابُ وَقَدْ صَلَّیْت بَعْضَ صَلاَتِکَ، فَاحْتَسِبْ بِمَا صَلَّیْت، ثُمَّ أَقْبِلْ بِوَجْہِکَ إلَی الْقِبْلَۃِ۔",,,3407
3408,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنْ حَمَّادٍ ؛ فِی رَجُلٍ صَلَّی لِغَیْرِ الْقِبْلَۃِ، قَالَ: قَدْ مَضَتْ صَلاَتُہُ۔",,,3408
3409,"حَدَّثَنَا ابْنُ أَبِی عَدِیٍّ، عَنْ ہِشَامٍ، عَنْ مُحَمَّدٍ، قَالَ: صَلَّی حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ فِی مَنْزِلِنَا، فَقُلْتُ لَہُ: إنَّ فِی قِبْلَتِنَا تَیَاسُرًا، فَأَعَادَ۔",,,3409
3410,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ، عَنْ زَکَرِیَّا بْنِ إِسْحَاقَ، عَنْ ہِشَامِ بْنِ حُجَیْرٍ، عَنْ طَاوُوسٍ، قَالَ: یُعِیدُ۔",,,3410
3411,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنِ ابْنِ أَبِی ذِئْبٍ، عَنِ الزُّہْرِیِّ، قَالَ: مَنْ صَلَّی إلَی غَیْرِ الْقِبْلَۃِ فَاسْتَفَاقَ وَہُوَ فِی وَقْتٍ، فَعَلَیْہِ الإِعَادَۃُ، وَإِنْ لَمْ یَکُنْ فِی وَقْتٍ فَلَیْسَ عَلَیْہِ إِعَادَۃٌ۔",,,3411
3412,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا رَبِیعٌ، عَنِ الْحَسَنِ، قَالَ: یُعِیدُ مَا دَامَ فِی وَقْتٍ۔",,,3412
3413,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ مَرْثَدٍ، عَنْ أَبِی ظَبْیَانَ ؛ أَنَّہُ کَرِہَ أَنْ یَقُولوا: قَدْ حَانَتِ الصَّلاَۃُ۔",,,3413
3414,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا مُغِیرَۃُ، عَنْ أَبِی مَعْشَرٍ، عَنْ إبْرَاہِیمَ، قَالَ: کَانُوا یَکْرَہُونَ أَنْ یَقُولُوا: قَدْ حَانَتِ الصَّلاَۃُ، فَقَالَ: إنَّ الصَّلاَۃَ لاَ تَحِینُ، وَلْیَقُولُوا: قَدْ حَضَرَتِ الصَّلاَۃُ۔",,,3414
3415,حَدَّثَنَا الْمُطَّلِبُ بْنُ زِیَادٍ، عَنْ عَبْدِ اللہِ بْنِ عِیسَی، عَنِ ابْنِ أَبِی لَیْلَی ؛ أَنَّہُ کَانَ یَنْتَظِرُ مَا سَمِعَ وَقْعَ نَعْلٍ۔,,,3415
3416,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ، عَنِ الشَّعْبِیِّ، قَالَ: إذَا کُنْتَ إمَامًا فَدَخَلَ إنْسَانٌ وَأَنْتَ رَاکِعٌ فَانْتَظِرْہُ۔",,,3416
3417,"حَدَّثَنَا وَکِیعٌ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ، عَنْ أَبِی مِجْلَزٍ، قَالَ: إذَا جَائَ أَحَدُکُمْ وَالإِمَامُ رَاکِعٌ، فَلْیُسْرِع الْمَشْیَ فَإِنَّا نَنْتَظِرُہُ۔",,,3417
3418,حَدَّثَنَا عِیسَی بْنُ یُونُسَ، عَنْ عِمْرَانَ، عَنْ أَبِی مِجْلَزٍ ؛ أَنَّہُ کَانَ یَنْتَظِرُ مَا سَمِعَ وَقْعَ النِّعَالِ۔,,,3418
3419,"حَدَّثَنَا عَفَّانُ، قَالَ: حدَّثَنَا ہَمَّامٌ، عَنْ مُحَمَّدِ بْنِ جُحَادَۃَ، عَنْ رَجُلٍ، عَنِ ابْنِ أَبِی أَوْفَی ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَنْتَظِرُ مَا سَمِعَ وَقْعَ نَعْلٍ۔",,,3419
3420,حَدَّثَنَا شَرِیکٌ، عَنْ جَابِرٍ، عَنْ عَامِرٍ ؛ أَنَّہُ کَانَ یَنْتَظِرُ مَا سَمِعَ وَقْعَ نَعْلٍ۔,,,3420
3421,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا حُمَیْدٌ، عَنْ أَنَسٍ، قَالَ: دَخَلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَاتَ یَوْمٍ، فَإِذَا حَبْلٌ مَمْدُودٌ، فَقَالَ: مَا ہَذَا ؟ قِیلَ: فُلاَنَۃٌ تُصَلِّی یَا رَسُولَ اللہِ، فَإِذَا أَعْیَتْ اسْتَرَاحَتْ عَلَی ہَذَا الْحَبْلِ، قَالَ: فَلْتُصَلِّ مَا نَشِطَتْ، فَإِذَا أَعْیَتْ فَلْتَنَمْ۔ (احمد 184۔ ابو یعلی 3786)",,,3421
3422,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ أَبِی حَازِمٍ، عَنْ مَوْلاَتِہِ، قَالَتْ: کُنْتُ فِی أَصْحَابِ الصُّفَّۃِ، کَانَ لَنَا حِبَالٌ نَتَعَلَّقُ بِہَا إذَا فَتَرْنَا وَنَعَسْنَا فِی الصَّلاَۃِ، وَبُسُطٌ نَقُومُ عَلَیْہِمَا مِنْ غِلَظِ الأَرْضِ، قَالَتْ: فَأَتَی أَبُو بَکْرٍ، فَقَالَ: اقْطَعُوا ہَذِہِ الْحِبَالَ وَأَفْضُوا إلَی الأَرْضِ۔",,,3422
3423,"حَدَّثَنَا وَکِیعٌ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ، عَنْ رَجُلٍ قَدْ سَمَّاہُ، یَحْسِبُہُ أَبُو بَکْرٍ: عَمْرَو بْنَ مُرَّۃَ، عَنْ حُذَیْفَۃَ، قَالَ: إنَّمَا یَفْعَلُ ذَلِکَ الْیَہُودُ، یَعْنِی بِالتَّعَلُّقِ مِنْ أَسْفَلَ ہَکَذَا۔",,,3423
3424,"حَدَّثَنَا وَکِیعٌ، عَنْ عِکْرِمَۃَ بن عمار، عَنْ عَاصِمِ بْنِ شُمَیْخٍ، قَالَ: رَأَیْتُ أَبَا سَعِیدٍ الْخُدْرِیَّ یُصَلِّی مُتَوَکِّئًا عَلَی عَصًا۔",,,3424
3425,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنِ ابْنِ أَبِی نَجِیحٍ، عَنْ أَبِیہِ، قَالَ: أَخْبَرَنِی مَنْ رَأَی أَبَا ذَرٍّ یُصَلِّی مُتَوَکِّئًا عَلَی عَصًا۔",,,3425
3426,"حَدَّثَنَا حَفْصٌ، وَیَزِیدُ، عَنْ حَجَّاجٍ، عَنْ عَطَائٍ، قَالَ: کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَتَوَکَّؤونَ عَلَی الْعصا فِی الصَّلاَۃِ ۔ زَادَ یَزِیدُ: إذَا اسْتَوَوْا۔",,,3426
3427,"حَدَّثَنَا جَرِیرٌ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ، قَالَ: کَانَ عَمْرُو بْنُ مَیْمُونٍ أُوتِدَ لَہُ وَتَدٌ فِی حَائِطِ الْمَسْجِدِ، وَکَانَ إذَا سَئِمَ مِنَ الْقِیَامِ فِی الصَّلاَۃِ، أَوْ شَقَّ عَلَیْہِ أَمْسَکَ بِالْوَتَدِ یَعْتَمِدُ عَلَیْہِ۔",,,3427
3428,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ، قَالَ: رَأَیْتُ مُرَّۃً، وَکَانَ یَؤُمُّ قَوْمَہُ، وَرَأَیْت لَہُ عُودًا فِی الطَّاقِ یَتَوَکَّأُ عَلَیْہِ إذَا نَہَضَ۔",,,3428
3429,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عِرَاکِ بْنِ مَالِکٍ، عَنْ أَبِیہِ، قَالَ: أَدْرَکْت النَّاسَ فِی شَہْرِ رَمَضَانَ تُرْبَطُ لَہُمَ الْحِبَالُ یَتَمَسَّکُونَ بِہَا مِنْ طُولِ الْقِیَامِ۔",,,3429
3430,"حَدَّثَنَا وَکِیعٌ، عَنْ أَبَانَ بن عَبْدِ اللہِ الْبَجَلِیِّ، قَالَ: رَأَیْتُ أَبَا بَکْرِ بْنَ أَبِی مُوسَی یُصَلِّی مُتَوَکِّئًا عَلَی عَصًا۔",,,3430
3431,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، وَأَبُو مُعَاوِیَۃَ، عَنْ لَیْثٍ، عَنْ عَبْدِ اللہِ بْنِ الْحَسَنِ، عَنْ أُمِّہِ، عَنْ فَاطِمَۃَ ابْنَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَتْ: کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا دَخَلَ الْمَسْجِدَ یَقُولُ: بِسْمِ اللہِ، وَالسَّلاَمُ عَلَی رَسُولِ اللہِ، صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، اللَّہُمَّ اغْفِرْ لِی ذُنُوبِی وَافْتَحْ لِی أَبْوَابَ رَحْمَتِکَ، وَإِذَا خَرَجَ، قَالَ: بِسْمِ اللہِ، وَالسَّلاَمُ عَلَی رَسُولِ اللہِ، صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، اللَّہُمَّ اغْفِرْ لِی ذُنُوبِی، وَافْتَحْ لِی أَبْوَابَ فَضْلِک۔ (ترمذی 314۔ احمد 6/283)",,,3431
3432,"حَدَّثَنَا وَکِیعٌ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ، عَنْ عَمْرِو بْنِ أَبِی عَمْرٍو الْمَدِینِیِّ، عَنِ الْمُطَّلِبِ بْنِ عَبْدِ اللہِ بْنِ حَنْطَبٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ إذَا دَخَلَ الْمَسْجِدَ، قَالَ: اللَّہُمَّ افْتَحْ لِی أَبْوَابَ رَحْمَتِکَ، وَیَسِّرْ لِی أَبْوَابَ رِزْقِک۔",,,3432
3433,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ، عَنِ النُّعْمَانِ بْنِ سَعْدٍ، عَنْ عَلِیٍّ، قَالَ: إذَا دَخَلَ الْمَسْجِدَ، قَالَ: اللَّہُمَّ اغْفِرْ لِی ذُنُوبِی وَافْتَحْ لِی أَبْوَابَ رَحْمَتِکَ، وَإِذَا خَرَجَ، قَالَ: اللَّہُمَّ اغْفِرْ لِی ذُنُوبِی، وَافْتَحْ لِی أَبْوَابَ فَضْلِک۔",,,3433
3434,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ، عَنِ ابْنِ عَجْلاَنَ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: قَالَ لِی کَعْبُ بْنُ عُجْرَۃَ: إذَا دَخَلْتَ الْمَسْجِدَ فَسَلِّمْ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقُلَ: اللَّہُمَّ افْتَحْ لِی أَبْوَابَ رَحْمَتِکَ، وَإِذَا خَرَجْتَ فَسَلِّمْ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقُلِ: اللَّہُمَّ احْفَظْنِی مِنَ الشَّیْطَانِ۔",,,3434
3435,"حَدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ، عَنْ مُحَمَّدِ بْنِ عَبْدِ الرَّحْمَنِ ؛ أَنَّ عَبْدَ اللہِ بْنَ سَلاَمٍ کَانَ إذَا دَخَلَ الْمَسْجِدَ سَلَّمَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، وَقَالَ: اللَّہُمَّ افْتَحْ لِی أَبْوَابَ رَحْمَتِکَ، وَإِذَا خَرَجَ سَلَّمَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَتَعَوَّذَ مِنَ الشَّیْطَانِ۔",,,3435
3436,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ أَبِی إِسْحَاقَ، عَنْ سَعِیدِ بْنِ ذِی حُدَّانَ، عَنْ عَلْقَمَۃَ ؛ أَنَّہُ کَانَ إذَا دَخَلَ الْمَسْجِدَ، قَالَ: السَّلاَمُ عَلَیْک أَیُّہَا النَّبِیُّ وَرَحْمَۃُ اللہِ وَبَرَکَاتُہُ، صَلَّی اللَّہُ وَمَلاَئِکَتُہُ عَلَی مُحَمَّدٍ۔",,,3436
3437,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ قَالَ: کَانَ إذَا دَخَلَ الْمَسْجِدَ، قَالَ: بِسْمِ اللہِ وَالسَّلاَم عَلَی رَسُولِ اللہِ، وَإِذَا دَخَلَ بَیْتًا لَیْسَ فِیہِ أَحَدٌ، قَالَ: السَّلاَمُ عَلَیْکُمْ۔",,,3437
3438,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ، عَنِ ابْنِ عَجْلاَنَ، عَنْ عَامِرِ بْنِ عَبْدِ اللہِ بْنِ الزُّبَیْرِ، عَنْ عَمْرِو بْنِ سُلَیْمٍ، عَنْ أَبِی قَتَادَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ: إذَا دَخَلْتَ الْمَسْجِدَ فَصَلِّ رَکْعَتَیْنِ قَبْلَ أَنْ تَجْلِسَ۔\n\n(بخاری 444۔ مسلم 495)",,,3438
3439,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ حُصَیْنٍ، عَنْ عَبْدِ الأَعْلَی بْنِ الْحَکَمِ، عَنْ خَارِجَۃَ بْنِ الصَّلْتِ الْبُرْجُمِیِّ، عَنْ عَبْدِ اللہِ، قَالَ: کَانَ یقال: مِنِ اقْتِرَابِ، أَوْ مِنْ أَشْرَاطِ، السَّاعَۃِ أَنْ تُتَّخَذَ الْمَسَاجِدُ طُرُقًا۔",,,3439
3440,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو، عَنْ أَبِی عَمْرِو بْنِ حَمَاسٍ، عَنْ مَالِکِ بْنِ أَوْسِ بْنِ الْحَدَثَانِ النَّضْرِیِّ، عَنْ أَبِی ذَرٍّ ؛ أَنَّہُ دَخَلَ الْمَسْجِدَ فَأَتَی سَارِیَۃً فَصَلَّی عِنْدَہَا رَکْعَتَیْنِ۔,,,3440
3441,"حَدَّثَنَا أَبُو خَالِدٍ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ، عَنْ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ حَزْمٍ، عَنْ عَمْرِو بْنِ سُلَیْمٍ، عَنْ أَبِی قَتَادَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ: أَعْطُوا الْمَسَاجِدَ حَقَّہَا قِیلَ: وَمَا حَقُّہَا ؟ قَالَ: رَکْعَتَانِ قَبْلَ أَنْ تَجْلِسَ۔",,,3441
3442,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، عَنِ الْمَسْعُودِیِّ، عَنْ أَبِی عُمَر، عَنْ عُبَیْدِ بْنِ الْخَشْخَاشِ، عَنْ أَبِی ذَرٍّ، قَالَ: دَخَلْتُ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ فِی الْمَسْجِدِ، فَقَالَ لِی: یَا أَبَا ذَرٍّ، صَلَّیْتَ ؟ قُلْتُ: لاَ، قَالَ: فَقُمْ فَصَلِّ رَکْعَتَیْنِ۔ (احمد 179۔ طیالسی 478)",,,3442
3443,حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ، عَنِ الْمَقْبُرِیِّ، عَنْ عُمَرَ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ، عَنْ أَبِیہِ، عَنْ عَمَّارِ بْنِ یَاسِرٍ ؛ أَنَّہُ دَخَلَ الْمَسْجِدَ فَصَلَّی رَکْعَتَیْنِ خَفِیفَتَیْنِ۔,,,3443
3444,"حَدَّثَنَا عَبَّادٌ، عن عَبْدِ الْمَلِکِ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَدْخُلُ الْمَسْجِدَ یُصَلِّی فِیہِ کُلَّمَا مَرَّ ؟ قَالَ: یُصَلِّی رَکْعَتَیْنِ، ثُم یَمُرُّ فِیہِ سَائِرَ یَوْمِہِ۔",,,3444
3445,"حَدَّثَنَا حَرَمِیُّ بْنُ عُمَارَۃَ، عَنْ أَبِی خَلْدَۃَ، قَالَ: رَأَیْتُ عِکْرِمَۃَ دَخَلَ الْمَسْجِدَ فَصَلَّی فِیہِ رَکْعَتَیْنِ، وَقَالَ: ہَذَا حَقُّ الْمَسْجِدِ۔",,,3445
3446,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، قَالَ: حدَّثَنَا مِسْعَرٌ، عَنْ مُحَارِبِ بْنِ دِثَارٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ، قَالَ: أَتَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ فِی الْمَسْجِدِ، فَقَالَ: صَلِّ رَکْعَتَیْنِ۔ (بخاری 443۔ مسلم 495)",,,3446
3447,"حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِیُّ، عَنْ زَیْدِ بْنِ أَسْلَمَ، قَالَ: کَانَ أَصْحَابُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَدْخُلُونَ الْمَسْجِدَ، ثُمَّ یَخْرُجُونَ وَلاَ یُصَلُّونَ، قَالَ: وَرَأَیْت ابْنَ عُمَرَ یَفْعَلُہُ۔",,,3447
3448,حَدَّثَنَا وَکِیعٌ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدِ بْنِ أَبِی ہِنْدٍ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ کَانَ یَمُرُّ فِی الْمَسْجِدِ، وَلاَ یُصَلِّی فِیہِ۔,,,3448
3449,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ، عَنِ ابْنِ عَوْنٍ، قَالَ: مَرَرْتُ مَعَ الشَّعْبِیِّ فِی مَسْجِدِ الْکُوفَۃِ، فَقُلْتُ لَہُ: أَلاَ تُصَلِّی ؟ قَالَ: إذنْ وَرَبِّی لاَ نَزَالُ نُصَلِّی۔",,,3449
3450,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ، عَنْ حَنَشٍ، قَالَ: رَأَیْتُ سُوَیْد بْنَ غَفَلَۃَ یَمُرُّ فِی مَسْجِدِنَا، فَرُبَّمَا صَلَّی، وَرُبَّمَا لَمْ یُصَلِّ۔",,,3450
3451,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ، قَالَ: رَأَیْتُ سَالِمًا یَدْخُلُ مِنَ الْمَسْجِدِ حَتَّی یَخْرُجَ مِنَ الْخَوْخَۃِ، فَلاَ یُصَلِّی فِیہِ۔",,,3451
3452,حَدَّثَنَا ہُشَیْمٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ لَیْثٍ، عَنْ مُجَاہِدٍ (ح) وَأَبُو إِسْحَاقَ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُمْ کَرِہُوا الضَّجَّۃَ فِی الصَّلاَۃِ إذَا ذَکَرَ الإِمَامُ آیَۃَ رَحْمَۃٍ، أَوْ آیَۃَ عَذَابٍ، أَوْ ذَکَرَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔,,,3452
3453,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو، قَالَ: خَیْرُ الْمَسْجِدِ الْمَقَامُ، ثُمَّ مَیَامِنُ الْمَسْجِدِ۔",,,3453
3454,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ حَمَّادٍ، عَنْ إبْرَاہِیمَ، قَالَ: یُسْتَحَبُّ یَمِینُ الإِمَامِ۔",,,3454
3455,حَدَّثَنَا عَبْدَۃُ، عَنْ سَعِیدٍ، عَنْ أَبِی مَعْشَرٍ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُعْجِبُہُ أَنْ یَقُومَ عَنْ یَمِینِ الإِمَامِ۔,,,3455
3456,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنْ سَلَمَۃَ بْنِ أَبِی یَحْیَی، قَالَ: رَأَیْتُ سَعِیدَ بْنَ الْمُسَیَّبِ یُصَلِّی فِی الشِّقِّ الأَیْمَنِ مِنَ الْمَسْجِدِ۔",,,3456
3457,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی، عَنْ سَلَمَۃَ بْنِ أَبِی یَحْیَی، قَالَ: رَأَیْتُ أنس بن مالک یُصَلِّی فِی الشِّقِّ الأَیْسَر مِنَ الْمَسْجِدِ۔",,,3457
3458,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ، عَنْ سُفْیَانَ، عَنْ عِمْرَانَ الْمُنْقِرِیِّ، عَنِ الْحَسَنِ، وَابْنِ سِیرِینَ ؛ أَنَّہُمَا کَانَا یُصَلِّیَانِ عَنْ یَسَارِ الإِمَامِ۔,,,3458
3459,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ، عَنِ ابْنِ الْبَرَائِ، عَنْ أَبِیہِ، قَالَ: کُنَّا نُحِبُّ أَو نَسْتَحِبُّ أَنْ نَقُومَ عَنْ یَمِینِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (احمد 304۔ مسلم 62)",,,3459
3460,"حَدَّثَنَا الْمُحَارِبِیُّ، عَنْ حَجَّاجِ بْنِ دِینَارٍ، عَنْ أَبِی جَعْفَرٍ، قَالَ: مَیَامِنُ الصُّفُوفِ تَزِیدُ عَلَی سَائِرِ المسجد، خَمْسًا وَعِشْرِینَ دَرَجَۃً۔",,,3460
3461,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ، عَنِ الزُّہْرِیِّ، عَنْ سَالِمٍ، عَنْ أَبِیہِ، رَفَعَہُ، قَالَ: إنَّ الَّذِی تَفُوتُہُ الْعَصْرُ، کَأَنَّمَا وُتِرَ أَہْلَہُ وَمَالَہُ۔ (مسلم 436۔ احمد 2/134)",,,3461
3462,"حَدَّثَنَا ہُشَیْمٌ، عَنْ حَجَّاجٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ تَرَکَ الْعَصْرَ حَتَّی تَغِیبَ الشَّمْسُ مِنْ غَیْرِ عُذْرٍ، فَکَأَنَّمَا وُتِرَ أَہْلَہُ وَمَالَہُ۔ (بخاری 552۔ مسلم 5/439)",,,3462
3463,"حَدَّثَنَا شَبَابَۃُ، قَالَ: حدَّثَنَا لَیْثُ بْنُ سَعْدٍ، عَنْ یَزِیدَ بْنِ أبی حَبِیبٍ، عَنْ عِرَاکٍ، عَنْ نَوْفَلِ بْنِ مُعَاوِیَۃَ بْنِ عُرْوَۃَ، قَالَ: سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ: إِنَّ من الصلوات صلاۃ من فاتتہ، فَکَأَنَّمَا وُتِرَ أَہْلَہُ وَمَالَہُ ۔ قَالَ ابن عمر: سَمِعْتُ النبی صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یقول: ہِیَ صَلاَۃُ الْعَصْرِ۔\n\n(بخاری 3602۔ احمد 422)",,,3463
3464,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا عَبَّادُ بْنُ مَیْسَرَۃَ الْمُنْقِرِیُّ، عَنْ أَبِی قِلاَبَۃَ، وَالْحَسَنِ ؛أَنَّہُمَا کَانَا جَالِسَیْنِ، فَقَالَ أَبُو قِلاَبَۃَ: قَالَ أَبُو الدَّرْدَائِ: مَنْ تَرَکَ الْعَصْرَ حَتَّی تَفُوتَہُ مِنْ غَیْرِ عُذْرٍ، فَقَدْ حَبِطَ عَمَلُہُ، قَالَ: وَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ تَرَکَ صَلاَۃً مَکْتُوبَۃً حَتَّی تَفُوتَہُ مِنْ غَیْرِ عُذْرٍ، فَقَدْ حَبِطَ عَمَلُہُ۔\n\n(احمد 6/442)",,,3464
3465,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ، عَنْ یَحْیَی بْنِ سَعِیدٍ، عَنْ أَبِی جَعْفَرٍ، قَالَ: مَنْ فَاتَتْہُ الْعَصْرُ، فَکَأَنَّمَا وُتِرَ أَہْلَہُ۔",,,3465
3466,"حَدَّثَنَا أَبُو أُسَامَۃَ، قَالَ: حدَّثَنَا الأَعْمَشُ، عَنْ مَالِکِ بْنِ الْحَارِثِ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: کَانَ سُلَیْمَانُ بْنُ دَاوُد النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یُکَلَّمُ إعْظَامًا لَہُ، فَلَقَدْ فَاتَتْہُ الْعَصْرُ، وَمَا اسْتَطَاعَ أَحَدٌ أَنْ یُکَلِّمَہُ۔",,,3466
3467,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ قَالَ: حَدَّثَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ، عَنْ أَوْسِ بْنِ ضَمْعَجٍ، قَالَ: أُخْبِرْتُ أَنَّہُ مَنْ أَخْطَأَتْہُ الْعَصْرُ، فَکَأَنَّمَا وُتِرَ أَہْلَہُ وَمَالَہُ۔",,,3467
3468,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ، وَوَکِیعٌ، عَنِ الأَوْزَاعِیِّ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ، عَنْ أَبِی قِلاَبَۃَ، عَنْ أَبِی الْمُہَاجِرِ، عَنْ بُرَیْدَۃَ الأَسْلَمِیِّ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ فَاتَتْہُ صَلاَۃُ الْعَصْرِ حَبِطَ عَمَلُہُ۔ (ابن ماجہ 694۔ احمد 5/361)",,,3468
3469,حَدَّثَنَا یَزِیدُ، عن ہِشَامٍ، عَنْ یَحْیَی، عَنْ أَبِی قِلاَبَۃَ، عَنْ أَبِی الْمَلِیحِ، عَنْ بُرَیْدَۃَ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِثْلَ حَدِیثِ عِیسَی وَوَکِیعٍ۔ (بخاری 594۔ احمد 5/357),,,3469
3470,"حَدَّثَنَا أَبُو خَالِدٍ، عَنِ الأَعْمَشِ، عَنْ إسْمَاعِیلَ بْنِ رَجَائٍ، عَنْ أَوْسِ بْنِ ضَمْعَجٍ، عَنْ أَبِی مَسْعُودٍ الأَنْصَارِیِّ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: یَؤُمُّ الْقَوْمَ أَقْرَؤُہُمْ لِکِتَابِ اللہِ، فَإِنْ کَانُوا فِی الْقِرَائَۃِ سَوَائً فَأَعْلمُہمْ بِالسُّنَّۃِ، فَإِنْ کَانُوا فِی السُّنَّۃِ سَوَائً، فَأَقْدَمُہُمْ ہِجْرَۃً، فَإِنْ کَانُوا فِی الْہِجْرَۃِ سَوَائً، فَأَقْدَمُہُمْ سِلْمًا، وَلاَ یَؤُمَّنَّ الرَّجُلُ الرَّجُلَ فِی سُلْطَانِہِ، وَلاَ یَقْعُدْ فِی بَیْتِہِ عَلَی تَکْرِمَتِہِ إِلاَّ بِإِذْنِہِ۔\n\n(مسلم 690۔ ابوداؤد 3/583)",,,3470
3471,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ، عَنِ ابْنِ أَبِی عَرُوبَۃَ، عَنْ قَتَادَۃَ، عَنْ أَبِی نَضْرَۃَ، عَنْ أَبِی سَعِیدٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: إذَا کَانُوا ثَلاَثَۃً فَلْیَؤُمَّہُمْ أَحَدُہُمْ، وَأَحَقُّہُمْ بِالإِمَامَۃِ أَقْرَؤُہُمْ۔\n\n(مسلم 464۔ احمد 36)",,,3471
3472,"حَدَّثَنَا أَبُو خَالِدٍ، عَنْ مُجَالِدٍ، عَنِ الشَّعْبِیِّ، وَزَیْدِ بْنِ إیَاسٍ قَالاَ: حدَّثَنَا مُرَّۃُ بْنُ شَرَاحِیلَ، قَالَ: کُنْتُ فِی بَیْتٍ فِیہِ عَبْدُ اللہِ بْنُ مَسْعُودٍ، وَحُذَیْفَۃُ، وَأَبُو مُوسَی الأَشْعَرِیُّ، فَحَضَرَتِ الصَّلاَۃُ، فَقَالَ ہَذَا لِہَذَا: تَقَدَّمْ، وَقَالَ ہَذَا لِہَذَا: تَقَدَّمْ، وعبد اللہ بین أبی مُوسَی وَحُذَیْفَۃ، فَأَخَذَا بِنَاحِیَتَیْہِ فَقَدَّمَاہُ، قُلْتُ: مِمَّ ذَلِکَ ؟ قَالَ: إِنَّہُ شَہِدَ بَدْرًا۔",,,3472
3473,"حَدَّثَنَا حَفْصٌ، عَنِ ابْنِ جُرَیْجٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ: کَانَ سَالِمٌ یَؤُمُّ الْمُہَاجِرِینَ وَالأَنْصَارَ فِی مَسْجِدِ قُبَائَ۔",,,3473
3474,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، قَالَ: حَدَّثَنَا عَاصِمٌ، عَنْ عَمْرِو بْنِ سَلِمَۃَ، قَالَ: لَما رَجَعَ قَوْمِی مِنْ عِنْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَالُوا لَہُ: إِنَّہُ قَالَ لَنَا: لِیَؤُمَّکُمْ أَکْثَرُکُمْ قِرَائَۃً لِلْقُرْآنِ، قَالَ: فَدَعَوْنِی فَعَلَّمُونِی الرکوع وَالسُّجُودَ، فَکُنْت أُصَلِّی بِہِمْ وَعَلَیَّ بُرْدَۃٌ مَفْتُوقَۃٌ، قَالَ: فَکَانُوا یَقُولُونَ لأَبِی: أَلاَ تُغَطِّی عَنَّا اسْتِ ابْنِک۔ (ابوداؤد 587۔ احمد 5/71)",,,3474
3475,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، عَنْ عَمْرِو بْنِ سَلِمَۃَ، قَالَ: کُنَّا عَلَی حَاضِرٍ، فَکَانَ الرُّکْبَانُ یَمُرُّونَ بِنَا رَاجِعِینَ مِنْ عِنْدِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فَأَدْنُو مِنْہُمْ فَأَسْتَمِعُ حَتَّی حَفِظْتُ قُرْآنًا کَثِیرًا، وَکَانَ النَّاسُ یَنْتَظِرُونَ بِإِسْلاَمِہِمْ فَتْحَ مَکَّۃَ، فَلَمَّا فُتِحَتْ جَعَلَ الرَّجُلُ یَأْتِیہِ فَیَقُولُ: یَا رَسُولَ اللہِ، أَنَا وَافِدُ بَنِی فُلاَنٍ، وَجِئْتُک بِإِسْلاَمِہِمْ، فَانْطَلَقَ أَبِی بِإِسْلاَمِ قَوْمِہِ، فَلَمَّا رَجَعَ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: قَدِّمُوا أَکْثَرَکُمْ قُرْآنًا، فَنَظَرُوا وَأَنَا عَلَی حِوَائٍ عَظِیمٍ، فَمَا وَجَدُوا فِیہِمْ أَحَدًا أَکْثَرَ قُرْآنًا مِنِّی، فَقَدَّمُونِی وَأَنَا غُلاَمٌ، فَصَلَّیْتُ بِہِمْ۔ (بخاری 4302۔ ابوداؤ9 586)",,,3475
3476,"حَدَّثَنَا وَکِیعٌ، عَنْ ثَوْرٍ الشَّامِیِّ، عَنْ مُہَاصِرِ بْنِ حَبِیبٍ، عَنْ أَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: إذَا خَرَجَ ثَلاَثَۃٌ مُسْلِمِینَ فِی سَفَرٍ فَلْیَؤُمَّہُمْ أَقْرَؤُہُمْ لِکِتَابِ اللہِ، وَإِنْ کَانَ أَصْغَرَہُمْ ، فَإِذَا أَمَّہُمْ فَہُوَ أَمِیرُہُمْ ، وَذَلِکَ أَمِیرٌ أَمَّرَہُ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔\n\n(عبدالرزاق 9256)",,,3476
3477,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرِ بْنِ حَبِیبٍ الْجَرْمِیِّ، عَنْ عَمْرِو بْنِ سَلِمَۃَ، عَنْ أَبِیہِ ؛ أَنَّہُمْ وَفَدُوا إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فَلَمَّا أَرَادُوا أَنْ یَنْصَرِفُوا قَالُوا: قلْنَا لَہُ: یَا رَسُولَ اللہِ، مَنْ یُصَلِّی بِنَا ؟ قَالَ: أَکْثَرُکُمْ جَمْعًا لِلْقُرْآنِ، أَوْ أَخْذًا لِلْقُرْآنِ، فَلَمْ یَکُنْ فِیہِمْ أَحَدٌ جَمَعَ مِنَ الْقُرْآنِ مَا جَمَعْتُ، قَالَ: فَقَدَّمُونِی وَأَنَا غُلاَمٌ، فَکُنْت أُصَلِّی بِہِمْ وَعَلَیَّ شَمْلَۃٌ، قَالَ: فَمَا شَہِدْتُ مَجْمَعًا مِنْ جَرْمٍ إِلاَّ کُنْتُ إمَامَہُمْ، وَأُصَلِّی علی جَنَائِزِہِمْ إلَی یَوْمِی ہَذَا۔ (ابوداؤد 588۔ احمد 5/29)",,,3477
3478,"حَدَّثَنَا وَکِیعٌ، عَنِ الرَّبِیعِ، عَنِ ابْنِ سِیرِینَ، قَالَ: یَؤُمُّ الْقَوْمَ، أَقْرَؤُہُمْ۔",,,3478
3479,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَائٍ، قَالَ: یَؤُمُّ الْقَوْمَ، أَفْقَہُہُمْ۔",,,3479
3480,حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنْ عُبَیْدِ اللہِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ الْمُہَاجِرِینَ حِینَ أَقْبَلُوا مِنْ مَکَّۃَ نَزَلُوا إلَی جَنْبِ قُبَائَ، فَأَمَّہُمْ سَالِمٌ مَوْلَی أَبِی حُذَیْفَۃَ، لأَنَّہُ کَانَ أَکْثَرَہُمْ قُرْآنًا، وَفِیہِمْ أَبُو سَلَمَۃَ بْنُ عَبْدِ الأَسَدِ، وَعُمَرُ بْنُ الْخَطَّابِ۔,,,3480
3481,"حَدَّثَنَا وَکِیعٌ، قَالَ: حَدَّثَنَا ہُشَیْمٌ، عَنْ أَبِیہِ، قَالَ: فَقَدَ عُمَرُ رَجُلاً فِی صَلاَۃِ الصُّبْحِ فَأَرْسَلَ إلَیْہِ، فَجَائَ فَقَالَ: أَیْنَ کُنْت ؟ فَقَالَ: کُنْتُ مَرِیضًا وَلَوْلا أَنَّ رَسُولَک أَتَانِی مَا خَرَجْت، فَقَالَ عُمَرُ: فَإِنْ کُنْتَ خَارِجًا إلَی أَحَدٍ فَاخْرُجْ إِلی الصَّلاَۃِ۔",,,3481
3482,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنْ أَبِی حَصِینٍ، عَنْ أَبِی بُرْدَۃَ، عَنْ أَبِی مُوسَی، قَالَ: مَنْ سَمِعَ الْمُنَادِی، ثُمَّ لَمْ یُجِبْہُ مِنْ غَیْرِ عُذْرٍ، فَلاَ صَلاَۃَ لَہُ۔",,,3482
3483,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنْ عَدِیِّ بْنِ ثَابِتٍ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: مَنْ سَمِعَ الْمُنَادِی، ثُمَّ لَمْ یُجِبْ مِنْ غَیْرِ عُذْرٍ، فَلاَ صَلاَۃَ لَہُ۔ (ابوداؤد 552)",,,3483
3484,"حَدَّثَنَا وَکِیعٌ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ حُصَیْنٍ، عَنْ أَبِی نَجِیحٍ الْمَکِّیِّ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: لأَنْ یَمْتَلِئَ أُذُنُ ابْنِ آدَمَ رَصَاصًا مُذَابًا، خَیْرٌ لَہُ مِنْ أَنْ یَسْمَعَ الْمُنَادِیَ، ثُمَّ لاَ یُجِیبُہُ۔",,,3484
3485,"حَدَّثَنَا وَکِیعٌ، عن سفیان، عَنْ مَنْصُورٍ، عَنْ عَدِیِّ بْنِ ثَابِتٍ، عَنْ عَائِشَۃَ، قَالَتْ: مَنْ سَمِعَ الْمُنَادِی فَلَمْ یُجِبْہ، لَمْ یُرِدْ خَیْرًا، وَلَمْ یُرَدْ بِہِ۔",,,3485
3486,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُلَیْمَانُ بْنُ الْمُغِیرَۃِ، عن أَبی مُوسَی الْہِلاَلِیِّ، عَنْ أَبِیہِ، عَنِ ابْنِ مَسْعُودٍ، قَالَ: مَنْ سَمِعَ الْمُنَادِی، ثُمَّ لَمْ یُجِبْ مِنْ غَیْرِ عُذْرٍ، فَلاَ صَلاَۃَ لَہُ۔",,,3486
3487,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا ابْنُ عَوْنٍ، عَنِ ابْنِ سِیرِینَ، قَالَ: خَرَجَ عُثْمَانُ وَقَدْ غَسَلَ أَحد شِقَّیْ رَأْسِہِ، فَقَالَ: إنَّ الْمُنَادِیَ جَائَ فَأَعْجَلَنِی ، فَکَرِہْتُ أَنْ أَحْبِسَہُ۔",,,3487
3488,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا أَبُو حَیَّانَ، عَنْ أَبِیہِ، عَنْ عَلِیٍّ، قَالَ: لاَ صَلاَۃَ لِجَارِ الْمَسْجِدِ إِلاَّ فِی الْمَسْجِدِ، قَالَ: قِیلَ لہ: وَمَنْ جَارُ الْمَسْجِدِ ؟ قَالَ: مَنْ أَسْمَعَہُ الْمُنَادِی۔",,,3488
3489,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا مَنْصُورٌ، عَنِ الْحَسَنِ، عَنْ عَلِیٍّ، أَنَّہُ قَالَ: مَنْ سَمِعَ النِّدَائَ فَلَمْ یَأْتِہِ، لَمْ تُجَاوِز صَلاَتُہُ رَأْسَہُ، إِلاَّ بِالْعُذْرِ۔",,,3489
3490,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: حدَّثَنَا یَحْیَی بْنُ سَعِیدٍ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، أَنَّہُ قَالَ: إِنْ کُنْتَ مُجِیبَ دَعْوَۃٍ، فَأَجِبْ دَاعِیَ اللہِ۔",,,3490
3491,"حَدَّثَنَا ہُشَیْمٌ، عَنْ حُصَیْنٍ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ، قَالَ: اسْتَقَلَّ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ النَّاسَ ذَاتَ لَیْلَۃٍ فِی الْعِشَائِ، یَعْنِی الْعَتَمَۃَ، قَالَ: فَلَقَدْ ہَمَمْتُ أَنْ آمُرَ بِالصَّلاَۃِ فَیُنَادَی بِہَا، ثُمَّ آتِیَ قَوْمًا فِی بُیُوتِہِمْ فَأُحَرِّقَہَا عَلَیْہِمْ، لاَ یَشْہَدُونَ الصَّلاَۃَ۔",,,3491
3492,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ سُفْیَانَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَابِسٍ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی، قَالَ: جَائَ ابْنُ أُمِّ مَکْتُومٍ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فَقَالَ: یَا رَسُولَ اللہِ، إنَّ الْمَدِینَۃَ أَرْضُ ہَوَامٍّ وَسِبَاخٍ، فَہَلْ لِی رُخْصَۃٌ أَنْ أُصَلِّیَ الْعِشَائَ وَالْفَجْرَ فِی بَیْتِی ؟ فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: أَتَسْمَعُ، حَیَّ عَلَی الصَّلاَۃِ، حَیَّ عَلَی الْفَلاَحِ ؟ قَالَ: فَقَالَ: نَعَمْ، قَالَ: فَحَیَّہَلاَ۔ (حاکم 247)",,,3492
3493,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ، عَنْ أَبِی سِنَانٍ، عَنْ عَمْرِو بْنِ مُرَّۃَ، قَالَ: حَدَّثَنِی أَبُو رَزِینٍ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: جَائَ ابْنُ أُمِّ مَکْتُومٍ إلَی رَسُولِ اللہ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، فَقَالَ: إنِّی رَجُلٌ ضَرِیرٌ شَاسِعُ الدَّارِ، وَلَیْسَ لِی قَائِدٌ یُلاَزِمُنِی، فَلِی رُخْصَۃٌ أَنْ لاَ آتِیَ الْمَسْجِدَ ؟ أَوْ کَمَا قَالَ، قَالَ: لاَ۔ (ابوداؤد 553۔ احمد 3/423)",,,3493
3494,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ لَیْثٍ، عَنْ مُجَاہِدٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: اخْتَلَفَ إلَیْہِ رَجُلٌ شَہْرًا یَسْأَلُہُ عَنْ رَجُلٍ یَصُومُ النَّہَارَ وَیَقُومُ اللَّیْلَ، وَلاَ یَشْہَدُ جُمُعَۃً، وَلاَ جَمَاعَۃً، مَات ؟قَالَ: فِی النَّارِ۔",,,3494
3495,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ، عَنْ أَشْعَثَ، عَنْ جَہْمِ بْنِ أَبِی سَبْرَۃَ ؛ أَنَّ الزُّبَیْرَ بْنَ الْعَوَّامِ کَانَ یَقْعُدُ خَلْفَہُ رَجُلٌ یَحْفَظ عَلیہ صَلاَتَہُ۔,,,3495
3496,"حَدَّثَنَا عَفَّانُ، قَالَ: حدَّثَنَا أَبُو ہِلاَلٍ، قَالَ: حَدَّثَنَا مُحَمَّدُ بْنُ سِیرِینَ، قَالَ: کَانَ عُمَرُ بْنُ الْخَطَّابِ یَخَافُ النِّسْیَانَ، قَالَ: فَکَانَ إذَا صَلَّی وَکَّلَ رَجُلاً فَیَلْحَظُ إلَیْہِ، فَإِنْ رَآہُ قَامَ قَامَ، وَإِنْ رَآہُ قَعَدَ قَعَدَ۔",,,3496
3497,"حَدَّثَنَا وَکِیعٌ، عَنْ شَرِیکٍ، عَنِ الرُّکَیْنِ، قَالَ: دَخَلْتُ عَلَی أَسْمَائَ وَہِیَ تُصَلِّی وَہِیَ عَجُوزٌ، وَامْرَأَۃٌ تَقُولُ لَہَا: ارْکَعِی وَاسْجُدِی۔",,,3497
3498,"حَدَّثَنَا عَبْدُ الْعَزِیزِ بْنُ مُحَمَّدٍ الدَّرَاوَرْدِیُّ، عَنْ مُوسَی بْنِ إِبْرَاہِیمَ، عَن سَلَمَۃَ بْنِ الأَکْوَعِ، أَنَّہُ قَالَ: قُلْتُ: یَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، إنِّی أَتَصَیَّدُ فَأُصَلِّی فِی الْقَمِیصِ الْوَاحِدِ ؟ قَالَ: نَعَمْ، وَزُرَّہُ وَلَوْ بِشَوْکَۃٍ۔ (ابوداؤد 632۔ ابن خزیمۃ 778)",,,3498
3499,"حَدَّثَنَا وَکِیعٌ، عَنْ کَثِیرِ بْنِ زَیْدٍ، قَالَ: رَأَیْتُ سَالِمًا وَہُوَ یُصَلِّی مُحَلَّلَۃٌ أَزْرَارُہُ۔",,,3499
3500,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَاب قَالَ: حدَّثَنِی عَبْدُ الْمَلِکِ بْنُ الرَّبِیعِ بْنِ سَبْرَۃَ بْنِ مَعْبَدٍ الْجُہَنِیُّ، قَالَ: حَدَّثَنِی أَبِی، عَنْ جَدِّی، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: إذَا بَلَغَ الْغُلاَمُ سَبْعَ سِنِینَ فَأمُرُوہُ بِالصَّلاَۃِ، فَإِذَا بَلَغَ عَشْرًا فَاضْرِبُوہُ عَلَیْہَا۔ (ترمذی 407۔ ابوداؤد 495)",,,3500
3501,"حَدَّثَنَا وَکِیعٌ، عَنْ دَاوُدَ بْنِ سَوَّارٍ، عَنْ عَمْرِو بْنِ شُعَیْبٍ، عَنْ أَبِیہِ، عَنْ جَدِّہِ، قَالَ: قَالَ نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مُرُوا صِبْیَانَکُمْ بِالصَّلاَۃِ إذَا بَلَغُوا سَبْعًا، وَاضْرِبُوہُمْ عَلَیْہَا إذَا بَلَغُوا عَشْرًا، وَفَرِّقُوا بَیْنَہُمْ فِی الْمَضَاجِعِ۔ (ابوداؤد 497۔ احمد 2/180)",,,3501
3502,"حَدَّثَنَا ابْنُ مُبَارَکٍ، عَنْ حُسَیْنِ بْنِ عَبْدِ اللہِ، قَالَ: حدَّثَتْنِی أُمُّ یُونُسَ خَادِمُ ابْنِ عَبَّاسٍ، قَالَتْ: کَانَ ابْنُ عَبَّاسٍ یَقُولُ: أَیْقِظُوا الصَّبِیَّ یُصَلِّی وَلَوْ سَجْدَۃً۔",,,3502
3503,"حَدَّثَنَا حَفْصٌ، عَنْ مُحَمَّدِ بْنِ أَبِی یَحْیَی، عَنِ امْرَأَۃٍ مِنْہُمْ، عَنْ جَدَّۃٍ لَہَا ؛ أَنَّ عُمَرَ مَرَّ بِامْرَأَۃٍ وَہِیَ تُوقِظُ صَبِیًّا لَہَا یُصَلِّی وَہُوَ یَتَلَکَّأُ، فَقَالَ: دَعِیہِ فَلَیْسَتْ عَلَیْہِ حَتَّی یَعْقِلَہَا۔",,,3503
3504,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ حَجَّاج، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ: یُعَلَّمُ الصَّبِیَّ الصَّلاَۃَ إذَا عَرَفَ یَمِینَہُ مِنْ شِمَالِہِ۔",,,3504
3505,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، وَحَفْصٌ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ، قَالَ: کَانَ یُعَلَّمُ الصَّبِیُّ الصَّلاَۃَ إذَا اثَّغَرَ۔",,,3505
3506,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: کَانُوا یُعَلِّمُونَ الصِّبْیَانَ الصَّلاَۃَ إذَا اثَّغَرُوا۔",,,3506
3507,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ ہِشَامٍ، عَنْ أَبِیہِ، قَالَ: کَانَ یُعَلِّمُ بَنِیہِ الصَّلاَۃَ إذَا عَقَلُوا، وَالصَّوْمَ إذَا أَطَاقُوا۔",,,3507
3508,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ، عَنْ عَبْدِ الرَّحْمَنِ الْیَحْصُبِیِّ، قَالَ: یُؤْمَرُ الصَّبِیُّ بِالصَّلاَۃِ إذَا عَدَّ عِشْرِینَ۔",,,3508
3509,حَدَّثَنَا ابْنُ مَہْدِیٍّ، عَنْ سُفْیَانَ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ، عَنِ امْرَأَۃِ عَبْدِ الرَّحْمَنِ الْیَحْصُبِیِّ، عَنْ عَبْدِ الرَّحْمَنِ الْیَحْصُبِیِّ، بِمِثْلِہِ۔,,,3509
3510,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ أَبِی رَجَائٍ، عَنْ مَکْحُولٍ، قَالَ: یُؤْمَرُ الصَّبِیُّ بِہَا إذَا بَلَغَ السَّبْعَ، وَیُضْرَبُ عَلَیْہَا إذَا بَلَغَ عَشْرًا",,,3510
3511,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ أَبِی فَزَارَۃَ، عَنْ مَیْمُونِ بْنِ مِہْرَانَ، قَالَ: یُؤْمَرُ بِہَا إذَا بَلَغَ حُلْمَہُ۔",,,3511
3512,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ حَجَّاجٍ، عَنْ أَبِی إِسْحَاقَ، قَالَ: کَانَ یُعَلَّمُ الصَّبِیُّ الصَّلاۃ مَا بَیْنَ سَبْعِ سِنِینَ إلَی عَشَرِ سِنِینَ۔",,,3512
3513,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ، عَنْ جَعْفَرٍ، عَنْ أَبِیہِ، قَالَ: کَانَ عَلِیُّ بْنُ الْحُسَیْنِ یَأْمُرُ الصِّبْیَانَ أَنْ یُصَلُّوا الظُّہْرَ وَالْعَصْرَ جَمِیعًا وَالْمَغْرِبَ وَالْعِشَائَ جَمِیعًا فَیُقَالُ یُصَلُّونَ الصَّلاَۃَ لِغَیْرِ وَقْتِہَا فَیَقُولُ ہَذَا خَیْرٌ مِنْ أَنْ یَنَامُوا عَنْہَا۔",,,3513
3514,"حَدَّثَنَا حَفْصٌ، عَنْ أَشْعَثَ، عَنِ ابْنِ سِیرِینَ، قَالَ: یُعَلَّمُ الصَّبِیُّ الصَّلاَۃَ إذَا عَرَفَ یَمِینَہُ مِنْ شِمَالِہِ۔",,,3514
3515,حَدَّثَنَا حَفْصٌ، عَنْ عُبَیْدِ اللہِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ مِثْلَہُ۔,,,3515
3516,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا الأَعْمَشُ، عَنْ عُمَارَۃَ، عَنْ أَبِی الأَحْوَصِ، قَالَ: قَالَ عَبْدُ اللہِ حَافِظُوا عَلَی أَبْنَائِکُمْ عَلَی الصَّلاَۃِ۔",,,3516
3517,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ، عَنْ عَبْدِ الْکَرِیمِ، عَنْ عَمْرِو بْنِ شُعَیْبٍ، قَالَ: کَانَ الْغُلاَمُ إذَا أَفْصَحَ مِنْ بَنِی عَبْدِ الْمُطَّلِبِ عَلَّمَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ہَذِہِ الآیَۃَ سَبْعَ مَرَّاتٍ: {الْحَمْدُ لِلَّہِ الَّذِی لَمْ یَتَّخِذْ وَلَدًا وَلَمْ یَکُنْ لَہُ شَرِیکٌ فِی الْمُلْکِ}۔ (عبدالرزاق 7976)",,,3517
3518,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ، عَنْ جَعْفَرٍ، عَنْ أَبِیہِ، قَالَ: کَانَ عَلِیُّ بْنُ الْحُسَیْنِ یُعَلِّمُ وَلَدَہُ یَقُولُ قُلْ آمَنْت بِاللَّہِ وَکَفَرْت بِالطَّاغُوتِ۔",,,3518
3519,"حَدَّثَنَا ہُشَیْمٌ، عَنِ الْعَوَّامِ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ، قَالَ: کَانُوا یَسْتَحِبُّونَ أَنْ یُلَقِّنُوا الصَّبِیَّ الصَّلاَۃَ وَیُعْرِبُ أَوَّلَ مَا یَتَکَلَّمُ یَقُولُ لاَ إلَہَ إِلاَّ اللَّہُ سَبْعَ مَرَّاتٍ فَیَکُونُ ذَلِکَ أَوَّلَ شَیْئٍ یَتَکَلَّمُ بِہِ۔",,,3519
3520,"حَدَّثَنَا وَکِیعٌ، عَنْ ہَمَّامٍ، عَنْ أَبِیہِ، أَنَّ الأَشْعَثَ قَدَّمَ غُلاَمًا فَقِیلَ لَہُ، فَقَالَ: إنَّمَا قَدَّمْت الْقُرْآنَ۔",,,3520
3521,"حَدَّثَنَا عَبْدَۃُ، عَنْ ہِشَامٍ، عَنْ أَبِیہِ، قَالَ: لَمَّا قَدِمَ الأَشْعَثُ، قَدَّمَ غُلاَمًا فَعَابُوا ذَلِکَ عَلَیْہِ، فَقَالَ: مَا قَدَّمْتُہُ، وَلَکِنِّی قَدَّمْت الْقُرْآنَ۔",,,3521
3522,"حَدَّثَنَا ہُشَیْمٌ، عَنْ یُونُسَ، عَنِ الْحَسَنِ، عَنْ إبْرَاہِیمَ، قَالَ: لاَ بَأْسَ أَنْ یَؤُمَّ الْغُلاَمُ قَبْلَ أَنْ یَحْتَلِمَ فِی شَہْرِ رَمَضَانَ۔",,,3522
3523,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ، عَنْ ہِشَامٍ، عَنِ الْحَسَنِ، قَالَ: لاَ بَأْسَ أَنْ یَؤُمَّ الْغُلاَمُ قَبْلَ أَنْ یَحْتَلِمَ۔",,,3523
3524,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ، عَنِ ابْنِ جُرَیْجٍ، عَنْ عَطَاء، وَعُمَر بْنِ عَبْدِ الْعَزِیز، قَالاَ: لاَ یَؤُمُّ الْغُلاَمُ قَبْلَ أَنْ یَحْتَلِمَ فِی الْفَرِیضَۃِ وَلاَ غَیْرِہَا۔",,,3524
3525,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ، عَنْ عَبْدِ الْعَزِیزِ، عَنِ الشَّعْبِیِّ، قَالَ: لاَ یَؤُمُّ الْغُلاَمُ حَتَّی یَحْتَلِمَ۔",,,3525
3526,"حَدَّثَنَا رَوَّادُ بْنُ جَرَّاحٍ أَبُو عِصَامٍ، عَنِ الأَوْزَاعِیِّ، عَنْ وَاصِلٍ أَبِی بَکْرٍ، عَنْ مُجَاہِدٍ، قَالَ: لاَ یَؤُمُّ غُلاَمٌ حَتَّی یَحْتَلِمَ۔",,,3526
3527,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: کَانَ یُکْرَہُ التَّمَطِّیَ عِنْدَ النِّسَائِ، وَفِی الصَّلاَۃِ۔",,,3527
3528,"حَدَّثَنَا جَرِیرٌ، عَنْ لَیْثٍ، قَالَ: قَالَ سَعِیدُ بْنُ جُبَیْرٍ: التَّمَطِّی یَنْقُصُ الصَّلاَۃَ۔",,,3528
3529,"حَدَّثَنَا أَبُو خَالِدٍ الأحمر، عَنِ ابْنِ عَجْلاَنَ، عَنْ أَبِی الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: نَہَی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُصَلِّیَ الرَّجُلُ فِی الثَّوْبِ الْوَاحِدِ، لَیْسَ عَلَی عَاتِقَیہِ مِنْہُ شَیْئٌ۔",,,3529
3530,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنْ أَبِی الزِّنَادِ، عَنِ الأَعْرَجِ، عَنْ أَبِی ہُرَیْرَۃَ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِثْلَہُ۔\n\n(مسلم 277۔ ابوداؤد 626)",,,3530
3531,"حَدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ أَبِی إِسْحَاقَ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ، قَالَ: کَانَ الرَّجُلُ مِنْ أَصْحَابِ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا لَمْ یَجِدْ رِدَائً یُصَلِّی فِیہِ، وَضَعَ عَلَی عَاتِقَیہِ عِقَالاً ثُمَّ صَلَّی۔",,,3531
3532,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: کَانُوا یَکْرَہُونَ إعْرَائَ الْمَنَاکِبِ فِی الصَّلاَۃِ۔",,,3532
3533,"حَدَّثَنَا حَفْصٌ، عَنْ أَشْعَثَ، عَنِ الْحَکَمِ ؛ أَنَّ مُحَمَّدَ بْنَ عَلِیٍّ کَانَ یَقُولُ: لاَ یُصَلِّی الرَّجُلُ، إِلاَّ وَہُوَ مُخَمِّرٌ عَاتِقَہُ۔",,,3533
3534,"حَدَّثَنَا جَرِیرٌ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ، عَنْ مُجَاہِدٍ، قَالَ: لَمَّا قَدِمَ عُمَرُ مَکَّۃَ أَتَاہُ أَبُو مَحْذُورَۃَ وَقَدْ أَذَّنَ، فَقَالَ: الصَّلاَۃَ یَا أَمِیرَ الْمُؤْمِنِینَ، حَیَّ عَلَی الصَّلاَۃِ، حَیَّ عَلَی الصَّلاَۃِ، حَیَّ عَلَی الْفَلاَحِ، حَیَّ عَلَی الْفَلاَحِ، قَالَ: وَیْحَک، أَمَجْنُونٌ أَنْتَ ؟ أَمَا کَانَ فِی دُعَائِکَ الَّذِی دَعَوْتنَا مَا نَأْتِیک حَتَّی تَأْتِیَنَا۔",,,3534
3535,"حَدَّثَنَا جَرِیرٌ، عَنْ مُغِیرَۃَ، قَالَ: کَانَ الْمُؤَذِّنُ إذَا اسْتَبْطَأَ الْقَوْمَ، قَالَ: أَشْہَدُ أَنَّ مُحَمَّدًا رَسُولُ اللہِ، قَدْ قَامَتِ الصَّلاَۃُ، قَدْ قَامَتِ الصَّلاَۃُ، حَیَّ عَلَی الصَّلاَۃِ، حَیَّ عَلَی الصَّلاَۃِ، حَیَّ عَلَی الْفَلاَحِ، حَیَّ عَلَی الْفَلاَحِ۔",,,3535
3536,"حَدَّثَنَا جَرِیرٌ، عَنْ مِسْحَاجِ بْنِ مُوسَی الضَّبِّیِّ، قَالَ: سَمِعْتُ أَنَسَ بْنَ مَالِکٍ یَقُولُ لِمُحَمَّدِ بْنِ عَمْرٍو: إذَا کُنْتَ فِی سَفَرٍ، فَقُلْتُ: أَزَالَتِ الشَّمْسُ، أَوْ لَمْ تَزُلْ، أَوِ انْتَصَفَ النَّہَارُ، أَوْ لَمْ یَنْتَصِفْ، فَصَلِّ قَبْلَ أَنْ تَرْتَحِلَ۔",,,3536
3537,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، قَالَ: إذَا کُنْتَ فِی سَفَرٍ ، فَقُلْتُ : زَالَتِ الشَّمْسُ ، أَوْ لَمْ تَزُلْ ، فَصَلِّ۔",,,3537
3538,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنْ حَمْزَۃَ الضَّبِّیِّ، قَالَ: سَمِعْتُ أَنَسًا یَقُولُ: کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا نَزَلَ مَنْزِلاً لَمْ یَرْتَحِلْ حَتَّی یُصَلِّیَ الظُّہْرَ، فَقَالَ لَہُ مُحَمَّدُ بْنُ عَمْرٍو: وَإِنْ کَانَ نِصْفَ النَّہَارِ ؟ قَالَ: وَإِنْ کَانَ نِصْفَ النَّہَارِ۔ (ابوداؤد 1198۔ احمد 3/130)",,,3538
3539,"حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنْ أَبِی حَیَّانَ، عَنْ أَبِیہِ، عَنِ الرَّبِیعِ بْنِ خُثَیْمٍ ؛ أَنَّہُ کَانَ بِہِ مَرَضٌ، فَکَانَ تُہَادَی بَیْنَ رَجُلَیْنِ إلَی الصَّلاَۃِ، فَیُقَالُ لَہُ: یَا أَبَا زَیْدٍ، إنَّک إِنْ شَائَ اللَّہُ فِی عُذْرٍ، فَیَقُولُ: أَجَلْ، وَلَکِنِّی أَسْمَعُ الْمُؤَذِّنَ یَقُولُ: حَیَّ عَلَی الصَّلاَۃِ، حَیَّ عَلَی الْفَلاَحِ، فَمَنْ سَمِعَہَا فَلْیَأْتِہَا وَلَوْ حَبْوًا، وَلَوْ زَحْفًا۔",,,3539
3540,حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنْ مَنْصُورٍ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ کَانَ یُحْمَلُ وَہُوَ مَرِیضٌ إلَی الْمَسْجِدِ۔,,,3540
3541,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ، عَنِ الأَسْوَدِ، عَنْ عَائِشَۃَ، قَالَتْ: لَقَدْ رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی مَرَضِہِ الَّذِی مَاتَ فِیہِ وَإِنَّہُ لیُہَادَی بَیْنَ رَجُلَیْنِ حَتَّی دَخَلَ فِی الصَّفِّ۔\n\n(بخاری 713)",,,3541
3542,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ شَیْخٍ یُکَنَّی أَبَا سَہْلٍ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ، قَالَ: مَا أَذَّنَ الْمُؤَذِّنُ مُنْذُ ثَلاَثِینَ سَنَۃً، إِلاَّ وَأَنَا فِی الْمَسْجِدِ۔",,,3542
3543,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ أَبِی حَمْزَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: مَا کَانُوا یُرَخِّصُونَ فِی تَرْکِ الْجَمَاعَۃِ، إِلاَّ لِخَائِفٍ، أَوْ مَرِیضٍ۔",,,3543
3544,"حَدَّثَنَا ہُشَیْمُ بْنُ بَشِیرٍ، قَالَ: أَخْبَرَنَا حُمَیْدٌ، عَنْ أَنَسٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: اعْتَدِلُوا فِی صُفُوفِکُمْ وَتَراصَّوا، فَإِنِّی أَرَاکُمْ مِنْ وَرَائِ ظَہْرِی، قَالَ أَنَسٌ: لَقَدْ رَأَیْت أَحَدَنَا یُلْزِقُ مَنْکِبَہُ بِمَنْکِبِ صَاحِبِہِ، وَقَدَمَہُ بِقَدَمِہِ، وَلَوْ ذَھَبْتَ تَفْعَلَ ذَلِکَ لَتَرَی أَحَدَھُمْ کَأَنَّہُ بَغْلٌ شَمُوسٌ۔ (بخاری 725۔ احمد 3/103)",,,3544
3545,"حَدَّثَنَا أَبُو الأَحْوَصِِ، عَنْ سِمَاکٍ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ، قَالَ: لَقَدْ رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَإِنَّہُ لیقَوِّمُ الصُّفُوفَ کَمَا تُقَوَّمُ الْقِدَاحُ، فَأَبْصَرَ یَوْمًا صَدْرَ رَجُلٍ خَارِجًا مِنَ الصَّفِّ، فَقَالَ: لَتُقِیمُنَّ صُفُوفَکُمْ، أَوْ لَیُخَالِفَنَّ اللَّہُ بَیْنَ وُجُوہِکُمْ۔ (مسلم 325۔ ابوداؤد 665)",,,3545
3546,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ، عَنْ طَلْحَۃَ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَوْسَجَۃَ، عَنِ الْبَرَائِ بْنِ عَازِبٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: أَقِیمُوا صُفُوفَکُمْ لاَ یَتَخَلَّلُکُمْ کَأَوْلاَدِ الْحَذَفِ، قِیلَ: یَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، وَمَا أَوْلاَدُ الْحَذَفِ ؟ قَالَ: ضَأْنٌ سُودٌ جُرْدٌ تَکُونُ بِأَرْضِ الْیَمَنِ۔ (ابوداؤد 664۔ احمد 4/297)",,,3546
3547,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، وَوَکِیعٌ، عَنِ الأَعْمَشِ، عَنْ عُمَارَۃَ، عَنْ أَبِی مَعْمَرٍ، عَنْ أَبِی مَسْعُودٍ، قَالَ: کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَمْسَحُ مَنَاکِبَنَا فِی الصَّلاَۃِ وَیَقُولُ: اسْتَوُوا، وَلاَ تَخْتَلِفُوا فَتَخْتَلِفَ قُلُوبُکُمْ، لِیَلِیَنِّی مِنْکُمْ أُولُوا الأَحْلاَمِ وَالنُّہَی، ثُمَّ الَّذِینَ یَلُونَہُمْ، قَالَ أَبُو مَسْعُودٍ: فَأَنْتُمُ الْیَوْمَ أَشَدُّ اخْتِلاَفًا۔\n\n(مسلم 122۔ ابوداؤد 674)",,,3547
3548,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنْ قَتَادَۃَ، عَنْ أَنَسٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: أَقِیمُوا صُفُوفَکُمْ، فَإِنَّ مِنْ حُسْنِ الصَّلاَۃِ إقَامَۃَ الصف۔ (بخاری 723۔ مسلم 124)",,,3548
3549,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ یُونُسَ بْنِ جُبَیْرٍ، عَنْ حِطَّانَ بْنِ عَبْدِ اللہِ الرَّقَاشِیِّ، قَالَ: صَلَّی بِنَا أَبُو مُوسَی الأَشْعَرِیُّ، فَلَمَّا انْفَتَلَ قَالَ: إِنَّ نَبِیَّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ خَطَبَنَا، فَبَیَّنَ لَنَا سُنَّتَنَا وَعَلَّمَنَا صَلاَتَنَا، فَقَالَ: إذَا صَلَّیْتُمْ فَأَقِیمُوا صُفُوفَکُمْ۔",,,3549
3550,"حَدَّثَنَا وَکِیعٌ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ، عَنْ أَبِی عُثْمَانَ، قَالَ: کُنْتُ فِیمَنْ یُقِیمُ عُمَرُ بْنُ الْخَطَّابِ قُدَّامَہُ لإِقَامَۃِ الصَّفِّ۔",,,3550
3551,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنِ ابْنِ الأَصْبَہَانِیِّ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ؛ أَنَّ عُمَرَ رَأَی فِی الصَّفِّ شَیْئًا، فَقَالَ بِیَدِہِ ہَکَذَا، یَعْنِی وَکِیعٌ، فَعَدَّلَہُ۔,,,3551
3552,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ مَالِکِ بْنِ أَنَسٍ، عَنْ سَالِمٍ أَبِی النَّضْرِ، عَنْ مَالِکِ بْنِ أَبِی عَامِرٍ، قَالَ: سَمِعْتُ عُثْمَانَ وَہُوَ یَقُولُ: اسْتَوُوا وَحَاذُوا بَیْنَ الْمَنَاکِبِ، فَإِنَّ مِنْ تَمَامِ الصَّلاَۃِ إقَامَۃَ الصَّفِّ، قَالَ: وَکَانَ لاَ یُکَبِّرُ حَتَّی یَأْتِیَہُ رِجَالٌ قَدْ وَکَّلَہُمْ بِإِقَامَۃِ الصُّفُوفِ۔",,,3552
3553,"حَدَّثَنَا أَبُو خَالِدٍ، عَنْ مُجَالِدٍ، عَنِ الشَّعْبِیِّ، عَنِ الْحَارِثِ، وَأَصْحَابِ عَلِیٍّ قَالُوا: کَانَ عَلِیٌّ یَقُولُ: اسْتَوُوا تَسْتَوِ قُلُوبُکُمْ، وَتَرَاصُّوا تَرَاحَمُوا۔",,,3553
3554,"حَدَّثَنَا ابْنُ نُمَیْرٍ، عَنِ الأَعْمَشِ، عَنْ عِمْرَانَ، عَنْ سُوَیْد، عَنْ بِلاَلٍ، قَالَ: کَانَ یُسَوِّی مَنَاکِبَنَا وَأَقْدَامَنَا فِی الصَّلاَۃِ۔",,,3554
3555,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ، عَنْ شُعْبَۃَ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ، عَنْ أَبِی الأَحْوَصِ، قَالَ: قَالَ عَبْدُ اللہِ: سَوُّوا صُفُوفَکُمْ۔",,,3555
3556,"حَدَّثَنَا ہُشَیْمٌ، عَنْ مُغِیرَۃَ، عَنْ إبْرَاہِیمَ، قَالَ: کَانَ یُقَالُ: سَوُّوا الصُّفُوفَ وَتَرَاصُّوا، لاَ تَتَخَلَّلُکُمُ الشَّیَاطِینُ، کَأَنَّہُمَ بَنَاتُ حَذَفٍ۔",,,3556
3557,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنْ عَاصِمٍ، عَنْ أَبِی عُثْمَانَ، قَالَ: مَا رَأَیْت أَحَدًا کَانَ أَشَدَّ تَعَاہُدًا لِلصَّفِّ مِنْ عُمَرَ، إِنْ کَانَ لیسْتَقْبِلَ الْقِبْلَۃَ حَتَّی إذَا قُلْنَا قَدْ کَبَّرَ، الْتَفَتَ فَنَظَرَ إلَی الْمَنَاکِبِ وَالأَقْدَامِ، وَإِنْ کَانَ یَبْعَثُ رِجَالاً یَطْرُدُونَ النَّاسَ حَتَّی یُلْحِقُوہُمْ بِالصُّفُوفِ۔",,,3557
3558,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ، عَنْ مُجَاہِدٍ، عَنْ أَبِی الْوَدَّاکِ، عَنْ أَبِی سَعِیدٍ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: یَضْحَکُ اللَّہُ إلَی ثَلاَثَۃٍ: الْقَوْمُ إذَا صَفُّوا فِی الصَّلاَۃِ، وَإِلَی الرَّجُلِ یُقَاتِلُ وَرَائَ أَصْحَابِہِ، وَإِلَی الرَّجُلِ یَقُومُ فِی سَوَادِ اللَّیْلِ۔",,,3558
3559,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ، عَنْ تَمِیمِ بْنِ طَرَفَۃَ، عَنْ جَابِرِ بْنِ سَمُرَۃَ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: أَلاَ تَصُفُّونَ کَمَا تَصُفُّ الْمَلاَئِکَۃُ عِنْدَ رَبِّہَا ؟ قَالُوا: وَکَیْفَ تَصُفُّ الْمَلاَئِکَۃُ عِنْدَ رَبِّہَا ؟ قَالَ: یُتِمُّونَ الصُّفُوفَ الأَولَی، وَیَتَرَاصُّونَ فِی الصَّفِّ۔ (مسلم 119۔ ابوداؤد 661)",,,3559
3560,"حَدَّثَنَا شَبَابَۃُ، عَنِ ابْنِ أَبِی ذِئْبٍ، عَنْ عَجْلاَنَ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: سَوُّوا صُفُوفَکُمْ، وَأَحْسِنُوا رُکُوعَکُمْ وَسُجُودَکُمْ۔ (احمد 2/234)",,,3560
3561,"حَدَّثَنَا شَرِیکٌ، عَنْ زِیَادِ بْنِ عِلاَقَۃَ، عَنْ قُطْبَۃَ بْنِ مَالِکٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ فِی الْفَجْرِ: {وَالنَّخْلَ بَاسِقَاتٍ}۔ (مسلم 165۔ ترمذی 306)",,,3561
3562,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنِ الْوَلِیدِ بْنِ سَرِیعٍ، عَنْ عَمْرِو بْنِ حُرَیْثٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ فِی الْفَجْرِ: {وَاللَّیْلِ إذَا عَسْعَسَ}۔ (مسلم 164۔ احمد 4/307)",,,3562
3563,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ، عَنْ زُہَیْرٍ، عَنْ سِمَاکٍ، قَالَ: سَأَلْتُ جَابِرَ بْنَ سَمُرَۃَ عَنْ صَلاَۃِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَأَنْبَأَنِی، أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الْفَجْرِ بِـ: {ق وَالْقُرْآنِ الْمَجِیدِ} وَنَحْوِہَا۔ (مسلم 169۔ احمد 5/105 )",,,3563
3564,حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ عَوْفٍ، عَنْ أَبِی الْمِنْہَالِ، عَنْ أَبِی بَرْزَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِیہَا بِالسِّتِّینَ إلَی الْمِئَۃِ، یَعْنِی فِی الْفَجْرِ۔,,,3564
3565,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ، عَنِ الزُّہْرِیِّ، عَنْ أَنَسٍ ؛ أَنَّ أَبَا بَکْرٍ قَرَأَ فِی صَلاَۃِ الصُّبْحِ بِالْبَقَرَۃِ، فَقَالَ لَہُ عُمَرُ حِینَ فَرَغَ: کَرَبَتِ الشَّمْسُ أَنْ تَطْلُعَ، قَالَ: لَوْ طَلَعَتْ لَمْ تَجِدْنَا غَافِلِینَ۔",,,3565
3566,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ، عَنِ الزُّبَیْرِ بْنِ خِرِّیتٍ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ، عَنِ الأَحْنَفِ، قَالَ: صَلَّیْت خَلْفَ عُمَرَ الْغَدَاۃَ، فَقَرَأَ بِیُونُسَ، وَہُودٍ، وَنَحْوَہُمَا۔",,,3566
3567,حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنْ عَبْدِالْمَلِکِ بْنِ مَیْسَرَۃَ، عَنْ زَیْدِ بْنِ وَہْبٍ؛ أَنَّ عُمَرَ قَرَأَ فِی الْفَجْرِ، بِالْکَہْفِ۔,,,3567
3568,"حَدَّثَنَا وَکِیعٌ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ، عَنْ عَبْدِ اللہِ بْنِ عَامِرِ بْنِ رَبِیعَۃَ، قَالَ: سَمِعْتُ عُمَرَ یَقْرَأُ فِی الْفَجْرِ بِسُورَۃِ یُوسُفَ قِرَائَۃً بَطِیئَۃً۔",,,3568
3569,"حَدَّثَنَا أَبُو أُسَامَۃَ، قَالَ: حدَّثَنَا عُبَیْدُ اللہِ، قَالَ: أَخْبَرَنِی ابْنُ الْفُرَافِصَۃِ، عَنْ أَبِیہِ، قَالَ: تَعَلَّمْتُ سُورَۃَ یُوسُفَ خَلْفَ عُمَرَ فِی الصُّبْحِ۔",,,3569
3570,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ، قَالَ: صَلَّی بِنَا عَبْدُ اللہِ الْفَجْرَ فَقَرَأَ بِسُورَتَیْنِ، الآخِرَۃُ مِنْہُمَا بَنِو إسْرَائِیلَ۔",,,3570
3571,"حَدَّثَنَا وَکِیعٌ، عَنْ إدْرِیسَ الأَوْدِیِّ، عَنْ أَبِیہِ، قَالَ: سَمِعْتُ عَلِیًّا یَقْرَأُ فِی الآخِرَۃِ مِنْہُمَا بـ: {سَبِّحِ اسْمَ رَبِّکَ}۔",,,3571
3572,"حَدَّثَنَا مُعْتَمِرٌ، عَنِ الزُّبَیْرِ بْنِ خِرِّیتٍ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: صَلَّیْت خَلْفَہُ صَلاَۃَ الْغَدَاۃِ، فَقَرَأَ بِیُونُسَ وَہُودٍ۔",,,3572
3573,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ، قَالَ: سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ، یُحَدِّثُ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ؛ أَنَّ مُعَاذَ بْنَ جَبَلٍ صَلَّی الصُّبْحَ بِالْیَمَنِ فَقَرَأَ بِالنِّسَائِ، فَلَمَّا أَتَی عَلَی ہَذِہِ الآیَۃِ: {وَاتَّخَذَ اللَّہُ إبْرَاہِیمَ خَلِیلاً} قَالَ رَجُلٌ مِنْ خَلْفِہِ: لَقَدْ قَرَّتْ عَیْنُ أُمِّ إبْرَاہِیمَ۔",,,3573
3574,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنْ عُبَیْدِ اللہِ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ، قَالَ: کَانَ یَقْرَأُ فِی الْفَجْرِ بِالسُّورَۃِ الَّتِی یُذْکَرُ فِیہَا یُوسُفُ، وَالَّتِی یُذْکَرُ فِیہَا الْکَہْفُ۔",,,3574
3575,"حَدَّثَنَا وَکِیعٌ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ، عَنِ الْحَارِثِ بْنِ سُوَیْد، قَالَ: کَانَ إمَامُنَا یَقْرَأُ بِنَا فِی الْفَجْرِ بِالسُّورَۃِ مِنَ الْمِئِینَ۔",,,3575
3576,حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنِ النُّعْمَانِ بْنِ قَیْسٍ، عَنْ عبیدَۃَ ؛ أَنَّہُ کَانَ یَقْرَأُ فِی الْفَجْرِ {الرَّحْمَنِ} ، وَنَحْوَہَا۔,,,3576
3577,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ عَطَائِ بْنِ السَّائِبِ، قَالَ: صَلَّیْت خَلْفَ عَرْفَجَۃَ فَرُبَّمَا قَرَأَ بِالْمَائِدَۃِ فِی الْفَجْرِ۔",,,3577
3578,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ، عَنْ جَدِّ ابْنِ إدْرِیسَ، قَالَ: صَلَّیْتُ خَلْفَ عَلِیٍّ الصُّبْحَ، فَقَرَأَ بِـ: {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی}۔",,,3578
3579,"حَدَّثَنَا غُنْدَرٌ، عَنْ شُعْبَۃَ، عَنْ تَوْبَۃَ الْعَنْبَرِیِّ ؛ أَنَّہُ سَمِعَ أَبَا سَوَّارٍ الْقَاضِیَ، قَالَ: صَلَّیْتُ خَلْفَ ابْنِ الزُّبَیْرِ الصُّبْحَ فَسَمِعْتُہُ یَقْرَأُ: {أَلَمْ تَرَ کَیْفَ فَعَلَ رَبُّک بِعَادٍ إرَمَ ذَاتِ الْعِمَادِ}۔",,,3579
3580,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنِ الْوَلِیدِ بْنِ جُمَیْعٍ، قَالَ: صَلَّیْتُ خَلْفَ إبْرَاہِیمَ، فَکَانَ یَقْرَأُ فِی الصُّبْحِ بـ: (یس) وَأَشْبَاہَہَا، وَکَانَ سَرِیعَ الْقِرَائَۃِ۔",,,3580
3581,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ عَطَائِ بْنِ السَّائِبِ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ قَالَ: مَا رَأَیْت رَجُلاً أَقْرَأَ مِنْ عَلِیٍّ، إِنَّہُ قَرَأَ بِنَا فِی صَلاَۃِ الْفَجْرِ بِالأَنْبِیَائِ، قَالَ: إذَا بَلَغَ رَأْسَ سَبْعِینَ تَرَکَ مِنْہَا آیَۃً فَقَرَأَ مَا بَعْدَہَا، ثُمَّ ذَکَرَ فَرَجَعَ فَقَرَأَہَا، ثُمَّ رَجَعَ إلَی مَکَانِہِ الَّذِی کَانَ قَرَأَ، لَمَّا یَتَتَعْتَعْ۔",,,3581
3582,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ، قَالَ: أَخْبَرَنَا الضَّحَّاکُ بْنُ عُثْمَانَ، قَالَ: رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ قَرَأَ فِی الْفَجْرِ بِسُورَتَیْنِ مِنْ طِوَالِ الْمُفَصَّلِ۔",,,3582
3583,"حَدَّثَنَا عَبْدُ الأَعْلَی، عَنِ الْجُریرِیِّ، عَنْ أَبِی الْعَلاَئِ، عَنْ أَبِی رَافِعٍ قَالَ: کَانَ عُمَرُ یَقْرَأُ فِی صَلاَۃِ الصُّبْحِ بِمِئَۃٍ مِنَ الْبَقَرَۃِ، وَیُتْبِعُہَا بِسُورَۃٍ مِنَ الْمَثَانِی، أَوْ مِنْ صُدُورِ الْمُفَصَّلِ، وَیَقْرَأُ بِمِئَۃٍ مِنْ آلِ عِمْرَانَ، وَیُتْبِعُہَا بِسُورَۃٍ مِنَ الْمَثَانِی، أَوْ مِنْ صُدُورِ الْمُفَصَّلِ۔",,,3583
3584,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ، عَنْ حُصَیْنِ بْنِ سَبْرَۃَ، قَالَ: صَلَّیْت خَلْفَ عُمَرَ، فَقَرَأَ فِی الرَّکْعَۃِ الأَولَی بِسُورَۃِ یُوسُفَ، ثُمَّ قَرَأَ فِی الثَّانِیَۃِ بِالنَّجْمِ، فَسَجَدَ، ثُمَّ قَامَ فَقَرَأَ: {إذَازُلْزِلَتِ الأَرض} ثُمَّ رَکَعَ۔",,,3584
3585,"حَدَّثَنَا ابْنُ عُیینَّۃَ، عَنْ إسْمَاعِیلَ بْنِ مُحَمَّدٍ بْنِ سَعْدٍ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ، قَالَ: سَمِعْتُ نَشِیجَ عُمَرَ \n\nوَأَنَا فِی آخِرِ الصُّفُوفِ فِی صَلاَۃِ الصُّبْحِ وَہُوَ یَقْرَأُ: {إنَّمَا أَشْکُو بَثِّی وَحُزْنِی إلَی اللہِ}۔",,,3585
3586,"حَدَّثَنَا أَبُو أُسَامَۃَ، عَنِ ابْنِ جُرَیْجٍ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ، عَنْ عَلْقَمَۃَ بْنِ وَقَّاصٍ، قَالَ: سَمِعْتُ عُمَرَ ؛ ثُمَّ ذَکَرَ نَحْوَہُ۔",,,3586
3587,"حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنْ مُغِیرَۃَ، عَنْ أَبِی حَمْزَۃَ الأَعْوَرِ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ صَلَّی بِہِمْ یَوْمَ جُمُعَۃٍ الْفَجْرَ، فَقَرَأَ بِـ: (کہیعص)۔",,,3587
3588,"حَدَّثَنَا ہُشَیْمٌ، عَنْ مَنْصُورٍ، عَنْ أَبِی بِشْرٍ الْہُجَیْمِیِّ، عَنْ أَبِی الصِّدِّیق، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ، قَالَ: کُنَّا نَحْزُرُ قِیَامَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الظُّہْرِ وَالْعَصْرِ، فَحَزَرْنَا قِیَامَہُ فِی الظُّہْرِ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ بِقَدْرِ ثَلاَثِینَ آیَۃً، وَحَزَرْنَا قِیَامَہُ فِی الرَّکْعَتَیْنِ الأُخْرَیَیْنِ عَلَی النِّصْفِ مِنْ ذَلِکَ، وَحَزَرْنَا قِیَامَہُ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ مِنَ الْعَصْرِ عَلَی قَدْرِ الأُخْرَیَیْنِ مِنَ الظُّہْرِ، وَحَزَرْنَا قِیَامَہُ فِی الأُخْرَیَیْنِ مِنَ الْعَصْرِ عَلَی النِّصْفِ مِنْ ذَلِکَ۔ (ابوداؤد 800۔ احمد 3/2)",,,3588
3589,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ، عَنْ شُعْبَۃَ، عَنْ سِمَاکٍ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الظُّہْرِ بِـ: {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} وَفِی الصُّبْحِ بِأَطْوَلَ مِنْ ذَلِکَ۔ \n\n(مسلم 338۔ احمد 5/86)",,,3589
3590,"حَدَّثَنَا أَبُو دَاوُدَ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ، عَنْ سِمَاکِ بْنِ حَرب، عَنْ جَابِرِ بْنِ سَمُرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الظُّہْرِ وَالْعَصْرِ بِـ: {السَّمَائِ وَالطَّارِقِ} ، وَ {وَالسَّمَائِ ذَاتِ الْبُرُوجِ}۔\n\n(طیالسی 774۔ ابن حبان 1827)",,,3590
3591,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، قَالَ: حدَّثَنَا ہِشَامٌ الدَّسْتَوَائِیُّ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ، عَنْ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ، عَنْ أَبِیہِ، قَالَ: کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ بِنَا فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ مِنَ الظُّہْرِ، یُطِیلُ فِی الأُولَی وَیُقَصِّرُ فِی الثَّانِیَۃِ، وَکَانَ یَفْعَلُ ذَلِکَ فِی صَلاَۃِ الصُّبْحِ، یُطِیلُ فِی الأُولَی وَیُقَصِّرُ فِی الثَّانِیَۃِ، وَکَانَ یَقْرَأُ بِنَا فِی الرَّکْعَتَیْنِ مِنَ الْعَصْرِ۔ (بخاری 759۔ مسلم 333)",,,3591
3592,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ زَیْدٍ الْعَمِّیِّ، عَنْ أَبِی الْعَالِیَۃِ، قَالَ: حزَرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قِرَائَتَہُ فِی الظُّہْرِ نَحْوًا مِنْ (أَلم تَنْزِیلُ)۔",,,3592
3593,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ عَلِیِّ بْنِ زَیْدِ بْنِ جُدْعَانَ، عَنْ أَبِی عُثْمَانَ النَّہْدِیِّ، قَالَ: سَمِعْتُ مِنْ عُمَرَ نَغْمَۃً مِنْ (ق) فِی صَلاَۃِ الظُّہْرِ۔",,,3593
3594,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْمَاعِیلَ بْنِ مُسْلِمٍ، عَنْ أَبِی الْمُتَوَکِّلِ النَّاجِی ؛ أَنَّ عُمَرَ قَرَأَ فِی الظُّہْرِبِـ: {ق}، {وَالذَّارِیَاتِ}۔",,,3594
3595,"حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ، عَنْ حُمَیْدٍ، قَالَ: صَلَّیْت خَلْفَ أَنَسٍ الظُّہْرَ، فَقَرَأَ بِـ: {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ، وَجَعَلَ یُسْمِعُنَا الآیَۃَ۔",,,3595
3596,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ ہِشَامٍ، عَنْ جَمِیلِ بْنِ مُرَّۃَ، عَنْ مُوَرِّقٍ الْعِجْلِیّ، قَالَ: صَلَّیْت خَلْفَ ابْنِ عُمَرَ الظُّہْرَ، فَقَرَأَ بِسُورَۃِ مَرْیَمَ۔",,,3596
3597,"حَدَّثَنَا وَکِیعٌ، عَنْ سَیْفٍ، عَنْ مُجَاہِدٍ، قَالَ: سَمِعْتُ عَبْدَ اللہِ بْنَ عَمْرو یَقْرَأُ فِی الظُّہْرِ بِـ: {کہیعص}",,,3597
3598,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مَنْصُورٍ، عَنْ إبْرَاہِیمَ، قَالَ: إنِّی لأَقْرَأُ فِی الظُّہْرِ بـ: {الصَّافَّاتِ}۔",,,3598
3599,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ، قَالَ: حدَّثَنَا مِسْعَرٌ، عَنْ حَمَّادٍ، قَالَ: الْقِرَائَۃُ فِی الظُّہْرِ وَالْفَجْرِ سَوَائٌ۔",,,3599
3600,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ حَمَّادٍ، قَالَ: تُعْدلُ الظُّہْرُ بِالْفَجْرِ۔",,,3600
3601,"حَدَّثَنَا وَکِیعٌ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ، عَنْ عُقْبَۃَ بْنِ نَافِعٍ، قَالَ: سَمِعْتُ ابْنَ عُمَرَ یَہْمِسُ بِالْقِرَائَۃِ فِی الظُّہْرِ وَالْعَصْرِ۔",,,3601
3602,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ سَعِیدٍ، عَنْ قَتَادَۃَ، عَنْ زُرَارَۃَ بْنِ أَوْفَی، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الظُّہْرَ، فَلَمَّا سَلَّمَ قَالَ: ہَلْ قَرَأَ أَحَدٌ مِنْکُمْ بِـ: {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} ؟ فَقَالَ رَجُلٌ مِنَ الْقَوْمِ: أَنَا، فَقَالَ: قَدْ عَلِمْتُ أَنَّ بَعْضَکُمْ خَالَجَنِیہَا۔ (مسلم 299۔ ابوداؤد 825)",,,3602
3603,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ وَسُفْیَانَ، عَنْ زِیَادِ بْنِ فَیَّاضٍ، عَنْ إبْرَاہِیمَ، قَالَ: الْعَصْرُ وَالْمَغْرِبُ سَوَائٌ۔",,,3603
3604,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ مُغِیرَۃَ، عَنْ شِبَاکٍ، عَنْ إبْرَاہِیمَ، قَالَ: تُضَاعَفُ الظُّہْرُ عَلَی الْعَصْرِ أَرْبَعَ مِرَار۔",,,3604
3605,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَعْدِلُونَ الظُّہْرَ بِالْعِشَائِ ، وَالْعَصْرَ بِالْمَغْرِبِ۔",,,3605
3606,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ سِمَاکِ بْنِ حَرْبٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الظُّہْرِ وَالْعَصْرِ بِـ : {السَّمَائِ وَالطَّارِقِ} ، {وَالسَّمَائِ ذَاتِ الْبُرُوجِ}۔",,,3606
3607,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُسَوِّی بَیْنَ رَکَعَاتِ الظُّہْرِ وَالْعَصْرِ۔,,,3607
3608,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ الرَّازِیّ ، عَنْ أَبِی جَعْفَرٍ، عَنْ أَبِی الرَّبِیعِ، عَنْ أَبِی الْعَالِیَۃِ، قَالَ: الْعَصْرُ عَلَی النِّصْفِ مِنَ الظُّہْرِ۔",,,3608
3609,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ مُحَمَّدِ بْنِ جُبَیْرِ بْنِ مُطْعِمٍ ، عَنْ أَبِیہِ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ فِی الْمَغْرِبِ بِـ : {الطُّورِ}۔ (بخاری 865۔ مسلم 174)",,,3609
3610,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عَبْدِ اللہِ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ أُمِّہِ ؛ أَنَّہَا سَمِعَتِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ فِی الْمَغْرِبِ : {وَالْمُرْسَلاَتِ}۔ (بخاری 763۔ مسلم 338)",,,3610
3611,حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ زَیْدٍ ، أَوْ أَبِی أَیُّوبَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ فِی الْمَغْرِبِ بِالأَعْرَافِ فِی الرَّکْعَتَیْنِ جَمِیعًا۔ (بخاری 864۔ احمد 5/185),,,3611
3612,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ فِی الْمَغْرِبِ بـ : {التِّینِ وَالزَّیْتُونِ}۔ (طحاوی 214)",,,3612
3613,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : صَلَّی بِنَا عُمَرُ صَلاَۃَ الْمَغْرِبِ ، فَقَرَأَ فِی الرَّکْعَۃِ الأَولَی بـ : {التِّینِ وَالزَّیْتُونِ} ، وَفِی الرَّکْعَۃِ الثَّانِیَۃِ : {أَلَمْ تَرَ کَیْفَ فَعَلَ رَبُّک بِأَصْحَابِ الْفِیلِ}، وَ {لإِیلاَفِ قُرَیْشٍ}۔",,,3613
3614,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، قَالَ : أَقْرَأَنِی أَبُو مُوسَی کِتَابَ عُمَرَ : أَنِ اقْرَأْ بِالنَّاسِ فِی الْمَغْرِبِ بِآخِرِ الْمُفَصَّلِ۔",,,3614
3615,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ قُرَّۃَ ، عَنِ النَّزَّالِ بْنِ عَمَّارٍ ، قَالَ : حدَّثَنِی أَبُو عُثْمَانَ النَّہْدِیُّ ، قَالَ : صَلَّی بِنَا أَبُو مَسْعُودٍ الْمَغْرِبَ فَقَرَأَ : (قُلْ ہُوَ اللَّہُ أَحَدٌ) فَوَدِدْت أَنَّہُ کَانَ قَرَأَ سُورَۃَ الْبَقَرَۃِ ، مِنْ حُسْنِ صَوْتِہِ۔",,,3615
3616,حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ، عَنْ خَالِدٍ، عَنْ عَبْدِاللہِ بْنِ الْحَارِثِ؛ أَنَّ ابْنَ عَبَّاسٍ قَرَأَ الدُّخَانَ فِی الْمَغْرِبِ۔,,,3616
3617,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی نَوْفَلِ بْنِ أَبِی عَقْرَبٍ ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: سَمِعْتُہُ یَقْرَأُ فِی الْمَغْرِبِ {إذَا جَائَ نَصْرُ اللہِ وَالْفَتْحُ}۔",,,3617
3618,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقْرَأُ بِـ : (قٓ) فِی الْمَغْرِبِ۔",,,3618
3619,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ قَرَأَ مَرَّۃً فِی الْمَغْرِبِ بِـ : (یٰسٓ)۔",,,3619
3620,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ قَرَأَ فِی الْمَغْرِبِ بِـ: (یَسِ)، وَ(عَمَّ یَتَسَائَلُونَ)۔",,,3620
3621,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ عِمْرَانُ بْنُ حُصَیْنٍ یَقْرَأُ فِی الْمَغْرِبِ {إذَا زُلْزِلَتِ الأَرْضُ} وَ(الْعَادِیَاتِ)۔",,,3621
3622,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ یَقْرَأُ فِی الْمَغْرِبِ مَرَّۃً {تُنَبِّیئُ أَخْبَارَہَا} وَمَرَّۃً {تُحَدِّثُ أَخْبَارَہَا}۔",,,3622
3623,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحِلٍّ، قَالَ: سَمِعْتُ إبْرَاہِیمَ یَقْرَأُ فِی الرَّکْعَۃِ الأَولَی مِنَ الْمَغْرِبِ {لإِیلاَفِ قُرَیْشٍ}۔",,,3623
3624,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، قَالَ : کَانَ الْحَسَنْ یَقْرَأُ فِی الْمَغْرِبِ : (إذَا زُلْزِلَت) (وَالْعَادِیَاتِ) لاَ یَدَعُہَا۔",,,3624
3625,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سَعِیدِ بْنِ مَسْرُوقٍ ، عَنْ مُحَارِبِ بْنِ دِثَارٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : أَمَّ مُعَاذٌ قَوْمًا فِی صَلاَۃِ الْمَغْرِبِ ، فَمَرَّ بِہِ غُلاَمٌ مِنَ الأَنْصَارِ وَہُوَ یَعْمَلُ عَلَی بَعِیرٍ لَہُ ، فَأَطَالَ بِہِمْ مُعَاذٌ ، فَلَمَّا رَأَی ذَلِکَ الْغُلاَمُ تَرَکَ الصَّلاَۃَ وَانْطَلَقَ فِی طَلَبِ بَعِیرِہِ ، فَرُفِعَ ذَلِکَ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ: أَفَتَّانٌ أَنْتَ یَامُعَاذُ؟ أَلاَّ یَقْرَأُ أَحَدُکُمْ فِی الْمَغْرِبِ بِـ: {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} وَ {الشَّمْسِ وَضُحَاہَا}۔\n\n(بخاری 705۔ مسلم 178)",,,3625
3626,"حَدَّثَنَا مُعَاوِیَۃُ بْنُ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ نُسَیْرِ بْنِ ذُعْلُوقٍ ، عَنِ الرَّبِیعِ بْنِ خُثَیْمٍ ؛ أَنَّہُ کَانَ یَقْرَأُ فِی الْمَغْرِبِ بِقِصَارِ الْمُفَصَّلِ : {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ {قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,3626
3627,"حَدَّثَنَا یَزِیدُ بْنُ حُبَابٍ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَقْرَأُ فِی الْمَغْرِبِ بِقِصَارِ الْمُفَصَّلِ۔",,,3627
3628,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : سَمِعْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ فِی الْعِشَائِ : {وَالتِّینِ وَالزَّیْتُونِ}۔ (بخار ی767۔ مسلم 175)",,,3628
3629,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : أَمَّنَا عَبْدُ اللہِ فِی الْعِشَائِ الآخِرَۃِ ، فَافْتَتَحَ الأَنْفَالَ حَتَّی بَلَغَ : {فَاعْلَمُوا أَنَّ اللَّہَ مَوْلاَکُمْ نِعْمَ الْمَوْلَی وَنِعْمَ النَّصِیرُ} رَکَعَ ، ثُمَّ قَامَ فَقَرَأَ فِی الثَّانِیَۃِ بِسُورَۃٍ۔",,,3629
3630,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، عَنْ عَبْدِ اللہِ ؛ مِثْلَہُ۔,,,3630
3631,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، قَالَ : أَقْرَأَنِی أَبُو مُوسَی کِتَابَ عُمَرَ إلَیْہِ : أَنِ اقْرَأْ بِالنَّاسِ فِی الْعِشَائِ بِوَسَطِ الْمُفَصَّلِ۔",,,3631
3632,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ زَیْدِ بْنِ جُدْعَانَ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، عَنْ مَسْرُوقِ بْنِ الأَجْدَعِ ؛ أَنَّ عُثْمَانَ قَرَأَ فِی الْعِشَائِ ، یَعْنِی الْعَتَمَۃَ بِـ : (النَّجْمِ) ، ثُمَّ سَجَدَ ، ثُمَّ قَامَ فَقَرَأَ بِـ : (التِّینِ وَالزَّیْتُونِ)۔",,,3632
3633,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ عَبَّادِ بْنِ عَبَّادٍ ، قَالَ : حدَّثَنِی ہِلاَلٌ ؛ أَنَّہُ سَمِعَ أَبَا ہُرَیْرَۃَ یَقْرَأُ {وَالْعَادِیَاتِ ضَبْحًا} فِی الْعِشَائِ۔",,,3633
3634,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ کَانَ یَقْرَأُ فِی الْعِشَائِ بِـ : {اَلَّذِینَ کَفَرُوا} وَ (الْفَتْحِ)۔",,,3634
3635,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَقْرَأُ فِی الْعِشَائِ بِـ : (تَنْزِیلِ) السَّجْدَۃِ، فَیَرْکَعُ بِہَا۔",,,3635
3636,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ عَلِیِّ بْنِ سُوَیْد بْنِ مَنْجُوفٍ ، قَالَ : حدَّثَنَا أَبُو رَافِعٍ ، قَالَ : صَلَّیْت مَعَ عُمَرَ الْعِشَائَ فَقَرَأَ : {إذَا السَّمَائُ انْشَقَّتْ}۔",,,3636
3637,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : أَخْبَرَنِی الضَّحَّاکُ بْنُ عُثْمَانَ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَقْرَأُ فِی الْعِشَائِ بِوَسَطِ الْمُفَصَّلِ۔",,,3637
3638,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ مَحْمُودِ بْنِ رَبِیعٍ ، عَنْ عُبَادَۃَ بْنِ الصَّامِتِ یَبْلُغُ بِہِ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ قَالَ : لاَ صَلاَۃَ لِمَنْ لَمْ یَقْرَأْ بِفَاتِحَۃِ الْکِتَابِ۔ (بخاری 756۔ ابوداؤد 818)",,,3638
3639,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الْعَلاَئِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ یَعْقُوبَ ؛ أَنَّ أَبَا السَّائِبِ أَخْبَرَہُ ، أَنَّہُ سَمِعَ أَبَا ہُرَیْرَۃَ یَقُولُ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ صَلَّی صَلاَۃً لَمْ یَقْرَأْ فِیہَا بِفَاتِحَۃِ الْکِتَابِ فَہِیَ خِدَاجٌ ، ہِیَ خِدَاجٌ ، ہِیَ خِدَاجٌ غَیْرُ تَمَامٍ۔ (مسلم 296۔ ابوداؤد 817)",,,3639
3640,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ یَحْیَی بْنِ عَبَّادِ بْنِ عَبْدِ اللہِ بْنِ الزُّبَیْرِ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : کُلُّ صَلاَۃٍ لاَ یُقْرَأُ فِیہَا بِفَاتِحَۃِ الْکِتَابِ فَہِیَ خِدَاجٌ۔",,,3640
3641,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْوَلِیدِ بْن أَبِی ہِشَامٍ ، عَنْ وَہْبِ بْنِ کَیْسَانَ ، قَالَ : قَالَ جَابِرُ بْنُ عَبْدِ اللہِ : مَنْ لَمْ یَقْرَأْ فِی کُلِّ رَکْعَۃٍ بِأُمِّ الْقُرْآنِ فَلَمْ یُصَلِّ ، إِلاَّ خَلْفَ الإِمَام۔",,,3641
3642,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیرِیِّ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ، قَالَ : لاَ تَجُوزُ صَلاَۃٌ لاَ یُقْرَأُ فِیہَا بِفَاتِحَۃِ الْکِتَابِ وَآیَتَیْنِ فَصَاعِدًا۔",,,3642
3643,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدِ بْنِ یَزِیدَ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ؛ فِی کُلِّ صَلاَۃٍ قِرَائَۃُ قُرْآنٍ ، أُمُّ الْکِتَابِ فَمَا زَادَ۔,,,3643
3644,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، عَنْ عَبَایَۃَ بْنِ رِبْعِیٍّ ، قَالَ : قَالَ عُمَرُ : لاَ تُجْزِیئُ صَلاَۃٌ لاَ یُقْرَأُ فِیہَا بِفَاتِحَۃِ الْکِتَابِ وَآیَتَیْنِ فَصَاعِدًا۔",,,3644
3645,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، قَالَ : جَلَسْت إلَی رَہْطٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنَ الأَنْصَارِ ، فَذَکَرُوا الصَّلاَۃَ وَقَالُوا : لاَ صَلاَۃَ إِلاَّ بِقِرَائَۃٍ وَلَوْ بِأُمِّ الْکِتَابِ ، قَالَ خَالِدٌ : فَقُلْتُ لِعَبْدِ اللہِ بْنِ الْحَارِثِ : ہَلْ تُسَمِّی مِنْہُمْ أَحَدًا ؟ قَالَ : نَعَمْ ، خَوَّاتُ بْنُ جُبَیْرٍ۔",,,3645
3646,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا لَمْ یَقْرَأْ فِی کُلِّ رَکْعَۃٍ بِفَاتِحَۃِ الْکِتَابِ ، فَإِنَّہُ یُعِیدُ تِلْکَ الرَّکْعَۃَ۔",,,3646
3647,حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ الْعَلاَئِ بْنِ الْمُسَیَّبِ ، عَنْ مُحَمَّدِ بْنِ الْحَکَمِ ؛ أَنَّ أَبَا وَائِلٍ قَرَأَ بِفَاتِحَۃِ الْکِتَابِ وَآیَۃٍ ، ثُمَّ رَکَعَ۔,,,3647
3648,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : تُجْزِیئُ فَاتِحَۃُ الْکِتَابِ ، قَالَ : فَلَقِیتُہُ بَعْدُ ، فَقُلْتُ : فِی الْفَرِیضَۃِ ؟ فَقَالَ : نَعَمْ۔",,,3648
3649,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنِ الْمُغِیرَۃِ ، عَنْ إبْرَاہِیمَ ، قَالَ : تُجْزِیئُ فَاتِحَۃُ الْکِتَابِ فِی الْفَرِیضَۃِ وَغَیْرِہَا۔",,,3649
3650,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی الْعَالِیَۃِ الْبَرَّائِ ، قَالَ : قُلْتُ لابْنِ عُمَرَ : أَفِی کُلِّ رَکْعَۃٍ أَقْرَأُ ؟ فَقَالَ : إنِّی لأَسْتَحِیی مِنْ رَبِّ ہَذَا الْبَیْتِ أَنْ لاَ أَقْرَأَ فِی کُلِّ رَکْعَۃٍ بِفَاتِحَۃِ الْکِتَابِ ، وَمَا تَیَسَّرَ ۔ وَسَأَلْت ابْنَ عَبَّاسٍ ؟ فَقَالَ : ہُوَ إمَامُک ، فَإِنْ شِئْتَ فَأَقِلَّ مِنْہُ ، وَإِنْ شِئْتَ فَأَکْثِر۔",,,3650
3651,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنِ الْوَلِیدِ بْنِ یَحْیَی ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ أَنَّہُ قَرَأَ : {مُدْہَامَّتَانِ} ، ثُمَّ رَکَعَ۔",,,3651
3652,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی سُفْیَانَ السَّعْدِیِّ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ أَبِی سَعِیدٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ صَلاَۃَ لِمَنْ لَمْ یَقْرَأْ فِی کُلِّ رَکْعَۃٍ بِـ : (الْحَمْدُ لِلَّہِ) وَسُورَۃٍ فِی الْفَرِیضَۃِ وَغَیْرِہَا۔\n\n(ترمذی 238۔ ابن ماجہ 839)",,,3652
3653,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ یَزِیدَ الْفَقِیرِ ، عَنْ جَابِرٍ ، قَالَ : کُنَّا نَتَحَدَّثُ ، أَنَّہُ لاَ صَلاَۃَ إِلاَّ بِقِرَائَۃِ فَاتِحَۃِ الْکِتَابِ فَمَا زَادَ۔",,,3653
3654,"حَدَّثَنَا وَکِیعٌ ، عَنِ الحَسَن ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : تُجْزِیئُ فَاتِحَۃُ الْکِتَابِ فِی التَّطَوُّعِ۔",,,3654
3655,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ بْنِ عُمَیْرٍ ، عَنْ أَبِی مَعْمَرٍ ، قَالَ : قلْنَا لِخَبَّابٍ : بِأَیِّ شَیْئٍ کُنْتُمْ تَعْرِفُونَ قِرَائَۃَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الظُّہْرِ وَالْعَصْرِ ؟ قَالَ : بِاضْطِرَابِ لِحْیَتِہِ ، وَقَالَ أَبُو مُعَاوِیَۃَ : لَحْیَیْہِ۔ (بخاری 777۔ ابوداؤد 797)",,,3655
3656,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الزَّعْرَائِ ، عَنْ أَبِی الأَحْوَصِ ، عَمَّنْ سَمِعَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : کَانُوا یَعْرِفُونَ قِرَائَتَہُ فِی الظُّہْرِ وَالْعَصْرِ بِاضْطِرَابِ لِحْیَیْہِ۔ (احمد 5/371)",,,3656
3657,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، عَنِ الْحَسَنِ الْعُرَنِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : مَا أَدْرِی، کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَأُ فِی الظُّہْرِ وَالْعَصْرِ ؟ وَلَکِنَّا نَقْرَأُ۔ (ابوداؤد 805۔ احمد 1/249)",,,3657
3658,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حَبِیبِ بْنِ شَہِیدٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : فِی کُلِّ صَلاَۃٍ أَقْرَأُ ، فَمَا أَعْلَنَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَعْلَنَّا ، وَمَا أَخْفَی أَخْفَیْنَا۔ (بخاری 772۔ مسلم 44)",,,3658
3659,"حَدَّثَنَا جَرِیرُ بْنِ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنْ یَحْیَی بْنِ عَبَّادٍ ، قَالَ : کَانَ خَبَّابُ بْنُ الأَرَتِّ یَجْہَرُ بِالْقِرَائَۃِ فِی الظُّہْرِ وَالْعَصْرِ۔",,,3659
3660,"حَدَّثَنَا وَکِیعٌ، عَنْ کِلاَبِ بْنِ عَمْرٍو، عَنْ عَمِّہِ ، قَالَ: تَعَلَّمْت {إذَا زُلْزِلَتِ الأَرض} خَلْفَ خَبَّابٍ فِی الْعَصْرِ۔",,,3660
3661,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ سَعِیدَ بْنِ الْعَاصِ صَلَّی بِالنَّاسِ الظُّہْرَ أَوِ الْعَصْرَ ، فَجَہَرَ بِالْقِرَائَۃِ فَسَبَّحَ الْقَوْمُ ، فَمَضَی فِی قِرَائَتِہِ ، فَلَمَّا فَرَغَ صَعِدَ الْمِنْبَرَ ، فَخَطَبَ النَّاسَ ، فَقَالَ : فِی کُلِّ صَلاَۃٍ قِرَائَۃٌ ، وَإِنَّ صَلاَۃَ النَّہَارِ تخرس ، وَإِنِّی کَرِہْت أَنْ أَسْکُتَ ، فَلاَ تَرَوْنَ أَنِّی فَعَلْت ذَلِکَ بِدْعَۃً۔",,,3661
3662,"حَدَّثَنَا وَکِیعٌ ، عَنْ حُسَیْنِ بْنِ عُقَیْلٍ ، عَنْ مُحَمَّدِ بْنِ مُزَاحِمٍ ، قَالَ : صَلَّیْت خَلْفَ سَعِیدِ بْنِ جُبَیْرٍ ، فَکَانَ الصَّفُّ الأَوَّلُ یَفْقَہُونَ قِرَائَتَہُ فِی الظُّہْرِ وَالْعَصْرِ۔",,,3662
3663,"حَدَّثَنَا حَمَّادُ بْنُ مَسْعَدَۃَ ، عَنْ حُمَیْدٍ ، قَالَ : صَلَّیْت خَلْفَ أَنَسٍ الظُّہْرَ ، فَقَرَأَ بِـ: {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} وَجَعَلَ یُسْمِعُنَا الآیَۃَ۔",,,3663
3664,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ زَیْدِ بْنِ جُدْعَانَ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : سَمِعْتُ مِنْ عُمَرَ نَغْمَۃً مِنْ (ق) فِی الظُّہْرِ۔",,,3664
3665,حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، عَنْ عَبْدِالرَّحْمَنِ بْنِ الأَسْوَدِ؛ أَنَّ الأَسْوَدَ وَعَلْقَمَۃَ کَانَا یَجْہَرَانِ فِی الظُّہْرِ وَالْعَصْرِ فَلاَ یَسْجُدَانِ۔,,,3665
3666,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ جَابِرٍ، قَالَ: سَأَلْتُ الشَّعْبِیَّ ، وَالْحَکَمَ ، وَسَالِمًا وَالْقَاسِمَ ، وَمُجَاہِدًا، وَعَطَائً ؛ عَنِ الرَّجُلِ یَجْہَرُ فِی الظُّہْرِ أَوَ الْعَصْرِ ؟ قَالُوا : لَیْسَ عَلَیْہِ سَہْوٌ۔",,,3666
3667,حَدَّثَنَا وَکِیعٌ ، عَنْ سَعِیدِ بْنِ بَشِیرٍ ، عَنْ قَتَادَۃَ ؛ أَنَّ أَنَسًا جَہَرَ فِی الظُّہْرِ وَالْعَصْرِ ، فَلَمْ یَسْجُدْ۔,,,3667
3668,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ سُئِلَ عَنِ الرَّجُلِ یَجْہَرُ فِیمَا لاَ یُجْہَرُ فِیہِ ؟ قَالَ : یَسْجُدُ سَجْدَتَیِ السَّہْوِ۔",,,3668
3669,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا جَہَرَ فِیمَا یُخَافَتُ فِیہِ ، أَوْ خَافَتَ فِیمَا یُجْہَرُ فِیہِ ، فَعَلَیْہِ سَجْدَتَا السَّہْوِ۔",,,3669
3670,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، قَالَ : حدَّثَنَا لَیْثٌ ، عَنْ طَاوُوسٍ ، قَالَ : مَنْ فَاتَہُ شَیْئٌ مِنْ صَلاَۃِ الإِمَامِ ، فَإِنْ شَائَ جَہَرَ ، وَإِنْ شَائَ لَمْ یَجْہَرْ۔",,,3670
3671,"حَدَّثَنَا حَفْصٌ ، عَنْ أَبِی الْعُمَیْسِ ، قَالَ : قَالَ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ : اصْنَعُوا مِثْلَ مَا صَنَعَ الإِمَامُ۔",,,3671
3672,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ أَبِی الْعُمَیْسِ ، عَنِ الْمُغِیرَۃِ بْنِ حَکِیمٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ؛نَحْوَہُ۔,,,3672
3673,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو قَالَ : فَاتَتْ عُبَیْدَ بْنَ عُمَیْرٍ رَکْعَۃٌ مِنَ الْمَغْرِبِ ، فَسَمِعْتُہُ یَقْرَأُ : {وَاللَّیْلِ إذَا یَغْشَی}۔",,,3673
3674,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُفَضَّلِ بْنِ مُہَلْہِل ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَسْتَحِبُّونَ لِمَنْ سُبِقَ بِبَعْضِ الصَّلاَۃِ فِی الْفَجْرِ أَوِ الْمَغْرِبِ أَوِ الْعِشَائِ إذَا قَامَ یَقْضِی ، أَنْ یَجْہَرَ بِالْقِرَائَۃِ ، کَیْ یَعْلَمَ مَنْ لاَ یَعْلَمُ أَنَّ الْقِرَائَۃَ فِیمَا یُقْضَی۔",,,3674
3675,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ عَاصِمٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یُصَلِّی الْمَغْرِبَ وَحْدَہُ ، قَالَ : یُسْمِعُ قِرَائَتَہُ أُذُنَیْہِ۔",,,3675
3676,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ أَیُّوبَ بْنِ نَجِیحٍ ، قَالَ : کُنْتُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ ، فَقُمْنَا إلَی الْمَغْرِبِ وَقَدْ سُبِقْنَا بِرَکْعَۃٍ ، فَلَمَّا قَامَ سَعِیدٌ یَقْضِی قَرَأَ بِـ : { أَلْہَاکُمُ التَّکَاثُرُ} ۔",,,3676
3677,حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، عَنْ عَبِیْدَۃَ ؛ فِی الْقِرَائَۃِ فِی صَلاَۃِ النَّہَارِ ، أَسْمِعْ نَفْسَک۔,,,3677
3678,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، عَنْ عَبِیْدَۃَ (ح) وَعَنْ لَیْثٍ ، عَنِ ابْنِ سَابِطٍ ، قَالاَ : أَدْنَی مَا یُقْرَأُ الْقُرْآنُ أَنْ تُسْمِعَ أُذُنَیْک۔",,,3678
3679,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : صَلَّیْت إلَی جَنْبِ عَبْدِ اللہِ بِالنَّہَارِ ، فَلَمْ أَدْرِ أَیَّ شَیْئٍ قَرَأَ ، حَتَّی انْتَہَی إلَی قَوْلِہِ : {رَبِّ زِدْنِی عِلْمًا} فَظَنَنْت أَنَّہُ یَقْرَأُ فِی طَہ۔",,,3679
3680,"حَدَّثَنَا حَفْصٌ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : حدَّثَنِی مَنْ صَلَّی خَلْفَ ابْنِ مَسْعُودٍ ، فَذَکَرَ نَحْوًا مِنْ حَدِیثِ وَکِیعٍ۔",,,3680
3681,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ رَأَی رَجُلاً یَجْہَرُ بِالْقِرَائَۃِ نَہَارًا ، فَدَعَاہُ فَقَالَ : إنَّ صَلاَۃَ النَّہَارِ لاَ یُجْہَرُ فِیہَا ، فَأَسِرَّ قِرَائَتَک۔",,,3681
3682,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، قَالَ : کَانَ ابْنُ سِیرِینَ یَتَطَوَّعُ فَکُنَّا نَسْمَعُ قِرَائَتَہُ ، فَإِذَا قَامَ إلَی الصَّلاَۃِ خَفِیَ عَلَیْنَا مَا یَقْرَأُ۔",,,3682
3683,"حَدَّثَنَا مُعْتَمِرٌ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ مُحَمَّدٌ یَتَطَوَّعُ بِالنَّہَارِ فَیُسْمِعُ۔",,,3683
3684,"حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : صَلاَۃُ النَّہَارِ عَجْمَائُ ، وَصَلاَۃُ اللَّیْلِ تُسْمِعُ أُذُنَیْک۔",,,3684
3685,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ الْکَرِیمِ ، قَالَ : صَلَّی رَجُلٌ إلَی جَنْبِ أَبِی عُبَیْدَۃَ فَجَہَرَ بِالْقِرَائَۃِ ، فَقَالَ لَہُ : إنَّ صَلاَۃَ النَّہَارِ عَجْمَائُ ، وَصَلاَۃَ اللَّیْلِ تُسْمِعُ أُذُنَیْک۔",,,3685
3686,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ یَجْہَرَ بِالنَّہَارِ فِی التَّطَوُّعِ إذَا کَانَ لاَ یُؤْذِی أَحَدًا۔",,,3686
3687,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : قُمْتُ إلَی جَنْبِ عَبْدِ اللہِ وَہُوَ یُصَلِّی فِی الْمَسْجِدِ ، فَمَا عَلِمْت أَنَّہُ یَقْرَأُ حَتَّی سَمِعْتُہ یَقُولُ: {رَبِّ زِدْنِی عِلْمًا} ، فَعَلِمْت أَنَّہُ یَقْرَأُ فِی سُورَۃِ طَہ۔",,,3687
3688,حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ صَلَّی فَرَفَعَ صَوْتَہُ ، فَأَرْسَلَ إلَیْہِ سَعِیدٌ ، أَفَتَّانٌ أَنْتَ أَیُّہَا الرَّجُلُ۔,,,3688
3689,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : قالُوا : یَا رَسُولَ اللہِ ، إنَّ ہَاہُنَا قومًا یَجْہَرُونَ بِالْقِرَائَۃِ بِالنَّہَارِ ؟ فَقَالَ : اُرْمُوہُمْ بِالْبَعْرِ۔ (طبرانی 3896)",,,3689
3690,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الْجُرَیرِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أبی عَاصِمِ ، عَنِ ابْنِ أَبِی لَیْلَی ، قَالَ : إذَا قَرَأْتَ فَأَسْمِع أُذُنَیْک ، فَإِنَّ الْقَلْبَ عَدْلٌ بَیْنَ اللِّسَانِ وَالأُذُنِ۔",,,3690
3691,"حَدَّثَنَا مَخْلَدُ بْنُ یَزِیدَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنْ حَکِیمِ بْنِ عِقَالٍ ؛ أَنَّہُ نَہَی عَنْ رَفْعِ الصَّوْتِ بِالْقِرَائَۃِ فِی النَّہَارِ ، وَقَالَ : یَرْفَعُ بِاللَّیْلِ إِنْ شَائَ۔",,,3691
3692,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ یَحْیَی بْنِ جَعْدۃ ، عَنْ أُمِّ ہَانِیئٍ ، قَالَتْ : کُنْتُ أَسْمَعُ قِرَائَۃَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَنَا عَلَی عَریشِی۔ (ترمذی 318۔ احمد 6/341)",,,3692
3693,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : قالُوا لَہُ : کَیْفَ کَانَتْ قِرَائَۃُ عَبْدِ اللہِ بِاللَّیْلِ ؟ فَقَالَ : کَانَ یُسْمِعُ أَحْیَانًا آلَ عُتْبَۃَ ، قَالَ : وَکَانُوا فِی حُجْرَۃٍ بَیْنَ یَدَیْہِ ، وَکَانَ عَلْقَمَۃُ مِمَّنْ یُبَایِتُہُ۔",,,3693
3694,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : بِتُّ عِنْدَ عَبْدِ اللہِ ذَاتَ لَیْلَۃٍ ، فَقَالُوا لَہُ : کَیْفَ کَانَتْ قِرَائَتُہُ ؟ قَالَ : کَانَ یُسْمِعُ أَہْلَ الدَّارِ۔",,,3694
3695,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ یَحْیَی بْنِ حَبَّانَ ، قَالَ : کَانَ رَجُلٌ إذَا قَرَأَ جَہَرَ بِقِرَائَتِہِ ، فَفَقَدَہُ مُعَاذٌ ، فَقَالَ : أَیْنَ الَّذِی کَانَ یُوقِظُ الْوَسْنَانَ ؟ وَیَزْجُرُ ، أَوْ یَطْرُدُ ، الشَّیْطَانَ۔",,,3695
3696,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی بَکْرِ بْنِ عَمْرٍو قَالَ : بَاتَتْ بِنَا عَمْرَۃُ لَیْلَۃً ، فَقُمْت أُصَلِّی فَأَخْفَیْتُ صَوْتِی ، فَقَالَتْ : أَلاَ تَجْہَرُ بِقِرَائَتِکَ ؟ فَمَا کَانَ یُوقِظُنَا إِلاَّ صَوْتُ مُعَاذٍ الْقَارِیِٔ ، وَأَفْلَحَ مَوْلَی أَبِی أَیُّوبَ۔",,,3696
3697,حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ أَبِی حُرَّۃَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُصَلِّی مِنَ اللَّیْلِ ، فَیُسْمِعُ أَہْلَ دَارِہِ۔,,,3697
3698,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : صَلاَۃُ اللَّیْلِ ، تُسْمِعُ أُذُنَیْک۔",,,3698
3699,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَلْقَمَۃَ ، قَالَ : صَلَّیْتُ مَعَ عَبْدِ اللہِ لَیْلَۃً کُلَّہَا ، فَکَانَ یَرْفَعُ صَوْتَہُ ، یَقْرَأُ قِرَائَۃً یُسْمِعُ أَہْلَ الْمَسْجِدِ ، یُرَتِّلُ وَلاَ یُرَجِّعُ۔",,,3699
3700,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، وَالْحَسَنُ بْنُ عُبَیْدِ اللہِ ، عَنْ جَامِعِ بْنِ شَدَّادٍ ، عَنِ الأَسْوَدِ بْنِ ہِلاَلٍ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ أَسْمَعَ أُذُنَیْہِ فَلَمْ یُخَافِتْ۔",,,3700
3701,"حَدَّثَنَا حَفْصٌ ، عَنْ عِمْرَانَ بْنِ زَائِدَۃَ بْنِ نَشِیطٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی خَالِدٍ الْوَالِبِیِّ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ: کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إذَا قَامَ مِنَ اللَّیْلِ یَخْفِضُ طَوْرًا ، وَیَرْفَعُ طَوْرًا۔ \n\n(ابوداؤد 1322۔ ابن حبان 2603)",,,3701
3702,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنِ الْمَعْرُورِ بْنِ سُوَیْد ، قَالَ : خَرَجْنَا مَعَ عُمَرَ حُجَّاجًا ، فَصَلَّی بِنَا الْفَجْرَ فَقَرَأ بِـ : (أَلَمْ تَرَ) ، وَ(لإِیلاَفِ)۔",,,3702
3703,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ غِیلاَنَ بْنِ جَامِعٍ الْمُحَارِبِیِّ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : صَلَّی بِنَا عُمَرُ الْفَجْرَ فِی السَّفَرِ ، فَقَرَأَ بِـ : {قُلْ یَا أَیُّہَا الْکَافِرُونَ} ، وَ {قُلْ ہُوَ اللَّہُ أَحَدٌ}۔",,,3703
3704,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقْرَؤُونَ فِی السَّفَرِ بِالسُّوَرِ الْقِصَارِ۔",,,3704
3705,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ دَاوُدَ ، قَالَ : خَرَجْت مَعَ أَنَسٍ ، فَکَانَ یَقْرَأُ بِنَا فِی الْفَجْرِ بِـ: {سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی} وَأَشْبَاہِہَا۔",,,3705
3706,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الْعَلاَئِ ، عَنْ مُحَمَّدِ بْنِ الْحَکَمِ ، عَنْ أَبِی وَائِلٍ ، قَالَ : صَلَّی بِنَا ابْنُ مَسْعُودٍ الْفَجْرَ فِی السَّفَرِ ، فَقَرَأَ بِآخِرِ بَنِی إسْرَائِیلَ : {الْحَمْدُ لِلَّہِ الَّذِی لَمْ یَتَّخِذْ وَلَدًا} ثُمَّ رَکَعَ۔",,,3706
3707,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ ، قَالَ : حَدَّثَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ عِمْرَانَ بْنِ أَبِی الْجَعْدِ ، قَالَ : کُنْتُ مَعَ ابْنِ عُمَرَ فِی سَفَرٍ فَصَلَّی بِنَا الْفَجْرَ ، فَقَرَأَ بِنَا : {إذَا الشَّمْسُ کُوِّرَتْ}۔",,,3707
3708,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ الْغَازِ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، عَنْ عُقْبَۃَ بْنِ عَامِرٍ الْجُہَنِیِّ ، قَالَ : کُنْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَفَرٍ ، فَلَمَّا طَلَعَ الْفَجْرُ أَذَّنَ وَأَقَامَ ، ثُمَّ أَقَامَنِی عَنْ یَمِینِہِ ، ثُمَّ قَرَأَ بِالْمُعَوِّذَتَیْنِ، فَلَمَّا انْصَرَفَ ، قَالَ : کَیْفَ رَأَیْتَ ؟ قُلْتُ : قَدْ رَأَیْت یَا رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ: فَاقْرَأْ بِہِمَا کُلَّمَا نِمْتَ وَکَمَا قُمْتَ۔ (ابوداؤد 1457۔ احمد 4/144)",,,3708
3709,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَقْرَأُ فِی الرَّکْعَۃِ ، بِعَشْرِ سُوَرٍ وَأَکْثَرَ وَأَقَلَّ۔,,,3709
3710,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنِ ابْنِ سِیرِینَ ، قَالَتْ نَائِلَۃُ ابْنَۃُ الْفَرَافِصَۃِ الْکَلْبِیَّۃُ حَیثُ دَخَلُوا عَلَی عُثْمَانَ فَقَتَلُوہُ ، فَقَالَتْ : إِنْ تَقْتُلُوہُ ، أَوْ تَدَعُوہُ فَقَدْ کَانَ یُحْیِی اللَّیْلَ بِرَکْعَۃٍ یَجْمَعُ فِیہَا الْقُرْآنَ۔",,,3710
3711,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ تَمِیمًا الدَّارِیَّ کَانَ یَقْرَأُ الْقُرْآنَ کُلَّہُ فِی رَکْعَۃٍ۔,,,3711
3712,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إنِّی لأَقْرَأُ السُّوَرَ مِنَ الْمُفَصَّلِ فِی رَکْعَۃٍ۔",,,3712
3713,"حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ بْنِ أَبِی إِسْحَاقَ ، قَالَ : حدَّثَنَا بَکْرُ بْنُ مَاعِزٍ ، عَنِ الرَّبِیعِ بْنِ خُثَیْمٍ ؛ یَقْرَأُ بالسُّورَتَیْنِ وَالثَّلاَثَ فِی الرَّکْعَۃِ۔",,,3713
3714,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حَدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَقْرُنُ بَیْنَ السُّورَتَیْنِ فِی رَکْعَۃٍ مِنَ الصَّلاَۃِ الْمَکْتُوبَۃِ۔",,,3714
3715,"حَدَّثَنَا یَعْلَی بْنُ عُبَیْدٍ، قَالَ: حدَّثَنَا عَبْدُ الْمَلِکِ بْنُ أَبِی سُلَیْمَانَ ، عَنْ عَطَائٍ؛ فِی الرَّجُلِ یُصَلِّی الْمَکْتُوبَۃَ فَیَقْرَأُ بِسُورَتَیْنِ فِی رَکْعَۃٍ ، أَوْ بِسُورَۃٍ فِی رَکْعَتَیْنِ ؟ قَالَ : لاَ بَأْسَ۔",,,3715
3716,"حَدَّثَنَا یَعْلَی ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ فِی الرَّجُلِ یَجْمَعُ بَیْنَ السُّورَتَیْنِ فِی رَکْعَۃٍ ؟ قَالَ : أَمَّا مَا کَانَ مِنَ الْمِئیْنَ فَارْکَعْ بِکُلِّ سُورَۃٍ ، وَأَمَّا مَا کَانَ مِنَ الْمَثَانِی وَالْمُفَصَّلِ فَاقْرُنْ إِنْ شِئْت۔",,,3716
3717,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ؛ أَنَّہُ کَانَ یَقْرُن السُّورَتَیْنِ فِی رَکْعَۃٍ۔,,,3717
3718,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنِ الْقَاسِمِ وَسَالِمٍ ، قَالاَ : اقْرُنْ کَمْ شِئْتَ۔",,,3718
3719,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، وَوَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ مَعْبَدِ بْنِ خَالِدٍ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالسَّبْعِ الطِّوَالِ فِی رَکْعَۃٍ ، إِلاَّ أَنَّ وَکِیعًا ، قَالَ : قَرَأَ۔",,,3719
3720,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْن عُثْمَانَ ، قَالَ : قمْتُ خَلْفَ الْمَقَامِ أُصَلِّی ، وَأَنَا أُرِیدُ أَنْ لاَ یَغْلِبَنِی عَلَیْہِ أَحَدٌ تِلْکَ اللَّیْلَۃَ ، قَالَ : فَإِذَا رَجُلٌ یَغْمِزُنِی مِنْ خَلْفِی ، فَلَمْ أَلْتَفِتْ ، ثُمَّ غَمَزَنِی فَالْتَفَتُّ ، فَإِذَا عُثْمَانَ بْنُ عَفَّانَ ،فَتَنَحَّیْتُ وَتَقَدَّمَ ، فَقَرَأَ الْقُرْآنَ فِی رَکْعَۃٍ ، ثُمَّ انْصَرَفَ۔",,,3720
3721,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ وِقَائٍ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یَجْمَعُ بَیْنَ سُورَتَیْنِ فِی کُلِّ رَکْعَۃٍ فِی الْفَرِیضَۃِ۔",,,3721
3722,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا کَہْمَسٌ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ الْعُقَیْلِیِّ ، قَالَ : قُلْتُ لِعَائِشَۃَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَجْمَعُ بَیْنَ السُّورَتَیْنِ فِی رَکْعَۃٍ ؟ قَالَتْ : نَعَمَ ،الْمُفَصَّلَ۔\n\n(ابوداؤد 1286۔ احمد 6/218)",,,3722
3723,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا الأَعْمَشُ، عَنْ إِبْرَاہِیمَ، عَن عَلْقَمَۃَ؛ أَنَّہُ کَانَ یَقْرَأُ فِی الْفَجْرِ فِی الرَّکْعَۃِ الأُولَی بـ: (حم) الدُّخَانِ، وَ (الطُّورِ)، وَالجن، وَیَقْرَأُ فِی الثَّانِیَۃِ بِآخِرِ الْبَقَرَۃِ وَآخِرِ آلِ عِمْرَانَ، وَبِالسُّورَۃِ الْقَصِیرَۃِ۔",,,3723
3724,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنِ الْمُسْتَوْرِدِ بْنِ الأَحْنَفِ ، عَنْ صِلَۃَ ، عَنْ حُذَیْفَۃَ ، قَالَ : صَلَّیْت مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَافْتَتَحَ الْبَقَرَۃَ ،فَقُلْت : یَخْتِمُہَا فَیَرْکَعُ بِہَا، ثُمَّ افْتَتَحَ آلَ عِمْرَانَ ، فَقُلْتُ : یَخْتِمُہَا فَیَرْکَعُ بِہَا ، ثُمَّ افْتَتَحَ النِّسَائَ ، فَقُلْتُ : یَرْکَعُ بِہَا ، فَقَرَأَ حَتَّی خَتَمَہَا۔",,,3724
3725,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْمَرِ بْنِ مُوسَی ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : لاَ یَقْرُنُ بَیْنَ سُورَتَیْنِ فِی کُلِّ رَکْعَۃٍ۔",,,3725
3726,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ ، قَالَ : کَانَ أَبُو بَکْرِ بْنُ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ لاَ یَجْمَعُ بَیْنَ سُورَتَیْنِ فِی رَکْعَۃٍ ، وَلاَ یُجَاوِزُ سُورَۃً إذَا خَتَمَہَا حَتَّی یَرْکَعَ۔",,,3726
3727,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ کَانَ لاَ یَقْرُن بَیْنَ سُورَتَیْنِ فِی رَکْعَۃٍ۔,,,3727
3728,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عِیسَی ، عَنِ الشَّعْبِیِّ ، عَنْ زَیْدِ بْنِ خَالِدٍ الْجُہَنِیِّ ، قَالَ : مَا أُحِبُّ أَنِّی قَرَنْتُ سُورَتَیْنِ فِی رَکْعَۃٍ وَلَوْ أَنَّ لِی حُمْرَ النَّعَمِ۔",,,3728
3729,حَدَّثَنَا وَکِیعٌ ، عَنْ عِیسَی ، عَنِ الشَّعْبِیِّ ، عَنْ زَیْدِ بْنِ خَالِدٍ ؛ مِثْلَہُ۔,,,3729
3730,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَاصِمٍ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : حدَّثَنِی مَنْ سَمِعَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : أَعْطِ کُلَّ سُورَۃٍ حَظَّہَا مِنَ الرُّکُوعِ وَالسُّجُودِ۔ (بیہقی 10۔ احمد 5/59)",,,3730
3731,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنِی إسْرَائِیلُ ، عَنْ أَبِی حَصِینٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : أَعْطِ کُلَّ سُورَۃٍ حَقَّہَا مِنَ الرُّکُوعِ وَالسُّجُودِ۔",,,3731
3732,حدَّثَنَا عَبْدَۃُ ، وَوَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ أَبِی أَیُّوبَ ، أَوْ زَیْدِ بْنِ ثَابِتٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ فِی الْمَغْرِبِ بِالأَعْرَافِ فِی رَکْعَتَیْنِ۔,,,3732
3733,حَدَّثَنَا عَبْدَۃُ ، وَوَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَا بَکْرٍ قَرَأَ فِی الْمَغْرِبِ بِالأَعْرَافِ فِی رَکْعَتَیْنِ,,,3733
3734,حَدَّثَنَا عَبْدَۃُ ، وَوَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَا بَکْرٍ قَرَأَ بِالْبَقَرَۃِ فِی الْفَجْرِ رَکْعَتَیْنِ۔,,,3734
3735,حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ یَحْیَی بْنِ عَبْدِ الرَّحْمَنِ بْنِ حَاطِبٍ ؛ أَنَّ عُمَرَ قَرَأَ بِآلِ عِمْرَانَ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ مِنَ الْعِشَائِ قَطََّعَہَا ، یَعْنِی فِیہِمَا۔,,,3735
3736,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عُمَرَ بْنِ یَعْلَی ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یَقْرَأُ فِی الْفَجْرِ بِبَنِی إسْرَائِیلَ فِی الرَّکْعَتَیْنِ۔,,,3736
3737,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، قَالَ : صَلَّیْت خَلْفَ سَعِیدِ بْنِ جُبَیْرٍ الْفَجْرَ ، فَقَرَأَ بِـ : (حم) الْمُؤْمِنِ ، فَلَمَّا بَلَغَ (بِالْعَشِیِّ وَالإِبْکَارِ) رَکَعَ ، ثُمَّ قَامَ فِی الثَّانِیَۃِ فَقَرَأَ بِبَقِیَّۃِ السُّورَۃِ ، ثُمَّ رَکَعَ ، وَلَمْ یَقْنُتْ۔",,,3737
3738,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ یَحْیَی ، قَالَ : کَانَ یَقْسِمُ السُّورَۃَ فِی الرَّکْعَتَیْنِ فِی الْفَجْرِ۔",,,3738
3739,حَدَّثَنَا عَبْدَۃُ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَقْسِمُ السُّورَۃَ فِی رَکْعَتَیْنِ۔,,,3739
3740,"حَدَّثَنَا وَکِیعٌ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ، عَنْ عَامِرٍ ، قَالَ : لاَ بَأْسَ أَنْ یَقْسِمَ السُّورَۃَ فِی رَکْعَتَیْنِ۔",,,3740
3741,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ یَحْیَی ، قَالَ : یقْسِمُ سُورَۃ فِی رَکْعَتَیِّ الْفَجْرِ۔",,,3741
3742,"حَدَّثَنَا یَعْلَی ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ أَنْ تُقْسَمَ السُّورَۃُ فِی رَکْعَتَیْنِ۔",,,3742
3743,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : نُبِّئْتُ أَنَّ ابْنَ مَسْعُودٍ کَانَ یَقْرَأُ فِی الظُّہْرِ وَالْعَصْرِ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ ، وَمَا تَیَسَّرَ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3743
3744,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَتَبَ عُمَرُ إلَی شُرَیْحٍ ، یَقْرَأُ فِی الأُولَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3744
3745,"حَدَّثَنَا أَبُو عَامِرٍ الْعَقَدِیُّ ، قَالَ : حدَّثَنَا عَلِیُّ بْنُ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ بْنِ الْحَارِثِ ، قَالَ : سَمِعْتُ ہِشَامَ بْنَ إسْمَاعِیلَ عَلَی مِنْبَرِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : کَانَ أَبُو الدَّرْدَائِ یَقُولُ : اقْرَؤُوا فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ مِنْ صَلاَۃِ الظُّہْرِ بِأُمِّ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ ، وَاقْرَؤُوا فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ مِنَ الْعَصْرِ بِأُمِّ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ ، وَفِی الرَّکْعَۃِ الآخِرَۃِ مِنَ الْمَغْرِبِ بِأُمِّ الْکِتَابِ ، وَفِی الرَّکْعَتَیْنِ مِنَ الْعِشَائِ بِأُمِّ الْکِتَابِ۔",,,3745
3746,"حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَکِ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : حُدِّثْت أَنَّ أَبَا الدَّرْدَائِ کَانَ یَقُولُ : اقْرَؤُوا فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ مِنَ الظُّہْرِ وَالْعَصْرِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ ، وَفِی الرَّکْعَۃِ الآخِرَۃِ مِنْ صَلاَۃِ الْمَغْرِبِ ، وَفِی الرَّکْعَتَیْنِ الأُخْرَیَیْنِ مِنَ الْعِشَائِ بِأُمِّ الْکِتَابِ۔",,,3746
3747,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ عَمِّہِ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی رَافِعٍ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یَقُولُ : یَقْرَأُ الإِمَامُ وَمَنْ خَلْفَہُ فِی الظُّہْرِ وَالْعَصْرِ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3747
3748,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، وَوَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ رَجَائِ بْنِ حَیْوَۃَ ، عَنْ مَحْمُودِ بْنِ رَبِیعِ ، عَنِ الصُّنَابِحِیِّ ، قَالَ : صَلَّیْت مَعَ أَبِی بَکْرٍ الْمَغْرِبَ فَدَنَوْت مِنْہُ حَتَّی مَسَّتْ ثِیَابِی ثِیَابَہُ ، أَوْ یَدِی ثِیَابَہُ ، شَکَّ ابْنُ مُبَارَکٍ ، فَقَرَأَ فِی الرَّکْعَۃِ الثَّالِثَۃِ بِفَاتِحَۃِ الْکِتَابِ ، وَقَالَ : {رَبَّنَا لاَ تُزِغْ قُلُوبَنَا بَعْدَ إذْ ہَدَیْتنَا}۔",,,3748
3749,"حَدَّثَنَا وَکِیعٌ، عَنْ مِسْعَرٍ، عَنْ یَزِیدَ الْفَقِیرِ، عَنْ جَابِرٍ، قَالَ: یَقْرَأُ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ ، کُنَّا نَتَحَدَّثُ أَنَّہُ لاَ صَلاَۃَ إِلاَّ بِقِرَائَۃِ فَاتِحَۃِ الْکِتَابِ فَمَا زَادَ۔",,,3749
3750,حَدَّثَنَا عَبْدُ السَّلاَمِ ، عَنْ لَیْثٍ ، عَنْ شَہْرٍ ، عَنْ أَبِی مَالِکٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الظُّہْرِ وَالْعَصْرِ فِی کُلِّہِنَّ۔ (طبرانی 2437),,,3750
3751,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ یَقْرَأُ فِی الأَرْبَعِ ، یُسَوِّی بَیْنَہُنَّ۔",,,3751
3752,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یَحْیَی بْنِ أَبِی إِسْحَاقَ ، قَالَ : حدَّثَنِی عُمَرُ بْنُ أَبِی سُحَیْمٍ ، قَالَ : کَانَ عَبْدُ اللہِ بْنُ مُغَفَّلٍ یَأْمُرُ بِالصَّلاَۃِ الَّتِی لاَ یَجْہَرُ فِیہَا الإِمَامُ أَنْ یَقْرَأَ فِی الصَّلاَۃِ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3752
3753,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَقُولُونَ : اقْرَأْ فِی الأُولَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ ، وَفِی الآخِرَۃِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3753
3754,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، وَوَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : اقْرَأْ فِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3754
3755,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ وَالشَّیْبَانِیُّ ، عَنِ الشَّعْبِیِّ (ح) وَحَجَّاجٌ ، عَنْ عَطَائٍ (ح) وَمَنْصُورٌ ، عَنِ الْحَسَنِ ، أَنَّہُمْ قَالُوا : اقْرَأْ فِی الرَّکْعَتَیْنِ ، یَعْنِی الأُخْرَیَیْنِ ، مِنَ الظُّہْرِ وَالْعَصْرِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3755
3756,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا لَمْ یَقْرَأْ فِی رَکْعَۃٍ بِفَاتِحَۃِ الْکِتَابِ ، فَإِنَّہُ یَقْضِی تِلْکَ الرَّکْعَۃَ۔",,,3756
3757,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ مُحَمَّدٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ تَقْرَأُ فِی صَلاَۃِ النَّہَارِ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ۔,,,3757
3758,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ سَلَمَۃَ ، عَنِ الضَّحَّاکِ ، قَالَ : اقْرَأْ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3758
3759,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حُمَیْدِ بْنِ سَلْمَانَ ، عَنْ مُجَاہِدٍ ، قَالَ : سَمِعْتُہُ یَقْرَأُ فِی الأُخْرَیَیْنِ مِنَ الظُّہْرِ وَالْعَصْرِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3759
3760,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سَلَمَۃَ بْنِ نُبَیْطٍ ، عَنِ الضَّحَّاکِ ؛ مِثْلَہُ۔,,,3760
3761,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ ، عَنِ الشَّعْبِیِّ ، قَالَ : اقْرَأْ فِی جَمِیعِہِنَّ۔",,,3761
3762,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہَمَّامٍ ، وَأَبَانُ الْعَطَّارُ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقْرَأُ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ۔ (بخاری 776۔ ابوداؤد 795),,,3762
3763,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَلِیٍّ ، وَعَبْدِ اللہِ ، أَنَّہُمَا قَالاَ : اقْرَأْ فِی الأُولَیَیْنِ ، وَسَبِّحْ فِی الأُخْرَیَیْنِ۔",,,3763
3764,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ قَالَ : یَقْرَأُ فِی الأُولَیَیْنِ ، وَیُسَبِّحُ فِی الأُخْرَیَیْنِ۔",,,3764
3765,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : مَا یُفْعَلُ فِی الرَّکْعَتَیْنِ الأُخْرَیَیْنِ مِنَ الصَلاَۃ ؟ قَالَ : سَبِّحْ ، وَاحْمَدِ اللَّہَ ، وَکَبِّر۔",,,3765
3766,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَبِّحْ فِی الأُخْرَیَیْنِ وَکَبِّرْ۔",,,3766
3767,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنِ ابْنِ الأَسْوَدِ ، قَالَ : یَقْرَأُ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ یُسَبِّحُ وَیُکَبِّرُ۔",,,3767
3768,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : یُسَبِّحُ وَیُکَبِّرُ فِی الأُخْرَیَیْنِ تَسْبِیحَتَیْنِ۔",,,3768
3769,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الشَّیْبَانِیُّ ، عَنْ جَوَّاب بْنِ عُبَیْدِ اللہِ التَّیْمِیِّ ، قَالَ : حَدَّثَنَا یَزِیدُ بْنُ شَرِیکٍ التَّیْمِیُّ أَبُو إبْرَاہِیمَ ، قَالَ : سَأَلْتُ عُمَرَ بْنَ الْخَطَّابِ عَنِ الْقِرَائَۃِ خَلْفَ الإِمَامِ ؟ فَقَالَ لِی : اقْرَأْ ، قُلْتُ : وَإِنْ کُنْتُ خَلْفَک ؟ قَالَ : وَإِنْ کُنْتَ خَلْفِی ، قَلْت : وَإِنْ قَرَأْتَ ؟ قَالَ : وَإِنْ قَرَأْتُ۔",,,3769
3770,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، عَنْ مُجَاہِدٍ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ عَمْرِو بْنِ الْعَاصِ یَقْرَأُ خَلْفَ الإِمَامِ فِی صَلاَۃِ الظُّہْرِ مِنْ سُورَۃِ مَرْیَمَ۔",,,3770
3771,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، قَالَ : صَلَّیْتُ إلَی جَنْبِ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، قَالَ : فَسَمِعْتُہُ یَقْرَأُ خَلْفَ الإِمَامِ ، قَالَ : فَلَقِیت مُجَاہِدًا فَذَکَرْت لَہُ ذَلِکَ ، قَالَ : فَقَالَ مُجَاہِدٌ : سَمِعْت عَبْدَ اللہِ بْنَ عَمْرٍو یَقْرَأُ خَلْفَ الإِمَامِ۔",,,3771
3772,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ ثَرْوَانَ ، عَنْ ہُذَیْلٍ ، عَنْ عَبْدِ اللہِ بْنِ مَسْعُودٍ ؛ أنَّہُ قَرَأَ فِی الْعَصْرِ خَلْفَ الإِمَامِ فِی الرَّکْعَتَیْنِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ۔,,,3772
3773,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَشْعَثَ بْنِ سُلَیْم ، عَنْ أَبِی مَرْیَمَ الأَسَدِیِّ ، عَنْ عَبْدِ اللہِ ، قَالَ : صَلَّیْت إلَی جَنْبِہِ فَسَمِعْتُہُ یَقْرَأُ خَلْفَ بَعْضِ الأُمَرَائِ فِی الظُّہْرِ وَالْعَصْرِ۔",,,3773
3774,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی رَافِعٍ ؛ أَنَّ عَلِیًّا کَانَ یَقُولُ : اقْرَأْ فِی الظُّہْرِ وَالْعَصْرِ خَلْفَ الإِمَامِ فِی کُلِّ رَکْعَۃٍ بِأُمِّ الْکِتَابِ وَسُورَۃٍ۔",,,3774
3775,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَشْعَثَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ؛ أَنَّ عَلِیًّا کَانَ یَأْمُرُ بِالْقِرَائَۃِ خَلْفَ الإِمَامِ۔,,,3775
3776,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : لاَ تَدَعْ أَنْ تَقْرَأَ خَلْفَ الإِمَامِ بِفَاتِحَۃِ الْکِتَابِ جَہَرَ ، أَوْ لَمْ یَجْہَرْ۔",,,3776
3777,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا مُحَمَّدُ بْنُ إِسْحَاقَ ، عَنْ مَکْحُولٍ ، عَنْ مَحْمُودِ بْنِ الرَّبِیعِ ، عَنْ عُبَادَۃَ بْنِ الصَّامِتِ ، قَالَ : صَلَّی بِنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃَ الْعِشَائِ فَثَقُلَتْ عَلَیْہِ الْقِرَائَۃُ ، فَلَمَّا انْصَرَفَ قَالَ : لَعَلَّکُمْ تَقْرَؤُونَ خَلْفَ إمَامِکُمْ ؟ قَالَ : قُلْنَا : أَجَلْ یَا رَسُولَ اللہِ إنَّا لَنَفْعَلُ ، قَالَ : فَلاَ تَفْعَلُوا إِلاَّ بِأُمِّ الْقُرْآنِ ، فَإِنَّہُ لاَ صَلاَۃَ إِلاَّ بِہَا۔",,,3777
3778,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لأَصْحَابِہِ : ہَلْ تَقْرَؤُونَ خَلْفَ إمَامِکُمْ ؟ فَقَالَ بَعْضٌ : نَعَمْ ، وَقَالَ بَعْضٌ : لاَ ، فَقَالَ : إِنْ کُنْتُمْ لاَ بُدَّ فَاعِلِینَ ، فَلْیَقْرَأْ أَحَدُکُمْ فَاتِحَۃَ الْکِتَابِ فِی نَفْسِہِ۔",,,3778
3779,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ مُحَمَّدِ بْنِ أَبِی عَائِشَۃَ ، عَنْ رَجُلٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ بِنَحْوٍ مِنْ حَدِیثِ ہُشَیْمٍ۔\n\n(احمد 4/236۔ عبدالرزاق 2766)",,,3779
3780,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی الْفَیْضِ ، قَالَ : سَمِعْتُ أَبَا شَیْبَۃَ الْمَہْرِیَّ یُحَدِّثُ ، عَنْ مُعَاذٍ ؛ أَنَّہُ قَالَ؛ فِی الرَّجُلِ یُصَلِّی خَلْفَ الإِمَامِ : إذَا کَانَ یَسْمَعُ قِرَائَتَہُ قَرَأَ : {قُلْ ہُوَ اللَّہُ أَحَدٌ} ، وَ{قُلْ أَعُوذُ بِرَبِّ النَّاسِ} ، وَ{قُلْ أَعُوذُ بِرَبِّ الْفَلَقِ} قَالَ شُعْبَۃُ : أَوْ نَحْوَہَا ، وَإِذَا کَانَ لاَ یَسْمَعُ الْقِرَائَۃَ فَلْیَقْرَأْ ، وَلاَ یُؤْذِ مَنْ عَنْ یَمِینِہِ ، وَمَنْ عَنْ شِمَالِہِ۔",,,3780
3781,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَنْتَ بِالْخِیَارِ ، إِنْ شِئْتَ فَاقْرَأْ ، وَإِنْ شِئْتَ فَاعْتَدَّ۔",,,3781
3782,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إذَا لَمْ تَسْمَعْ قِرَائَۃَ الإِمَامِ ، فَاقْرَأْ فِی نَفْسِکَ إِنْ شِئْتَ۔",,,3782
3783,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ وَیُونُسُ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : اقْرَأْ خَلْفَ الإِمَامِ فِی کُلِّ رَکْعَۃٍ بِفَاتِحَۃِ الْکِتَابِ فِی نَفْسِک۔",,,3783
3784,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الشَّیْبَانِیُّ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَانَ یَقُولُ : اقْرَأْ خَلْفَ الإِمَامِ فِی الظُّہْرِ وَالْعَصْرِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3784
3785,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا إسْمَاعِیلُ بْنُ سَالِمٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : سَمِعْتُہُ یَقُولُ : الْقِرَائَۃُ خَلْفَ الإِمَامِ فِی الظُّہْرِ وَالْعَصْرِ نُورٌ لِلصَّلاَۃِ۔",,,3785
3786,"حَدَّثَنَا عَبَّادٌ ، عَنْ سَعِیدِ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ قَالَ : یَقْرَأُ الإِمَامُ وَمَنْ خَلْفَہُ فِی الظُّہْرِ وَالْعَصْرِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3786
3787,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ، قَالَ : اقْرَأْ خَلْفَ الإِمَامِ فِیمَا لَمْ یَجْہَرْ ، فِی الأُولَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ وَسُورَۃٍ ، وَفِی الأُخْرَیَیْنِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3787
3788,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : اُسْکُتُوا فِیمَا یَجْہَرُ ، وَاقْرَؤُوا فِیمَا لاَ یَجْہَرُ۔",,,3788
3789,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یَحْیَی بْنِ أَبِی إِسْحَاقَ ، قَالَ : صَلَّیْت الْمَغْرِبَ وَالْحَکَمُ بْنُ أَیُّوبَ إمَامُنَا ، وَأَبُو مَلِیحٍ إلَی جَنْبِ ابْنِ أُسَامَۃَ ، فَسَمِعْتُہُ یَقْرَأُ بِفَاتِحَۃِ الْکِتَابِ ، فَلَمَّا سَلَّمَ الإِمَامُ قُلْتُ لأَبِی مَلِیحٍ : تَقْرَأُ خَلْفَ الإِمَامِ وَہُوَ یَقْرَأُ ؟ ، قَالَ : سَمِعْتَ شَیْئًا ؟ قُلتُ : نَعَمْ ، قَالَ : نَعَمْ۔",,,3789
3790,حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ ثَعْلَبَۃَ ، عَنْ أَنَسٍ ؛ أَنَّہُ قَالَ فِی الْقِرَائَۃِ خَلْفَ الإِمَامِ التَّسْبِیحُ۔,,,3790
3791,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ رَجَائِ بْنِ حَیْوَۃَ ، عَنْ مَحْمُودِ بْنِ رَبِیعٍ ، قَالَ : صَلَّیْت صَلاَۃً وَإِلَی جَنْبِی عُبَادَۃُ بْنُ الصَّامِتِ ، قَالَ : فَقَرَأَ بِفَاتِحَۃِ الْکِتَابِ ، قَالَ : فَقُلْتُ لَہُ : یَا أَبَا الْوَلِیدِ ، أَلَمْ أَسْمَعْک تَقْرَأُ بِفَاتِحَۃِ الْکِتَابِ ؟ قَالَ : أَجَلْ ، إِنَّہُ لاَ صَلاَۃَ إِلاَّ بِہَا۔",,,3791
3792,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : إِنْ قَرَأْتَ خَلْفَ الإِمَامِ فَحَسَنٌ ، وَإِنْ لَمْ تَقْرَأْ أَجْزَأَکَ قِرَائَۃُ الإِمَامِ۔",,,3792
3793,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الْعَیْزَارِ بْنِ حُرَیْثٍ الْعَبْدِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : اقْرَأْ خَلْفَ الإِمَامِ بِفَاتِحَۃِ الْکِتَابِ۔",,,3793
3794,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مَالِکُ بْنُ مِغْوَلٍ ، قَالَ : سَمِعْتُ الشَّعْبِیَّ یُحَسِّنُ الْقِرَائَۃَ خَلْفَ الإِمَامِ۔",,,3794
3795,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، عَنْ أَبِیہِ ، قَالَ : إنِّی لاَحِبُّ أَنْ أَشْغَلَ نَفْسِی فِی الظُّہْرِ وَالْعَصْرِ خَلْفَ الإِمَامِ۔",,,3795
3796,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الْعَلاَئِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ یَعْقُوبَ ، أَنَّ أَبَا السَّائِبِ أخْبَرَہُ، قَالَ: قُلْتُ لأَبِی ہُرَیْرَۃَ: إنِّی أَکُونُ وَرَائَ الإِمَامِ؟ فَغَمَزَ ذِرَاعِی، فَقَالَ: یَا فَارِسِیُّ، اقْرَأْ بِہَا فِی نَفْسِکَ، یَعْنِی بِأُمِّ الْقُرْآنِ۔",,,3796
3797,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنِ ابْنِ أُکیمَۃَ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یَقُولُ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃً ، نَظُنُّ أَنَّہَا الصُّبْحُ ، فَلَمَّا قَضَاہَا ، قَالَ : ہَلْ قَرَأَ مِنْکُمْ أَحَدٌ ؟ قَالَ رَجُلٌ : أَنَا ، قَالَ: إنِّی أَقُولُ : مَا لِی أُنَازَعُ الْقُرْآنَ۔ (ترمذی 312۔ احمد 2/284)",,,3797
3798,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الظُّہْرَ ، فَلَمَّا سَلَّمَ قَالَ : ہَلْ قَرَأَ أَحَدٌ مِنْکُمْ بِـ (سَبِّحِ اسْمَ رَبِّکَ الأَعْلَی) ؟ فَقَالَ رَجُلٌ مِنَ الْقَوْمِ : أَنَا ، فَقَالَ : قَدْ عَلِمْتُ أَنَّ بَعْضَکُمْ خَالَجَنِیہَا۔",,,3798
3799,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ یُونُسَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی الأَحْوَصِ ، عَنْ عَبْدِ اللہِ ، قَالَ : کُنَّا نَقْرَأُ خَلْفَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : خَلَطْتُمْ عَلَیَّ الْقُرْآنَ۔ \n\n(احمد 1/451۔ ابو یعلی 4985)",,,3799
3800,"حَدَّثَنَا شَرِیکٌ ، وَجَرِیرٌ ، عَنْ مُوسَی بْنِ أَبِی عَائِشَۃَ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ کَانَ لَہُ إمَامٌ ، فَقِرَاء َتُہُ لَہُ قِرَاء َۃٌ۔",,,3800
3801,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مَنْصُورٍ ، عَنْ أَبِی وَائِلٍ ، قَالَ : جَائَ رَجُلٌ إلَی عَبْدِ اللہِ ، فَقَالَ : أَقْرَأُ خَلْفَ الإِمَامِ ؟ فَقَالَ لَہُ عَبْدُ اللہِ : إنَّ فِی الصَّلاَۃِ شُغْلاً ، وَسَیَکْفِیک ذَاکَ الإِمَامُ۔",,,3801
3802,"حَدَّثَنَا مُحَمَّدُ بْنُ سُلَیْمَانَ الأَصْبَہَانِیُّ ، عَنْ عَبْدِ الرَّحْمَنِ بن الأصبہانی ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَلِیٍّ ، قَالَ : مَنْ قَرَأَ خَلْفَ الإِمَامِ فَقَدْ أَخْطَأَ الْفِطْرَۃَ۔",,,3802
3803,"حَدَّثَنَا وَکِیعٌ ، عَنْ قَتَادَۃَ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، عَنْ أَبِی بِجَادٍ ، عَنْ سَعْدٍ ، قَالَ : وَدِدْت أَنَّ الَّذِی یَقْرَأُ خَلْفَ الإِمَامِ فِی فِیہِ جَمْرَۃٌ۔",,,3803
3804,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبَّادِ بْنِ إِسْحَاقَ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ قُسَیْطٍ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : لاَ قِرَائَۃَ خَلْفَ الإِمَامِ۔",,,3804
3805,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، وَأَنَسِ بْنِ سِیرِینَ ، قَالاَ : قَالَ ابن عُمَرُ : یَکْفِیک قِرَائَۃَ الإِمَامِ۔",,,3805
3806,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، وَابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ الأَسْوَدُ : لأَنْ أَعَضَّ عَلَی جَمْرَۃٍ، أَحَبُّ إلَیَّ مِنْ أَنْ أَقْرَأَ خَلْفَ إِمَامٍ أَعْلَمُ أَنَّہُ یَقْرَأُ۔",,,3806
3807,"حَدَّثَنَا وَکِیعٌ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ ، عَنْ عُبَیْدِ اللہِ بْنِ مِقْسَمٍ ، عَنْ جَابِرٍ ، قَالَ : لاَ تَقْرَأْ خَلْفَ الإِمَامِ۔",,,3807
3808,"حَدَّثَنَا وَکِیعٌ ، عَنِ الضَّحَّاکِ بْنِ عُثْمَانَ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، عَنِ ابْنِ ثَوْبَانَ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ: لاَ تَقْرَأْ خَلْفَ الإِمَامِ إِنْ جَہَرَ ، وَلاَ إِنْ خَافَتَ۔",,,3808
3809,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُمَرَ بْنِ مُحَمَّدٍ ، عَنْ مُوسَی بْنِ سَعْدٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : مَنْ قَرَأَ خَلْفَ الإِمَامِ فَلاَ صَلاَۃَ لَہُ۔",,,3809
3810,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ وَبَرَۃَ ، عَنِ الأَسْوَدِ بْنِ یَزِیدَ ، أَنَّہُ قَالَ : وَدِدْت أَنَّ الَّذِی یَقْرَأُ خَلْفَ الإِمَامِ مُلِیئَ فُوہُ تُرَابًا۔",,,3810
3811,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، مِثْلَہُ۔,,,3811
3812,"حَدَّثَنَا مُعْتَمِرٌ ، حَدَّثَنَا مَعْمَرٌ ، عَنْ أَبِی ہَارُونَ ، قَالَ : سَأَلْتُ أَبَا سَعِیدٍ ، عَنِ الْقِرَائَۃِ خَلْفَ الإِمَامِ ؟ فَقَالَ: یَکْفِیک ذَاکَ الإِمَامُ۔",,,3812
3813,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَبِی بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : سَأَلْتُہ عَنِ الْقِرَائَۃِ خَلْفَ الإِمَامِ ؟ قَالَ : لَیْسَ وَرَائَ الإِمَامِ قِرَائَۃٌ۔",,,3813
3814,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ : أَنْصِتْ لِلإِمَامِ۔",,,3814
3815,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدٍ ، قَالَ : لاَ أَعْلَمُ الْقِرَائَۃَ خَلْفَ الإِمَامِ مِنَ السُّنَّۃِ۔",,,3815
3816,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَکْرَہُ الْقِرَائَۃَ خَلْفَ الإِمَامِ ، وَکَانَ یَقُولُ : تَکْفِیک قِرَائَۃُ الإِمَامِ۔",,,3816
3817,"حَدَّثَنَا الْفَضْلُ ، عَنْ زُہَیْرٍ ، عَنِ الْوَلِیدِ بْنِ قَیْسٍ ، قَالَ : سَأَلْتُ سُوَیْد بْنَ غَفَلَۃَ : أَقْرَأُ خَلْفَ الإِمَامِ فِی الظُّہْرِ وَالْعَصْرِ ؟ فَقَالَ : لاَ۔",,,3817
3818,"حَدَّثَنَا الْفَضْلُ ، عَنْ أَبِی کِبْران ، قَالَ : کَانَ الضَّحَّاکُ یَنْہَی عَنِ الْقِرَائَۃِ خَلْفَ الإِمَامِ۔",,,3818
3819,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنْ مَالِکِ بْنِ عُمَارَۃَ ، قَالَ : سَأَلْتُ ، لاَ أَدْرِی ، کَمْ رَجُلٍ مِنْ أَصْحَابِ عَبْدِ اللہِ کُلُّہُمْ یَقُولُ : لاَ یُقْرَأُ خَلْفَ إمَامٍ ، مِنْہُمْ عَمْرُو بْنُ مَیْمُونٍ۔",,,3819
3820,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّمَا جُعِلَ الإِمَامُ لِیُؤْتَمَّ بِہِ ، فَإِذَا کَبَّرَ فَکَبِّرُوا ، وَإِذَا قَرَأَ فَأَنْصِتُوا۔\n\n(ابوداؤد 604۔ احمد 2/376)",,,3820
3821,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ أُکَیْلٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : الَّذِی یَقْرَأُ خَلْفَ الإِمَامِ مُشَاقٌّ۔",,,3821
3822,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ، عَنْ مِسْعَرٍ، عَنْ عَمْرِو بْنِ مُرَّۃَ، عَنْ أَبِی وَائِلٍ، قَالَ: یَکْفِیک قِرَائَۃُ الإِمَامِ۔",,,3822
3823,"حَدَّثَنَا مَالِکُ بْنُ إسْمَاعِیلَ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنْ أَبِی الزُّبَیْرِ ، عَنْ جَابِرٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : کُلُّ مَنْ کَانَ لَہُ إمَامٌ ، فَقِرَائَ تُہُ لَہُ قِرَائَۃٌ۔",,,3823
3824,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ طَلْحَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَوْسَجَۃَ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ اللَّہَ وَمَلاَئِکَتَہُ یُصَلُّونَ عَلَی الصَّفِّ الأَوَّلِ۔\n\n(ابوداؤد 664۔ احمد 4/684)",,,3824
3825,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ عَمَّارِ بْنِ رُزَیْقٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَوْسَجَۃَ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنَّ اللَّہَ وَمَلاَئِکَتَہُ یُصَلُّونَ عَلَی الصُّفُوفِ الأُوَلِ۔\n\n(احمد 4/299۔ ابن خزیمۃ 1552)",,,3825
3826,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنْ فِرَاسٍ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : إنَّ اللَّہَ وَمَلاَئِکَتَہُ یُصَلُّونَ عَلَی الصَّفِّ الْمُقَدَّمِ۔",,,3826
3827,"حَدَّثَنَا عَبْدَۃُ بْنُ سُلَیْمَانَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ یُقَالُ : خَیْرُ صُفُوفِ الرِّجَالِ مُقَدَّمُہَا ، وَشَرُّ صُفُوفِ النِّسَائِ مُقَدِّمُہَا۔",,,3827
3828,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ ضِرَارٍ ، عَنْ زَاذَانَ ، قَالَ : لَوْ یَعْلَمُ النَّاسُ مَا فِی الصَّفِّ الْمُقَدَّمِ ، مَا قَدَرُوا عَلَیْہِ إِلاَّ بِقُرْعَۃٍ۔",,,3828
3829,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ یُقَالُ : إنَّ اللَّہَ وَمَلاَئِکَتَہُ یُصَلُّونَ عَلَی الَّذِینَ یُصَلُّونَ فِی الصُّفُوفِ الأُوَلِ۔",,,3829
3830,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حدَّثَنَا دَاوُد بْنُ أَبِی ہِنْدٍ ، قَالَ : حُدِّثْت أَنَّ رَجُلاً جَائَ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، دُلَّنِی عَلَی عَمَلٍ أَعْمَلُہُ ، قَالَ : کُنْ إمَامَ قَوْمِکَ ، قَالَ : فَإِنْ لَمْ أَسْتَطِعْ ؟ قَالَ : کُنْ مُؤَذِّنَہُمْ ، قَالَ : فَإِنْ لَمْ أَسْتَطِعْ ؟ قَالَ : فَکُنْ فِی الصَّفِّ الأَوَّلِ۔ (بخاری 59)",,,3830
3831,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، قَالَ : کُنْتُ مَعَ عَبْدِ اللہِ بْنِ شَدَّادٍ ، فَأَقَمْتُ الصَّلاَۃَ ، قَالَ : فَجَعَلَ یَقُولُ : تَقَدَّمُوا تَقَدَّمُوا ، فَإِنَّہُ کَانَ یُقَالُ : إنَّ اللَّہَ وَمَلاَئِکَتَہُ یُصَلُّونَ عَلَی الَّذِینَ یُصَلُّونَ فِی الصُّفُوفِ الْمُقَدَّمَۃِ۔ (عبدالرزاق 2454)",,,3831
3832,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ عَامِرِ بْنِ مَسْعُودٍ الْقُرَشِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لَوْ یَعْلَمُ النَّاسُ مَا فِی الصَّفِّ الأَوَّلِ مَا صَفُّوا فِیہِ إِلاَّ بِقُرْعَۃٍ۔\n\n(بخاری 615۔ مسلم 119)",,,3832
3833,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : أَخْبَرَنَا شَیْبَانُ ، عَنْ یَحْیَی ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ ، أَنَّ خَالِدَ بْنَ مَعْدَانَ حَدَّثَہُ، أَنَّ جُبَیْرَ بْنَ نُفَیْرٍ حَدَّثَہُ ، أَنَّ الْعِرْبَاضَ بْنَ سَارِیَۃَ حَدَّثَہُ ، وَکَانَ الْعِرْبَاضُ مِنْ أَصْحَابِ الصُّفَّۃِ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی عَلَی الصَّفِّ الْمُقَدَّمِ ثَلاَثًا ، وَعَلَی الثَّانِی وَاحِدَۃً۔\n\n(احمد 4/126۔ ابن حبان 6158)",,,3833
3834,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : خَیْرُ صُفُوفِ الرِّجَالِ مُقَدَّمُہَا ، وَشَرُّہَا مُؤَخَّرُہَا ، وَخَیْرُ صُفُوفِ النِّسَائِ آخِرُہَا ، وَشَرُّہَا مُقَدَّمُہَا۔(ابن ماجہ 1001۔ احمد 3/387)",,,3834
3835,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ ، قَالَ : سَمِعْتُ عُرْوَۃَ بْنَ الزُّبَیْرِ حِینَ أُقِیمَتِ الصَّلاَۃُ یَقُولُ : تَقَدَّمُوا ، تَقَدَّمُوا۔",,,3835
3836,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْعَیْزَارِ ، عَنْ أَبِی بَصِیرٍ ، قَالَ : قَالَ أُبَیّ بْنُ کَعْبٍ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ الصَّفَّ الأَوَّلَ لَعَلَی مِثْلِ صَفِّ الْمَلاَئِکَۃِ ، وَلَوْ تَعْلَمُونَ لاَبْتَدَرْتُمُوہُ۔",,,3836
3837,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : حدَّثَنَا زُہَیْرُ بن محمد ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَمِعَہُ یَقُولُ : خَیْرُ صُفُوفِ الرِّجَالِ الْمُقَدَّمُ ، وَشَرُّہَا الْمُؤَخَّرُ ، وَخَیْرُ صُفُوفِ النِّسَائِ الْمُؤَخَّرُ ، وَشَرُّہَا الْمُقَدَّمُ۔",,,3837
3838,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ زَیْدٍ ، عَنْ مُجَاہِدٍ ، قَالَ : رَأَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الصَّفِّ الْمُقَدَّمِ رِقَّۃً ، فَقَالَ : إنَّ اللَّہَ وَمَلاَئِکَتَہُ یُصَلُّونَ عَلَی الصُّفُوفِ الأُوَلِ ، فَازْدَحَمَ النَّاسُ عَلَیْہِ۔",,,3838
3839,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : حدَّثَنَا زُہَیْرُ بْنُ مُحَمَّدٍ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، أَنَّہُ سَمِعَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : إذَا قُمْتُمْ إلَی الصَّلاَۃِ فَاعْدِلُوا صُفُوفَکُمْ ، وَسُدُّوا الْفُرَجَ ، فَإِنِّی أَرَاکُمْ مِنْ وَرَائِ ظَہْرِی۔",,,3839
3840,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مُوسَی بْنِ مُسْلِمٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ سَابِطٍ ، قَالَ : مَا تَغَیَّرَتِ الأَقْدَامُ فِی شَیْئٍ أَحَبَّ إلَی اللہِ مِنْ رَقْعِ صَفٍّ۔",,,3840
3841,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، قَالَ : رَأَی ابْنُ عُمَرَ رَجُلاً یُصَلِّی وَأَمَامُہُ فُرْجَۃٌ فِی الصَّفِّ ، فَدَفَعَہُ إلَیْہَا۔",,,3841
3842,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، قَالَ : صَلَّیْت إلَی جَنْبِ ابْنِ عُمَرَ ، فَرَأَی فِی الصَّفِّ فُرْجَۃً فَأَوْمَأَ إلَیَّ ، فَلَمْ أَتَقَدَّمْ ، قَالَ : فَتَقَدَّمَ ہُوَ فَسَدَّہَا۔",,,3842
3843,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إیَّاکَ وَالْفُرَجَ ، یَعْنِی فِی الصَّفِّ۔",,,3843
3844,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الْمَقْبُرِیِّ ، عَنْ عُرْوَۃَ بْنِ الزُّبَیْرِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ سَدَّ فُرْجَۃً فِی صَفٍّ رَفَعَہُ اللَّہُ بِہَا دَرَجَۃً ، أَوْ بَنَی لَہُ بَیْتًا فِی الْجَنَّۃِ۔",,,3844
3845,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، قَالَ : کَانَ یُقَالُ ذَلِکَ۔",,,3845
3846,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی رَوَّادٍ ، عَنْ رَجُلٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : لأَنْ تَسْقُطَ ثَنِیَّتَایَ أَحَبّ إلَیَّ مِنْ أَنْ أَرَی فِی الصَّفِّ خَلَلاً لاَ أَسُدّہُ۔",,,3846
3847,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِیسَی بْنِ حَفْصٍ ، عَنْ أَبِیہِ ، قَالَ : خَرَجْنَا مَعَ ابْنِ عُمَرَ ، قَالَ : فَصَلَّیْنَا الْفَرِیضَۃَ ، فَرَأَی بَعْضَ وَلَدِہِ یَتَطَوَّعُ ، فَقَالَ ابْنُ عُمَرَ : صَلَّیْت مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَبِی بَکْرٍ ، وَعُمَرَ ، وَعُثْمَانَ فَلاَ صَلاَۃَ قَبْلَہَا ، وَلاَ بَعْدَہَا فِی السَّفَرِ ، وَلَوْ تَطَوَّعْت لأَتْمَمْت۔(بخاری 1102۔ مسلم 479)",,,3847
3848,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُجَاہِدٍ ، قَالَ : سَأَلْنَاہُ : أَکَانَ ابْنُ عُمَرَ یَتَطَوَّعُ فِی السَّفَرِ ؟ فَقَالَ : لاَ، فَقُلْتُ : فَرَکْعَتَان قَبْلَ الْفَجْرِ ؟ قَالَ : مَا رَأَیْتُہُ تَرَکَ تَیْنِکَ فِی سَفَرٍ ، وَلاَ حَضَرٍ۔",,,3848
3849,حَدَّثَنَا ہُشَیْمٌ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَتَطَوَّعُ فِی السَّفَرِ قَبْلَ الصَّلاَۃِ ، وَلاَ بَعْدَہَا ، وَکَانَ یُصَلِّی مِنَ اللَّیْلِ۔,,,3849
3850,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ مَوْلَی الأَنْصَارِ ، قَالَ : سَمِعْتُ أَبَا جَعْفَرٍ مُحَمَّدَ بْنَ عَلِیٍّ یُحَدِّثُ ، عَنْ أَبِیہِ عَلِیِّ بْنِ حُسَیْنٍ ؛ أَنَّہُ کَانَ لاَ یَتَطَوَّعُ فِی السَّفَرِ قَبْلَ الصَّلاَۃِ ، وَلاَ بَعْدَہَا۔",,,3850
3851,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ أَبِی الْیَمَانِ ، قَالَ : رَأَیْتُ أَنَسًا یَتَطَوَّعُ فِی السَّفَرِ۔",,,3851
3852,حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ؛ أَنَّ أَبَاہُ کَانَ یَتَطَوَّعُ فِی السَّفَرِ ، وَأَنَّ عَبْدَ اللہِ کَانَ یَتَطَوَّعُ فِی السَّفَرِ۔,,,3852
3853,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَتَطَوَّعُ فِی السَّفَرِ۔,,,3853
3854,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، عَنْ رَجُلٍ یُقَالُ لَہُ : مُحَمَّدُ بْنُ قَیْسٍ ، قَالَ : دَخَلْتُ عَلَی جَابِرِ بْنِ عَبْدِ اللہِ وَہُوَ یَتَطَوَّعُ فِی السَّفَرِ۔",,,3854
3855,حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنْ أَبِی إِسْحَاقَ ؛ أَنَّ عَلِیًّا کَانَ لاَ یَرَی بِالتَّطَوُّعِ فِی السَّفَرِ بَأْسًا۔,,,3855
3856,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَاصِمٍ ؛ أَنَّ عَلِیًّا تَطَوَّعَ فِی السَّفَرِ۔,,,3856
3857,حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّ أُمَّ الْمُؤْمِنِینَ کَانَتْ تَتَطَوَّعُ فِی السَّفَرِ۔,,,3857
3858,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، وَعَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُمَا لَمْ یَکُونَا یَرَیَانِ بَأْسًا بِالتَّطَوُّعِ فِی السَّفَرِ قَبْلَ الصَّلاَۃِ ، وَلاَ بَعْدَہَا۔,,,3858
3859,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، قَالَ : رَأَیْتُ الْقَاسِمَ یَتَطَوَّعُ فِی السَّفَرِ۔",,,3859
3860,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عِیسَی بْنِ أَبِی عَزَّۃَ ، قَالَ : رَأَیْتُ الشَّعْبِیَّ یَتَطَوَّعُ فِی السَّفَرِ۔",,,3860
3861,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّ أَبَا ذَرٍّ وَعُمَرَ کَانَا یَتَطَوَّعَانِ فِی السَّفَرِ۔,,,3861
3862,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ یَتَطَوَّعُونَ فِی السَّفَرِ۔",,,3862
3863,حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ ، کَانَ أَبِی یُصَلِّی عَلَی إِثْرِ الْمَکْتُوبَۃِ فِی السَّفَرِ۔,,,3863
3864,حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ، قَالَ ؛ وَافَقْنَا أَصْحَابَ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَکَانُوا یُصَلُّونَ قَبْلَ الْفَرِیضَۃِ وَبَعْدَہَا ، یَعْنِی فِی السَّفَرِ۔,,,3864
3865,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، قَالَ : صَحِبْت ابْنَ عُمَرَ مِنَ الْمَدِینَۃِ إلَی مَکَّۃَ ، فَکَانَ یُصَلِّی تَطَوُّعًا عَلَی دَابَّتِہِ حَیْثُ مَا تَوَجَّہَتْ بِہِ ، فَإِذَا کَانَتِ الْفَرِیضَۃُ نَزَلَ فَصَلَّی۔",,,3865
3866,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَشْعَثَ ، قَالَ : صَحِبْت أَبِی وَالأَسْوَدَ بْنَ یَزِیدَ وَعَمْرَو بْنَ مَیْمُونٍ وَأَبَا وَائِلٍ ، فَکَانُوا یُصَلُّونَ رَکْعَتَیْنِ ، ثُمَّ یُصَلُّونَ بَعْدَہَا رَکْعَتَیْنِ۔",,,3866
3867,حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، وَأَشْعَثُ ، وَحَجَّاجٍ ، عَنْ عَطِیَّۃَ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ کَانَ یَتَطَوَّعُ فِی السَّفَرِ۔,,,3867
3868,حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ سَالِمٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَعُمَرَ کَانَا یَتَطَوَّعَانِ فِی السَّفَرِ۔,,,3868
3869,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا دَخَلَ الْمُسَافِرُ فِی صَلاَۃِ الْمُقِیمِینَ صَلَّی بِصَلاَتِہِمْ۔",,,3869
3870,"حَدَّثَنَا حَفْصٌ ، عَنْ عبیدَۃَ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، قَالَ : یُصَلِّی بِصَلاَتِہِمْ۔",,,3870
3871,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی مِجْلَزٍ ، عَنِ ابْنِ عُمَرَ ؛ فِی مُسَافِرٍ أَدْرَکَ مِنْ صَلاَۃِ الْمُقِیمِینَ رَکْعَۃً، قَالَ : یُصَلِّی مَعَہُمْ ، وَیَقْضِی مَا سُبِقَ بِہِ۔",,,3871
3872,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، وَعَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ قَالاَ : إذَا دَخَلَ الْمُسَافِرُ فِی صَلاَۃِ الْمُقِیمِینَ صَلَّی بِصَلاَتِہِمْ۔",,,3872
3873,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنِ الشَّعْبِیِّ ، قَالَ : أَقَامَ بِوَاسِطَ سَنَتَیْنِ یُصَلِّی رَکْعَتَیْنِ ، إِلاَّ أَنْ یُصَلِّیَ مَعَ قَوْمٍ فَیُصَلِّیَ بِصَلاَتِہِم۔",,,3873
3874,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، وَیُونُسَ ، عَنِ الْحَسَنِ قَالاَ : یُصَلِّی بِصَلاَتِہِمْ۔",,,3874
3875,حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ فِی الْمُسَافِرِ یُدْرِکُ مِنْ صَلاَۃِ الْمُقِیمِینَ رَکْعَۃً ، أَوْ ثِنْتَیْنِ ؛ فَلْیُصَلِّ بِصَلاَتِہِمْ۔,,,3875
3876,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قدِمْت الْمَدِینَۃَ فَأَدْرَکْت رَکْعَۃً مِنَ الْعِشَائِ ، فَجَعَلْتُ أُحَدِّثُ نَفْسِی کَیْفَ أَصْنَعُ ؟ فَذَکَرْت ذَلِکَ لِلْقَاسِمِ ، فَقَالَ : کُنْت تَرْہَبُ لَوْ صَلَّیْت أَرْبَعًا أَنْ یُعَذِّبَک اللَّہُ؟",,,3876
3877,حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ رَبَاحِ بْنِ أَبِی مَعْرُوفٍ ، عَنْ عَطَائٍ ، قَالَ ، إذَا أَدْرَکْت مِنْ صَلاَۃِ الْمُقِیمِینَ رَکْعَۃً فَصَلِّ بِصَلاَتِہِمْ۔,,,3877
3878,"حَدَّثَنَا عَبْدُالسَّلاَمِ، عَنْ سُلَیْمَانَ التَّیْمِیِّ، عَنْ أَبِی مِجْلَزٍ، عَنِ ابْنِ عُمَرَ؛ فِی الْمُسَافِرِ فِی صَلاَۃِ الْمُقِیمِینَ، قَالَ : یُصَلِّی بِصَلاَتِہِمْ۔",,,3878
3879,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْمُخْتَارُ بْنُ عَمْرٍو الأَزْدِیُّ ، قَالَ : سَأَلْتُ جَابِرَ بْنَ زَیْدٍ عَنِ الصَّلاَۃِ فِی السَّفَرِ ؟ قَالَ : فَقَالَ : إذَا صَلَّیْت وَحْدَک فَصَلِّ رَکْعَتَیْنِ ، وَإِذَا صَلَّیْت فِی جَمَاعَۃٍ فَصَلِّ بِصَلاَتِہِمْ۔",,,3879
3880,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ، قَالَ : أَقَمْتُ مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَامَ الْفَتْحِ بِمَکَّۃَ ، فَأَقَامَ ثَمَانَ عَشْرَۃَ لَیْلَۃً لاَ یُصَلِّی إِلاَّ رَکْعَتَیْنِ ، ثُمَّ یَقُولُ لأَہْلِ الْبَلَدِ: صَلُّوا أَرْبَعًا ، فَإِنَّا قَوْمٌ سَفْرٌ۔ (ترمذی 545۔ ابوداؤد 1222)",,,3880
3881,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، عَنْ عُمَرَ (ح) وَعَنْ سُفْیَانَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن أَبِیہِ ، عَنْ عُمَرَ (ح) وَعَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عُمَرَ ؛ أَنَّہُ صَلَّی بِمَکَّۃَ رَکْعَتَیْنِ ، ثُمَّ قَالَ : إنَّا قَوْمٌ سَفْرٌ ، فَأَتِمُّوا الصَّلاَۃَ۔",,,3881
3882,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، عَنْ عُمَرَ ، بِمِثْلِہِ۔",,,3882
3883,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن حَمَّادٍ ، عَنْ عُمَرَ ، بِمِثْلِہِ۔,,,3883
3884,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : صَلَّیْت مَعَ عُمَرَ رَکْعَتَیْنِ بِمَکَّۃَ ، ثُمَّ قَالَ : یَا أَہْلَ مَکَّۃَ ، إنَّا قَوْمٌ سَفْرٌ ، فَأَتِمُّوا الصَّلاَۃَ۔",,,3884
3885,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن أَبِیہِ ، عَنْ عُمَر (ح) وَعَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ، عَنْ عُمَرَ ، مِثْلَہُ۔,,,3885
3886,حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی إلَی بَعِیرِہِ۔ (بخاری 430۔ ابوداؤد 692),,,3886
3887,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، عَنْ إسْرَائِیلَ ، عَنْ زِیَادِ الْمُصَفِّرِ ، عَنِ الْحَسَنِ ، عَنِ الْمِقْدَامِ الرَّہَاوِیِّ ، قَالَ : جَلَسَ عُبَادَۃُ بْنُ الصَّامِتِ ، وَأَبُو الدَّرْدَائِ ، وَالْحَارِثُ بْنُ مُعَاوِیَۃَ ، فَقَالَ أَبُو الدَّرْدَائِ : أَیُّکُمْ یَذْکُرُ حَدِیثَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ صَلِّی إلَی بَعِیرٍ مِنَ الْمَغْنَمِ ، قَالَ عُبَادَۃُ : أَنَا ، قَالَ : فَحَدِّثْ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إلَی بَعِیرٍ مِنَ الْمَغْنَمِ۔ (ابن ماجہ 2850)",,,3887
3888,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ دَاوُدَ ، عَنْ أَبِی سَلاَّمٍ ، قَالَ : حدَّثَنَا أَبُو إدْرِیسَ الْخَوْلاَنِیُّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی إلَی صَفْحَۃِ بَعِیرٍ۔",,,3888
3889,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو قَالَ : کَانَ ابْنُ عُمَرَ یُصَلِّی إلَی الْبَعِیرِ إذَا کَانَ عَلَیْہِ رَحْلٌ۔",,,3889
3890,حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُعَرِّضُ رَاحِلَتَہُ وَیُصَلِّی إلَیْہَا۔,,,3890
3891,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عَاصِمٍ ، قَالَ : رَأَیْتُ أَنَسًا یُصَلِّی وَبَیْنَہُ وَبَیْنَ الْقِبْلَۃِ بَعِیرٌ عَلَیْہِ مَحْمَلٌ۔",,,3891
3892,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ إبْرَاہِیمَ بْنِ عَبْدِ الأَعْلَی ، قَالَ : رَأَیْتُ سُوَیْد بْنَ غَفَلَۃَ یُنِیخُ رَاحِلَتَہُ فِی طَرِیقِ مَکَّۃَ ، فَیُصَلِّی إلَیْہَا۔",,,3892
3893,حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنِ الأَسْوَدِ ؛ أَنَّہُ کَانَ یُصَلِّی إلَی رَاحِلَتِہِ وَہِیَ أَمَامَہُ مُنَاخَۃٌ۔,,,3893
3894,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، قَالَ : رَأَیْتُ الْقَاسِمَ وَسَالِمًا یُصَلِّیَانِ إلَی بَعِیرَیْہِمَا۔",,,3894
3895,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : یَسْتَتِرُ بِالْبَعِیرِ۔",,,3895
3896,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ یَسْتَتِرَ بِالْبَعِیرِ۔",,,3896
3897,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ، عَنْ عَبْدِ اللہِ بْنِ مُغَفَّلٍ الْمُزَنِیّ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلُّوا فِی مَرَابِضِ الْغَنَمِ ، وَلاَ تُصَلُّوا فِی أَعْطَانِ الإِبِلِ ، فَإِنَّہَا خُلِقَتْ مِنَ الشَّیَاطِینِ۔\n\n(ابن ماجہ 769۔ ابن حبان 1702)",,,3897
3898,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ عَبْدِ اللہِ بْنِ عَبْدِ اللہِ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْبَرَائِ بْنِ عَازِبٍ ، قَالَ : سُئِلَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الصَّلاَۃِ فِی مَبَارِکِ الإِبِلِ ؟ فَقَالَ : لاَ تُصَلُّوا فِیہَا ، وَسُئِلَ عَنِ الصَّلاَۃِ فِی مَرَابِضِ الْغَنَمِ ؟ فَقَالَ : صَلُّوا فِیہَا ، فَإِنَّہَا بَرَکَۃٌ۔",,,3898
3899,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْبَرَائِ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، نَحْوَہُ ، وَلَمْ یَذْکُرْ : فَإِنَّہَا بَرَکَۃٌ۔",,,3899
3900,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنْ مُحَمَّدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا لَمْ تَجِدُوا إِلاَّ مَرَابِضَ الْغَنَمِ وَمَعَاطِنَ الإِبِلِ فَصَلُّوا فِی مَرَابِضِ الْغَنَمِ ، وَلاَ تُصَلُّوا فِی أَعْطَانِ الإِبِلِ۔ (ترمذی 348۔ ابن حبان 1384)",,,3900
3901,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنَا عَبْدُ الْمَلِکِ بْنُ الرَّبِیعِ بْنِ سَبْرَۃَ ، عَنْ أَبِیہِ ، عَنْ جَدِّہِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یُصَلَّی فِی أَعْطَانِ الإِبِلِ وَیُصَلَّی فِی مُرَاحِ الْغَنَمِ ۔\n\n(احمد 3/102۔ دارقطنی 276)",,,3901
3902,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ جَعْفَرِ بْنِ أَبِی ثَوْرٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : یُصَلَّی فِی مَرَابِضِ الْغَنَمِ ، وَلاَ یُصَلَّی فِی أَعْطَانِ الإِبِلِ۔",,,3902
3903,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ حُسَیْنٍ الْمُعَلِّمِ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ مَاعِزِ بْنِ نَضْلَۃَ ، قَالَ : أَتَانَا أَبُو ذَرٍّ ، فَدَخَلَ زَرْبَ غَنَمٍ لَنَا ، فَصَلَّی فِیہِ۔",,,3903
3904,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، قَالَ : حدَّثَنِی رَجُلٌ سَأَلَ عَبْدَ اللہِ بْنَ عُمَرَ عَنِ الصَّلاَۃِ فِی أَعْطَانِ الإِبِلِ ؟ قَالَ : فَنَہَاہُ ، وَقَالَ : صَلِّ فِی مُرَاحِ الْغَنَمِ۔",,,3904
3905,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی التَّیَّاحِ ، عَنْ أَنَسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی فِی مَرَابِضِ الْغَنَمِ قَبْلَ أَنْ یُبْنَی الْمَسْجِدُ۔ (بخاری 429۔ مسلم 374)",,,3905
3906,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الرَّحْمَنِ ؛ أَنَّ عُمَرَ صَلَّی فِی مَکَان فِیہِ دِمَنٌ۔,,,3906
3907,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ صَخْرِ بْنِ جُوَیْرِیَۃَ ، عَنْ عَاصِمِ بْنِ الْمُنْذِرِ ، قَالَ : خَرَجَ ابْنُ الزُّبَیْرِ إلَی الْمُزْدَلِفَۃِ فِی غَیْرِ أَشْہُرِ الْحَجِّ ، فَصَلَّی بِنَا فِی مُرَاحِ الْغَنَمِ ، وَہُوَ یَجِدُ أَمْکِنَۃً سِوَاہَا ، لَوْ شَائَ لَصَلَّی فِیہِمَا ، وَمَا رَأَیْتُہ فَعَلَ ذَلِکَ إِلاَّ لِیُرِیَنَا۔",,,3907
3908,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، قَالَ : سَمِعْتُ مُحَمَّدًا یَقُولُ : کَانُوا إذَا لَمْ یَجِدُوا إِلاَّ أَنْ یُصَلُّوا فِی مَرَابِضِ الْغَنَمِ وَمَرَابِضِ الإِبِلِ ، صَلَّوْا فِی مَرَابِضِ الْغَنَمِ۔",,,3908
3909,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : صَلِّ فِی دِمَنِ الْغَنَمِ۔",,,3909
3910,حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَبَّادِ بْنِ رَاشِدٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہ الصَّلاَۃَ فِی أَعْطَانِ الإِبِلِ ، وَلاَ یَرَی بِہَا بَأْسًا فِی أَعْطَانِ الْغَنَمِ۔,,,3910
3911,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی حَمْزَۃَ ، قَالَ : سَمِعْتُ عُبَیْدَ بْنَ عُمَیْرٍ یَقُولُ : إنَّ لِی لَعَنَاقًا تَنَامُ مَعِی فِی مَسْجِدِی ، وَتَبْعَرُ فِیہِ۔",,,3911
3912,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ جُنْدُبِ بْنِ عَامِرٍ السُّلَمِیِّ ؛ أَنَّہُ کَانَ یُصَلِّی فِی أَعْطَانِ الإِبِلِ وَمَرَابِضِ الْغَنَمِ۔,,,3912
3913,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَمَّنْ سَمِعَ جَابِرَ بْنَ سَمُرَۃَ یَقُولُ : کُنَّا نُصَلِّی فِی مَرَابِضِ الْغَنَمِ ، وَلاَ نُصَلِّی فِی أَعْطَانِ الإِبِلِ۔",,,3913
3914,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ہِشَامُ بْنُ عُرْوَۃَ ، قَالَ : حَدَّثَنِی رَجُلٌ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو قَالَ : صَلُّوا فِی مَرَابِضِ الْغَنَمِ ، وَلاَ تُصَلُّوا فِی أَعْطَانِ الإِبِلِ۔",,,3914
3915,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ابْنُ أَبِی خَالِدٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃِ فِی دِمْنَۃِ الْغَنَمِ۔",,,3915
3916,حَدَّثَنَا وَکِیعٌ ؛ فِی رَجُلٍ صَلَّی فِی أَعْطَانِ الإِبِلِ یُجْزِئُہُ ، وَلاَ یَتَوَضَّأُ مِنْ لُحُومِ الإِبِلِ۔,,,3916
3917,"حَدَّثَنَا عُبَیْدُ اللہِ ، قَالَ : أَخْبَرَنَا إسْرَائِیلُ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ جَعْفَرِ بْنِ أَبِی ثَوْرٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : أَمَرَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ نُصَلِّیَ فِی مَرَابِضِ الْغَنَمِ ، وَلاَ نُصَلِّیَ فِی أَعْطَانِ الإِبِلِ۔",,,3917
3918,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنْ قَطْرَۃِ بَوْلٍ أَصَابَتْ خُفًّا ؟ فَقَالَ أَحَدُہُمَا : یُعِیدُ ، وَقَالَ الأَخَرُ : لاَ یُعِیدُ۔",,,3918
3919,حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ؛ وَقَدْ ذَکَرَ عِدَّۃً مِنْہُمْ أَبُو جَعْفَرٍ ؛ أَنَّہُمْ کَانُوا لاَ یُعِیدُونَ الصَّلاَۃَ مِنْ نَضْحِ الْبَوْلِ وَالدَّمِ۔,,,3919
3920,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا صَلَّی الرَّجُلُ فَوَجَدَ بَعْدَ مَا صَلَّی فِی ثَوْبِہِ ، أَوْ جِلْدِہِ قَطْرَۃً ، أَوْ بَوْلاً غَسَلَہُ وَأَعَادَ الصَّلاَۃَ ، وَإذَا وَجَدَ فِی جِلْدِہِ مَنِیًّا ، أَوْ دَمًا ، غَسَلَہُ وَلَمْ یُعِدِ الصَّلاَۃَ۔",,,3920
3921,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی جَعْفَرٍ الرَّازِیّ ، عَنِ الرَّبِیعِ بْنِ أَنَسٍ ، عَنْ رَجُلٍ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : التَّبَسُّمُ فِی الصَّلاَۃِ لَیْسَ بِشَیْئٍ۔",,,3921
3922,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ، عَنْ أَبِی الزُّبَیْرِ، عَنْ جَابِرٍ، قَالَ: التَّبَسُّمُ لاَ یَقْطَعُ، وَلَکِنْ تَقْطَعُ الْقَرْقَرَۃُ۔",,,3922
3923,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : التَّبَسُّمُ فِی الصَّلاَۃِ لَیْسَ بِشَیْئٍ۔",,,3923
3924,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : التَّبَسُّمُ فِی الصَّلاَۃِ لَیْسَ بِشَیْئٍ حَتَّی یُقَرْقِرَ۔",,,3924
3925,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ (ح) وَہِشَامٌ ، عَنِ الْحَسَنِ ؛ أَنَّہُمَا لَمْ یَرَیَا بِالتَّبَسُّمِ فِی الصَّلاَۃِ شَیْئًا۔,,,3925
3926,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنِ الْحَکَمِ بْنِ عَطِیَّۃَ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ سُئِلَ عَنِ التَّبَسُّمِ فِی الصَّلاَۃِ ؟ فَقَرَأَ ہَذِہِ الآیَۃَ : {فَتَبَسَّمَ ضَاحِکًا مِنْ قَوْلِہَا} لاَ أَعْلَمُ التَّبَسُّمَ إِلاَّ ضَحِکًا۔",,,3926
3927,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ حُمَیْدٍ قَالَ : کَانَ الْحَسَنُ بْنُ مُسْلِمٍ إِذَا رَآنِی تَبَسَّمَ فِی وَجْہِی ، وَہُوَ فِی الصَّلاَۃِ۔",,,3927
3928,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ شَیْبَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ بَأْسَ بِالتَّبَسُّمِ۔",,,3928
3929,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : إذَا ضَحِکَ الرَّجُلُ فِی الصَّلاَۃِ ، أَعَادَ الصَّلاَۃَ وَلَمْ یُعِدِ الْوُضُوئَ۔",,,3929
3930,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، قَالَ : ضَحِکْت خَلْفَ أَبِی وَأَنَا فِی الصَّلاَۃِ ، فَأَمَرَنِی أَنْ أُعِیدَ الصَّلاَۃَ۔",,,3930
3931,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الْقَاسِمِ ، قَالَ : ضَحِکْتُ وَأَنَا أُصَلِّی مَعَ أَبِی ، فَأَمَرَنِی أَنْ أُعِیدَ الصَّلاَۃَ۔",,,3931
3932,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : یُعِیدُ الصَّلاَۃَ ، وَلاَ یُعِیدُ الْوُضُوئَ۔",,,3932
3933,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ ہِشَامٍ ، قَالَ : ضَحِکَ أَخِی فِی الصَّلاَۃِ ، فَأَمَرَہُ عُرْوَۃُ أَنْ یُعِیدَ الصَّلاَۃَ ، وَلَمْ یَأْمُرْہُ أَنْ یُعِیدَ الْوُضُوئَ۔",,,3933
3934,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَضْحَکُ فِی الصَّلاَۃِ ، فَقَالَ : إِنْ تَبَسَّمَ فَلاَ یَنْصَرِفُ ، وَإِنْ قَہْقَہَ اسْتَقْبَلَ الصَّلاَۃَ ، وَلَیْسَ عَلَیْہِ وُضُوئٌ۔",,,3934
3935,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ سُلَیْمَانَ بْنِ الْمُغِیرَۃِ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ، قَالَ : کَانُوا فِی سَفَرٍ فَصَلَّی بِہِمْ أَبُو مُوسَی ، فَسَقَطَ رَجُلٌ أَعْوَرُ فِی بِئْرٍ ، أَوْ شَیْئٍ فَضَحِکَ الْقَوْمُ کُلُّہُمْ غَیْرُ أَبِی مُوسَی وَالأَحْنَفِ ، فَأَمَرَہُمْ أَنْ یُعِیدُوا الصَّلاَۃَ۔",,,3935
3936,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : کَانُوا یَأْمُرُونَنَا وَنَحْنُ صِبْیَانٌ إذَا ضَحِکْنَا فِی الصَّلاَۃِ أَنْ نُعِیدَ الصَّلاَۃَ۔",,,3936
3937,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یَضْحَکُ فِی الصَّلاَۃِ ، قَالَ : یُکَبِّرُ وَیُعِیدُ الصَّلاَۃَ۔",,,3937
3938,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی بِأَصْحَابِہِ ، فَجَائَ رَجُلٌ ضَرِیرُ الْبَصَرِ ، فَوَقَعَ فِی بِئْرٍ فِی الْمَسْجِدِ ، فَضَحِکَ بَعْضُ أَصْحَابِہِ ، فَلَمَّا أنْصَرَفَ أَمَرَ مَنْ ضَحِکَ أَنْ یُعِیدَ الْوُضُوئَ وَالصَّلاَۃَ۔ (دارقطنی 42۔ عبدالرزاق 3763)",,,3938
3939,"حَدَّثَنَا أَبُو خَالِدٍ ، عَنْ أَشْعَثَ ، عَنْ عَامِرٍ ، قَالَ : ہِیَ فِتْنَۃٌ ، یُعِیدُ الْوُضُوئَ وَالصَّلاَۃَ۔",,,3939
3940,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا ضَحِکَ الرَّجُلُ فِی الصَّلاَۃِ أَعَادَ الْوُضُوئَ وَالصَّلاَۃَ۔\n\nقالَ أَبُو بَکْرٍ : یُعِیدُ الصَّلاَۃَ ، وَلاَ یُعِیدُ الْوُضُوئَ۔",,,3940
3941,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُسْتَحَبُّ لِمَنْ صَلَّی وَہُوَ قَاعِدٌ ، أَنْ یُصَلِّیَ رَکْعَتَیْنِ وَہُوَ قَائِمٌ۔",,,3941
3942,"حَدَّثَنَا حَفْصٌ، عَنْ لَیْثٍ، عَنْ طَاوُوسٍ، قَالَ: کَانَ یُسْتَحَبُّ لِمَنْ صَلَّی وَہُوَ قَاعِدٌ، أَنْ یُنشئہا وَہُوَ قَائِمٌ۔",,,3942
3943,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، قَالَ : رُبَّمَا صَلَّیْت وَأَنَا قَاعِدٌ ، فَإِذَا أَرَدْت أَنْ أَرْکَعَ ، قُمْت فَقَرَأْت ، ثُمَّ رَکَعْت۔",,,3943
3944,"حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی صَلاَۃَ اللَّیْلِ قَائِمًا ، فَلَمَّا دَخَلَ فِی السِّنِّ جَعَلَ یُصَلِّی جَالِسًا ، فَإِذَا بَقِیَتْ عَلَیْہِ ثَلاَثُونَ ، أَوْ أَرْبَعُونَ قَامَ فَقَرَأَہَا ، ثُمَّ سَجَدَ۔ (بخاری 1148۔ ابوداؤد 950)",,,3944
3945,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی وَہُوَ جَالِسٌ ، فَإِذَا بَقِیَ مِنَ السُّورَۃِ ثَلاَثُونَ آیَۃً ، أَوْ أَرْبَعُونَ آیَۃً قَامَ فَقَرَأَ ثُمَّ رَکَعَ۔ (مسلم 505)",,,3945
3946,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ عَوْفٍ ، عَنْ مُحَمَّدٍ ، قَالَ : مَنْ قَرَأَ وَہُوَ قَاعِدٌ ، فَإِنَّہُ یَرْکَعُ وَیَسْجُدُ وَہُوَ قَاعِدٌ ، وَمَنْ قَرَأَ وَہُوَ قَائِمٌ ، فَإِنَّہُ یَرْکَعُ وَیَسْجُدُ وَہُوَ قَائِمٌ ۔ وَقَالَ الْحَسَنُ : ہُوَ بِالْخِیَارِ ، أَیَّ ذَلِکَ شَائَ فَعَلَ۔",,,3946
3947,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ یُصَلِّیَ الرَّجُلُ رَکْعَۃً قَائِمًا ، وَرَکْعَۃً قَاعِدًا۔",,,3947
3948,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ الْحَکَمِ وَحَمَّادٍ قَالاَ : لاَ بَأْسَ أَنْ یُصَلِّیَ الرَّجُلُ رَکْعَۃً قَائِمًا ، وَرَکْعَۃً قَاعِدًا۔ ثُمَّ قَالَ : حَدَّثَنَا وَکِیعٌ بِآخِرَۃٍ : عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَلَمْ یَذْکُرْ حَمَّادًا۔",,,3948
3949,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ لاَ یُصَلِّی رَکْعَتَیِ الْفَجْرِ فِی السَّفَرِ۔",,,3949
3950,"حَدَّثَنَا جَرِیرٌ ، عَنْ قَابُوسَ ، عَنْ أَبِیہِ ، عَنْ عَائِشَۃَ ، قَالَتْ: أَمَّا مَا لَمْ یَدَعْ صَحِیحًا ، وَلاَ مَرِیضًا فِی سَفَرٍ، وَلاَ حَضَرٍ غَائِبًا ، وَلاَ شَاہِدًا ، تَعْنِی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَرَکْعَتَانِ قَبْلَ الْفَجْرِ۔",,,3950
3951,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، قَالَ : سَمِعْتُ عَمْرَو بْنَ مَیْمُونٍ الأَوْدِیَّ یَقُولُ : کَانُوا لاَ یَتْرُکُونَ أَرْبَعًا قَبْلَ الظُّہْرِ ، وَرَکْعَتَیْنِ قَبْلَ الْفَجْرِ عَلَی حَالٍ۔",,,3951
3952,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَبِیبِ بْنِ جُرَیٍّ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ لاَ یَدَعُ الرَّکْعَتَیْنِ بَعْدَ الْمَغْرِبِ ، وَالرَّکْعَتَیْنِ قَبْلَ الْفَجْرِ فِی حَضَرٍ ، وَلاَ سَفَرٍ۔",,,3952
3953,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : حَدَّثَنَا ابْنُ عَوْنٍ ، عَنْ مُجَاہِدٍ ، قَالَ : سَأَلْتُہُ أَکَانَ ابْنُ عُمَرَ یُصَلِّی رَکْعَتَیِ الْفَجْرِ؟ قَالَ : مَا رَأَیْتُہُ یَتْرُکُ شَیْئًا فِی سَفَرٍ ، وَلاَ حَضَرٍ۔",,,3953
3954,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنَا مُعَاوِیَۃُ بْنُ صَالِحٍ ، قَالَ : حَدَّثَنِی یُونُسُ بْنُ سَیْفٍ العَنَسِیُّ ، عَنِ الْحَارِثِ بْنِ غُطَیْفٍ ، أَوْ غُضَیْفِ بْنِ الْحَارِثِ الْکِنْدِیِّ ، شَکَّ مُعَاوِیَۃُ ، قَالَ : مَہْمَا رَأَیْتُ نَسِیتُ لَمْ أَنْسَ أَنِّی رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَضَعَ یَدَہُ الْیُمْنَی عَلَی الْیُسْرَی ، یَعْنِی فِی الصَّلاَۃِ۔\n\n(احمد 4/105۔ طبرانی 3399)",,,3954
3955,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سِمَاکٍ ، عَنْ قَبِیصَۃَ بْنِ ہُلْبٍ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَاضِعًا یَمِینَہُ عَلَی شِمَالِہِ فِی الصَّلاَۃِ۔ (ترمذی 252۔ احمد 4/226)",,,3955
3956,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عَاصِمِ بْنِ کُلَیْبٍ ، عَنْ أَبِیہِ ، عَنْ وَائِلِ بْنِ حُجْرٍ ، قَالَ : رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ کَبَّرَ أَخَذَ شِمَالَہٗ بِیَمِینِہِ۔ (ابن ماجہ 810)",,,3956
3957,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الأَعْمَشِ ، عَنْ مُجَاہِدٍ ، عَنْ مُوَرِّقٍ الْعِجْلِیّ ، عَنْ أَبِی الدَّرْدَائِ ، قَالَ : مِنْ أَخْلاَقِ النَّبِیِّینَ وَضْعُ الْیَمِینِ عَلَی الشِّمَالِ فِی الصَّلاَۃِ۔ (ابن حبان 1770۔ طبرانی 11485)",,,3957
3958,"حَدَّثَنَا وَکِیعٌ ، عَنْ یُوسُفَ بْنِ مَیْمُونٍ ، عَنِ الْحَسَنِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : کَأَنِّی أَنْظُرُ إلَی أَحْبَارِ بَنِی إسْرَائِیلَ وَاضِعِی أَیْمَانِہِمْ عَلَی شَمَائِلِہِمْ فِی الصَّلاَۃِ۔",,,3958
3959,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُمَیْرٍ ، عَنْ عَلْقَمَۃَ بْنِ وَائِلِ بْنِ حُجْرٍ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَضَعَ یَمِینَہُ عَلَی شِمَالِہِ فِی الصَّلاَۃِ تَحْتَ السُّرَّۃِ۔",,,3959
3960,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَضَعُ یَمِینَہُ عَلَی شِمَالِہِ فِی الصَّلاَۃِ تَحْتَ السُّرَّۃِ۔",,,3960
3961,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عَبْدُ السَّلاَمِ بْنُ شَدَّادٍ الْجُرَیری أَبُو طَالُوتَ ، عَنْ غَزْوَان بْنِ جَرِیرٍ الضَّبِّیِّ، عَنْ أَبِیہِ ، قَالَ : کَانَ عَلِیٌّ إذَا قَامَ فِی الصَّلاَۃِ وَضَعَ یَمِینَہُ عَلَی رُسْغِہِ ، فَلاَ یُزَالُ کَذَلِکَ حَتَّی یَرْکَعَ مَتَی مَا رَکَعَ، إِلاَّ أَنْ یُصْلِحَ ثَوْبَہُ ، أَوْ یَحُکَّ جَسَدَہُ۔",,,3961
3962,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ زِیَادٍ بن أَبِی الْجَعْدِ ، عَنْ عَاصِمٍ الْجَحْدَرِیِّ ، عَنْ عُقْبَۃَ بْنِ ظُہَیْرٍ ، عَنْ عَلِیٍّ : فِی قَوْلِہِ {فَصَلِّ لِرَبِّکَ وَانْحَرْ} قَالَ : وَضْعُ الْیَمِینِ عَلَی الشِّمَالِ فِی الصَّلاَۃِ۔",,,3962
3963,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا الحَجَّاجُ بْنُ حَسَّانَ ، قَالَ : سَمِعْتُ أَبَا مِجْلَزٍ ، أَوْ سَأَلْتُہُ ، قَالَ : قُلْتُ : کَیْفَ أَصْنَعُ ؟ قَالَ : یَضَعُ بَاطِنَ کَفِّ یَمِینِہِ عَلَی ظَاہِرِ کَفِّ شِمَالِہِ ، وَیَجْعَلُہَا أَسْفَلَ مِنَ السُّرَّۃِ۔",,,3963
3964,"حَدَّثَنَا یَزِیدُ ، قَالَ : أَخْبَرَنَا الْحَجَّاجُ بْنُ أَبِی زَیْنَبَ ، قَالَ : حَدَّثَنِی أَبُو عُثْمَانَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مَرَّ بِرَجُلٍ یُصَلِّی وَقَدْ وَضَعَ شِمَالَہُ عَلَی یَمِینِہِ ، فَأَخَذَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَمِینَہُ فَوَضَعَہَا عَلَی شِمَالِہِ۔",,,3964
3965,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ أَنْ تَضَعَ الْیُمْنَی عَلَی الْیُسْرَی فِی الصَّلاَۃِ۔",,,3965
3966,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنْ زِیَادِ بْنِ زَیْدٍ السُّوَائِیِّ ، عَنْ أَبِی جُحَیْفَۃَ ، عَنْ عَلِیٍّ ، قَالَ : مِنْ سُنَّۃِ الصَّلاَۃِ وَضْعُ الأَیْدِی عَلَی الأَیْدِی تَحْتَ السُّرَرِ۔ (ابوداؤد 495۔ دار قطنی 286)",,,3966
3967,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ ثَوْرٍ ، عَنْ خَالِدِ بْنِ مَعْدَانَ ، عَنْ أَبِی زِیَادٍ مَوْلَی آلِ دَرَّاجٍ قَالَ : مَا رَأَیْتُ فَنَسِیتُ فَإِنِّی لَمْ أَنْسَ أَنَّ أَبَا بَکْرٍ کَانَ إذَا قَامَ فِی الصَّلاَۃِ ، قَالَ : ہَکَذَا فَوَضَعَ الْیُمْنَی عَلَی الْیُسْرَی۔",,,3967
3968,حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَضَعَ الْیُمْنَی عَلَی الشِّمَالِ ، فَیَقُولُ عَلَی کَفِّہِ، أَوْ عَلَی الرُّسْغِ ، وَیَقُولُ فَوْقَ ذَلِکَ ، وَیَقُولُ أَہْلُ الْکِتَابِ یَفْعَلُونَہُ۔,,,3968
3969,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْمُسْتَمِرِّ بْنِ الرَّیَّانِ ، عَنْ أَبِی الْجَوْزَائِ ؛ أَنَّہُ کَانَ یَأْمُرُ أَصْحَابَہُ أَنْ یَضَعَ أَحَدُہُمْ یَدَہُ الْیُمْنَی عَلَی الْیُسْرَی ، وَہُوَ یُصَلِّی۔,,,3969
3970,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ (ح) ، وَمُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُمَا کَانَا یُرْسِلاَنِ أَیْدِیَہُمَا فِی الصَّلاَۃِ۔,,,3970
3971,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا یَزِیدُ بْنُ إبْرَاہِیمَ ، قَالَ : سَمِعْتُ عَمْرَو بْنَ دِینَارٍ ، قَالَ : کَانَ ابْنُ الزُّبَیْرِ إذَا صَلَّی یُرْسِلُ یَدَیْہِ۔",,,3971
3972,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ سُئِلَ عَنِ الرَّجُلِ یُمْسِکُ یَمِینَہُ بِشِمَالِہِ ؟قَالَ : إنَّمَا فُعِلَ ذَلِکَ مِنْ أَجْلِ الدَّمِ۔",,,3972
3973,"حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، قَالَ : مَا رَأَیْت ابْنَ الْمُسَیَّبِ قَابِضًا یَمِینَہُ فِی الصَّلاَۃِ ، کَانَ یُرْسِلُہا۔",,,3973
3974,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عَبْدِ اللہِ بْنِ الْعَیْزَارِ ، قَالَ : کُنْتُ أَطُوفُ مَعَ سَعِیدِ بْنِ جُبَیْرٍ ، فَرَأَی رَجُلاً یُصَلِّی وَاضِعًا إحْدَی یَدَیْہِ عَلَی الأُخْرَی ، ہَذِہِ عَلَی ہَذِہِ ، وَہَذِہِ عَلَی ہَذِہِ ، فَذَہَبَ فَفَرَّقَ بَیْنَہُمَا ثُمَّ جَائَ۔",,,3974
3975,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ وَمَنْصُورٌ ، عَنِ ابْنِ سِیرِینَ ، عَنْ یَحْیَی بْنِ الْجَزَّارِ ؛ أَنَّ ابْنَ مَسْعُودٍ صَلَّی وَعَلَی بَطْنِہِ فَرْثٌ وَدَمٌ ، قَالَ : فَلَمْ یُعِدِ الصَّلاَۃَ۔",,,3975
3976,حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ أَمْسَکَ عَنْ ہَذَا الْحَدِیثِ بَعْدُ ، وَلَمْ یُعْجِبْہُ۔,,,3976
3977,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا یُونُسُ، عَنِ الْحَسَنِ، قَالَ: مَا فِی نَضَخَاتٍ مِنْ دَمٍ مَا یُفْسِدُ عَلَی رَجُلٍ صَلاَتَہُ۔",,,3977
3978,حَدَّثَنَا وَکِیعٌ ، عَنْ عَمْرو بْنِ شَیْبَۃَ ، عَنْ قَارِظٍ أَخِیہِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ کَانَ لاَ یَنْصَرِفُ مِنَ الدَّمِ حَتَّی یَکُونَ مِقْدَارَ الدِّرْہَمِ۔,,,3978
3979,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا ؟ فَقَالَ الْحَکَمُ : إذَا کَانَ مِقْدَارَ الدِّرْہَمِ ، وَقَالَ حَمَّادٌ : إذَا کَانَ مِقْدَارَ الْمِثْقَالِ ، ثُمَّ قَالَ : أَوِ الدِّرْہَمِ۔",,,3979
3980,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَبِی الرَّبِیعِ ، قَالَ : رَأَیْتُ مُجَاہِدًا فِی ثَوْبِہِ دَمٌ یُصَلِّی فِیہِ أَیَّامًا۔",,,3980
3981,"حَدَّثَنَا وَکِیعٌ ، عَنْ حُسَیْنِ بْنِ صَالِحٍ ، عَنْ عِیسَی بْنِ أَبِی عَزَّۃَ ، عَنِ الشَّعْبِیِّ ؛ فِی رَجُلٍ صَلَّی وَفِی ثَوْبِہِ دَمٌ ، قَالَ : لاَ یُعِیدُ۔",,,3981
3982,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَاصِمٍ ، قَالَ : رَأَیْتُ أَبَا وَائِلٍ یُصَلِّی وَفِی ثَوْبِہِ قَطَرَاتٌ مِنْ دَمٍ۔",,,3982
3983,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَاسِینَ ، عَنِ الزُّہْرِیِّ ، قَالَ : إذَا کَانَ قَدْرَ الدِّرْہَمِ أَعَادَ۔",,,3983
3984,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَقُولُ فِی الدَّمِ یَکُونُ فِی الثَّوْبِ قَدْرَ الدِّینَارِ، أَوِ الدِّرْہَمِ ، قَالَ : فَلْیُعِدْ۔",,,3984
3985,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ إبْرَاہِیمَ ، قَالَ : سَأَلْتُہ عَنِ الرَّجُلِ یَری فِی ثَوْبِہِ الدَّمُ وَہُوَ فِی الصَّلاَۃِ ؟ قَالَ : إِنْ کَانَ کَثِیرًا فَلْیُلْقِ الثَّوْبَ عَنْہُ ، وَإِنْ کَانَ قَلِیلاً فَلْیَمْضِ فِی صَلاَتِہِ۔",,,3985
3986,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَاصِمٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : سَأَلْتُہُ عَنِ الدَّمِ أَرَاہُ فِی ثَوْبِی بَعْدَ مَا أُصَلِّی؟ قَالَ : اغْسِلْہُ وَأَعِدِ الصَّلاَۃَ۔",,,3986
3987,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَیُّوبَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ؛ فِی رَجُلٍ صَلَّی وَفِی ثَوْبِہِ دَمٌ ، فَلَمَّا انْصَرَفَ رَآہُ ، قَالَ : لاَ یُعِیدُ۔",,,3987
3988,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا صَلَّیْتَ فَرَأَیْتَ فِی ثَوْبِکَ دَمًا فَلاَ تُعِدْ ، قَدْ مَضَتْ صَلاَتُک۔",,,3988
3989,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ لَمْ یَکُنْ یَرَی فِی الدَّمِ وَالْمَنِیِّ فِی الثَّوْبِ أَنْ تُعَادَ مِنْہُ الصَّلاَۃُ۔,,,3989
3990,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ مُطَرِّفٍ ، عَنِ الْحَکَمِ ؛ فِی رَجُلٍ صَلَّی وَفِی ثَوْبِہِ دَمٌ ، قَالَ : إِنْ کَانَ کَثِیرًا یُعِیدُ مِنْہُ الصَّلاَۃ ، وَإِنْ کَانَ قَلِیلاً لَمْ یُعِدْ۔",,,3990
3991,"حَدَّثَنَا شَرِیکٌ، عَنْ أَبِی إِسْحَاقَ، عَنْ عَطَائٍ، قَالَ: رَأَیْتُہُ یُصَلِّی وَفِی ثَوْبِہِ کَفٌّ مِنْ دَمٍ۔",,,3991
3992,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، عَنْ زُیَیْدِ بْنِ الصَّلْتِ ) ؛ أَنَّ عُمَرَ غَسَلَ مَا رَأَی فِی ثَوْبِہِ ، وَنَضَحَ مَا لَمْ یَرَ ، وَأَعَادَ بَعْدَ مَا ارْتَفَعَ الضُّحَی مُتَمَکِّنًا۔,,,3992
3993,"حَدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سُلَیْمَانَ بْنِ یَسَارٍ ؛ أَنَّ عُمَرَ صَلَّی صَلاَۃَ الْغَدَاۃِ ، ثُمَّ غَدَا إلَی أَرْضٍ لَہُ بِالْجُرْفِ ، فَوَجَدَ فِی ثَوْبِہِ احْتِلاَمًا ، قَالَ : فَغَسَلَ الاحْتِلاَمَ وَاغْتَسَلَ ، ثُمَّ أَعَادَ صَلاَۃَ الصُّبْحِ۔",,,3993
3994,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَفْلَحَ ، عَنْ أَبِیہِ ، قَالَ : صَلَّیْت وَفِی ثَوْبِی جَنَابَۃٌ ، فَأَمَرَنِی ابْنُ عُمَرَ فَأَعَدْت۔",,,3994
3995,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یُصَلِّی وَفِی ثَوْبِہِ جَنَابَۃٌ ، قَالَ : مَضَتْ صَلاَتُہُ ، وَلاَ إعَادَۃَ عَلَیْہِ۔",,,3995
3996,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ وَمَنْصُورٌ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : یُعِیدُ مَا کَانَ فِی وَقْتٍ۔",,,3996
3997,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ قَالَ : مَنْ صَلَّی وَفِی ثَوْبِہِ جَنَابَۃٌ ، فَلاَ إعَادَۃَ عَلَیْہِ۔",,,3997
3998,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا وَجَدَ فِی ثَوْبِہِ دَمًا ، أَوْ مَنِیًّا غَسَلَہُ ، وَلَمْ یُعِدِ الصَّلاَۃَ۔",,,3998
3999,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : کَانَ عَبْدُ اللہِ یَنْہَضُ فِی الصَّلاَۃِ عَلَی صُدُورِ قَدَمَیْہِ۔",,,3999
4000,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ یَزِیدَ ، عَنْ یَزِیدَ بْنِ زِیَادِ بْنِ أَبِی الْجَعْدِ ، عَنْ عُبَیْدِ بْنِ أَبِی الْجَعْدِ ، قَالَ : کَانَ عَلِیٌّ یَنْہَضُ فِی الصَّلاَۃِ عَلَی صُدُورِ قَدَمَیْہِ۔",,,4000
4001,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : کَانَ عَبْدُ اللہِ یَنْہَضُ فِی الصَّلاَۃِ عَلَی صُدُورِ قَدَمَیْہِ۔",,,4001
4002,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ خَیْثَمَۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : رَأَیْتُہُ یَنْہَضُ فِی الصَّلاَۃِ عَلَی صُدُورِ قَدَمَیْہِ۔",,,4002
4003,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ مُحَمَّدِ بْنِ عَبْدِ اللہِ ، قَالَ : کَانَ ابْنُ أَبِی لَیْلَی یَنْہَضُ فِی الصَّلاَۃِ عَلَی صُدُورِ قَدَمَیْہِ۔",,,4003
4004,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ عِیسَی بْنِ مَیْسَرَۃَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ عُمَرَ وَعَلِیًّا وَأَصْحَابَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانُوا یَنْہَضُونَ فِی الصَّلاَۃِ عَلَی صُدُورِ أَقْدَامِہِمْ۔,,,4004
4005,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ وَہْبِ بْنِ کَیْسَانَ ، قَالَ : رَأَیْتُ ابْنَ الزُّبَیْرِ إذَا سَجَدَ السَّجْدَۃَ الثَّانِیَۃَ قَامَ کَمَا ہُوَ عَلَی صُدُورِ قَدَمَیْہِ۔",,,4005
4006,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ ، عَنْ وَہْبِ بْنِ کَیْسَانَ ، عَنِ ابْنِ الزُّبَیْرِ ؛ بِنَحْوِہِ۔,,,4006
4007,حَدَّثَنَا وَکِیعٌ، عَنْ أُسَامَۃَ، وَالْعُمَرِیِّ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ یَنْہَضُ فِی الصَّلاَۃِ عَلَی صُدُورِ قَدَمَیْہِ۔,,,4007
4008,"حَدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن أَبِی الْمُعَلَّی ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ ابْنُ مَسْعُودٍ فِی الرَّکْعَۃِ الأُولَی وَالثَّالِثَۃِ لاَ یَقْعُدُ حِینَ یُرِیدُ أَنْ یَقُومَ حَتَّی یَقُومَ۔",,,4008
4009,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ، قَالَ: أَخْبَرَنَا مُحَمَّدُ بْنُ عَمْرٍو ، عَنِ الزُّہْرِیِّ ، قَالَ : کَانَ أَشْیَاخُنَا لاَ یُمَایلُونَ ، یَعْنِی إذَا رَفَعَ أَحَدُہُمْ رَأْسَہُ مِنَ السَّجْدَۃِ الثَّانِیَۃِ فِی الرَّکْعَۃِ الأُولَی وَالثَّالِثَۃِ یَنْہَضُ کَمَا ہُوَ ، وَلَمْ یَجْلِسْ۔",,,4009
4010,حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُسْرِعُ فِی الْقِیَامِ فِی الرَّکْعَۃِ الأُولَی مِنْ آخِرِ سَجْدَۃٍ۔,,,4010
4011,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنِ النُّعْمَانِ بْنِ أَبِی عَیَّاشٍ ، قَالَ : أَدْرَکْت غَیْرَ وَاحِدٍ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَکَانَ إذَا رَفَعَ رَأْسَہُ مِنَ السَّجْدَۃِ فِی أَوَّلِ رَکْعَۃٍ وَالثَّالِثَۃِ ، قَامَ کَمَا ہُوَ وَلَمْ یَجْلِسْ۔",,,4011
4012,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ خَالِدٍ ، قَالَ : رَأَیْتُ أَبَا قِلاَبَۃَ وَالْحَسَنَ یَعْتَمِدَانِ عَلَی أَیْدِیہِمَا فِی الصَّلاَۃِ۔",,,4012
4013,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یَعْتَمِدَ الرَّجُلُ عَلَی یَدَیْہِ إذَا نَہَضَ فِی الصَّلاَۃِ۔,,,4013
4014,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَرِہَہُ۔,,,4014
4015,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُحَمَّدِ بْنِ جُحَادَۃَ ، عَنِ الْحَارِثِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَکْرَہُ ذَلِکَ ، إِلاَّ أَنْ یَکُونَ شَیْخًا کَبِیرًا ، أَوْ مَرِیضًا۔,,,4015
4016,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی الأَسْوَدَ وَشُرَیْحًا وَمَسْرُوقًا یَعْتَمِدُونَ عَلَی أَیْدِیہِمْ إذَا نَہَضُوا۔",,,4016
4017,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِِ ، عَنْ إسْمَاعِیلَ ، قَالَ : رَأَیْتُ قَیْسًا یَعْتَمِدُ عَلَی یَدَیْہِ إذَا نَہَضَ۔",,,4017
4018,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنِ الأَزْرَقِ بْنِ قَیْسٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یَنْہَضُ فِی الصَّلاَۃِ وَیَعْتَمِدُ عَلَی یَدَیْہِ۔",,,4018
4019,حَدَّثَنَا وَکِیعٌ ، عَنِ الْعُمَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَعْتَمِدُ عَلَی یَدَیْہِ۔,,,4019
4020,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ إِسْحَاقَ ، عَنْ زِیَادِ بْنِ زَیْدٍ السُّوَائِیِّ ، عَنْ أَبِی جُحَیْفَۃَ ، عَنْ عَلِیٍّ ، قَالَ : إنَّ مِنَ السُّنَّۃِ فِی الصَّلاَۃِ الْمَکْتُوبَۃِ إذَا نَہَضَ الرَّجُلُ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ أَنْ لاَ یَعْتَمِدَ بِیَدَیْہِ عَلَی الأَرْضِ ، إِلاَّ أَنْ یَکُونَ شَیْخًا کَبِیرًا لاَ یَسْتَطِیعُ۔ (بیہقی 136)",,,4020
4021,حَدَّثَنَا وَکِیعٌ ، عَنْ مَہْدِیِّ بْنِ مَیْمُونٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَرِہَ أَنْ یَعْتَمِدَ ، وَکَانَ الْحَسَنُ یَعْتَمِدُ۔,,,4021
4022,"حَدَّثَنَا أَبُو دَاوُدَ ، عَنِ الْہُذَیْلِ بْنِ بِلاَلٍ ، قَالَ : رَأَیْتُ عَطَائً یَعْتَمِدُ إذَا نَہَضَ۔",,,4022
4023,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : کَانَ مَالِکُ بْنُ الْحُوَیْرِثِ یَأْتِینَا فَیَقُولُ : أَلاَّ أُحَدِّثُکُمْ عَنْ صَلاَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ فَیُصَلِّی فِی غَیْرِ وَقْتِ صَلاَۃٍ ، فَإِذَا رَفَعَ رَأْسَہُ مِنَ السَّجْدَۃِ الثَّانِیَۃِ فِی أَوَّلِ رَکْعَۃٍ اسْتَوَی قَاعِدًا ، ثُمَّ قَامَ وَاعْتَمَدَ۔ (بخاری 823۔ ابوداؤد 840)",,,4023
4024,"حَدَّثَنَا حَاتِمُ بْنُ وَرْدَانَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ سُئِلَ عَنْ رَجُلٍ لَمْ یَقْرَأْ بِفَاتِحَۃِ الْکِتَابِ ؟ قَالَ : إِنْ کَانَ قَرَأَ غَیْرَہَا أَجْزَأَ عَنْہُ۔",,,4024
4025,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ حَمَّادٍ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ عَنِ الرَّجُلِ یَنْسَی فَاتِحَۃَ الْکِتَابِ ، فَیَقْرَأُ سُورَۃً ، أَوْ یَقْرَأُ فَاتِحَۃَ الْکِتَابِ ، وَلاَ یَقْرَأُ مَعَہَا شَیْئًا ؟ قَالَ : یُجْزئہ۔",,,4025
4026,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَالْحَکَمِ ؛ فِی رَجُلٍ نَسِیَ فَاتِحَۃَ الْکِتَابِ ، قَالَ الشَّعْبِیُّ : یَسْجُدُ سَجْدَتَیِ السَّہْوِ ، وَقَالَ الْحَکَمُ : یَقْرَؤُہَا إذَا ذُکر۔",,,4026
4027,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَرَأَ ، {قُلْ ہُوَ اللَّہُ أَحَدٌ} ، وَنَسِیَ فَاتِحَۃَ الْکِتَابِ ، قَالَ : تُجْزئہ۔",,,4027
4028,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ مُحَمَّدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِی سَلَمَۃَ ، قَالَ : صَلَّی عُمَرُ الْمَغْرِبَ فَلَمْ یَقْرَأْ ، فَلَمَّا انْصَرَفَ ، قَالَ لَہُ النَّاسُ : إنَّک لَمْ تَقْرَأْ ، قَالَ : فَکَیْفَ کَانَ الرُّکُوعُ وَالسُّجُودُ تَامٌّ ہُوَ ؟ قَالُوا : نَعَمْ ، فَقَالَ : لاَ بَأْسَ ، إنِّی حَدَّثْت نَفْسِی بِعِیرٍ جَہَّزْتہَا بِأَقْتَابِہَا وَحَقَائِبِہَا۔",,,4028
4029,"حَدَّثَنَا ابْنُ أَبِی غَنِیَّۃَ ، عَنْ أَبِیہِ ، عَنِ الْحَکَمِ ، قَالَ : إذَا صَلَّی الرَّجُلُ فَنَسِیَ أَنْ یَقْرَأَ حَتَّی فَرَغَ مِنْ صَلاَتِہِ ، قَالَ : تُجْزئہ مَا کُلُّ النَّاسِ تَقْرَأُ۔",,,4029
4030,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ (ح) وَعَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ؛ فِی رَجُلٍ نَسِیَ الْقِرَائَۃَ فِی الظُّہْرِ وَالْعَصْرِ حَتَّی فَرَغَ مِنْ صَلاَتِہِ ، قَالاَ : أَجْزَأَتْ عَنْہُ إذَا أَتَمَّ الرُّکُوعَ وَالسُّجُودَ۔",,,4030
4031,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، قَالَ : جَائَ رَجُلٌ إلَی عَلِیٍّ ، فَقَالَ : إنِّی صَلَّیْت وَنَسِیت أَنْ أَقْرَأَ ؟ فَقَالَ لَہُ : أَتْمَمْتَ الرُّکُوعَ وَالسُّجُودَ ؟ قَالَ : نَعَمْ ، قَالَ : یُجْزِئُکَ۔",,,4031
4032,"حَدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا نَسِیَ الْقِرَائَۃَ ، فَإِنَّہُ لاَ یَعْتَدُّ بِتِلْکَ الرَّکْعَۃِ۔",,,4032
4033,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لاَ صَلاَۃَ إِلاَّ بِقِرَائَۃٍ۔",,,4033
4034,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن ہَمَّامٍ ، قَالَ : صَلَّی عُمَرُ الْمَغْرِبَ فَلَمْ یَقْرَأْ فِیہَا ، فَلَمَّا انْصَرَفَ ، قَالُوا لَہُ : یَا أَمِیرَ الْمُؤْمِنِینَ ، إنَّک لَمْ تَقْرَأْ ، فَقَالَ : إنِّی حَدَّثْت نَفْسِی وَأَنَا فِی الصَّلاَۃِ بِعِیرٍ وَجَّہْتہَا مِنَ الْمَدِینَۃِ ، فَلَمْ أَزَلْ أُجَہِّزُہَا حَتَّی دَخَلَتِ الشَّامَ ، قَالَ : ثُمَّ أَعَادَ الصَّلاَۃَ وَالْقِرَائَۃَ۔",,,4034
4035,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ، قَالَ : کَانَ إذَا کَبَّرَ سَکَتَ سَاعَۃً لاَ یَقْرَأُ ، فَکَبَّرَ ، فَرَکَعَ قَبْلَ أَنْ یَقْرَأَ ، فَرَفَعَ رَأْسَہُ فَقَرَأَ ، وَأَوْمَأَ أَنْ لاَّ تَرْکَعُوا ، وَافْتَتَحَ الْقِرَائَۃَ بِـ (الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ)۔",,,4035
4036,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا رَکَعْتَ فَرَفَعْتَ رَأْسَک ، فَاقْرَأْ إِنْ شِئْتَ بَعْدَ مَا تَرْفَعُ رَأْسَک ، ثُمَّ ارْکَعْ ، وَإنْ شِئْت فَاسْجُدْ کَمَا أَنْتَ۔",,,4036
4037,"حَدَّثَنَا وَکِیعٌ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، قَالَ : کَانَ الْمَسْجِدُ یُرَشُّ وَیُقَمُّ عَلَی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَبِی بَکْرٍ۔ (بخاری 458۔ ابوداؤد 3195)",,,4037
4038,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حَدَّثَنَا کَثِیرُ بْنُ زَیْدٍ ، عَنِ الْمُطَّلِبِ بْنِ عَبْدِ اللہِ بْنِ حَنْطَبٍ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ أَتَی مَسْجِدَ قُبَائَ عَلَی فَرَسٍ لَہُ فَصَلَّی فِیہِ ، ثُمَّ قَالَ : یَا یَرْفَأُ ، ائتنی بِجَرِیدَۃٍ ، قَالَ : فَأَتَاہُ بِجَرِیدَۃٍ ، فَاحْتَجَزَ عُمَرُ بِثَوْبِہِ ، ثُمَّ کَنَسَہُ۔",,,4038
4039,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو عَاصِمٍ الثَّقَفِیُّ ، قَالَ : کُنْتُ مَعَ الشَّعْبِیِّ فِی الْمَسْجِدِ ، فَجَعَلَ یَتَطَأْطَأُ ، فَقُلْتُ : مَا تَصْنَعُ یَا أَبَا عَمْرٍو ؟ قَالَ : أَلْتَقِطُ الْقَصَبَۃَ وَالْخَشَاشَۃَ وَالشَّیْئَ مِنَ الْمَسْجِدِ ، قَالَ : وَکَانَ أَبُو عَاصِمٍ مَکْفُوفًا۔",,,4039
4040,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِکْرِمَۃَ بْنِ عَمَّارٍ ، قَالَ : رَأَیْتُ سَالِمًا کَنَسَ مَکَانًا ، ثُمَّ صَلَّی فِیہِ۔",,,4040
4041,حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ یَعْقُوبَ بْنِ زَیْدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَتْبَعُ غُبَارَ الْمَسْجِدِ بِجَرِیدَۃٍ۔,,,4041
4042,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ سِمَاکٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی عَلَی خُمْرَۃٍ۔ (ترمذی 331۔ احمد 1/358)",,,4042
4043,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، وَعَلِیُّ بْنُ مُسْہِرٍ ، عَنِ الشَّیْبَانِیِّ ، عَنْ عَبْدِ اللہِ بْنِ شَدَّادٍ ، قَالَ : أَخْبَرَتْنِی مَیْمُونَۃُ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی عَلَی الْخُمْرَۃِ۔ (بخاری 333۔ ابوداؤد 656)",,,4043
4044,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ أَبِی سَعِیدٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی عَلَی حَصِیرٍ۔ (مسلم 271۔ احمد 3/10),,,4044
4045,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، عَنْ أُمِّ سُلَیْمٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی فِی بَیْتِہَا عَلَی الْخُمْرَۃِ۔ (نسائی 816۔ احمد 6/377),,,4045
4046,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أُمِّ کُلْثُومٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی عَلَی الْخُمْرَۃِ۔ (احمد 6/302۔ ابو یعلی 6884),,,4046
4047,حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنِ الأَزْرَقِ بْنِ قَیْسٍ ، عَنْ ذَکْوَانَ ، عَنْ عَائِشَۃَ ؛أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یُصَلِّی عَلَی الْخُمْرَۃِ۔ (احمد 6/209۔ طیالسی 1544),,,4047
4048,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ الْمُنْذِرِ بْنِ الْجَارُودِ ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : صَنَعَ بَعْضُ عُمُومَتِی لِلنَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ طَعَامًا ، فَقَالَ : إنِّی أُحِبُّ أَنْ تَأْکُلَ فِی بَیْتِی وَتُصَلِّیَ فِیہِ ، قَالَ : فَأَتَاہُ وَفِی الْبَیْتِ فَحْلٌ مِنْ تِلْکَ الْفُحُولِ ، فَأَمَرَ بِجَانِبٍ مِنْہُ فَکُنِسَ وَرُشَّ ، فَصَلَّی وَصَلَّیْنَا مَعَہُ۔ (احمد 3/112۔ ابو یعلی 4227)",,,4048
4049,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ یُصَلِّی عَلَی الْخُمْرَۃِ۔",,,4049
4050,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عُمَرُ بْنُ ذَرٍّ ، عَنْ یَزِیدَ الْفَقِیرِ ، قَالَ : رَأَیْتُ جَابِرَ بْنَ عَبْدِ اللہِ یُصَلِّی عَلَی حَصِیرٍ مِنْ بَرْدِیٍّ۔",,,4050
4051,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الْعُمَرِیُّ ، عَنْ إِسْحَاقَ بْنِ عَبْدِ اللہِ بْنِ أَبِی طَلْحَۃَ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی عَلَی حَصِیرٍ۔ (بخاری 380۔ ابوداؤد 612)",,,4051
4052,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ الْغَازِ ، عَنْ مَکْحُولٍ ، قَالَ : رَأَیْتُہُ یُصَلِّی عَلَی الْحَصِیرِ ، وَیَسْجُدُ عَلَیْہِ۔",,,4052
4053,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ صَفْوَانَ ، عَنْ عَطَائِ بْنِ أَبِی مَرْوَانَ ، عَنْ أَبِیہِ ، عَنْ أَبِی ذَرٍّ ؛ أَنَّہُ کَانَ یُصَلِّی عَلَی الْخُمْرَۃِ۔,,,4053
4054,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ ثَابِتِ بْنِ عُبَیْدِ اللہِ ، قَالَ : رَأَیْتُ زَیْدَ بْنَ ثَابِتٍ یُصَلِّی عَلَی حَصِیرٍ یَسْجُدُ عَلَیْہِ۔",,,4054
4055,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ عَدِیِّ بْنِ ثَابِتٍ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی زَیْدَ بْنَ ثَابِتٍ یُصَلِّی عَلَی حَصِیرٍ۔",,,4055
4056,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ تَوْبَۃَ الْعَنْبَرِیِّ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یُصَلِّی عَلَی حَصِیرٍ۔,,,4056
4057,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : الصَّلاَۃُ عَلَی الْخُمْرَۃِ سُنَّۃٌ۔",,,4057
4058,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُجَالِد ، عَنْ عَامِرٍ ، قَالَ : صَلَّیْت مَعَ ابْنِ عَبَّاسٍ فِی بَیْتِہِ عَلَی مِسْحٍ یَسْجُدُ عَلَیْہِ۔",,,4058
4059,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عِیسَی بْنِ سِنَانٍ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یُصَلِّی عَلَی مِسْحٍ۔",,,4059
4060,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُجَالِد ، عَنْ عَامِرٍ ، عَنْ جَابِرٍ ؛ أَنَّہُ صَلَّی عَلَی مِسْحٍ۔,,,4060
4061,"حَدَّثَنَا عَائِذُ بْنُ حَبِیبٍ ، عَنْ أَبِیہِ ، عَنْ رَجُلٍ مِنْ بَکْرِ بْنِ وَائِلٍ ، قَالَ : رَأَیْتُ عَلِیًّا یُصَلِّی عَلَی مُصَلًّی مِنْ مُسُوحٍ ، یَرْکَعُ عَلَیْہِ وَیَسْجُدُ۔",,,4061
4062,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ الأَحْوَصِ بْنِ حَکِیمٍ ، عَنْ أَبِی الزَّاہِرِیَّۃِ ، عَنْ جُبَیْرِ بْنِ نُفَیْرٍ ؛ أَنَّ أَبَا الدَّرْدَائِ کَانَ یُصَلِّی عَلَی مِسْحٍ یَسْجُدُ عَلَیْہِ۔,,,4062
4063,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ وَأَصْحَابِہِ ؛ أَنَّہُمْ کَانُوا یَکْرَہُونَ أَنْ یُصَلُّوا عَلَی الطَّنَافِسِ وَالْفِرَائِ وَالْمُسُوحِ۔,,,4063
4064,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ صَالِحِ بْنِ حَیَّانَ ، عَنْ شَقِیقِ بْنِ سَلَمَۃَ ، قَالَ : صَلَّیْت مَعَ ابْنِ مَسْعُودٍ عَلَی مِسْحٍ ، فَکَانَ یَسْجُدُ عَلَیْہِ۔",,,4064
4065,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی التَّیَّاحِ الضُّبَعِیِّ ، قَالَ : سَمِعْتُ أَنَسَ بْنَ مَالِکٍ ، یَقُولُ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُخَالِطُنَا ، فَیَقُولُ لإِخٍ لِی : یَا أَبَا عُمَیْرٍ ، مَا فَعَلَ النُّغَیْرُ ، قَالَ : وَنَضَحَ بِسَاطًا لَنَا فَصَلَّی عَلَیْہِ۔ (بخاری 6129۔ مسلم 1692)",,,4065
4066,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَمْعَۃَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، وَسَلَمَۃَ بْنِ وَہْرَام ، قَالَ أَحَدُہُمَا : عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی عَلَی بِسَاطٍ۔ (احمد 232۔ حاکم 259)",,,4066
4067,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، وَعِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عُثْمَانَ بْنِ أَبِی سَوْدَۃَ ، عَنْ خُلَیْدٍ ، عَنْ أَبِی الدَّرْدَائِ ، قَالَ : مَا أُبَالِی لَوْ صَلَّیْت عَلَی سِتِّ طَنَافِسَ بَعْضُہَا فَوْقَ بَعْضٍ۔",,,4067
4068,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الأَعْمَش ، عَنْ سَعِیدِ بْنِ جُبَرٍن ، قَالَ : صَلَّی بِنَا ابْنُ عَبَّاسٍ عَلَی طُنْفُسَۃٍ قَدْ طَبَقَتِ الْبَیْتَ صَلاَۃَ الْمَغْرِبِ۔",,,4068
4069,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، قَالَ : شَہِدْت مُحِلاًّ یَقُولُ لإِبْرَاہِیمَ : إنِّی رَأَیْت أَبَا وَائِلٍ یُصَلِّی عَلَی طُنْفُسَۃٍ ، فَقَالَ إبْرَاہِیمُ : کَانَ أَبُو وَائِلٍ خَیْرًا مِنِّی۔",,,4069
4070,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ تَوْبَۃَ الْعَنْبَرِیِّ ، عَنْ عِکْرِمَۃَ بْنِ خَالِدٍ الْمَخْزُومِیِّ ، عَنْ عَبْدِ اللہِ بْنِ عَمَّارٍ، قَالَ : رَأَیْتُ عُمَرَ یُصَلِّی عَلَی عَبْقَرِیٍّ۔",,,4070
4071,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : رَأَیْتُ عَطَائً یُصَلِّی عَلَی بِسَاطٍ أَبْیَضَ فِی الْمَسْجِدِ الْحَرَامِ ، وَلَیْسَ بَیْنَہُ وَبَیْنَ الطَّوَافِ أَحَدٌ۔",,,4071
4072,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃِ عَلَی الطُّنْفُسَۃِ۔",,,4072
4073,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنِ الرَّبِیعِ بْنِ الْمُنْذِرِ ، عَنْ عَبْدِ الْمَلِکِ بْنِ سَعِیدٍ ، قَالَ : رَأَیْتُ أَبِی سَعِیدَ بْنَ جُبَیْرٍ یُصَلِّی عَلَی بِسَاطٍ یَسْجُدُ عَلَیْہِ۔",,,4073
4074,"حَدَّثَنَا بِشْرُ بْنُ مُفَضَّلٍ ، عَنْ سَلَمَۃَ بْنِ عَلْقَمَۃَ ، عَنْ نَافِعٍ ، قَالَ : کَانَ ابْنُ عُمَرَ إذَا صَلَّی عَلَی شَیْئٍ سَجَد عَلَیْہِ۔",,,4074
4075,"حَدَّثَنَا ہَاشِمُ بْنُ الْقَاسِمِ ، عَنْ شُعْبَۃَ ، عَنْ تَوْبَۃَ الْعَنْبَرِیِّ ، قَالَ : سَمِعْتُ بَکْرَ بْنَ عَبْدِ اللہِ الْمُزَنِیّ یَقُولُ : إنَّ قَیْسَ بْنَ عُبَادٍ الْقَیْسِیَّ صَلَّی عَلَی لِبْدِ دَابَّتِہِ۔",,,4075
4076,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، قَالَ ، رَأَیْت مُرَّۃً الْہَمْدَانِیَّ یُصَلِّی عَلَی لِبْدٍ۔",,,4076
4077,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُصَلِّی عَلَی طُنْفُسَۃٍ قَدَمَاہُ وَرُکْبَتَاہُ عَلَیْہَا ، وَیَدَاہُ وَوَجْہُہُ عَلَی الأَرْضِ ، أَوْ عَلَی بُورِیٍّ۔,,,4077
4078,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، قَالَ : أَخْبَرَنَا مَنْ رَأَی إبْرَاہِیمَ وَالْحَسَنَ یُصَلِّیَانِ عَلَی بِسَاطٍ فِیہِ تَصَاوِیرُ۔",,,4078
4079,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : الصَّلاَۃُ عَلَی الطُّنْفُسَۃِ مُحْدَثٌ۔",,,4079
4080,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : الصَّلاَۃُ عَلَی الطُّنْفُسَۃِ مُحْدَثٌ۔",,,4080
4081,حَدَّثَنَا زِیَادُ بْنُ الرَّبِیعِ ، عَنْ صَالِحٍ الدَّہَان ؛ أَنَّ جَابِرَ بْنَ زَیْدٍ کَانَ یَکْرَہُ الصَّلاَۃَ عَلَی کُلِّ شَیْئٍ مِنَ الْحَیَوَانِ ، وَیَسْتَحِبُّ الصَّلاَۃَ عَلَی کُلِّ شَیْئٍ مِنْ نَبَاتِ الأَرْضِ۔,,,4081
4082,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ أَبِی عُبَیْدَۃَ ، قَالَ : کَانَ عَبْدُ اللہِ لاَ یُصَلِّی ، وَلاَ یَسْجُدُ إِلاَّ عَلَی الأَرْضِ۔",,,4082
4083,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَعْقِلِ بْنِ عُبَیْدِ اللہِ ، عَنْ عَبْدِ الْکَرِیمِ الْجَزَرِیِّ ، عَنْ مُجَاہِدٍ ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃِ عَلَی الأَرْضِ وَعَلَی مَا أَنْبَتَتْ۔",,,4083
4084,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ وَحُصَیْنٍ ، قَالَ سُفْیَانُ : أَوْ أَحَدُہُمَا ، عَنْ أَبِی حَازِمٍ الأَشْجَعِیِّ، عَنْ مَوْلاَتِہِ عَزَّۃَ ، قَالَتْ : سَمِعْت أَبَا بَکْرٍ یَنْہَی عَنِ الصَّلاَۃِ عَلَی الْبَرَادِعِ۔",,,4084
4085,حَدَّثَنَا حَاتِمٌ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُسْجَدَ عَلَی شَیْئٍ دُونَ الأَرْضِ۔,,,4085
4086,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ أَبِی نَضْرَۃَ ، عَنْ جَابِرٍ ، قَالَ : خَرَجَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَاتَ لَیْلَۃٍ وَأَصْحَابُہُ یَنْتَظِرُونَہُ لِصَلاَۃِ الْعِشَائِ الآخِرَۃِ ، فَقَالَ : نَامَ النَّاسُ وَرَقَدُوا ، وَأَنْتُمْ تَنْتَظِرُونَ الصَّلاَۃَ ، أَمَا إنَّکُمْ فِی صَلاَۃٍ مَا انْتَظَرْتُمُوہَا ، وَلَوْلاَ ضَعْفُ الضَّعِیفِ وَکِبَرُ الْکَبِیرِ ، لَأَخَّرْتُ ہَذِہِ الصَّلاَۃَ إلَی شَطْرِ اللَّیْلِ۔ (ابو یعلی 1935۔ ابن حبان 1529)",,,4086
4087,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : مَنْ دَخَلَ الْمَسْجِدَ وَہُوَ عَلَی طُہُورٍ ، لَمْ یَزَلْ عَاکِفًا فِیہِ مَا دَامَ فِیہِ حَتَّی یَخْرُجَ مِنْہُ ، أَوْ یُحْدِثَ۔",,,4087
4088,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُقَالُ ، إذَا صَلَّی الرَّجُلُ ثُمَّ جَلَسَ فِی مُصَلاَّہُ فَہُوَ فِی صَلاَۃٍ ، وَالْمَلاَئِکَۃُ تُصَلِّی عَلَیْہِ مَا لَمْ یُحْدِثْ فِیہِ ، وَإِذَا جَلَسَ فِی الْمَسْجِدِ فَہُوَ فِی صَلاَۃٍ مَا لَمْ یُحْدِثْ، وَمَا لَمْ یُؤْذِ فِیہِ۔",,,4088
4089,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنِ الْحَکَمِ بْنِ أَبَانَ ، عَنْ عِکْرِمَۃَ ، قَالَ : مَا مِنْ رَجُلٍ صَلَّی صَلاَۃً وَیَنْتَظِرُ أُخْرَی ، إِلاَّ قَالَتِ الْمَلاَئِکَۃُ : عَبْدُک فُلاَنٌ اللَّہُمَّ ارْحَمْہُ حَتَّی یُصَلِّیَہَا۔",,,4089
4090,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ زَائِدَۃَ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : إذَا کَانَ الرَّجُلُ جَالِسًا فِی الْمَسْجِدِ یَنْتَظِرُ الصَّلاَۃَ ، فَہُوَ مُعْتَکِفٌ۔",,,4090
4091,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ عَیَّاشٍ الْحَضْرَمِیِّ ، قَالَ : أَخْبَرَنَا یَحْیَی بْنُ مَیْمُونٍ قَاضِی مِصْرَ ، قَالَ : حَدَّثَنِی سَہْلُ بْنُ سَعْدٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : مَنِ انْتَظَرَ الصَّلاَۃَ ، فَہُوَ فِی صَلاَۃٍ مَا لَمْ یُحْدِثْ۔ (احمد 5/331۔ ابو یعلی 7546)",,,4091
4092,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : جَہَّزَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَیْشًا حَتَّی انْتَصَفَ اللَّیْلُ ، أَوْ بَلَغَ ذَلِکَ ، ثُمَّ خَرَجَ إلَیْنَا ، فَقَالَ : صَلَّی النَّاسُ وَرَقَدُوا وَأَنْتُمْ تَنْتَظِرُونَ الصَّلاَۃَ ، أَمَا إنَّکُمْ لَمْ تَزَالُوا فِی صَلاَۃٍ مَا انْتَظَرْتُمُوہَا۔ (احمد 3/367۔ ابو یعلی 1936)",,,4092
4093,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا دَخَلَ أَحَدُکُمُ الْمَسْجِدَ کَانَ فِی صَلاَۃٍ مَا کَانَتِ الصَّلاَۃُ تَحْبِسُہُ ، وَالْمَلاَئِکَۃُ یُصَلُّونَ عَلَی أَحَدِکُمْ مَا دَامَ فِی مَجْلِسِہِ الَّذِی صَلَّی فِیہِ ، یَقُولُونَ : اللَّہُمَّ اغْفِرْ لَہُ ، اللَّہُمَّ ارْحَمْہُ ، اللَّہُمَّ تُبْ عَلَیْہِ ، مَا لَمْ یُؤْذِ فِیہِ ، مَا لَمْ یُحْدِثْ فِیہِ۔ (بخاری 477۔ ابوداؤد 560)",,,4093
4094,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : حدَّثَنَا رَجُلٌ مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا صَلَّی أَحَدُکُمْ فَقَضَی صَلاَتَہُ ، ثُمَّ قَعَدَ فِی مُصَلاَّہُ یَذْکُرُ اللَّہَ فَہُوَ فِی صَلاَۃٍ ، وَإِنَّ الْمَلاَئِکَۃَ یُصَلُّونَ عَلَیْہِ ، یَقُولُونَ : اللَّہُمَّ ارْحَمْہُ وَاغْفِرْ لَہُ ، وَإِنْ ہُوَ دَخَلَ مُصَلاَّہُ یَنْتَظِرُ کَانَ مِثْلَ ذَلِکَ۔ (ابن سعد 174)",,,4094
4095,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَاصِمٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : احْتَبَسَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنْ أَصْحَابِہِ فِی صَلاَۃِ الْعِشَائِ ، حَتَّی بَقِیَ ثُلُثُ اللَّیْلِ ، فَأَتَاہُمْ وَبَعْضُہُمْ قَائِمٌ ، وَبَعْضُہُمْ قَاعِدٌ ، وَبَعْضُہُمْ مُضْطَجِعٌ ، فَقَالَ : مَا زِلْتُمْ فِی صَلاَۃٍ مُنْذُ انْتَظَرْتُمُوہَا ، قَائِمُکُمْ وَقَاعِدُکُمْ وَمُضْطَجِعُکُمْ۔",,,4095
4096,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : لاَ یَزَالُ أَحَدُکُمْ فِی صَلاَۃٍ مَا دَامَتِ الصَّلاَۃُ تَحْبِسُہُ۔",,,4096
4097,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ ، عَنْ أَنَسٍ ، قَالَ : أَخَّرَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَاتَ لَیْلَۃٍ الصَّلاَۃَ إلَی شَطْرِ اللَّیْلِ ، فَجَعَلَ النَّاسُ یُصَلُّونَ وَیَنْکَفِئُونَ ، فَخَرَجَ وَقَدْ بَقِیَتْ عِصَابَۃٌ فَصَلَّی بِہِمْ ، فَلَمَّا سَلَّمَ أَقْبَلَ عَلَیْہِم بِوَجْہِہِ ، فَقَالَ : إنَّ النَّاسَ قَدْ صَلَّوْا وَرَقَدُوا ، وَإِنَّکُمْ لَمْ تَزَالُوا فِی صَلاَۃٍ مُنْذُ انْتَظَرْتُمُ الصَّلاَۃَ ، قَالَ : فَکَأَنِّی أَنْظُرُ إلَی وَبِیصِ خَاتَمِہِ فِی یَدِہِ۔ (بخاری 847۔ مسلم 222)",,,4097
4098,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ صَدَقَۃَ بْنِ یَسَارٍ ، عَنْ أَبِی سَلَمَۃَ ، قَالَ : کَانُوا یُشَبِّہُونَ صَلاَۃَ الْہَجِیرِ بِصَلاَۃٍ فِی جَوْفِ اللَّیْلِ۔",,,4098
4099,"حَدَّثَنَا إسْمَاعِیلُ بْنُ إِبْرَاہِیمَ ، عَن عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ، عَنْ أَنَسٍ ، قَالَ : صَلُّوا صَلاَۃَ الْہَجِیرِ ، فَإِنَّا کُنَّا نَسْتَحِبّہَا۔",,,4099
4100,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ ، قَالَ : صَلُّوا صَلاَۃَ الأَصَالِ حِینَ یَفِیئَ الْفَیئُ عِنْدَ النِّدَائِ بِالظُّہْرِ ، مَنْ صَلاَّہَا فَکَأَنَّمَا تَہَجَّدَ بِاللَّیْلِ۔",,,4100
4101,"حَدَّثَنَا مُحَمَّدُ بْنُ عُبَیْدٍ ، عَنْ ہَارُونَ بْنِ عَنْتَرَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِہِم ، قَالَ : أَصَبْت أَنَا وَعَلْقَمَۃُ صَحِیفَۃً ، فَانْطَلَقْنَا بِہَا إلَی عَبْدِ اللہِ ، فَجَلَسْنَا بِالْبَابِ وَقَدْ زَالَتِ الشَّمْسُ ، أَوْ کَادَتْ تَزُولُ ، فَاسْتَیْقَظَ وَأَرْسَلَ الْجَارِیَۃَ ، فَقَالَ : اُنْظُرِی مَنْ بِالْبَابِ ، فَرَجَعَتْ إلَیْہِ ، فَقَالَتْ : عَلْقَمَۃُ وَالأَسْوَدُ ، فَقَالاَ : ائْذَنِی لَہُمَا ، فَدَخَلْنَا ، فَقَالَ : کَأَنَّکُمَا قَدْ أَطَلْتُمَا الْجُلُوسَ بِالْبَابِ ؟ قَالاَ : أَجَلْ ، قَالَ : فَمَا مَنَعَکُمَا أَنْ تَسْتَأْذِنَا ؟ قَالاَ: خَشِینَا أَنْ تَکُونَ نَائِمًا ، قَالَ : مَا کُنْت أُحِبُّ أَنْ تَظُنُّوا بِی ہَذَا ، إنَّ ہَذِہِ سَاعَۃٌ کُنَّا نُشَبِّہُہَا بِصَلاَۃِ اللَّیْلِ۔",,,4101
4102,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ، قَالَ : صَلاَۃُ الأَوَّابِینَ بَعْدَ زَوَالِ الشَّمْسِ۔",,,4102
4103,حَدَّثَنَا وَکِیعٌ ، عَنْ یُونُسَ بْنِ الْحَارِثِ ، عَنْ أَبِی عَوْنٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی عَلَی فَرْوَۃٍ مَدْبُوغَۃٍ۔,,,4103
4104,حَدَّثَنَا حَفْصٌ ، عَنْ مُجَالِدٍ ، عَنِ الشَّعْبِیِّ ، عَنْ مَسْرُوقٍ ؛ أَنَّہُ کَانَ یَدْبُغُ جِلْدَ أُضْحِیَّتِہِ ، فَیَتَّخِذَہُ مُصَلًّی یُصَلِّی عَلَیْہِ۔,,,4104
4105,حَدَّثَنَا حَفْصٌ ، عَنْ ہِشَامِ بْنِ یَزِیدَ ، عَنْ إسْمَاعِیلَ بْنِ رَجَائٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ؛ أَنَّہُ کَانَ یَدْبُغُ جِلْدَ أُضْحِیَّتِہِ ، فَیَتَّخِذُہُ مُصَلًّی یُصَلِّی عَلَیْہِ۔,,,4105
4106,حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ وَأَصْحَابِہِ ؛ أَنَّہُمَا کَانُوا یَکْرَہُونَ أَنْ یُصَلُّوا عَلَی الْفِرَائِ۔,,,4106
4107,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِلاَلِ بْنِ خَبَّابٍ ، قَالَ : دَخَلْتُ عَلَی عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ بِالْمَدَائِنِ وَہُوَ یُصَلِّی فِی بَیْتِہِ عَلَی جِلْدِ فَرْوِ ضَأْنٍ ، الصُّوفُ ظَاہِرٌ یَلِی قَدَمَیْہِ۔",,,4107
4108,"حَدَّثَنَا شَرِیکٌ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، قَالَ : کَانَ سُوَیْد بْنُ غَفَلَۃَ یُکَبِّرُ إذَا قَالَ الْمُؤَذِّنُ قَدْ قَامَتِ الصَّلاَۃُ۔",,,4108
4109,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنْ قَیْسٍ ؛ أَنَّہُ کَانَ یُکَبِّرُ إذَا قَالَ الْمُؤَذِّنُ قَدْ قَامَتِ الصَّلاَۃُ ، یَعْنِی فِی الأُولَی۔,,,4109
4110,"حَدَّثَنَا أَبُو الأَحْوَصِِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إِنْ کُنْت لأَسْمَعُ الْمُؤَذِّنَ یُصَوِّتُ بَعْدَ مَا یُکَبِّرُ إبْرَاہِیمُ لِلصَّلاَۃِ۔",,,4110
4111,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إِنْ شَائَ کَبَّرَ إذَا قَالَ قَدْ قَامَتِ الصَّلاَۃُ ، وَإِنْ شَائَ انْتَظَرَ حَتَّی یَفْرُغَ۔",,,4111
4112,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحِلٍّ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُکَبِّرُ إذَا قَالَ الْمُؤَذِّنُ قَدْ قَامَتِ الصَّلاَۃُ فِی الثَّانِیَۃِ۔",,,4112
4113,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ کَرِہَ أَنْ یَقُومَ الإِمَامُ حَتَّی یَقُولَ الْمُؤَذِّنُ قَدْ قَامَتِ الصَّلاَۃُ، وَکَرِہَ أَنْ یُکَبِّرَ حَتَّی یَفْرُغَ الْمُؤَذِّنُ مِنْ إقَامَتِہِ۔,,,4113
4114,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ إذَا قَالَ الْمُؤَذِّنُ حَیَّ عَلَی الصَّلاَۃِ قامَ ، فَإذَا قَالَ قَدْ قَامَتِ الصَّلاَۃُ کَبَّرَ۔",,,4114
4115,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامٍ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الأَعْمَشِ ، عَنْ یَحْیَی بْنِ وَثَّابٍ ، قَالَ : کَانَ یَسْکُتُ حَتَّی یَفْرُغَ الْمُؤَذِّنُ ، ثُمَّ یُکَبِّرَ ۔ وَکَانَ إبْرَاہِیمُ یَقُولُ إذَا قَامَتِ الصَّلاَۃُ کَبَّرَ۔",,,4115
4116,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ مَعْمَرٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ ، عَنْ أَبِیہِ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إذَا أُقِیمَتِ الصَّلاَۃُ فَلاَ تَقُومُوا حَتَّی تَرَوْنِی۔ (بخاری 637۔ مسلم 156)",,,4116
4117,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، عَنْ زَائِدَۃَ بْنِ نَشِیطٍ ، عَنْ أَبِی خَالِدٍ الْوَالِبِیِّ ، قَالَ : خَرَجَ عَلِیٌّ وَقَدْ أُقِیمَتِ الصَّلاَۃُ وَہُمْ قِیَامٌ یَنْتَظِرُونَہُ ، فَقَالَ : مَا لِی أَرَاکُمْ سَامِدِینَ ؟۔",,,4117
4118,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یَقُومَ الرَّجُلُ إذَا قَالَ الْمُؤَذِّنُ قَدْ قَامَتِ الصَّلاَۃُ ، وَلَیْسَ عِنْدَہُمُ الإِمَامُ ، وَکَانُوا یَکْرَہُونَ أَنْ یَنْتَظِرُوا الإِمَامَ قِیَامًا، وَکَانَ یُقَالُ: ہُوَ السَّمُودُ۔",,,4118
4119,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : الْقَوْمُ یَنْتَظِرُونَ الإِمَامَ قِیَامًا ، أَوْ قُعُودًا ؟ قَالَ : لاَ ، بَلْ قُعُودًا۔",,,4119
4120,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الْقَوْمِ یَنْتَظِرُونَ الإِمَامَ قِیَامًا ، قَالَ : ذَلِکَ السَّمُودُ۔",,,4120
4121,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ أَبِی عُبَیْدٍ ، قَالَ : سَمِعْتُہُ یَقُولُ : سَمِعْت عُمَرَ بْنَ عَبْدِ الْعَزِیزِ بِخَنَاصِرَۃَ یَقُولُ حِینَ یَقُولُ الْمُؤَذِّنُ قَدْ قَامَتِ الصَّلاَۃُ : قُومُوا ، قَدْ قَامَتِ الصَّلاَۃُ۔",,,4121
4122,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَرِہَ أَنْ یَقُومَ الإِمَامُ حَتَّی یَقُولَ الْمُؤَذِّنُ قَدْ قَامَتِ الصَّلاَۃُ۔,,,4122
4123,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، قَالَ : رَأَی عُبَیْدُ اللہِ بْنُ أَبِی یَزِیدَ حُسَیْنَ بْنَ عَلِیٍّ فِی حَوْضِ زَمْزَمَ ، وَقَدْ أُقِیمَتِ الصَّلاَۃُ ، فَشَجر بَیْنَ الإِمَامِ وَبَعْضِ النَّاسِ شَیْئٌ ، وَنَادَی الْمُنَادِی : قَدْ قَامَتِ الصَّلاَۃُ ، فَجَعَلُوا یَقُولُونَ لَہُ : اجْلِسْ ، فَیَقُولُ : قَدْ قَامَتِ الصَّلاَۃُ ۔",,,4123
4124,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ جَابِرِ بْنِ یَزِیدَ بْنِ مُرَّۃَ ، عَنْ سُوَیْد بْنِ غَفَلَۃَ ، قَالَ : إذَا دَخَلَ الرَّجُلُ وَالْمُؤَذِّنُ یُقِیمُ الصَّلاَۃَ ، قَالَ : لِیَقُمْ کَمَا ہُوَ إِنْ شَائَ ، فَإِنَّ ذَلِکَ یُرْفِقُ بِالرَّجُلِ الْکَبِیرِ ، وَقَالَ عَامِرٌ: لاَ بَأْسَ بِہِ۔",,,4124
4125,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، قَالَ : بَلَغَنِی أَنَّ إبْرَاہِیمَ انْتَہَی إلَی الْمَسْجِدِ وَقَدْ أَخَذَ الْمُؤَذِّنُ فِی الإِقَامَۃِ ، فَوَضَعَ رِجْلَہُ بَیْنَ الظُّلَّۃِ وَالصَّحْنِ حَتَّی فَرَغَ مِنَ الإِقَامَۃِ۔",,,4125
4126,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ عِمْرَانَ بْنِ مُسْلِمٍ ، قَالَ : قَالَ سُوَیْد : لَوِ اسْتَطَعْتُ لَکُنْت أُؤَذِّنُ لَہُمْ وَأَؤُمُّہُمْ ، قَالَ : فَذَکَرْت ذَلِکَ لِمُصْعَبِ بْنِ سَعْدٍ ، فَقَالَ : أَمَا إنَّ ذَلِکَ لَیْسَ مِنَ السُّنَّۃِ أَنْ یَکُونَ مُؤَذِّنًا وَإِمَامًا۔",,,4126
4127,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی رَوَّادٍ ، عَنْ أَصْبَغَ ، قَالَ : کَانَ ابْنُ عُمَرَ یُؤَذِّنُ لَنَا وَیَؤُمُّنَا فِی السَّفَرِ۔",,,4127
4128,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ ضِرَارِ بْنِ مُرَّۃَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی الْہُذَیْلِ الْعَنَزِیِّ ، قَالَ : قَالَ عُمَرُ: لَوْلاَ أَنْ یَکُونَ سُنَّۃً لأَذَّنْتُ۔",,,4128
4129,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، قَالَ : قیلَ لِلأَسْوَدِ بْنِ ہِلاَلٍ : تَقَدَّمْ ، فَقَالَ : أَرَاضُونَ أَنْتُمْ ؟",,,4129
4130,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُوسَی بْنُ قَیْسٍ الْحَضْرَمِیُّ ، عَنِ الْعَیْزَارِ بْنِ جَرْوَلٍ ؛ أَنَّ قَوْمًا شَکَوْا إمَامًا لَہُمْ إلَی عَلِیٍّ ، فَقَالَ لَہُ عَلِیٌّ : إنَّک لَخَرُوطٌ ، تَؤُمُّ قَوْمًا وَہُمْ کَارِہُونَ۔",,,4130
4131,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو عُبَیْدَۃَ النَّاجِی ، عَنِ الْحَسَنِ ، قَالَ: قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: مَنْ أَمَّ قَوْمًا وَہُمْ لَہُ کَارِہُونَ ، لَمْ تَجُزْ صَلاَتُہُ تَرْقُوَتَہُ۔",,,4131
4132,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الأَعْمَشِ ، عَنِ الْمِنْہَالِ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، قَالَ : ثَلاَثَۃٌ لاَ تُجَاوِزُ صَلاَۃُ أَحَدِہِمْ رَأْسَہُ ؛ إمَامُ قَوْمٍ وَہُمْ لَہُ کَارِہُونَ ، وَامْرَأَۃٌ تَعْصِی زَوْجَہَا ، وَعَبْدٌ أَبَقَ مِنْ سَیِّدِہِ۔",,,4132
4133,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ زِیَادِ بْنِ أَبِی الْجَعْدِ ، عَنْ عَمْرِو بْنِ الْحَارِثِ بْنِ الْمُصْطَلِقِ، قَالَ: کَانَ یُقَالُ: أَشَدُّ النَّاسِ عَذَابًا؛ امْرَأَۃٌ تَعْصِی زَوْجَہَا، وَإِمَامُ قَوْمٍ وَہُمْ لَہُ کَارِہُونَ۔(ترمذی 359)",,,4133
4134,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ہِشَامُ بْنُ حَسَّانَ ، قَالَ : حَدَّثَنَا الْحَسَنُ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : ثَلاَثَۃٌ لاَ تُقْبَلُ لَہُمْ صَلاَۃٌ ؛ رَجُلٌ أَمَّ قَوْمًا وَہُمْ لَہُ کَارِہُونَ ، وَالْعَبْدُ إذَا أَبَقَ حَتَّی یَرْجِعَ إلَی مَوْلاَہُ ، وَامْرَأَۃٌ إذَا بَاتَتْ مُہَاجِرَۃً لِزَوْجِہَا ، عَاصِیَۃً لَہُ۔ (ابن ماجہ 971)",,,4134
4135,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، قَالَ : سَمِعْتُ الْقَاسِمَ بْنَ مُخَیْمِرَۃَ یَذْکُرُ ؛ أَنَّ سَلْمَانَ قَدَّمَہُ قَوْمٌ یُصَلِّی بِہِمْ ، فَأَبَی حَتَّی دَفَعُوہُ ، فَلَمَّا صَلَّی بِہِمْ قَالَ : کُلّکُمْ رَاضٍ ؟ قَالُوا : نَعَمْ ، قَالَ : الْحَمْدُ لِلَّہِ ، إنِّی سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : ثَلاَثَۃٌ لاَ تُقْبَلُ صَلاَتُہُمُ ؛ الْمَرْأَۃُ تَخْرُجُ مِنْ بَیْتِہَا بِیْرِ ، إذْنِہِ ، وَالْعَبْدُ الآبِقُ ، وَالرَّجُلُ یَؤُمُّ الْقَوْمَ وَہُمْ لَہُ کَارِہُونَ۔",,,4135
4136,"حَدَّثَنَا عَلِیُّ بْنُ حَسَنِ بْنِ شَقِیقٍ ، عَنْ حُسَیْنِ بْنِ وَاقِدٍ ، عَنْ أَبِی غَالِبٍ ، عَنْ أَبِی أُمَامَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ثَلاَثَۃٌ لاَ تُجَاوِزُ صَلاَتُہُمْ رُؤُوسَہُمْ حَتَّی یَرْجِعُوا ؛ الْعَبْدُ الآبِقُ ، وَامْرَأَۃٌ بَاتَتْ وَزَوْجُہَا عَلَیْہَا سَاخِطٌ ، وَإِمَامُ قَوْمٍ وَہُمْ لَہُ کَارِہُونَ۔ (ترمذی 360۔ طبرانی 8098)",,,4136
4137,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی ظَبْیَانَ ، عَنْ حُذَیْفَۃَ ، قَالَ : خَرَجَ فِی سَفَرٍ فَتَقَدَّمَ فَأَمَّہُمْ ، ثُمَّ قَالَ : لَتَلْتَمِسُنَّ إمَامًا غَیْرِی ، أَوْ لَتُصَلُّنَّ وُحْدَانًا۔",,,4137
4138,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ أَشْیَاخِ مُحَارِبٍ ، قَالَ : قَالَ حُذَیْفَۃُ : لَتَبْتَغُنَّ إمَامًا غَیْرِی ، أَوْ لَتُصَلُّنَّ وُحْدَانًا۔",,,4138
4139,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ مُبَارَکٍ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : ابْتَدِرُوا الأَذَانَ ، وَلاَ تَبْتَدِرُوا الإِمَامَۃَ۔",,,4139
4140,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَسَنِ بْنِ عُقْبَۃَ أبِی کِبْرَانَ ، أَنَّہُ قَالَ : کُنَّا مَعَ الضَّحَّاکِ فَقَالَ : إِنْ کَانَ مِنْکُمْ مَنْ یَتَقَدَّمُ فَلْیُؤَذِّنْ وَلْیُصَلِّ ، قَالَ : فَأَبَوْا ، فَصَلَّیْنَا وُحْدَانًا۔",,,4140
4141,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَاصِمٍ ، قَالَ : أَمَّ أَبُو عُبَیْدَۃَ قَوْمًا مَرَّۃً ، فَلَمَّا انْصَرَفَ قَالَ : مَا زَالَ عَلَیَّ الشَّیْطَانُ آنِفًا حَتَّی رَأَیْت أَنَّ الْفَضْلَ لِی عَلَی مَنْ خَلْفِی ، لاَ أَؤُمّ أَبَدًا۔",,,4141
4142,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ: أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ حُذَیْفَۃُ یَتَخَلَّفُ عَنِ الإِمَامَۃِ ، قَالَ : فَأُقِیمَتِ الصَّلاَۃُ ذَاتَ یَوْمٍ ، قَالَ : فَتَخَلَّفَ عَبْدُ اللہِ ، قَالَ : فَتَقَدَّمَ حُذَیْفَۃُ ، فَلَمَّا قَضَی صَلاَتَہُ ، قَالَ لَہُم : لَتَبْتَغُنَّ، أَوْ کَلِمَۃً غَیْرَہَا ، إمَامًا غَیْرِی ، أَوْ لَتُصَلُّنَّ فُرَادَی ۔ قَالَ : فَقَالَ مُجَاہِدٌ : قَالَ أَبُو مَعْمَرٍ ، عَنْ حُذَیْفَۃَ أَنَّہُ قَالَ : أَوْ لَتُصَلُّنَّ وُحْدَانًا ، قَالَ : فَقَالَ إبْرَاہِیمُ : أَوْ قَالَ : لَتُصَلُّنَّ وُحْدَانًا۔",,,4142
4143,"حَدَّثَنَا ہُشَیْمٌ، قَالَ: أَخْبَرَنَا الْعَوَّامُ، قَالَ: حَدَّثَنَا عَبْدُاللہِ بْنُ أَبِی الْہُذَیْلِ، قَالَ: کَانَ شَیْخٌ مِنْ تِلْکَ الشُّیُوخِ یَؤُمُّ قَوْمَہُ ثُمَّ تَرَکَ ذَلِکَ ، قَالَ : فَلَقِیَہُ بَعْضُ إِخْوَانِہِ ، فَقَالَ لَہُ : لِمَ تَرَکْت إمَامَۃَ قَوْمِکَ ؟ قَالَ : کَرِہْتُ أَنْ یَمُرَّ الْمَارُّ فَیَرَانِی أُصَلِّی فَیَقُولُ : مَا قَدَّمَ ہَؤُلاَء ہَذَا الرَّجُلَ إِلاَّ وَہُوَ خَیْرُہُمْ ، وَاللَّہِ لاَ أَؤُمُّہُمْ أَبَدًا۔",,,4143
4144,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، قَالَ : کُنْتُ مَعَ ابْنِ سِیرِینَ فِی جِنَازَۃٍ ، فَلَمَّا انْصَرَفْنَا حضَرَتِ الصَّلاَۃُ ، قَالَ : فَلَمَّا أُقِیمَتْ قِیلَ لابْنِ سِیرِینَ : تَقَدَّمْ ، قَالَ : فَقَالَ : لِیَتَقَدَّمْ بَعْضُکُمْ ، وَلاَ یَتَقَدَّمْ إِلاَّ مَنْ قَرَأَ الْقُرْآنَ ، قَالَ ، ثُمَّ قَالَ لِی : تَقَدَّمْ ، فَتَقَدَّمْتُ فَصَلَّیْتُ بِہِمْ ، فَلَمَّا فَرَغْت قُلْتُ فِی نَفْسِی : مَاذَا صَنَعْت ؟ شَیْئًا کَرِہَہُ ابْنُ سِیرِینَ لِنَفْسِہِ تَقَدَّمْت عَلَیْہِ ، فَقُلْتُ لَہُ : یَرْحَمُکَ اللَّہُ ، أَمَرْتَنِی بِشَیْئٍ کَرِہْتَہُ لِنَفْسِکَ ؟ فَقَالَ : إنِّی کَرِہْتُ أَنْ یَمُرَّ الْمَارُّ فَیَقُولَ : ہَذَا ابْنُ سِیرِینَ یَؤُمّ النَّاسَ۔",,,4144
4145,"حَدَّثَنَا وَکِیعٌ ، قَالَ : أَخْبَرَنَا عِکْرِمَۃُ بْنُ عَمَّارٍ الْیَمَامِیُّ ، عَنْ ضَمْضَمِ بْنِ جَوْسٍ الْہِفَّانِیِّ ، عَنْ عَبْدِ اللہِ بْنِ حَنْظَلَۃَ بْنِ الرَّاہِبِ ، قَالَ : صَلَّی بِنَا عُمَرُ بْنُ الْخَطَّابِ فَنَسِیَ أَنْ یَقْرَأَ فِی الرَّکْعَۃِ الأُولَی ، فَلَمَّا قَامَ فِی الرَّکْعَۃِ الثَّانِیَۃِ قَرَأَ بِفَاتِحَۃِ الْکِتَابِ مَرَّتَیْنِ وَسُورَتَیْنِ ، فَلَمَّا قَضَی الصَّلاَۃَ سَجَدَ سَجْدَتَیْنِ۔",,,4145
4146,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ؛ أَنَّہُ نَسِیَ أَنْ یَقْرَأَ فِی الأُولَیَیْنِ ، فَقَرَأَ فِی الأُخْرَیَیْنِ۔,,,4146
4147,"حَدَّثَنَا أَسْبَاطٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا نَسِیَ أَنْ یَقْرَأَ فِی الأُولَیَیْنِ ، قَرَأَ فِی الأُخْرَیَیْنِ۔",,,4147
4148,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُغِیرَۃَ ، وَالْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إبْرَاہِیمَ ، قَالَ : کُنْتُ أَقُومُ خَلْفَ الأَسْوَدِ حَتَّی یَنْزِلَ الْمُؤَذِّنُ۔",,,4148
4149,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَقُومُ خَلْفَ الإِمَامِ مَا بَیْنَہُ وَبَیْنَ الرَّکْعَۃِ ، فَإِنْ جَائَ أَحَدٌ ، وَإِلاَّ قَامَ عَنْ یَمِینِہِ۔",,,4149
4150,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَقَدْ رَأَیْتُنِی أَقُومُ خَلْفَ عَلْقَمَۃَ حَتَّی یَدْخُلَ دَاخِلٌ ، أَوْ یَنْزِلَ مُؤَذِّنٌ۔",,,4150
4151,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُرَیْرِیِّ ، عَنْ قَیْسِ بْنِ عَبَایَۃَ ، قَالَ : حدَّثَنِی ابْنُ عَبْدِ اللہِ بْنِ مُغَفَّلٍ ، عَنْ أَبِیہِ ، قَالَ ، وَلَمْ أَرَ رَجُلاً مِنْ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ أَشَدَّ عَلَیْہِ حَدَثٌ فِی الإِسْلاَمِ مِنْہُ ، قَالَ : سَمِعَنِی أَبِی وَأَنَا أَقْرَأُ : {بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیم} قَالَ : یَا بُنَیَّ ، إیَّاکَ وَالْحَدَثَ ، فَإِنِّی قَدْ صَلَّیْت خَلْفَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَبِی بَکْرٍ ، وَعُمَرَ ، وَعُثْمَانَ فَلَمْ أَسْمَعْ أَحَدًا مِنْہُمْ یَقُولُ ذَلِکَ ، إذَا قَرَأْت فَقُلِ : {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ}۔ (ترمذی 244۔ احمد 55)",,,4151
4152,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ ، عَنْ أَنَسٍ ، أَنَّ أَبَا بَکْرٍ ، وَعُمَرَ ، وَعُثْمَانَ کَانُوا یَسْتَفْتِحُونَ الْقِرَائَۃَ بِـ {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ} ۔ قَالَ حُمَیْدٌ : وَأَحْسَبُہُ ذَکَرَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (عبدالرزاق 2592۔ ابو یعلی 3509)",,,4152
4153,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا سَعِیدٌ ، قَالَ : حَدَّثَنَا قَتَادَۃُ ، عَنْ أَنَسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَأَبَا بَکْرٍ ، وَعُمَرَ ، وَعُثْمَانَ کَانُوا یَسْتَفْتِحُونَ الْقِرَائَۃَ بِـ {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ}۔ (بخاری 743۔ مسلم 299)",,,4153
4154,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا حُسَیْنٌ الْمُعَلِّمُ ، عَنْ بُدَیْلٍ ، عَنْ أَبِی الْجَوْزَائِ ، عَنْ عَائِشَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَفْتَتِحُ الصَّلاَۃَ بِالتَّکْبِیرِ ، وَالْقِرَائَۃِ بِـ {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ}۔",,,4154
4155,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یَفْتَتِحُ الْقِرَائَۃَ بِـ {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ}۔,,,4155
4156,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ؛ أَنَّہُ کَانَ یَسْتَفْتِحُ الْقِرَائَۃَ بِـ {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ}۔,,,4156
4157,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا ابْنُ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ یُخْفِی {بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیم}۔",,,4157
4158,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یَفْتَتِحُ الْقِرَائَۃَ بِـ {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ}۔",,,4158
4159,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، وَمُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُخْفِی الإِمَامُ بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیم وَالاسْتِعَاذَۃَ ، وَآمِینَ ، وَرَبَّنَا لَکَ الْحَمْدُ۔",,,4159
4160,حَدَّثَنَا ہُشَیْمٌ ، عَنْ سَعِیدِ بْنِ الْمَرْزُبَانِ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ یُخْفِی {بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیم} وَالاسْتِعَاذَۃَ ، وَرَبَّنَا لَکَ الْحَمْدُ۔,,,4160
4161,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : جَہْرُ الإِمَامِ بـ {بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیم} بِدْعَۃٌ۔",,,4161
4162,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَبِیہِ ، وَابْنِ الزُّبَیْرِ ؛ أَنَّہُمَا کَانَا لاَ یَجْہَرَانِ۔,,,4162
4163,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ؛ أَنْ أَبَا بَکْرٍ کَانَ یَفْتَتِحُ الْقِرَائَۃَ بِـ {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ}۔,,,4163
4164,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَاصِمٍ ، قَالَ ، سَمِعْت أَبَا وَائِلٍ یَسْتَفْتِحُ الْقِرَائَۃَ بِـ {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ}۔,,,4164
4165,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا وَأَبَا إِسْحَاقَ عَنِ الْجَہْرِ ؟ قالوا : اقْرَأْ : (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیم) فِی نَفْسِک۔",,,4165
4166,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی بَشِیرٍ ، عَنْ عِکْرِمَۃَ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : الْجَہْرُ بـ (بسم اللہِ الرَّحْمَنِ الرَّحِیمِ) قِرَائَۃُ الأَعْرَابِ۔",,,4166
4167,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : صَلَّیْت خَلْفَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَبِی بَکْرٍ ، وَعُمَرَ ، وَعُثْمَانَ فَلَمْ یَجْہَرُوا بِـ (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔ (بخاری 743۔ مسلم 299)",,,4167
4168,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، وَأَبَا بَکْرٍ ، وَعُمَرَ ، وَعُثْمَانَ کَانُوا یَسْتَفْتِحُونَ الصَّلاَۃَ بِـ {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ}۔,,,4168
4169,حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ ، عَنْ ثُوَیْرٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا کَانَ لاَ یَجْہَرُ بِـ (بسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔,,,4169
4170,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : لاَ یُجْہَرُ بِـ (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔",,,4170
4171,"حَدَّثَنَا إِسْحَاقُ بْنُ سُلَیْمَانَ الرَّازِیّ ، عَنْ أَبِی سِنَانٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : صَلَّیْت خَلْفَ عُمَرَ سَبْعِینَ صَلاَۃً ، فَلَمْ یَجْہَرْ فِیہَا بِـ (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔",,,4171
4172,"حَدَّثَنَا شَاذَانُ ، قَالَ : حدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی وَائِلٍ ؛ أَنَّ عَلِیًّا وَعَمَّارًا کَانَا لاَ یَجْہَرَانِ بِـ (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔",,,4172
4173,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ مُعَاوِیَۃَ بْنِ صَالِحٍ ، قَالَ : أَخْبَرَنَا مَالِکُ بْنُ زِیَادٍ ، قَالَ : صَلَّی بِنَا عُمَرُ بْنُ عَبْدِ الْعَزِیزِ فَافْتَتَحَ الصَّلاَۃَ بِـ {الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ}۔",,,4173
4174,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو مَعْشَرٍ ، عَنْ سَعِیدِ بْنِ أَبِی سَعِیدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّہُ کَانَ یَجْہَرُ بِـ (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔",,,4174
4175,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ وِقَائٍ ، قَالَ : سَمِعْتُ سَعِیدَ بْنَ جُبَیْرٍ یَجْہَرُ بِـ (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔",,,4175
4176,حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ ؛ أَنَّہُمْ کَانُوا یَجْہَرُونَ بِـ (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔,,,4176
4177,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الأَزْرَقِ بْنِ قَیْسٍ ، قَالَ : سَمِعْتُ ابْنَ الزُّبَیْرِ قَرَأَ : (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ) ، ثُمَّ قَرَأَ : (الْحَمْدُ لِلَّہِ رَبِّ الْعَالَمِینَ) ثُمَّ قَرَأَ : (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔",,,4177
4178,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ بْنُ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ کَانَ إذَا افْتَتَحَ ألصَّلاَۃَ قَرَأَ : (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ) فَإِذَا فَرَغَ مِنَ الْحَمْدِ قَرَأَ : (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔",,,4178
4179,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، وَمُعَاذُ بْنُ مُعَاذٍ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ؛ أَنَّ ابْنَ الزُّبَیْرِ کَانَ یَجْہَرُ بِـ (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ) وَیَقُولُ : مَا یَمْنَعُہُمْ مِنْہَا إِلاَّ الْکِبْرُ۔",,,4179
4180,حَدَّثَنَا خَالِدُ بْنُ مَخْلَدٍ ، عَنْ عُمَرَ بْنِ ذَرٍّ ، عَنْ أَبِیہِ ، عَنْ سَعِیدِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ أَبْزَی ، عَنْ أَبِیہِ ؛ أَنَّ عُمَرَ جَہَرَ بِـ (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔,,,4180
4181,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَقُولُ : إذَا قَرَأَ الرَّجُلُ فِی صَلاَتِہِ مَرَّۃً وَاحِدَۃً (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ) أَجْزَأَہُ ذَلِکَ۔",,,4181
4182,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ قَالَ : إذَا تَعَوَّذَ مَرَّۃً ، وَقَرَأَ (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ) أَجْزَأَہُ لِبَقِیَّۃِ صَلاَتِہِ۔",,,4182
4183,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یَقْرَأُ : (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ) فِی کُلِّ رَکْعَۃٍ۔",,,4183
4184,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا ، وَأَبَا إِسْحَاقَ فَقَالُوا : اقْرَأْ فِی کُلِّ رَکْعَۃٍ بِـ (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ) ۔",,,4184
4185,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، وَأَبِی إِسْحَاقَ؛ فِی الرَّجُلِ یَقْرَأُ فِی الرَّکْعَۃِ بِالسُّورَتَیْنِ، کُلَّمَا قَرَأَ سُورَۃً اسْتَفْتَحَ بِـ (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔,,,4185
4186,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ طَلْحَۃَ ؛ أَنَّہُ کَانَ یَقْرَأُ فِی الْمُصْحَفِ ، فَکَانَ کُلَّمَا خَتَمَ سُورَۃً قَرَأَ : (بِسْمِ اللہِ الرَّحْمَنِ الرَّحِیمِ)۔",,,4186
4187,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ کَثِیرِ بْنِ شِنْظِیرٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إذَا انْتَہَی الرَّجُلُ إلَی الْقَوْمِ وَہُمْ قُعُودٌ فِی آخِرِ الصَّلاَۃِ ، فَقَدْ دَخَلَ فِی التَّضْعِیفِ ، وَإِذَا انْتَہَی إلَیْہِمْ وَقَدْ سَلَّمَ الإِمَامُ ، وَلَمْ یَتَفَرَّقُوا ، فَقَدْ دَخَلَ فِی التَّضْعِیفِ۔\n\nوَقَالَ عَطَائٌ : کَانَ یُقَالُ : إذَا خَرَجَ مِنْ بَہِتِگ وَہُوَ یَنْوِیہِمْ فَأَدْرَکَہُمْ ، أَوْ لَمْ یُدْرِکْہُمْ ، فَقَدْ دَخَلَ فِی التَّضْعِیفِ۔",,,4187
4188,"حَدَّثَنَا شَرِیکٌ ، عَنْ عَامِرِ بْنِ شَقِیقٍ ، عَنْ أَبِی وَائِلٍ ، قَالَ : قَالَ عَبْدُ اللہِ : مَنْ أَدْرَکَ التَّشَہُّدَ ، فَقَدْ أَدْرَکَ الصَّلاَۃَ۔",,,4188
4189,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِی سَلَمَۃَ ، قَالَ : مَنْ خَرَجَ مِنْ بَیْتِہِ قَبْلَ أَنْ یُسَلِّمَ الإِمَامُ ، فَقَدْ أَدْرَکَ۔",,,4189
4190,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنِ ابْنِ صُہَیْبٍ ، قَالَ : کَانَ زَرٌّ ، وَأَبُو وَائِلٍ إذَا رَأَوْنَا فِی الصَّفِّ ، وَنَحْنُ صِبْیَانٌ أَخْرَجُونَا۔",,,4190
4191,حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِیہِ ، عَنْ ہِلاَلٍ ، عَنْ عَبْدِ اللہ بْنِ عُکَیْمٍ ؛ أَنَّہُ کَانَ إذَا رَأَی صَبِیًّا فِی الصَّفِّ أَخْرَجَہُ۔,,,4191
4192,حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ أَبَانَ الْعَطَّارِ ، عَنْ أَبِی ہَاشِمٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ کَانَ إذَا رَأَی غُلاَمًا فِی الصَّفِّ أَخْرَجَہُ۔,,,4192
4193,"حَدَّثَنَا شَرِیکُ بْنُ عَبْدِ اللہِ ، عَنْ یَحْیَی بْنِ ہَانِیئٍ الْمُرَادِیِّ ، عَنْ رَجُلٍ مِنْ قَوْمِہِ ؛ أَنَّ حُذَیْفَۃَ کَانَ یُفَرِّقُ بَیْنَ الصِّبْیَانِ فِی الصَّفِّ ، أَوَ قَالَ : فِی الصَّلاَۃِ۔",,,4193
4194,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مَنْصُورٍ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، أَوْ ہِلاَلٍ ، عَنْ سَعْدِ بْنِ عُبَیْدَۃَ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : قَالَ عَلِیٌّ : الْمُؤَذِّنُ أَمْلَکُ بِالأَذَانِ ، وَالإِمَامُ أَمْلَکُ بِالإِقَامَۃِ۔",,,4194
4195,"حَدَّثَنَا وَکِیعٌ، قَالَ: حدَّثَنَا سُفْیَانُ، عَنِ الْحَسَنِ بْنِ عُبَیْدِاللہِ، قَالَ: کَانُوا یَنْتَظِرُونَ الأَسْوَدَ، وَکَانَ إمَامَہُمْ۔",,,4195
4196,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : کَانُوا یَنْتَظِرُونَ الإِمَامَ حَتَّی یَنْزِلَ الْمُؤَذِّنُ۔",,,4196
4197,"حَدَّثَنَا وَکِیعٌ ، قَالَ :حَدَّثَنَا مِسْعَرٌ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنْ مَعْقِلِ بْنِ أَبِی بَکْرٍ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ انْتُظِرَ بَعْدَ مَا أُقِیمَتِ الصَّلاَۃُ۔",,,4197
4198,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ، عَنْ أَنَسٍ ، قَالَ : أُقِیمَتِ الصَّلاَۃُ وَرَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَجِیٌّ لِرَجُلٍ فِی جَانِبِ الْمَسْجِدِ ، فَمَا قَامَ إلَی الصَّلاَۃِ حَتَّی نَامَ الْقَوْمُ۔ (بخاری 642۔ مسلم 284)",,,4198
4199,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ التَّیْمِیِّ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : إِنْ کَانَ عُمَرُ لَیُقَاوِمُ الرَّجُلَ بَعْدَ مَا تُقَامُ الصَّلاَۃُ۔",,,4199
4200,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : أُقِیمَتِ الصَّلاَۃُ وَصُفَّتِ الصُّفُوفُ فَانْدَرَأَ رَجُلٌ لِعُمَرَ فَکَلَّمَہُ ، فَأَطَالاَ الْقِیَامَ حَتَّی أَلْقَیَا إلَی الأَرْضِ وَالْقَوْمُ صُفُوفٌ۔",,,4200
4201,حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، وَابْنِ سِیرِینَ ؛ أَنَّہُمَا کَانَا إذَا قَرَآ السَّجْدَۃَ سَلَّمَا۔,,,4201
4202,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ کَانَ یُسَلِّمُ یَقُولُ : السَّلاَمُ عَلَیْکُمْ، إذَا قَرَأَ السَّجْدَۃَ۔",,,4202
4203,"حَدَّثَنَا وَکِیعٌ، عَنْ شُعْبَۃَ، عَنِ الْحَکَمِ، قَالَ: رَأَیْتُ أَبَا الأَحْوَص وَقَرَأَ السَّجْدَۃَ فَسَلَّمَ عَنْ یَمِینِہِ تَسْلِیمَۃً۔",,,4203
4204,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ إبْرَاہِیمُ ، وَأَبُو صَالِحٍ ، وَیَحْیَی بْنُ وَثَّابٍ لاَ یُسَلِّمُونَ فِی السَّجْدَۃِ۔",,,4204
4205,حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ؛ أَنَّہُ کَانَ إذَا قَرَأَ السَّجْدَۃَ لَمْ یُسَلِّمْ فِیہَا۔,,,4205
4206,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، قَالَ : کَانَ الْحَسَنُ یَقْرَأُ بِنَا سُجُودَ الْقُرْآنِ وَلاَ یُسَلِّمُ۔",,,4206
4207,حَدَّثَنَا عَبَّادٌ ، عَنْ وِقَائِ بْنِ إیَاسٍ الأَسَدِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یَقْرَأُ السَّجْدَۃَ ، فَیَرْفَعُ رَأْسَہُ ، وَلاَ یُسَلِّمُ۔,,,4207
4208,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَأَبُو الأَشْہَبِ ، عَنِ الْحَسَنِ ، أَنَّہُمَا قَالاَ : إذَا قَرَأَ الرَّجُلُ السَّجْدَۃَ ، فَلْیُکَبِّرْ إذَا رَفَعَ رَأْسَہُ ، وَإِذَا سَجَدَ۔",,,4208
4209,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، وَابْنِ سِیرِینَ ، أَنَّہُمَا قَالاَ : إذَا قَرَأَ الرَّجُلُ السَّجْدَۃَ فِی غَیْرِ صَلاَۃٍ قَالَ : اللَّہُ أَکْبَرُ۔",,,4209
4210,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمٍ ، قَالَ : کَانَ أَبِی إذَا قَرَأَ السَّجْدَۃَ ، قَالَ : اللَّہُ أَکْبَرُ ، ثُمَّ سَجَدَ۔",,,4210
4211,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ کَانَ یَقْرَأُ السَّجْدَۃَ وَہُوَ یَمْشِی ، فَیُکَبِّرُ وَیُومِیئُ حَیْثُ کَانَ وَجْہُہُ ، وَیُکَبِّرُ إذَا رَفَعَ۔,,,4211
4212,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : إذَا قَرَأْتَ السَّجْدَۃَ فَکَبِّرْ۔",,,4212
4213,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ، عَنْ عَطَائِ بْنِ السَّائِبِ، عَنْ أَبِی عَبْدِالرَّحْمَنِ السُّلَمِیِّ، قَالَ: کُنَّا نَقْرَأُ عَلَی أَبِی عَبْدِ الرَّحْمَنِ وَنَحْنُ نَمْشِی ، فَإِذَا مَرَّ بِالسَّجْدَۃِ کَبَّرَ وَأَوْمَأَ وَسَلَّمَ ، وَزَعَمَ أَنَّ ابْنَ مَسْعُودٍ کَانَ یَصْنَعُ ذَلِکَ۔",,,4213
4214,حَدَّثَنَا شَرِیکٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّ أَصْحَابَ عَبْدِ اللہِ کَانُوا یَقْرَؤُونَ السَّجْدَۃَ وَہُمْ یَمْشُونَ ، فَیُومِئُونَ إیمَائً۔,,,4214
4215,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَنِ الأَسْوَدِ ؛ أَنَّہُ کَانَ یَقْرَؤُہَا وَہُوَ یَمْشِی ، فَیُومِیئُ إِیمَائً۔,,,4215
4216,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ؛ أَنَّہُ کَانَ یُومِیئُ۔,,,4216
4217,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ أَشْعَثَ ، قَالَ : سَأَلْتُ کُرْدُوسًا عَنِ السَّجْدَۃِ یَقْرَؤُہَا الرَّجُلُ وَہُوَ یَمْشِی؟ قَالَ : یُومِیئُ۔",,,4217
4218,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ زِیَادٍ ، قَالَ : حدَّثَنِی عُمَارَۃُ بْنُ الْقَعْقَاعِ ، عَنْ أَبِی زُرْعَۃَ بْنِ عَمْرِو بْنِ جَرِیرٍ ؛ أَنَّہُ ذَکَرَ الإِیمَائَ ، وَذَکَرْتُ لَہُ : أَنَّ إبْرَاہِیمَ قَرَأَہَا فِی مَسِیرٍ لَہُ فَأَوْمَأَ۔",,,4218
4219,"حَدَّثَنَا عَبْدَۃُ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ التَّیْمِیِّ ، قَالَ : کُنْتُ أَعْرِضُ عَلَی أُبَیٍّ وَیَعْرِضُ عَلَیَّ فِی الطَّرِیقِ ، فَیَمُرُّ بِالسَّجْدَۃِ فَیَسْجُدُ ، فَقُلْتُ لَہُ : أَتَسْجُدُ فِی الطَّرِیقِ ؟ قَالَ : نَعَمْ۔",,,4219
4220,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَبِی جَعْفَرٍ الرَّازِیّ ، عَنِ الرَّبِیعِ بْنِ أَنَسٍ ، قَالَ : قُلْتُ لأَبِی الْعَالِیَۃِ : إنِّی آخُذ فِی سِکَّۃٍ ضَیِّقَۃٍ ، فَأَسْمَعُ الْقَارِیئَ یَقْرَأُ السَّجْدَۃَ ، فَأَسْجُدُ عَلَی الطَّرِیقِ ؟ قَالَ : نَعَمْ ، اُسْجُدْ عَلَی الطَّرِیقِ۔",,,4220
4221,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّ ابْنَ مَسْعُودٍ کَانَ یَقْرَأُ وَہُوَ یَمْشِی ، فتَأْتِی السَّجْدَۃَ فَیَتَنَحَّی فَیَسْجُدُ۔,,,4221
4222,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ أَبِی سُلَیْمَانَ ، عَنْ سَلَمَۃَ بْنِ کُہَیْلٍ ، قَالَ : إذَا قَرَأْتَ السَّجْدَۃَ وَأَنْتَ تَمْشِی ، فَضَعْ جَبْہَتَکَ عَیَح أَوَّلِ حَائِطٍ تَلْقَی۔",,,4222
4223,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ (ح) وَأَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَقْرَأُ السَّجْدَۃَ ، ثُمَّ یُعِیدُ قِرَائَتَہَا ، قَالاَ : تُجْزِئُہُ السَّجْدَۃُ الأُولَی۔",,,4223
4224,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : إذَا قَرَأْتَ السَّجْدَۃَ أَجْزَأَک أَنْ تَسْجُدَ بِہَا مَرَّۃً۔",,,4224
4225,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ کَانَ یَقْرَأُ السَّجْدَۃَ فَیَسْجُدُ ، ثُمَّ یُعِیدُہَا فِی مَجْلِسِہِ ذَلِکَ مِرَارًا ، لاَ یَسْجُدُ۔,,,4225
4226,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : کَانُوا یَکْرَہُونَ اخْتِصَارَ السُّجُودِ۔",,,4226
4227,"حَدَّثَنَا ہُشَیْمٌ ، وَعَلِیُّ بْنُ مُسْہِرٍ ، وَابْنُ فُضَیْلٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانُوا یَکْرَہُونَ اخْتِصَارَ السُّجُودِ ، وَکَانُوا یَکْرَہُونَ إذَا أَتَوْا عَلَی السَّجْدَۃِ أَنْ یُجَاوِزُوہَا حَتَّی یَسْجُدُوا۔",,,4227
4228,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : ثَلاَثٌ مِمَّا أَحْدَثَ النَّاسُ : اخْتِصَارُ السُّجُودِ ، وَرَفْعُ الأَیْدِی فِی الدُّعَائِ ، قَالَ ہُشَیْمٌ : وَنَسِیتُ الثَّالِثَۃَ۔",,,4228
4229,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ قُرَیْرٍ ، قَالَ : سَأَلْتُ ابْنَ سِیرِینَ عَنِ اخْتِصَارِ السُّجُودِ ؟ فَکَرِہَہُ وَعَبَسَ وَجْہُہُ ، وَقَالَ : لاَ أَدْرِی مَا ہَذَا۔",,,4229
4230,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ مَعْمَرٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : ہُوَ مِمَّا أَحْدَثَ النَّاسُ۔",,,4230
4231,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ تُخْتَصَرَ السَّجْدَۃُ۔",,,4231
4232,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ یُکْرَہُ أَنْ یُخْتَصَرَ سُجُودُ الْقُرْآنِ۔",,,4232
4233,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ، عَنِ أَبِی الْمُعْتَمِرِ، عَنْ قَتَادَۃَ، عَنْ شَہْرِ بْنِ حَوْشَبٍ، قَالَ: ہُوَ مِمَّا أَحْدَثَ النَّاسُ۔",,,4233
4234,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، عَنْ مِسْعَرٍ ، عَنْ وَبَرَۃَ ، قَالَ : سَأَلْتُ ابْنَ عُمَرَ ، وَأَنَا مُقْبِلٌ مِنَ الْمَدِینَۃِ عَنِ الرَّجُلِ یَقْرَأُ السَّجْدَۃَ وَہُوَ عَلَی الدَّابَّۃِ ؟ قَالَ : یُومِیئُ۔",,,4234
4235,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَقْرَأُ السَّجْدَۃَ وَہُوَ عَلَی دَابَّۃٍ ، قَالَ : یُومِیئُ بِرَأْسِہِ إیمَائً حَیْثُ کَانَ وَجْہُہُ۔",,,4235
4236,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : کُنْتُ أَسِیرُ مَعَ أَبِی عُبَیْدَۃَ بَیْنَ الْکُوفَۃِ وَالْحِیرَۃِ ، فَقَرَأَ السَّجْدَۃَ ، فَذَہَبْت أَنْزِلُ لأَسْجُدَ ، فَقَالَ : یُجْزِیک أَنْ تُومِیئَ بِرَأْسِکَ ، قَالَ : وَأَوْمَأَ بِرَأْسِہِ۔",,,4236
4237,حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ ثُوَیْرٍ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَانَ یَقْرَأُ السَّجْدَۃَ وَہُوَ عَلَی رَاحِلَتِہِ فَیُومِیئُ۔,,,4237
4238,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ سَعِیدِ بْنِ زَیْدٍ ، قَالَ : کَانَ یَقْرَأُ السَّجْدَۃَ عَلَی رَاحِلَتِہِ فَیُومِیئُ۔",,,4238
4239,"حَدَّثَنَا وَکِیعٌ، عَنْ إسْرَائِیلَ، عَنْ ثُوَیْرٍ، قَالَ: رَأَیْتُ ابْنَ الزُّبَیْرِ یَقْرَأُ السَّجْدَۃَ وَہُوَ عَلَی رَاحِلَتِہِ، فَیُومِیئُ۔",,,4239
4240,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَقْرَأُ السَّجْدَۃَ وَہُوَ عَلَی دَابَّتِہِ ، قَالَ: یُومِیئُ۔",,,4240
4241,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ شِبَاکٍ ، عَنْ إِبْرَاہِیمَ ؛ قَالَ : إِذَا قَرَأَ السَّجْدَۃَ وَہُوَ عَلَی دَابَّتِہِ أَوْمَأَ بِرَأْسِہِ إِیمَائً۔",,,4241
4242,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حَدَّثَنَا مِسْعَرٌ ، قَالَ : حدَّثَنَا حَمَّادٌ ؛ أَنَّ إبْرَاہِیمَ سَأَلَ عَلْقَمَۃَ : أَیَنْزِلُ عَنْ دَابَّتِہِ لِلسَّجْدَۃِ ؟ فَأَمَرَہُ أَنْ لاَ یَنْزِلَ۔",,,4242
4243,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إنَّمَا السَّجْدَۃُ عَلَی مَنْ جَلَسَ لَہَا۔",,,4243
4244,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : قَالَ عُمَرُ : إنَّمَا السَّجْدَۃُ فِی الْمَسْجِدِ ، وَعِنْدَ الذِّکْرِ۔",,,4244
4245,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی الْعَوَّامِ ، عَنْ عَطَائٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إنَّمَا السَّجْدَۃُ عَلَی مَنْ جَلَسَ لَہَا۔",,,4245
4246,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ، قَالَ : إنَّمَا السُّجُودُ عَلَی مَنْ جَلَسَ لَہُ ، وَأَنْصَتَ۔",,,4246
4247,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عُثْمَانَ ، قَالَ : إنَّمَا السَّجْدَۃُ عَلَی مَنْ جَلَسَ لَہَا۔",,,4247
4248,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ قَاصًّا کَانَ یَجْلِسُ قَرِیبًا مِنْ مَجْلِسِہِ ، فَیَقْرَأُ السَّجْدَۃَ ، فَلاَ یَسْجُدُ سَعِیدٌ وَقَدْ سَمِعَہَا ، قَالَ : فَقِیلَ لَہُ : فَمَا یَمْنَعُک مِنَ السُّجُودِ ؟ قَالَ : لَیْسَ إلَیْہِ جَلَسْتُ۔",,,4248
4249,"حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، وَنَافِعٍ ، وَسَعِید بْنِ جُبَیْرٍ ، قَالُوا : مَنْ سَمِعَ السَّجْدَۃَ ، فَعَلَیْہِ أَنْ یَسْجُدَ۔",,,4249
4250,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : دَخَلَ سَلْمَانُ الْفَارِسِیُّ الْمَسْجِدَ وَفِیہِ قَوْمٌ یَقْرَؤُونَ ، فَقَرَؤُوا السَّجْدَۃَ فَسَجَدُوا ، فَقَالَ لَہُ صَاحِبُہُ : یَا أَبَا عَبْدِ اللہِ ، لَوْلاَ أَتَیْنَا ہَؤُلاَئِ الْقَوْمَ ، فَقَالَ : مَا لِہَذَا غَدَوْنَا۔",,,4250
4251,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنِ الْجُرَیْرِیِّ ، عَنْ أَبِی الْعَلاَئِ ، عَنْ مُطَرِّفٍ ، قَالَ : سَأَلْتُہُ عَنِ الرَّجُلِ یَتَمَارَی فِی السَّجْدَۃِ ، أَسَمِعَہَا أَمْ لَمْ یَسْمَعْہَا ؟ قَالَ : وَسَمِعَہَا ، فَمَاذَا ؟ ثُمَّ قَالَ مُطَرِّفٌ : سَأَلْتُ عِمْرَانَ بْنَ حُصَیْنٍ عَنْ الرَّجُلِ لاَ یَدْرِی أَسَمِعَ السَّجْدَۃَ ، أَمْ لاَ ؟ قَالَ : وَسَمِعَہَا ، فَمَاذَا ؟۔",,,4251
4252,"حَدَّثَنَا وَکِیعٌ ، وَمُحَمَّدُ بْنُ بِشْرٍ ، عَنْ مِسْعَرٍ ، عَنْ عَطِیَّۃَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إنَّمَا السَّجْدَۃُ عَلَی مَنْ سَمِعَہَا۔",,,4252
4253,"حَدَّثَنَا عَبْدُ اللہِ بْنُ الْمُبَارَکِ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، وَالْحَسَنِ ، قَالاَ : قَالَ عُمَرُ : لَیْسَ فِی الْمُفَصَّلِ سُجُودٌ۔",,,4253
4254,"حَدَّثَنَا ہُشَیْمٌ، أَخْبَرَنَا خَالِدٌ، عَنِ أَبِی الْعُرْیَان الْمُجَاشِعِیِّ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: لَیْسَ فِی الْمُفَصَّلِ سُجُود۔",,,4254
4255,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنِ الْحَسَنِ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ کَانَ یَقُولُ : لَیْسَ فِی الْمُفَصَّلِ سُجُود۔",,,4255
4256,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : لَیْسَ فِی الْمُفَصَّلِ سُجُود۔",,,4256
4257,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ ، عَنِ الْحَسَنِ ، کَانَ یَقُولُ : لَیْسَ فِی الْعَرَبِیِّ سُجُودٌ ، یَعْنِی الْمُفَصَّلَ۔",,,4257
4258,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، وَعِکْرِمَۃَ ، وَالْحَسَنِ ، قَالُوا : لَیْسَ فِی الْمُفَصَّلِ سُجُودٌ۔",,,4258
4259,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَیْمَنِ بْنِ نَابِلٍ ، قَالَ : سَمِعْتُ طَاوُوسًا یَقُولُ : لَیْسَ فِی الْمُفَصَّلِ سُجُودُ۔",,,4259
4260,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ اللہِ بْنِ قُسَیْطٍ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، عَنْ زَیْدِ بْنِ ثَابِتٍ ، قَالَ : قرَأْتُ عَلَی رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ النَّجْمَ ، فَلَمْ یَسْجُدْ۔ (بخاری 1073۔ ابوداؤد 1399)",,,4260
4261,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَطَائِ بْنِ یَسَارٍ ، قَالَ : سَأَلْتُ أُبَیَّ بْنَ کَعْبٍ : فِی الْمُفَصَّلِ سُجُودٌ ؟ قَالَ : لاَ۔",,,4261
4262,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنْ قَیْسِ بْنِ سَعْدٍ ، عَنْ مُجَاہِدٍ ، قَالَ : لَیْسَ فِی الْمُفَصَّلِ سُجُودٌ۔",,,4262
4263,"حَدَّثَنَا وَکِیعٌ ، عَنْ دَاوُدَ بْنِ قَیْسٍ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَطَائِ بْنِ یَسَارٍ ، عَنْ أُبَیِّ بْنِ کَعْبٍ ، قَالَ : لَیْسَ فِی الْمُفَصَّلِ سُجُودٌ۔",,,4263
4264,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ أَیُّوبَ بْنِ مُوسَی ، عَنْ عَطَائِ بْنِ مِینَائٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : سَجَدْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی {إذَا السَّمَائُ انْشَقَّتْ} ، وَ {اقْرَأْ بِاسْمِ رَبِّکَ الَّذِی خَلَقَ}۔ (مسلم 108۔ احمد 2/461)",,,4264
4265,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ حَزْمٍ ، عَنْ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، عَنْ أَبِی بَکْرِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ الْحَارِثِ بْنِ ہِشَامٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَجَدَ فِی : {إذَا السَّمَائُ انْشَقَّتْ} ۔(ابن ماجہ 1059۔ احمد 2/247)",,,4265
4266,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَلِیُّ بْنُ زَیْدِ بْنِ جُدْعَانَ ، عَنْ أَبِی رَافِعٍ ، قَالَ : صَلَّیْتُ خَلْفَ أَبِی ہُرَیْرَۃَ بِالْمَدِینَۃِ الْعِشَائَ الآخِرَۃَ ، قَالَ : فَقَرَأَ فِیہَا {إذَا السَّمَائُ انْشَقَّتْ} فَسَجَدَ فِیہَا ، فَقُلْتُ لَہُ : تَسْجُدُ فِیہَا ؟ فَقَالَ: رَأَیْت خَلِیلِی أَبَا الْقَاسِمِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَجَدَ فِیہَا ، فَلاَ أَدَعُ ذَلِکَ۔ (طحاوی 357)",,,4266
4267,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الأَسْوَدِ ، عَنْ عَبْدِ اللہِ ، قَالَ : سَجَدَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی النَّجْمِ ، فَمَا بَقِیَ أَحَدٌ إِلاَّ سَجَدَ مَعَہُ ، إِلاَّ شَیْخًا أَخَذَ کَفًّا مِنْ تُرَابٍ ، فَرَفَعَہُ إلَی جَبْہَتِہِ ، قَالَ : فَلَقَدْ رَأَیْتُہُ قُتِلَ کَافِرًا۔ (بخاری 3972۔ ابوداؤد 1401)",,,4267
4268,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، عَنْ عَلِیِّ بْنِ سُوَیْد بْنِ مَنْجُوفٍ ، قَالَ : حَدَّثَنَا أَبُو رَافِعٍ الصَّائِغُ ، قَالَ : صَلَّی بِنَا عُمَرُ صَلاَۃَ الْعِشَائِ الآخِرَۃِ ، فَقَرَأَ فِی إحْدَی الرَّکْعَتَیْنِ الأُولَیَیْنِ: {إذَا السَّمَائُ انْشَقَّتْ} فَسَجَدَ ، وَسَجَدْنَا مَعَہُ۔",,,4268
4269,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : رَأَیْتُ عُمَرَ ، وَعَبْدَ اللہِ یَسْجُدَانِ فِی {إذَا السَّمَائُ انْشَقَّتْ} ، أَوْ أَحَدَہُمَا۔",,,4269
4270,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنِ الْمَسْعُودِیِّ ، عَنِ ابْنِ الأَصْبَہَانِیِّ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ، عَنِ ابْنِ مَسْعُودٍ؛ أَنَّہُ کَانَ یَسْجُدُ فِی {إذَا السَّمَائُ انْشَقَّتْ}۔,,,4270
4271,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ دَاوُدَ ، عَنْ أَبِی الْعَالِیَۃِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَجَدَ فِی النَّجْمِ ، وَالْمُسْلِمُونَ۔,,,4271
4272,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ بْنِ مَسْعُودٍ ؛ أَنَّہُ کَانَ یَسْجُدُ فِی الأَعْرَافِ ، وَبَنِی إسْرَائِیلَ ، وَالنَّجْمِ وَ : {اقْرَأْ بِاسْمِ رَبِّکَ الَّذِی خَلَقَ}۔",,,4272
4273,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ سَجَدَ فِی النَّجْمِ وَ{اقْرَأْ بِاسْمِ رَبِّکَ الَّذِی خَلَقَ}۔,,,4273
4274,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ شُعْبَۃَ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، قَالَ : عَزَائِمُ السُّجُودِ ؛ (الم تَنْزِیلُ) وَ(حم تَنْزِیلُ) وَ(النَّجْمُ) وَ{اقْرَأْ بِاسْمِ رَبِّکَ الَّذِی خَلَقَ}۔",,,4274
4275,حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ (وَالنَّجْمِ) فَسَجَدَ فِیہَا الْمُسْلِمُونَ ، وَالْمُشْرِکُونَ ، وَالْجِنُّ ، وَالإِنْسُ۔,,,4275
4276,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَاصِمٍ ، عَنْ قَسَامَۃَ بْنِ زُہَیْرٍ ، قَالَ : کَانَ یَسْجُدُ فِی النَّجْمِ ، وَ {إذَا السَّمَائُ انْشَقَّتْ}۔",,,4276
4277,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ بْنِ جَابِرٍ ، عَنْ سُلَیْمَانَ بْنِ حَبِیبٍ ، قَالَ : سَجَدْت مَعَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ فِی {إذَا السَّمَائُ انْشَقَّتْ}۔",,,4277
4278,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، قَالَ : رَأَیْتُ إبْرَاہِیمَ یَسْجُدُ فِی {إذَا السَّمَائُ انْشَقَّتْ}۔",,,4278
4279,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کَانَ یَسْجُدُ فِی النَّجْمِ ، وَفِی {اقْرَأْ بِاسْمِ رَبِّک} إِلاَّ أَنْ یَقْرَأَ بِہِمَا فِی صَلاَۃٍ مَکْتُوبَۃٍ ، فَإِنَّہُ کَانَ لاَ یَسْجُدُ بِہِمَا وَیَرْکَعُ۔",,,4279
4280,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قَرَأَ مُحَمَّدٌ : {إذَا السَّمَائُ انْشَقَّتْ} وَأَنَا جَالِسٌ فَسَجَدَ فِیہَا۔",,,4280
4281,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، قَالَ : قَرَأَ عَمَّارٌ عَلَی الْمِنْبَرِ : {إذَا السَّمَائُ انْشَقَّتْ} ، ثُمَّ نَزَلَ إلَی الْقَرَارِ ، فَسَجَدَ بِہَا۔",,,4281
4282,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، عَنْ مَسْرُوقِ بْنِ الأَجْدَعِ ؛ أَنَّ عُثْمَانَ قَرَأَ فِی الْعِشَائِ بِالنَّجْمِ ، فَسَجَدَ۔,,,4282
4283,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الْحَارِثِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِی سَلَمَۃَ، عَنْ أَبِی ہُرَیْرَۃَ، قَالَ: سَجَدَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَالْمُسْلِمُونَ فِی (النَّجْمِ) إِلاَّ رَجُلَیْنِ مِنْ قُرَیْشٍ أَرَادَا بِذَلِکَ الشُّہْرَۃَ۔ (احمد 2/304)",,,4283
4284,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، عَنِ الأَسْوَدِ ، قَالَ : رَأَیْتُ عَبْدَ اللہِ یَسْجُدُ فِی {إذَا السَّمَائُ انْشَقَّتْ}۔",,,4284
4285,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، سَمِعَ ابْنَ عَبَّاسٍ یَقُولُ : فِی (ص) سَجْدَۃٌ ، وَتَلاَ: (أُولَئِکَ الَّذِینَ ہَدَی اللَّہُ فَبِہُدَاہُمُ اقْتَدِہِ)۔",,,4285
4286,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَبْدَۃَ ، وَصَدَقَۃَ ، سَمِعَا ابْنَ عُمَرَ یَقُولُ : فِی (ص) سَجْدَۃٌ۔",,,4286
4287,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : کُنْتُ لاَ أَسْجُدُ فِی (ص) حَتَّی حَدَّثَنِی السَّائِبُ أَنَّ عُثْمَانَ سَجَدَ فِیہَا۔",,,4287
4288,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّ عُمَرَ کَانَ یسْجُدُ فِی (ص)۔",,,4288
4289,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، وَالْعَوَّامُ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَسْجُدُ فِی (ص) وَتَلاَ ہَذِہِ الآیَۃَ : {أُولَئِکَ الَّذِینَ ہَدَی اللَّہُ فَبِہُدَاہُمُ اقْتَدِہِ}۔ (بخاری 3422۔ ابوداؤد 1404)",,,4289
4290,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْجُدُ فِی (ص)۔",,,4290
4291,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْعَوَّامُ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ سُورَۃَ (ص) وَہُوَ عَلَی الْمِنْبَرِ ، فَلَمَّا أَتَی عَلَی السَّجْدَۃِ قَرَأَہَا ، ثُمَّ نَزَلَ فَسَجَدَ۔",,,4291
4292,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ عَبْدِ اللہِ بْنِ الْحَارِثِ ، قَالَ : ہِیَ مُوجَبَۃٌ، سَجْدَۃُ (ص)۔",,,4292
4293,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ، قَالَ : ذُکِرت عِنْدَ ابْنِ عَبَّاسٍ ، فَقَالَ : {أُولَئِکَ الَّذِینَ ہَدَی اللَّہُ فَبِہُدَاہُمُ اقْتَدِہِ}۔",,,4293
4294,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : کَانَ طَاوُوس یَسْجُدُ فِی (ص)۔",,,4294
4295,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، قَالَ : شَہِدْتُ الْحَسَنَ وَقَرَأَ السَّجْدَۃَ الَّتِی فِی (ص) فَسَجَدَ۔",,,4295
4296,حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ؛ أَنَّہُ کَانَ یَسْجُدُ فِی (ص)۔,,,4296
4297,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ بْنِ عَمْرو ، عَنْ زَائِدَۃَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : کَانَ أَبُو عَبْدِ الرَّحْمَنِ یَسْجُدُ فِی (ص)۔",,,4297
4298,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ مُصْعَبِ بْنِ شَیْبَۃَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : رَأَیْتُ الضَّحَّاکَ بْنَ قَیْسٍ یَسْجُدُ فِی (ص) ، قَالَ : فَذَکَرْتُہُ لابْنِ عَبَّاسٍ ، فَقَالَ : إِنَّہُ رَأَی عُمَرَ بْنَ الْخَطَّابِ یَسْجُدُ فِیہَا۔",,,4298
4299,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ مُجَاہِدٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّہُ قَالَ : فِیہَا سَجْدَۃٌ ، ثُمَّ قَرَأَ : {أُولَئِکَ الَّذِینَ ہَدَی اللَّہُ فَبِہُدَاہُمُ اقْتَدِہِ}۔",,,4299
4300,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ کَانَ لاَ یَسْجُدُ فِی (ص) وَیَقُولُ : تَوْبَۃُ نَبِیٍّ۔",,,4300
4301,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ، قَالَ : ذُکِرَتْ (ص) عِنْدَ عَبْدِ اللہِ ، فَقَالَ: تَوْبَۃُ نَبِیٍّ۔",,,4301
4302,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ (ح) وَأَخْبَرَنَا دَاوُد ، عَنِ الشَّعْبِیِّ ، قَالاَ : کَانَ عَبْدُ اللہِ لاَ یَسْجُدُ فِی (ص) وَیَقُولُ : تَوْبَۃُ نَبِیٍّ۔",,,4302
4303,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِی مَعَنْ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : کَانَ بَعْضُ أَصْحَابِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْجُدُ فِی (ص) ، وَبَعْضُہُمْ لاَ یَسْجُدُ ، فَأَیَّ ذَلِکَ شِئْتَ فَافْعَلْ۔",,,4303
4304,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدِ ، عَنْ ثَابِتِ بْنِ قَیْسٍ ، قَالَ : کَانَ أَبُو الْمَلِیحِ لاَ یَسْجُدُ فِی (ص)۔",,,4304
4305,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : سَمِعْتُہُ یُحَدِّثُ عَنِ الضَّحَّاکِ بْنِ قَیْسٍ ؛ أَنَّہُ خَطَبَ فَقَرَأَ : (ص) فَسَجَدَ فِیہَا ، وَعَلْقَمَۃُ وَأَصْحَابُ عَبْدِ اللہِ وَرَائَہُ ، فَلَمْ یَسْجُدُوا۔",,,4305
4306,حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ؛ أَنَّ أَصْحَابَ عَبْدِ اللہِ کَانُوا لاَ یَسْجُدُونَ فِی (ص)۔,,,4306
4307,حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَانَ یَسْجُدُ فِی آخِرِ الآَیَتَیْنِ مِنْ (حم) السَّجْدَۃِ۔,,,4307
4308,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ أَبِی وَائِلٍ ؛ أَنَّہُ کَانَ یَسْجُدُ فِی الآخِرَۃِ۔",,,4308
4309,حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ یَسْجُدُ فِی الآخِرَۃِ۔,,,4309
4310,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ طَلْحَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَسْجُدُ فِی الآخِرَۃِ۔,,,4310
4311,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، قَالَ : کَانَ ابْنُ عَبَّاسٍ یَسْجُدُ بِالآخِرَۃِ۔",,,4311
4312,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنِ الْحَکَمِ ، عَنْ رَجُلٍ مِنْ بَنِی سُلَیْمٍ ؛ أَنَّہُ سَمِعَ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْجُدُ فِی (حم) بِالآَیَۃِ الأُولَی۔,,,4312
4313,حَدَّثَنَا ہُشَیْمٌ ، عَنْ حَجَّاجٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَسْجُدُ بِالأُولَی۔,,,4313
4314,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ أَبِی الضُّحَی، عَنْ مَسْرُوقٍ، قَالَ: کَانَ أَصْحَابُ عَبْدِاللہِ یَسْجُدُونَ بِالأُولَی۔",,,4314
4315,حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ عَطَائٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ کَانَ یَسْجُدُ بِالآَیَۃِ الأُولَی مِنْ (حم)۔,,,4315
4316,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنِ الأَعْمَشِ ، قَالَ : أَدْرَکْتُ إبْرَاہِیمَ ، وَأَبَا صَالِحٍ ، وَطَلْحَۃَ ، وَیَحْیَی ، وَزُبَیْدًا الْیَامِیَّ ؛ یَسْجُدُونَ بِالآَیَۃِ الأُولَی مِنْ (حم) السَّجْدَۃِ۔",,,4316
4317,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، وَمُحَمَّدٍ ؛ أَنَّہُمَا کَانَا یَسْجُدَانِ بِالآَیَۃِ الأُولَی مِنْ (حم) السَّجْدَۃِ۔,,,4317
4318,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مَنْصُورٍ ، عَنِ ابْنِ سِیرِینَ ، عَنِ ابْنِ عُمَرَ ، عَنْ عُمَرَ ؛ أَنَّہُ سَجَدَ فِی الْحَجِّ سَجْدَتَیْنِ ، ثُمَّ قَالَ : إنَّ ہَذِہِ السُّورَۃَ فُضِّلَتْ عَلَی سَائِرِ السُّوَرِ بِسَجْدَتَیْنِ۔",,,4318
4319,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعد بْنِ إِبْرَاہِیمَ ، عَن ثَعْلَبَۃَ بْنِ عَبْدِ اللہِ بْنِ الأَصْعَرِ ؛ أَنَّہُ صَلَّی مَعَ عُمَرَ بْنِ الْخَطَّابِ ، فَقَرَأَ بِالْحَجِّ فَسَجَدَ فِیہَا سَجْدَتَیْنِ۔,,,4319
4320,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنْ یَزِیدَ بْنِ خُمَیْرٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ جُبَیْرِ بْنِ نُفَیْرٍ ، عَنْ أَبِیہِ ؛ أَنَّ أَبَا الدَّرْدَائِ سَجَدَ فِی الْحَجِّ سَجْدَتَیْنِ۔,,,4320
4321,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنْ أَبِی الْعَالِیَۃِ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : فِی سُورَۃِ الْحَجِّ سَجْدَتَانِ۔",,,4321
4322,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرنَا أَبُو عَبْدِ اللہِ الْجُعْفِیُّ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ السُّلَمِیِّ ، عَنْ عَلِیٍّ ؛ أَنَّہُ سَجَدَ فِی الْحَجِّ سَجْدَتَیْنِ۔",,,4322
4323,حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُصَیْنٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ کَانَ یَسْجُدُ فِی الْحَجِّ سَجْدَتَیْنِ۔,,,4323
4324,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی رَوَّادٍ ، عَنْ رَجُلٍ مِنْ أَہْلِ الطَّائِفِ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرٍو ؛ أَنَّہُ سَجَدَ فِی الْحَجِّ سَجْدَتَیْنِ۔,,,4324
4325,"حَدَّثَنَا وَکِیعٌ ، عَنْ خَالِدِ بْنِ دِینَارٍ ، قَالَ : سَمِعْتُ أَبَا الْعَالِیَۃِ یَقُولُ : فِی الْحَجِّ سَجْدَتَانِ مُبَارَکَتَانِ طَیِّبَتَانِ۔",,,4325
4326,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : أَدْرَکْتُ النَّاسَ مُنْذُ سَبْعِینَ سَنَۃً یَسْجُدُونَ فِی الْحَجِّ سَجْدَتَیْنِ۔",,,4326
4327,حَدَّثَنَا عَبْدُ الصَّمَدِ بْنُ عَبْدِ الْوَارِثِ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، وَأَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّہُمَا کَانَا یَسْجُدَانِ فِی الْحَجِّ سَجْدَتَیْنِ۔,,,4327
4328,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنْ أَبِی الْعُرْیَانِ الْمُجَاشِعِیِّ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: فِی الْحَجِّ سَجْدَۃٌ وَاحِدَۃٌ۔",,,4328
4329,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، أَنَّہُ کَانَ یَقُولُ : فِی الْحَجِّ سَجْدَۃٌ وَاحِدَۃٌ۔",,,4329
4330,"حَدَّثَنَا ہُشَیْمٌ قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إِبْرَاہِیمَ ، قَالَ : فِی الْحَجِّ سَجْدَۃٌ وَاحِدَۃٌ۔",,,4330
4331,"حَدَّثَنَا ہُشَیْمٌ ، عَنِ الْعَوَّامِ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ فِی السَّجْدَۃِ : ہِیَ السَّجْدَۃُ الأُولَی مِنْ سُورَۃِ الْحَجِّ۔",,,4331
4332,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ ، قَالاَ : فِی الْحَجِّ سَجْدَۃٌ وَاحِدَۃٌ ، الأُولَی مِنْہُمَا۔\n\n حَدَّثَنَا ابْنُ فُضَیْلٍ، عَنِ الأَعْمَشِ، عَنْ إبْرَاہِیمَ؛ أَنَّہُ قَالَ: لَیْسَ فِی الْحَجِّ إِلاَّ سَجْدَۃٌ وَاحِدَۃٌ، وَہِیَ الأُولَی۔",,,4332
4333,"حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِی مَعَنْ ، قَالَ : قُلْتُ لِجَابِرِ بْنِ زَیْد : رَجُلٌ سَجَدَ فِی الْحَجِّ سَجْدَتَیْنِ ؟ قَالَ : لاَ یَسْجُدُ إِلاَّ وَاحِدَۃً۔",,,4333
4334,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، وَحَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ؛ فِی الرَّجُلِ یَسْمَعُ السَّجْدَۃَ وَہُوَ فِی الصَّلاَۃ ، قَالَ : لاَ یَسْجُدُ۔",,,4334
4335,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ، قَالَ : لاَ یَسْجُدُ۔",,,4335
4336,"حَدَّثَنَا قَاسِمُ بْنُ مَالِکٍ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ؛ فِی الرَّجُلِ یَسْمَعُ السَّجْدَۃَ وَہُوَ یُصَلِّی ، قَالَ : لاَ یَسْجُدُ۔",,,4336
4337,"حَدَّثَنَا ابْنُ مُبَارَکِ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : لاَ تُدْخِلْ فِی صَلاَتِکَ صَلاَۃَ غَیْرِک۔",,,4337
4338,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : یَسْجُدُ إذَا انْصَرَفَ۔",,,4338
4339,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ حَبِیبٍ ، عَنْ عَمْرِو بْنِ ہَرِمٍ ، قَالَ : سُئِلَ جَابِرُ بْنُ زَیْدٍ عَنْ رَجُلٍ قَائِمٍ یُصَلِّی ، وَرَجُلٌ یُصَلِّی قَرِیبًا مِنْہُ ، فَقَرَأَ السَجْدَۃً ، أَیَسْجُدُ إذَا سَمِعَہَا ؟ قَالَ : لاَ۔",,,4339
4340,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَقُولُ : إذَا سَمِعَ الرَّجُلُ السَّجْدَۃَ وَہُوَ یُصَلِّی فَلْیَسْجُدْ۔",,,4340
4341,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَلْحَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَسْجُدُ۔",,,4341
4342,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : کَانَ أَصْحَابُ عَبْدِ اللہِ إذَا سَمِعُوا السَّجْدَۃَ سَجَدُوا ، فِی صَلاَۃٍ کَانُوا ، أَوْ غَیْرِہَا۔",,,4342
4343,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ حَمَّادًا عَنِ الرَّجُلِ یُصَلِّی فَسَمِعَ السَّجْدَۃَ ؟ قَالَ : یَسْجُدُ ، وَقَالَ الْحَکَمُ مِثْلَ ذَلِکَ۔",,,4343
4344,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا سَمِعَ الرَّجُلُ السَّجْدَۃَ وَہُوَ یُصَلِّی ، فَلْیَخِرَّ سَاجِدًا۔",,,4344
4345,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَقُولُ فِی الْجُنُبِ إذَا سَمِعَ السَّجْدَۃَ : یَغْتَسِلُ ثُمَّ یَقْرَؤُہَا فَیَسْجُدُ بِہَا ، وَإِنْ کَانَ لاَ یُحْسِنُہَا قَرَأَ غَیْرَہَا ، ثُمَّ سَجَدَ۔",,,4345
4346,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ حَمَّادٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ، أَنَّہُمَا قَالاَ : إذَا سَمِعَ الْجُنُبُ السَّجْدَۃَ اغْتَسَلَ ، ثُمَّ سَجَدَ۔",,,4346
4347,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَقُولُ فِی الْحَائِضِ تَسْمَعُ السَّجْدَۃَ ، قَالَ : لاَ تَسْجُدُ ، ہِیَ تَدَعُ مَا ہُوَ أَعْظَمُ مِنَ السَّجْدَۃِ ، الصَّلاَۃ الْمَکْتُوبَۃَ۔",,,4347
4348,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حَجَّاجٍ ، عَنْ حَمَّادٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ ، وَإِبْرَاہِیمَ عَنِ الْحَائِضِ تَسْمَعُ السَّجْدَۃَ ؟ فَقَالاَ : لَیْسَ عَلَیْہَا سُجُودٌ ، الصَّلاَۃ أَکْبَرُ مِنْ ذَلِکَ۔",,,4348
4349,"حَدَّثَنَا مُحَمَّدُ بْنُ بَکْرٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : قُلْتُ لَہُ : أَرَأَیْتَ إِنْ مَرَّتْ حَائِضٌ بِقَوْمٍ یَقْرَؤُونَ الْمُصْحَفَ فَسَجَدُوا ، تَسْجُد مَعَہُمْ ؟ قَالَ : لاَ ، قَدْ مُنِعَتْ خَیْرًا مِنْ ذَلِکَ ،الصَّلاَۃ۔",,,4349
4350,"حَدَّثَنَا حَفْصٌ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ أَبِی الضُّحَی (ح) وَعَنْ إبْرَاہِیمَ ، قَالاَ : إذَا سَمِعَتِ الْحَائِضُ السَّجْدَۃَ فَلاَ تَسْجُدُ ، ہِیَ تَدَعُ أَوْجَبَ مِنْ ذَلِکَ۔",,,4350
4351,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ؛ فِی الْجُنُبِ وَالْحَائِضِ یَسْمَعَانِ السَّجْدَۃَ، فَقَال: لاَ یَسْجُدَانِ۔",,,4351
4352,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ أَبَانَ الْعَطَّارِ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ عُثْمَانَ ، قَالَ : تُومِیئُ بِرَأْسِہَا إیمَائً۔",,,4352
4353,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ، قَالَ: حدَّثَنَا سَعِیدٌ ، عَنْ قَتَادَۃَ ، عَنِ ابْنِ الْمُسَیَّبِ ، قَالَ : تُومِیئُ بِرَأْسِہَا وَتَقُولُ: اللَّہُمَّ لَکَ سَجَدْت۔",,,4353
4354,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا زَکَرِیَّا بْنُ أَبِی زَائِدَۃَ ، قَالَ : أَخْبَرَنَا أَبُو الْحَسَنِ ، عَنْ رَجُلٍ ، زَعَمَ أَنَّہُ کَنَفْسِہِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : کَانَ عَبْدُ اللہِ بْنُ عُمَرَ یَنْزِلُ عَنْ رَاحِلَتِہِ فَیُہْرِیقُ الْمَائَ ، ثُمَّ یَرْکَبُ فَیَقْرَأُ السَّجْدَۃَ فَیَسْجُدُ ، وَمَا تَوَضَّأَ۔",,,4354
4355,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَسْمَعُ السَّجْدَۃَ وَہُوَ عَلَی غَیْرِ وُضُوئٍ، فَلاَ سُجُودَ عَلَیْہِ۔",,,4355
4356,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا سَمِعَہُ وَہُوَ غَیْرُ طَاہِرٍ فَلْیَتَوَضَّأْ ، ثُمَّ لِیَقْرَأْہَا فَیَسْجُدْ ، فَإِنْ کَانَ لاَ یُحْسِنُہَا قَرَأَ غَیْرَہَا ، ثُمَّ سَجَدَ۔",,,4356
4357,"حَدَّثَنَا وَکِیعٌ ، عَنْ زَکَرِیَّا ، عَنِ الشَّعْبِیِّ ، قَالَ : فِی الرَّجُلِ یَقْرَأُ السَّجْدَۃَ وَہُوَ عَلَی غَیْرِ وُضُوئٍ ، قَالَ : یَسْجُدُ حَیْثُ کَانَ وَجْہُہُ۔",,,4357
4358,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَسْمَعُ السَّجْدَۃَ وَلَیْسَ عَلَی وُضُوئٍ ، قَالَ : إِنْ کَانَ عِنْدَہُ مَائٌ تَوَضَّأَ وَسَجَدَ ، وَإِنْ لَمْ یَکُنْ عِنْدَہُ مَائٌ تَیَمَّمَ وَسَجَدَ۔",,,4358
4359,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ مُحَمَّدِ بْنِ کُرَیْبٍ ، عَنْ أَبِیہِ ، عَنِ ابْنِ عَبَّاسٍ ؛ فِی الرَّجُلِ یَقْرَأُ السَّجْدَۃَ وَہُوَ عَلَی غَیْرِ الْقِبْلَۃِ أَیَسْجُدُ ؟ قَالَ : نَعَمْ ، لاَ بَأْسَ بِہِ۔",,,4359
4360,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرُ ، عَنِ الأَعْمَشِ ، عَنْ عَطَائٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : کَانَ یَقْرَأُ السَّجْدَۃَ وَہُوَ عَلَی غَیْرِ الْقِبْلَۃِ وَہُوَ یَمْشِی ، فَیُومِیئُ بِرَأْسِہِ ، ثُمَّ یُسَلِّمُ۔",,,4360
4361,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سُفْیَانَ بْنِ حُسَیْنٍ ، قَالَ : سَمِعْتُ الْحَسَنَ وَقَرَأَ السَّجْدَۃَ الَّتِی فِی (ص) فَسَجَدَ عَلَی حَرْفِ أُسْطُوَانَۃٍ ، ثُمَّ قَالَ لِلْقَوْمِ : تَوَجَّہُوا۔",,,4361
4362,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ کَانَ یَقْرَأُ بِہَا وَہُوَ جَالِسٌ ، فَیَسْتَقْبِلُ الْقِبْلَۃَ وَیَسْجُدُ۔,,,4362
4363,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا دَاوُد ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَانَ یَقُولُ : إذَا قَرَأَ الرَّجُلُ السَّجْدَۃَ بَعْدَ الْعَصْرِ وَبَعْدَ الْفَجْرِ ، فَلْیَسْجُدْ۔",,,4363
4364,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ (ح) وَمُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، أَنَّہُمَا قَالاَ : اقْرَأْ وَاسْجُدْ مَا کُنْتَ فِی وَقْتٍ بَعْدَ الْعَصْرِ ، وَبَعْدَ الْفَجْرِ۔",,,4364
4365,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ عَنِ الرَّجُلِ یَقْرَأُ السَّجْدَۃَ بَعْدَ الْعَصْرِ ؟ فَقَالَ الْحَکَمُ : قَدِمَ عَلَیْنَا رَجَائُ بْنُ حَیْوَۃَ زَمَانَ بَشْرِ بْنِ مَرْوَانَ ، وَکَانَ قَاصَّ الْعَامَّۃِ ، فَکَانَ یَقْرَأُ السَّجْدَۃَ بَعْدَ الْعَصْرِ فَیَسْجُدُ، قَالَ شُعْبَۃُ : وَسَأَلْت حَمَّادًا ، فَقَالَ : إذَا کَانَ فِی وَقْتِ صَلاَۃٍ فَلاَ بَأْسَ۔",,,4365
4366,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ جَابِرٍ ، عَنْ سَالِمٍ ، وَالْقَاسِمِ ، وَعَطَائٍ ، وَعَامِرٍ ؛ فِی الرَّجُلِ یَقْرَأُ السَّجْدَۃَ بَعْدَ الْعَصْرِ ، وَقَبْلَ أَنْ تَطْلُعَ الشَّمْسُ فَیَسْجُدُ ؟ قَالُوا : نَعَمْ۔",,,4366
4367,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : إذَا قَرَأْتَ الْقُرْآنَ فَأَتَیْت عَلَی السَّجْدَۃِ بَعْدَ الْعَصْرِ وَبَعْدَ الْغَدَاۃِ فَاسْجُدْ۔",,,4367
4368,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ خَالِدٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : إنَّمَا یَمْنَعُہُمْ مِنْ ذَلِکَ الْکَسَلُ۔",,,4368
4369,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ عُبَیْدِ اللہِ بْنِ مِقْسَمٍ ؛ أَنَّ قَاصًّا کَانَ یَقْرَأُ السَّجْدَۃَ بَعْدَ الْفَجْرِ فَیَسْجُدُ ، فَنَہَاہُ ابْنُ عُمَرَ فَأَبَی أَنْ یَنْتَہِیَ ، فَحَصَبَہُ ، وَقَالَ : إنَّہُمْ لاَ یَعْقِلُونَ۔",,,4369
4370,"حَدَّثَنَا وَکِیعٌ ، عَنْ ثَابِتِ بْنِ عُمَارَۃَ ، عَنْ أَبِی تَمِیمَۃَ الْہُجَیْمِیِّ ، قَالَ : کُنْتُ أَقْرَأُ السَّجْدَۃَ بَعْدَ الْفَجْرِ فَأَسْجُدُ ، فَأَرْسَلَ إلَیَّ ابْنُ عُمَرَ فَنَہَانِی۔",,,4370
4371,"حَدَّثَنَا أَزْہَرُ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَانَ سَعِیدُ بْنُ أَبِی الْحَسَنِ یَقْرَأُ بَعْدَ الْغَدَاۃِ ، فَیَمُرُّ بِالسَّجْدَۃِ فَیُجَاوِزُہَا ، فَإِذَا حَلَّتِ الصَّلاَۃ قَرَأَہَا وَسَجَدَ۔",,,4371
4372,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُبَارَکٍ ، قَالَ : رَأَیْتُ الْحَسَنَ قَرَأَ سَجْدَۃً بَعْدَ الْعَصْرِ ، فَلَمَّا غَابَتِ الشَّمْسُ قَرَأَہَا ، ثُمَّ سَجَدَ۔",,,4372
4373,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، قَالَ : أَخْبَرَنَا ثَابِتٌ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی عُتْبَۃَ ؛ أَنَّ أَبَا أَیُّوبَ کَانَ یُحَدِّثُ ، فَإِذَا بَزَغَتِ الشَّمْسُ قَرَأَ السَّجْدَۃَ فَسَجَدَ۔",,,4373
4374,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سَلِیمِ بْنِ حَیَّانَ ، عَنْ أَبِی غَالِبٍ ؛ أَنَّ أَبَا أُمَامَۃَ کَانَ یَکْرَہُ الصَّلاَۃ بَعْدَ الْعَصْرِ حَتَّی تَغْرُبَ الشَّمْسُ ، وَبَعْدَ الْفَجْرِ حَتَّی تَطْلُعَ الشَّمْسُ ، وَکَانَ أَہْلُ الشَّامِ یَقْرَؤُونَ السَّجْدَۃَ بَعْدَ الْعَصْرِ ، فَکَانَ أَبُو أُمَامَۃَ إذَا رَأَی أَنَّہُمْ یَقْرَؤُونَ سُورَۃً فِیہَا سَجْدَۃٌ بَعْدَ الْعَصْرِ ، لَمْ یَجْلِسْ مَعَہُمْ۔,,,4374
4375,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ مُحَمَّدِ بْنِ سُوقَۃَ ، عَنِ نَافِع ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ سَمِعَ قَاصًّا یَقْرَأُ السَّجْدَۃَ قَبْلَ أَنْ تَحِلَّ الصَّلاَۃ ، فَسَجَدَ الْقَاصُّ وَمَنْ مَعَہُ ، فَأَخَذَ ابْنُ عُمَرَ بِیَدَیَّ ، فَلَمَّا أَضْحَی ، قَالَ لِی : یَا نَافِعُ ، اُسْجُدْ بِنَا السَّجْدَۃَ الَّتِی سَجَدَہَا الْقَوْمُ فِی غَیْرِ حِینِہَا۔",,,4375
4376,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ؛ أَنَّہُ کَانَ یَسْجُدُ اثْنَتَیْ عَشْرَۃَ سَجْدَۃً فِی الْقُرْآنِ ، الَّتِی یَسْجُدُونَ فِیہَا ، لَمْ یَذْکُرْ فِیہَا : {إذَا السَّمَائُ انْشَقَّتْ}۔",,,4376
4377,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، قَالَ : عَدَّ عَلَیَّ مَسْرُوقٌ ثِنْتَیْ عَشْرَۃَ سَجْدَۃً فِی الْقُرْآنِ ، لَمْ یَذْکُرِ الَّتِی فِی {إذَا السَّمَائُ انْشَقَّتْ}۔",,,4377
4378,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ ، عَنْ أَبِی الْعُرْیَانِ الْمُجَاشِعِیِّ ، عَنِ ابْنِ عَبَّاسٍ ، وَذَکَرُوا سُجُودَ الْقُرْآنِ ، فَقَالَ : الأَعْرَافُ ، وَالرَّعْدُ ، وَالنَّحْلُ ، وَبَنِی إسْرَائِیلَ ، وَمَرْیَمُ ، وَالْحَجُّ سَجْدَۃٌ وَاحِدَۃٌ ، وَالنَّمْلُ، وَالْفُرْقَانُ ، وَ(الم تَنْزِیلُ) ، وَ(حم تَنْزِیل) ، وَ(ص) ، وَقَالَ : وَلَیْسَ فِی الْمُفَصَّلِ سُجُودٌ۔",,,4378
4379,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ بْنِ مَسْعُودٍ ؛ أَنَّہُ کَانَ یَسْجُدُ فِی الأَعْرَافِ ، وَبَنِی إسْرَائِیلَ ، وَالنَّجْمِ ، وَ{اقْرَأْ بِاسْمِ رَبِّکَ الَّذِی خَلَقَ} ، وَ{إذَا السَّمَائُ انْشَقَّتْ}۔,,,4379
4380,"حَدَّثَنَا ہُشَیْمٌ ، أَخْبَرَنَا أَبُو بِشْرٍ ، عَنْ یُوسُفَ الْمَکِّیِّ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ؛ أَنَّہُ قَالَ : عَزَائِمُ السُّجُودِ : (ألم تَنْزِیلُ) ، وَ(حٰمٓ تَنْزِیلُ) ، وَالأَعْرَافُ ، وَبَنِی إسْرَائِیلَ۔",,,4380
4381,"حَدَّثَنَا عَفَّانُ ، قَالَ : حَدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ عَلِیِّ بْنِ زَیْدٍ ، عَنْ یُوسُفَ بْنِ مِہْرَانَ ، عَنِ ابْنِ عَبَّاسٍ ، عَنْ عَلِیٍّ ، قَالَ : عَزَائِمُ سُجُود الْقُرْآن : (ألم تَنْزِیلُ) السَّجْدَۃَ ، وَ(حم تَنْزِیلُ)السَّجْدَۃَ ، وَالنَّجْمُ ، وَ(اقْرَأْ بِاسْمِ رَبِّکَ الَّذِی خَلَقَ)۔",,,4381
4382,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ دَاوُدَ ، یَعْنِی ابْنَ إیَاسٍ ، عَنْ جَعْفَرٍ ؛ أَنَّ سَعِیدَ بْنَ جُبَیْرٍ ، قَالَ : عَزَائِمُ السُّجُودِ : (الم تَنْزِیلُ) ، وَالنَّجْمُ ، وَ{اقْرَأْ بِاسْمِ رَبِّکَ الَّذِی خَلَقَ}۔",,,4382
4383,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حَدَّثَنَا ثَابِتُ بْنُ عُمَارَۃَ ، عَنْ أَبِی تَمِیمَۃَ الْہُجَیْمِیِّ ؛ أَنَّ أَشْیَاخًا مِنْ بَنِی الہُجَیْمِ بَعَثُوا رَاکِبًا لَہُمْ إلَی الْمَدِینَۃِ وَإِلَی مَکَّۃَ ، لِیَسْأَلَ لَہُمْ عَنْ سُجُودِ الْقُرْآنِ ، فَرَجَعَ إلَیْہِمْ فَأَخْبَرَہُمْ أَنَّہُمْ أَجْمَعُوا عَلَی عَشْرِ سَجَدَاتٍ۔",,,4383
4384,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : دَخَلْتُ الْمَسْجِدَ فَإِذَا أَنَا بِشَیْخَیْنِ یَقْرَأُ أَحَدُہُمَا عَلَی صَاحِبِہِ الْقُرْآنَ ، فَجَلَسْتُ إلَیْہِمَا ، فَإِذَا أَحَدُہُمَا قَیْسُ بْنُ السَّکَنِ الأَسَدِیُّ ، وَإِذَا الآَخَرُ یَقْرَأُ سُورَۃَ مَرْیَمَ ، فَلَمَّا بَلَغَ السَّجْدَۃَ قَالَ لَہُ قَیْسُ بْنُ سَکَنٍ : دَعْہَا ، فَإِنَّا نَکْرَہُ أَنْ یَرَانَا أَہْلُ الْمَسْجِدِ ، فَتَرَکَہَا وَقَرَأَ مَا بَعْدَہَا ، قَالَ قَیْسٌ : وَاللَّہِ مَا صَرَفَنَا عَنْہَا إِلاَّ شَیْطَانٌ ، اقْرَأْہَا ، فَقَرَأَہَا فَسَجَدنَا۔",,,4384
4385,"حَدَّثَنَا ہُشَیْمٌ ، وَعَلِیُّ بْنُ مُسْہِرٍ ، عَنْ دَاوُدَ ، عَنِ الشَّعْبِیِّ ، قَالَ : کَانُوا یَکْرَہُونَ إذَا أَتَوْا عَلَی السَّجْدَۃِ أَنْ یُجَاوِزُوہَا حَتَّی یَسْجُدُوا۔",,,4385
4386,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إسْمَاعِیلَ ، عَنِ الْحَسَنِ ؛ فِی الرَّجُلِ یَمُرُّ بِالسَّجْدَۃِ فِی الصَّلاَۃ ، فَقَالَ : لاَ یَنْبَغِی لَہُ أَنْ یَمَرَّ بِہَا فَیَتْرُکَہَا۔",,,4386
4387,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ إسْمَاعِیلَ ، عَنْ حَمَّادٍ ، عَنْ إِبْرَاہِیمَ ، قَالَ : لاَ یَنْبَغِی لَہُ إذَا مَرَّ بِہَا أَنْ یَتْرُکَہَا ، وَلَکِنْ یَسْجُدُ بِہَا ، وَإِنْ شَائَ رَکَعَ بِہَا۔",,,4387
4388,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، قَالَ : حَدَّثَنَا بَکْرُ بْنُ عَبْدِ اللہِ الْمُزَنِیّ ، عَنْ صَفْوَانَ بْنِ مُحْرِزٍ ، قَالَ: بَیْنَا الأَشْعَرِیُّ یَخْطُبُ یَوْمَ الْجُمُعَۃِ إذْ قَرَأَ السَّجْدَۃَ الآخِرَۃَ مِنْ سُورَۃِ الْحَجِّ ، قَالَ : فَنَزَلَ عَنِ الْمِنْبَرِ ، فَسَجَدَ ثُمَّ عَادَ إلَی مَجْلِسِہِ۔",,,4388
4389,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْعَوَّامُ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ سَجْدَۃَ سُورَۃِ (ص) عَلَی الْمِنْبَرِ ، فَلَمَّا أَتَی عَلَی السَّجْدَۃِ قَرَأَہَا ، ثُمَّ نَزَلَ فَسَجَدَ۔",,,4389
4390,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو إِسْحَاقَ الْکُوفِی ، عَنِ الشَّعْبِیِّ ، عَنِ النُّعْمَانِ بْنِ بَشِیرٍ ؛ أَنَّہُ قَرَأَ سَجْدَۃَ (ص) وَہُوَ عَلَی الْمِنْبَرِ ، فَنَزَلَ فَسَجَدَ ، ثُمَّ عَادَ إلَی مَجْلِسِہِ۔",,,4390
4391,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، عَنْ زِرٍّ ، قَالَ : قَرَأَ عَمَّارٌ عَلَی الْمِنْبَرِ : (إذَا السَّمَائُ أنْشَقَّتْ) ، ثُمَّ نَزَلَ إلَی الْقَرَارِ ، فَسَجَدَ بِہَا۔",,,4391
4392,حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ عُمَرَ قَرَأَہَا وَہُوَ عَلَی الْمِنْبَرِ ، ثُمَّ نَزَلَ فَسَجَدَ۔,,,4392
4393,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ شُرَیْحٍ ، قَالَ : حدَّثَنِی وَاہِبٌ الْمَعَافِرِیُّ ، عَنْ أَوْسِ بْنِ بِشْرٍ، قَالَ : رَأَیْتُ عُقْبَۃَ بْنَ عَامِرٍ قَرَأَ عَلَی الْمِنْبَرِ السَّجْدَۃَ ، فَنَزَلَ فَسَجَدَ۔",,,4393
4394,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ؛ فِی الْمَرْأَۃِ تَقْرَأُ السَّجْدَۃَ وَمَعَہَا رِجَالٌ ، أَوْ رَجُلٌ ، قَالَ : یَسْجُدُونَ قَبْلَہَا ، وَلاَ یَأْتَمُّونَ بِہَا۔",,,4394
4395,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ مُغِیرَۃَ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ عَنِ الْمَرْأَۃِ تَقْرَأُ السَّجْدَۃَ ؟ فَقَالَ : ہِیَ إمَامُک۔",,,4395
4396,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ؛ أَنَّ غُلاَمًا قَرَأَ عِنْدَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ السَّجْدَۃَ ، فَانْتَظَرَ الْغُلاَمُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یَسْجُدَ ، فَلَمَّا لَمْ یَسْجُدْ ، قَالَ : یَا رَسُولَ اللہِ ، أَلَیْسَ فِی ہَذِہِ السُّورَۃِ سَجْدَۃٌ ؟ قَالَ : بَلَی ، وَلَکِنَّک کُنْت إمَامَنَا فِیہَا ، فَلَوْ سَجَدْتَ لَسَجَدْنَا۔ (بیہقی 324)",,,4396
4397,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ سُلَیْمٍ أَبِی إِسْحَاقَ ، عَنْ سُلَیْمِ بْنِ حَنْظَلَۃَ ، قَالَ : قرَأْتُ عَلَی عَبْدِ اللہِ بْنِ مَسْعُودٍ سُورَۃَ بَنِی إسْرَائِیلَ ، فَلَمَّا بَلَغْتُ السَّجْدَۃَ ، قَالَ عَبْدُ اللہِ : اقْرَأْہَا ، فَإِنَّک إمَامُنَا فِیہَا۔",,,4397
4398,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ؛ أَنَّ عَلْقَمَۃَ ، وَالأَسْوَدَ ، وَمَسْرُوقًا ، وَعَمْرَو بْنَ شُرَحبیلَ ؛ کَانُوا یَقُولُونَ : إذَا کَانَتِ السَّجْدَۃُ آخِرَ السُّورَۃِ ، أَجْزَأک أَنْ تَرْکَعَ بِہَا۔",,,4398
4399,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا کَانَ فِی آخِرِ السُّورَۃِ سَجْدَۃٌ ، أَجْزَأک أَنْ تَرْکَعَ بِہَا۔",,,4399
4400,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ مَعْمَرٍ ، عَنِ ابْنِ طَاوُوس ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ یَقْرَأُ فِی الْعِشَائِ الآخِرَۃِ : (تَنْزِیلَ) السَّجْدَۃَ فَیَرْکَعُ بِالسَّجْدَۃِ۔",,,4400
4401,"حَدَّثَنَا ابْنُ إدْرِیسَ، عَنْ عَبْدِالْمَلِکِ بْنِ أَبِی سُلَیْمَانَ، قَالَ: سَمِعْتُ الشَّعْبِیَّ، وَسُئِلَ عَنِ الرَّجُلِ یَقْرَأُ بِالسَّجْدَۃِ فَتَکُونُ فِی آخِرِ السُّورَۃِ ؟ فَقَالَ : إِنْ ہُوَ سَجَدَ بِہَا قَامَ فَقَرَأَ بَعْدَہَا ، وَإِنْ شَائَ أَنْ یَرْکَعَ بِہَا رَکَعَ بِہَا۔",,,4401
4402,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، قَالَ : حَدَّثَنِی عُتْبَۃُ بْنُ قَیْسٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّہُ کَانَ یَقْرَأُ السَّجْدَۃَ فِی بَنِی إسْرَائِیلَ ، وَمَا بَعْدَہَا ، ثُمَّ یَرْکَعُ۔",,,4402
4403,"حَدَّثَنَا عُبَیْدُاللہِ ، قَالَ: أَخْبَرَنَا إسْرَائِیلُ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، عَنِ الرَّبِیعِ بْنِ خُثَیْمٍ، قَالَ : إذَا کَانَتِ السَّجْدَۃُ آخِرَ السُّورَۃِ ، فَإِنْ شِئْتَ فَارْکَعْ ، وَإِنْ شِئْتَ فَاسْجُدْ ، فَإِنَّ الرَّکْعَۃَ مَعَ السَّجْدَۃِ۔",,,4403
4404,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَوَکِیعٌ ، قَالاَ : حَدَّثَنَا سُفْیَانُ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ : سَأَلْنَا عَبْدَ اللہِ عَنِ السُّورَۃِ تَکُونُ فِی آخِرِہَا سَجْدَۃٌ ، أَیَرْکَعُ ، أَوْ یَسْجُدُ ؟ قَالَ : إذَا لَمْ یَکُنْ بَیْنَکَ وَبَیْنَ السَّجْدَۃِ إِلاَّ الرُّکُوعُ فَہُوَ قَرِیبٌ۔",,,4404
4405,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ ، عَنْ أَبِی الْعَالِیَۃِ ، عَنْ عَائِشَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَقُولُ فِی سُجُودِ الْقُرْآنِ : سَجَدَ وَجْہِی لِلَّذِی خَلَقَہُ وَصَوَّرَہُ ، وَشَقَّ سَمْعَہُ وَبَصَرَہُ ، بِحَوْلِہِ وَقُوَّتِہِ۔ (ترمذی 580۔ احمد 30)",,,4405
4406,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ زِیَادِ بْنِ الْحُصَیْنِ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَقُولُ فِی سُجُودِہِ : اللَّہُمَّ لَکَ سَجَدَ سَوَادِی ، وَبِکَ آمَنَ فُؤَادِی ، اللَّہُمَّ اُرْزُقْنِی عِلْمًا یَنْفَعُنِی ، وَعَمَلاً یَرْفَعُنِی۔",,,4406
4407,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ رَجُلٍ ، عَنْ أَبِی الْعَالِیَۃِ ، عَنْ عَائِشَۃَ ، قَالَتْ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ فِی سُجُودِ الْقُرْآنِ بِاللَّیْلِ فِی السَّجْدَۃِ مِرَارًا : سَجَدَ وَجْہِی لِمَنْ خَلَقَہُ ، وَشَقَّ سَمْعَہُ وَبَصَرَہُ ، بِحَوْلِہِ وَقُوَّتِہِ۔ (ابوداؤد 1409۔ احمد 217)",,,4407
4408,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ؛ أَنَّہُ کَانَ یَقُولُ إذَا قَرَأَ السَّجْدَۃَ {سُبْحَانَ رَبِّنَا إِنْ کَانَ وَعْدُ رَبِّنَا لَمَفْعُولاً} ، سُبْحَانَ اللہِ وَبِحَمْدِہِ ، سُبْحَانَ اللہِ وَبِحَمْدِہِ ، ثَلاَثًا۔,,,4408
4409,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : دَخَلْتُ الْمَسْجِدَ فَإِذَا أَنَا بِشَیْخَیْنِ یَقْرَأُ أَحَدُہُمَا عَلَی صَاحِبِہِ الْقُرْآنَ ، فَجَلَسْتُ إلَیْہِمَا فَإِذَا أَحَدُہُمَا قَیْسُ بْنُ سَکَنِ الأَسَدِیُّ ، وَالأَخَرُ یَقْرَأُ عَلَیْہِ سُورَۃَ مَرْیَمَ ، فَلَمَّا بَلَغَ السَّجْدَۃَ ، قَالَ لَہُ قَیْسٌ : دَعْہَا ، فَإِنَّا نَکْرَہُ أَنْ یَرَانَا أَہْلُ الْمَسْجِدِ ، فَتَرَکَہَا وَقَرَأَ مَا بَعْدَہَا ، ثُمَّ قَالَ قیْسٌ : وَاللَّہِ مَا صَرَفَنَا عَنْہَا إِلاَّ الشَّیْطَانُ ، اقْرَأْہَا ، فَقَرَأَہَا فَسَجَدْنَا ، فَلَمَّا رَفَعْنَا رُؤُوسَنَا ، قَالَ لَہُ قَیْسٌ : تَدْرِی مَا کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ إذَا سَجَدَ ؟ قَالَ : نَعَمْ ، کَانَ یَقُولُ : سَجَدَ وَجْہِی لِمَنْ خَلَقَہُ ، وَشَقَّ سَمْعَہُ وَبَصَرَہُ ، قَالَ : صَدَقْت ، وَبَلَغَنِی أَنَّ دَاوُد عَلَیْہِ السَّلاَمُ کَانَ یَقُولُ : سَجَدَ وَجْہِی مُتَعَفِّرًا فِی التُّرَابِ لِخَالِقِی وَحُقَّ لَہُ ، ثُمَّ قَالَ : سُبْحَانَ اللہِ ! مَا أَشْبَہَ کَلاَمَ الأَنْبِیَائِ بَعْضَہُم بِبَعض۔",,,4409
4410,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَرَأَ عَبْدُ اللہِ السَّجْدَۃَ فَسَجَدَ ، قَالَ إبْرَاہِیمُ: فَحَدَّثَنِی مَنْ سَمِعَہُ یَقُولُ فِی سُجُودِہِ : لَبَّیْکَ وَسَعْدَیْکَ ، وَالْخَیْرُ فِی یَدَیْک۔",,,4410
4411,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ؛ أَنَّ إبْرَاہِیمَ لَبَّی وَہُوَ سَاجِدٌ۔,,,4411
4412,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، قَالَ : قُلْتُ لإِبْرَاہِیمَ : قَرَأْتُ سَجْدَۃً فَسَجَدْت بِہَا ، فَأَضَفْتُ إلَیْہَا سَجْدَۃً أُخْرَی نَاسِیًا ؟ قَالَ : اُسْجُدْ سَجْدَتَیِ السَّہْوِ۔",,,4412
4413,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ قَرَأَ السَّجْدَۃَ وَہُوَ فِی صَلاَۃٍ مَکْتُوبَۃٍ ، فَسَجَدَ سَجْدَتَیْنِ ، قَالَ : یَسْجُدُ سَجْدَتَیْنِ إذَا فَرَغَ۔",,,4413
4414,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی زِیَادٍ ، قَالَ : قُلْتُ لِسَعِیدِ بْنِ جُبَیْرٍ : قَرَأْتُ السَّجْدَۃَ وَأَنَا سَاجِدٌ ، أَسْجُدُ ؟ قَالَ : لاَ ، وَلِمَ تَقْرَأُ وَأَنْتَ سَاجِدٌ ؟۔",,,4414
4415,"حَدَّثَنَا إسْمَاعِیلُ ابْنُ عُلَیَّۃَ ، عَنْ حَاتِمِ بْنِ أَبِی صَغِیرَۃَ ، قَالَ : قُلْتُ لِعَبْدِ اللہِ بْنِ أَبِی مُلَیْکَۃَ : قَرَأْتُ السَّجْدَۃَ وَأَنَا أَطُوفُ بِالْبَیْتِ فَکَیْفَ تَرَی ؟ قَالَ : آمُرُک أَنْ تَسْجُدَ ، قُلْتُ : إذَا تَرَکَنِی النَّاسُ وَہُمْ یَطُوفُونَ، فَیَقُولُونَ : مَجْنُونٌ ، أَفَأَسْتَطِیعُ أَنْ أَسْجُدَ وَہُمْ یَطُوفُونَ ؟ فَقَالَ : وَاللَّہِ لَئِنْ قُلْتَ ذَلِکَ لَقَدْ قَرَأَ ابْنُ الزُّبَیْرِ السَّجْدَۃَ فَلَمْ یَسْجُدْ ، فَقَامَ الْحَارِثُ بْنُ أَبِی رَبِیعَۃَ فَقَرَأَ السَّجْدَۃَ ثُمَّ جَائَ فَجَلَسَ ، فَقَالَ : یَا أَمِیرَ الْمُؤْمِنِینَ، مَا مَنَعَک أَنْ تَسْجُدَ قُبَیْلُ حَیْثُ قَرَأْتَ السَّجْدَۃَ ؟ فَقَالَ : لأَیِّ شَیْئٍ أَسْجُدُ ؟ إنِّی لَوْ کُنْت فِی صَلاَۃٍ سَجَدْت ، فَأَمَّا إذَا لَمْ أَکُنْ فِی صَلاَۃٍ فَإِنِّی لاَ أَسْجُدُ ، قَالَ : وَسَأَلْتُ عَطَائً عَنْ ذَلِکَ ؟ فَقَالَ : اسْتَقْبِلِ الْبَیْتَ وَأَوْمِیئْ بِرَأْسِک۔",,,4415
4416,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ فِی الرَّجُلِ یَقْرَأُ السَّجْدَۃَ وَہُوَ یَطُوفُ بِالْبَیْتِ ، قَالَ : یُومِیئُ ، أَوْ قَالَ : یَسْجُدُ۔",,,4416
4417,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، قَالَ : قَرَأَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی صَلاَۃٍ مَکْتُوبَۃٍ سَجْدَۃً ، ثُمَّ سَجَدَ۔",,,4417
4418,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ أَبِیہِ ، قَالَ : بَلَغَنِی عَنْ أَبِی مِجْلَزٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ فِی صَلاَۃِ الظُّہْرِ سَجْدَۃ فَسَجَدَ ، فَرَأَوْا أَنَّہُ قَرَأَ : (ألم تَنْزِیلُ) السَّجْدَۃَ۔",,,4418
4419,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا التَّیْمِیُّ ، عَنْ أَبِی مِجْلَزٍ ، عَنِ ابْنِ عُمَرَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ بِمِثْلِہِ ، قَالَ : وَلَمْ یَسْمَعْہُ التَّیْمِیُّ مِنْ أَبِی مِجْلَزٍ۔",,,4419
4420,حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ إیَاسِ بْنِ دَغْفَلٍ ، عَنْ أَبِی حَکِیمَۃَ ؛ أَنَّ ابْنَ عُمَرَ صَلَّی بِأَصْحَابِہِ الظُّہْرَ، فَسَجَدَ فِیہَا۔,,,4420
4421,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ، قَالَ : أَخْبَرَنِی مَنْ رَأَی ابْنَ الزُّبَیْرِ فِی حَائِطٍ مِنْ حِیطَانِ مَکَّۃَ ، قَالَ : فَصَلَّی الْعَصْرَ ، أَوِ الظُّہْرَ ، قَالَ : فَسَجَدَ ، فَقَالَ لَہُ رَجُلٌ : إنَّک صَلَّیْت خَمْسَ رَکَعَاتٍ ، فَقَالَ : إنِّی قَرَأْتُ سُورَۃً فِیہَا سَجْدَۃٌ۔",,,4421
4422,"حَدَّثَنَا وَکِیعٌ ، وَالْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ أَبِی ہِلاَلٍ ، عَنْ أَنَسِ بْنِ سِیرِینَ ؛ أَنَّ ابْنَ مَسْعُودٍ قَرَأَ فِی الظُّہْرِ: (ألم تَنْزِیلُ) السَّجْدَۃَ ، وَفِی الأُخْرَی بِسُورَۃٍ مِنَ الْمَثَانِی۔",,,4422
4423,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یُقَالُ: لاَ تَقْرَأُ السَّجْدَۃَ فِی شَیْئٍ مِنَ الْمَکْتُوبَۃِ إِلاَّ فِی صَلاَۃِ الْفَجْرِ ، وَکَانَ إبْرَاہِیمُ یَسْتَحِبُّ یَوْمَ الْجُمُعَۃِ أَنْ یَقْرَأَ بِسُورَۃٍ فِیہَا سَجْدَۃٌ۔",,,4423
4424,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ عِمْرَانَ بن حُدیر ، عَنْ أَبِی مِجْلَزٍ ؛ أَنَّہُ کَانَ لاَ یَسْجُدُ فِی صَلاَۃٍ مَکْتُوبَۃٍ ، وَیَقُولُ : أَکْرَہُ أَنْ أَزِیدَ فِی صَلاَۃٍ مَکْتُوبَۃٍ۔",,,4424
4425,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ دَاوُدَ بْنِ أَبِی ہِنْدٍ ، عَنْ بَکْرِ بْنِ عَبْدِ اللہِ ، قَالَ : جَائَ رَجُلٌ إلَی عُمَرَ ، فَقَالَ: إنَّ فُلاَنًا صَلَّی بِنَا الْفَجْرَ فَقَرَأَ بِسُورَۃٍ سَجَدَ فِیہَا ، فَقَالَ لَہُ عُمَرُ : أَوَقَدْ فَعَلَ ؟ قَالَ : نَعَمْ ، فَصَلَّی عُمَرُ مِنَ الْغَدِ ، فَقَرَأَ بِالنَّحْلِ وَبَنِی إسْرَائِیلَ ، فَسَجَدَ فِیہِمَا جَمِیعًا۔",,,4425
4426,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَلِیِّ بْنِ زَیْدِ بْنِ جُدْعَانَ ، عَنْ زُرَارَۃَ بْنِ أَوْفَی ، عَنْ مَسْرُوقِ بْنِ الأَجْدَعِ ، قَالَ : صَلَّیْتُ مَعَ عُثْمَانَ الْعِشَائَ الآخِرَۃَ ، فَقَرَأَ بِالنَّجْمِ فَسَجَدَ فِیہَا ، ثُمَّ قَامَ فَقَرَأَ : وَالتِّینِ وَالزَّیْتُونِ۔",,,4426
4427,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : حدَّثَنَا عَلِیُّ بْنُ سُوَیْد بْنِ مَنْجُوفٍ ، قَالَ : حدَّثَنَا أَبُو رَافِعٍ ، قَالَ : صَلَّی بِنَا عُمَرُ الْعِشَائَ الآخِرَۃَ ، فَقَرَأَ فِی إحْدَی الرَّکْعَتَیْنِ : {إذَا السَّمَائُ انْشَقَّتْ} فَسَجَدَ ، وَسَجَدْنَا مَعَہُ۔",,,4427
4428,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَبِی خَلْدَۃَ ، قَالَ : قُلْتُ لأَبِی الْعَالِیَۃِ : صَلَّیْتُ فِی مَسْجِدِ بَنِی فُلاَنٍ ، فَقَرَأَ إمَامُہُمُ السَّجْدَۃَ فَلَمْ یَسْجُدْ ، قَالَ : أَفَلاَ سَجَدْتَ ؟۔",,,4428
4429,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إبْرَاہِیمَ ؛ أَنَّہُ سَمِعَ عَبْدَ الرَّحْمَن الأَعْرَجَ یَقُولُ : کَانَ أَبُو ہُرَیْرَۃَ یَسْجُدُ فِی {إذَا السَّمَائُ انْشَقَّتْ} فَإِذَا قُرِئَتْ وَکَانَ خَلْفَ الإِمَام فَلَمْ یَسْجُدِ الإِمَامُ ، قَالَ : فَیُومِیئُ بِرَأْسِہِ أَبُو ہُرَیْرَۃَ۔",,,4429
4430,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ أَبِی عَمْرٍو مَوْلَی الْمُطَّلِبِ ؛ أَنَّہُ حَدَّثَہُمْ ، قَالَ : إنِّی لَقَاعِدٌ مَعَ ابْنِ عُمَرَ یَوْمَ الْجُمُعَۃِ إلَی حُجْرَۃِ عَائِشَۃَ ، وَطَارِقٌ یَخْطُبُ النَّاسَ عَلَی الْمِنْبَرِ ، فَقَرَأَ (النَّجْمَ) ، فَلَمَّا فَرَغَ وَقَعَ ابْنُ عُمَرَ سَاجِدًا ، وَسَجَدْنَا مَعَہُ ، وَمَا یَتَحَرَّک الأَخَرُ۔",,,4430
4431,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ نَسِیَ سَجْدَۃً مِنْ أول صَلاَتِہِ فَلَمْ یَذْکُرْہَا حَتَّی کَانَ فِی آخِرِ رَکْعَۃٍ مِنْ صَلاَتِہِ ، قَالَ : یَسْجُدُ فِیہَا ثَلاَثَ سَجَدَاتٍ ، فَإِنْ لَمْ یَذْکُرْہَا حَتَّی یَقْضِیَ صَلاَتَہُ غَیْرَ أَنَّہُ لَمْ یُسَلِّمْ بَعْدُ ، قَالَ : یَسْجُدُ سَجْدَۃً وَاحِدَۃً مَا لَمْ یَتَکَلَّمْ ، فَإِنْ تَکَلَّمَ اسْتَأْنَفَ الصَّلاَۃ۔",,,4431
4432,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا نَسِیَ الرَّجُلُ سَجْدَۃً مِنَ الصَّلاَۃ ، فَلْیَسْجُدْہَا مَتَی مَا ذَکَرَہَا فِی صَلاَتِہِ۔",,,4432
4433,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ؛ فِی الرَّجُلِ یَشُکُّ فِی سَجْدَۃٍ وَہُوَ جَالِسٌ لاَ یَدْرِی سَجَدَہَا أَمْ لاَ ، قَالَ مُجَاہِدٌ : إِنْ شِئْتَ فَاسْجُدْہَا ، فَإِذَا قَضَیْتَ صَلاَتَکَ ، فَاسْجُدْ سَجْدَتَیْنِ وَأَنْتَ جَالِسٌ ، وَإِنْ شِئْتَ فَلاَ تَسْجُدْہَا ، وَاسْجُدْ سَجْدَتَیْنِ وَأَنْتَ جَالِسٌ فِی آخِرِ صَلاَتِک۔",,,4433
4434,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا سَمِعَ السَّجْدَۃَ وَہُوَ رَاکِعٌ ، أَوْ سَاجِدٌ ، أَجْزَأَہُ رُکُوعُہُ وَسُجُودُہُ مِنَ السُّجُودِ بِہَا۔",,,4434
4435,"حَدَّثَنَا جَرِیرٌ، عَنْ مَنْصُورٍ، عَنْ إِبْرَاہِیمَ، عَن عَلْقَمَۃَ، عَنْ عَبْدِاللہِ، قَالَ: صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلاَۃً فَزَادَ ، أَوْ نَقَصَ ، فَلَمَّا سَلَّمَ وَأَقْبَلَ عَلَی الْقَوْمِ بِوَجْہِہِ ، قَالُوا: یَا رَسُولَ اللہِ ، حَدَثَ فِی الصَّلاَۃ شَیْئٌ؟ قَالَ : وَمَا ذَاکَ ؟ قَالُوا : صَلَّیْتَ کَذَا وَکَذَا ، فَثَنَی رِجْلَہُ فَسَجَدَ سَجْدَتَیْنِ ، ثُمَّ سَلَّمَ وَأَقْبَلَ عَلَی الْقَوْمِ بِوَجْہِہِ ، فَقَالَ : إِنَّہُ لَوْ حَدَثَ فِی الصَّلاَۃ شَیْئٌ أَنْبَأْتُکُمْ بِہِ ، وَلَکِنِّی بَشَرٌ أَنْسَی کَمَا تَنْسَوْنَ ، فَإِذَا نَسِیتُ فَذَکِّرُونِی ، فَإِذَا سَہَا أَحَدُکُمْ فِی صَلاَتِہ فَلْیَتَحَرَّ الصَّوَابَ فَلْیُتِمَّ عَلَیْہِ ، فَإِذَا سَلَّمَ سَجَدَ سَجْدَتَیْنِ۔ (بخاری 401۔ ابوداؤد 1012)",,,4435
4436,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عْن عَطَائِ بْنِ یَسَارٍ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا شَکَّ أَحَدُکُمْ فِی صَلاَتِہِ فَلْیُلْغ الشَّکَّ ، وَیَبْنِ عَلَی الْیَقِینِ ، فَإِذَا اسْتَیْقَنَ التَّمَامَ رَکَعَ رَکْعَۃً وَسَجَدَ سَجْدَتَیْنِ ، فَإِنْ کَانَتْ صَلاَتُہُ تَامَّۃً ، کَانَتِ الرَّکْعَۃُ وَالسَّجْدَتَانِ نَافِلَۃً ، وَإِنْ کَانَتْ نَاقِصَۃً کَانَتِ الرَّکْعَۃُ تَمَامَ صَلاَتِہِ ، وَالسَّجْدَتَانِ یُرْغِمَانِ الشَّیْطَانَ۔ (ابوداؤد 1016۔ احمد 3/84)",,,4436
4437,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ عَوْنِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِیہِ ، قَالَ : صَلَّیْتُ مَعَ عُمَرَ أَرْبَعًا قَبْلَ الظُّہْرِ فِی بَیْتِہِ ، وَقَالَ : إذَا أَوْہَمْتَ فَکُنْ فِی زِیَادَۃٍ ، وَلاَ تَکُنْ فِی نُقْصَانٍ۔",,,4437
4438,"حَدَّثَنَا جَرِیرُ بْنُ عَبْدِ الْحَمِیدِ ، عَنْ مَنْصُورٍ ، عَنِ الْحَکَمِ ، قَالَ : قَالَ عَلِیٌّ : إذَا شَکَّ فِی الزِّیَادَۃِ وَالنُّقْصَانِ فَلْیُصَلِّ رَکْعَۃً ، فَإِنَّ اللَّہَ لاَ یُعَذِّبُ عَیََ زِیَادَۃٍ فِی صَلاَۃ ، فَإِنْ کَانَتْ تَمَامًا کَانَتْ لَہُ ، وَإِنْ کَانَتْ زِیَادَۃً کَانَتْ لَہُ۔",,,4438
4439,"حَدَّثَنَا أَبُو الأَحْوَصِ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ: إذَا شَکَکْتَ فَلَمْ تَدْرِ، أَتْمَمْتَ، أَوْ لَمْ تُتِمَّ ، فَأَتْمِمْ مَا شَکَکْتَ ، فَإِنَّ اللَّہَ لاَ یُعَذِّبُ عَلَی الزِّیَادَۃِ۔",,,4439
4440,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : إذَا شَکَّ أَحَدُکُمْ فِی صَلاَتِہِ ، فَلْیَتَحَرَّ أَکْثَرَ ظَنِّہِ ، فَلْیَبْنِ عَلَیْہِ ، فَإِنْ کَانَ أَکْثَرُ ظَنِّہِ أَنَّہُ صَلَّی ثَلاَثًا ، فَلْیَرْکَعْ رَکْعَۃً ، وَیَسْجُدْ سَجْدَتَیْنِ ، وَإِنْ کَانَ ظَنُّہُ أَرْبَعًا فَلْیَسْجُدْ سَجْدَتَیْنِ۔",,,4440
4441,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ الْحَجَّاجِ ، عَنِ الْحَکَمِ ، عَنْ أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : یَتَحَرَّی وَیَسْجُدُ سَجْدَتَیْنِ۔",,,4441
4442,"حَدَّثَنَا ابْنُ عُلَیَّۃَ، عَنْ أَیُّوبَ، عَنْ نَافِعٍ، عَنِ ابْنِ عُمَرَ؛ أَنَّہُ کَانَ یَقُولُ: یَتَوَخَّی الَّذِی یُرَی أَنَّہُ نَقَصَ فَیُتِمَّہُ۔",,,4442
4443,"حَدَّثَنَا عَبْدَۃُ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ سَالِمٍ ، قَالَ : إذَا شَکَّ فَلَمْ یَدْرِ أَثَلاَثًا صَلَّی أَمْ أَرْبَعًا ، فَلْیَرْمِ بِالشَّکِّ وَیَسْجُدْ سَجْدَتَیْنِ ، فَذَکَرْتُ ذَلِکَ لِلْقَاسِمِ ، فَقَالَ : وَأَنَا کَذَاکَ أَقُولُ ، وَأَنَا کَذَاکَ أَقُولُ۔",,,4443
4444,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، قَالَ : حدَّثَنِی مَالِکُ بْنُ أَنَسٍ ، عَنْ عَفِیفِ بْنِ عَمْرٍو السَّہْمِیِّ ، عَنْ عَطَائِ بْنِ یَسَارٍ ، قَالَ : سَأَلْتُ عَبْدَ اللہِ بْنَ عَمْرِو بْنِ الْعَاصِ ، وَکَعْبًا عَنِ الَّذِی یَشُکُّ فِی صَلاَتِہِ ، صَلَّی ثَلاَثًا ، أَوْ أَرْبَعًا ؟ فَکِلاَہُمَا قَالَ : لِیَقُمْ فَلْیُصَلِّ رَکْعَۃً ، ثُمَّ یَسْجُدْ سَجْدَتَیْنِ ، إذَا صَلَّی وَہُوَ جَالِسٌ۔",,,4444
4445,"حَدَّثَنَا حَفْصٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَتَحَرَّی وَیَسْجُدُ سَجْدَتَیْنِ۔",,,4445
4446,"حَدَّثَنَا حَفْصٌ، عَنْ یَحْیَی، عَنْ سَالِمٍ، قَالَ: یَبْنِی عَلَی مَا یَسْتَیْقِنُ، قِیلَ لَہُ: وَیَسْجُدُ سَجْدَتَیْنِ؟ قَالَ: نَعَمْ۔",,,4446
4447,"حَدَّثَنَا عَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ مَکْحُولٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ، قَالَ : إذَا شَکَّ أَحَدُکُمْ فِی صَلاَتِہِ فَلَمْ یَدْرِ زَادَ ، أَوْ نَقَصَ ، فَإِنْ کَانَ شَکَّ فِی الْوَاحِدَۃِ وَالثِّنْتَیْنِ ، فَلْیَجْعَلْہَا وَاحِدَۃً حَتَّی یَکُونَ الْوَہْمُ فِی الزِّیَادَۃِ ، ثُمَّ یَسْجُدْ سَجْدَتَیْنِ وَہُوَ جَالِسٌ قَبْلَ أَنْ یُسَلِّمَ ، ثُمَّ یُسَلِّمُ ۔ قَالَ مُحَمَّدٌ: قَالَ لِی حُسَیْنُ بْنُ عَبْدِ اللہِ : ہَلْ أَسْنَدَ لَکَ مَکْحُولٌ الْحَدِیثَ ؟ قَالَ مُحَمَّدٌ : ما سَأَلْتُہُ عَنْ ذَلِکَ ، قَالَ : فَإِنَّہُ ذَکَرَہُ عَنْ کُرَیْبٍ ، عَنِ ابْنِ عَبَّاسٍ ، أَنَّ عُمَرَ ، وَابْنَ عَبَّاسٍ تَدَارَآ فِیہِ ، فَجَائَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ ، فَقَالَ : أنَا سَمِعْتُ مِنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ہَذَا الْحَدِیثَ۔(ترمذی 398۔ احمد 1/190)",,,4447
4448,حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ فُرَاتٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَأَبِی عُبَیْدَۃَ ؛ أَنَّہُمَا کَانَا إذَا وَہِمَا فِی صَلاَتِہِمَا ، فَلَمْ یَدْرِیَا ثَلاَثًا صَلَّیَا ، أَمْ أَرْبَعًا ، سَجَدَا سَجْدَتَیْنِ قَبْلَ أَنْ یُسَلِّمَا۔,,,4448
4449,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمُہَلَّبِ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ، قَالَ : صَلَّی بِنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْعَصْرَ ، فَسَلَّمَ مِنْ ثَلاَثِ رَکَعَاتٍ ، ثُمَّ دَخَلَ ، فَقَامَ إلَیْہِ رَجُلٌ ، یُقَالُ لَہُ : الْخِرْبَاقُ ، فَقَالَ : یَا رَسُولَ اللہِ ، فَذَکَرَ لَہُ الَّذِی صَنَعَ ، فَخَرَجَ مُغْضَبًا یَجُرُّ رِدَائَہُ حَتَّی انْتَہَی إلَی النَّاسِ ، فَقَالَ : صَدَقَ ہَذَا ؟ فَقَالُوا : نَعَمْ ، فَصَلَّی تِلْکَ الرَّکْعَۃَ ، ثُمَّ سَلَّمَ ، ثُمَّ سَجَدَ سَجْدَتَیْنِ ، ثُمَّ سَلَّمَ۔ (مسلم 101۔ ابوداؤد 1010)",,,4449
4450,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، وَالْحَسَنِ ، قَالاَ : یَنْتَہِی إلَی آخِرِ وَہْمِہِ ، ثُمَّ یَسْجُدُ سَجْدَتَیْنِ۔",,,4450
4451,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَارِبِ بْنِ دِثَارٍ ، قَالَ : سَمِعْتُ ابْنَ عُمَرَ یَقُولُ : أَحْصِ مَا اسْتَطَعْتَ ، وَلاَ تُعِدْ۔",,,4451
4452,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ؛ أَنَّ أَنَسَ بْنَ مَالِکٍ قَعَدَ فِی الرَّکْعَۃِ الثَّالِثَۃِ ، فَسَبَّحُوا بِہِ ، فَقَامَ فَأَتَمَّہُنَّ أَرْبَعًا ، فَلَمَّا سَلَّمَ سَجَدَ سَجْدَتَیْنِ ، ثُمَّ أَقْبَلَ عَلَی الْقَوْمِ بِوَجْہِہِ ، فَقَالَ : إذَا وَہَمْتُمْ فَاصْنَعُوا ہَکَذَا۔",,,4452
4453,"حَدَّثَنَا مُحَمَّدُ بْنُ مُصْعَبٍ ، عَنِ الأَوْزَاعِیِّ ، عَنْ یَحْیَی ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا لَمْ یَدْرِ أَزَادَ ، أَمْ نَقَصَ ، فَلْیَسْجُدْ سَجْدَتَیْنِ وَہُوَ جَالِسٌ۔",,,4453
4454,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : أَمَّا أَنَا فَإِذَا لَمْ أَدْرِ کَمْ صَلَّیْتُ فَإِنِّی أُعِیدُ۔",,,4454
4455,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عُمَرَ ؛ فِی الَّذِی لاَ یَدْرِی ثَلاَثًا صَلَّی ، أَوْ أَرْبَعًا ، قَالَ : یُعِیدُ حَتَّی یَحْفَظَ۔",,,4455
4456,"حَدَّثَنَا حَفْصٌ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ (ح) وَعَنْ أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالاَ : إذَا صَلَّی فَانْصَرَفَ فَلَمْ یَدْرِ کَمْ صَلَّی شَفْعًا ، أَوْ وِتْرًا ، فَلْیُعِدْ۔",,,4456
4457,حَدَّثَنَا عَبْدَۃُ ، عَنْ عَاصِمٍ ، عَنِ الشَّعْبِیِّ (ح) وَعَنْ أَیُّوبَ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ بِنَحْوِہِ۔,,,4457
4458,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، قَالَ : سَأَلْتُ سَعِیدَ بْنَ جُبَیْرٍ عَنِ الشَّکِّ فِی الصَّلاَۃ ؟ فَقَالَ : أَمَّا أَنَا فَإِذَا کَانَ فِی الْمَکْتُوبَۃِ فَإِنِّی أُعِیدُ۔",,,4458
4459,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ رَمَیْتُ الْجِمَار فَلَمْ أَدْرِ بِکَمْ رَمَیْتُ ، فَسَأَلْتُ ابْنَ عُمَرَ فَلَمْ یُجِبْنِی ، فَمَرَّ ابْنُ الْحَنَفِیَّۃِ فَسَأَلْتُہُ ، فَقَالَ : یُعِیدُ یَا أَبَا عَبْدِ اللہِ ، لَیْسَ شَئٌَٔ أَعْظَمَ عِنْدَنَا مِنَ الصَّلاَۃ ، فَإِذَا نَسِیَ أَحَدُنَا أَعَادَ ، قَالَ : فَذَکَرْت لابْنِ عُمَرَ قَوْلَہُ ، فَقَالَ : إنَّہُمْ أَہْلُ بَیْتٍ مُفْہِمُونَ۔",,,4459
4460,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَوَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : یُعِیدُ ، فَذَکَرْتُہُ لأَبِی ألضُّحَی ، فَقَالَ : کَانَ شُرَیْحٌ یَقُولُ : یُعِیدُ۔",,,4460
4461,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : إذَا صَلَّیْتَ فَلَمْ تَدْرِ کَمْ صَلَّیْتَ فَأَعِدْہَا مَرَّۃً ، فَإِنِ التبستْ عَلَیْک مَرَّۃً أُخْرَی ، فَلاَ تُعِدْہَا۔",,,4461
4462,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، وَوَکِیعٍ ، عَنْ مَالِکٍ ، عَنْ عَطَائٍ ، قَالَ : یُعِیدُ۔",,,4462
4463,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، قَالَ : یُعِیدُ مَرَّۃً۔",,,4463
4464,حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ فُرَاتٍ ، عَنْ عَبْدِ الْکَرِیمِ ، وَسَعِیدِ بْنِ جُبَیْرٍ ، وَمَیْمُونٍ ؛ أَنَّہُمْ کَانُوا إذَا وَہَمُوا فِی الصَّلاَۃ أَعَادُوا۔,,,4464
4465,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، وَسَعِیدِ بْنِ جُبَیْرٍ ، قَالاَ : فِی التَّطَوُّعِ سَہْوٌ۔",,,4465
4466,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَرَی الْوَہْمَ فِی التَّطَوُّعِ۔,,,4466
4467,"حَدَّثَنَا أَبُو عَبْدِ الرَّحْمَنِ الْمُقْرِی ، قَالَ : حدَّثَنَا سَعِیدُ بْنُ أَبِی أَیُّوبَ ، قَالَ : حَدَّثَنِی أَبُو عَقِیلٍ ؛ أَنَّہُ سَمِعَ سَعِیدَ بْنَ الْمُسَیَّبِ یَقُولُ : سَجْدَتَا السَّہْوِ فِی النَّوَافِلِ ، کَسَجْدَتَیِ السَّہْوِ فِی الْمَکْتُوبَۃِ۔",,,4467
4468,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : سَأَلْتُ مُحَمَّدًا عَنْ شَیْئٍ مِنَ الْوَہْمِ فِی التَّطَوُّعِ ؟ فَقَالَ : لاَ أَدْرِی أَیْنَ مَوْضِعُہُ ، فَقُلْتُ : أَسْجُدُ بَعْدَہُ سَجْدَتَیْنِ ؟ قَالَ : أَتُشَبِّہُہَا بِالْمَکْتُوبَۃِ ؟ أَمَّا أَنَا فَلَوْ کُنْتُ لَمْ أَفْعَلْ۔",,,4468
4469,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدِ بْنِ أَبِی عَرُوبَۃَ ، عَنْ قَتَادَۃَ ؛ أَنَّہُ کَانَ لاَ یَرَی الْوَہْمَ فِی التَّطَوُّعِ۔,,,4469
4470,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ زِیَادِ بْنِ سَعْدٍ ، عَنْ ضَمْرَۃَ بْنِ سَعِیدٍ ، عَنْ أَنَسٍ ؛ أَنَّہُ سَجَدَ سَجْدَتَیِ السَّہْوِ بَعْدَ السَّلاَمِ۔,,,4470
4471,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ زِیَادِ بْنِ سَعْدٍ ، عَنِ الزُّہْرِیِّ ، عَنْ أَبِی سَلَمَۃَ ؛ أَنَّہُ سَجَدَہُمَا بَعْدَ التَّسْلِیمِ۔,,,4471
4472,"حَدَّثَنَا یَحْیَی بْنُ سُلَیْمٍ الطَّائِفِیُّ ، عَنْ جَعْفَرٍ ، عَنْ أَبِیہِ ؛ أَنَّ عَلِیًّا قَالَ : سَجْدَتَا السَّہْوِ بَعْدَ السَّلاَمِ وَقَبْلَ الْکَلاَمِ۔",,,4472
4473,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَجَدَہُمَا بَعْدَ مَا سَلَّمَ وَتَکَلَّمَ۔ (بخاری 1229۔ مسلم 97),,,4473
4474,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ أَبِی الْمُہَلَّبِ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَہَا فَصَلَّی رَکْعَۃً ، ثُمَّ سَلَّمَ ، ثُمَّ سَجَدَ سَجْدَتَیْنِ ، ثُمَّ سَلَّمَ۔,,,4474
4475,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ؛ أَنَّ عَبْدَ اللہِ سَجَدَ سَجْدَتَیِ السَّہْوِ بَعْدَ السَّلاَمِ ، وَذُکِرَ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَعَلَہُ۔ (بخاری401۔ ترمذی 392),,,4475
4476,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ سَعْدًا ، وَعَمَّارًا سَجَدَاہُمَا بَعْدَ التَّسْلِیمِ۔,,,4476
4477,"حَدَّثَنَا غُنْدَرٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ بْنِ الْحَارِثِ ؛ أَنَّ أَبَا ہُرَیْرَۃَ ، وَالسَّائِبَ الْقَارِیَّ کَانَا یَقُولاَنِ : السَّجْدَتَانِ قَبْلَ الْکَلاَمِ وَبَعْدَ التَّسْلِیمِ۔",,,4477
4478,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَأَنَسٍ ؛ أَنَّہُمَا سَجَدَا سَجْدَتَیِ السَّہْوِ بَعْدَ السَّلاَمِ ، ثُمَّ قَامَا وَلَمْ یُسَلِّمَا۔,,,4478
4479,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی لَیْلَی ؛ أَنَّہُ سَہَا فَسَلَّمَ ، ثُمَّ سَجَدَ سَجْدَتَیْنِ ، ثُمَّ سَلَّمَ۔,,,4479
4480,حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُمَرَ ، عَنْ أَبِیہِ ؛ أَنَّہُ سَہَا فِی الصَّلاَۃ بِالشَّامِ ، فَسَجَدَ سَجْدَتَیْنِ بَعْدَ التَّسْلِیمِ۔,,,4480
4481,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عُقْبَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ سَجَدَہُمَا بَعْدَ مَا سَلَّمَ۔,,,4481
4482,حدَّثَنَا سُفْیَانُ ، عَنِ الزُّہْرِیِّ ، عَنِ الأَعْرَجِ ، عَنِ ابْنِ بُحَیْنَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی صَلاَۃً نَظُنُّ أَنَّہَا الْعَصْرُ ، فَلَمَّا کَانَ فِی الثَّالِثَۃِ قَامَ قَبْلَ أَنْ یَجْلِسَ ، فَلَمَّا کَانَ قَبْلَ أَنْ یُسَلِّمَ سَجَدَ سَجْدَتَیْنِ۔ (بخاری 829۔ ابوداؤد 1027),,,4482
4483,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ، وَالزُّہْرِیِّ ، قَالاَ : سَجْدَتَانِ قَبْلَ أَنْ یُسَلِّمَ۔",,,4483
4484,حَدَّثَنَا أَبُو الأَحْوَصِ ، وَحَفْصٌ ، عَنْ عَاصِمٍ ، عَنْ أَبِی قِلاَبَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَلَّمَ فِی سَجْدَتَیِ السَّہْوِ۔,,,4484
4485,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ سَلَّمَ فِیہِمَا۔,,,4485
4486,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حُصَیْنٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، قَالَ : فِیہِمَا تَسْلِیمٌ۔",,,4486
4487,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ سَعْدٍ ، وَعَمَّارٍ ؛ أَنَّہُمَا صَلَّیَا ثَلاَثًا ، ثُمَّ سَلَّمَا ، فَقِیلَ لَہُمَا : فَقَضَیَا الَّتِی بَقِیَتْ عَلَیْہِمَا ، ثُمَّ کَبَّرَا ، ثُمَّ سَجَدَا ، ثُمَّ سَلَّمَا تَسْلِیمَتَیْنِ۔",,,4487
4488,حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، عَنِ ابْنِ أَبِی لَیْلَی ؛ أَنَّہُ سَجَدَہُمَا ثُمَّ سَلَّمَ۔,,,4488
4489,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ سَلَّمَ فِیہِمَا۔,,,4489
4490,"حَدَّثَنَا جَرِیرٌ، عَنِ الشَّیْبَانِیِّ، عَنْ عَبْدِالْمَلِکِ بْنِ إیَاسٍ، عَنْ إبْرَاہِیمَ، قَالَ: تَسْلِیمُ السَّہْوِ وَالْجِنَازَۃِ وَاحِدٌ۔",,,4490
4491,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی سَجْدَتَیِ السَّہْوِ فِیہِمَا سَلاَمٌ۔,,,4491
4492,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : یَتَشَہَّدُ فِیہِمَا۔",,,4492
4493,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حُصَیْنٍ ، عَنْ إِبْرَاہِیمَ ، عَن عَبْدِ اللہِ ، قَالَ : فِیہِمَا تَشَہُّدٌ۔",,,4493
4494,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ سَجَدَ سَجْدَتَیِ السَّہْوِ فَتَشَہَّدَ فِیہِمَا ثُمَّ سَلَّمَ۔,,,4494
4495,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَلَمَۃَ ، عَنْ عَلْقَمَۃَ ، قَالَ : سُئِلَ مُحَمَّدُ بْنُ سِیرِینَ عَنْ سَجْدَتَیِ الْوَہْمِ ، فِیہِمَا تَشَہُّدٌ ؟ قَالَ : أَحَبُّ إلَیَّ أَنْ یَتَشَہَّدَ فِیہِمَا۔",,,4495
4496,"حَدَّثَنَا مُعَاذُ بْنُ مُعَاذٍ ، قَالَ : أَخْبَرَنَا ابْنُ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لَیْسَ فِی سَجْدَتَیِ السَّہْوِ تَشَہُّدٌ ، وَلاَ تَسْلِیمٌ۔",,,4496
4497,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لَیْسَ فِیہِمَا تَشَہُّدٌ ، وَلاَ تَسْلِیمٌ۔",,,4497
4498,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ، عَنِ الْحَسَنِ ، وَأَنَسٍ ؛ أَنَّہُمَا سَجَدَاہُمَا ، ثُمَّ قَامَا وَلَمْ یُسَلِّمَا۔,,,4498
4499,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَتَشَہَّدُ الإِمَام فِی سَجْدَتَیِ السَّہْوِ۔",,,4499
4500,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا شُعْبَۃُ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ؛ أَنَّہُمَا قَالاَ : یَتَشَہَّدُ فِی السَّہْوِ ، ثُمَّ یُسَلِّمُ۔",,,4500
4501,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : سَجَدَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَجْدَتَیِ السَّہْوِ بَعْد َمَا سَلَّمَ وَکَبَّرَ ، فَسَجَدَ وَکَبَّرَ وَہُوَ جَالِسٌ ، ثُمَّ رَفَعَ وَکَبَّرَ ، ثُمَّ سَجَدَ وَکَبَّرَ ، ثُمَّ رَفَعَ وَکَبَّرَ۔",,,4501
4502,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، عَنْ سَعْدٍ ، وَعَمَّارٍ ؛ أَنَّہُمَا صَلَّیَا ثَلاَثًا ، فَقِیلَ لَہُمَا : فَقَضَیَا الَّتِی بَقِیَتْ عَلَیْہِمَا ثُمَّ سَلَّمَا ، ثُمَّ کَبَّرَا ، ثُمَّ سَجَدَا ، ثُمَّ کَبَّرَا، ثُمَّ رَفَعَا، ثُمَّ کَبَّرَا وَسَجَدَا، ثُمَّ کَبَّرَا وَرَفَعَا۔",,,4502
4503,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عُقْبَۃَ بن أبی العَیزار ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ سَجَدَہُمَا بِتَکْبِیرَۃٍ۔,,,4503
4504,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَیْسَ فِی سَجْدَتَیِ السَّہْوِ سَہْوٌ۔",,,4504
4505,"حَدَّثَنَا عُقْبَۃُ بْنُ خَالِدٍ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، وَحَمَّادٍ ، قَالاَ : لَیْسَ فِی سَجْدَتَیِ السَّہْوِ سَہْوٌ۔",,,4505
4506,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ مُغِیرَۃَ ، وَابْنَ أَبِی لَیْلَی ، والبَتّیَّ ، عَنْ رَجُلٍ سَہَا فِی سَجْدَتَیِ السَّہْوِ ؟ فَقَالوا : لَیْسَ عَلَیْہِ سَہْوٌ۔",,,4506
4507,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : لَیْسَ فِی سَجْدَتَیِ السَّہْوِ سَہْوٌ۔",,,4507
4508,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ سَجَدَ سَجْدَتَیِ السَّہْوِ بَعْدَ الْکَلاَمِ۔ (مسلم 402۔ ترمذی 393),,,4508
4509,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ؛ فِی رَجُلٍ نَسِیَ سَجْدَتَیِ السَّہْوِ حَتَّی یَخْرُجَ مِنَ الْمَسْجِدِ ؟ قَالَ : لاَ یُعِیدُ ، وَقَالَ ابْنُ شُبْرُمَۃَ : یُعِیدُ الصَّلاَۃ۔",,,4509
4510,حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ؛ أَنَّہُ لَقِیَ ذَلِکَ فَأَعَادَ الصَّلاَۃ۔,,,4510
4511,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ وَضَّاحٍ ، قَالَ : سَأَلْتُ قَتَادَۃَ ، فَقَالَ : یُعِیدُ سَجْدَتَیِ السَّہْوِ۔",,,4511
4512,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ، قَالاَ : إذَا صَرَفَ وَجْہَہُ عَنِ الْقِبْلَۃِ لَمْ یَبْنِ ، وَلَمْ یَسْجُدْ سَجْدَتَیِ السَّہْوِ۔",,,4512
4513,"حَدَّثَنَا شَرِیکٌ ، عَنْ سَلَمَۃَ بْنِ نُبَیْطٍ ، قَالَ : قُلْتُ لِلضَّحَّاکِ : إنِّی سَہَوْتُ ، وَلَمْ أَسْجُدْ ؟ قَالَ : ہَاہُنَا فَاسْجُدْ۔",,,4513
4514,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ إسْمَاعِیلَ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ: ہُمَا عَلَیْہِ حَتَّی یَخْرُجَ، أَوْ یَتَکَلَّمَ۔",,,4514
4515,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ إبْرَاہِیمَ ، وَعَلِیِّ بْنِ مُدْرِکٍ ، قَالاَ : صَلَّی بِنَا عَلْقَمَۃُ فَصَلَّی بِنَا خَمْسًا ، فَلَمَّا سَلَّمَ ، قَالُوا لَہُ : صَلَّیْتَ خَمْسًا ، فَالْتَفَتَ إلَی رَجُلٍ مِنَ الْقَوْمِ ، فَقَالَ : کَذلکَ یَا أَعْوَرُ ؟ فَقَالَ : نَعَمْ ، فَسَجَدَ سَجْدَتَیْنِ۔",,,4515
4516,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ شُعْبَۃَ ، عَنْ جَابِرٍ ، عَنِ الشَّعْبِیِّ ، قَالاَ : فِی کُلِّ سَہْوٍ سَجْدَتَانِ۔",,,4516
4517,"حَدَّثَنَا الْمُعَلَّی بْنُ مَنْصُورٍ ، قَالَ: أَخْبَرَنَا الْہَیْثُمُ بْنُ حُمَیْدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُبَیْدٍ ، عَنْ زُہَیْرٍ الْحِمْصِیِّ، عَنْ ثَوْبَانَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِکُلِّ سَہْوٍ سَجْدَتَانِ۔",,,4517
4518,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی فَرْوَۃَ ، قَالَ : صَلَّی بِنَا عَبْدُ الرَّحْمَنِ بْنُ أَبِی لَیْلَی ، فَلَمَّا جَلَسَ تَحَرَّکَ لِلْقِیَامِ ، سَجَدَ سَجْدَتَیِ السَّہْوِ۔",,,4518
4519,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، قَالَ : أَمَّنَا أَنَسٌ فِی سَفَرٍ ، فَصَلَّی بِنَا الْعَصْرَ رَکْعَتَیْنِ ، فَلَمَّا جَلَسَ فِی الثَّانِیَۃ نَسِیَ أَنْ یُسَلِّمَ ، فَذَہَبَ لِیَقُومَ فَسَبَّحْنَا بِہِ ، فَلَمَّا جَلَسَ سَلَّمَ وَسَجَدَ سَجْدَتَیِ السَّہْوِ۔",,,4519
4520,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ؛ أَنَّ أَنَسًا قَعَدَ فِی الرَّکْعَۃِ الثَّالِثَۃِ فَسَبَّحُوا ، فَقَامَ فَأَتَمَّہَا أَرْبَعًا ، فَلَمَّا سَلَّمَ سَجَدَ سَجْدَتَیْنِ ، ثُمَّ أَقْبَلَ عَلَی الْقَوْمِ ، فَقَالَ : إِذَا وَہِمْتُمْ فَاصْنَعُوا ہَکَذَا۔",,,4520
4521,"حَدَّثَنَا یَحْیَی بْنُ یَمَانٍ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ أَبِی جَعْفَرٍ ، وَعَطَائٍ ، قَالاَ : إنَّمَا السَّہْوُ فِی الزِّیَادَۃِ وَالنُّقْصَانِ۔",,,4521
4522,حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ یَزِیدَ الدَّالانِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ أَبِیہِ ، وَعَلْقَمَۃَ ؛ أَنَّہُمَا کَانَا یَرْفَعَانِ رُؤُوسَہُمَا مِنَ السُّجُودِ حَتَّی تَرْتَفِعَ أَلْیَتَاہُمَا ، فَیَجْلِسَانِ وَلاَ یَسْجُدَانِ سَجْدَتَیِ السَّہْوِ۔,,,4522
4523,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، قَالَ : صَلَّی فَنَہَضَ فِی الرَّکْعَتَیْنِ فَلَمْ یَسْتَتمِمْ قَائِمًا ، فَسَبَّحَ بِہِ الْقَوْمُ ، فَجَلَسَ فَلَمْ یَسْجُدْ لِذَلِکَ سَجْدَتَیِ السَّہْوِ۔",,,4523
4524,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ؛ فِی الَّذِی یَقُومُ فِی الرَّکْعَتَیْنِ ، قَالَ : إِنْ ذَکَرَ وَہُوَ مُتَحَادِبٌ جَلَسَ۔",,,4524
4525,حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الرَّجُلِ یَسْہُو فِی الصَّلاَۃ ، إنِ اسْتَوَی قَائِمًا فَعَلَیْہِ السَّجْدَتَانِ ، وَإِنْ ذَکَرَ قَبْلَ أَنْ یَعْتَدِلَ قَائِمًا فَلاَ سَہْوَ عَلَیْہِ۔,,,4525
4526,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الشَّعْبِیِّ ، قَالَ : صَلَّیْتُ خَلْفَ الْمُغِیرَۃِ بْنِ شُعْبَۃَ فَقَامَ فِی الثَّانِیَۃِ ، فَسَبَّحَ النَّاسُ بِہِ فَلَمْ یَجْلِسْ ، فَلَمَّا سَلَّمَ وَانْفَتَلَ سَجَدَ سَجْدَتَنِیْ وَہُوَ جَالِسٌ ، ثُمَّ قَالَ : ہَکَذَا رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَنَعَ۔ (ابوداؤد 1029۔ احمد 4/253)",,,4526
4527,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ بَیَانٍ ، عَنْ قَیْسٍ ، قَالَ : صَلَّی سَعْدُ بْنُ مَالِکٍ بِأَصْحَابِہِ ، فَقَامَ فِی الرَّکْعَۃِ الثانیۃ فَسَبَّحَ بِہِ الْقَوْمُ ، فَلَمْ یَجْلِسْ وَسَبَّحَ ہُوَ وَأَشَارَ إلَیْہِمْ ، أَنْ قُومُوا فَصَلَّی وَسَجَدَ سَجْدَتَیْنِ۔",,,4527
4528,حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، وَعَبْدُ اللہِ بْنُ نُمَیْرٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عَبْدِ الرَّحْمَنِ الأَعْرَجِ ؛ أَنَّ ابْنَ بُحَیْنَۃَ أَخْبَرَہُ ، أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَامَ فِی اثْنَتَیْنِ مِنَ الظُّہْرِ ، نَسِیَ الْجُلُوسَ ، حَتَّی إذَا فَرَغَ مِنْ صَلاَتِہِ إِلاَّ أَنْ یُسَلِّمَ ، سَجَدَ سَجْدَتَیِ السَّہْوِ وَسَلَّمَ۔ (ابن ماجہ 1207),,,4528
4529,حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ الزُّبَیْرِ ؛ أَنَّہُ قَامَ فِی رَکْعَتَیْنِ فَسَبَّحَ الْقَوْمُ ، حَتَّی إذَا عَرَفَ أَنَّہُ قَدْ وَہَمَ فَمَضَی فِی صَلاَتِہِ۔,,,4529
4530,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ عَوْنٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّ النُّعْمَانَ بْنَ بَشِیرٍ صَلَّی فَنَہَضَ فِی الرَّکْعَتَیْنِ فَسَبَّحُوا بِہِ فَمَضَی ، فَلَمَّا فَرَغَ سَجَدَ سَجْدَتَیِ السَّہْوِ وَہُوَ جَالِسٌ۔,,,4530
4531,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : قُلْتُ لِلشَّعْبِیِّ : صَلَّیْتُ رَکْعَتَیْنِ ، فَلَمَّا أَرَدْتُ أَنْ أَجْلِسَ قُمْتُ ، قَالَ : لَوْ کُنْتُ أَنَا لَمَضَیْتُ۔",,,4531
4532,"حَدَّثَنَا شَبَابَۃُ ، قَالَ : حدَّثَنَا لَیْثُ بْنُ سَعْدٍ ، عَنْ یَزِیدَ ؛ أَنَّ عَبْدَ الرَّحْمَن بْنَ شِمَاسَۃَ حَدَّثَہُ ، أَنَّ عُقْبَۃَ بْنَ عَامِرٍ قَامَ فِی صَلاَۃٍ وَعَلَیْہِ جُلُوسٌ ، فَقَالَ النَّاسُ : سُبْحَانَ اللہِ ، فَعَرَفَ الَّذِی یُرِیدُونَ ، فَلَمَّا أَنْ صَلَّی سَجَدَ سَجْدَتَیْنِ وَہُوَ جَالِسٌ ، فَقَالَ : إنِّی قَدْ سَمِعْتُ قَوْلَکُمْ ، وَہَذِہِ سُنَّۃٌ۔",,,4532
4533,"حَدَّثَنَا یَحْیَی بْنُ عَبْدِ الْمَلِکِ بْنِ أَبِی غَنِیَّۃَ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یُصَلِّی رَکْعَتَیْنِ مِنَ الْمَکْتُوبَۃِ ، ثُمَّ یَقُومُ ، قَالَ : إنِ استتم قَائِمًا مَضَی فِی صَلاَتِہِ ، فَإِذَا ہُوَ أَکْمَلَ صَلاَتَہُ سَجَدَ سَجْدَتَیْنِ وَہُوَ جَالِسٌ بَعْدَ مَا یُسَلِّمُ۔",,,4533
4534,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ صَلَّی رَکْعَتَیْنِ مِنَ الْمَکْتُوبَۃِ وَنَسِیَ أَنْ یَتَشَہَّدَ حَتَّی نَہَضَ ، قَالَ : إذَا اسْتَوَی قَائِمًا مَضَی فِی صَلاَتِہِ ، وَسَجَدَ سَجْدَتَیِ السَّہْو۔",,,4534
4535,"حَدَّثَنَا مُحَمَّدُ بْنُ بِشْرٍ ، قَالَ : حدَّثَنَا مِسْعَرٌ ، عَنْ ثَابِتِ بْنِ عُبَیْدٍ ، قَالَ : صَلَّیْت خَلْفَ الْمُغِیرَۃِ بْنِ شُعْبَۃَ، فَقَامَ فِی الرَّکْعَتَیْنِ فَلَمْ یَجْلِسْ ، فَلَمَّا فَرَغَ سَجَدَ سَجْدَتَیْنِ۔",,,4535
4536,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، قَالَ : صَلَّی بِنَا عِمْرَانُ بْنُ حُصَیْنٍ فِی الْمَسْجِدِ فَنَہَضَ فِی رَکْعَتَیْنِ ، أَوْ قَعَدَ فِی ثَلاَثٍ ، وَأَکْثَرُ ظَنِّ ہِشَامٍ أَنَّہُ قَعَدَ فِی الرَّکْعَتَیْنِ ، فَلَمَّا أَتَمَّ الصَّلاَۃ سَجَدَ سَجْدَتَیِ السَّہْوِ۔",,,4536
4537,"حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ ، عَنْ مُطَرِّفٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : صَلَّی الضَّحَّاکُ بْنُ قَیْسٍ بِالنَّاسِ الظُّہْرَ ، فَلَمْ یَجْلِسْ فِی الرَّکْعَتَیْنِ الأُولَیَیْنِ ، فَلَمَّا سَلَّمَ سَجَدَ سَجْدَتَیْنِ وَہُوَ جَالِسٌ۔",,,4537
4538,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنْ عَطَائٍ ، قَالَ : صَلَّی ابْنُ الزُّبَیْرِ فَسَلَّمَ فِی رَکْعَتَیْنِ ، ثُمَّ قَامَ إلَی الْحَجَرِ فَاسْتَلَمَہُ ، فَسَبَّحَ بِہِ الْقَوْمُ ، فَرَجَعَ فَأَتَمَّ وَسَجَدَ سَجْدَتَیْنِ ، قَالَ : فَذَکَرْتُ ذَلِکَ لابْنِ عَبَّاسٍ ، فَقَالَ : لِلَّہِ أَبُوہُ ، مَا أَمَاطَ عَنْ سُنَّۃِ نَبِیِّہِ۔ (احمد 1/351۔ ابو یعلی 2597)",,,4538
4539,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خُصَیْفٍ ، عَنْ أَبِی عُبَیْدَۃَ ، عَنْ عَبْدِ اللہِ ؛ أَنَّہُ سَلَّمَ فِی رَکْعَتَیْنِ ، فَقَامَ فَأَتَمَّ وَسَجَدَ سَجْدَتَیْنِ۔,,,4539
4540,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی رَجُلٍ سَہَا فِی صَلاَتِہِ فَسَلَّمَ فِی رَکْعَتَیْنِ ؟ قَالَ : ثُمَّ ذَکَرَ ، قَالَ : یَمْضِی فِی صَلاَتِہِ ، وَیَسْجُدُ سَجْدَتَیْنِ۔",,,4540
4541,"حَدَّثَنَا وَکِیعٌ ، عَنْ شَرِیکٍ ، عَنِ ابْنِ الأَصْبَہَانِیِّ ، قَالَ : صَلَّی بِنَا ابْنُ أَبِی لَیْلَی فَسَلَّمَ فِی الرَّکْعَتَیْنِ فَسَبَّحْنَا بِہِ ، فَقَامَ فَأَتَمَّ الصَّلاَۃ ، فَلَمَّا فَرَغَ سَجَدَ سَجْدَتَیْنِ ، قَالَ : فَذَکَرْتُ ذَلِکَ لِعِکْرِمَۃَ ، فَقَالَ : أَحْسَنَ۔",,,4541
4542,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ ، عَنِ الْحَسَنِ ، قَالَ : إذَا سَلَّمَ فِی الرَّکْعَتَیْنِ أَتَمَّ وَسَجَدَ سَجْدَتَیِ السَّہْوِ۔",,,4542
4543,"حَدَّثَنَا شَبَابَۃُ بْنُ سَوَّارٍ ، قَالَ : حدَّثَنَا لَیْثُ بْنُ سَعْدٍ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ؛ أَنَّ سُوَیْد بْنَ قَیْسٍ أَخْبَرَہُ، عَنْ مُعَاوِیَۃَ بْنِ حُدِیجٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی یَوْمًا فَسَلَّمَ وَانْصَرَفَ وَقَدْ بَقِیَ عَلَیْہِ مِنَ الصَّلاَۃ رَکْعَۃٌ ، فَأَدْرَکَہُ رَجُلٌ ، فَقَالَ : نَسِیتَ مِنَ الصَّلاَۃ رَکْعَۃً ، فَرَجَعَ فَدَخَلَ الْمَسْجِدَ وَأَمَرَ بِلاَلاً فَأَقَامَ الصَّلاَۃ فَصَلَّی بِالنَّاسِ رَکْعَۃً ، فَأَخْبَرْتُ بِذَلِکَ النَّاسَ فَقَالُوا : أَتَعْرِفُ الرَّجُلَ ؟ فَقُلْتُ : لاَ ، إِلاَّ أَنْ أَرَاہُ ، فَمَرَّ بِی ، فَقُلْتُ : ہُوَ ہَذَا ، فَقَالُوا : ہَذَا طَلْحَۃُ بْنُ عُبَیْدِ اللہِ۔ (ابوداؤد 1015۔ احمد 401)",,,4543
4544,"حَدَّثَنَا شَبَابَۃُ ، عَنْ لَیْثٍ ، عَنْ یَزِیدَ ، عَنْ عِمْرَانَ بْن أَبِی أَنَسٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی یَوْمًا فَسَلَّمَ فِی رَکْعَتَیْنِ ، ثُمَّ انْصَرَفَ فَأَدْرَکَہُ ذُو الشِّمَالَیْنِ ، فَقَالَ : یَا رَسُولَ اللہِ ، أَنَقَصَتِ الصَّلاَۃُ أَمْ نَسِیتَ ؟ قَالَ : لَمْ تَنْقُصِ الصَّلاَۃ ، وَلَمْ أَنْسَ ، فَقَالَ : بَلَی ، وَالَّذِی بَعَثَک بِالْحَقِّ ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَصَدَقَ ذُو الْیَدَیْنِ ؟ قَالُوا : نَعَمْ یَا رَسُولَ اللہِ ، فَصَلَّی بِالنَّاسِ رَکْعَتَیْنِ۔ (بخاری 725۔ ابوداؤد 1001)",,,4544
4545,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن أَبِی سَلَمَۃَ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الظُّہْرَ رَکْعَتَیْنِ ، ثُمَّ سَلَّمَ ، فَقِیلَ لَہُ : أَنَقَصَ مِنَ الصَّلاَۃ ؟ فَصَلَّی رَکْعَتَیْنِ أُخْرَاوَیْنِ وَسَلَّمَ، ثُمَّ سَجَدَ سَجْدَتَیْنِ۔ (بخاری 1227۔ ابوداؤد 1006)",,,4545
4546,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ عِکْرِمَۃَ ، قَالَ : صَلَّی النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بِالنَّاسِ ثَلاَثَ رَکَعَاتٍ ، ثُمَّ انْصَرَفَ ، فَقَالَ لَہُ بَعْضُ الْقَوْمِ : حَدَثَ فِی الصَّلاَۃ شَیْئٌ ؟ قَالَ : وَمَا ذَاکَ ؟ قَالُوا : لَمْ تُصَلِّ إِلاَّ ثَلاَثَ رَکَعَاتٍ ، فَقَالَ : أَکَذَلِکَ یَا ذَا الْیَدَیْنِ ؟ وَکَانَ یُسَمَّی ذا الشِّمَالَیْنِ ، قَالَ : نَعَمْ ، قَالَ : فَصَلَّی رَکْعَۃً وَسَجَدَ سَجْدَتَیْنِ۔",,,4546
4547,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنِ أبی الْمُہَلَّبِ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْعَصْرَ فَسَلَّمَ فِی ثَلاَثِ رَکَعَاتٍ ، ثُمَّ دَخَلَ فَقَامَ إلَیْہِ رَجُلٌ، یُقَالُ لَہُ: الْخِرْبَاقُ، فَقَالَ : یَا رَسُولَ اللہِ ، فَذَکَّرَ لَہ الَّذِی صَنَعَ ، فَخَرَجَ مُغْضَبًا یَجُرُّ رِدَائَہُ حَتَّی انْتَہَی إلَی النَّاسِ ، فَقَالَ : صَدَقَ ہَذَا ؟ قَالُوا : نَعَمْ ، قَالَ : فَصَلَّی تِلْکَ الرَّکْعَۃَ ثُمَّ سَلَّمَ ، وَسَجَدَ سَجْدَتَیْنِ ، ثُمَّ سَلَّمَ۔",,,4547
4548,"حَدَّثَنَا أَبُو أُسَامَۃَ ، قَالَ : حدَّثَنَا عُبَیْدُ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی بِالنَّاسِ رَکْعَتَیْنِ فَسَہَا فَسَلَّمَ ، فَقَالَ لَہُ رَجُلٌ ، یُقَالُ لَہُ ذُو الْیَدَیْنِ ، فَذَکَرَ مِثْلَ حَدِیثِ ابْنِ عَوْنٍ ، وَہِشَامٍ ، وَحَدِیثُہُمَا أَنَّہُ قَالَ : نَقَصَتِ الصَّلاَۃُ ؟ فَقَالَ : لاَ ، فَصَلَّی رَکْعَتَیْنِ أُخْرَاوَیْنِ ، ثُمَّ سَلَّمَ ، ثُمَّ سَجَدَ سَجْدَتَیْنِ ، ثُمَّ سَلَّمَ۔",,,4548
4549,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ عَاصِمٍ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ؛ أَنَّ الزُّبَیْرَ بْنَ الْعَوَّامِ صَلَّی فَتَکَلَّمَ، فَبَنَی عَلَی صَلاَتِہِ۔,,,4549
4550,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ مُحَمَّدِ بْنِ عَجْلاَنِ ، عَنْ مُحَمَّدِ بْنِ یُوسُفَ ، عَنْ أَبِیہِ ، قَالَ : فَاتَ ابْنَ الزُّبَیْرِ بَعْضُ الصَّلاَۃ ، فَقَالَ لِی بِیَدِہِ : کَمْ فَاتَنِی ؟ قَالَ : قُلْتُ : لاَ أَدْرِی مَا تَقُولُ ؟ قَالَ : کَمْ صَلَّیْتُم ؟ قُلْتُ : کَذَا وَکَذَا ، قَالَ : فَصَلَّی وَسَجَدَ سَجْدَتَیْنِ۔",,,4550
4551,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ مَکْحُولٍ ؛ أَنَّ أَبَا الدَّرْدَائِ صَلَّی بِہِمْ فِی سَقِیفَۃٍ بِالشَّامِ وَہُمْ خَارِجُونَ ، قَالَ : فَمُطِرُوا مَطَرًا بَلَغَ مِنْہُمْ ، فَلَمَّا صَلَّی أَوَ سَلَّمَ ، قَالَ : أَمَا کَانَ فِی الْقَوْمِ فَقِیہٌ یَقُولُ : یَا ہَذَا ، خَفِّفْ ، فَإِنَّا قَدْ مُطِرْنَا۔",,,4551
4552,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ ابْنِ الأَصْبَہَانِیِّ ، عَنْ عِکْرِمَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی الْعَصْرَ رَکْعَتَیْنِ ، ثُمَّ سَلَّمَ وَدَخَلَ ، فَدَخَلَ عَلَیْہِ رَجُلٌ مِنْ أَصْحَابِہِ ، یُقَالُ لَہُ : ذُو الشِّمَالَیْنِ ، فَقَالَ : یَا رَسُولَ اللہِ ، قَصُرَتِ الصَّلاَۃ ؟ قَالَ : مَاذَا ؟ قَالَ : صَلَّیْتَ رَکْعَتَیْنِ ، فَخَرَجَ ، فَقَالَ : مَا یَقُولُ ذُو الْیَدَیْنِ ؟ فَقَالُوا : یَا رَسُولَ اللہِ ، نَعَمْ ، فَصَلَّی بِہِمْ رَکْعَتَیْنِ وَسَجَدَ سَجْدَتَیْنِ۔",,,4552
4553,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا : أَحْدَثْت فَصَلِّ رَکْعَتَیْنِ وَإِنْ تَکَلَّمْت۔",,,4553
4554,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن عُرْوَۃَ بْنِ الزُّبَیْرِ ؛ أَنَّہُ صَلَّی مَرَّۃً الْمَغْرِبَ رَکْعَتَیْنِ، ثُمَّ سَلَّمَ فَکَلَّمَ قَائِدَہُ ، فَقَالَ لَہُ قائِدُہُ : إنَّمَا صَلَّیْتَ رَکْعَتَیْنِ ، فَصَلَّی رَکْعَۃً ، ثُمَّ سَلَّمَ وَسَجَدَ سَجْدَتَیْنِ ، ثُمَّ قَالَ: إنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَعَلَ مِثْلَ ہَذَا۔",,,4554
4555,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ، قَالَ: أَوْہَمَ إمَامٌ مِنْ أَئِمَّۃِ الْمَسْجِدِ الْجَامِعِ ، فَلَمْ یَسْجُدْ سَجْدَتَیِ السَّہْوِ، فَسَجَدَ بَعْضُ الْقَوْمِ ، وَلَمْ یَسْجُدْ بَعْضُہُمْ ، فَذُکِرَ ذَلِکَ لِلْحَسَنِ ، فَلَمْ یَرَ عَلَیْہِمْ سُجُودًا ، وَذُکِرَ ذَلِکَ لابْنِ سِیرِینَ ، فَاخْتَارَ صَنِیعَ الَّذِینَ سَجَدُوا۔",,,4555
4556,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالاَ : إذَا لَمْ یَسْجُدِ الإمَام ، فَلَیْسَ عَلَیْہِمْ سَہْوٌ۔",,,4556
4557,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ وُہَیب بْنِ عَجْلاَنَ ، قَالَ : رَأَیْتُ الْقَاسِمَ ، وَسَالِمًا صَلَّیَا خَلْفَ إِمَام فَسَہَا فَلَمْ یَسْجُدْ ، فَلَمْ یَسْجُدَا۔",,,4557
4558,"حَدَّثَنَا عَبْدُالصَّمَدِ بْنُ عَبْدِالْوَارِثِ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، قَالَ : قَالَ حَمَّادٌ: إذَا أَوْہَمَ الإِمَام فَلَمْ یَسْجُدْ، فَلاَ یَسْجُدُوا۔",,,4558
4559,"حَدَّثَنَا مُصْعَبُ بْنُ الْمِقْدَامِ ، قَالَ : حدَّثَنِی مِسْعَرٌ ، قَالَ : سَأَلْتُ عَنْہُ الْحَکَمَ ، وَحَمَّادًا ، فَقَالَ الْحَکَمُ : یَسْجُدُونَ ، وَقَالَ حَمَّادٌ : لَیْسَ عَلَیْہِمْ شَیْئٌ۔",,,4559
4560,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَدْخُلُ مَعَ الإِمَامِ فَیَسْہُو ، قَالَ : تُجْزِئہ صَلاَۃُ الإِمَام ، وَلَیْسَ عَلَیْہِ سَہْوٌ۔",,,4560
4561,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عُبَیْدٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لَیْسَ عَلَی مَنْ خَلْفَ الإِمَام سَہْوٌ۔",,,4561
4562,"حَدَّثَنَا خَالِدُ بْنُ حَیَّانَ ، عَنْ بَکَّارٍ ، عَنْ مَکْحُولٍ ، قَالَ : لَیْسَ عَلَی مَنْ خَلْفَ الإِمَام سَہْوٌ۔",,,4562
4563,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ سَجَدَ سَجْدَتَیِ السَّہْوِ ، وَلاَ نَعْلَمُہُ نَقَصَ ، فَنَقُولُ : إنَّک لَمْ تَنْقُصْ شَیْئًا ؟ فَیَقُولُ : إنِّی حَدَّثْتُ نَفْسِی بِشَیْئٍ۔",,,4563
4564,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا نُعَیْمُ بْنُ حَکِیمٍ ، عَنْ أَبِی مَرْیَمَ الثَّقَفِیِّ ، قَالَ : صَلَّی بِنَا الْحَسَنُ بْنُ عَلِیٍّ الْمَغْرِبَ ، فَلَمَّا قَضَی الصَّلاَۃ سَجَدَ سَجْدَتَیْنِ ، وَلَمْ نَرَہُ سَہَا ، فَلَمَّا سَلَّمَ قُلْنَا لَہُ ، قَالَ : إنِّی سَہَوْت۔",,,4564
4565,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَشْعَثَ بْنِ أَبِی الشَّعْثَائِ ، عَنْ أَبِیہِ ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ، قَالَتْ : سَأَلْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الالْتِفَاتِ فِی الصَّلاَۃ ؟ فَقَالَ : اخْتِلاَسَۃٌ یَخْتَلِسُہَا الشَّیْطَانُ مِنْ صَلاَۃِ الْعَبْدِ۔ (بخاری 751۔ ابوداؤد 907)",,,4565
4566,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ ابْنِ أَبِی مُلَیْکَۃَ ، عَنْ عُبَیْدِ بْنِ عُمَیْرٍ ، قَالَ : کَانَ أَبُو بَکْرٍ لاَ یَلْتَفِت إذَا صَلَّی۔",,,4566
4567,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنْ یَزِیدَ بْنِ عَبْدِ الرَّحْمَنِ الدَّالانِیِّ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ ، عَنْ زَیْدِ بْنِ وَہْبٍ ؛ أَنَّ عُمَرَ بْنَ الْخَطَّابِ رَأَی رَجُلاً صَلَّی رَکْعَتَیْنِ بَعْدَ غُرُوبِ الشَّمْسِ وَقَبْلَ الصَّلاَۃ ، فَجَعَلَ یَلْتَفِتُ فَضَرَبَہُ بِالدِّرَّۃِ حِینَ قَضَی الصَّلاَۃ ، وَقَالَ : لاَ تَلْتَفِتْ ، ولم یَعِب الرَّکْعَتَیْنِ۔",,,4567
4568,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، عَنِ ابْنِ مَسْعُودٍ ، قَالَ : إنَّ اللَّہَ لاَ یَزَالُ مُقْبِلاً عَلَی الْعَبْدِ مَا دَامَ فِی صَلاَتِہِ ، مَا لَمْ یُحْدِثْ ، أَوْ یَلْتَفِتْ۔",,,4568
4569,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مَنْصُورِ بن حَیَّانَ ، قَالَ : حدَّثَنِی جَعْفَرُ بْنُ کَثِیرِ بْنِ الْمُطَّلِبِ السَّہْمِیِّ ، قَالَ : قَالَ أَبُو الدَّرْدَائِ : أَیُّہَا النَّاسُ ، إیَّاکُمْ وَالالْتِفَاتَ فِی الصَّلاَۃ ، فَإِنَّہُ لاَ صَلاَۃَ لِلْمُلْتَفِتِ ، وَإِنْ غُلِبْتُمْ عَلَی تَطَوُّعٍ فَلاَ تُغْلَبُوا عَلَی الْمَکْتُوبَۃِ۔",,,4569
4570,حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَکْرَہُ الالْتِفَاتَ فِی الصَّلاَۃ۔,,,4570
4571,"حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ عُمَارَۃَ ، عَنْ أَبِی عَطِیَّۃَ ، قَالَ : قالَتْ عَائِشَۃُ : الالْتِفَاتُ فِی الصَّلاَۃ خِلْسَۃٌ یَخْتَلِسُہَا الشَّیْطَانُ۔",,,4571
4572,"حَدَّثَنَا غُنْدَرٌ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : سَمِعْتُ أَبَا ہُرَیْرَۃَ یَقُولُ : إذَا صَلَّیْتَ فَإِنَّ رَبَّک أَمَامَک وَأَنْتَ مُنَاجِیہِ فَلاَ تَلْتَفِتْ ، قَالَ عَطَائٌ : وَبَلَغَنِی أَنَّ الرَّبَّ یَقُولُ : یَا ابْنَ آدَمَ ، إلَی مَنْ تَلْتَفِت ؟ أَنَا خَیْرٌ لَکَ مِمَّنْ تَلْتَفِتُ إلَیْہِ۔",,,4572
4573,"حَدَّثَنَا جَرِیرٌ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ رُفَیْعٍ ، عَنْ مُجَاہِدٍ ، قَالَ : مَا یُؤْمَنُ ہَذَا الَّذِی یَلْتَفِتُ فِی الصَّلاَۃ أَنْ یُقَلِّبَ اللَّہُ وَجْہَہُ ؟ اللَّہُ مُقْبِلٌ عَلَیْہِ وَہُوَ مُلْتَفِتٌ عَنْہُ۔",,,4573
4574,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ اللہِ بْنِ مُنْقِذ ، قَالَ : إذَا قَامَ الرَّجُلُ إلَی الصَّلاَۃ أَقْبَلَ اللَّہُ عَلَیْہِ بِوَجْہِہِ ، فَإِذَا الْتَفَتَ أَعْرَضَ عَنْہُ۔",,,4574
4575,"حَدَّثَنَا جَرِیرٌ ، عَنْ ثَابِتٍ ، عَنْ لَیْثٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : ہُوَ یَنْقُصُ الصَّلاَۃ۔",,,4575
4576,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ خَالِدِ بْنِ أَبِی بَکْرٍ ، قَالَ : رَأَیْتُ سَالِمًا ، وَالْقَاسِمَ لاَ یَلْتَفِتَانِ فِی صَلاَتِہِمَا۔",,,4576
4577,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی لَبِیدٍ ، عَنْ مُحَمَّدِ بْنِ إبْرَاہِیمَ التَّیْمِیِّ ، عَنْ عَبْدِ اللہِ بْنِ ضَمْرَۃَ ، عَنْ کَعْبٍ ، قَالَ : إذَا قَامَ الرَّجُلُ فِی الصَّلاَۃ أَقْبَلَ اللَّہُ عَلَیْہِ بِوَجْہِہِ مَا لَمْ یَلْتَفِتْ۔",,,4577
4578,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو عُبَیْدَۃَ النَّاجِی ، عَنِ الْحَسَنِ ، عَنْ أَبِی ہُرَیْرَۃَ ، أَنَّہُ قَالَ فِی مَرَضِہِ : أَقْعِدُونِی ، فَإِنَّ عِنْدِی وَدِیعَۃً أَوْدَعَنِیہَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : لاَ یَلْتَفِتْ أَحَدُکُمْ فِی صَلاَتِہِ ، فَإِنْ کَانَ لاَ بُدَّ فَاعِلاً فَفِی غَیْرِ مَا افْتَرَضَ اللَّہُ عَلَیْہِ۔ (ترمذی 589)",,,4578
4579,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا خَطَّابٌ الْعُصْفُرِیُّ ، عَنِ الْحَکَمِ ، قَالَ : إنَّ مِنْ تَمَامِ الصَّلاَۃ أَنْ لاَ تعْرِفَ مَنْ عَنْ یَمِینِکَ ، وَلاَ مَنْ عَنْ شِمَالِک۔",,,4579
4580,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا ہُرَیْمٌ ، عَنْ یَزِیدَ بْنِ أَبِی حَبِیبٍ ، عَنْ أَبِی الأَسْوَدِ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ : {وَالَّذِینَ ہُمْ عَلَی صَلاَتِہِمْ دَائِمُونَ} قَالَ : الَّذِی لاَ یَلْتَفِتُ فِی صَلاَتِہِ۔",,,4580
4581,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ عَاصِمٍ ، قَالَ : مَا رَأَیْت أَبَا وَائِلٍ مُلْتَفِتًا فِی صَلاَتِہِ قَطُّ۔",,,4581
4582,حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ اللہِ بْنِ سَعِیدٍ ، عَنْ رَجُلٍ مِنْ أَصْحَابِ عِکْرِمَۃَ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ یَلْحَظُ فِی الصَّلاَۃ مِنْ غَیْرِ أَنْ یُثْنِیَ عُنُقَہُ۔ (ابوداؤد 25۔ احمد 1/275),,,4582
4583,حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ التَّیْمِیِّ ، عَنْ عِکْرِمَۃَ ؛ أَنَّہُ کَانَ یَفْعَلُہُ۔,,,4583
4584,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : بَعْضُ أَصْحَابِنَا أَخْبَرَنِی عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَلْحَظُ فِی الصَّلاَۃ ، وَلاَ یَلْتَفِتُ۔",,,4584
4585,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یَقُولُ : إذَا دَخَلَ عَلَی الإِمَام السَّہْوُ فَلَمْ یَدْرِ مَا ہُوَ، فَلْیُلَمِّحْ إلَی مَنْ خَلْفَہُ۔",,,4585
4586,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا خَالِدٌ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، قَالَ : رَأَیْتُ أَنَسَ بْنَ مَالِکٍ یَتَشَرَّفُ إلَی الشَّیْئِ یَنْظُرُ إلَیْہِ فِی الصَّلاَۃ۔",,,4586
4587,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حُمَیْدٍ ، عَنْ مُعَاوِیَۃَ بْنِ قُرَّۃَ ، قَالَ : قِیلَ لابْنِ عُمَرَ : إِنََّ ابْنَ الزُّبَیْرِ إذَا قَامَ إلَی الصَّلاَۃ لَمْ یَلْتَفِتْ ، وَلَمْ یَتَحَرَّکْ ، قَالَ : لَکِنَّا نَلْتَفِتُ وَنَتَحَرَّکُ۔",,,4587
4588,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ، قَالَ: إذَا سَہَا الإِمَام فَلَمْ یَدْرِ کَمْ صَلَّی نَظَرَ مَا یَصْنَعُ مَنْ خَلْفَہُ۔",,,4588
4589,"حَدَّثَنَا وَکِیعٌ ، عَنِ الْوَلِیدِ بْنِ عَبْدِ اللہِ بْنِ جُمَیْعٍ ، قَالَ : رَأَیْتُ إبْرَاہِیمَ یَلْحَظُ یَمِینًا وَشِمَالاً۔",,,4589
4590,"حَدَّثَنَا وَکِیعٌ ، عَنْ فِطْرٍ ، قَالَ : رَأَیْتُ ابْنَ مُغَفَّلٍ ، یَفْعَلُہُ۔",,,4590
4591,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَسْہُو مِرَارًا فِی صَلاَتِہِ ، قَالَ : تُجْزِئُہ سَجْدَتَانِ لِجَمِیعِ سَہْوِہِ۔",,,4591
4592,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا انْتَہَی إلَی الإِمَام وَقَدْ سَہَا قَبْلَ ذَلِکَ ، فَلْیَسْجُدْ مَعَ الإِمَامِ ، ثُمَّ لِیَقْضِ مَا سَبَقَ بِہِ۔",,,4592
4593,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ؛ کَمَا قَالَ إبْرَاہِیمُ۔",,,4593
4594,"حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : إذَا سُبِقَ بِبَعْضِ الصَّلاَۃ وَقَدْ سَہَا الإِمَام ، قَالَ: یَسْجُدُ مَعَ الإِمَامِ ، ثُمَّ یَقُومُ فَیَقْضِی۔",,,4594
4595,حَدَّثَنَا ابْنُ مُبَارَکٍ ، عَنْ جُوَیْبِرٍ ، عَنِ الضَّحَّاکِ ؛ مِثْلُہُ۔,,,4595
4596,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ ابْنِ سِیرِینَ ، وَالْحَسَنِ ، قَالَ ابْنُ سِیرِینَ : یَقْضِی ، ثُمَّ یَسْجُدُ ، وَقَالَ الْحَسَنُ : یَسْجُدُ مَعَ الإِمَامِ ، ثُمَّ یَقُومُ فَیَقْضِی۔",,,4596
4597,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَسْجُدُ مَعَ الإِمَامِ ، فَإِذَا انْصَرَفَ قَامَ فَقَضَی مَا سَبَقَہُ بِہِ۔",,,4597
4598,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ أَبِی سَعِیدٍ ، وَابْنِ عُمَرَ ، وَابْنِ الزُّبَیْرِ ؛ فِی الرَّجُلِ یَدْخُلُ مَعَ الإِمَامِ وَقَدْ فَاتَہُ بَعْضُ الصَّلاَۃ ، قَالُوا : یَصْنَعُ کَمَا یَصْنَعُ الإِمَام ، فَإِذَا قَضَی الإِمَام صَلاَتَہُ قَامَ فَقَضَی، وَسَجَدَ سَجْدَتَیْنِ۔",,,4598
4599,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنْ زَکَرِیَّا بْنِ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، عَنْ جَابِرِ بْنِ زَیْدٍ ، قَالَ : إذَا فَاتَکَ التَّشَہُّدُ فِی الرَّکْعَتَیْنِ ، فَلاَ تَجْلِسْ فِی رَکْعَتِکَ تَشَہَّدُ ، اقْتَدِ بِالإِمَام۔",,,4599
4600,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ؛ فِی الرَّجُلِ یَدْخُلُ فِی الصَّلاَۃ وَقَدْ سُبِقَ بِرَکْعَۃٍ ، فَإِنَّہُ یَصْنَعُ کَمَا یَصْنَعُ الإِمَام ، فَإِذَا سَلَّمَ قَامَ وَقَضَی۔,,,4600
4601,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ عُقْبَۃَ بْنِ أَبِی الْعَیْزَارِ ، قَالَ : سَأَلْتُ إبْرَاہِیمَ عَنِ الرَّجُلِ یَدْخُلُ مَعَ الإِمَامِ وَقَدْ سَبَقَہُ الإِمَام بِرَکْعَۃٍ وَقَدْ سَہَا الإِمَام ، فَکَیْفَ یَصْنَعُ ؟ قَالَ : إذَا دَخَلْتَ مَعَ الإِمَامِ فَاصْنَعْ کَمَا یَصْنَعُ۔",,,4601
4602,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ أَبِی جَابِرٍ الْبَیَاضِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی بِالنَّاسِ وَہُوَ جُنُبٌ ، فَأَعَادَ وَأَعَادُوا۔ (بیہقی 400),,,4602
4603,حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَالِمٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ صَلَّی بِہِمُ الْغَدَاۃَ ، ثُمَّ ذَکَرَ أَنَّہُ صَلَّی بِغَیْرِ وُضُوئٍ فَأَعَادَ ، وَلَمْ یُعِیدُوا۔,,,4603
4604,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا الأَعْمَشُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّ عُمَرَ صَلَّی بِالنَّاسِ وَہُوَ جُنُبٌ فَأَعَادَ ، وَأَمَرَہُمْ أَنْ لاَ یُعِیدُوا۔",,,4604
4605,"حَدَّثَنَا وَکِیعٌ ، عَنْ إبْرَاہِیمَ بْنِ یَزِیدَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، عَنْ عَلِیٍّ ، قَالَ : یُعِیدُ وَیُعِیدُونَ۔",,,4605
4606,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ سُئِلَ عَنْ رَجُلٍ أَمَّ قَوْمًا فِی شَہْرِ رَمَضَانَ وَہُوَ عَلَی غَیْرِ وُضُوئٍ ، فَصَلَّی بِہِمْ صَلاَۃَ الْعِشَائِ ، وَصَلاَۃَ رَمَضَانَ وَالْوِتْرَ ؟ فَقَالَ : یُعِیدُ ، وَلاَ یُعِیدُ مَنْ خَلْفَہُ۔",,,4606
4607,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : سَأَلْتُہُ ، فَقَالَ : أَعِدِ الصَّلاَۃ وَأَخْبِرْ أَصْحَابَک أَنَّک صَلَّیْتَ بِہِمْ وَأَنْتَ غَیْرُ طَاہِرٍ۔",,,4607
4608,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُعِیدُ ، وَلاَ یُعِیدُ مَنْ خَلْفَہُ۔",,,4608
4609,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذا صَلَّی الْجُنُبُ بِالْقَوْمِ فَأَتَمَّ بِہِمُ الصَّلاَۃ ، آمُرُہ أَنْ یَغْتَسِلَ وَیُعِیدَ ، وَلَمْ آمُرْہُمْ أَنْ یُعِیدُوا۔",,,4609
4610,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ؛ أَنَّہُ قَالَ فِی الرَّجُلِ یُصَلِّی بِالْقَوْمِ وَہُوَ جُنُبٌ ، قَالَ : أَحَبُّ إلَیَّ أَنْ یُعِیدُوا۔",,,4610
4611,"حَدَّثَنَا قَبِیصَۃُ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الشَّیْبَانِیِّ ، عَنْ بُکَیْرِ بْنِ الأَخْنَسِ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : إذَا صَلَّی بِہِمْ وَہُوَ عَلَی غَیْرِ وُضُوئٍ أَعَادَ ، وَلَمْ یُعِیدُوا ، قَالَ سُفْیَانُ : وَأَحَبُّ إلَیَّ أَنْ یُعِیدَ وَیُعِیدُوا۔",,,4611
4612,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ خُصَیْفٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانَ ابْنُ عُمَرَ إذَا دَخَلَ بَیْتًا ، فَرَأَی فِی قِبْلَۃِ الْمَسْجِدِ مُصْحَفًا ، أَوْ شِبْہَہُ أَخَذَہُ فَرَمَی بِہِ ، وَإِنْ کَانَ عَنْ یَمِینِہِ ، أَوْ شِمَالِہِ تَرَکَہُ۔",,,4612
4613,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یُصَلِّیَ الرَّجُلُ وَفِی قِبْلَۃِ الْمَسْجِدِ مُصْحَفٌ ، أَوْ غَیْرُہُ۔",,,4613
4614,"حَدَّثَنَا حَرَمِیّ بن عُمَارَۃَ بْنِ أَبِی حَفْصَۃَ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، وَحَمَّادًا عَنِ الرَّجُلِ یَکُونُ بَیْنَہُ وَبَیْنَ الْقِبْلَۃِ الْمُصْحَفُ ؟ فَکَرِہَاہ۔",,,4614
4615,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ مُجَاہِدٍ ، قَالَ : کَانُوا یَکْرَہُونَ أَنْ یَکُونَ بَیْنَہُمْ وَبَیْنَ الْقِبْلَۃِ شَیْئٌ حَتَّی الْمُصْحَفِ۔",,,4615
4616,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ خُصَیْفٍ ، عَنْ مِقْسَمٍ ، قَالَ : قَالَ ابْنُ عَبَّاسٍ : لاَ تُصَلِّ فِی بَیْتٍ فِیہِ تَمَاثِیلُ۔",,,4616
4617,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عَطَائٍ الْخُرَاسَانِیِّ ، قَالَ : لَمَّا بُنِیَ الْمَسْجِدُ فِی عَہْدِ عُثْمَانَ جَعَلُوا فِی سَقْفِہِ أُتْرُجَّۃ ، فَکَانَ الدَّاخِلُ إذَا دَخَلَ یَسْمُو بَصَرُہُ إلَیْہَا ، فَبَلَغَ ذَلِکَ عُثْمَانَ فَأَمَرَ بِہَا فَنُزِعَتْ۔",,,4617
4618,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مَنْصُورِ بْنِ صَفِیَّۃَ ، عَنْ خَالَۃِ مُسَافِعٍ ، عَنْ أُخْتِہِ صَفِیَّۃَ أُمِّ مَنْصُورٍ ، قَالَتْ : أَخْبَرَتْنِی امْرَأَۃٌ مِنْ أَہْلِ الدَّارِ مِنْ بَنِی سُلَیْمٍ ، قَالَتْ : قُلْتُ لِعُثْمَانَ بْنِ طَلْحَۃَ : لِمَ دَعَاک رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حِینَ خَرَجَ مِنَ الْبَیْتِ ؟ قَالَ : قَالَ : إنِّی رَأَیْتُ قَرْنَیِ الْکَبْشِ فَنَسِیتُ أَنْ آمُرَک أَنْ تُخَمِّرَہُمَا ، وَإِنَّہُ لاَ یَنْبَغِی أَنْ یَکُونَ فِی الْبَیْتِ شَیْئٌ یَشْغَلُ الْمُصَلِّیَ۔ (ابوداؤد 2023۔ عبدالرزاق 9083)",,,4618
4619,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِیسَی بْنِ حُمَیْدٍ ، قَالَ : سَأَلَ عُقْبَۃُ الْحَسَنَ ، قَالَ : إنَّ فِی مَسْجِدِنَا سَاجَۃً فِیہَا تَصَاوِیرُ ، قَالَ : اِنْخَرُوہَا۔",,,4619
4620,"حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ خَالِدٍ ، عَنْ أَبِی عُثْمَانَ ، قَالَ : حَدَّثَتْنِی لُبَابَۃُ ، عَنْ أُمِّہَا ، وَکَانَتْ تَخْدِمُ عُثْمَانَ بْنَ عَفَّانَ ؛ أَنَّ عُثْمَانَ بْنَ عَفَّانَ کَانَ یُصَلِّی إلَی تَابُوتٍ فِیہِ تَمَاثِیلُ ، فَأَمَرَ بِہِ فَحُکَّ۔",,,4620
4621,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَبْدُ الْمَلِکِ بْنُ أَبِی سُلَیْمَانَ ، عَنْ عَطَائٍ ؛ أَنَّہُ سُئِلَ عَنِ الْمَسْجِدِ یُکْتَبُ فِی قِبْلَتِہِ مِنَ الْقُرْآنِ ؟ فَلَمْ یَرَ بِہِ بَأْسًا۔",,,4621
4622,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَرِہَہُ۔,,,4622
4623,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ مُحَمَّدِ بْنِ الزُّبَیْرِ الْحَنْظَلِیِّ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ رَأَی ابْنًا لَہُ کَتَبَ فِی الْحَائِطِ ، بِسْمِ اللہِ ، فَضَرَبَہُ۔",,,4623
4624,"حَدَّثَنَا وَکِیعٌ ، حَدَّثَنَا سَعِیدُ بْنُ زِیَادٍ ، عَنْ زِیَادِ بْنِ صُبَیْحِ الْحَنَفِیِّ ، قَالَ : صَلَّیْت إلَی جَنْبِ ابْنِ عُمَرَ فَوَضَعْتُ یَدِی عَلَی خَاصِرَتِی ، فَلَمَّا صَلَّی ، قَالَ : ہَذَا الصُّلْبُ فِی الصَّلاَۃ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَنْہَی عَنْہُ۔ (ابوداؤد 899۔ احمد 2/30)",,,4624
4625,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی الضُّحَی ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَرِہَتْ أَنْ یَضَعَ یَدَہُ عَلَی خَاصِرَتِہِ فِی الصَّلاَۃ ، وَقَالَتْ : تَفْعَلُہُ الْیَہُودُ۔",,,4625
4626,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا ثَوْرٌ الشَّامِیُّ ، عَنْ خَالِدِ بْنِ مَعْدَانَ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا رَأَتْ رَجُلاً وَاضِعًا یَدَہُ عَلَی خَاصِرَتِہِ ، فَقَالَتْ : ہَکَذَا أَہْلُ النَّارِ فِی النَّارِ۔",,,4626
4627,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ صَالِحٍ مَوْلَی التَّوْأَمَۃِ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَرِہَہُ فِی الصَّلاَۃ ، وَقَالَ : إنَّ الشَّیْطَانَ یَحْضُرُ ذَلِکَ۔",,,4627
4628,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الزُّبَیْرِ بْنِ عَدِیٍّ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ أَنْ یَضَعَ الرَّجُلُ یَدَہُ عَلَی خَاصِرَتِہِ فِی الصَّلاَۃ۔",,,4628
4629,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ إِسْحَاقَ بْنِ عُوَیْمِرٍ ، عَنْ مُجَاہِدٍ ، قَالَ : وَضْعُ الْیَدَیْنِ عَلَی الْحَقْوِ اسْتِرَاحَۃُ أَہْلِ النَّارِ۔",,,4629
4630,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا عِمْرَانُ بْنُ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ؛ أَنَّہُ رَأَی رَجُلاً وَاضِعًا یَدَہُ عَلَی خَاصِرَتِہِ فِی الصَّلاَۃ ، فَضَرَبَ یَدَہُ۔",,,4630
4631,حَدَّثَنَا الثَّقَفِیُّ ، عَنْ خَالِدٍ ، عَنْ حُمَیْدِ بْنِ ہِلاَلٍ ؛ أَنَّہُ إنَّمَا کُرِہَ التَّخَصُّرُ فِی الصَّلاَۃ ، أَنَّ إبْلِیسَ أُہْبِطَ مُتَخَصِّرًا۔,,,4631
4632,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : نُہِیَ عَنِ الاخْتِصَارِ فِی الصَّلاَۃ ، قَالَ مُحَمَّدٌ : وَہُوَ أَنْ یَضَعَ یَدَہ عَلَی خَاصِرَتِہِ وَہُوَ یُصَلِّی۔ (بخاری 1220۔ ابوداؤد 944)",,,4632
4633,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنِ الْجُریرِیِّ ، عَنْ حَیَّانَ بْنِ عُمَیْرٍ ، قَالَ : إِنی کُنْتُ مَعَ قَسِ بْنِ عُبَادٍ ، فَرَأَی رَجُلاً یُصَلِّی مُتَخَصِّرًا ، فَقَالَ : اذْہَبْ إلَی ذَلکَ فَقُلْ لَہُ : یَضَعُ یَدَہ مِنْ مَکَانِ یَدِ الراجز۔",,,4633
4634,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ مُسْلِمٍ ، عَنْ مَسْرُوقٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَرِہَتِ الاخْتِصَارَ فِی الصَّلاَۃِ ، وَقَالَتْ : لاَ تَشَبَّہُوا بِالْیَہُودِ۔",,,4634
4635,حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، عَنْ أَبِی ہُرَیْرَۃَ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ أَنَّہُ نَہَی أَنْ یُصَلِّیَ الرَّجُلُ مُتَخَصِّرًا۔,,,4635
4636,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ أَبِی سَلَمَۃَ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أُمِّ سَلَمَۃَ أُمِّ الْمُؤْمِنِینَ ، قَالَتْ : وَالَّذِی ذَہَبَ بِنَفْسِہِ ، مَا مَاتَ حَتَّی کَانَ أَکْثَرُ صَلاَتِہِ وَہُوَ جَالِسٌ۔ (احمد 322۔ طبرانی 516)",,,4636
4637,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ کَہْمَسٍ ، عَنْ عَبْدِ اللہِ بْنِ شَقِیقٍ ، قَالَ : سَأَلْتُ عَائِشَۃَ ، أَکَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی قَاعِدًا ؟ قَالَتْ : بَعْدَ مَا حَطَّمَتْہُ السِّنُّ۔ (مسلم 506۔ ابوداؤد 953)",,,4637
4638,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ حَسَنِ بْنِ صَالِحٍ ، عَنِ سِمَاکِ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : مَا مَاتَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ حَتَّی صَلَّی قَاعِدًا۔ (مسلم 119۔ بیہقی 490)",,,4638
4639,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، قَالَ : مَا رَأَیْت ابْنَ عُمَرَ یُصَلِّی جَالِسًا إِلاَّ مِنْ مَرَضٍ۔",,,4639
4640,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ مُبَارَکٍ ، عَنْ عَبْدِ اللہِ بْنِ مُسْلِمِ بْنِ یَسَارٍ ، عَنْ أَبِیہِ ، قَالَ : إنِّی لأَکْرَہُ أَنْ یَرَانِی اللَّہُ أُصَلِّی لَہُ قَاعِدًا مِنْ غَیْر مَرَضٍ۔",,,4640
4641,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَمْرِو بْنِ مَیْمُونِ بْنِ مِہْرَانَ ، عَنْ أَبِیہِ ؛ أَنَّہُ سُئِلَ ، مَا حَدُّ الْمَرِیضِ أَنْ یُصَلِّیَ جَالِسًا ؟ فَقَالَ : حَدُّہُ لَوْ کَانَتْ دُنْیَا تُعْرَضُ لَہُ لَمْ یَقُمْ إلَیْہَا۔",,,4641
4642,"حَدَّثَنَا حَاتِمُ بْنُ إسْمَاعِیلَ ، عَنْ عَبْدِ اللہِ بْنِ یَزِیدَ ، قَالَ : رَأَیْتُ أَنَسَ بْنَ مَالِکٍ یُصَلِّی فِی الْمَقْصُورَۃِ الْمَکْتُوبَۃَ مَعَ عُمَرَ بْنِ عَبْدِ الْعَزِیزِ ، ثُمَّ یَخرج عَلَیْنَا مِنْہَا۔",,,4642
4643,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ؛ أَنَّ الْحَسَنَ کَانَ یُصَلِّی فِی الْمَقْصُورَۃِ۔,,,4643
4644,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ، عَنْ جَعْفَرٍ، قَالَ: کَانَ عَلِیُّ بْنُ حُسَیْنٍ، وأبی والْقَاسِمُ یُصَلُّونَ فِی الْمَقْصُورَۃِ۔",,,4644
4645,"حَدَّثَنَا عُمَرُ بْنُ ہَارُونَ ، عَنْ عُبَیْدِ اللہِ بْنِ یَزِیدَ ، قَالَ : رَأَیْتُ السَّائِبَ بْنَ یَزِیدَ یُصَلِّی الْمَکْتُوبَۃَ فِی الْمَقْصُورَۃِ۔",,,4645
4646,"حَدَّثَنَا وَکِیعٌ ، عَنْ قَیْسِ بْنِ عَبْدِ اللہِ ، وَکَانَ ثِقَۃً ، قَالَ : رَأَیْتُ الْحَسَنَ یُصَلِّی فِی الْمَقْصُورَۃِ۔",,,4646
4647,"حَدَّثَنَا وَکِیعٌ ، عَنْ سَلَمَۃَ بْنِ وَرْدَانَ ، قَالَ : رَأَیْتُ أَنَسًا صَلَّی عِنْدَ الْحَجَرِ۔",,,4647
4648,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ عَامِرِ بْنِ ذُؤَیْبٍ ، قَالَ : سَأَلْتُ ابْنُ عُمَرَ عَنِ الصَّلاَۃ مِنْ وَرَائِ الْحَجَرِ ؟ فَقَالَ : إنَّہُمْ یَخَافُونَ أَنْ یَقْتُلُوہُمْ۔",,,4648
4649,"حَدَّثَنَا حَفْصٌ ، عَنْ عُبَیْدِ اللہِ ، قَالَ : رَأَیْتُ سَالِمًا ، وَالْقَاسِمَ ، وَنَافِعًا یُصَلُّونَ فِی الْمَقْصُورَۃِ۔",,,4649
4650,حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنِ الأَزْرَقِ بْنِ قَیْسٍ ، عَنِ الأَحْنَفِ بْنِ قَیْسٍ ؛ أَنَّہُ کَرِہَ الصَّلاَۃ فِی الْمَقْصُورَۃِ۔,,,4650
4651,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِیسَی الْخَیَّاطِ ، عَنِ الشَّعْبِیِّ ، قَالَ : لَیْسَ الْمَقْصُورَۃُ مِنَ الْمَسْجِدِ۔",,,4651
4652,حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ جَبَلَۃَ بْنِ عَطِیَّۃَ ، عَنِ ابْنِ مُحَیْرِیزٍ ؛ أَنَّہُ کَرِہَ الصَّلاَۃ فِیہَا۔,,,4652
4653,حَدَّثَنَا وَکِیعٌ ، عَنْ عِیسَی ، عَنْ نَافِعٍ ؛ أَنَّ ابْنَ عُمَرَ کَانَ إذَا حَضَرَتْہُ الصَّلاَۃ وَہُوَ فِی الْمَقْصُورَۃِ خَرَجَ إلَی الْمَسْجِدِ۔,,,4653
4654,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنٌ ، عَنْ ہِلاَلِ بْنِ یَِسَافٍ ، عَنْ أَبِی حَیَّانَ الأَشْجَعِیِّ ،وَکَانَ مِنْ أَصْحَابِ عَبْدِ اللہِ ، قَالَ : قَالَ عبد اللہ : لاَ تُبَادِرُوا أَئِمَّتَکُمْ بِالرُّکُوعِ ، وَلاَ بِالسُّجُودِ ، وَإِذَا رَفَعَ أَحَدُکُمْ رَأْسَہُ وَالإِمَام سَاجِدٌ فَلْیَسْجُدْ ، ثُمَّ لْیَمْکُثْ قَدْرَ مَا سَبَقَ بِہِ الإِمَام۔",,,4654
4655,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ ہِلاَلٍ ، عَنْ أَبِی حَیَّانَ ، قَالَ : قَالَ عبد اللہ : فَذَکَرَ نَحْوَہُ۔",,,4655
4656,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ مُحَمَّدِ بْنِ إِسْحَاقَ ، عَنْ یَعْقُوبَ بْنِ عَبْدِ اللہِ بن الأَشَجِّ ، عَنْ بُسر بْنِ سَعِیدٍ ، عَنِ الْحَارِثِ بْنِ الْمَخْلَدِ ، عَنْ أَبِیہِ ، قَالَ : قَالَ عُمَرُ : مَنْ رَفَعَ رَأْسَہُ قَبْلَ الإِمَام فَلْیُعِدْ ، وَلْیَمْکُثْ حَتَّی یَرَی أَنَّہُ أَدْرَکَ مَا فَاتَہُ۔",,,4656
4657,"حَدَّثَنَا مُحَمَّدُ بْنُ ہَارُونَ الْبَصْرِیُّ ، عَنْ سُلَیْمَانَ بْنِ کِنْدِیرٍ ، قَالَ : صَلَّیْت إلَی جَنْبِ ابْنِ عُمَرَ فَرَفَعْت رَأْسِی قَبْلَ الإِمَام ، فَأَخَذَہُ فَأَعَادَہُ۔",,,4657
4658,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ : إذَا رَفَعَ رَأْسَہُ قَبْلَ الإِمَام وَالإِمَامُ سَاجِدٌ فَلْیَعُدْ ، فَلْیَسْجُدْ۔",,,4658
4659,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَقُولُ ذَلِکَ۔,,,4659
4660,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یَعُودُ فَیَسْجُدُ۔",,,4660
4661,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : إذَا رَفَعْتَ رَأْسَک قَبْلَ الإِمَام فَعُدْ إلَی أَنْ تَرَی ، أَنَّ الإِمَام قَدْ رَفَعَ قَبْلَک۔",,,4661
4662,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ مُخَارِقٍ ، قَالَ : مَرَرْتُ بِأَبِی ذَرٍّ بِالرَّبَذَۃِ وَأَنَا حَاجٌّ ، فَدَخَلْت عَلَیْہِ مَنْزِلَہُ ، فَرَأَیْتُہُ یُصَلِّی یُخَفِّفُ الْقِیَامَ قَدْرَ مَا یَقْرَأُ (إنَّا أَعْطَیْنَاک الْکَوْثَرَ) ، وَ(إذَا جَائَ نَصْرُ اللہِ) وَیُکْثِرُ الرُّکُوعَ وَالسُّجُودَ ، فَلَمَّا قَضَی صَلاَتَہُ ، قُلْتُ : یَا أَبَا ذَرٍّ ، رَأَیْتُک تُخَفِّف الْقِیَامَ وَتُکْثِرُ الرُّکُوعَ وَالسُّجُودَ ؟ فَقَالَ : إنِّی سَمِعْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَا مِنْ عَبْدٍ یَسْجُدُ لِلَّہِ سَجْدَۃً ، أَوْ یَرْکَعُ لَہُ رَکْعَۃً ، إِلاَّ حَطَّ اللَّہُ بِہَا عَنہ خَطِیئََۃ ، وَرَفَعَ لَہُ بِہَا دَرَجَۃ۔ (احمد 5/147۔ بزار 3903)",,,4662
4663,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : ذَکَرُوا سُجُودَ الْقُرْآنِ عِنْدَ عَائِشَۃَ ، فَقَالَتْ : ہُوَ فَرِیضَۃٌ أَدَّیْتَہَا ، أَوْ تَطَوُّعٌ تَطَوَّعْتَہُ ، مَا مِنْ مُسْلِمٍ یَسْجُدُ سَجْدَۃً إِلاَّ رَفَعَ اللَّہُ لَہ بِہَا دَرَجَۃً ، وَحَطَّ عَنْہُ خَطِیئَۃ۔",,,4663
4664,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ دَاوُدَ ، عَنْ أَبِی عُثْمَانَ ، عَنْ مُطَرِّفِ بْنِ عَبْدِ اللہِ بْنِ الشِّخِّیرِ ، قَالَ : أتَیْتُ الشَّامَ فَإِذَا أَنَا بِرَجُلٍ یُصَلِّی ، یَرْکَعُ وَیَسْجُدُ وَلاَ یَفْصِلُ ، فَقُلْتُ : لَوْ قَعَدْتُ حَتَّی أَرْشُدَ ہَذَا الشَّیْخَ ، قَالَ: فَجَلَسْتُ ، فَلَمَّا قَضَی الصَّلاَۃ قُلْتُ لَہُ : یَا عَبْدَ اللہِ ، أَعَلَی شَفْعٍ انْصَرَفْتَ أَمْ عَلَی وِتْرٍ ؟ قَالَ : قَدْ کُفِیتُ ذَلِکَ ، قُلْتُ : وَمَنْ یَکْفِیک ؟ قَالَ : الْکِرَامُ الْکَاتِبُونَ مَا سَجَدْتُ سَجْدَۃً إِلاَّ رَفَعَنِی اللَّہُ بِہَا دَرَجَۃً ، وَحَطَّ عَنِّی بِہَا خَطِیئَۃً ، قُلْتُ : مَنْ أَنْتَ یَا عَبْدَ اللہِ ؟ قَالَ : أَبُو ذَرٍّ ، قُلْتُ : ثَکِلْت مُطْرِفًا أُمُّہُ یُعْلِمُ أَبَا ذَرٍّ السُّنَّۃَ ، فَلَمَّا أَتَیْتُ مَنْزِلَ کَعْبٍ قِیلَ لِی : قَدْ سَأَلَ عَنْک ، فَلَمَّا لَقِیتُہُ ذَکَرْتُ لَہُ أَمْرَ أَبِی ذَرٍّ ، وَمَا قَالَ لِی ، قَالَ : فَقَالَ لِی مِثْلَ قَوْلِہِ۔",,,4664
4665,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَمْرِو بْنِ مُرَّۃَ ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، قَالَ : قِیلَ لِثَوْبَانَ : حَدِّثْنَا عَنْ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَکْذِبُونَ عَلَیَّ سَمِعْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُ : مَا مِنْ مُسْلِمٍ یَسْجُدُ لِلَّہِ سَجْدَۃً إِلاَّ رَفَعَہُ اللَّہُ بِہَا دَرَجَۃً ، أَوْ حَطَّ عَنْہُ بِہَا خَطِیئَۃً۔ (مسلم 225۔ ترمذی 389)",,,4665
4666,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ حُسَیْنٍ الْمُعَلِّمِ ، عَنِ ابْنِ بُرَیْدَۃَ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ؛ أَنَّہُ سَأَلَ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ عَنِ الصَّلاَۃ قَاعِدًا ؟ فَقَالَ : صَلِّ قَائِمًا ، فَإِنَّہُ أَفْضَلُ ، ثُمَّ قَالَ : صَلاَۃُ الْقَاعِدِ عَلَی النِّصْفِ مِنْ صَلاَۃِ الْقَائِمِ ، وَصَلاَۃُ النَّائِمِ عَلَی النِّصْفِ مِنْ صَلاَۃِ الْقَاعِدِ۔ (بخاری 1117۔ ابوداؤد 948)",,,4666
4667,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ شَیْخٍ یُکَنَّی أَبَا مُوسَی ، عَنْ عَبْدِ اللہِ بْنِ عَمْرو ، قَالَ : أُرَاہُ عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : صَلاَۃُ الْقَاعِدِ عَلَی النِّصْفِ مِنْ صَلاَۃِ الْقَائِمِ۔ (ابن ماجہ 1229۔ احمد 2/192)",,,4667
4668,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنِ الزُّہْرِیِّ ، عَنِ ابْنِ عَمْرو ، قَالَ : قَدِمْنَا الْمَدِینَۃَ فَأَصَابَنَا وَبَائٌ حَتَّی سَبَّحْنَا قُعُودًا ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلاَۃُ الْقَاعِدِ عَلَی النِّصْفِ مِنْ صَلاَۃِ الْقَائِمِ۔",,,4668
4669,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ حُصَیْنٍ ، عَنْ مُجَاہِدٍ ، عَنْ عَبْدِ اللہِ بْنِ عَمْرو ، قَالَ : صَلاَۃُ الْقَاعِدِ عَلَی النِّصْفِ مِنْ صَلاَۃِ الْقَائِمِ۔",,,4669
4670,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، عَنْ زُہَیْرٍ ، عَنْ إبْرَاہِیمَ بْنِ مُہَاجِرٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّ السَّائِبَ سَأَلَ عَائِشَۃَ عَنْ صَلاَۃِ الْقَاعِدِ ؟ فَقَالَتْ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلاَۃُ الْقَاعِدِ عَلَی النِّصْفِ مِنْ صَلاَۃِ الْقَائِمِ۔ (نسائی 4941۔ احمد 6/227)",,,4670
4671,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ مُجَاہِدٍ ، قَالَ : صَلاَۃُ الْقَاعِدِ غَیْرُ مُتَرَبِّعٍ عَلَی النِّصْفِ مِنْ صَلاَۃِ الْقَائِمِ۔",,,4671
4672,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا الْعَوَّامُ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ الْکَاہِلِیِّ ، قَالَ : صَلاَۃُ الْقَاعِدِ عَلَی النِّصْفِ مِنْ صَلاَۃِ الْقَائِمِ إِلاَّ مِنْ عُذْرٍ۔",,,4672
4673,"حَدَّثَنَا مُعَلَّی بْنُ مَنْصُورٍ ، وَخَالِدُ بْنُ مَخْلَدٍ ، عَنْ عَبْدِ اللہِ بْنِ جَعْفَرٍ ، عَنْ إسْمَاعِیلَ بْنِ مُحَمَّدِ بْنِ سَعْدٍ، عَنْ أَنَسِ بْنِ مَالِکٍ ، قَالَ : قَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : صَلاَۃُ الْقَاعِدِ عَلَی مِثْلِ نِصْفِ صَلاَۃِ الْقَائِمِ۔(نسائی 1364۔ احمد 3/214)",,,4673
4674,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عَوْفٌ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا أَنْ یُصَلِّیَ الرَّجُلُ وَہُوَ مُحْتَبٍ، وَابْنُ سِیرِینَ کَانَ یَکْرَہُہُ۔",,,4674
4675,حَدَّثَنَا ہُشَیْمٌ ، عَنِ ابْنِ عَوْنٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یُصَلِّی مُحْتَبِیًا۔,,,4675
4676,حَدَّثَنَا عَبْدَۃُ ، عَنْ ہِشَامٍ ؛ أَنَّ أَبَاہُ کَانَ یُصَلَّی مُحْتَبِیًا۔,,,4676
4677,"حَدَّثَنَا عَبْدُ اللہِ بْنُ دَاوُد ، عَنْ طَلْحَۃَ بْنِ یَحْیَی ، قَالَ : رَأَیْتُ أَبَا بَکْرِ بْنَ عَبْدِ الرَّحْمَنِ یُصَلِّی مُحْتَبِیًا۔",,,4677
4678,"حَدَّثَنَا عَبْدُ اللہِ بْنُ دَاوُد ، عَنْ طَلْحَۃَ بْنَ یَحْیَی ، قَالَ : رَأَیْتُ عِیسَی بْنَ طَلْحَۃَ یُصَلِّی مُحْتَبِیًا۔",,,4678
4679,حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ؛ أَنَّہُ رَأَی عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یُصَلِّی مُحْتَبِیًا خَلْفَ الْمَقَامِ تَطَوُّعًا۔,,,4679
4680,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یُصَلِّی مُحْتَبِیًا ، فَإِذَا أَرَادَ أَنْ یَرْکَعَ حَلَّ حَبْوَتَہُ ، ثُمَّ قَامَ فَرَکَعَ۔",,,4680
4681,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنِ الزُّہْرِیِّ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ کَانَ یُصَلِّی مُحْتَبِیًا۔,,,4681
4682,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ إسْمَاعِیلَ ، عَنْ عَمْرِو بْنِ دِینَارٍ ، قَالَ : رَأَیْتُ عُبَیْدَ بْنَ عُمَیْرٍ یُصَلِّی مُحْتَبِیًا۔",,,4682
4683,"حَدَّثَنَا وَکِیعٌ ، عَنِ الرَّبِیعِ بْنِ صُبَیْحٍ ، قَالَ : رَأَیْتُ عَطَائً یُصَلِّی مُحْتَبِیًا ، یَعْنِی التَّطَوُّعَ۔",,,4683
4684,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی حَازِمٍ ، عَنْ سَہْلِ بْنِ سَعْدٍ السَّاعِدِیِّ ، قَالَ : لَقَدْ رَأَیْت الرِّجَالَ عَاقِدِی أُزُرَہُمْ فِی أَعْنَاقِہِمْ ، مِثْلَ الصِّبْیَانِ ، مِنْ ضِیقِ الأُزُرِ ، خَلْفَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ قائِلٌ : یَا مَعْشَرَ النِّسَائِ ، لاَ تَرْفَعَنْ رُؤُوسَکُنَّ حَتَّی یَرْفَعَ الرِّجَالُ۔ (بخاری 362۔ ابوداؤد 630)",,,4684
4685,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ جَابِرٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : یَا مَعْشَرَ النِّسَائِ ، إذَا سَجَدَ الرِّجَالُ فَاغْضُضْنَ أَبْصَارَکُنَّ ، لاَ تَرَیْنَ عَوْرَاتِ الرِّجَالِ مِنْ ضِیقِ الأُزُرِ۔ (احمد 387)",,,4685
4686,"حَدَّثَنَا یَحْیَی بْنُ أَبِی بُکَیْرٍ ، قَالَ : حدَّثَنَا زُہَیْرُ بْنُ مُحَمَّدٍ ، عَنْ عَبْدِ اللہِ بْنِ مُحَمَّدِ بْنِ عَقِیلٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، عَنْ أَبِی سَعِیدٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : یَا مَعْشَرَ النِّسَائِ ، إذَا سَجَدَ الرِّجَالُ فَاغْضُضْنَ أبْصَارَکُنَّ ، لاَ تَرَیْنَ عَوْرَاتِ الرِّجَالِ مِنْ ضِیقِ الأُزُرِ۔ (احمد 3/3۔ بیہقی 16)",,,4686
4687,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ مَنْصُورِ بْنِ حَیَّانَ ، قَالَ : أَخْبَرَنِی سُلَیْمَانُ بْنُ بشر الْخُزَاعِیُّ ، عَنْ خَالِہِ مَالِکِ بْنِ عَبْدِ اللہِ ، قَالَ : غَزَوْت مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلَمْ أُصَلِّ خَلْفَ إمَامٍ کَانَ أَخَفَّ صَلاَۃً فِی الْمَکْتُوبَۃِ مِنْہُ۔ (احمد 5/225۔ طبرانی 652)",,,4687
4688,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ صُہَیْبٍ ، عَنْ أَنَسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُوجِزُ الصَّلاَۃَ وَیُکْمِلُہَا۔ (بخاری 706۔ مسلم 342)",,,4688
4689,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ سِمَاکٍ ، عَنْ جَابِرِ بْنِ سَمُرَۃَ ، قَالَ : کَانَتْ صَلاَۃُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَصْدًا ، وَخُطْبَتُہُ قَصْدًا۔ (مسلم 41۔ احمد 5/91)",,,4689
4690,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی صَالِحٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : تَجَوَّزُوا الصَّلاَۃ ، فَإِنَّ فِیہِمُ الضَّعِیفَ وَالْکَبِیرَ وَذَا الْحَاجَۃِ۔ (بخاری 703۔ ابوداؤد 791)",,,4690
4691,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ ، عن قَیْسٍ ، عَنْ أَبِی مَسْعُودٍ ، قَالَ : جَائَ رَجُلٌ إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : یَا رَسُولَ اللہِ ، إنِّی لأَتَأَخَّرُ عَنْ صَلاَۃِ الْغَدَاۃِ مِمَّا یُطِیلُ فُلاَنٌ فِیہَا ، قَالَ : فَقَامَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَمَا رَأَیْتُہُ فِی مَوْعِظَۃٍ أَشَدَّ مِنْہُ غَضَبًا یَوْمَئِذٍ ، فَقَالَ : أَیُّہَا النَّاسُ ، إنَّ فِیکُمْ مُنَفِّرِینَ ، فَأَیُّکُمْ صَلَّی بِالنَّاسِ فَلْیُجَوِّزْ ، فَإِنَّ فِیہِمُ الضَّعِیفَ وَالْکَبِیرَ وَذَا الْحَاجَۃِ۔ (بخاری 90۔ ابن ماجہ 984)",,,4691
4692,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مُحَارِبٍ، عَنْ جَابِرِ بْنِ عَبْدِ اللہِ؛ أَنَّ مُعَاذًا صَلَّی بِأَصْحَابِہِ فَقَرَأَ بِالْبَقَرَۃِ، فَقَالَ لَہُ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : أَفَتَّانًا ؟ أَفَتَّانًا ؟ (بخاری 705۔ احمد 3/299)",,,4692
4693,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَمْرِو بْنِ عُثْمَانَ بْنِ مَوہَبٍ ، عَنْ مُوسَی بْنِ طَلْحَۃَ ، عَنْ عُثْمَانَ بْنِ أَبِی الْعَاصِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لَہُ : أُمَّ قَوْمَک ، وَمَنْ أَمَّ قَوْمًا فَلْیُخَفِّفْ ، فَإِنَّ فِیہِمُ الضَّعِیفَ وَالْکَبِیرَ وَذَا الْحَاجَۃِ ، فَإِذَا صَلَّیْتَ لِنَفْسِکَ فَصَلِّ کَیْفَ شِئْت۔ (مسلم 186۔ احمد 4/218)",,,4693
4694,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ، قَالَ : کَانَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَخَفَّ النَّاسِ صَلاَۃً فِی تَمَامٍ۔ (بخاری 710۔ مسلم 342)",,,4694
4695,"حَدَّثَنَا وَکِیعٌ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ قَتَادَۃَ ، عَنْ عَبَّاسٍ الْجُشَمِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إنَّ مِنَ الأَئِمَّۃِ طَرَّادِینَ۔ (دارقطنی 85)",,,4695
4696,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ عَبْدِ اللہِ بْنِ عُثْمَانَ بْنِ خُثیم ، عَنْ نَافِعِ بْنِ سَرْجِسَ ، أَبِی سَعِیدٍ ؛ أَنَّہُ سَمِعَ أَبَا وَاقِدٍ اللَّیْثِیَّ صَاحِبَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَذَکَرْتُ الصَّلاَۃ عِنْدَہُ ، فَقَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَخَفَّ النَّاسِ عَلَی النَّاسِ ، وَأَدْوَمَہُ عَلَی نَفْسِہِ۔ (ابویعلی 1444۔ طبرانی 3314)",,,4696
4697,"حَدَّثَنَا زَیْدُ بْنُ حُبَابٍ ، عَنْ یَحْیَی بْنِ الْوَلِیدِ بْنِ الْمُسَیَّرِ الطَّائِیِّ ، قَالَ : أَخْبَرَنِی مُحِلٌّ الطَّائِیُّ ، عَنْ عَدِیِّ بْنِ حَاتِمٍ ، قَالَ : إنَّ مَنْ أَمَّنَا فَلْیُتِمَّ الرُّکُوعَ وَالسُّجُودَ ، فَإِنَّ فِینَا الضَّعِیفَ ،وَالْکَبِیرَ ، وَالْمَرِیضَ ، وَالْعَابِرَ سَبِیلٍ ، وَذَا الْحَاجَۃِ ، ہَکَذَا کُنَّا نُصَلِّی مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ۔ (طبرانی 222)",,,4697
4698,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ ثَابِتٍ ، قَالَ : صَلَّیْت مَعَ أَنَسٍ الْعَتَمَۃَ فَتَجَوَّزَ مَا شَائَ اللَّہُ۔",,,4698
4699,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ مُوسَی الْحَنَفِیِّ ، عَنْ مُصْعَبِ بْنِ سَعْدٍ ، أَنَّہُ حَدَّثَ ، قَالَ : کَانَ أَبِی إذَا صَلَّی فِی الْمَسْجِدِ خَفَّفَ الرُّکُوعَ وَالسُّجُودَ وَجَوَّزَ ، وَإِذَا صَلَّی فِی بَیْتِہِ أَطَالَ الرُّکُوعَ وَالسُّجُودَ وَالصَّلاَۃ ، فَقُلْتُ لَہُ ، فَقَالَ : إِنَّا أَئِمَّۃٌ یُقْتَدَی بِنَا۔",,,4699
4700,"حَدَّثَنَا عَبْدَۃُ ، عَنِ ابْنِ أَبِی عَرُوبَۃَ ، عَنْ أَبِی رَجَائٍ ، قَالَ : رَأَیْتُ الزُّبَیْرَ بْنَ الْعَوَّامِ صَلَّی صَلاَۃً خَفِیفَۃً ، فَقُلْتُ : أَنْتُمْ أَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَخَفُّ النَّاسِ صَلاَۃً ، قَالَ : إِنَا نُبَادِرُ ہَذَا الْوَسْوَاسَ۔",,,4700
4701,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ قَیْسٍ ، عَنْ نُسَیر ، عَنْ خُلَیْد الثَّوْرِیِّ ، عَنْ عَمَّارٍ ، قَالَ : احْذِفُوا ہَذِہِ الصَّلاَۃ قَبْلَ وَسْوَسَۃِ الشَّیْطَانِ۔ (عبدالرزاق 3728)",,,4701
4702,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ زَیْدِ بْنِ وَہْبٍ ، عَنْ حُذَیْفَۃَ ؛ أَنَّہُ عَلَّمَ رَجُلاً ، فَقَالَ : إنَّ الرَّجُلَ لَیُخَفِّفُ الصَّلاَۃ ، وَیُتِمُّ الرُّکُوعَ وَالسُّجُودَ۔",,,4702
4703,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ إسْمَاعِیلَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ یُصَلِّی خَلْفَ أَبِی ہُرَیْرَۃَ ، قَالَ : وَکَانَتْ صَلاَتُہُ نَحْوًا مِنْ صَلاَۃِ قَیْسٍ یُتِمُّ الرُّکُوعَ وَالسُّجُودَ وَیُجَوِّزُ ، قَالَ : فَقِیلَ لأَبِی ہُرَیْرَۃَ : ہَکَذَا کَانَتْ صَلاَۃُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : نَعَمْ ، وَأَجْوَزُ۔ (ابویعلی 6422۔ حمیدی 987)",,,4703
4704,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنَ أَبِی خَالِدٍ ، عَنْ أَبِیہِ ، قَالَ : رَأَیْتُ أَبَا ہُرَیْرَۃَ صَلَّی صَلاَۃً تَجَوَّزَ فِیہَا ، فَقُلْتُ لَہُ : ہَکَذَا کَانَتْ صَلاَۃُ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؟ قَالَ : نَعَمْ ، وَأَجْوَزُ۔",,,4704
4705,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : لَمَّا طُعِنَ عُمَرُ وَمَاجَ النَّاسُ، تَقَدَّمَ عَبْدُ الرَّحْمَنِ بْنُ عَوْفٍ فَقَرَأَ بِأَقْصَرَ سُورَتَیْنِ فِی الْقُرْآنِ : {إنَّا أَعْطَیْنَاک الْکَوْثَرَ} وَ {إذَا جَائَ نَصْرُ اللہِ وَالْفَتْحُ}۔",,,4705
4706,حَدَّثَنَا عَبْدَۃُ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ؛ کَانَ یُخَفِّفُ الصَّلاَۃ ، وَیُتِمُّ الرُّکُوعَ وَالسُّجُودَ۔,,,4706
4707,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : کَانُوا یُتِمُّونَ وَیُوجِزُونَ ، وَیُبَادِرُونَ الْوَسْوَسَۃَ۔",,,4707
4708,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُمَیْدٍ ، عَنْ أَنَسٍ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنْ أَخَفِّ النَّاسِ صَلاَۃً وَأَوْجَزَ۔",,,4708
4709,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ مِسْعَرٍ ، عَنْ مُہَاجِرٍ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : مَا رَأَیْت الصَّلاَۃ فِی مَوْضِعٍ أَخَفَّ مِنْہَا فِیمَا بَیْنَ ہَذَیْنِ الْحَائِطَیْنِ ، یَعْنِی مَسْجِدَ الْکُوفَۃِ الأَعْظَمَ۔",,,4709
4710,"حَدَّثَنَا وَکِیعٌ ، وَابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنِ النُّعْمَانِ بْنِ قَیْسٍ ، قَالَ : کُنَّ النِّسَائُ إذَا مَرَرْنَ عَلَی عبیدَۃَ وَہُوَ یُصَلِّی ، قُلْنَ : خَفِّفُوا ، فَإِنَّہَا صَلاَۃُ عبیدَۃَ ، یَعْنِی مِنْ خِفَّتِہَا۔",,,4710
4711,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُمَیْدٌ ، عَنْ أَنَسٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : إنِّی لأَکُونُ فِی الصَّلاَۃ فَأَسْمَعُ صَوْتَ الصَّبِیِّ یَبْکِی ، فَأَتَجَوَّزُ فِی صَلاَتِی مَخَافَۃَ أَنْ أَشُقَّ عَلَی أُمِّہِ۔ (ترمذی 376۔ احمد 257)",,,4711
4712,"حَدَّثَنَا عَلِیُّ بْنُ إِسْحَاقَ ، عَنِ ابْنِ المُبَارَکِ ، عَنِ الأَوْزَاعِیِّ ، قَالَ : حدَّثَنَا یَحْیَی بْنُ أَبِی کَثِیرٍ ، عَنْ عَبْدِ اللہِ بْنِ أَبِی قَتَادَۃَ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ: إنِّی لأَکُونُ فِی الصَّلاَۃ فَأُرِیدُ أَنْ أُطَوِّلَ فِیہَا، فَأَسْمَعُ بُکَائَ الصَّبِیِّ فَأَتَجَوَّزُ فِی الصَّلاَۃ ، کَرَاہِیَۃَ أَنْ أَشُقَّ عَلَی أُمِّہِ۔ (بخاری 707۔ ابوداؤد 785۔ احمد 305)",,,4712
4713,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی الْحُوَیْرِثِ الزُّرَقِیِّ ، عَنْ عَلِیِّ بْنِ حسین ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إنِّی لأَسْمَعُ بُکَائَ الصَّبِیِّ خَلْفِی فَأُخَفِّفُ ، شَفَقَۃَ أَنْ أَفْتِنَ أُمَّہُ۔ (عبدالرزاق 3723)",,,4713
4714,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی السَّوْدَائِ النَّہْدِیِّ ، عَنِ ابْنِ سَابِطٍ ؛ أَنَّ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ قَرَأَ فِی الرَّکْعَۃِ الأُولَی بِسُورَۃٍ نَحْوًا مِنْ سِتِّینَ آیَۃً ، فَسَمِعَ بُکَائَ صَبِیٍّ ، قَالَ : فَقَرَأَ فِی الثَّانِیَۃِ بِثَلاَثِ آیَاتٍ۔ (ابوداؤد 39۔ عبدالرزاق 3724)",,,4714
4715,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی ہَارُونَ ، عَنْ أَبِی سَعِیدٍ ، فِیمَا نَعْلَمُ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : أَنِّی لأَکُونُ فِی الصَّلاَۃ ، فَأَسْمَعُ بُکَائَ الصَّبِیِّ ، فَأُخَفِّفُ مَخَافَۃَ أَنْ أَشُقَّ عَلَی أُمِّہِ ، أَوَ قَالَ : أَنْ تُفْتَنَ أُمُّہُ۔ (عبدالرزاق 3721)",,,4715
4716,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی الرَّجُلِ یُدْرِکُ مَعَ الإِمَامِ وِتْرًا مِنْ صَلاَتِہِ ، قَالَ : یُصَلِّی مَا أَدْرَکَ ، وَلاَ یَسْجُدُ سَجْدَتَیْنِ۔",,,4716
4717,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، قَالَ : سُئِلَ یُونُسُ عَنِ الرَّجُلِ یُدْرِکُ مِنْ صَلاَۃِ الْقَوْمِ رَکْعَۃً ، أَوْ تَفُوتُہُ رَکْعَۃٌ ؟ قَالَ : کَانَ الْحَسَنُ وَمُحَمَّدُ لاَ یَرَیَانِ عَلَیْہِ سُجُودًا۔",,,4717
4718,حَدَّثَنَا مُعْتَمِرُ بْنُ سُلَیْمَانَ ، عَنْ أَبِیہِ ، عَنْ رَجُلٍ ، عَنْ عَطَائٍ ؛ أَنَّ ابْنَ عَبَّاسٍ ، وَابْنَ الزُّبَیْرِ وَأَبَا سَعِیدٍ ، وَابْنَ عُمَرَ ؛ کَانُوا إذَا فَاتَہُمْ وِتْرٌ مِنْ صَلاَۃِ الإِمَام ، سَجَدُوا سَجْدَتَیْنِ۔,,,4718
4719,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عَبْدِ الْمَلِکِ ، عَنْ عَطَائٍ ، عَنْ أَبِی سَعِیدٍ ، وَابْنِ عُمَرَ ، وَابْنِ الزُّبَیْرِ ؛ قَالُوا : إذَا فَاتَہُ بَعْضُ الصَّلاَۃ قَامَ فَقَضَی ، وَسَجَدَ سَجْدَتَیْنِ۔",,,4719
4720,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : إذَا أَدْرَکَ الرَّجُلُ سَجْدَۃً مِنْ صَلاَۃِ الإِمَام سجَدَ إلَیْہَا أُخْرَی ، ثُمَّ سَجَدَ سَجْدَتَیْنِ بَعْدَ مَا یَفْرُغُ مِنْ صَلاَتِہِ ، وَإِذَا أَدْرَکَ سَجْدَتَیْنِ ، سَجَدَ بَعْدَ مَا یَفْرُغُ مِنْ صَلاَتِہِ۔",,,4720
4721,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ نَافِعٍ ، عَنِ ابْنَ عُمَرَ ؛ مِثْلَہُ۔,,,4721
4722,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، وَطَاوُوس ، وَمُجَاہِدٍ ؛ قَالُوا : إذَا فَاتَکَ وِتْرٌ مِنْ صَلاَۃِ الإِمَام ، فَاقْضِ مَا فَاتَکَ ، وَاسْجُدْ سَجْدَتَیْنِ وَأَنْتَ جَالِسٌ۔",,,4722
4723,"حَدَّثَنَا عَبْدُ الْوَہَّابِ ، عَنْ سَعِیدٍ ، عَنْ أَبِی مَعْشَرٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَسْجُدُ مَعَہُمْ ، وَلاَ یَسْجُدُ إلَیْہَا أُخْرَی۔",,,4723
4724,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ ؛ أَنَّہُ فَاتَتْہُ رَکْعَۃٌ فَقَامَ فَتَطَوَّعَ ، ثُمَّ ذَکَرَ فَصَلَّی الرَّکْعَۃَ الَّتِی فَاتَتْہُ ، وَسَجَدَ سَجْدَتَیْنِ۔,,,4724
4725,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ شُعْبَۃَ ، عَنِ الْحَکَمِ ، قَالَ : یَقْطَعُ وَیُصَلِّی الرَّکْعَۃَ ، قَالَ : وَأَظُنُّہُ ، قَالَ : وَیَسْجُدُ سَجْدَتَیْنِ۔",,,4725
4726,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ فِی رَجُلٍ فَاتَتْہُ مَعَ الإِمَامِ رَکْعَۃٌ ، فَلَمَّا سَلَّمَ الإِمَام ظَنَّ أَنَّہُ قَدْ أَدْرَکَ مَعَہُ أَوَّلَ الصَّلاَۃ فَقَامَ یَتَطَوَّعُ ، فَقَالَ الْحَسَنُ : إذَا أَدَخَلَ تَطَوُّعًا فِی فَرِیضَۃٍ فَسَدَتْ عَلَیْہِ صَلاَتُہُ۔",,,4726
4727,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ إبْرَاہِیمَ بْنِ الْمُہَاجِرِ ، عَنْ أَبِیہِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَرِہَ الصَّلاَۃ فِی الطَّاقِ۔",,,4727
4728,"حَدَّثَنَا وَکِیعٌ ، عَنْ مُوسَی بْنِ قَیْسٍ ، قَالَ : رَأَیْتُ إبْرَاہِیمَ یَتَنَکَّبُ الطَّاقَ۔",,,4728
4729,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ یَزِیدَ بْنِ أَبِی زِیاد ، عَنْ عُبَیْدِ بْنِ أَبِی الْجَعْدِ ، عَنْ کَعْبٍ ؛ أَنَّہُ کَرِہَ المذبح فِی الْمَسْجِدِ۔",,,4729
4730,"حَدَّثَنَا وَکِیعٌ ، قَالَ: حدَّثَنَا حَسَنُ بْنُ صَالِحٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ سَعِیدِ بْنِ أَبْجَرَ، عَنْ نُعَیْمِ بْنِ أَبِی ہِنْدٍ، عَنْ سَالِمِ بْنِ أَبِی الْجَعْدِ ، قَالَ : لاَ تَتَّخِذُوا المذابح فِی الْمَسَاجِدِ۔",,,4730
4731,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَکْرَہُ الصَّلاَۃ فِی الطَّاقِ۔",,,4731
4732,"حَدَّثَنَا ہُشَیْمٌ قَالَ : أَخْبَرَنَا یَحْیَی بْنُ بَدْرٍ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَکْرَہُ الصَّلاَۃَ فِی الطَّاقِ۔",,,4732
4733,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا عُبیدَۃُ ، عَنْ عُبید بْنِ أَبِی الْجَعْدِ ، قَالَ : کَانَ أَصْحَابُ مُحَمَّدٍ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَقُولُونَ : إِنْ مِنْ أَشْرَاطِ السَّاعَۃِ أَنْ تُتَّخَذَ المذابح فِی الْمَسَاجِدِ ، یَعْنِی الطَّاقَاتِ۔",,,4733
4734,"حَدَّثَنَا وَکِیعٌ ، قَالَ : أَخْبَرَنَا أَبُو إسْرَائِیلَ ، عَنْ مُوسَی الْجُہَنِیِّ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لاَ تَزَالُ ہَذِہِ الأُمَّۃُ ، أَوَ قَالَ : أُمَّتِی بِخَیْرٍ مَا لَمْ یَتَّخِذُوا فِی مَسَاجِدِہِمْ مَذَابِحَ کَمَذَابِحِ النَّصَارَی۔",,,4734
4735,"حَدَّثَنَا عَبْدُ اللہِ بْنُ إدْرِیسَ ، عَنْ مُطَرِّفٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : قَالَ عَبْدُ اللہِ : اتَّقُوا ہَذِہِ الْمَحَارِیبَ ، وَکَانَ إبْرَاہِیمُ لاَ یَقُومُ فِیہَا۔",,,4735
4736,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ قَیْسٍ ، عَنْ أَبِی ذَرٍّ ، قَالَ : إِنَّ مِنْ أَشْرَاطِ السَّاعَۃِ أَنْ تُتَّخَذَ الْمَذَابِحُ فِی الْمَسَاجِدِ۔",,,4736
4737,"حَدَّثَنَا عَبْدُ الْحَمِیدِ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : رَأَیْتُ أَبَا خَالِدٍ الْوَالِبِیَّ لاَ یَقُومُ فِی الطَّاقِ ، وَیَقُومُ قِبَلَ الطَّاقِ۔",,,4737
4738,"حَدَّثَنَا حُمَیْدٌ ، عَنْ مُوسَی بْنِ عُبَیْدَۃَ ، قَالَ : رَأَیْتُُ مَسْجِدَ أَبِی ذَرٍّ فَلَمْ أَرَ فِیہِ طَاقًا۔",,,4738
4739,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ قَیْسِ بْنِ أَبِی حَازِمٍ ، قَالَ : کَانَ یُصَلِّی بِنَا فِی الطَّاقِ۔",,,4739
4740,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُوسَی بْنُ نَافِعٍ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یُصَلِّی فِی الطَّاقِ۔",,,4740
4741,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا نِفَاعَۃُ بْنُ مُسْلِمٍ ، قَالَ : رَأَیْتُ سُوَیْد بْنَ غَفَلَۃَ یُصَلِّی فِی الطَّاقِ۔",,,4741
4742,"حَدَّثَنَا إِسْحَاقُ بْنُ مَنْصُورٍ ، قَالَ : حدَّثَنَا ہُرَیْمٌ ، عَنْ أُمِّ عَمْرٍو الْمُرَادِیَّۃِ ، قَالَتْ : رَأَیْت الْبَرَائَ بْنَ عَازِبٍ یُصَلِّی فِی الطَّاقِ۔",,,4742
4743,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ وِقَائَ بْنِ إیَاسٍ ، قَالَ : رَأَیْتُ سَعِیدَ بْنَ جُبَیْرٍ یُصَلِّی فِی الطَّاقِ۔",,,4743
4744,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ قطن ، قَالَ : رَأَیْتُ أَبَا رَجَائٍ یُصَلِّی فِی الْمِحْرَابِ۔",,,4744
4745,"حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنِ الْحَکَمِ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ : إذَا کُنْتَ فِی الصَّلاَۃ ، فَلاَ تَمْسَحْ جَبْہَتَکَ ، وَلاَ تَنْفُخْ ، وَلاَ تُحَرِّکِ الْحَصْبَائَ۔",,,4745
4746,"حَدَّثَنَا خَلَفُ بْنُ خَلِیفَۃَ ، عَنْ حُصَیْنٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، قَالَ : ہُوَ مِنَ الْجَفَائِ۔",,,4746
4747,"حَدَّثَنَا وَکِیعٌ ، عَنْ کَہْمَسِ بْنِ الْحَسَنِ ، عَنِ ابْنِ بُرَیْدَۃَ ، قَالَ : کَانَ یُقَالُ، أَرْبَعٌ مِنَ الْجَفَائِ : أَنْ یَمْسَحَ جَبْہَتَہ قَبْلَ أَنْ یَنْصَرِفَ ، أَوْ یَبُولَ قَائِمًا ، أَوْ یَسْمَعَ الْمُنَادِیَ ، ثُمَّ لاَ یُجِیبَہُ ، أَوْ یَنْفُخَ فِی سُجُودِہ۔",,,4747
4748,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ بُرْدٍ ، عَنْ مَکْحُولٍ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَمْسَحَ الرَّجُلُ جَبْہَتَہُ فِی الصَّلاَۃ ، وَیَقُولُ : ہُوَ مِنَ الْجَفَائِ۔",,,4748
4749,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَمْسَحَ جَبْہَتَہُ قَبْلَ أَنْ یَنْصَرِفَ۔,,,4749
4750,"حَدَّثَنَا وَکِیعٌ ، عَنْ حُرَیْثٍ ، عَنِ الشَّعْبِیِّ ؛ فِی الرَّجُلِ یَمْسَحُ جَبْہَتَہُ قَبْلَ أَنْ یَنْصَرِفَ ، قَالَ : ہُوَ جَفَاء ، وَقَالَ الْحَکَمُ : لاَ بَأْسَ بِہِ۔",,,4750
4751,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ عَاصِمِ بْنِ أَبِی النَّجُودِ ، عَنِ الْمُسَیَّبِ بْنِ رَافِعٍ ، قَالَ : قَالَ عَبْدُ اللہِ : أَرْبَعٌ مِنَ الْجَفَائِ : أَنْ یُصَلِّیَ الرَّجُلُ إلَی غَیْرِ سُتْرَۃٍ ، وَأَنْ یَمْسَحَ جَبْہَتَہُ قَبْلَ أَنْ یَنْصَرِفَ ، أَوْ یَبُولَ قَائِمًا ، أَوْ یَسْمَعَ الْمُنَادِیَ ، ثُمَّ لاَ یُجِیبَہُ۔",,,4751
4752,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : لاَ بَأْسَ بِہِ ، یَعْنِی یَمْسَح جَبْہَتَہُ قَبْلَ أَنْ یَنْصَرِفَ۔",,,4752
4753,"حَدَّثَنَا یَزِیدُ بْنُ أَبِی الْخنْدِقِ ، عَنْ مَالِکِ بْنِ دِینَارٍ ، قَالَ : سَأَلْتُ سَالِمًا عَنِ الرَّجُلِ یَمْسَحُ جَبْہَتَہُ ؟ فَلَمْ یَرَ بِہِ بَأْسًا۔",,,4753
4754,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، قَالَ : لاَ بَأْسَ بِہِ۔",,,4754
4755,حَدَّثَنَا ابْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ؛ مِثْلَہُ۔,,,4755
4756,"حَدَّثَنَا وَکِیعٌ ، عَنْ یَزِیدَ بْنِ إبْرَاہِیمَ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : رَأَیْتُہ قَالَ بِثَوْبِہِ ہَکَذَا ، فَمَسَحَ بِہِ جَبْہَتَہُ ، وَأَمَرَّ وَکِیعٌ یَدَہُ عَلَی جَبْہَتِہِ۔",,,4756
4757,حَدَّثَنَا بِشْرُ بْنُ الْمُفَضَّلِ ، عَنْ سَلَمَۃَ بْنِ عَلْقَمَۃَ ، عَنِ ابْنِ سِیرِینَ ؛ بِنَحْوِ حَدِیثِ وَکِیعٍ ، أَوْ مِثْلِہِ۔,,,4757
4758,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ (ح) وَمُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَنَامُ خَلْفَ الإِمَامِ حَتَّی یَرْکَعَ الإِمَامُ وَیَسْجُدَ ، ثُمَّ یَنْتَبِہَ النَّائِمُ ، قَالاَ : یَتْبَعُ الإِمَامَ فَیصلی مَا سَبَقَہُ بِہِ۔",,,4758
4759,"حَدَّثَنَا شَرِیکٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَنْسَی الصَّلَوَاتِ ، قَالَ : یَبْدَأُ بِالأُولَی فَالأُولَی۔",,,4759
4760,"حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ، قَالَ : إذَا نَسِیَ الصَّلَوَاتِ فَلْیَبْدَأْ بِالأَولِ فَالأَولِ ، فَإِنْ خَافَ الْفَوْتَ یَبْدَأُ بِالَّتِی یَخَافُ فَوْتَہَا۔",,,4760
4761,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی رَاشِدٍ ، قَالَ : نِمْتُ عَنِ الظُّہْرِ ، وَالْعَصْرِ ، وَالْمَغْرِبِ ، وَالْعِشَائِ ، فَأَتَیْتُ عُبَیْدَ بْنَ عُمَیْرٍ فَذَکَرْتُ ذَلِکَ لَہُ ، فَقَالَ : ابْدَأْ بِالظُّہْرِ وَالْعَصْرِ ، وَالْمَغْرِبِ وَالْعِشَائِ۔",,,4761
4762,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ مَعْمَرٍ ، عَنْ عَبْدِ الْکَرِیمِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ فِی رَجُلٍ نَسِیَ صَلاَۃً فَذَکَرَہَا عِنْدَ غُرُوبِ الشَّمْسِ ، وَلَمْ یَکُنْ صَلَّی تِلْکَ الصَّلاَۃ ، قَالَ : إِنْ خَشِیَ أَنْ یُصَلِّیَ ہَذِہِ الَّتِی کَانَ نَسِیَ فَیَذْہَبَ وَقْتُ تِلْکَ ، فَلْیَبْدَأْ بِالَّتِی یَخَافُ فَوْتَہَا۔",,,4762
4763,"حَدَّثَنَا عَبْدُ اللہِ بْنُ مُبَارَکٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : یَقْضِی الأَولَ فَالأَولَ۔",,,4763
4764,"حَدَّثَنَا کَثِیرُ بْنُ ہِشَامٍ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ حَمَّادِ بْنِ فَرْوَۃَ ، قَالَ : أَہْرَقْتُ الْمَائُ فَنَسِیتُ أَنْ أَتَوَضَّأَ ، فَصَلَّیْتُ الظُّہْرَ وَالْعَصْرَ وَالْمَغْرِبَ ، فَذَکَرْت أَنِّی صَلَّیْتہَا عَلَی غَیْرِ طُہْرٍ ، فَلَمَّا أَصْبَحْتُ سَأَلْتُ عَطَائً وَمُجَاہِدًا ، قَالَ جَعْفَرُ : وَأَحْسِبُہُ ، قَالَ : وَسَعِیدَ بْنَ جُبَیْرٍ ، فَکُلُّہُمْ قَال لَہُ : تَوَضَّأْ وَأَعِدْ صَلاَتَکَ الآنَ، تَبْدَأُ بِالأَولِ فَالأَولِ۔",,,4764
4765,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی حَمْزَۃَ ، عَنْ مَوْلًی لأَبِی بَکْرَۃَ ، قَالَ : دَخَلَ أَبُو بَکْرَۃَ بُسْتَانًا ، فَطَافَ فِیہِ وَنَظَرَ إلَیْہِ وَنَسِیَ صَلاَۃَ الْعَصْرِ حَتَّی مَالَتِ الشَّمْسُ ، فَلَمَّا ذَکَرَہَا تَوَضَّأَ وَجَلَسَ ، فَلَمَّا وَجَبَتْ قَامَ فَصَلَّی الْعَصْرَ ، ثُمَّ صَلَّی الْمَغْرِبَ۔",,,4765
4766,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنْ وَاصِلٍ مَوْلَی أَبِی عُیَیْنَۃَ ، عَنْ رَجُلٍ یُقَالُ لَہُ : سَعْدٌ ، قَالَ : صَلَّیْت فِی رَمَضَانَ مَعَ النَّاسِ ، ثُمَّ أَتَیْتُ بَیْتًا لأَہْلِی فَدَخَلْت فِیہِ فَنِمْت لَیْلَتِی وَیَوْمِی وَلَیْلَتِی حَتَّی الْغَدِ ، فَأَتَیْت ابْنَ عُمَرَ فَأَخْبَرْتُہُ ؟ قَالَ : فَصَنَعْتَ مَاذَا ؟ قَالَ : صَلَّیْت الظُّہْرَ ، قَالَ : أَحْسَنْت ، قَالَ : ثم مَاذَا ؟ قَالَ : صَلَّیْتُ الْعَصْرَ ، قَالَ : أَحْسَنْت ، قَالَ ، ثُمَّ مَاذَا ؟ قَالَ : صَلَّیْت الْمَغْرِبَ ، قَالَ أَحْسَنْت قَالَ : ثُمَّ مَاذَا ؟ قَالَ : صَلَّیْت الْعِشَائَ ، قَالَ : أَحْسَنْت ، قَالَ ، ثُمَّ مَاذَا ؟ قَالَ : أَوْتَرْت ، قَالَ : مَا کُنْت تَصْنَعُ بِالْوِتْرِ ؟ قَالَ : ثُمَّ مَاذَا ؟ قَالَ : صَلَّیْت الصُّبْحَ ، قَالَ : أَحْسَنْت۔",,,4766
4767,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، وَمَنْصُورٌ ، عَنِ الْحَسَنِ ، أَنَّہُ کَانَ یَقُولُ : مَنْ نَامَ عَنْ صَلاَۃِ الْعِشَائِ فَاسْتَیْقَظَ عِنْدَ طُلُوعِ الشَّمْسِ ، قَالَ : یُصَلِّی الْفَجْرَ ، ثُمَّ یُصَلِّی الْعِشَائَ۔",,,4767
4768,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، أَنَّہُ کَانَ یَقُولُ : یَبْدَأُ بِالْعِشَائِ الَّتِی نَامَ عَنْہَا۔",,,4768
4769,"حَدَّثَنَا رَوْحُ بْنُ عُبَادَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ فِی الرَّجُلِ یَنْسَی الْعَتَمَۃَ ، أَوْ یَرْقُدُ عَنْہَا حَتَّی یَکُونَ الصُّبْحُ ، فَقِیلَ لَہُ : فَإِنْ بَدَأَ بِالْعَتَمَۃِ فَاتَتْہُ الصُّبْحُ ؟ قَالَ : فَلْیَبْدَأْ بِالْعَتَمَۃِ وَإِنْ فَاتَتْہُ الصُّبْحُ۔",,,4769
4770,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ أَیُّوبَ أَبِی الْعَلاَئِ ، قَالَ : حدَّثَنَا قَتَادَۃُ ، عَنْ أَنَسٍ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ نَسِیَ صَلاَۃً ، أَوْ نَامَ عَنْہَا فَکَفَّارَتُہُ أَنْ یُصَلِّیَہَا إذَا ذَکَرَہَا۔ (بخاری 597۔ مسلم 314)",,,4770
4771,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ جَامِعِ بْنِ شَدَّادٍ ، قَالَ : سَمِعْتُ عَبْدَ الرَّحْمَن بْنَ أَبِی عَلْقَمَۃَ ، قَالَ : سَمِعْتُ عَبْدَ اللہِ بْنَ مَسْعُودٍ ، قَالَ : أَقْبَلْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ مِنَ الْحُدَیْبِیَۃِ ، فَذَکَرُوا أَنَّہُمْ نَزَلُوا دَہَاسًا مِنَ الأَرْضِ ، یَعْنِی بِالدَّہَاسِ : الرَّمْلَ ، قَالَ : فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَنْ یَکْلَؤُنَا ؟ فَقَالَ بِلاَلٌ : أَنَا ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذًا نَنَامُ ، قَالَ : فَنَامُوا حَتَّی طَلَعَتْ عَلَیْہِمُ الشَّمْسُ ، قَالَ : فَاسْتَیْقَظَ نَاسٌ فِیہِمْ فُلاَنٌ وَفُلاَنٌ وَفِیہِمْ عُمَرُ ، فَقُلْنَا : اہْضِبُوا ، یَعْنِی تَکَلَّمُوا ، قَالَ : فَاسْتَیْقَظَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، فَقَالَ : افْعَلُوا کَمَا کُنْتُمْ تَفْعَلُونَ ، قَالَ : فَفَعَلْنَا ، قَالَ : کَذَلِکَ لِمَنْ نَامَ ، أَوْ نَسِیَ۔ (ابوداؤد 448۔ احمد 1/386)",,,4771
4772,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ أبی إسْمَاعِیلَ ، عَنْ أَبِی حَازِمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : عَرَّسْنَا مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ذَاتَ لَیْلَۃٍ ، فَلَمْ نَسْتَیْقِظْ حَتَّی آذَتْنَا الشَّمْسُ ، فَقَالَ لَنَا رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ: لِیَأْخُذْ کُلُّ رَجُلٍ مِنْکُمْ بِرَأْسِ رَاحِلَتِہِ ، ثُمَّ لْیَتَنَحَّ عَنْ ہَذَا الْمَنْزِلِ ، ثُمَّ دَعَا بِمَائٍ فَتَوَضَّأَ فَسَجَدَ سَجْدَتَیْنِ ، ثُمَّ أُقِیمَتِ الصَّلاَۃ فَصَلَّی۔ (مسلم 310۔ احمد 2/429)",,,4772
4773,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ عَبْدِ الْجَبَّارِ بن عَبَّاسٍ ، عَنْ عَوْنِ بْنِ أَبِی جُحَیْفَۃَ ، عَنْ أَبِیہِ ، قَالَ : کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَفَرِہِ الَّذِی نَامُوا فِیہِ حَتَّی طَلَعَتِ الشَّمْسُ ، ثُمَّ قَالَ : إنَّکُمْ کُنْتُمْ أَمْوَاتًا فَرَدَّ اللَّہُ إلَیْکُمْ أَرْوَاحَکُمْ ، فَمَنْ نَامَ عَنْ صَلاَۃٍ ، أَوْ نَسِیَ صَلاَۃً فَلْیُصَلِّہَا إذَا ذَکَرَہَا ، وَإِذَا اسْتَیْقَظَ۔ (ابو یعلی 895۔ طبرانی 268)",,,4773
4774,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا نَامَ الرَّجُلُ عَنْ صَلاَۃٍ ، أَوْ نَسِیَ فَلْیُصَلِّ إذَا اسْتَیْقَظَ ، أَوْ ذَکَرَ۔",,,4774
4775,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّ عِمْرَانَ بْنَ حُصَیْنٍ وَسَمُرَۃَ بْنَ جُنْدُبٍ اخْتَلَفَا فِی الَّذِی یَنْسَی صَلاَتَہُ ، فَقَالَ عِمْرَانُ : یُصَلِّیہَا إذَا ذَکَرہَا ، وَقَالَ سَمُرَۃُ : یُصَلِّیہَا إذَا ذَکَرَ وَفِی وَقْتِہَا مِنَ الْغَدِ۔",,,4775
4776,"حَدَّثَنَا وَکِیعٌ، عَنْ عَلِیِّ بْنِ صَالِحٍ، عَنْ سِمَاکٍ، عَنْ سَبْرَۃَ بْنِ نَخَفٍ، عَنِ ابْنِ عَبَّاسٍ، قَالَ: یُصَلِّی إذَا ذَکَرَ۔",,,4776
4777,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ أَبِی بَکْرِ بْنِ أَبِی مُوسَی ، عَنْ سَعْدٍ ، قَالَ : قَالَ: یُصَلِّیہَا إذَا ذَکَرَہَا ، وَیُصَلِّی مِثْلَہَا مِنَ الْغَدِ۔",,,4777
4778,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ، قَالَ : مَنْ نَامَ عَنْ صَلاَۃٍ ، أَوْ نَسِیَہَا ، قَالَ : یُصَلِّی مَتَی ذَکَرَہَا عِنْدَ طُلُوعِ الشَّمْسِ ، أَوَعِنْدَ غُرُوبِہَا ، ثُمَّ قَرَأَ : (أَقِمِ الصَّلاَۃ لِذِکْرِی) قَالَ : إذَا ذَکَرْتَہَا فَصَلِّہَا فِی أَیِّ سَاعَۃٍ کُنْتَ۔",,,4778
4779,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی حُمَیْدٍ ) ، عَنْ أَبِی مَلِیحٍ ، عَنْ أَبِی ذَرٍّ ، وَعَبْدِ الرَّحْمَنِ بْنِ عَوْفٍ؛ فِی الصَّلاَۃ تُنْسَی ؟ قَالاَ : یُصَلِّیہَا إذَا ذَکَرَہَا۔",,,4779
4780,"حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مُوسَی بْنِ قَیْسٍ ، عَنْ زَکَرِیَّا بْنِ جَرَادٍ ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، قَالَ : مَا کَانَ لَکَ أَحَدٌ یُہبَّکَ ؟ صَلِّہَا لِذِّکْرِی۔",,,4780
4781,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ أَشْعَثَ ، عَنِ الشَّعْبِیِّ ، وَإِبْرَاہِیمَ ، قَالاَ : {أَقِمِ الصَّلاَۃ لِذِکْرِی} أَیْ : صَلِّہَا إذَا ذَکَرْتَہَا وَقَدْ نَسِیتَہَا۔",,,4781
4782,"حَدَّثَنَا زَیْدُ بْنُ الْحُبَابِ ، عَنْ صَخْرِ بْنِ جُوَیْرِیَۃَ ، قَالَ : سَأَلْتُ نَافِعًا عَنْ رَجُلٍ نَسِیَ صَلاَۃَ الْعَصْرِ حَتَّی اصْفَارَّت الشَّمْسُ ؟ قَالَ : یُصَلِّیہَا لَیْسَتْ کَشَیْئٍ مِنَ الصَّلَوَاتِ۔",,,4782
4783,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ ، قَالَ : یُصَلِّیہَا إذَا ذَکَرَہَا۔",,,4783
4784,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَنَامُ عَنْ صَلاَۃِ الْعِشَائِ حَتَّی تَبْزُغَ الشَّمْسُ ، قَالَ : یُصَلِّی۔",,,4784
4785,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَعْفَرٍ ، عَنِ الزُّہْرِیِّ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ نَامَ عَنْ صَلاَۃِ الْفَجْرِ حَتَّی طَلَعَتِ الشَّمْسُ ، فَقَالَ لأَصْحَابِہِ : تَزَحْزَحُوا عَنِ الْمَکَانِ الَّذِی أَصَابَتْکُمْ فِیہِ الْغَفْلَۃُ ، فَصَلَّی ثُمَّ قَالَ : {أَقِمِ الصَّلاَۃ لِذِکْرِی}۔",,,4785
4786,"حَدَّثَنَا عَبْدُ الْوَہَّابِ الثَّقَفِیُّ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، عَنْ بَعْضِ بَنِی أَبِی بَکْرَۃَ ؛ أَنَّ أَبَا بَکْرَۃَ نَامَ فِی دَالِیَۃٍ لَہُمْ وَظَنَنَّا أَنَّہُ قَدْ صَلَّی الْعَصْرَ ، فَاسْتَیْقَظَ عِنْدَ غُرُوبِ الشَّمْسِ ، قَالَ : فَانْتَظَرَ حَتَّی غَابَتِ الشَّمْسُ ، ثُمَّ صَلَّی۔",,,4786
4787,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ سَعْدِ بن إِسْحَاقَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ عَبْدِ الْمَلِکِ بْنِ کَعْبٍ ، عَنْ أَبِیہِ ، قَالَ : نِمْتُ عَنِ الْفَجْرِ حَتَّی طَلَعَ قَرْنُ الشَّمْسِ ، وَنَحْنُ خَارِفُونَ فِی مَالٍ لَنَا ، فَمِلْتُ إلَی شَرْبَۃٍ مِنَ النَّخْلِ أَتَوَضَّأُ ، قَالَ : فَبَصُرَ بِی أَبِی فَقَالَ : مَا شَأْنُک ؟ قُلْتُ : أُصَلِّی قَدْ تَوَضَّأْت ، فَدَعَانِی فَأَجْلَسَنِی إلَی جَنْبِہِ ، فَلَمَّا أَنْ تَعَلَّتِ الشَّمْسُ وَابْیَضَّتْ وَأَتَیْتُ الْمَسْجِدَ ، ضَرَبَنِی قَبْلَ أَنْ أَقُومَ إلَی الصَّلاَۃ ، وَقَالَ : تَنْسَی ؟ صَلِّ الأَنَ۔",,,4787
4788,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ؛ فِی الرَّجُلِ إذَا نَسِیَ أَنْ یُصَلِّیَ صَلاَۃً حَتَّی تَصْفَرَّ الشَّمْسُ ، قَالَ: یُصَلِّیہَا إذَا غَابَتِ الشَّمْسُ ، وَقَالَ قَتَادَۃُ مِثْلَ ذَلِکَ۔",,,4788
4789,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا حُصَیْنُ بْنُ عَبْدِ الرَّحْمَنِ ، قَالَ : حَدَّثَنَا عَبْدُ اللہِ بْنُ أَبِی قَتَادَۃَ ، عَنْ أَبِیہِ أَبِی قَتَادَۃَ ، قَالَ : سِرْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَفَرٍ ذَاتَ لَیْلَۃٍ ، قَالَ : قُلْنَا : یَا رَسُولَ اللہِ ، لَوْ عَرَّسْت بِنَا ، فَقَالَ : إنِّی أَخَافُ أَنْ تَنَامُوا عَنِ الصَّلاَۃ ، فَمَنْ یُوقِظُنَا لِلصَّلاَۃِ ؟ قَالَ : فَقَالَ بِلاَلٌ : أَنَا ، یَا رَسُولَ اللہِ ، قَالَ : فَعَرَّسَ بِالْقَوْمِ وَاضْطَجَعُوا ، وَاسْتَنَدَ بِلاَلٌ إلَی رَاحِلَتِہِ فَغَلَبَتْہُ عَیْنَاہُ ، وَاسْتَیْقَظَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَقَدْ طَلَعَ حَاجِبُ الشَّمْسِ ، فَقَالَ : یَا بِلاَلُ ، أَیْنَ مَا قُلْتَ لَنَا ؟ فَقَالَ : یَا رَسُولَ اللہِ ، وَالَّذِی بَعَثَک بِالْحَقِّ مَا أُلْقِیَتْ عَلَیَّ نَوْمَۃٌ مِثْلہَا ، قَالَ : فَقَالَ : إنَّ اللَّہَ قَبَضَ أَرْوَاحَکُمْ حِینَ شَائَ ، وَرَدَّہَا عَلَیْکُمْ حِینَ شَائَ ، قَالَ : ثُمَّ أَمَرَہُمْ فَانْتَشَرُوا لِحَاجَتِہِمْ ، وَتَوَضَّؤُوا وَارْتَفَعَتِ الشَّمْسُ ، فَصَلَّی بِہِمُ الْفَجْرَ۔ (بخاری 595۔ ابوداؤد 441)",,,4789
4790,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَلِیِّ بْنِ الْمُبَارَکِ ، عَنْ یَحْیَی ، عَنْ أَبِی سَلَمَۃَ ، عَنْ جَابِرٍ ، قَالَ : جَائَ عُمَرُ یَوْمَ الْخَنْدَقِ فَجَعَلَ یَسُبُّ کُفَّارَ قُرَیْشٍ وَیَقُولُ : یَا رَسُولَ اللہِ ، مَا صَلَّیْتُ الْعَصْرَ حَتَّی کَادَتِ الشَّمْسُ أَنْ تَغِیبَ ، فَقَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : وَأَنَا وَاللَّہِ مَا صَلَّیْتُ بَعْدُ ، فَنَزَلَ فَتَوَضَّأَ ثُمَّ صَلَّی الْعَصْرَ بَعْدَ مَا غَرَبَتِ الشَّمْسُ ، ثُمَّ صَلَّی الْمَغْرِبَ بَعْدَ مَا صَلَّی الْعَصْرَ۔ (بخاری 945۔ مسلم 438)",,,4790
4791,"حَدَّثَنَا مَرْوَانُ بْنُ مُعَاوِیَۃَ ، عَنْ عَوْفٍ ، عَنْ أَبِی رَجَائٍ ، عَنْ عِمْرَانَ بْنِ حُصَیْنٍ ، قَالَ : کُنَّا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی سَفَرٍ ، وَإِنَّا سَرَیْنَا اللَّیْلَۃَ حَتَّی إذَا کَانَ آخِرُ اللَّیْلِ وَقَعْنَا تِلْکَ الْوَقْعَۃَ ، وَلاَ وَقْعَۃَ عِنْدَ الْمُسَافِرِ أَحْلَی مِنْہَا ، فَمَا أَیْقَظَنَا إِلاَّ حَرُّ الشَّمْسِ ، فَجَعَلَ عُمَرُ یُکَبِّرُ ، فَلَمَّا اسْتَیْقَظَ شَکَا النَّاسُ إلَیْہِ مَا أَصَابَہُمْ ، فَقَالَ : لاَ ضَیْرَ ، قَالَ : فَارْتَحَلُوا فَسَارُوا غَیْرَ بَعِیدٍ ، ثُمَّ نَزَلَ فَنُودِیَ بِالصَّلاَۃ ، فَصَلَّی بِالنَّاسِ۔ (بخاری 344۔ مسلم 476)",,,4791
4792,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ (ح) وَعَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالاَ: إذَا کُنْتَ فِی صَلاَۃِ الْعَصْرِ، فَذَکَرْت أَنَّک لَمْ تُصَلِّ الظُّہْرَ ، فَانْصَرِفْ فَصَلِّ الظُّہْرَ ، ثُمَّ صَلِّ الْعَصْرَ۔",,,4792
4793,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ فِی رَجُلٍ نَسِیَ الظُّہْرَ ، ثُمَّ ذَکَرَہَا وَہُوَ فِی الْعَصْرِ ، قَالَ : یَنْصَرِفُ فَیُصَلِّی الظُّہْرَ ، ثُمَّ یُصَلِّی الْعَصْرَ۔",,,4793
4794,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ فِی حَدِیثِہِ : وَإِنْ ذَکَرَہَا بَعْدَ مَا صَلَّی الْعَصْرَ فَقَدْ مَضَتْ ، وَیُصَلِّی الظُّہْرَ۔",,,4794
4795,"حَدَّثَنَا عَبْدُ الأَعْلَی ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : إِنْ ذَکَرَ وَہُوَ فِی الصَّلاَۃ ، انْصَرَفَ فَصَلَّی الظُّہْرَ، ثُمَّ صَلَّی الْعَصْرَ۔",,,4795
4796,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ وَحَمَّادًا عَنْ رَجُلٍ ذَکَرَ صَلاَۃً وَہُوَ فِی صَلاَۃٍ ؟ قَالاَ : إِنْ ذَکَرَہَا قَبْلَ أَنْ یَتَشَہَّدَ ، أَوْ یَجْلِسَ مِقْدَارَ التَّشَہُّدِ تَرَکَ ہَذِہِ وَعَادَ إلَی تِلْکَ ، وَإِنْ ذَکَرَہَا بَعْدَ ذَلِکَ اعْتَدَّ بِہَذِہِ ، وَعَادَ إلَی تِلْکَ۔",,,4796
4797,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مَنْصُورٌ ، عَنِ الْحَسَنِ ، قَالَ : یُصَلِّی الْعَصْرَ ، فَإِذَا فَرَغَ صَلَّی الظُّہْرَ۔",,,4797
4798,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : إذَا ذَکَرَ وَہُوَ فِی الْعَصْرِ أَنَّہُ لَمْ یُصَلِّ الظُّہْرَ ، فَإِنَّہُ یُصَلِّی الْعَصْرَ ، ثُمَّ یُصَلِّی الظُّہْرَ بَعْدُ۔",,,4798
4799,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ یَقُولُ : إذَا ذَکَرْتَ وَأَنْتَ تُصَلِّی الْعَصْرَ أَنَّک لَمْ تُصَلِّ الظُّہْرَ ، مَضَیْت فِیہَا ، ثُمَّ صَلَّیْت الظُّہْرَ ، فَإِذَا صَلَّیْتَ الْعَصْرَ وَذَکَرْت أَنَّک لَمْ تُصَلِّ الظُّہْرَ فَصَلَّیْت أَجْزَأَتْک۔",,,4799
4800,حَدَّثَنَا حَفْصٌ ، عَنْ أَشْعَثَ بْنِ عَبْدِ الْمَلِکِ ، عَنِ الْحَسَنِ ، مِثْلَہُ۔,,,4800
4801,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ فِی رَجُلٍ صَلَّی بِقَوْمٍ الظُّہْرَ وَہِیَ لَہُ الْعَصْرُ ، قَالَ : تَمَّتْ صَلاَتُہُ ، وَیُعِیدُ مَنْ خَلْفَہُ۔",,,4801
4802,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ خَالِدٍ ، عَنْ أَبِی قِلاَبَۃَ ، قَالَ : لاَ تُجْزِئُ صَلاَۃٌ وَاحِدَۃٌ عَنْ قَوْمَیْنِ شَتَّی۔",,,4802
4803,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ عَبَّادِ بْنِ مَنْصُورٍ ، قَالَ : انْتَہَیْت إلَی الْمَسْجِدِ الْجَامِعِ وَأَنَا أَرَی أَنَّہُمْ لَمْ یُصَلُّوا الظُّہْرَ ، فَقُمْتُ أَتَطَوَّعُ حَتَّی أُقِیمَتِ الصَّلاَۃ ، فَلَمَّا صَلَّوْا إذَا ہِیَ الْعَصْرُ ، فَقُمْت فَصَلَّیْت بِہِمُ الظُّہْرَ ، ثُمَّ صَلَّیْت الْعَصْرَ ، ثُمَّ أَتَیْتُ الْحَسَنَ ، فَذَکَرْت ذَلِکَ لَہُ فَأَمَرَنِی بِمِثْلِ الَّذِی صَنَعْت۔",,,4803
4804,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ مُحَمَّدِ بْنِ سِیرِینَ ، عَنْ کَثِیرِ بْنِ أَفْلَحَ ، قَالَ : انْتَہَیْنَا إلَی الْمَسْجِدِ وَلَمْ أُصَلِّ الْمَغْرِبَ ، فَأُقِیمَتِ الصَّلاَۃ فَصَلَّیْت مَعَہُمْ وَأَنَا أَرَی أَنَّہَا الْمَغْرِبُ ، فَإِذَا ہِیَ الْعِشَائُ ، فَقُمْت فَصَلَّیْت الْمَغْرِبَ ، ثُمَّ صَلَّیْت الْعِشَائَ ، ثُمَّ سَأَلْتُ ، فَأَمَرُونِی بِالَّذِی صَنَعْت۔",,,4804
4805,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنِ الزُّہْرِیِّ ؛ فِی رَجُلٍ دَخَلَ مَعَ قَوْمٍ فِی الظُّہْرِ ، وَہِیَ لَہُمُ الْعَصْرُ ؟ قَالَ : یَبْدَأُ بِالَّذِی بَدَأَ اللَّہُ بِہِ یُصَلِّی الظُّہْرَ ، ثُمَّ یُصَلِّی الْعَصْرَ۔",,,4805
4806,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، قَالَ : بَلَغَنِی عَنْ طَاوُوسٍ ، وَعَطَائٍ ، أَنَّہُمَا قَالاَ : یُجْزِئُہُ۔",,,4806
4807,"حَدَّثَنَا مُحَمَّدُ بْنُ عَبْدِ اللہِ الأَسَدِیُّ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، قَالَ : سَأَلْتُ أَبَا جَعْفَرٍ وَسَالِمًا ، وَالْقَاسِمَ ، وَعَطَائً عَنْ رَجُلٍ دَخَلَ مَعَ قَوْمٍ فِی الْعَصْرِ وَہُوَ یَرَی أَنَّہَا الظُّہْرُ ؟ قَالُوا : یَنْصَرِفُ فَیُصَلِّی الظُّہْرَ، ویُجْزِئُ عَنْہُ الْعَصْرُ ، قَالَ : وَسَأَلْت عَامِرًا ، وَمُسْلِمَ بْنَ صُبَیْحٍ ، فَقَالاَ : یَنْصَرِفُ فَیُصَلِّی الظُّہْرَ ، ثُمَّ یُصَلِّی الْعَصْرَ ، فَإِنَّ اللَّہَ قَدْ کَتَبَہَا عِنْدَہُ قَبْلَ الْعَصْرِ ، فَلاَ تَکُونُ لَہُ الظُّہْرُ ۔ وَقَالَ جَابِرٌ : عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، مِثْلَ ذَلِکَ۔",,,4807
4808,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ ، قَالاَ : فِی رَجُلٍ دَخَلَ مَعَ قَوْمٍ فِی صَلاَۃِ الْعَصْرِ، وَہُوَ یَحْسَبُہُمْ فِی صَلاَۃِ الظُّہْرِ، فَإِذَا ہُمْ فِی الْعَصْرِ، قَالَ: یَسْتَقْبِلُ الصَّلاَتَیْنِ جَمِیعًا۔",,,4808
4809,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَقُولُ فِی الْمُسَافِر إذَا نَسِیَ صَلاَۃً فَذَکَرَہَا فِی الْحَضَرِ: صَلَّی صَلاَۃَ السَّفَرِ، وَإِذَا نَسِیَ صَلاَۃً فِی الْحَضَرِ فَذَکَرَہَا فِی السَّفَرِ، فَلْیُصَلِّ صَلاَۃَ الْحَضَرِ۔",,,4809
4810,حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، وَعُبَیْدَۃَ ، عَنْ إبْرَاہِیمَ ؛ مِثْلَ ذَلِکَ۔,,,4810
4811,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ أبی الْفَضْلِ ، عَنِ الْحَسَنِ ، قَالَ : إذَا نَسِیَ صَلاَۃً فِی الْحَضَرِ ، فَذَکَرَہَا فِی السَّفَرِ صَلَّی صَلاَۃَ الْحَضَرِ، وَإِذَا نَسِیَ صَلاَۃً فِی السَّفَرِ فَذَکَرَہَا فِی الْحَضَرِ، صَلَّی صَلاَۃَ السَّفَرِ۔",,,4811
4812,"حَدَّثَنَا وَکِیعٌ ، قَالَ : سَمِعْتُ سُفْیَانَ یَقُولُ : یُصَلِّی الصَّلاَۃ الَّتِی نَسِیَہَا۔",,,4812
4813,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ الْخَالِقِ ، عَنْ حَمَّادٍ ، قَالَ : إذَا نَسِیَ صَلاَۃً فِی الْحَضَرِ فَذَکَرَہَا فِی السَّفَرِ صَلَّی أَرْبَعًا ، وَإِذَا نَسِیَ صَلاَۃً فِی السَّفَرِ فَذَکَرَہَا فِی الْحَضَرِ ، صَلَّی صَلاَۃَ سَفَرٍ۔",,,4813
4814,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو الزُّبَیْرِ ، عَنْ نَافِعِ بْنِ جُبَیْرٍ ، عَنْ أَبِی عُبَیْدَۃَ بْنِ عَبْدِ اللہِ ، عَنْ أَبِیہِ ؛ أَنَّ الْمُشْرِکِینَ شَغَلُوا النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَوْمَ الْخَنْدَقِ عَنْ أَرْبَعِ صَلَوَاتٍ ، حَتَّی ذَہَبَ مِنَ اللَّیْلِ مَا شَائَ اللَّہُ ، قَالَ : فَأَمَرَ بِلاَلاً فَأَذَّنَ وَأَقَامَ ، فَصَلَّی الظُّہْرَ ، ثُمَّ أَقَامَ فَصَلَّی الْعَصْرَ ، ثُمَّ أَقَامَ فَصَلَّی الْمَغْرِبَ ، ثُمَّ أَقَامَ فَصَلَّی الْعِشَائَ۔ (ترمذی 179۔ احمد 1/375)",,,4814
4815,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ابْنُ أَبِی ذِئْبٍ ، عَنِ الْمَقْبُرِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ أَبِی سَعِیدٍ الْخُدْرِیِّ ، عَنْ أَبِیہِ ، قَالَ : حُبِسْنَا یَوْمَ الْخَنْدَقِ عَنِ الظُّہْرِ وَالْعَصْرِ وَالْمَغْرِبِ وَالْعِشَائِ ، حَتَّی کُفِینَا ذَلِکَ ، وَذَلِکَ قولہ تعالی : {وَکَفَی اللَّہُ الْمُؤْمِنِینَ الْقِتَالَ وَکَانَ اللَّہُ قَوِیًّا عَزِیزًا} فَقَامَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَمَرَ بِلاَلاً ، فَأَقَامَ الصَّلاَۃ ، ثُمَّ صَلَّی الظُّہْرَ کَمَا کَانَ یُصَلِّیہَا قَبْلَ ذَلِکَ ، ثُمَّ أَقَامَ الْعَصْرَ ، فَصَلَّی الْعَصْرَ کَمَا کَانَ یُصَلِّیہَا قَبْلَ ذَلِکَ ، ثُمَّ أَقَامَ الْمَغْرِبَ ، فَصَلَّی الْمَغْرِبَ کَمَا کَانَ یُصَلِّیہَا قَبْلَ ذَلِکَ ، ثُمَّ أَقَامَ الْعِشَائَ فَصَلاَّہَا کَمَا کَانَ یُصَلِّیہَا قَبْلَ ذَلِکَ ، قَبْلَ أَنْ یَنْزِلَ : {فَإِنْ خِفْتُمْ فَرِجَالاً أَوْ رُکْبَانًا}۔ (احمد 3/68۔ دارمی 1524)",,,4815
4816,"حَدَّثَنَا وَکِیعٌ ، عَنْ مِسْعَرٍ ، عن سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، قَالَ : قَالَ عُمَرُ : مَنْ فَاتَہُ شَیْئٌ مِنْ قِرَائَتِہِ بِاللَّیْلِ ، فَصَلَّی مَا بَیْنَہُ وَبَیْنَ الظُّہْرِ ، فَکَأَنَّمَا صَلَّی بِاللَّیْلِ۔",,,4816
4817,"حَدَّثَنَا وَکِیعٌ ، عَنِ الأَوْزَاعِیِّ ، عَنْ عَبْدَۃَ ، عَنْ أَبِی بَکْرِ بْنِ عَمْرِو بْنِ حَزْمٍ ؛ أَنَّ رَجُلاً اسْتَأْذَنَ عَلَی عُمَرَ بِالْہَاجِرَۃِ ، فَحَجَبَہُ طَوِیلاً ، ثُمَّ أَذِنَ لَہُ ، فَقَالَ : إنِّی کُنْتُ نِمْتُ عَنْ حِزْبِیْ ، فَکُنْت أَقْضِیہِ۔",,,4817
4818,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ عُثْمَانَ الثَّقَفِیِّ ، عَنْ أَبِی عُبَیْدِ اللہِ مَوْلَی ابْنِ عَبَّاسٍ ، قَالَ : قَالَ عَلِیٌّ : مَنْ فَاتَہُ شَیْئٌ مِنْ حِزْبِہِ ، فَصَلاَّہُ ارْتِفَاعَ النَّہَارِ ، فَکَأَنَّمَا صَلاَّہُ بِاللَّیْلِ۔",,,4818
4819,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَفْلَحَ ، عَنِ الْقَاسِمِ ، قَالَ : کُنَّا نَأْتِی عَائِشَۃَ قَبْلَ صَلاَۃِ الْفَجْرِ فَأَتَیْنَاہَا ذَاتَ یَوْمٍ فَإِذَا ہِیَ تُصَلِّی ، فَقَالَتْ : نِمْت عَنْ حِزْبِی فِی ہَذِہِ اللَّیْلَۃِ فَلَمْ أَکُنْ لأَدَعَہُ۔",,,4819
4820,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ مُحَمَّدِ بْنِ عَمْرٍو ، عَنْ أَبِی سَلَمَۃَ ، قَالَ : مَنْ فَاتَہُ جُزْؤُہُ مِنَ اللَّیْلِ فَقَضَاہُ قَبْلَ أَنْ تَزُولَ الشَّمْسُ ، فَقَدْ أَدْرَکَ۔",,,4820
4821,"حَدَّثَنَا شَرِیکٌ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ (ح) وَعَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالاَ : ہُوَ کَلاَمٌ ، یَعْنِی الْفَتْحَ عَلَی الإِمَام۔",,,4821
4822,حَدَّثَنَا حَفْصٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کان یَکْرَہُ أَنْ یَفْتَحَ عَلَی الإِمَام۔,,,4822
4823,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ مَیْمُونِ أَبِی حَمْزَۃَ ، عَنْ إبْرَاہِیمَ ، عَنِ ابْنِ مَسْعُودٍ ؛ فِی تَلْقِینِ الإِمَام : إنَّمَا ہُوَ کَلاَمٌ یُلْقِیہِ إلَیْہِ ، قَالَ : وَقَالَ إبْرَاہِیمُ : مَا أُبَالِی لَقَّنتُۃٌ ، أَوْ قُلْتُ : یَا کَبِیرۃ۔",,,4823
4824,"حَدَّثَنَا حَفْصٌ ، عَنْ مُحَمَّدِ بْنِ قَیْسٍ ، عَنْ سَلَمِ بْنِ عَطِیَّۃَ ؛ أَنَّ رَجُلاً فَتَحَ عَلَی إمَامِ شُرَیْحٍ وَہُوَ فِی الصَّلاَۃ، فَلَمَّا انْصَرَفَ ، قَالَ لَہُ : اقْضِ صَلاَتَک۔",,,4824
4825,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حُرَیْثٍ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ؛ أَنَّہُ کَرِہَ أَنْ یُلَقَّنَ الْقَارِیئُ۔,,,4825
4826,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : مَنْ فَتَحَ عَلَی الإِمَام فَقَدْ تَکَلَّمَ۔",,,4826
4827,حَدَّثَنَا حَفْصٌ ، عَنْ حَجَّاجٍ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ؛ أَنَّہُ کَرِہَ الْفَتْحَ عَلَی الإِمَام۔,,,4827
4828,"حَدَّثَنَا عَبْدُ الرَّحْمَنِ بْنُ مَہْدِیٍّ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنْ عَبِیْدَۃَ بْنِ رَبِیعَۃَ ، قَالَ : أَتَیْتُ الْمَقَامَ فَإِذَا رَجُلٌ حَسَنُ الثِّیَابِ طَیِّبُ الرِّیحِ یُصَلِّی فَقَرَأَ ، وَرَجُلٌ إلَی جَنْبِہِ یَفْتَحُ عَلَیْہِ ، فَقُلْتُ : مَنْ ہَذَا ؟ قَالُوا: عُثْمَانَ۔",,,4828
4829,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ لَیْثٍ ، عَنْ عَبْدِ الأَعْلَی ، عَنْ أَبِی عَبْدِ الرَّحْمَنِ ، عَنْ عَلِیٍّ، قَالَ: إذَا اسْتَطْعَمَک الإِمَام فَأَطْعِمْہُ۔",,,4829
4830,"حَدَّثَنَا غُنْدَرٌ ، عَنْ مَعْمَرٍ ، عَنِ الزُّہْرِیِّ ، قَالَ : کَانَ مَرْوَانُ یُلَقِّنُ فِی الصَّلاَۃ وَأَصْحَابُ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْمَدِینَۃِ۔",,,4830
4831,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ، أَنَّہُمَا کَانَا لاَ یَرَیَانِ بَأْسًا بِتَلْقِینِ الإِمَام۔,,,4831
4832,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عن ہشام ، عَنِ الْحَسَنِ ، وَابْنِ سِیرِینَ ، قَالاَ : لُـقِّنَ الإِمَام۔",,,4832
4833,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ مُحَمَّدٍ ؛ أَنَّ ابْنَ مُغَفَّلٍ أَمَرَ رَجُلاً یُلَقِّنُہُ إذَا تَعَایَی۔,,,4833
4834,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مُسَاوِرٍ ، قَالَ : حدَّثَنِی ہِلاَلُ بْنُ أَبِی حُمَیْدٍ ، قَالَ : کُنْتُ أَفْتَحُ عَلَی عَبْدِ اللہِ بْنِ عُکَیْمٍ إذَا تَعَایَی فِی الصَّلاَۃ ، فَقَالَ لِی یَوْمًا : أَمَا صَلَّیْتَ مَعَنَا ؟ قَالَ : فَقُلْتُ : لاَ ،قَالَ : قَدِ اسْتَنکَرْتُ ذَلِکَ ، تَرَدَّدْت الْبَارِحَۃَ فَلَمْ أَجِدْ أَحَدًا یَفْتَحُ عَلَیَّ ؟۔",,,4834
4835,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِتَلْقِینِ الإِمَام۔",,,4835
4836,"حَدَّثَنَا معن بْنُ عِیسَی ، عَنْ مَالِکِ بْنِ أَنَسٍ ، عَنْ یَزِیدَ بْنَ رُومَانَ ، قَالَ : کُنْتُ أُصَلِّی إلَی جَنْبِ نَافِعِ بْنِ جُبَیْرِ بْنِ مُطْعِمٍ ، فَیَغْمِزُنِی فَأَفْتَحُ عَلَیْہِ وَہُوَ یُصَلِّی۔",,,4836
4837,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ أَشْعَثَ ، عَنْ نَافِعٍ ، قَالَ : صَلَّی بِنَا ابْنُ عُمَرَ ، قَالَ : فَتَرَدَّدَ ، قَالَ : فَفَتَحْتُ عَلَیْہِ فَأَخَذَ عَنِّی۔",,,4837
4838,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَاصِمٍ ، عن أَبِی وَائِلٍ ، عَنْ عَبْدِ اللہِ ، قَالَ : کُنَّا نُسَلِّمُ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یُصَلِّی فَیَرُدُّ عَلَیْنَا ، قَبْلَ أَنْ نَأْتِیَ أَرْضَ الْحَبَشَۃِ ، فَلَمَّا قَدِمْنَا مِنْ أَرْضِ الْحَبَشَۃِ سَلَّمْتُ عَلَیْہِ فَلَمْ یَرُدَّ عَلَیَّ ، فَأَخَذَنِی مَا قَرُبَ ، وَمَا بَعُدَ ، فَلَمَّا قَضَی صَلاَتَہُ ، قَالَ : إنَّ اللَّہَ یُحْدِثُ مِنْ أَمْرِہِ مَا شَائَ ، وَقَدْ أَحْدَثَ أَنْ لاَ تَکَلَّمُوا فِی الصَّلاَۃ۔ (ابوداؤد 921۔ احمد 1/377)",,,4838
4839,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ أبی الزُّبَیْرِ ، عن جابر ، قَالَ : بَعَثَنِی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی حَاجَۃٍ ، فَجِئْت وَہُوَ یُصَلِّی ، فَسَلَّمْت عَلَیْہِ ، فَلاَ یَرُدُّ عَلَیَّ السَّلاَمَ ۔(ابوداؤد 923۔ احمد 3/379)",,,4839
4840,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ، قَالَ : السَّلاَمُ عَلَی الْمُصَلِّی عَجْز۔",,,4840
4841,"حَدَّثَنَا حَفْصٌ ، وَوَکِیعٌ ، عَنْ زَکَرِیَّا ، قَالَ : قُلْتُ لِلشَّعْبِیِّ : أَدْخُلُ عَلَی قَوْمٍ وَہُمْ یُصَلُّونَ فُرَادَی ، أَأُسَلِّمُ عَلَیْہِمْ ؟ قَالَ : لاَ۔",,,4841
4842,"حَدَّثَنَا جَرِیرٌ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : یَرُدُّ عَلَیْہِ فِی نَفْسِہِ۔",,,4842
4843,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ أَبِی قِلاَبَۃَ ، عَنْ رَجُلٍ مِنْ بَنِی عَامِرٍ ، قَالَ : قُمْتُ إلَی جَنْبِ أَبِی ذَرٍّ وَہُوَ یُصَلِّی ، فَسَلَّمْت عَلَیْہِ ، فَمَا رَدَّ عَلَیَّ۔",,,4843
4844,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ یَعْقُوبَ بن عَبْدِ اللہِ بْنِ الأَشَجِّ ، عَنْ بُسر بْنِ سَعِیدٍ ، قَالَ : سَلَّمَ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلٌ وَہُوَ یُصَلِّی ، فَأَشَارَ إلَیْہِ بِیَدِہِ ، کَأَنَّہُ یَنْہَاہُ۔",,,4844
4845,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنِ الأَعْمَشِ ، عَنْ إِبْرَاہِیمَ ، عَن عَلْقَمَۃَ ، عَنْ عَبْدِ اللہِ ، قَالَ : کُنَّا نُسَلِّمُ عَلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ فِی الصَّلاَۃ قَبْلَ أَنْ نَخْرُجَ إلَی النَّجَاشِیِّ فَیَرُدُّ عَلَیْنَا ، فَلَمَّا رَجَعْنَا مِنْ عِنْدِ النَّجَاشِیِّ سَلَّمْت عَلَیْہِ فَلَمْ یَرُدَّ ، وَقَالَ : إنَّ فِی الصَّلاَۃ شُغْلاً۔ (بخاری 1199۔ ابوداؤد 920)",,,4845
4846,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ زَیْدِ بْنِ أَسْلَمَ ، عَنِ ابْنِ عُمَرَ ، قَالَ : سَأَلْتُ صُہَیْبًا ، کَیْفَ کَانَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَصْنَعُ حَیْثُ کَانَ یُسَلَّمُ عَلَیْہِ ؟ قَالَ : کَانَ یُشِیرُ بِیَدِہِ۔ (ابوداؤد 922۔ ترمذی 367)",,,4846
4847,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائٍ ، قَالَ : سَلَّمْتُ عَلَی ابْنِ عَبَّاسٍ وَہُوَ یُصَلِّی فِی وَجْہِ الْکَعْبَۃِ ، فَأَخَذَ بِیَدِی۔",,,4847
4848,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ عَطَائٍ ، قَالَ : سَلَّمْتُ عَلَی ابْنِ عَبَّاسٍ وَہُوَ فِی الصَّلاَۃ ،فَلَمْ یَرُدَّ عَلَیَّ ، وَبَسَطَ یَدَہُ إلَیَّ وَصَافَحَنِی۔",,,4848
4849,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ عَبْدِ رَبِّہِ ، عَنْ أَبِی عِیَاضٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إذَا سُلِّمَ عَلَیْک وَأَنْتَ فِی الصَّلاَۃ ، فَرُدَّ۔",,,4849
4850,"حَدَّثَنَا حَفْصٌ ، وَأَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، عَنْ أَبِی سُفْیَانَ ، عَنْ جَابِرٍ ، قَالَ : مَا کُنْتُ لِأُسَلِّمُ عَلَی رَجُلٍ وَہُوَ یُصَلِّی ، زَادَ أَبُو مُعَاوِیَۃَ : وَلَوْ سَلَّمَ عَلَیَّ لَرَدَدْت عَلَیْہِ۔",,,4850
4851,"حَدَّثَنَا عَبْدَۃُ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : إذَا سُلِّمَ علی أَحَدِکُمْ وَہُوَ فِی الصَّلاَۃ فَلْیُشِرْ بِیَدِہِ۔",,,4851
4852,"حَدَّثَنَا وَکِیعٌ ، عَنْ عِمْرَانَ بْنِ حُدَیْرٍ ، عَنْ أَبِی مِجْلَزٍ ؛ سُئِلَ عَنِ الرَّجُلِ یُسَلَّمُ عَلَیْہِ فِی الصَّلاَۃ ؟ قَالَ : یَرُدُّ بِشِقِّ رَأْسِہِ الأَیْمَنِ۔",,,4852
4853,"حَدَّثَنَا جَرِیرٌ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یُسَلَّمُ عَلَیْہِ فِی الصَّلاَۃ ، قَالَ : یَرُدُّ عَلَیْہِ السَّلاَمَ إذَا انْصَرَفَ ، فَإِذَا ذَہَبَ اتَّبَعَہُ بِالسَّلاَمِ۔",,,4853
4854,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ عَوْنٍ ، عَنِ ابْنِ سِیرِینَ ، قَالَ : لَمَّا قَدِمَ عَبْدُ اللہِ مِنَ الْحَبَشَۃِ أَتَی النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یُصَلِّی ، فَسَلَّمَ عَلَیْہِ فَأَوْمَأَ ، وَأَشَارَ بِرَأْسِہِ۔",,,4854
4855,"حَدَّثَنَا وَکِیعُ بْنُ الْجَرَّاحِ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ حَبِیبِ بْنِ أَبِی ثَابِتٍ ، عَنْ عَطَائِ بْنِ أَبِی رَبَاحٍ ؛ أَنَّ رَجُلاً سَلَّمَ عَلَی ابْنِ عَبَّاسٍ وَہُوَ فِی الصَّلاَۃ ، فَأَخَذَ بِیَدِہِ فَصَافَحَہُ ، وَغَمَزَ یَدَہُ۔",,,4855
4856,"حَدَّثَنَا وَکِیعٌ ، قَالَ : سَمِعْتُ سُفْیَانَ یَقُولُ : لاَ یَرُدُّ السَّلاَمَ حَتَّی یُصَلِّیَ ، فَإِنْ کَانَ قَرِیبًا رَدَّ عَلَیْہِ ، وَإِنْ کَانَ بَعِیدًا تبِعَہُ بِالسَّلاَمِ۔",,,4856
4857,"حَدَّثَنَا یُونُسُ ، عَنْ مُحَمَّدٍ ، عَنْ عَبْدِ الْوَاحِدِ بْنِ زِیَادٍ ، قَالَ : حدَّثَنَا عَاصِمٌ ، عَنْ أَبِی الْعَالِیَۃِ ، قَالَ : سُئِلَ عَنِ الرَّجُلِ یُسَلَّمُ عَلَیْہِ وَہُوَ فِی الصَّلاَۃ ؟ قَالَ : إذَا قَضَی الصَّلاَۃ أَتْبَعَہُ بِالسَّلاَمِ۔",,,4857
4858,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا حَمَّادُ بْنُ سَلَمَۃَ ، عَنْ أَبِی الزُّبَیْرِ ، عَنِ ابْنِ الْحَنَفِیَّۃِ ، عَنْ عَمَّارٍ ، قَالَ : أَتَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یُصَلِّی فَسَلَّمْت عَلَیْہِ ، قَالَ : فَرَدَّ عَلَیَّ السَّلاَمَ۔ (احمد 4/263۔ ابو یعلی 1634)",,,4858
4859,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ الرَّحْمَنِ بْنِ مَوْہَبٍ ، عَنْ عَمِّہِ ، عَنْ مَوْلًی لأَبِی سَعِیدٍ الْخُدْرِیِّ ؛ أَنَّہُ کَانَ مَعَ أَبِی سَعِیدٍ الْخُدْرِیِّ وَہُوَ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ جَالِسٌ ، قَالَ : فَدَخَلَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ الْمَسْجِدَ فَرَأَی رَجُلاً جَالِسًا وَسَطَ الْمَسْجِدِ مُشَبِّکًا أَصَابِعَہُ یُحَدِّثُ نَفْسَہُ ، قَالَ : فَأَوْمَأَ إلَیْہِ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَلَمْ یَفْطِنْ ، فَالْتَفَتَ إلَی أَبِی سَعِیدٍ الْخُدْرِیِّ ، فَقَالَ : إذَا صَلَّی أَحَدُکُمْ فَلاَ یُشَبِّکَنَّ بَیْنَ أَصَابِعِہِ ، فَإِنَّ التَّشْبِیکَ مِنَ الشَّیْطَانِ ، وَإِنَّ أَحَدَکُمْ لاَ یَزَالُ فِی صَلاَۃٍ مَا دَامَ فِی الْمَسْجِدِ حَتَّی یَخْرُجَ مِنْہُ۔ (احمد 3/54)",,,4859
4860,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنْ یَزِیدَ بْنِ خُصَیْفَۃَ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : إذَا کَانَ أَحَدُکُمْ فِی الْمَسْجِدِ ، فَلاَ یُشَبِّکَنَّ أَصَابِعَہُ۔",,,4860
4861,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ سَعْدِ بْنِ إِسْحَاقَ ، عَنْ سَعِیدِ بْنِ أَبِی سعید ، عن أبی ثُمَامَۃَ الْقَمَّاحِ ، قَالَ: لَقِیت کَعْبًا وَأَنَا بِالْبَلاَطِ قَدْ أَدْخَلْت بَعْضَ أَصَابِعِی فِی بَعْضٍ ، فَضَرَبَ یَدِی ضَرْبًا شَدِیدًا ، وَقَالَ : نُہِینَا أَنْ نُشَبِّکَ بَیْنَ أَصَابِعِنا فِی الصَّلاَۃ ، قَالَ : قُلْتُ لَہُ : یَرْحَمُک اللَّہُ تَرَانِی فِی صَلاَۃٍ ؟ فَقَالَ : مَنْ تَوَضَّأَ فَعَمَدَ إلَی الْمَسْجِدِ ، فَہُوَ فِی صَلاَۃٍ۔ (ابوداؤد 563۔ احمد 4/241)",,,4861
4862,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ ابْنِ عَجْلاَنَ ، عَنِ النُّعْمَانِ بْنُ أَبِی عَیَّاشٍ ، قَالَ : کَانُوا یَنْہَوْنَ عَنْ تَشْبِیکِ الأَصَابِعِ ، یَعْنِی فِی الصَّلاَۃ۔",,,4862
4863,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ مُحِلٍّ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَرِہَ أَنْ یُشَبِّکَ أَصَابِعَہُ فِی الصَّلاَۃ۔,,,4863
4864,"حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ خَلِیفَۃَ بْنِ غَالِبٍ ، عَنْ نَافِعٍ ، قَالَ : رَأَیْتُ ابْنَ عُمَرَ یُشَبِّکُ بَیْنَ أَصَابِعِہِ فِی الصَّلاَۃ۔",,,4864
4865,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَصْحَابُنَا ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یُشَبِّکُ بَیْنَ أَصَابِعِہِ فِی الْمَسْجِدِ۔",,,4865
4866,"حَدَّثَنَا عَفَّانُ ، قَالَ : حدَّثَنَا وُہَیْبٌ ، عَنْ إسْمَاعِیلَ بْنِ أُمَیَّۃَ ، قَالَ : رَأَیْتُ سَالِمَ بْنَ عَبْدِ اللہِ یُشَبِّکُ بَیْنَ أَصَابِعِہِ فِی الصَّلاَۃ۔",,,4866
4867,"حَدَّثَنَا شَرِیکٌ ، عَنْ جَابِرٍ ، عَنِ الْحَکَمِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا أَرَادَ أَنْ یَقُولَ سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، فَقَالَ : اللَّہُ أَکْبَرُ ، قَالَ : یَسْتَغْفِرُ اللَّہُ۔",,,4867
4868,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنِ الأَعْمَشِ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا أَرَادَ أَنْ یَقُولَ سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، فَقَالَ : اللَّہُ أَکْبَرُ ، فَلاَ سَہْوَ عَلَیْہِ۔",,,4868
4869,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، وَغَیْرِہِ ؛ فِی رَجُلٍ أَرَادَ أَنْ یَقُولَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، فَقَالَ : اللَّہُ أَکْبَرُ ، قَالُوا : لَیْسَ عَلَیْہِ سَہْوٌ۔",,,4869
4870,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ مُحَمَّدِ بْنِ عَلِیٍّ ، وَعَامِرٍ ، وَعَطَائٍ ، قَالُوا : فِی رَجُلٍ أَرَادَ أَنْ یَقُولَ : سَمِعَ اللَّہُ لِمَنْ حَمِدَہُ ، فَقَالَ : اللَّہُ أَکْبَرُ ، قَالُوا : لَیْسَ عَلَیْہِ سَہْوٌ۔",,,4870
4871,"حَدَّثَنَا وَکِیعٌ ، عَنْ شُعْبَۃَ ، قَالَ : سَأَلْتُ الْحَکَمَ عْن رَجُلٍ نَسِیَ تَکْبِیرَۃً ؟ قَالَ : یَسْجُدُ سَجْدَتَیِ السَّہْوِ۔",,,4871
4872,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، عَنِ الْحَسَنِ ؛ فِی رَجُلٍ صَلَّی الْمَغْرِبَ أَرْبَعًا ، قَالَ : یَسْجُدُ سَجْدَتَیِ السَّہْوِ۔",,,4872
4873,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : یُعِیدُ۔",,,4873
4874,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، قَالَ : إذَا لَمْ یَجْلِسْ فِی الثَّالِثَۃِ أَعَادَ۔",,,4874
4875,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَمْرٍو ، عَنْ عَطَائِ بْنِ یَسَارٍ ، سَمِعَ أَبَا ہُرَیْرَۃَ یَقُولُ : إذَا أُقِیمَتِ الصَّلاَۃ فَلاَ صَلاَۃَ إِلاَّ الْمَکْتُوبَۃُ۔ (مسلم 493۔ ابوداؤد 1260)",,,4875
4876,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، عَنْ عَمْرٍو ، عَنْ عَطَائِ بْنِ یَسَارٍ ، عَنْ أَبِی ہُرَیْرَۃَ ، قَالَ : إذَا أُقِیمَتِ الصَّلاَۃ فَلاَ صَلاَۃَ إِلاَّ الْمَکْتُوبَۃُ۔ (مسلم 493۔ ابوداؤد 1260)",,,4876
4877,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنِ الْحَسَنِ بْنِ عَمْرٍو ، عَنْ فُضَیْلٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ رَأَی رَجُلاً یُصَلِّی عِنْدَ إقَامَۃِ الْعَصْرِ ، قَالَ : یَسُرُّک أَنْ یُقَالَ : صَلَّی ابْنُ فُلاَنَۃَ سِتًّا ، قَالَ : فَذَکَرْت ذَلِکَ لإِبْرَاہِیمَ ، فَقَالَ : کَانَتْ تُکْرَہُ الصَّلاَۃ مَعَ الإِقَامَۃِ۔",,,4877
4878,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مَنْصُورٍ ، عَنْ فُضَیْلِ بْنِ عَمْرٍو ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانُوا یَکْرَہُونَ الصَّلاَۃ إذَا أَخَذَ الْمُؤَذِّنُ فِی الإِقَامَۃِ۔",,,4878
4879,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ مَیْمُونٍ ، قَالَ : إذَا کَبَّرَ الْمُؤَذِّنُ بِالإِقَامَۃِ فَلاَ تُصَلِّیَنَّ شَیْئًا حَتَّی تُصَلِّیَ الْمَکْتُوبَۃَ۔",,,4879
4880,"حَدَّثَنَا عَبْدُ السَّلاَمِ بْنُ حَرْبٍ ، عَنِ ابْنِ أَبِی فَرْوَۃَ ، عَنْ أَبِی بَکْرِ بْنِ الْمُنْکَدِرِ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّ عُمَرَ رَأَی رَجُلاً یُصَلِّی رَکْعَتَیْنِ وَالْمُؤَذِّنُ یُقِیمُ فَانْتَہَرَہُ ، وَقَالَ : لاَ صَلاَۃَ وَالْمُؤَذِّنُ یُقِیمُ إِلاَّ الصَّلاَۃ الَّتِی تُقَامُ لَہَا الصَّلاَۃ۔",,,4880
4881,"حَدَّثَنَا عُبَیْدُ اللہِ بْنُ مُوسَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ عَطَائٍ ، قَالَ : إذَا کُنْتَ فِی الْمَسْجِدِ فَأُقِیمَتِ الصَّلاَۃ فَلاَ تَرْکَعْ۔",,,4881
4882,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، أَنَّہُ قَالَ فِی الرَّجُلِ یُصَلِّی فِی الْمَسْجِدِ رَکْعَتَیْنِ مِنَ الْفَرِیضَۃِ وَحْدَہُ ، ثُمَّ تُقَامُ الصَّلاَۃ ، قَالَ : یُصَلِّی مَعَہُمْ وَلاَ یَعْتَدُّ بِہَا۔",,,4882
4883,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا سَیَّارٌ ، وَالْمُغِیرَۃُ ، عَنِ الشَّعْبِیِّ (ح) وَأَخْبَرَنَا یُونُسُ ، وَمَنْصُورٌ ، عَنِ الْحَسَنِ (ح) وَحَجَّاجٌ ، عَنْ عَطَائٍ (ح) وَشُعْبَۃُ ، عَنِ الْحَکَمِ ، قَالُوا : یُسَلِّمُ ثُمَّ یَدْخُلُ مَعَ الإِمَامِ فِی صَلاَتِہِ۔",,,4883
4884,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مِسْعَرٍ ، قَالَ : أَظُنُّہُ ، عَنْ عُتْبَۃَ بْنِ قَیْسٍ ، عَنْ عَبْدِ اللہِ بْنِ عُتْبَۃَ ، قَالَ : یَقْطَعُہا ثُمَّ یَدْخُلُ مَعَہُمْ۔",,,4884
4885,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ مِسْعَرٍ ، قَالَ : سَمِعْتُ حَمَّادًا یَقُولُ : أَحَبُّ إلَیَّ أَنْ یَتَکَلَّمَ وَیَدْخُلَ مَعَہُمْ فِی الصَّلاَۃ۔",,,4885
4886,"حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ إسْمَاعِیلَ بْنِ أَبِی خَالِدٍ ، قَالَ : سَمِعْتُ الشَّعْبِیَّ یَقُولُ : إذَا دَخَلَ الرَّجُلُ فِی الْفَرِیضَۃِ ، ثُمَّ فَجِئَتْہُ الإِقَامَۃُ قَطَعَہَا ، وَکَانَتْ لَہُ نَافِلَۃً وَدَخَلَ فِی الْفَرِیضَۃِ۔",,,4886
4887,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ فِی الرَّجُلِ یَأْتِی الْمَسْجِدَ فَیری أَنَّہُمْ صَلَّوْا ، فَافْتَرَضَ الصَّلاَۃ فَصَلَّی رَکْعَتَیْنِ مِنَ الْمَکْتُوبَۃِ فَأُقِیمَتِ الصَّلاَۃ ، قَالَ : یَدْخُلُ مَعَ الإِمَامِ فِی صَلاَتِہِ ، فَإِذَا صَلَّی مَعَ الإِمَامِ رَکْعَتَیْنِ ، ثُمَّ یُسَلِّم ، ثُمَّ یَجْعَلُ الرَّکْعَتَیْنِ الأُخْرَیَیْنِ مَعَ الإِمَامِ تَطَوُّعًا۔",,,4887
4888,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ شُعْبَۃَ ، عَنْ حَمَّادٍ ، أَنَّہُ قَالَ : کَمَا قَالَ إبْرَاہِیمُ۔",,,4888
4889,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ مُغِیرَۃَ ، عَنِ الشَّعْبِیِّ ، قَالَ : إذَا کَانَ الرَّجُلُ قَائِمًا یُصَلِّی فَسَمِع الإِقَامَۃَ فَلْیَقْطَعْ ۔ وَقَالَ إبْرَاہِیمُ : یُضِیفُ إلَیْہَا أُخْرَی وَلاَ یَقْطَعُ۔",,,4889
4890,"حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مَنْصُورٍ ، عَنْ فُضَیْلِ بْنِ عَمْرٍو ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یَقُولُ : إِنْ بَقِیَ عَلَیْک مِنْ صَلاَتِکَ شَیْئٌ فَأَتْمِمْہُ ۔ وَکَانَ سَعِیدُ بْنُ جُبَیْرٍ یَقُولُ : اقْطَعْہَا۔",,,4890
4891,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنِ الْحَسَنِ بْنِ عُبَیْدِ اللہِ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا افْتَتَحْت الصَّلاَۃ تَطَوُّعًا وَأُقِیمَتِ الصَّلاَۃ فَأَتِمَّ۔",,,4891
4892,"حَدَّثَنَا یَحْیَی بْنُ آدَمَ ، قَالَ : حدَّثَنَا زُہَیْرٌ ، قَالَ : حَدَّثَنَا أَبُو إِسْحَاقَ ، قَالَ : کُنْتُ إلَی جَنْبِ عَبْدِ اللہِ بْنِ معقل ، وَہُوَ یُصَلِّی وَیَقْرَأُ فِی سُورَۃِ النُّورِ ، فَأَقَامَ الْمُؤَذِّنُ فَرَکَعَ وَسَجَدَ ، وَجَلَسَ فَتَشَہَّدَ ، ثُمَّ قَامَ مَعَ الإِمَامِ فَأَخَذَ مِنْ حَیْثُ انْتَہَی۔",,,4892
4893,"حَدَّثَنَا ابْنُ آدَمَ ، عَنْ إسْرَائِیلَ ، عَنْ بَیَانَ ، قَالَ : کَانَ قَیْسُ بْنُ أَبِی حَازِمٍ یَؤُمَّنَا ، فَأَقَامَ الْمُؤَذِّنُ الصَّلاَۃ وَقَدْ صَلَّی رَکْعَۃً ، قَالَ : فَتَرَکَہَا ، ثُمَّ تَقَدَّمَ فَصَلَّی بِنَا۔",,,4893
4894,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ ، عَنْ جَعْفَرٍ ، عَنْ مَیْمُونٍ ، قَالَ : إِنْ کَبَّرْت بِالصَّلاَۃ تَطَوُّعًا قَبْلَ أَنْ یُکَبِّرَ بِالإِقَامَۃِ، فَصَلِّ رَکْعَتَیْنِ۔",,,4894
4895,"حَدَّثَنَا عُبَیْدُ اللہِ ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، عَنْ عَطَائٍ ، قَالَ : إذَا کُنْتَ فِی الْمَسْجِدِ فَأُقِیمَتِ الصَّلاَۃ فَلاَ تَرْکَعْ ، إِلاَّ أَنْ تَکُونَ عَلَی وِتْرٍ فَتَشْفَع۔",,,4895
4896,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنْ حُمَیْدٍ ، عَنْ بَکْرٍ ، قَالَ : کَتَبْت إلَی عُمَرَ مِنْ نَجْرَانَ : لَمْ یَجِدُوا مَکَانًا أَنْظَفَ ، وَلاَ أَجْوَدَ مِنْ بَیْعَۃٍ ؟ فَکَتَبَ : انْضَحُوہَا بِمَائٍ وَسِدْرٍ وَصَلُّوا فِیہَا۔",,,4896
4897,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ (ح) وَعَنْ یُونُسَ ، عَنِ الْحَسَنِ (ح) وَعَنْ حُصَیْنٍ ، عَنِ الشَّعْبِیِّ ، أَنَّہُمْ قَالُوا : لاَ بَأْسَ بِالصَّلاَۃ فِی الْبِیَعِ۔",,,4897
4898,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنْ حَجَّاجٍ ، قَالَ : سَأَلْتُ عَطَائً عَنِ الصَّلاَۃ فِی الْکَنَائِسِ وَالْبِیَعِ ؟ فَلَمْ یَرَ بِہَا بَأْسًا۔",,,4898
4899,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إِبْرَاہِیمَ (ح) وَعَن جَابِرٍ ، عَنِ الشَّعْبِیِّ ، قَالاَ : لاَ بَأْسَ بِالصَّلاَۃ فِی الْکَنِیسَۃِ وَالْبِیعَۃِ۔",,,4899
4900,"حَدَّثَنَا غُنْدَرٌ ، عَنْ أَشْعَثَ ، عَنْ مُحَمَّدٍ ، قَالَ : لاَ بَأْسَ بِالصَّلاَۃ فِی الْکَنِیسَۃِ۔",,,4900
4901,حَدَّثَنَا مُحَمَّدُ بْنِ أَبِی عَدِیٍّ ، عَنْ أَشْعَثَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَرِہَہُ ، وَأَنَّ مُحَمَّدًا لَمْ یَرَ بِہِ بَأْسًا۔,,,4901
4902,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خُصَیْفٍ ، عَنْ مِقْسَمٍ ، عَنِ ابْنِ عَبَّاسٍ ؛ أَنَّہُ کَرِہَ الصَّلاَۃ فِی الْکَنِیسَۃِ إذَا کَانَ فِیہَا تَصَاوِیرُ۔,,,4902
4903,"حَدَّثَنَا وَکِیعٌ ، عَنْ عُثْمَانَ بْنِ أَبِی ہِنْدٍ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَؤُمُّ النَّاسَ فَوْقَ کَنِیسَۃٍ ، وَالنَّاسُ أَسْفَلُ مِنْہُ۔",,,4903
4904,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ رَافِعٍ ، قَالَ : رَأَیْتُ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ یَؤُمُّ النَّاسَ فِی کَنِیسَۃٍ بِالشَّامِ۔",,,4904
4905,"حَدَّثَنَا مُلاَزِمُ بْنُ عَمْرٍو ، عَنْ عَبْدِ اللہِ بْنِ بَدْرٍ ، عَنْ قَیْسِ بْنِ طَلْقٍ ، عَنْ أَبِیہِ طَلْقِ بْنِ عَلِیٍّ ، قَالَ : خَرَجْنَا وَفْدًا إلَی النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَخْبَرْنَاہُ أَنَّ بِأَرْضِنَا بِیَعَۃً لَنَا ، فَاسْتَوْہَبْنَاہُ فَضْلَ طَہُورِہِ ، فَدَعَا بِمَائٍ فَتَوَضَّأَ ثُمَّ تَمَضْمَضَ ، ثُمَّ جَعَلَہُ لَنَا فِی إدَاوَۃٍ ، فَقَالَ : اخْرُجُوا بِہِ مَعَکُمْ ، فَإِذَا قَدِمْتُمْ بَلَدَکُمْ فَاکْسِرُوا بِیَعَتَکُمْ ، وَانْضَحُوا مَکَانَہَا بِالْمَائِ ، وَاتَّخِذُوہَا مَسْجِدًا۔ (احمد 4/23۔ ابن حبان 1602)",,,4905
4906,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا أَبُو فَضَالَۃَ ، قَالَ : حَدَّثَنَا أَزْہَرُ الحَرَازی ؛ أَنَّ أَبَا مُوسَی صَلَّی فِی کَنِیسَۃٍ بِدِمَشْقَ ، یُقَالُ لَہَا : کَنِیسَۃُ یُحَنَّا۔",,,4906
4907,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَعْتَمِدَ الرَّجُلُ عَلَی الْحَائِطِ فِی صَلاَۃ الْمَکْتُوبَۃِ ، إِلاَّ مِنْ عِلَّۃٍ ، وَلَمْ یَرَ بِہِ فِی التَّطَوُّعِ بَأْسًا۔,,,4907
4908,حَدَّثَنَا أَبُو الأَحْوَصِ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ کَانَ یَکْرَہُ أَنْ یَتَسَانَدَ الرَّجُلُ عَلَی الْحَائِطِ فِی الصَّلاَۃ ، وَکَانَ یَکْرَہُ رَفْعَ رِجْلَیْہِ إِلاَّ مِنْ عِلَّۃٍ۔,,,4908
4909,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : کَانَ یَکْرَہُ أَنْ یَرْفَعَ إحْدَی رِجْلَیْہِ عَلَی الأُخْرَی فِی الصَّلاَۃ ، وَیُسند إلَی جِدَارٍ إِلاَّ مِنْ عِلَّۃٍ۔",,,4909
4910,"حَدَّثَنَا جَرِیرٌ ، عَنْ لَیْثٍ ، عَنْ حَمَّادٍ ، عَنْ مُجَاہِدٍ ، قَالَ : یَنْقُصُ مِنْ أَجْرِہِ بِقَدْرِ ذَلِکَ۔",,,4910
4911,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ لَیْثٍ ، عَنْ حَمَّادٍ ، عَنْ مُجَاہِدٍ ؛ فِی الرَّجُلِ یُصَلِّی فَیَتَوَکَّأُ عَلَی الْحَائِطِ ، قَالَ : یَنْقُصُ مِنْ صَلاَتِہِ بِقَدْرِ ذَلِکَ۔",,,4911
4912,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْرَائِیلَ ، عَنْ جَابِرٍ ، عَنْ عَامِرٍ ، قَالَ : لاَ بَأْسَ أَنْ یَعْتَمِدَ عَلَی الْحَائِطِ۔",,,4912
4913,حَدَّثَنَا إِسْحَاقُ الأَزْرَقُ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَرِہَ أَنْ یَعْتَمِدَ الرَّجُلُ عَلَی شَیْئٍ فِی الْفَرِیضَۃِ إِلاَّ مِنْ عِلَّۃٍ ، وَکَانَ لاَ یَرَی بِہِ بَأْسًا فِی التَّطَوُّعِ ۔ وَکَانَ ابْنُ سِیرِینَ یَکْرَہُ فِی الْفَرِیضَۃِ وَالتَّطَوُّعِ۔,,,4913
4914,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنِ الْمُطْعِمِ بْنِ الْمِقْدَامِ ، قَالَ : قَالَ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : مَا خَلَفَ عَبْدٌ عَلَی أَہْلِہِ أَفْضَلَ مِنْ رَکْعَتَیْنِ یَرْکَعُہُمَا عِنْدَہُمْ حِینَ یُرِیدُ سَفَرًا۔",,,4914
4915,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا خَرَجْت فَصَلِّ رَکْعَتَیْنِ۔",,,4915
4916,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ عُبَیْدِ اللہِ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إذَا أَرَادَ أَنْ یَخْرُجَ دَخَلَ الْمَسْجِدَ فَصَلَّی۔,,,4916
4917,"حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ زُہَیْرٍ ، عَنْ أَبِی إِسْحَاقَ ، قَالَ : رَأَیْتُ الْحَارِثَ بْنَ أَبِی رَبِیعَۃَ صَلَّی حِینَ أَرَادَ أَنْ یَخْرُجَ إلَی بَاجُمَیْرا فِی الْحُجْرَۃِ ضُحًی رَکْعَتَیْنِ ، وَصَلَّی مَعَہُ نَفَرٌ مِنْہُمَ الأَسْوَدُ بْنُ یَزِیدَ۔",,,4917
4918,"حَدَّثَنَا وَکِیعٌ ، عَنْ أُسَامَۃَ بْنِ زَیْدٍ ، عَنْ مُعَاذِ بْنِ عَبْدِ اللہِ بْنِ خبیب ، عَنْ جَابِرٍ ، قَالَ : لَمَّا قَدِمْنَا مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ لِی : یَا جَابِرُ ، ہَلْ صَلَّیْت ؟ قُلْتُ : لاَ ، قَالَ : فَصَلِّ رَکْعَتَیْنِ۔",,,4918
4919,حَدَّثَنَا وَکِیعٌ ، عَنْ کَامِلٍ أَبِی الْعَلاَئِ ، عَنْ أَبِی صَالِحٍ ؛ أَنَّ عُثْمَانَ کَانَ إذَا قَدِمَ مِنْ سَفَرٍ صَلَّی رَکْعَتَیْنِ۔,,,4919
4920,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ أَبِی إِسْحَاقَ ، عَنِ الْحَارِثِ ، عَنْ عَلِیٍّ ، قَالَ : إذَا قَدِمْت فَصَلِّ رَکْعَتَیْنِ۔",,,4920
4921,"حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنْ مُقَاتِلِ بْنِ بَشِیرٍ الْعِجْلِیّ ، عَنْ رَجُلٍ یُقَالُ لَہُ : مُوسَی ؛ أَنَّ ابْنَ عَبَّاسٍ قَدِمَ مِنْ سَفَرٍ ، فَصَلَّی فِی بَیْتِہِ رَکْعَتَیْنِ عَلَی طِنْفِسَۃٍ۔",,,4921
4922,حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنِ ابْنِ جُرَیْجٍ ، عَنِ الزُّہْرِیِّ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ کَعْبِ بْنِ مَالِکٍ ، عَنْ أَبِیہِ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ کَانَ لاَ یَقْدَمُ مِنْ سَفَرٍ إِلاَّ نَہَارًا فِی الضُّحَی ، فَإِذَا قَدِمَ بَدَأَ بِالْمَسْجِدِ فَصَلَّی رَکْعَتَیْنِ۔ (بخاری 3088۔ مسلم 496),,,4922
4923,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ تَمِیمِ بْنِ سَلَمَۃَ ، عَنْ مَسْرُوقٍ ، قَالَ : کَانَ النَّبِیُّ علیہ الصَّلاَۃ والسلام فِی سَفَرٍ ، فَعَرَّسَ بِأَصْحَابِہِ ، فَلَمْ یُوقِظْہُمْ مَعَ تَعْرِیسِہِمْ إِلاَّ الشَّمْسُ ، فَقَامَ فَأَمَرَ الْمُؤَذِّنَ ، فأذن وَأَقَامَ ، ثُمَّ صَلَّی ، فَقَالَ مَسْرُوقٌ : مَا أُحِبُّ أَنَّ لَنَا الدُّنْیَا ، وَمَا فِیہَا بِصَلاَۃِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ بَعْدَ طُلُوعِ الشَّمْسِ۔",,,4923
4924,حَدَّثَنَا عَبیدۃ بْنُ حُمَیْدٍ ، عَنْ یَزِیدَ بْنِ أَبِی زِیَادٍ ، عَنْ تَمِیمِ بْنِ سَلَمَۃَ ، عَنْ مَسْرُوقٍ ، عَنِ ابْنِ عَبَّاسٍ ، عَنِ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ؛ مِثْلَہُ۔ (احمد 1/259۔ ابو یعلی 2375),,,4924
4925,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ سَعْدِ بْنِ إِبْرَاہِیمَ ، عَن عَطَائِ بْنِ یَسَارٍ ، قَالَ : صَلَّی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَکْعَتَیِ الْفَجْرِ بَعْدَ مَا جَازَ الْوَادِیَ ، ثُمَّ أَمَرَ بِلاَلاً فَأَذَّنَ وَأَقَامَ ، ثُمَّ صَلَّی الْفَرِیضَۃَ۔",,,4925
4926,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، قَالَ : أَخْبَرَنَا ہِشَامٌ ، عَنِ الْحَسَنِ ، قَالَ : یُجْزِئُ الرَّجُلَ أَنْ یَقْضِیَ الصَّلواتِ بِإِقَامَۃٍ وَاحِدَۃٍ۔",,,4926
4927,"حَدَّثَنَا حُسَیْنُ بْنُ عَلِیٍّ ، عَنْ زَائِدَۃَ ، عَنْ سِمَاکٍ ، عَنِ الْقَاسِمِ بْنِ عَبْدِ الرَّحْمَنِ ، عَنْ أَبِیہِ ، عَنْ عَبْدِ اللہِ ، قَالَ : سَرَیْنَا ذَاتَ لَیْلَۃٍ مَعَ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ ، قَالَ : فَقُلْنَا : یَا رَسُولَ اللہِ ، لَوْ أمسستنا الأَرْضَ فَنِمْنَا وَرَعَتْ رِکَابُنَا ؟ قَالَ : فَمَنْ یَحْرُسُنَا ؟ قَالَ : قُلْتُ : أَنَا ، قَالَ : فَغَلَبَتْنِی عَیْنِی ، فَلَمْ یُوقِظْنَا إِلاَّ وَقْتَ طَلَعَتِ الشَّمْسُ ، وَلَمْ یَسْتَیْقِظْ رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ إِلاَّ بِکَلاَمِنَا ، قَالَ : فَأَمَرَ بِلاَلاً فَأَذَّنَ وَأَقَامَ ، فَصَلَّی بِنَا۔ (احمد 1/450۔ طبرانی 10349)",,,4927
4928,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا مُغِیرَۃُ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ لَمْ یَکُنْ یَرَی بِعَدَدِ الآیِ فِی الصَّلاَۃ بَأْسًا۔",,,4928
4929,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ مِثْلَہُ۔,,,4929
4930,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الشَّیْبَانِیِّ ، عَنْ یُسیر بْنِ عَمْرٍو ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِعَدَدِ الآیِ فِی الصَّلاَۃ۔,,,4930
4931,حَدَّثَنَا عَبْدَۃُ ، وَوَکِیعٌ ، عَنْ ہِشَامٍ ؛ أَنَّ أَبَاہُ کَانَ یَعُدُّ الآیَ فِی الصَّلاَۃِ۔,,,4931
4932,"حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنِ الأَعْمَشِ ، قَالَ : کَانَ یَحْیَی بْنُ وَثَّابٍ یَعُدُّ الآیَ فِی الصَّلاَۃ۔",,,4932
4933,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ أَیُّوبَ ، قَالَ : رَأَیْتُ طَاوُوسًا وَنَافِعًا یَعُدَّانِ الآیَ فِی الصَّلاَۃ۔",,,4933
4934,حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ خَالِدٍ ، عَنِ ابْنِ سِیرِینَ ؛ أَنَّہُ کَانَ یَعُدُّ الآیَ بِشِمَالِہِ فِی الصَّلاَۃ۔,,,4934
4935,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ مَنْصُورٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : لاَ بَأْسَ بِعَدِّ الآیِ فِی الصَّلاَۃ۔",,,4935
4936,حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ یَحْیَی بْنِ عَتِیقٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ؛ أَنَّہُ کَانَ یَعُدُّ الآیَ فِی الصَّلاَۃ۔,,,4936
4937,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ عَطَائِ بْنِ السَّائِبِ ، قَالَ : رَأَیْتُ أَبَا عَبْدِ الرَّحْمَنِ یَعُدُّ الآیَ فِی الصَّلاَۃ۔",,,4937
4938,"حَدَّثَنَا وَکِیعٌ ، عَنْ إسْمَاعِیلَ بْنِ عَبْدِ الْمَلِکِ ، قَالَ : رَأَیْتُ ابْنَ أَبِی مُلَیْکَۃَ یَعُدُّ الآیَ فِی الصَّلاَۃ ، فَقُلْتُ لَہُ ؟ فَقَالَ : إِنَّہُ أَحْفَظُ۔",,,4938
4939,"حَدَّثَنَا وَکِیعٌ ، عَنْ حَمَّادِ بْنِ زَیْدٍ ، عَنْ یَحْیَی بْنِ عَتِیقٍ ، قَالَ : رَأَیْتُ طَاوُوسًا وَالْمُغِیرَۃَ بْنَ حَکِیمٍ الصَّنْعَانِیَّ یَعُدَّانِ الآیَ فِی الصَّلاَۃ۔",,,4939
4940,"حَدَّثَنَا أَبُو أَیُّوبَ الْقُریعِیُّ ، قَالَ : رَأَیْتُ عِمْرَانَ بْنَ حُدَیْرٍ یَعُدُّ الآیَ فِی الصَّلاَۃ ، وَذَکَرَ أَنَّ أَبَا مِجْلَزٍ کَانَ لاَ یَرَی بِذَلِکَ بَأْسًا۔",,,4940
4941,"حَدَّثَنَا حَفْصٌ ، عَنْ عَمْرٍو ، عَنِ الْحَسَنِ ، قَالَ : لاَ بَأْسَ أَنْ یَعُدَّ الآیِ فِی الصَّلاَۃ إذَا خَافَ النِّسْیَانَ۔",,,4941
4942,"حَدَّثَنَا وَکِیعٌ ، عَنْ رَبِیعٍ ، قَالَ : رَأَیْتُ ابْنَ سِیرِینَ یَعُدُّ الآیَ فِی الْعَصْرِ۔",,,4942
4943,"حَدَّثَنَا وَکِیعٌ ، عَنْ حُرَیْثٍ ، عَنِ الشَّعْبِیِّ ، قَالَ : لاَ بَأْسَ بِعَدِّ الآیِ فِی الْفَرِیضَۃِ۔",,,4943
4944,"حَدَّثَنَا یَحْیَی بْنُ بَشِیرٍ الْجَزَرِیُّ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ، قَالَ : لاَ بَأْسَ بِعَدِّ الآیِ فِی الصَّلاَۃ۔",,,4944
4945,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ نَافِعِ بْنِ عُمَرَ ، قَالَ : رَأَیْتُ ابْنَ أَبِی مُلَیْکَۃَ یَعُدُّ الآیَ فِی الصَّلاَۃ ، قَالَ : وَقَالَ یَحْیَی بْنُ عَبْدِ اللہِ بْنِ صَیْفِیٍّ : ہُوَ رَأْسُ الْعِبَادَۃِ۔",,,4945
4946,"حَدَّثَنَا عُمَرُ بْنُ أَیُّوبَ الْمَوْصِلِیُّ ، عَنْ جَعْفَرِ بْنِ بُرْقَانَ ، عَنْ حَبِیبِ بْنِ أَبِی مَرْزُوقٍ ، عَنْ عَمْرِو بْنِ مَیْمُونٍ ، قَالَ : سَأَلَہُ عُمَرُ بْنُ عَبْدِ الْعَزِیزِ ، تَعُدُّ الآیَ فِی الصَّلاَۃ ؟ فَقَالَ : مَا أَفْعَلُ ، قَالَ : وَأَنَا أَیْضًا مَا أَفْعَلُ۔",,,4946
4947,"حَدَّثَنَا صَفْوَانُ بْنُ عِیسَی ، عَنِ الْحَارِثِ بن عَبْدِ الرَّحْمَنِ ، قَالَ : سَأَلْتُ سُلَیْمَانَ بْنَ یَسَارٍ عَنِ النَّوْمِ فِی الْمَسْجِدِ ؟ فَقَالَ : کَیْفَ تَسْأَلُونَ عَنْ ہَذَا ، وَقَدْ کَانَ أَہْلُ الصِّفَۃِ یَنَامُونَ فِیہِ وَیُصَلُّونَ فِیہِ۔",,,4947
4948,"حَدَّثَنَا الثَّقَفِیُّ ، عَنْ یُونُسَ ، قَالَ : رَأَیْتُ ابْنَ سِیرِینَ یَنَامُ فِی الْمَسْجِدِ۔",,,4948
4949,"حَدَّثَنَا ابْنُ إدْرِیسَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ، قَالَ : کَانَ لَہُ مَسْجِدٌ یُصَلِّی فِیہِ ، وَیَنَامُ فِیہِ۔",,,4949
4950,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ، قَالَ : کُنَّا وَنَحْنُ شَبَابٌ نَبِیتُ فِی عَہْدِ رَسُولِ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فِی الْمَسْجِدِ وَنَقِیلُ۔ (ترمذی 321۔ احمد 2/12)",,,4950
4951,"حَدَّثَنَا جَرِیرٌ ، عَنْ یَزِیدَ ، عَنْ عَطَائٍ ، قَالَ : قَالَ رَجُلٌ لْاِبْنِ عَبَّاسٍ : إنِّی نِمْتُ فِی الْمَسْجِدِ الْحَرَامِ فَاحْتَلَمْت ، فَقَالَ : أَمَّا أَنْ تَتَّخِذَہُ مَبِیتًا ، أَوْ مَقِیلاً فَلاَ ، وَأَمَّا أَنْ تَنَامَ تَسْتَرِیحَ ، أَوْ تَنْتَظِرَ حَاجَۃً فَلاَ بَأْسَ۔",,,4951
4952,حَدَّثَنَا أَسْبَاطُ بْنُ مُحَمَّدٍ، عَنْ لَیْثٍ، عَنْ عَطَائٍ، وَطَاوُوس، وَمُجَاہِدٍ؛ أَنَّہُمْ کَرِہُوا النَّوْمَ فِی الْمَسْجِدِ۔,,,4952
4953,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ ابْنِ جُرَیْجٍ ، قَالَ : قُلْتُ لِعَطَائٍ : أَتَکْرَہُ النَّوْمَ فِی الْمَسْجِدِ؟ قَالَ: بَلْ أُحِبُّہُ۔",,,4953
4954,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ أَبِی الْہَیْثُمِ ، قَالَ : نَہَانِی مُجَاہِدٌ عَنِ النَّوْمِ فِی الْمَسَاجِدِ۔",,,4954
4955,"حَدَّثَنَا وَکِیعٌ ، عَنْ أَیْمَنِ بْنِ نَابِلٍ ، قَالَ : رَآنِی سَعِیدُ بْنُ جُبَیْرٍ وَأَنَا نَائِمٌ فِی الْحِجْرِ فَأَیْقَظَنِی ، وَقَالَ : مِثْلُک یَنَامُ ہَاہُنَا ؟۔",,,4955
4956,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا إسْمَاعِیلُ بْنُ أَبِی خَالِدٍ ، عَنْ أَبِی عَمْرٍو الشَّیْبَانِیِّ ، قَالَ : رَأَیْتُ ابْنَ مَسْعُودٍ یَعُسُّ فِی الْمَسْجِدِ لَیْلاً ، فَلاَ یَدَعُ سَوَادًا إِلاَّ أَخْرَجَہُ ، إِلاَّ رَجُلاً یُصَلِّی۔",,,4956
4957,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا مُغِیرَۃُ بْنُ زِیَادٍ ، قَالَ : کُنْتُ أَنام فِی الْمَسْجِدِ الْحَرَامِ ، فَأَحْتَلِمُ فِی اللَّیْلَۃ مِرَارًا ، فَسَأَلْت عَطَائً ؟ فَقَالَ : نَمْ وَإِنِ احْتَلَمْتَ عَشْرَ مَرَّاتٍ۔",,,4957
4958,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنْ إسْمَاعِیلَ بْنِ أمیۃ ، عَنِ الْمُغِیرَۃِ بْنِ حَکِیمٍ ، عَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ؛ أَنَّہُ سُئِلَ عَنِ النَّوْمِ فِی الْمَسْجِدِ ؟ فَقَالَ : أَیْنَ کَانَ أَہْلُ الصُّفَّۃِ ؟ یَعْنِی یَنَامُونَ فِیہِ۔",,,4958
4959,"حَدَّثَنَا وَکِیعٌ ، قَالَ : حدَّثَنَا سُفْیَانُ ، عَنِ ابْنِ أَبِی نَجِیحٍ ، قَالَ نِمْتُ فِی الْمَسْجِدِ الْحَرَامِ فَاحْتَلَمْتُ فِیہِ، فَسَأَلْت سَعِیدَ بْنَ جُبَیْرٍ ؟ فَقَالَ : اذْہَبْ وَاغْتَسِلْ ، یَعْنِی ، وَلَمْ یَنْہَہُ۔",,,4959
4960,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا أَبُو بِشْرٍ ، عَنْ سَعِیدِ بْنِ جُبَیْرٍ ، عَنِ ابْنِ عَبَّاسٍ ، قَالَ بِتُّ ذَاتَ لَیْلَۃٍ عِنْدَ مَیْمُونَۃَ بِنْتِ الْحَارِثِ ، فَقَامَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یُصَلِّی مِنَ اللَّیْلِ ، فَقُمْتُ عَنْ یَسَارِہِ فَأَخَذَ بِذُؤَابَۃٍ کَانَتْ لِی ، أَوْ بِرَأْسِی فَأَقَامَنِی عَنْ یَمِینِہِ۔ (بخاری 117۔ احمد 1/215)",,,4960
4961,"حَدَّثَنَا غُنْدَرٌ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْمُخْتَارِ ، عَنْ مُوسَی بْنِ أَنَسٍ ، عَنْ أَنَسٍ ، قَالَ : أَتَیْتُ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ وَہُوَ یُصَلِّی فَأَقَامَنِی عَنْ یَمِینِہِ۔ (مسلم 269۔ احمد 3/194)",,,4961
4962,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ شُرَحْبِیلَ ، عَنْ جَابِرٍ ، قَالَ : صَلَّیْت مَعَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَأَقَامَنِی عَنْ یَمِینِہِ۔ (ابن ماجہ 973۔ احمد 3/326)",,,4962
4963,"حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنْ أَبِیہِ ، قَالَ : أَتَیْتُ عُمَرَ وَہُوَ یُصَلِّی ، فَقُمْتُ عَنْ شِمَالِہِ ، فَجَعَلَنِی عَنْ یَمِینِہِ۔",,,4963
4964,"حَدَّثَنَا مُحَمَّدُ بْنُ أَبِی عَدِیٍّ ، عَنْ حُمَیْدٍ ، عَنْ ثَابِتٍ ، عَنْ أَنَسٍ ، قَالَ : صَلَّیْتُ مَعَہُ فَأَقَامَنِی عَنْ یَمِینِہِ۔",,,4964
4965,حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَر ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ قَامَ رَجُلٌ یُصَلِّی عَنْ یَسَارِہِ ، فَحَوَّلَہُ عن یَمِینِہِ۔,,,4965
4966,"حَدَّثَنَا سَہْلُ بْنُ یُوسُفَ ، عَنِ ابْنِ عَوْنٍ ، عَنْ مُحَمَّدٍ ، قَالَ : کَانَ ابْنُ عَبَّاسٍ إذَا صَلَّی مَعَہُ رَجُلٌ ، أَقَامَہُ عَنْ یَمِینِہِ۔",,,4966
4967,حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ یَزِیدَ ، قَالَ ، دَخَلْتُ مَعَ مَکْحُولٍ مَسْجِدَ دِمَشْقَ وَقَدْ صَلَّی أَہْلُہُ ، فَأَقَامَنِی عَنْ یَمِینِہِ فَصَلَّیْتُ بِصَلاَتِہِ۔,,,4967
4968,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، قَالَ : یُقِیمُہُ عَنْ یَمِینِہِ۔",,,4968
4969,حَدَّثَنَا وَکِیعٌ ، عَنْ مَالِکِ بْنِ مِغْوَلٍ ، عَنِ الشَّعْبِیِّ ؛ أَنَّہُ کَانَ إذَا قَامَ مَعَہُ رَجُلٌ ، أَقَامَہُ عَنْ یَمِینِہِ۔,,,4969
4970,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، قَالَ : جِئْتُ إلی عُرْوَۃَ وَہُوَ یُصَلِّی ، فَأَقَامَنِی عَنْ یَمِینِہِ۔",,,4970
4971,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، قَالَ : سَأَلْتُ عَنْہُ سَعِیدَ بْنَ الْمُسَیَّبِ ، فَقَالَ : یُقِیمُہُ عَنْ یَسَارِہِ۔",,,4971
4972,"حَدَّثَنَا مُحَمَّدُ بْنُ فُضَیْلٍ ، عَنْ ہَارُونَ بْنِ عَنْتَرَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، قَالَ : اسْتَأْذَنَ عَلْقَمَۃُ وَالأَسْوَدُ عَلَی عَبْدِ اللہِ فَأَذِنَ لَہُمَا ، وَقَالَ : إِنَّہُ سَیَکُونُ أُمَرَائُ یَشْغَلُونَ عَنْ وَقْتِ الصَّلاَۃ ، فَصَلُّوہَا لِوَقْتِہَا ، ثُمَّ قَامَ فصلی بَیْنِی وَبَیْنَہُ ، وَقَالَ : ہَکَذَا رَأَیْت رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ فَعَلَ۔",,,4972
4973,حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ ہَارُونَ بْنِ عَنْتَرَۃَ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ الأَسْوَدِ ، عَنْ عَلْقَمَۃَ ، وَالأَسْوَدِ ، عَنْ عَبْدِ اللہِ ؛ رَفَعَہُ ، مِثْلَہُ۔,,,4973
4974,"حَدَّثَنَا وَکِیعٌ ، عَنْ سُفْیَانَ ، عَنْ حَمَّادٍ ، عَنْ إبْرَاہِیمَ ، عَنِ ابْنِ عُمَرَ ، أَنَّہُ قَالَ : إذَا کَانُوا ثَلاَثَۃً تَقَدَّمَہُمْ أَحَدُہُمْ وَتَأَخَّرَ اثْنَانِ۔",,,4974
4975,حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ لَیْثٍ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ إذَا صَلَّی ثَالِثُ ثَلاَثَۃٍ جَعَلَ اثْنَیْنِ خَلْفَہُ۔,,,4975
4976,حَدَّثَنَا أَبُو مُعَاوِیَۃَ ، عَنْ ہِشَامِ بْنِ عُرْوَۃَ ، عَنْ أَبِیہِ ؛ أَنَّہُ کَانَ إذَا صَلَّی مَعَہُ الرَّجُلاَنِ خَلَفَہُمَا خَلْفَہُ۔,,,4976
4977,"حَدَّثَنَا جَرِیرٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ، قَالَ : إذَا کَانُوا ثَلاَثَۃً تَقَدَّمَہُمْ أَحَدُہُمْ۔",,,4977
4978,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ زَکَرِیَّا ، عَنْ عَامِرٍ ، قَالَ : إذَا کَانَ الْقَوْمُ ثَلاَثَۃً سِوَی الإِمَام ، تَقَدَّمَہُمْ أَحَدُہُمْ۔",,,4978
4979,"حَدَّثَنَا یَحْیَی بْنُ یَعْلَی ، عَنْ عُثْمَانَ بْنِ الأَسْوَدِ ، قَالَ : صَلَّیْتُ أَنَا وَرَجُلٌ مَعَ مُجَاہِدٍ ، فَأَقَامَ أَحَدَنَا عَنْ یَمِینِہِ ، وَالآَخَر عَنْ یَسَارِہِ ، وَقَالَ : ہَکَذَا یَصْنَعُ الثَّلاَثَۃُ۔",,,4979
4980,"حَدَّثَنَا ابن عُیَیْنَۃُ ، عَنِ الزُّہْرِیِّ ، عَنْ عُبَیْدِ اللہِ ، عَنْ أَبِیہِ ، قَالَ : أَتَیْتُ عُمَرَ وَہُوَ یُصَلِّی بِالْہَاجِرَۃِ ، فَقُمْت عَنْ شِمَالِہِ فَجَعَلَنِی عَنْ یَمِینِہِ ، فَجَائَ یَرْفَأ فَتَأَخَّرْنَا فصرنا اثْنَیْنِ خَلْفَہُ۔",,,4980
4981,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أَنَسٍ (ح) وَعَنْ سَعِیدِ بْنِ الْمُسَیَّبِ ، وَالْحَسَنِ ، قَالُوا : إذَا کَانُوا ثَلاَثَۃً تَقَدَّمَہُمْ أَحَدُہُمْ وَصَلَّی اثْنَانِ خَلْفَہُ۔",,,4981
4982,"حَدَّثَنَا أَبُو خَالِدٍ الأَحْمَرِِ ، عَنْ یَحْیَی بْنِ سَعِیدٍ ، عَنْ عُبَیْدِ اللہِ بْنِ عَبْدِ اللہِ ، عَنْ أَبِیہِ ، قَالَ : جِئْت إلَی عُمَرَ وَہُوَ یُصَلِّی فَجَعَلَنِی عَنْ یَمِینِہِ ، فَجَائَ یَرْفَأُ فَجَعَلَنَا خَلْفَہُ۔",,,4982
4983,"حَدَّثَنَا أَبُو نُعَیْمٍ ، قَالَ: حدَّثَنَا نُصَیْرُ بْنُ أَبِی الأَشْعَثِ ، عَنْ حَمَّادِ بْنِ خُوَارٍ ، عَنْ عَبْدِ الْمَلِکِ بْنِ مَیْسَرَۃَ، عَنِ النَّزَّالِ بْنِ سَبْرَۃَ ، عَنْ عَلِیٍّ ، قَالَ : إذَا کَانُوا ثَلاَثَۃً تَقَدَّمَہم أَحَدُہُمْ۔",,,4983
4984,حَدَّثَنَا أَبُو دَاوُدَ الطَّیَالِسِیُّ ، عَنْ شُعْبَۃَ ، عَنْ عَبْدِ اللہِ بْنِ الْمُخْتَارِ ، عَنْ مُوسَی بْنِ أَنَسٍ ، عَنْ أَنَسٍ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ صَلَّی بِہِمْ وَامْرَأَۃٍ مِنْ أَہْلِہِ ، فَجَعَلَ أَنَسًا عَنْ یَمِینِہِ وَالْمَرْأَۃَ خَلْفَہُ۔,,,4984
4985,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ حُمَیْدٍ، عَنْ ثَابِتٍ، قَالَ: صَلَّیْتُ مَعَ أَنَسٍ فَقُمْتُ عَنْ یَمِینِہِ ، وَقَامَتْ أُمُّ وَلَدِہِ خَلْفَنَا۔",,,4985
4986,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، قَالَ : جِئْت إلَی عُرْوَۃَ وَہُوَ یُصَلِّی وَخَلْفَہُ امْرَأَۃٌ ، فَأَقَامَنِی عَنْ یَمِینِہِ وَالْمَرْأَۃَ خَلْفَہُ۔",,,4986
4987,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ ، قَالَ : إذَا کَانَ الإِمَام مَعَہُ رَجُلٌ وَاحِدٌ وَامْرَأَۃٌ ، فَلْیَقُومُوا مُتَوَاتِرَیْنِ۔",,,4987
4988,حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عَمَّارٍ الدُّہْنِیِّ ، عَنِ امْرَأَۃٍ مِنْ قَوْمِہِ اسْمُہَا حُجَیْرَۃُ ، قَالَتْ أَمَّتْنَا أُمُّ سَلَمَۃَ قَائِمَۃً وَسَطَ النِّسَائِ۔,,,4988
4989,حَدَّثَنَا عَلِیُّ بْنُ مُسْہِرٍ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ أُمِّ الْحَسَنِ ؛ أَنَّہَا رَأَتْ أُمَّ سَلَمَۃَ زَوْجَ النَّبِیِّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ تَؤُمُّ النِّسَائَ ، تَقُومُ مَعَہُنَّ فِی صَفِّہِنَّ۔,,,4989
4990,حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ تَؤُمُّ النِّسَائَ فِی الْفَرِیضَۃِ۔,,,4990
4991,حَدَّثَنَا عَلِیُّ بْنُ ہَاشِمٍ ، عَنِ ابْنِ أَبِی لَیْلَی ، عَنْ عَطَائٍ ، عَنْ عَائِشَۃَ ؛ أَنَّہَا کَانَتْ تَؤُمُّ النِّسَائَ ، تقوم مَعَہُنَّ فِی الصَّفِّ۔,,,4991
4992,"حَدَّثَنَا ہُشَیْمٌ ، قَالَ : أَخْبَرَنَا یُونُسُ ، عَنِ الْحَسَنِ (ح) وَمُغِیرَۃُ ، عَنْ إبْرَاہِیمَ (ح) وَحُصَیْنٌ ، عَنِ الشَّعْبِیِّ ، قَالَ : تَؤُمُّ الْمَرْأَۃُ النِّسَائَ فِی صَلاَۃِ رَمَضَانَ ، تَقُومُ مَعَہُنَّ فِی صَفِّہِنَّ۔",,,4992
4993,"حَدَّثَنَا ابْنُ نُمَیْرٍ ، عَنْ حُرَیْثٍ ، عَنْ حُمَیْدِ بْنِ عَبْدِ الرَّحْمَنِ ، أَنَّہُ قَالَ : لاَ بَأْسَ أَنْ تَؤُمَّ الْمَرْأَۃُ النِّسَائَ ، تَقُومُ مَعَہُنَّ فِی الصَّفِّ۔",,,4993
4994,"حَدَّثَنَا وَکِیعٌ ، عَنِ ابْنِ أَبِی ذِئْبٍ ، عَنْ مَوْلًی لِبَنِی ہَاشِمٍ ، عَنْ عَلِیٍّ ، قَالَ : لاَ تَؤُمُّ الْمَرْأَۃُ۔",,,4994
4995,"حَدَّثَنَا عَبْدُ الْوَہَّابِ بْنُ عَطَائٍ ، عَنِ ابْنِ عَوْنٍ ، قَالَ : کَتَبْتُ إلَی نَافِعٍ أَسْأَلُہُ ، أَتَؤُمُّ الْمَرْأَۃُ النِّسَائَ ؟ فَقَالَ: لاَ أَعْلَمُ الْمَرْأَۃَ تَؤُمُّ النِّسَائَ۔",,,4995
4996,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عمرو ، قَالَ : أَخْبَرَنِی مَنْ رَأَی جَابِرَ بْنَ زَیْدٍ یُومِیئُ فِی مَایئٍ وَطِینٍ۔",,,4996
4997,"حَدَّثَنَا حَفْصٌ ، عَنْ لَیْثٍ ، عَنْ طَاوُوسٍ ، قَالَ : إذَا کَانَ فِی مَائٍ وَطِینٍ أَوْمَأَ إیمَائً۔",,,4997
4998,"حَدَّثَنَا ابْنُ فُضَیْلٍ ، عَنْ حُصَیْنٍ ، عَنْ عَامِرٍ ، قَالَ : الَّذِی فِی الْمَائِ وَالطِّینِ یُومِئُ إیمَائً۔",,,4998
4999,"حَدَّثَنَا أَبُو بَکْرِ بْنُ عَیَّاشٍ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ، قَالَ: إذَا کُنْتَ فِی مَائٍ ، أَوْ سَبْخَۃٍ ، فَأَوْمِیئْ إیمَائً۔",,,4999
5000,"حَدَّثَنَا عَبْدَۃُ ، عَنْ سَعِیدٍ ، عَنْ قَتَادَۃَ ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ فِی الرَّجُلِ تُدْرِکُہُ الصَّلاَۃ فِی الْمَائِ وَالطِّینِ ، قَالَ : یُومِیئُ إیمَائً ، وَیَجْعَلُ السُّجُودَ أَخْفَضَ مِنَ الرُّکُوعِ۔",,,5000
5001,"حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ ہِشَامٍ الدَّسْتَوَائِیِّ ، عَنْ یَحْیَی بْنِ أَبِی کَثِیرٍ ، عَنْ أَبِی سَلَمَۃَ ، عَنْ أَبِی سَعِیدٍ الْخُدْرِیِّ، قَالَ: رَأَیْتُ رَسُولَ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ یَسْجُدُ فِی الْمَائِ وَالطِّینِ۔ (بخاری 669۔ مسلم 826)",,,5001
5002,"حَدَّثَنَا أَبُو أُسَامَۃَ ، عَنْ ہِشَامٍ ، عَنْ أَنَسِ بْنِ سِیرِینَ ، قَالَ : أَقْبَلْت مَعَ أَنَسِ بْنِ مَالِکٍ مِنَ الْکُوفَۃِ ، حَتَّی إذَا کُنَّا بِأَطَطٍ وَقَدْ أَخَذَتْنَا السَّمَائُ قَبْلَ ذَلِکَ ، وَالأَرْضُ ضَحْضَاحٌ ، فَصَلَّی أَنَسٌ وَہُوَ عَلَی حِمَارٍ مُسْتَقْبِلَ الْقِبْلَۃِ ، وَأَوْمَأَ إیمَائً ، وَجَعَلَ السُّجُودَ أَخْفَضَ مِنَ الرُّکُوعِ۔",,,5002
5003,"حَدَّثَنَا إسْمَاعِیلُ بْنُ عَیَّاشٍ ، عَنْ عَبْدِ الْعَزِیزِ بْنِ عُبَیْدِ اللہِ ، عَنْ سَالِمٍ ، وَعَامِرٍ ، قَالاَ : إذَا کُنْتَ فِی مَائٍ وَطِینٍ لاَ تَجِدُ مَکَانًا تَسْجُدُ عَلَیْہِ ، فَأَوْمِیئْ بِرَأْسِکَ إیمَائً۔",,,5003
5004,"حَدَّثَنَا وَکِیعٌ ، عَنْ جَرِیرِ بْنِ حَازِمٍ ، عَنْ غَالِبِ بْنِ سُلَیْمَانَ ، عَنْ رَجُلٍ مِنْ حُدَّان ، عَنْ جَابِرِ بْنِ زَیْدٍ ؛ أَنَّہُ وَقَعَ فِی مَائٍ وَطِینٍ فَجَعَلَ یَرْکَعُ ، فَإِذَا أَرَادَ أَنْ یَسْجُدَ أَوْمَأَ ، فَقُلْتُ لَہُ ؟ فَقَالَ : یَا أَحْمَقُ ، أَتُرِیدُ أَنْ أُفْسِدَ ثِیَابِی؟",,,5004
5005,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ مَعْمَرٍ ، عَنْ یَحْیَی ، عَنْ ضَمْضَمٍ ، عَنْ أَبِی ہُرَیْرَۃَ ؛ أَنَّ النَّبِیَّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَمَرَ بِقَتْلِ الأَسْوَدَیْنِ فِی الصَّلاَۃ ، الْحَیَّۃِ وَالْعَقْرَبِ۔ (ابن ماجہ 1245۔ احمد 2/248),,,5005
5006,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ بُرْدٍ ، عَنْ سُلَیْمَانَ بْنِ مُوسَی ، قَالَ : رَأَی نَبِیُّ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ رَجُلاً یُصَلِّی جَالِسًا ، فَقَالَ النَّبِیُّ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ : لِمَ تُصَلِّی جَالِسًا ؟ فَقَالَ : إنَّ عَقْرَبًا لَسَعَتْنِی ، قَالَ : فَإِذَا رَأَی أَحَدُکُمْ عَقْرَبًا ، وَإِنْ کَانَ فِی الصَّلاَۃ ، فَلْیَأْخُذْ نَعْلَہُ الْیُسْرَی ، فَلْیَقْتُلْہَا بِہَا۔",,,5006
5007,حَدَّثَنَا حُمَیْدُ بْنُ عَبْدِ الرَّحْمَنِ ، عَنْ حَسَنٍ ، عَنِ ابْنِ أَبِی لَیْلَی ؛ أَنَّ عَلِیًّا قَتَلَہَا وَہُوَ فِی الصَّلاَۃ۔,,,5007
5008,حَدَّثَنَا ابْنُ عُیَیْنَۃَ ، عَنْ عَبْدِ اللہِ بْنِ دِینَارٍ ؛ رَأَی ابْنُ عُمَرَ رِیشَۃً وَہُوَ یُصَلِّی ، فَحَسِبَ أَنَّہَا عَقْرَبٌ ، فَضَرَبَہَا بِنَعْلِہِ۔,,,5008
5009,حَدَّثَنَا ابْنُ عُلَیَّۃَ ، عَنْ شعبۃ ، عَنْ أَبِی الْعَالِیَۃِ ؛ أَنَّہُ قَتَلَہَا وَہُوَ یُصَلِّی۔,,,5009
5010,حَدَّثَنَا ہُشَیْمٌ ، عَنْ یُونُسَ ، عَنِ الْحَسَنِ ؛ أَنَّہُ کَانَ لاَ یَرَی بَأْسًا بِقَتْلِہَا وَہُوَ فِی الصَّلاَۃ۔,,,5010
5011,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ سَلْم بْنِ أَبِی الذَّیَّالِ ، عَنِ الْحَسَنِ ، قَالَ : یَقْتُلُہَا وَہُوَ یُصَلِّی ، قَالَ : وَقَالَ قَتَادَۃُ : إذَا لَمْ تَعْرِضْ لَکَ فَلاَ تَقْتُلْہَا۔",,,5011
5012,"حَدَّثَنَا عَبَّادٌ ، عَنْ حَجَّاجٍ ، عَنْ عَطَائٍ ، قَالَ : اقْتُلْہَا وَأَنْتَ فِی الصَّلاَۃِ۔",,,5012
5013,"حَدَّثَنَا عَبَّادُ بْنُ الْعَوَّامِ ، عَنْ حَجَّاجٍ ، عَنْ فُضَیْلٍ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ قَالَ فِی الْعَقْرَبِ یَرَاہَا الرَّجُلُ فِی الصَّلاَۃ ، قَالَ : اصْرِفْہَا عَنْک ، قُلْتُ : فَإِنْ أَبَتْ ؟ قَالَ : اصْرِفْہَا عَنْک ، قُلْتُ : فَإِنْ أَبَتْ ؟ قَالَ : فَاقْتُلْہَا ، وَاغْسِلْ مَکَانَہَا الَّذِی قَتَلْتہَا فِیہِ۔",,,5013
5014,حَدَّثَنَا الْفَضْلُ بْنُ دُکَیْنٍ ، عَنْ حَمَّادِ بْنِ سَلَمَۃَ ، عَنْ قَتَادَۃَ ؛ أَنَّ مُوَرِّقًا قَتَلَہَا وَہُوَ یُصَلِّی۔,,,5014
5015,"حَدَّثَنَا ہُشَیْمٌ ، عَنْ مُغِیرَۃَ ، عَنْ إبْرَاہِیمَ ؛ أَنَّہُ سُئِلَ عَنْ قَتْلِ الْعَقْرَبِ فِی الصَّلاَۃ ؟ فَقَالَ : إنَّ فِی الصَّلاَۃ لَشُغْلاً۔",,,5015
5016,"حَدَّثَنَا وَکِیعٌ ، عَنْ عَبْدِ الْحَمِیدِ بْنِ جَعْفَرٍ ، عَنْ أَبِیہِ ، عَنْ تَمِیمِ بْنِ مَحْمُودٍ ، عَنْ عَبْدِ الرَّحْمَنِ بْنِ شِبْلٍ ، قَالَ : نَہَی رَسُولُ اللہِ صَلَّی اللَّہُ عَلَیْہِ وَسَلَّمَ أَنْ یُوَطِّنَ الرَّجُلُ الْمَکَانَ یُصَلِّی فِیہِ کَمَا یُوَطِّنُ الْبَعِیرُ۔",,,5016
5017,حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ الْقَطَّانُ ، عَنْ عُبَیْدِ اللہِ بْنِ عُمَرَ ، عَنْ نَافِعٍ ، عَنِ ابْنِ عُمَرَ ؛ أَنَّہُ کَانَ لاَ یَتَّخِذُ فِی بَیْتِہِ مَکَانًا یُصَلِّی فِیہِ۔,,,5017
5018,"حَدَّثَنَا یَحْیَی بْنُ سَعِیدٍ ، عَنْ عُمَرَ بْنِ نَبِیہٍ ، عَنْ جُمْہَانَ ، قَالَ : رَأَیْتُ سَعْدًا جَائَ مِرَارًا وَالنَّاسُ فِی الصَّلاَۃ ، فَمَشَی بَیْنَ الصَّفِّ وَالْجِدَارِ حَتَّی انْتَہَی إلَی مُصَلاَّہُ ، وَکَانَ یُصَلِّی عِنْدَ الاسْطُوَانَۃِ الْخَامِسَۃِ۔",,,5018
5019,"حَدَّثَنَا سُفْیَانُ بْنُ عُیَیْنَۃَ ، عَنْ عُبَیْدِ اللہِ بْنِ أَبِی یَزِیدَ ، قَالَ : رَأَیْتُ الْمِسْوَرَ بْنَ مَخْرَمَۃَ بَعْدَ مَا تُقَامُ الصَّلاَۃُ یَتَخَلَّلُ الصُّفُوفَ حَتَّی یَنْتَہِیَ إلَی الثَّانِی ، أَوِ الأَوَّلِ۔",,,5019
5020,"حَدَّثَنَا مَعْنُ بْنُ عِیسَی ، عَنْ مُحَمَّدِ بْنِ صَالِحٍ التَّمَّارِ ، قَالَ : رَأَیْتُ الْقَاسِمَ بْنَ مُحَمَّدٍ یَلْزَمُ مُصَلًّی وَاحِدًا فِی الْمَسْجِدِ یُصَلِّی فِیہِ ، وَلاَ یُصَلِّی فِی غَیْرِہِ ، وَرَأَیْت سَعِیدَ بْنَ الْمُسَیَّبِ یَفْعَلُ ذَلِکَ۔",,,5020
5021,"حَدَّثَنَا حَفْصُ بْنُ غِیَاثٍ ، عَنِ ابْنِ جُرَیْجٍ ، عَنْ عَطَائٍ ؛ سُئِلَ عَنْ قَوْمٍ انْکَسَرَتْ بِہِمْ سَفِینَتُہُمْ ، فَأَدْرَکَتْہُمُ الصَّلاَۃ وَہُمْ فِی الْمَائِ ؟ قَالَ : یُومِئُونَ إِیمَائً ، فَإِنْ خَرَجُوا عُرَاۃً ؟ قَالَ : یُصَلُّونَ قُعُودًا۔",,,5021
5022,"حَدَّثَنَا عِیسَی بْنُ یُونُسَ ، عَنِ الأَوْزَاعِیِّ ، عَنْ وَاصِلٍ ، عَنْ مُجَاہِدٍ ؛ أَنَّ عُمَرَ بْنَ عَبْدِ الْعَزِیزِ سَأَلَہُ عَنْ قَوْمٍ انْکَسَرَتْ بِہِمْ سَفِینَتُہُمْ ، فَخَرَجُوا ، فَحَضَرَتِ الصَّلاَۃُ ؟ فَقَالَ : یَکُونُ إِمَامُہُمْ مَیْسَرَتَہُمْ ، وَیَصُفُّونَ صَفًّا وَاحِدًا ، وَیَسْتَتِرُ کُلُّ رَجُلٍ مِنْہُمْ بِیَدِہِ الْیُسْرَی عَلَی فَرْجِہِ مِنْ غَیْرِ أَنْ یَمَسَّ الْفَرْجَ۔",,,5022
5023,"حَدَّثَنَا یَزِیدُ بْنُ ہَارُونَ ، عَنْ ہِشَامٍ ، عَنِ الْحَسَنِ ؛ فِی الْقَوْمِ تَنْکَسِرُ بِہِمُ السَّفِینَۃُ فَیَخْرُجُونَ عُرَاۃً ، کَیْفَ یُصَلُّونَ ؟ قَالَ : جُلُوسًا ، وَإِمَامُہُمْ وَسَطُہُمْ ، وَیَسْجُدُونَ وَیَغُضُّونَ أَبْصَارَہُمْ۔",,,5023
5024,"حَدَّثَنَا وَکِیعٌ ، عَنْ إِبْرَاہِیمَ بْنِ یَزِیدَ ، عَنْ عَطَائٍ ؛ فِی الْعُرَاۃِ ، قَالَ : یُصَلُّونَ قُعُودًا ، یُومِئُونَ إِیمَائً ، یَقُومُ إِمَامُہُمْ وَسَطَہُمْ۔",,,5024
5025,"حَدَّثَنَا مُعْتَمِرٌ ، عَنْ حُمْرَانَ ، عَنِ الْحَسَنِ ، قَالَ : الْغَرِیقُ یَسْجُدُ عَلَی مَتْنِ الْمَائِ۔",,,5025
