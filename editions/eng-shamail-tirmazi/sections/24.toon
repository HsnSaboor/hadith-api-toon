metadata:
  section_id: 24
  section_name: رسول اللہ صلی اللہ علیہ وسلم کا کسی کے سہارے ٹیک لگانا
  hadith_first: 131
  hadith_last: 132

hadiths[2]{hadithnumber,text,grades,reference,international_number,narrator_chain,chapter_intro}:
131,"""Allah’s Messenger said (Allah bless him and give him peace):‘As for me, I do not eat while leaning on a support!’”",,,131,"Abu Juhaifa said:",رسول اللہ صلی اللہ علیہ وسلم کا کسی کے سہارے ٹیک لگانا
132,"""Allah’s Messenger said (Allah bless him and give him peace): 'I do not eat while leaning on a support! I do not eat while leaning on a support'!”",,,132,"Abu Juhaifa said:",رسول اللہ صلی اللہ علیہ وسلم کا کسی کے سہارے ٹیک لگانا
