{"hadithnumber": "938", "text": "زید بن اسلم رحمہ اللہ سے روایت ہے کہ بے شک ایک آدمی حضرت عمر بن خطاب رضی اللہ عنہ کے پاس آیا ، پھر ک"}
{"hadithnumber": "939", "text": "یحیی بن سعید رحمہ اللہ سے روایت ہے کہ ایک آدمی حضرت عمر بن خطاب رضی اللہ عنہ کی طرف آیا ، اس نے ان س"}
{"hadithnumber": "940", "text": "حضرت کعب بن عُجرہ رضی اللہ عنہ سے روایت ہے کہ بے شک وہ حالت احرام میں رسول اللہ ﷺ کے ہمراہ تھے ، جوو"}
{"hadithnumber": "941", "text": "حضرت کعب بن عجرہ رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے اُن سے فرمایا :’’ شاید تمھیں تمھار"}
{"hadithnumber": "942", "text": "عطاء بن عبداللہ خراسانی رحمہ اللہ سے روایت ہے ، کہتے ہیں کہ مجھے کوفہ میں ہانڈیوں کے بازار میں ایک ش"}
{"hadithnumber": "943", "text": "سعید بن جبیر رحمہ اللہ سے روایت ہے کہ بے شک حضرت عبداللہ بن عباس رضی اللہ عنہ نے فرمایا : جو شخص اپن"}
{"hadithnumber": "944", "text": "حضرت عبداللہ بن عمرو بن عاص رضی اللہ عنہ سے روایت ہے ، کہتے ہیں کہ رسول اللہ ﷺ حجۃ الوداع کے موقع پر"}
{"hadithnumber": "945", "text": "حضرت عبداللہ بن عمر رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ جب کسی غزوے یا حج یا عمرے سے لوٹتے"}
{"hadithnumber": "946", "text": "حضرت عبداللہ بن عباس رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ کا ایک عورت کے پاس سے گزر ہوا جو"}
{"hadithnumber": "947", "text": "طلحہ بن عبیداللہ بن کریز رحمہ اللہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ شیطان کسی بھی دن م"}
{"hadithnumber": "948", "text": "طلحہ بن عبیداللہ بن کریز رحمہ اللہ سے روایت ہے کہ بے شک رسول اللہ ﷺ نے فرمایا :’’ سب سے افضل دعا یوم"}
{"hadithnumber": "949", "text": "حضرت انس بن مالک رضی اللہ عنہ سے روایت ہے کہ بے شک رسول اللہ ﷺ فتح مکہ والے سال ( فتح مکہ کے موقع پر"}
{"hadithnumber": "950", "text": "نافع رحمہ اللہ سے روایت ہے کہ بے شک حضرت عبداللہ بن عمر رضی اللہ عنہ مکہ سے ( مدینہ کی طرف ) متوجہ ہ"}
{"hadithnumber": "952", "text": "محمد بن عمران انصاری رحمہ اللہ اپنے والد عمران رحمہ اللہ سے روایت کرتے ہیں ، انھوں نے کہا کہ حضرت عب"}
{"hadithnumber": "953", "text": "ابن بی ملیکہ سے روایت ہے کہ بے شک حضرت عمربن خطاب رضی اللہ عنہ کوڑھ کے مرض میں مبتلا ایک عورت کے پاس"}
{"hadithnumber": "954", "text": "امام مالک رحمہ اللہ کو یہ خبری پہنچی کہ بے شک حضرت عبداللہ بن عباس رضی اللہ عنہ فرمایا کرتے تھے کہ ر"}
{"hadithnumber": "955", "text": "محمد بن یحیی بن حبان رحمہ اللہ سے روایت ہے کہ بے شک ایک آدمی ’’ ربذہ ‘‘ مقام پر حضرت ابوذر رضی اللہ"}
{"hadithnumber": "956", "text": "امام مالک رحمہ اللہ نے ابن شہاب رحمہ اللہ سے حج میں استثناء یعنی شرط لگا لینے کے متعلق سوال کیا تو و"}
{"hadithnumber": "957", "text": "اُمّ المومنین سیدہ عائشہ رضی اللہ عنہا سے روایت ہے ، وہ کہا کرتی تھیں کہ جو شخص حج کے ساتھ عمرہ کو م"}
